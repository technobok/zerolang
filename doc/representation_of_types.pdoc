#~"ztypes.py" -- #~"ZType" dataclass (line 223):

#ul:
  [#*: Add #~"needs_field_cleanup: bool = field(default=False, init=False)".
  True when the type has owned fields requiring cleanup.]

#~"ztypecheck.py" -- #~"_set_destructor_metadata()" (line 170):

#ul:
  [#*: After existing metadata, scan children for fields whose types have
  #~"needs_destructor=True". If found, set #~"needs_field_cleanup=True".]

Testing: #~"make check && make test". All tests pass -- no behaviour change.



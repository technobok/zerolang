# Recursive-descent parser for zerolang, ported from src/zparser.py.
# This slice covers atoms (identifiers, dotted paths, string literals)
# and the operations/calls layer (binops and calls with positional and
# named arguments).
#
# Public productions return (Option t: Node): none means "nothing here"
# (the caller tries another production), some carrying an `error` arm
# means "committed but malformed". Internally the parse helpers return a
# bare Node and the leading token is checked first (atomLookahead),
# because a reftype payload cannot be moved back out of an Option to
# build a parent node -- so an owned Node local is threaded through
# construction and wrapped in an Option only at the boundary. Node ids
# come from the parser's sequential counter, in parse order, mirroring
# the Python reference.

# Local alias for the cross-unit AST node union, for brevity at the many
# `Node.<arm>` / `(Option t: Node)` sites below.
Node: zast.Node

# StringChunk.chunkKind codes. Values match the Python TT enum
# (EOL=5, STRMID=21, STRCHR=22) so the eventual ast_nodes differential
# lines up; the zerolang TT variant''s auto-assigned tags differ, hence
# the explicit mapping.
chunkkind: data {
    eol: 5
    strmid: 21
    strchr: 22
} out u8

chunkKindOf: function {tt: zlexer.TT} out u8 is {
    match tt case STRMID then {
        return chunkkind.strmid
    } case STRCHR then {
        return chunkkind.strchr
    } case EOL then {
        return chunkkind.eol
    } else {
        return 0
    }
}

# True for the token types that contribute literal text to a string
# (a coalesced run, an escaped char, or an embedded newline).
isStrChunkTok: function {tt: zlexer.TT} out bool is {
    match tt case STRMID then {
        return true
    } case STRCHR then {
        return true
    } case EOL then {
        return true
    } else {
        return false
    }
}

# True if every byte of `sv` is a space or tab (matches the Python
# _is_ws_only; not `trim`, which also strips \n \r \f \v).
isWsOnlyView: function {sv: StringView} out bool is {
    n: sv.length
    i: 0.u64
    allWs: true
    for i < n loop {
        bOpt: sv.byteAt i
        match (
            bOpt
        ) case some then {
            isSp: bOpt == 32
            isTab: bOpt == 9
            if isSp then {
            } else if (isTab) == false then {
                allWs = false
            }
        } case none then {
        }
        i = i + 1
    }
    return allWs
}

# Classify a string part for the whitespace scans:
# 0 = not a stringchunk (interpolation) ; 1 = EOL ; 2 = STRMID ws-only ;
# 3 = STRMID has non-ws ; 4 = STRCHR ; 5 = other stringchunk kind.
partClass: function {n: Node} out i64 is {
    code: 0
    match (
        n
    ) case stringchunk then {
        k: n.chunkKind
        if k == chunkkind.eol then {
            code = 1
        } else if k == chunkkind.strmid then {
            ws: isWsOnlyView sv: n.text.stringview
            if ws then {
                code = 2
            } else {
                code = 3
            }
        } else if k == chunkkind.strchr then {
            code = 4
        } else {
            code = 5
        }
    } else {
    }
    return code
}

# True if Node `n` is a stringchunk whose text starts with `p`.
chunkStartsWith: function {n: Node p: StringView} out bool is {
    res: false
    match (
        n
    ) case stringchunk then {
        res = n.text.stringview.startsWith prefix: p
    } else {
    }
    return res
}

# True for the keyword token types that open an inline type definition
# (record / class / variant / union / protocol / facet / data). These are
# rejected inside an object body -- such a type must be defined at unit
# level and referenced by name.
isInlineTypedefTok: function {tt: zlexer.TT} out bool is {
    match tt case RECORD then {
        return true
    } case CLASS then {
        return true
    } case VARIANT then {
        return true
    } case UNION then {
        return true
    } case PROTOCOL then {
        return true
    } case FACET then {
        return true
    } case DATA then {
        return true
    } else {
        return false
    }
}

# Reverse a node list into a new list. The greedy operation list is
# built in source order but consumed front-to-back; List.pop yields the
# tail, so reversing once lets each pop yield the next source element.
# The input is drained (its elements move into the result).
reverseNodes: function {src: (List Node).take} out List Node is {
    output: (List Node)
    for src.length > 0 loop {
        output.append src.pop
    }
    return output
}

# True when byte `b` is NOT permitted at position `first?` of a unit name.
# Valid names start with a lowercase ascii letter, then lowercase letters,
# digits, or underscores (zlexer.isvalidunitname). Returns the negative so
# the scanner can early-return on the first bad byte.
unitNameCharBad: function {b: u8 first: bool} out bool is {
    if first then {
        if b >= 97 when b <= 122 then return false
        return true
    }
    if b >= 97 when b <= 122 then return false
    if b >= 48 when b <= 57 then return false
    if b == 95 then return false
    return true
}

# Port of zlexer.isvalidunitname: a unit (file) name is a lowercase ascii
# letter followed by lowercase letters, digits, or underscores. Used by
# parseUnitFile to reject malformed names and by collectExterns to keep
# only loadable references in the extern set.
isValidUnitName: function {name: StringView} out bool is {
    n: name.length
    if n == 0 then return false
    i: 0.u64
    for i < n loop {
        b: name.byteAt i
        match (
            b
        ) case some then {
            isFirst: i == 0
            bad: unitNameCharBad :b first: isFirst
            if bad then return false
        } case none then {
            return false
        }
        i = i + 1
    }
    return true
}

# FileSeg -- one parsed file's contiguous nodeid range [startId, endId) and
# its VFS fsno. Subunit loads nest child ranges inside the parent's; the
# innermost containing range wins (fsnoForNode).
FileSeg: class {
    startId: u32
    endId: u32
    fsno: u32
}

Parser: class {
    # Monotonic source-node id, assigned in parse order.
    nextNodeId: u32
    # Nesting depth of function bodies (reserved for later slices).
    functionBodyDepth: u32
    # Per-file nodeid segments: diagnostics map an erroring node back to
    # the file whose parse allocated it.
    fileSegs: (List FileSeg)
} as {
    create: function {} out this is {
        return (meta.create nextNodeId: 1 functionBodyDepth: 0 fileSegs: (List FileSeg))
    }

    # Allocate the next node id.
    nextId: function {:this} out u32 is {
        id: this.nextNodeId
        this.nextNodeId = this.nextNodeId + 1
        return id
    }

    # fsnoForNode -- the fsno of the file whose parse allocated `nodeid`:
    # the innermost containing segment (subunit ranges nest inside their
    # parent's, so the largest containing startId wins). 0 when no segment
    # contains it (synthesized nodes minted after parsing).
    fsnoForNode: function {:this nodeid: u32} out u32 is {
        best9: 0.u32
        bestStart9: 0.u32
        n9: this.fileSegs.length
        i9: 0.u64
        for i9 < n9 loop {
            sg9: this.fileSegs.get i: i9
            i9 = i9 + 1
            if sg9.startId <= nodeid when nodeid < sg9.endId then {
                if best9 == 0 then {
                    best9 = sg9.fsno
                    bestStart9 = sg9.startId
                } else {
                    if sg9.startId >= bestStart9 then {
                        best9 = sg9.fsno
                        bestStart9 = sg9.startId
                    }
                }
            }
        }
        return best9
    }

    # Build an error node located at `tok`.
    mkError: function {:this tok: zlexer.Token code: zast.err msg: String.take} out Node is {
        return (Node.error (zast.ErrorData
            nodeid: this.nextId
            lineno: tok.lineno
            colno: tok.colno
            width: tok.tokstr.length.u32
            err: code
            :msg
            fsno: tok.fsno
            note: "".string
            hint: "".string)
        )
    }

    # True when `node` is an `error` arm (propagate malformed sub-results).
    isError: function {node: Node} out bool is {
        match node case error then {
            return true
        } else {
            return false
        }
    }

    # True when `node` is an `atomid` arm (a binop operator must be one).
    isAtomId: function {node: Node} out bool is {
        match node case atomid then {
            return true
        } else {
            return false
        }
    }

    # True when `node` is an arm valid as a call's first unnamed argument.
    isOperationArm: function {node: Node} out bool is {
        match node case binop then {
            return true
        } case dottedpath then {
            return true
        } case atomid then {
            return true
        } case atomstring then {
            return true
        } case expression then {
            return true
        } case namedoperation then {
            return true
        } case labelvalue then {
            return true
        } else {
            return false
        }
    }

    # True when `tok` is a named-argument label (LABEL) or label shorthand
    # (LABELPRE), which forces a single-path operation to parse as a call.
    tokIsLabel: function {tok: zlexer.Token} out bool is {
        tt: tok.toktype
        match tt case LABEL then {
            return true
        } case LABELPRE then {
            return true
        } else {
            return false
        }
    }

    # Does an atom start at the current token? (PARENOPEN | REFID | STRBEG)
    atomLookahead: function {:this lex: zlexer.Lexer} out bool is {
        t: lex.peek
        match t.toktype case PARENOPEN then {
            return true
        } case REFID then {
            return true
        } case STRBEG then {
            return true
        } else {
            return false
        }
    }

    # parseAtom -> atomexpr | atomid | atomstring
    #
    # Dispatch on the leading token. Precondition: atomLookahead is true,
    # so the else arm is unreachable (guarded with an error node).
    parseAtom: function {:this lex: zlexer.Lexer} out Node is {
        t: lex.peek
        match t.toktype case PARENOPEN then {
            return (this.parseAtomExpr :lex)
        } case REFID then {
            return (this.parseAtomId :lex)
        } case STRBEG then {
            return (this.parseAtomString :lex)
        } else {
            return (this.mkError tok: t code: zast.err.BADREFERENCE msg: "Expected an atom".string)
        }
    }

    # parseAtomId -> id
    parseAtomId: function {:this lex: zlexer.Lexer} out Node is {
        r: lex.accept tt: zlexer.TT.REFID
        match r case some then {
            return (Node.atomid (zast.AtomIdData
                nodeid: this.nextId
                lineno: r.lineno
                colno: r.colno
                name: r.tokstr.copy)
            )
        } case none then {
            t: lex.peek
            return (this.mkError
                tok: t
                code: zast.err.BADREFERENCE
                msg: "Expected an identifier".string
            )
        }
    }

    # acceptAtom -> Option boundary over parseAtom.
    acceptAtom: function {:this lex: zlexer.Lexer} out Option Node is {
        la: this.atomLookahead :lex
        if la then {
            n: this.parseAtom :lex
            return (Option.some n)
        } else {
            return (Option.none Node)
        }
    }

    # path -> atom | ( path "." atomid )
    #
    # Bare-Node producer: an atom followed by zero or more `. id`
    # selectors, folded left into nested DottedPath nodes. Used by the
    # greedy operation-path collector, which appends owned nodes.
    parsePath: function {:this lex: zlexer.Lexer} out Node is {
        startTok: lex.peek
        sLine: startTok.lineno
        sCol: startTok.colno
        node: this.parseAtom :lex
        nIsErr: this.isError :node
        if nIsErr then return node
        nx: lex.peek
        nxIsDot: nx.toktype == zlexer.TT.DOT
        if nxIsDot then {
            return (this.parsePathTail :lex parent: node startLine: sLine startCol: sCol)
        }
        return node
    }

    # Consume `. id` selectors, nesting each into a DottedPath whose
    # parent is the path built so far. Recursion (rather than a loop
    # reassigning an outer-scope binding) keeps each owned `parent`
    # local to its call.
    parsePathTail: function {:this lex: zlexer.Lexer parent: Node.take startLine: u32 startCol: u32} out Node is {
        dotOpt: lex.accept tt: zlexer.TT.DOT
        match dotOpt case none then {
            return parent
        } case some then {
            idOpt: lex.accept tt: zlexer.TT.REFID
            match idOpt case some then {
                child: Node.atomid (zast.AtomIdData
                    nodeid: this.nextId
                    lineno: idOpt.lineno
                    colno: idOpt.colno
                    name: idOpt.tokstr.copy
                )
                np: Node.dottedpath (zast.DottedPathData
                    nodeid: this.nextId
                    lineno: startLine
                    colno: startCol
                    :parent
                    :child
                )
                return (this.parsePathTail :lex parent: np :startLine :startCol)
            } case none then {
                bad: lex.acceptAny
                err: (this.mkError
                    tok: bad
                    code: zast.err.BADPATH
                    msg: "Expected ID after dot".string
                )
                return err
            }
        }
    }

    # acceptPath -> Option boundary over parsePath.
    acceptPath: function {:this lex: zlexer.Lexer} out Option Node is {
        la: this.atomLookahead :lex
        if la then {
            return (Option.some (this.parsePath :lex))
        } else {
            return (Option.none Node)
        }
    }

    # atomexpr: filled in by the next stage.
    # atomexpr -> "(" expression ")". EOLs are filtered inside the parens
    # (a parenthesised expression may span lines). Returns the inner
    # Expression node (bare), or an error.
    parseAtomExpr: function {:this lex: zlexer.Lexer} out Node is {
        firstTok: lex.peek
        openOpt: lex.accept tt: zlexer.TT.PARENOPEN
        match openOpt case none then {
            return (this.mkError
                tok: firstTok
                code: zast.err.BADEXPRESSION
                msg: "Expected open parenthesis".string
            )
        } case some then {
            prevFilter: lex.filterEolState
            lex.setFilterEol enabled: true
            expr: this.parseExpression :lex
            isErr: this.isError node: expr
            if isErr then {
                lex.setFilterEol enabled: prevFilter
                return expr
            }
            lex.setFilterEol enabled: prevFilter
            closeOpt: lex.accept tt: zlexer.TT.PARENCLOSE
            match closeOpt case some then {
                return expr
            } case none then {
                bad: lex.peek
                return (this.mkError
                    tok: bad
                    code: zast.err.BADEXPRESSION
                    msg: "Expected closing parenthesis".string
                )
            }
        }
    }

    # atomstring -> "\"" { strmid | newline | strchr | strexpr } "\""
    #
    # Collect literal-text chunks; an embedded interpolation (STREXPRBEG)
    # is rejected for now because acceptExpression is stubbed. The
    # closing STREND must repeat the opening delimiter.
    parseAtomString: function {:this lex: zlexer.Lexer} out Node is {
        firstTok: lex.peek
        fLine: firstTok.lineno
        fCol: firstTok.colno
        fDelim: firstTok.tokstr.copy
        lex.advance
        parts: (List Node)
        for true loop {
            t: lex.peek
            tt: t.toktype
            if tt == zlexer.TT.STREND then {
                same: t.tokstr.stringview == fDelim.stringview
                if same then {
                    lex.advance
                    break
                } else {
                    return (this.mkError
                        tok: t
                        code: zast.err.BADSTRING
                        msg: "Unmatched string literal delimiter".string
                    )
                }
            } else if tt == zlexer.TT.STREXPRBEG then {
                lex.advance
                bt: lex.peek
                if bt.toktype != zlexer.TT.BRACEOPEN then {
                    return (this.mkError
                        tok: bt
                        code: zast.err.BADSTRING
                        msg: "Expected open brace after backslash in string interpolation".string
                    )
                }
                lex.advance
                eLook: this.exprLookahead :lex
                if eLook then {
                    expr: this.parseExpression :lex
                    eErr: this.isError node: expr
                    if eErr then return expr
                    parts.append expr
                    ct: lex.peek
                    if ct.toktype != zlexer.TT.BRACECLOSE then {
                        return (this.mkError
                            tok: ct
                            code: zast.err.BADSTRING
                            msg: "Expected close brace after interpolation expression".string
                        )
                    }
                    lex.advance
                } else {
                    bad: lex.peek
                    return (this.mkError
                        tok: bad
                        code: zast.err.BADEXPRESSION
                        msg: "Bad expression in string interpolation".string
                    )
                }
            } else if (isStrChunkTok :tt) then {
                ck: chunkKindOf :tt
                chunk: Node.stringchunk (zast.StringChunkData
                    nodeid: this.nextId
                    lineno: t.lineno
                    colno: t.colno
                    text: t.tokstr.copy
                    chunkKind: ck
                )
                parts.append chunk
                lex.advance
            } else {
                bad: lex.acceptAny
                return (this.mkError
                    tok: bad
                    code: zast.err.BADSTRING
                    msg: "Unexpected token in string literal".string
                )
            }
        }
        stripped: this.stripStringWhitespace :parts
        return (Node.atomstring (zast.AtomStringData
            nodeid: this.nextId
            lineno: fLine
            colno: fCol
            stringparts: stripped)
        )
    }

    # Apply the spec''s string newline/whitespace handling. PR-E sees
    # chunk-only inputs (interpolation is rejected above), and the
    # common case needs no rewriting, so this currently returns the
    # parts unchanged; the blank-line/common-prefix trimming lands in a
    # follow-up alongside interpolation.
    stripStringWhitespace: function {:this parts: (List Node).take} out List Node is {
        origLen: parts.length
        if origLen == 0 then return parts

        # Step 1: blank first line -> startIdx (first kept index).
        startIdx: 0.u64
        i: 0.u64
        stop1: false
        for i < origLen loop {
            if (stop1) == false then {
                el: parts.get :i
                c: partClass n: el
                if c == 1 then {
                    startIdx = i + 1
                    stop1 = true
                } else if c != 2 then {
                    stop1 = true
                }
            }
            i = i + 1
        }

        # Step 2: blank last line -> endIdx (exclusive) + common prefix.
        endIdx: origLen
        lastEol: false
        lastEolIdx: 0.u64
        j: origLen
        stop2: false
        for j > startIdx loop {
            if (stop2) == false then {
                j2: j - 1
                el: parts.get i: j2
                c: partClass n: el
                if c == 1 then {
                    lastEol = true
                    lastEolIdx = j2
                    stop2 = true
                } else if c != 2 then {
                    stop2 = true
                }
            }
            j = j - 1
        }

        prefix: "".string
        if lastEol then {
            m: lastEolIdx + 1
            for m < origLen loop {
                el: parts.get i: m
                match (
                    el
                ) case stringchunk then {
                    prefix.append el.text.stringview
                } else {
                }
                m = m + 1
            }
            endIdx = lastEolIdx
        }

        if startIdx >= endIdx then {
            emptyParts: (List Node)
            return emptyParts
        }

        prefixView: prefix.stringview
        prefixLen: prefixView.length
        needStrip: prefixLen > 0

        # Step 3 pre-check: every non-blank line-start STRMID must start
        # with the prefix, else stripping is abandoned.
        canStrip: true
        if needStrip then {
            atLineStart: true
            p: startIdx
            for p < endIdx loop {
                el: parts.get i: p
                c: partClass n: el
                if c == 1 then {
                    atLineStart = true
                } else if c == 0 then {
                    atLineStart = false
                } else {
                    if atLineStart then {
                        if c == 3 then {
                            sw: chunkStartsWith n: el p: prefixView
                            if (sw) == false then {
                                canStrip = false
                            }
                        }
                    }
                    atLineStart = false
                }
                p = p + 1
            }
        }

        doStrip: needStrip
        if (canStrip) == false then {
            doStrip = false
        }

        # Nothing trimmed and nothing to strip -> return unchanged.
        noTrim: startIdx == 0
        if endIdx != origLen then {
            noTrim = false
        }
        if noTrim then {
            if (doStrip) == false then {
                return parts
            }
        }

        # Rebuild: reverse-drain, then pop in original order with an index.
        rev: (List Node)
        for parts.length > 0 loop {
            rev.append parts.pop
        }
        result: (List Node)
        atLineStart2: true
        idx: 0.u64
        pfxLen32: prefixLen.u32
        for rev.length > 0 loop {
            el: rev.pop
            inRange: idx >= startIdx
            if idx >= endIdx then {
                inRange = false
            }
            if inRange then {
                action: 0
                ncNodeId: 0.u32
                ncLine: 0.u32
                ncCol: 0.u32
                ncText: "".string
                match (
                    el
                ) case stringchunk then {
                    kk: el.chunkKind
                    if kk == chunkkind.eol then {
                        atLineStart2 = true
                    } else if atLineStart2 then {
                        if kk == chunkkind.strmid then {
                            ws: isWsOnlyView sv: el.text.stringview
                            if (ws) == false then {
                                if doStrip then {
                                    sp: el.text.stringview.stripPrefix p: prefixView
                                    match (
                                        sp
                                    ) case some then {
                                        slen: sp.length
                                        if slen > 0 then {
                                            action = 2
                                            ncNodeId = el.nodeid
                                            ncLine = el.lineno
                                            ncCol = el.colno + pfxLen32
                                            ncText = sp.string
                                        } else {
                                            action = 1
                                        }
                                    } case none then {
                                    }
                                }
                            }
                        }
                        atLineStart2 = false
                    } else {
                        atLineStart2 = false
                    }
                } else {
                    atLineStart2 = false
                }
                if action == 0 then {
                    result.append el
                } else if action != 1 then {
                    result.append (Node.stringchunk (zast.StringChunkData
                        nodeid: ncNodeId
                        lineno: ncLine
                        colno: ncCol
                        text: ncText.take
                        chunkKind: chunkkind.strmid)
                    )
                }
            }
            idx = idx + 1
        }
        return result
    }

    # mkBinop / mkCall / mkNamedOp / mkLabelValue: id-allocating node
    # constructors for the operations layer. Children move in.
    mkBinop: function {:this lhs: Node.take operator: Node.take rhs: Node.take line: u32 col: u32} out Node is {
        return (Node.binop (zast.BinOpData
            nodeid: this.nextId
            lineno: line
            colno: col
            :lhs
            :operator
            :rhs)
        )
    }

    mkCall: function {:this callable: Node.take arguments: (List Node).take line: u32 col: u32} out Node is {
        return (Node.call (zast.CallData
            nodeid: this.nextId
            lineno: line
            colno: col
            :callable
            :arguments)
        )
    }

    mkNamedOp: function {:this name: (Option String).take operation: Node.take line: u32 col: u32} out Node is {
        return (Node.namedoperation (zast.NamedOperationData
            nodeid: this.nextId
            lineno: line
            colno: col
            :name
            :operation)
        )
    }

    mkLabelValue: function {:this line: u32 col: u32 name: String.take} out Node is {
        return (Node.labelvalue (zast.LabelValueData
            nodeid: this.nextId
            lineno: line
            colno: col
            :name)
        )
    }

    # Greedily collect operand/operator paths in source order. Stops at
    # the first non-atom token. A malformed path is appended as a
    # trailing error arm (callers pop and check the tail before
    # dispatching on the count).
    operationPaths: function {:this lex: zlexer.Lexer} out List Node is {
        paths: (List Node)
        for (this.atomLookahead :lex) loop {
            node: this.parsePath :lex
            errored: this.isError :node
            paths.append node
            if errored then break
        }
        return paths
    }

    # Fold a reversed operand/operator stack (pop yields source order)
    # into a left-associative, flat-precedence binop chain. The stack
    # must be non-empty. The whole chain is positioned at its first
    # operand, matching the reference.
    foldStack: function {:this stack: (List Node).take nextTok: zlexer.Token} out Node is {
        acc: stack.pop
        sp: zast.posOf n: acc
        return (this.foldBinopTail :stack :acc line: sp.line col: sp.col :nextTok)
    }

    foldBinopTail: function {:this stack: (List Node).take acc: Node.take line: u32 col: u32 nextTok: zlexer.Token} out Node is {
        if stack.length == 0 then return acc
        op: stack.pop
        opOk: this.isAtomId node: op
        if opOk then {
            if stack.length == 0 then {
                return (this.mkError
                    tok: nextTok
                    code: zast.err.BADEXPRESSION
                    msg: "Expected an operand for the right hand side of operation".string
                )
            }
            rhs: stack.pop
            nb: this.mkBinop lhs: acc operator: op :rhs :line :col
            return (this.foldBinopTail :stack acc: nb :line :col :nextTok)
        } else {
            return (this.mkError
                tok: nextTok
                code: zast.err.BADEXPRESSION
                msg: "Expected an operator (single identifier)".string
            )
        }
    }

    # Fold a source-order path list into a binop chain (reverse, then
    # drain). A single path returns itself.
    foldBinop: function {:this paths: (List Node).take nextTok: zlexer.Token} out Node is {
        stack: this.reverseStack src: paths
        return (this.foldStack :stack :nextTok)
    }

    # reverseNodes wrapper as a method, for `this.`-prefixed calls.
    reverseStack: function {src: (List Node).take} out List Node is {
        return (reverseNodes :src)
    }

    # ( term binop ) form: callable + one unnamed folded argument, with
    # NO named arguments. Distinct from acceptCall (which consumes named
    # args); used for grammar operations like `abs -5`.
    acceptTermBinopCall: function {:this paths: (List Node).take lex: zlexer.Lexer} out Node is {
        stack: this.reverseStack src: paths
        callable: stack.pop
        cp: zast.posOf n: callable
        args: (List Node)
        if stack.length > 0 then {
            argNode: this.foldStack :stack nextTok: lex.peek
            argIsErr: this.isError node: argNode
            if argIsErr then return argNode
            ap: zast.posOf n: argNode
            uarg: (this.mkNamedOp
                name: (Option.none String)
                operation: argNode
                line: ap.line
                col: ap.col
            )
            args.append uarg
        }
        return (this.mkCall :callable arguments: args line: cp.line col: cp.col)
    }

    # call = callable path + arguments. The first unnamed argument is the
    # remaining paths folded as a binop; then zero or more named
    # arguments (LABEL -> operation value; LABELPRE -> label shorthand).
    acceptCall: function {:this lex: zlexer.Lexer paths: (List Node).take} out Node is {
        stack: this.reverseStack src: paths
        callable: stack.pop
        cp: zast.posOf n: callable
        args: (List Node)
        if stack.length > 0 then {
            argNode: this.foldStack :stack nextTok: lex.peek
            argIsErr: this.isError node: argNode
            if argIsErr then return argNode
            argIsOp: this.isOperationArm node: argNode
            if argIsOp then {
                ap: zast.posOf n: argNode
                uarg: (this.mkNamedOp
                    name: (Option.none String)
                    operation: argNode
                    line: ap.line
                    col: ap.col
                )
                args.append uarg
            }
        }
        argNames: (List String)
        for true loop {
            lblOpt: lex.accept tt: zlexer.TT.LABEL
            match lblOpt case some then {
                nm: lblOpt.tokstr.copy
                noName: lblOpt.tokstr.copy
                vLine: lblOpt.lineno
                vCol: lblOpt.colno
                dup: argNames.contains item: nm
                if dup then {
                    bad: lex.acceptAny
                    return (this.mkError
                        tok: bad
                        code: zast.err.BADARGUMENT
                        msg: "Duplicate argument name".string
                    )
                }
                vpaths: this.operationPaths :lex
                vlen: vpaths.length
                if vlen == 0 then {
                    bad: lex.acceptAny
                    return (this.mkError
                        tok: bad
                        code: zast.err.BADARGUMENT
                        msg: "Expected an Operation after label".string
                    )
                }
                val: this.operationFromPaths paths: vpaths :lex
                vIsErr: this.isError node: val
                if vIsErr then return val
                no: this.mkNamedOp name: (Option.some noName) operation: val line: vLine col: vCol
                args.append no
                argNames.append nm
            } case none then {
                lblOpt2: lex.accept tt: zlexer.TT.LABELPRE
                match lblOpt2 case some then {
                    nm: lblOpt2.tokstr.copy
                    lvName: lblOpt2.tokstr.copy
                    noName: lblOpt2.tokstr.copy
                    vLine: lblOpt2.lineno
                    vCol: lblOpt2.colno
                    dup: argNames.contains item: nm
                    if dup then {
                        bad: lex.acceptAny
                        return (this.mkError
                            tok: bad
                            code: zast.err.BADARGUMENT
                            msg: "Duplicate argument name".string
                        )
                    }
                    lv: this.mkLabelValue line: vLine col: vCol name: lvName
                    no: (this.mkNamedOp
                        name: (Option.some noName)
                        operation: lv
                        line: vLine
                        col: vCol
                    )
                    args.append no
                    argNames.append nm
                } case none then {
                    break
                }
            }
        }
        return (this.mkCall :callable arguments: args line: cp.line col: cp.col)
    }

    # Bare operation core: dispatch a non-empty path list. Odd count ->
    # binop; even count -> ( term binop ) call. A trailing error path is
    # propagated. NO named arguments (those belong to acceptCall).
    operationFromPaths: function {:this paths: (List Node).take lex: zlexer.Lexer} out Node is {
        last: paths.pop
        lerr: this.isError node: last
        if lerr then return last
        paths.append last
        n: paths.length
        half: n / 2
        twiceHalf: half * 2
        even: twiceHalf == n
        if even then {
            return (this.acceptTermBinopCall :paths :lex)
        }
        return (this.foldBinop :paths nextTok: lex.peek)
    }

    # operation: binop | ( term binop ). Top-level Option boundary; no
    # named arguments. none means no paths were found.
    acceptOperation: function {:this lex: zlexer.Lexer} out Option Node is {
        paths: this.operationPaths :lex
        n: paths.length
        if n == 0 then return (Option.none Node)
        return (Option.some (this.operationFromPaths :paths :lex))
    }

    # parseTyperefOperation -- a parameter / return type parsed as a grammar
    # `operation` (doc/grammar.pdoc: `in`/`out` types are operations, not bare
    # paths). The `(term binop)` unnamed-argument form (e.g. `List u8`)
    # materialises as a Call; wrap it in an Expression so it matches the
    # parenthesised `(List u8)` shape the type checker already resolves.
    # Named-argument generics (`Map u8 value: u32`) are calls, not operations,
    # so operationPaths stops at the label and they still need parentheses.
    # Mirrors Python `_accept_typeref_operation`.
    parseTyperefOperation: function {:this lex: zlexer.Lexer} out Node is {
        paths: this.operationPaths :lex
        n: paths.length
        if n == 0 then {
            bad: lex.peek
            return (this.mkError
                tok: bad
                code: zast.err.BADARGUMENT
                msg: "Expected type reference".string
            )
        }
        half: n / 2
        isCall: (half * 2) == n
        node: this.operationFromPaths :paths :lex
        nerr: this.isError :node
        if nerr then return node
        if isCall then {
            return (this.wrapExpression inner: node)
        }
        return node
    }

    # operation-or-call: the top-level entry that also accepts named
    # arguments. Dispatch on the pre-parsed path count: (count == 1 and
    # the next token is a label) or count is even -> call; else binop.
    # Bare core of operation-or-call dispatch: a non-empty path list maps
    # to a call (named args allowed) or a binop, returning the bare Node.
    # parseExpression needs the bare result to wrap it in an Expression
    # without moving it out of an Option.
    operationOrCallFromPaths: function {:this paths: (List Node).take lex: zlexer.Lexer} out Node is {
        last: paths.pop
        lerr: this.isError node: last
        if lerr then return last
        paths.append last
        n: paths.length
        pk: lex.peek
        half: n / 2
        twiceHalf: half * 2
        even: twiceHalf == n
        if even then {
            return (this.acceptCall :lex :paths)
        }
        nIsOne: n == 1
        if nIsOne then {
            labelNext: this.tokIsLabel tok: pk
            if labelNext then {
                return (this.acceptCall :lex :paths)
            }
        }
        return (this.foldBinop :paths nextTok: pk)
    }

    # operation-or-call: top-level Option boundary over the bare core;
    # none when the pre-parsed path list is empty.
    acceptOperationOrCall: function {:this paths: (List Node).take lex: zlexer.Lexer} out Option Node is {
        n0: paths.length
        if n0 == 0 then return (Option.none Node)
        return (Option.some (this.operationOrCallFromPaths :paths :lex))
    }

    # Does an expression start at the current token? Control-flow forms
    # begin with a keyword; everything else begins with an atom.
    exprLookahead: function {:this lex: zlexer.Lexer} out bool is {
        t: lex.peek
        match t.toktype case IF then {
            return true
        } case FOR then {
            return true
        } case MATCH then {
            return true
        } case DATA then {
            return true
        } case WITH then {
            return true
        } case BRACEOPEN then {
            return true
        } case YIELD then {
            return true
        } else {
            return (this.atomLookahead :lex)
        }
    }

    # parseExpression -> bare Node. The control-flow expression forms
    # (if/for/match/data/with/block/yield) land in later slices and report
    # a not-yet-implemented error for now; the operation form wraps the
    # operation/call in an Expression node.
    # Wrap an operation/block node in an Expression carrier, positioned at
    # its inner node (matches the Python _accept_expression).
    wrapExpression: function {:this inner: Node.take} out Node is {
        ip: zast.posOf n: inner
        return (Node.expression (zast.ExpressionData
            nodeid: this.nextId
            lineno: ip.line
            colno: ip.col
            expression: inner)
        )
    }

    # True for a block-line separator token (EOL or ';').
    atSeparator: function {:this lex: zlexer.Lexer} out bool is {
        t: lex.peek
        match t.toktype case EOL then {
            return true
        } case SEMICOLON then {
            return true
        } else {
            return false
        }
    }

    # True when the current token is an EOL (a unit-body definition
    # separator; only observable while EOL filtering is off).
    atEol: function {:this lex: zlexer.Lexer} out bool is {
        t: lex.peek
        return (t.toktype == zlexer.TT.EOL)
    }

    # Does a block line start at the current token? (a binding label, a
    # label shorthand, or an expression)
    blocklineLookahead: function {:this lex: zlexer.Lexer} out bool is {
        t: lex.peek
        match t.toktype case LABEL then {
            return true
        } case LABELPRE then {
            return true
        } else {
            return (this.exprLookahead :lex)
        }
    }

    # blockline -> ( label expression ) | label-value | expression.
    # Reassignment/swap (path "=" / "swap") are deferred. The caller
    # guarantees blocklineLookahead, so the bare-expression tail always
    # finds an expression. Returns a bare StatementLine node.
    parseBlockline: function {:this lex: zlexer.Lexer} out Node is {
        startTok: lex.peek
        sLine: startTok.lineno
        sCol: startTok.colno
        tt: startTok.toktype
        if tt == zlexer.TT.LABELPRE then {
            lblTok: lex.acceptAny
            lvName: lblTok.tokstr.copy
            asgnName: lblTok.tokstr.copy
            lv: this.mkLabelValue line: lblTok.lineno col: lblTok.colno name: lvName
            asgn: Node.assignment (zast.AssignmentData
                nodeid: this.nextId
                lineno: sLine
                colno: sCol
                name: asgnName
                value: lv
            )
            return (Node.statementline (zast.StatementLineData
                nodeid: this.nextId
                lineno: sLine
                colno: sCol
                statementline: asgn)
            )
        }
        if tt == zlexer.TT.LABEL then {
            lblTok: lex.acceptAny
            nm: lblTok.tokstr.copy
            lex.accept tt: zlexer.TT.EOL
            eLook: this.exprLookahead :lex
            if eLook then {
                expr: this.parseExpression :lex
                eErr: this.isError node: expr
                if eErr then return expr
                asgn: Node.assignment (zast.AssignmentData
                    nodeid: this.nextId
                    lineno: sLine
                    colno: sCol
                    name: nm
                    value: expr
                )
                return (Node.statementline (zast.StatementLineData
                    nodeid: this.nextId
                    lineno: sLine
                    colno: sCol
                    statementline: asgn)
                )
            } else {
                bad: lex.acceptAny
                return (this.mkError
                    tok: bad
                    code: zast.err.BADSTATEMENT
                    msg: "Expected expression for assignment statement".string
                )
            }
        }
        expr: this.parseExpression :lex
        eErr: this.isError node: expr
        if eErr then return expr
        return (Node.statementline (zast.StatementLineData
            nodeid: this.nextId
            lineno: sLine
            colno: sCol
            statementline: expr)
        )
    }

    # block -> "{" { sep } { blockline { sep } } "}" | blockline. EOL
    # filtering is disabled inside the braces so newlines separate lines.
    # Duplicate-definition detection is deferred to the typechecker.
    # Returns a bare Statement node.
    acceptBlock: function {:this lex: zlexer.Lexer} out Node is {
        startTok: lex.peek
        sLine: startTok.lineno
        sCol: startTok.colno
        openOpt: lex.accept tt: zlexer.TT.BRACEOPEN
        match openOpt case some then {
            prevFilter: lex.filterEolState
            lex.setFilterEol enabled: false
            statements: (List Node)
            for true loop {
                for (this.atSeparator :lex) loop {
                    lex.advance
                }
                la: this.blocklineLookahead :lex
                if la then {
                    sl: this.parseBlockline :lex
                    slErr: this.isError node: sl
                    if slErr then {
                        lex.setFilterEol enabled: prevFilter
                        return sl
                    }
                    statements.append sl
                } else {
                    break
                }
            }
            lex.setFilterEol enabled: prevFilter
            closeOpt: lex.accept tt: zlexer.TT.BRACECLOSE
            match closeOpt case some then {
                return (Node.statement (zast.StatementData
                    nodeid: this.nextId
                    lineno: sLine
                    colno: sCol
                    :statements)
                )
            } case none then {
                bad: lex.acceptAny
                return (this.mkError
                    tok: bad
                    code: zast.err.BADSTATEMENT
                    msg: "Expected closing brace for statement body".string
                )
            }
        } case none then {
            la: this.blocklineLookahead :lex
            if la then {
                sl: this.parseBlockline :lex
                slErr: this.isError node: sl
                if slErr then return sl
                one: (List Node)
                one.append sl
                return (Node.statement (zast.StatementData
                    nodeid: this.nextId
                    lineno: sLine
                    colno: sCol
                    statements: one)
                )
            } else {
                return (this.mkError
                    tok: startTok
                    code: zast.err.BADSTATEMENT
                    msg: "Expected a statement".string
                )
            }
        }
    }

    # bareblock -> "{ ... }" as an expression; wraps a block in a Do node.
    acceptBareblock: function {:this lex: zlexer.Lexer} out Node is {
        startTok: lex.peek
        sLine: startTok.lineno
        sCol: startTok.colno
        blk: this.acceptBlock :lex
        bErr: this.isError node: blk
        if bErr then return blk
        return (Node.doexpr (zast.DoData
            nodeid: this.nextId
            lineno: sLine
            colno: sCol
            statement: blk)
        )
    }

    # primary-expression -> block | operation. Control-flow bodies
    # (if/match then/else). A block parses directly to a Statement; a bare
    # expression is wrapped Statement(StatementLine(Expression)) so the
    # clause statement field has a uniform shape.
    acceptPrimaryExpression: function {:this lex: zlexer.Lexer} out Node is {
        t: lex.peek
        sLine: t.lineno
        sCol: t.colno
        if t.toktype == zlexer.TT.BRACEOPEN then {
            return (this.acceptBlock :lex)
        }
        eLook: this.exprLookahead :lex
        if eLook then {
            expr: this.parseExpression :lex
            eErr: this.isError node: expr
            if eErr then return expr
            sl: Node.statementline (zast.StatementLineData
                nodeid: this.nextId
                lineno: sLine
                colno: sCol
                statementline: expr
            )
            one: (List Node)
            one.append sl
            return (Node.statement (zast.StatementData
                nodeid: this.nextId
                lineno: sLine
                colno: sCol
                statements: one)
            )
        } else {
            return (this.mkError
                tok: t
                code: zast.err.EXPECTEDSTATEMENT
                msg: "Expected primary-expression".string
            )
        }
    }

    # Tail of the if-clause loop. Threads the clauses list and the current
    # clause's conditions list through recursion (so the conditions list is
    # moved into the IfClause and a fresh one passed on, never reassigned).
    # `when` adds a condition; `then` closes a clause and starts a fresh one;
    # otherwise the clauses end and an optional `else` is parsed.
    ifClausesTail: function {:this lex: zlexer.Lexer clauses: (List Node).take conditions: (List Node).take clauseLine: u32 clauseCol: u32 ifLine: u32 ifCol: u32} out Node is {
        t: lex.peek
        tt: t.toktype
        if tt == zlexer.TT.WHEN then {
            lex.advance
            lex.accept tt: zlexer.TT.EOL
            vpaths: this.operationPaths :lex
            n: vpaths.length
            if n == 0 then {
                bad: lex.acceptAny
                return (this.mkError
                    tok: bad
                    code: zast.err.EXPECTEDOP
                    msg: "Expected operation (condition) for 'if'".string
                )
            }
            cond: this.operationFromPaths paths: vpaths :lex
            cErr: this.isError node: cond
            if cErr then return cond
            cp: zast.posOf n: cond
            no: this.mkNamedOp name: (Option.none String) operation: cond line: cp.line col: cp.col
            conditions.append no
            return (this.ifClausesTail
                :lex
                :clauses
                :conditions
                :clauseLine
                :clauseCol
                :ifLine
                :ifCol
            )
        }
        if tt == zlexer.TT.THEN then {
            lex.advance
            stmt: this.acceptPrimaryExpression :lex
            sErr: this.isError node: stmt
            if sErr then return stmt
            clause: Node.ifclause (zast.IfClauseData
                nodeid: this.nextId
                lineno: clauseLine
                colno: clauseCol
                :conditions
                statement: stmt
            )
            clauses.append clause
            nextTok: lex.peek
            return (this.ifClausesTail
                :lex
                :clauses
                conditions: (List Node)
                clauseLine: nextTok.lineno
                clauseCol: nextTok.colno
                :ifLine
                :ifCol
            )
        }
        cn: conditions.length
        if cn != 0 then {
            return (this.mkError
                tok: t
                code: zast.err.BADTHEN
                msg: "Expected then after conditions".string
            )
        }
        if tt == zlexer.TT.ELSE then {
            lex.advance
            estmt: this.acceptPrimaryExpression :lex
            eErr: this.isError node: estmt
            if eErr then return estmt
            return (Node.ifexpr (zast.IfData
                nodeid: this.nextId
                lineno: ifLine
                colno: ifCol
                :clauses
                elseclause: (Option.some estmt))
            )
        }
        return (Node.ifexpr (zast.IfData
            nodeid: this.nextId
            lineno: ifLine
            colno: ifCol
            :clauses
            elseclause: (Option.none Node))
        )
    }

    # if-expression -> "if" op { "when" op }* "then" primary
    #                  { "when" op }* "then" primary ... [ "else" primary ]
    acceptIfExpression: function {:this lex: zlexer.Lexer} out Node is {
        startTok: lex.peek
        ifLine: startTok.lineno
        ifCol: startTok.colno
        ifOpt: lex.accept tt: zlexer.TT.IF
        match ifOpt case none then {
            return (this.mkError
                tok: startTok
                code: zast.err.BADEXPRESSION
                msg: "Expected if".string
            )
        } case some then {
            clauseStart: lex.peek
            cLine: clauseStart.lineno
            cCol: clauseStart.colno
            vpaths: this.operationPaths :lex
            n: vpaths.length
            if n == 0 then {
                bad: lex.acceptAny
                return (this.mkError
                    tok: bad
                    code: zast.err.EXPECTEDOP
                    msg: "Expected operation (condition) for 'if'".string
                )
            }
            cond: this.operationFromPaths paths: vpaths :lex
            cErr: this.isError node: cond
            if cErr then return cond
            cp: zast.posOf n: cond
            no: this.mkNamedOp name: (Option.none String) operation: cond line: cp.line col: cp.col
            conditions: (List Node)
            conditions.append no
            clauses: (List Node)
            return (this.ifClausesTail
                :lex
                :clauses
                :conditions
                clauseLine: cLine
                clauseCol: cCol
                :ifLine
                :ifCol
            )
        }
    }

    # Tail of the case-clause loop. Threads the subject and the clauses
    # list through recursion (each clause's owned pieces move into the
    # CaseClause, the list moves on), so neither is held across a loop
    # body -- mirrors ifClausesTail. `case` adds a clause; anything else
    # ends the clauses and parses an optional `else`.
    caseClausesTail: function {:this lex: zlexer.Lexer subject: Node.take clauses: (List Node).take mLine: u32 mCol: u32} out Node is {
        clStart: lex.peek
        isCase: clStart.toktype == zlexer.TT.CASE
        if isCase then {
            cLine: clStart.lineno
            cCol: clStart.colno
            lex.advance
            lex.accept tt: zlexer.TT.EOL
            idOpt: lex.accept tt: zlexer.TT.REFID
            match idOpt case some then {
                nm: idOpt.tokstr.copy
                armNode: Node.atomid (zast.AtomIdData
                    nodeid: this.nextId
                    lineno: idOpt.lineno
                    colno: idOpt.colno
                    name: idOpt.tokstr.copy
                )
                tk: lex.peek
                isThen: tk.toktype == zlexer.TT.THEN
                if isThen then {
                    lex.advance
                    body: this.acceptPrimaryExpression :lex
                    bErr: this.isError node: body
                    if bErr then return body
                    clause: Node.caseclause (zast.CaseClauseData
                        nodeid: this.nextId
                        lineno: cLine
                        colno: cCol
                        name: nm
                        matcharm: armNode
                        statement: body
                    )
                    clauses.append clause
                    return (this.caseClausesTail :lex :subject :clauses :mLine :mCol)
                } else {
                    bad: lex.acceptAny
                    return (this.mkError
                        tok: bad
                        code: zast.err.BADCASE
                        msg: "Expected then keyword for case".string
                    )
                }
            } case none then {
                bad: lex.acceptAny
                return (this.mkError
                    tok: bad
                    code: zast.err.BADREFERENCE
                    msg: "Case match expression expected (simple id)".string
                )
            }
        }
        elseOpt: lex.accept tt: zlexer.TT.ELSE
        match elseOpt case some then {
            estmt: this.acceptPrimaryExpression :lex
            eErr: this.isError node: estmt
            if eErr then return estmt
            return (Node.caseexpr (zast.CaseData
                nodeid: this.nextId
                lineno: mLine
                colno: mCol
                :subject
                :clauses
                elseclause: (Option.some estmt))
            )
        } case none then {
            return (Node.caseexpr (zast.CaseData
                nodeid: this.nextId
                lineno: mLine
                colno: mCol
                :subject
                :clauses
                elseclause: (Option.none Node))
            )
        }
    }

    # match-expression -> "match" [ "on" ] op
    #                     { "case" id "then" primary }* [ "else" primary ]
    # The subject is a bare operation; each clause binds the matched id's
    # name plus the AtomId arm being matched. The clause loop is a
    # recursive tail (caseClausesTail) so the subject/clauses are never
    # held across a loop body. Narrowing the subject and rejecting `.take`
    # on it are typecheck concerns, not parse ones.
    acceptMatchExpression: function {:this lex: zlexer.Lexer} out Node is {
        startTok: lex.peek
        mLine: startTok.lineno
        mCol: startTok.colno
        matchOpt: lex.accept tt: zlexer.TT.MATCH
        match matchOpt case none then {
            return (this.mkError
                tok: startTok
                code: zast.err.BADEXPRESSION
                msg: "Expected match".string
            )
        } case some then {
            lex.accept tt: zlexer.TT.ON
            spaths: this.operationPaths :lex
            sn: spaths.length
            if sn == 0 then {
                bad: lex.acceptAny
                return (this.mkError
                    tok: bad
                    code: zast.err.EXPECTEDOP
                    msg: "Expected operation for match (subject)".string
                )
            }
            subject: this.operationFromPaths paths: spaths :lex
            sErr: this.isError node: subject
            if sErr then return subject
            clauses: (List Node)
            return (this.caseClausesTail :lex :subject :clauses :mLine :mCol)
        }
    }

    # Tail of the for-header. Threads the conditions + postconditions
    # lists and the optional body through recursion as `.take` params so
    # nothing owned is held across a loop body (E0200). `while` before the
    # body is a condition, after it a postcondition; `label op` is the
    # at-most-one binding; `loop primary` is the body. `hasBody` mirrors
    # Python's `if loop:` truthiness without inspecting the owned body.
    forClausesTail: function {:this lex: zlexer.Lexer conditions: (List Node).take postconditions: (List Node).take body: (Option Node).take hasBody: bool bound: bool forLine: u32 forCol: u32} out Node is {
        t: lex.peek
        tt: t.toktype
        if tt == zlexer.TT.WHILE then {
            lex.advance
            lex.accept tt: zlexer.TT.EOL
            vpaths: this.operationPaths :lex
            n: vpaths.length
            if n == 0 then {
                bad: lex.acceptAny
                return (this.mkError
                    tok: bad
                    code: zast.err.EXPECTEDOP
                    msg: "Expected operation (condition) for for".string
                )
            }
            op: this.operationFromPaths paths: vpaths :lex
            oErr: this.isError node: op
            if oErr then return op
            if hasBody then {
                postconditions.append op
            } else {
                cp: zast.posOf n: op
                no: (this.mkNamedOp
                    name: (Option.none String)
                    operation: op
                    line: cp.line
                    col: cp.col
                )
                conditions.append no
            }
            return (this.forClausesTail
                :lex
                :conditions
                :postconditions
                :body
                :hasBody
                :bound
                :forLine
                :forCol
            )
        }
        if tt == zlexer.TT.LABEL then {
            if hasBody then {
                return (this.mkError
                    tok: t
                    code: zast.err.BADFOR
                    msg: "Binding label not allowed after loop".string
                )
            }
            if bound then {
                return (this.mkError
                    tok: t
                    code: zast.err.BADFOR
                    msg: "for accepts at most one binding".string
                )
            }
            lblTok: lex.acceptAny
            nm: lblTok.tokstr.copy
            lex.accept tt: zlexer.TT.EOL
            vpaths: this.operationPaths :lex
            n: vpaths.length
            if n == 0 then {
                bad: lex.acceptAny
                return (this.mkError
                    tok: bad
                    code: zast.err.EXPECTEDOP
                    msg: "Expected operation for for binding label".string
                )
            }
            op: this.operationFromPaths paths: vpaths :lex
            oErr: this.isError node: op
            if oErr then return op
            no: (this.mkNamedOp
                name: (Option.some nm)
                operation: op
                line: lblTok.lineno
                col: lblTok.colno
            )
            conditions.append no
            return (this.forClausesTail
                :lex
                :conditions
                :postconditions
                :body
                :hasBody
                bound: true
                :forLine
                :forCol
            )
        }
        if tt == zlexer.TT.LOOP then {
            if hasBody then {
                bad: lex.acceptAny
                return (this.mkError tok: bad code: zast.err.BADFOR msg: "Duplicate loop".string)
            }
            lex.advance
            stmt: this.acceptPrimaryExpression :lex
            sErr: this.isError node: stmt
            if sErr then return stmt
            return (this.forClausesTail
                :lex
                :conditions
                :postconditions
                body: (Option.some stmt)
                hasBody: true
                :bound
                :forLine
                :forCol
            )
        }
        empty: conditions.length == 0
        if empty then {
            if hasBody then {
                return (Node.forexpr (zast.ForData
                    nodeid: this.nextId
                    lineno: forLine
                    colno: forCol
                    :conditions
                    :body
                    :postconditions)
                )
            }
            bad: lex.acceptAny
            return (this.mkError
                tok: bad
                code: zast.err.BADFOR
                msg: "Require at least one condition or a loop for for".string
            )
        }
        return (Node.forexpr (zast.ForData
            nodeid: this.nextId
            lineno: forLine
            colno: forCol
            :conditions
            :body
            :postconditions)
        )
    }

    # for-expression -> "for" [op] { "while" op } [ label op ] { "while" op }
    #                   [ "loop" primary ] { "while" op }
    # -> forexpr (conditions: namedoperation arms [named=binding,
    # unnamed=while/leading], body, postconditions: bare op Nodes). The
    # optional leading naked operation is an unnamed precondition; the rest
    # of the header is consumed by the recursive forClausesTail.
    acceptForExpression: function {:this lex: zlexer.Lexer} out Node is {
        startTok: lex.peek
        forLine: startTok.lineno
        forCol: startTok.colno
        forOpt: lex.accept tt: zlexer.TT.FOR
        match forOpt case none then {
            return (this.mkError
                tok: startTok
                code: zast.err.BADEXPRESSION
                msg: "Expected for".string
            )
        } case some then {
            conditions: (List Node)
            postconditions: (List Node)
            paths: this.operationPaths :lex
            n: paths.length
            if n == 0 then {
                return (this.forClausesTail
                    :lex
                    :conditions
                    :postconditions
                    body: (Option.none Node)
                    hasBody: false
                    bound: false
                    :forLine
                    :forCol
                )
            }
            op: this.operationFromPaths :paths :lex
            oErr: this.isError node: op
            if oErr then return op
            cp: zast.posOf n: op
            no: this.mkNamedOp name: (Option.none String) operation: op line: cp.line col: cp.col
            conditions.append no
            return (this.forClausesTail
                :lex
                :conditions
                :postconditions
                body: (Option.none Node)
                hasBody: false
                bound: false
                :forLine
                :forCol
            )
        }
    }

    # with-expression -> "with" label op "do" expression. The binding name
    # is a LABEL; the value is an operation (wrapped in an Expression, no
    # named-arg calls); the body is a full expression in the binding's scope.
    acceptWithExpression: function {:this lex: zlexer.Lexer} out Node is {
        startTok: lex.peek
        wLine: startTok.lineno
        wCol: startTok.colno
        wOpt: lex.accept tt: zlexer.TT.WITH
        match wOpt case none then {
            return (this.mkError
                tok: startTok
                code: zast.err.BADEXPRESSION
                msg: "Expected with".string
            )
        } case some then {
            t: lex.peek
            isLabel: t.toktype == zlexer.TT.LABEL
            if isLabel then {
                lblTok: lex.acceptAny
                nm: lblTok.tokstr.copy
                vpaths: this.operationPaths :lex
                n: vpaths.length
                if n == 0 then {
                    bad: lex.peek
                    return (this.mkError
                        tok: bad
                        code: zast.err.EXPECTEDEXP
                        msg: "Expected operation for with value".string
                    )
                }
                op: this.operationFromPaths paths: vpaths :lex
                oErr: this.isError node: op
                if oErr then return op
                value: this.wrapExpression inner: op
                doOpt: lex.accept tt: zlexer.TT.DO
                match doOpt case none then {
                    bad: lex.peek
                    return (this.mkError
                        tok: bad
                        code: zast.err.EXPECTEDEXP
                        msg: "Expected do after with definition".string
                    )
                } case some then {
                    body: this.parseExpression :lex
                    bErr: this.isError node: body
                    if bErr then return body
                    return (Node.withexpr (zast.WithData
                        nodeid: this.nextId
                        lineno: wLine
                        colno: wCol
                        name: nm
                        :value
                        :body)
                    )
                }
            }
            bad: lex.acceptAny
            return (this.mkError
                tok: bad
                code: zast.err.EXPECTEDDEF
                msg: "Expected label after with".string
            )
        }
    }

    # data-definition -> "data" ["is"] "{" { [label] term | label-value } "}"
    # ["out" type]. Elements are single terms (paths): a LABEL names the
    # element, a LABELPRE is a label-value, bare terms are positional.
    # Duplicate member names are rejected here (the typechecker does not
    # re-check). The optional "out" pins the element type.
    acceptDataDefinition: function {:this lex: zlexer.Lexer} out Node is {
        startTok: lex.peek
        dLine: startTok.lineno
        dCol: startTok.colno
        dOpt: lex.accept tt: zlexer.TT.DATA
        match dOpt case none then {
            return (this.mkError
                tok: startTok
                code: zast.err.BADEXPRESSION
                msg: "Expected data".string
            )
        } case some then {
            lex.accept tt: zlexer.TT.IS
            openOpt: lex.accept tt: zlexer.TT.BRACEOPEN
            match openOpt case none then {
                bad: lex.acceptAny
                return (this.mkError
                    tok: bad
                    code: zast.err.BADDATA
                    msg: "Expected opening brace for data body".string
                )
            } case some then {
                elements: (List Node)
                datanames: (List String)
                for true loop {
                    et: lex.peek
                    ett: et.toktype
                    if ett == zlexer.TT.LABELPRE then {
                        lblTok: lex.acceptAny
                        checkName: lblTok.tokstr.copy
                        dup: datanames.contains item: checkName
                        if dup then {
                            bad: lex.acceptAny
                            return (this.mkError
                                tok: bad
                                code: zast.err.BADARGUMENT
                                msg: "Duplicate data member name".string
                            )
                        }
                        datanames.append checkName
                        lvName: lblTok.tokstr.copy
                        opName: lblTok.tokstr.copy
                        lv: this.mkLabelValue line: lblTok.lineno col: lblTok.colno name: lvName
                        no: (this.mkNamedOp
                            name: (Option.some opName)
                            operation: lv
                            line: lblTok.lineno
                            col: lblTok.colno
                        )
                        elements.append no
                    } else {
                        isLbl: ett == zlexer.TT.LABEL
                        if isLbl then {
                            lblTok: lex.acceptAny
                            checkName: lblTok.tokstr.copy
                            dup: datanames.contains item: checkName
                            if dup then {
                                bad: lex.acceptAny
                                return (this.mkError
                                    tok: bad
                                    code: zast.err.BADARGUMENT
                                    msg: "Duplicate data member name".string
                                )
                            }
                            datanames.append checkName
                            opName: lblTok.tokstr.copy
                            la: this.atomLookahead :lex
                            if la then {
                                pathNode: this.parsePath :lex
                                pErr: this.isError node: pathNode
                                if pErr then return pathNode
                                no: (this.mkNamedOp
                                    name: (Option.some opName)
                                    operation: pathNode
                                    line: lblTok.lineno
                                    col: lblTok.colno
                                )
                                elements.append no
                            } else {
                                bad: lex.peek
                                return (this.mkError
                                    tok: bad
                                    code: zast.err.BADDATA
                                    msg: "Expected term after data label".string
                                )
                            }
                        } else {
                            la: this.atomLookahead :lex
                            if la then {
                                pathNode: this.parsePath :lex
                                pErr: this.isError node: pathNode
                                if pErr then return pathNode
                                cp: zast.posOf n: pathNode
                                no: (this.mkNamedOp
                                    name: (Option.none String)
                                    operation: pathNode
                                    line: cp.line
                                    col: cp.col
                                )
                                elements.append no
                            } else {
                                break
                            }
                        }
                    }
                }
                closeOpt: lex.accept tt: zlexer.TT.BRACECLOSE
                match closeOpt case none then {
                    bad: lex.acceptAny
                    return (this.mkError
                        tok: bad
                        code: zast.err.BADDATA
                        msg: "Expected closing brace for data body".string
                    )
                } case some then {
                    eLen: elements.length
                    if eLen == 0 then {
                        return (this.mkError
                            tok: startTok
                            code: zast.err.BADDATA
                            msg: "data definition must have at least one element".string
                        )
                    }
                    outOpt: lex.accept tt: zlexer.TT.OUT
                    match outOpt case some then {
                        la: this.atomLookahead :lex
                        if la then {
                            typeNode: this.parsePath :lex
                            tErr: this.isError node: typeNode
                            if tErr then return typeNode
                            return (Node.datablock (zast.DataBlockData
                                nodeid: this.nextId
                                lineno: dLine
                                colno: dCol
                                :elements
                                outType: (Option.some typeNode))
                            )
                        } else {
                            bad: lex.acceptAny
                            return (this.mkError
                                tok: bad
                                code: zast.err.BADDATA
                                msg: "Expected type reference after out".string
                            )
                        }
                    } case none then {
                        return (Node.datablock (zast.DataBlockData
                            nodeid: this.nextId
                            lineno: dLine
                            colno: dCol
                            :elements
                            outType: (Option.none Node))
                        )
                    }
                }
            }
        }
    }

    # yield-expression -> "yield" expression. Valid only directly inside a
    # function body (depth 1); rejected at top level (0) or in a nested
    # function literal (>1). Whether the function is a generator is checked
    # later by the typechecker.
    acceptYieldExpression: function {:this lex: zlexer.Lexer} out Node is {
        startTok: lex.peek
        yOpt: lex.accept tt: zlexer.TT.YIELD
        match yOpt case none then {
            return (this.mkError
                tok: startTok
                code: zast.err.BADEXPRESSION
                msg: "Expected yield".string
            )
        } case some then {
            depth: this.functionBodyDepth
            atTop: depth == 0
            if atTop then {
                return (this.mkError
                    tok: startTok
                    code: zast.err.BADSTATEMENT
                    msg: "yield is only valid inside a function body".string
                )
            }
            nested: depth > 1
            if nested then {
                return (this.mkError
                    tok: startTok
                    code: zast.err.BADSTATEMENT
                    msg: "yield is not allowed inside a nested function literal".string
                )
            }
            body: this.parseExpression :lex
            bErr: this.isError node: body
            if bErr then return body
            return (Node.yieldexpr (zast.YieldExprData
                nodeid: this.nextId
                lineno: startTok.lineno
                colno: startTok.colno
                expr: body)
            )
        }
    }

    # Build a reassignment from an already-parsed LHS path list (the `=`
    # is consumed). The LHS must be a single path; the RHS is a full
    # expression (so `x = if c then a else b` parses).
    buildReassignment: function {:this paths: (List Node).take lex: zlexer.Lexer startLine: u32 startCol: u32} out Node is {
        n: paths.length
        if n != 1 then {
            bad: lex.peek
            return (this.mkError
                tok: bad
                code: zast.err.BADSTATEMENT
                msg: "Reassignment must be to a single path on the LHS".string
            )
        }
        lhs: paths.pop
        lhsErr: this.isError node: lhs
        if lhsErr then return lhs
        rhs: this.parseExpression :lex
        rErr: this.isError node: rhs
        if rErr then return rhs
        return (Node.reassignment (zast.ReassignmentData
            nodeid: this.nextId
            lineno: startLine
            colno: startCol
            topath: lhs
            value: rhs)
        )
    }

    # Build a swap from an already-parsed LHS path list (the `swap` is
    # consumed). Both sides are single paths.
    buildSwap: function {:this paths: (List Node).take lex: zlexer.Lexer startLine: u32 startCol: u32} out Node is {
        n: paths.length
        if n != 1 then {
            bad: lex.peek
            return (this.mkError
                tok: bad
                code: zast.err.BADSTATEMENT
                msg: "Swap must be to a single path on the LHS".string
            )
        }
        lhs: paths.pop
        lhsErr: this.isError node: lhs
        if lhsErr then return lhs
        la: this.atomLookahead :lex
        if la then {
            rhs: this.parsePath :lex
            rErr: this.isError node: rhs
            if rErr then return rhs
            return (Node.swapstmt (zast.SwapStmtData
                nodeid: this.nextId
                lineno: startLine
                colno: startCol
                :lhs
                :rhs)
            )
        } else {
            bad: lex.acceptAny
            return (this.mkError
                tok: bad
                code: zast.err.BADSTATEMENT
                msg: "Swap requires a right hand side".string
            )
        }
    }

    # Parse a `{ (:name | name: typeref)* }` parameter block into a
    # (List of: Node) of namedoperation arms (name=param, operation=type
    # path or label-value). Duplicate names rejected. Errors use the
    # operationPaths trailing-sentinel: on failure an error node is the
    # last element (the caller pop-checks and propagates).
    acceptParamBlock: function {:this lex: zlexer.Lexer} out List Node is {
        params: (List Node)
        names: (List String)
        openOpt: lex.accept tt: zlexer.TT.BRACEOPEN
        match openOpt case none then {
            bad: lex.peek
            params.append (this.mkError
                tok: bad
                code: zast.err.BADARGUMENT
                msg: "Expected open brace for parameter block".string
            )
            return params
        } case some then {
            for true loop {
                lex.accept tt: zlexer.TT.EOL
                pk: lex.peek
                pktt: pk.toktype
                if pktt == zlexer.TT.LABELPRE then {
                    lblTok: lex.acceptAny
                    nm: lblTok.tokstr.copy
                    dup: names.contains item: nm
                    if dup then {
                        params.append (this.mkError
                            tok: lblTok
                            code: zast.err.BADPARAMETER
                            msg: "Duplicate parameter name".string
                        )
                        return params
                    }
                    names.append nm
                    lvName: lblTok.tokstr.copy
                    opName: lblTok.tokstr.copy
                    lv: this.mkLabelValue line: lblTok.lineno col: lblTok.colno name: lvName
                    no: (this.mkNamedOp
                        name: (Option.some opName)
                        operation: lv
                        line: lblTok.lineno
                        col: lblTok.colno
                    )
                    params.append no
                } else {
                    isLbl: pktt == zlexer.TT.LABEL
                    if isLbl then {
                        lblTok: lex.acceptAny
                        nm: lblTok.tokstr.copy
                        dup: names.contains item: nm
                        if dup then {
                            params.append (this.mkError
                                tok: lblTok
                                code: zast.err.BADPARAMETER
                                msg: "Duplicate parameter name".string
                            )
                            return params
                        }
                        names.append nm
                        opName: lblTok.tokstr.copy
                        la: this.atomLookahead :lex
                        if la then {
                            pathNode: this.parseTyperefOperation :lex
                            pErr: this.isError node: pathNode
                            if pErr then {
                                params.append pathNode
                                return params
                            }
                            no: (this.mkNamedOp
                                name: (Option.some opName)
                                operation: pathNode
                                line: lblTok.lineno
                                col: lblTok.colno
                            )
                            params.append no
                        } else {
                            bad: lex.peek
                            params.append (this.mkError
                                tok: bad
                                code: zast.err.BADPARAMETER
                                msg: "Expected type reference for parameter".string
                            )
                            return params
                        }
                    } else {
                        break
                    }
                }
            }
            closeOpt: lex.accept tt: zlexer.TT.BRACECLOSE
            match closeOpt case none then {
                bad: lex.peek
                params.append (this.mkError
                    tok: bad
                    code: zast.err.BADPARAMETERBLOCK
                    msg: "Expected closing brace after parameters".string
                )
                return params
            } case some then {
                return params
            }
        }
    }

    # Tail of the function-definition clause loop (out/is/in; `as` lands
    # in slice 2). Threads the owned accumulators through recursion so
    # nothing is held across a loop body (E0200) -- mirrors forClausesTail.
    # Each clause rejects a duplicate; an unmatched token terminates and
    # builds the functiondef.
    functionClausesTail: function {:this lex: zlexer.Lexer parameters: (List Node).take asItems: (List Node).take returntype: (Option Node).take body: (Option Node).take gotIn: bool hasOut: bool hasIs: bool isNative: bool hasAs: bool startLine: u32 startCol: u32} out Node is {
        t: lex.peek
        tt: t.toktype
        if tt == zlexer.TT.OUT then {
            if hasOut then {
                return (this.mkError tok: t code: zast.err.BADARGUMENT msg: "Duplicate out".string)
            }
            lex.advance
            la: this.atomLookahead :lex
            if la then {
                rt: this.parseTyperefOperation :lex
                rErr: this.isError node: rt
                if rErr then return rt
                return (this.functionClausesTail
                    :lex
                    :parameters
                    :asItems
                    returntype: (Option.some rt)
                    :body
                    :gotIn
                    hasOut: true
                    :hasIs
                    :isNative
                    :hasAs
                    :startLine
                    :startCol
                )
            } else {
                bad: lex.acceptAny
                return (this.mkError
                    tok: bad
                    code: zast.err.BADARGUMENT
                    msg: "Expected type reference for out".string
                )
            }
        }
        if tt == zlexer.TT.IS then {
            if hasIs then {
                return (this.mkError tok: t code: zast.err.BADARGUMENT msg: "Duplicate is".string)
            }
            lex.advance
            natOpt: lex.accept tt: zlexer.TT.NATIVE
            match natOpt case some then {
                return (this.functionClausesTail
                    :lex
                    :parameters
                    :asItems
                    :returntype
                    :body
                    :gotIn
                    :hasOut
                    hasIs: true
                    isNative: true
                    :hasAs
                    :startLine
                    :startCol
                )
            } case none then {
                stmt: this.acceptBlock :lex
                sErr: this.isError node: stmt
                if sErr then return stmt
                return (this.functionClausesTail
                    :lex
                    :parameters
                    :asItems
                    :returntype
                    body: (Option.some stmt)
                    :gotIn
                    :hasOut
                    hasIs: true
                    :isNative
                    :hasAs
                    :startLine
                    :startCol
                )
            }
        }
        if tt == zlexer.TT.AS then {
            if hasAs then {
                return (this.mkError tok: t code: zast.err.BADARGUMENT msg: "Duplicate as".string)
            }
            lex.advance
            ab: this.getObjectBody :lex
            an: ab.length
            if an > 0 then {
                last: ab.pop
                le: this.isError node: last
                if le then return last
                ab.append last
            }
            return (this.functionClausesTail
                :lex
                :parameters
                asItems: ab
                :returntype
                :body
                :gotIn
                :hasOut
                :hasIs
                :isNative
                hasAs: true
                :startLine
                :startCol
            )
        }
        if tt == zlexer.TT.IN then {
            if gotIn then {
                return (this.mkError tok: t code: zast.err.BADARGUMENT msg: "Duplicate in".string)
            }
            lex.advance
            pb: this.acceptParamBlock :lex
            pn: pb.length
            if pn > 0 then {
                last: pb.pop
                le: this.isError node: last
                if le then return last
                pb.append last
            }
            return (this.functionClausesTail
                :lex
                parameters: pb
                :asItems
                :returntype
                :body
                gotIn: true
                :hasOut
                :hasIs
                :isNative
                :hasAs
                :startLine
                :startCol
            )
        }
        return (Node.functiondef (zast.FunctionData
            nodeid: this.nextId
            lineno: startLine
            colno: startCol
            :returntype
            :parameters
            :body
            :isNative
            :asItems)
        )
    }

    # Body of acceptFunctionDefinition after `function` is consumed. A
    # leading `{` is an implicit `in` param block; otherwise the clause
    # tail starts with empty accumulators.
    functionDefinitionInner: function {:this lex: zlexer.Lexer startLine: u32 startCol: u32} out Node is {
        parameters: (List Node)
        asItems: (List Node)
        pk: lex.peek
        isBrace: pk.toktype == zlexer.TT.BRACEOPEN
        if isBrace then {
            pb: this.acceptParamBlock :lex
            pn: pb.length
            if pn > 0 then {
                last: pb.pop
                le: this.isError node: last
                if le then return last
                pb.append last
            }
            return (this.functionClausesTail
                :lex
                parameters: pb
                :asItems
                returntype: (Option.none Node)
                body: (Option.none Node)
                gotIn: true
                hasOut: false
                hasIs: false
                isNative: false
                hasAs: false
                :startLine
                :startCol
            )
        }
        return (this.functionClausesTail
            :lex
            :parameters
            :asItems
            returntype: (Option.none Node)
            body: (Option.none Node)
            gotIn: false
            hasOut: false
            hasIs: false
            isNative: false
            hasAs: false
            :startLine
            :startCol
        )
    }

    # Parse a function definition whose `function` keyword the caller has
    # already peeked (startTok points at it); this consumes it. Bumps
    # functionBodyDepth around the whole definition (incl. the `as` block)
    # so the yield gate sees nested function literals, and restores it on
    # the single funneled return. Returns a bare functiondef Node.
    parseFunctionDefinition: function {:this lex: zlexer.Lexer startTok: zlexer.Token} out Node is {
        lex.advance
        this.functionBodyDepth = this.functionBodyDepth + 1
        inner: this.functionDefinitionInner :lex startLine: startTok.lineno startCol: startTok.colno
        this.functionBodyDepth = this.functionBodyDepth - 1
        return inner
    }

    # function-definition -> "function" [in-block] {out|is|as|in}*. The
    # Option boundary: none when there is no `function` keyword.
    acceptFunctionDefinition: function {:this lex: zlexer.Lexer} out Option Node is {
        startTok: lex.peek
        isFunc: startTok.toktype == zlexer.TT.FUNCTION
        if isFunc then {
            return (Option.some (this.parseFunctionDefinition :lex :startTok))
        }
        return (Option.none Node)
    }

    # object-body -> "{" { item } "}". Each item is `name: value` or a
    # `:name` shorthand: a method (function), an inline unit, an inline
    # field operation, or a label-value. Inline type definitions are
    # rejected. EOL filtering is on while an object body is parsed (the
    # enclosing definition value), so newlines never reach the loop in
    # practice; the EOL skip is kept for the filtering-off case. Returns
    # the items as namedoperation arms; a trailing error node flags a
    # malformed item for the caller to detect.
    getObjectBody: function {:this lex: zlexer.Lexer} out List Node is {
        items: (List Node)
        names: (List String)
        openOpt: lex.accept tt: zlexer.TT.BRACEOPEN
        match openOpt case none then {
            bad: lex.peek
            items.append (this.mkError
                tok: bad
                code: zast.err.BADOBJECTBLOCK
                msg: "Expected open brace for object body".string
            )
            return items
        } case some then {
            for true loop {
                for (this.atEol :lex) loop {
                    lex.advance
                }
                pk: lex.peek
                pktt: pk.toktype
                if pktt == zlexer.TT.LABELPRE then {
                    lblTok: lex.acceptAny
                    nm: lblTok.tokstr.copy
                    dup: names.contains item: nm
                    if dup then {
                        items.append (this.mkError
                            tok: lblTok
                            code: zast.err.BADITEM
                            msg: "Duplicate item name".string
                        )
                        return items
                    }
                    names.append nm
                    lvName: lblTok.tokstr.copy
                    opName: lblTok.tokstr.copy
                    lv: this.mkLabelValue line: lblTok.lineno col: lblTok.colno name: lvName
                    no: (this.mkNamedOp
                        name: (Option.some opName)
                        operation: lv
                        line: lblTok.lineno
                        col: lblTok.colno
                    )
                    items.append no
                } else {
                    isLbl: pktt == zlexer.TT.LABEL
                    if isLbl then {
                        lblTok: lex.acceptAny
                        nm: lblTok.tokstr.copy
                        dup: names.contains item: nm
                        if dup then {
                            items.append (this.mkError
                                tok: lblTok
                                code: zast.err.BADITEM
                                msg: "Duplicate item name".string
                            )
                            return items
                        }
                        names.append nm
                        opName: lblTok.tokstr.copy
                        lex.accept tt: zlexer.TT.EOL
                        member: this.objectBodyMember :lex
                        mErr: this.isError node: member
                        if mErr then {
                            items.append member
                            return items
                        }
                        no: (this.mkNamedOp
                            name: (Option.some opName)
                            operation: member
                            line: lblTok.lineno
                            col: lblTok.colno
                        )
                        items.append no
                    } else {
                        break
                    }
                }
            }
            closeOpt: lex.accept tt: zlexer.TT.BRACECLOSE
            match closeOpt case none then {
                bad: lex.peek
                items.append (this.mkError
                    tok: bad
                    code: zast.err.BADOBJECTBLOCK
                    msg: "Expected closing brace for object body".string
                )
                return items
            } case some then {
                return items
            }
        }
    }

    # The value of a `name:` item inside an object body: a method, an
    # inline unit, or a field operation (no named arguments). Inline type
    # definitions (record / class / ...) are rejected. Returns a bare Node.
    objectBodyMember: function {:this lex: zlexer.Lexer} out Node is {
        t: lex.peek
        tt: t.toktype
        if tt == zlexer.TT.FUNCTION then {
            return (this.parseFunctionDefinition :lex startTok: t)
        }
        if tt == zlexer.TT.UNIT then {
            return (this.parseUnitDefinition :lex startTok: t)
        }
        inlineTypedef: isInlineTypedefTok :tt
        if inlineTypedef then {
            bad: lex.acceptAny
            return (this.mkError
                tok: bad
                code: zast.err.BADITEM
                msg: "Inline type definition is not allowed here; define it at unit level and reference it by name".string
            )
        }
        paths: this.operationPaths :lex
        n: paths.length
        if n == 0 then {
            bad: lex.acceptAny
            return (this.mkError
                tok: bad
                code: zast.err.BADITEM
                msg: "Expected a function or expression for item".string
            )
        }
        return (this.operationFromPaths :paths :lex)
    }

    # type-definition dispatcher: unit / function / the six item-definition
    # kinds (record/class/variant/union/protocol/facet) / the if/match/data
    # expression forms (wrapped as an Expression) / else a bare operation.
    # Returns a bare Node; an absent definition becomes an EXPECTEDTYPEDEF
    # error node.
    acceptTypeDefinition: function {:this lex: zlexer.Lexer} out Node is {
        t: lex.peek
        match t.toktype case UNIT then {
            return (this.parseUnitDefinition :lex startTok: t)
        } case FUNCTION then {
            return (this.parseFunctionDefinition :lex startTok: t)
        } case RECORD then {
            return (this.parseItemDefinition :lex startTok: t kind: zast.nodetype.RECORD)
        } case CLASS then {
            return (this.parseItemDefinition :lex startTok: t kind: zast.nodetype.CLASS)
        } case VARIANT then {
            return (this.parseItemDefinition :lex startTok: t kind: zast.nodetype.VARIANT)
        } case UNION then {
            return (this.parseItemDefinition :lex startTok: t kind: zast.nodetype.UNION)
        } case PROTOCOL then {
            return (this.parseItemDefinition :lex startTok: t kind: zast.nodetype.PROTOCOL)
        } case FACET then {
            return (this.parseItemDefinition :lex startTok: t kind: zast.nodetype.FACET)
        } case IF then {
            ifn: this.acceptIfExpression :lex
            iErr: this.isError node: ifn
            if iErr then return ifn
            return (this.wrapExpression inner: ifn)
        } case MATCH then {
            mexpr: this.acceptMatchExpression :lex
            mErr: this.isError node: mexpr
            if mErr then return mexpr
            return (this.wrapExpression inner: mexpr)
        } case DATA then {
            dn: this.acceptDataDefinition :lex
            dErr: this.isError node: dn
            if dErr then return dn
            return (this.wrapExpression inner: dn)
        } else {
            paths: this.operationPaths :lex
            n: paths.length
            if n == 0 then {
                return (this.mkError
                    tok: t
                    code: zast.err.EXPECTEDTYPEDEF
                    msg: "Expected a type definition or expression".string
                )
            }
            return (this.operationFromPaths :paths :lex)
        }
    }

    # unit-body -> { newline | definition }. A definition is `name: value`
    # or `:name`; values dispatch through acceptTypeDefinition. EOL
    # filtering is off so newlines separate definitions, and re-enabled
    # while a definition value is parsed. Returns the definitions as
    # namedoperation arms; a trailing error node flags a malformed body.
    acceptUnitBody: function {:this lex: zlexer.Lexer} out List Node is {
        body: (List Node)
        names: (List String)
        prevFilter: lex.filterEolState
        lex.setFilterEol enabled: false
        for true loop {
            for (this.atEol :lex) loop {
                lex.advance
            }
            pk: lex.peek
            pktt: pk.toktype
            if pktt == zlexer.TT.LABELPRE then {
                lblTok: lex.acceptAny
                nm: lblTok.tokstr.copy
                dup: names.contains item: nm
                if dup then {
                    body.append (this.mkError
                        tok: lblTok
                        code: zast.err.DUPLICATEDEF
                        msg: "Duplicate definition".string
                    )
                    lex.setFilterEol enabled: prevFilter
                    return body
                }
                names.append nm
                lvName: lblTok.tokstr.copy
                opName: lblTok.tokstr.copy
                lv: this.mkLabelValue line: lblTok.lineno col: lblTok.colno name: lvName
                no: (this.mkNamedOp
                    name: (Option.some opName)
                    operation: lv
                    line: lblTok.lineno
                    col: lblTok.colno
                )
                body.append no
            } else {
                isLbl: pktt == zlexer.TT.LABEL
                if isLbl then {
                    lblTok: lex.acceptAny
                    nm: lblTok.tokstr.copy
                    dup: names.contains item: nm
                    if dup then {
                        body.append (this.mkError
                            tok: lblTok
                            code: zast.err.DUPLICATEDEF
                            msg: "Duplicate definition".string
                        )
                        lex.setFilterEol enabled: prevFilter
                        return body
                    }
                    names.append nm
                    opName: lblTok.tokstr.copy
                    lex.accept tt: zlexer.TT.EOL
                    lex.setFilterEol enabled: true
                    defNode: this.acceptTypeDefinition :lex
                    lex.setFilterEol enabled: false
                    dErr: this.isError node: defNode
                    if dErr then {
                        body.append defNode
                        lex.setFilterEol enabled: prevFilter
                        return body
                    }
                    no: (this.mkNamedOp
                        name: (Option.some opName)
                        operation: defNode
                        line: lblTok.lineno
                        col: lblTok.colno
                    )
                    body.append no
                } else {
                    break
                }
            }
        }
        lex.setFilterEol enabled: prevFilter
        return body
    }

    # subunit -> "unit" [ "as" ] "{" unit-body "}". The caller has peeked
    # the `unit` keyword (startTok); this consumes it. Returns a bare
    # unitdef Node positioned at the keyword.
    parseUnitDefinition: function {:this lex: zlexer.Lexer startTok: zlexer.Token} out Node is {
        lex.advance
        lex.accept tt: zlexer.TT.AS
        openOpt: lex.accept tt: zlexer.TT.BRACEOPEN
        match openOpt case none then {
            bad: lex.peek
            return (this.mkError
                tok: bad
                code: zast.err.BADARGUMENT
                msg: "Expected open brace for unit body".string
            )
        } case some then {
            body: this.acceptUnitBody :lex
            bn: body.length
            if bn > 0 then {
                last: body.pop
                le: this.isError node: last
                if le then return last
                body.append last
            }
            closeOpt: lex.accept tt: zlexer.TT.BRACECLOSE
            match closeOpt case none then {
                bad: lex.peek
                return (this.mkError
                    tok: bad
                    code: zast.err.BADUNIT
                    msg: "Expected closing brace at end of unit".string
                )
            } case some then {
                return (Node.unitdef (zast.UnitData
                    nodeid: this.nextId
                    lineno: startTok.lineno
                    colno: startTok.colno
                    :body)
                )
            }
        }
    }

    # item-definition entry (record/class/variant/union/protocol/facet).
    # The caller has peeked the keyword (startTok); this consumes it, seeds
    # empty is/as accumulators, and tail-calls the reorder loop. Stays a
    # thin seed so the tail is re-entrant with the keyword already consumed.
    parseItemDefinition: function {:this lex: zlexer.Lexer startTok: zlexer.Token kind: zast.nodetype} out Node is {
        lex.advance
        isItems: (List Node)
        asItems: (List Node)
        return (this.acceptItemBodiesTail
            :lex
            :isItems
            :asItems
            isNative: false
            hasIs: false
            hasAs: false
            :kind
            startLine: startTok.lineno
            startCol: startTok.colno
        )
    }

    # Reorderable `is { ... }` / `as { ... }` / `is native` / bare `native`
    # clause loop for an item definition. Recursive tail threading the two
    # owned member lists (like functionClausesTail) -- a leading bare `{`
    # defaults to the is-body. An item must carry an is-body or `native`;
    # otherwise the body is malformed. Builds the objectdef at the terminal.
    acceptItemBodiesTail: function {:this lex: zlexer.Lexer isItems: (List Node).take asItems: (List Node).take isNative: bool hasIs: bool hasAs: bool kind: zast.nodetype startLine: u32 startCol: u32} out Node is {
        t: lex.peek
        tt: t.toktype
        if tt == zlexer.TT.IS then {
            if hasIs then {
                return (this.mkError
                    tok: t
                    code: zast.err.BADITEM
                    msg: "Duplicate is clause".string
                )
            }
            if isNative then {
                return (this.mkError
                    tok: t
                    code: zast.err.BADITEM
                    msg: "Duplicate is clause".string
                )
            }
            lex.advance
            natOpt: lex.accept tt: zlexer.TT.NATIVE
            match natOpt case some then {
                return (this.acceptItemBodiesTail
                    :lex
                    :isItems
                    :asItems
                    isNative: true
                    :hasIs
                    :hasAs
                    :kind
                    :startLine
                    :startCol
                )
            } case none then {
                ib: this.getObjectBody :lex
                ibn: ib.length
                if ibn > 0 then {
                    last: ib.pop
                    le: this.isError node: last
                    if le then return last
                    ib.append last
                }
                return (this.acceptItemBodiesTail
                    :lex
                    isItems: ib
                    :asItems
                    :isNative
                    hasIs: true
                    :hasAs
                    :kind
                    :startLine
                    :startCol
                )
            }
        }
        if tt == zlexer.TT.NATIVE then {
            noBodyYet: true
            if hasIs then noBodyYet = false
            if isNative then noBodyYet = false
            if noBodyYet then {
                lex.advance
                return (this.acceptItemBodiesTail
                    :lex
                    :isItems
                    :asItems
                    isNative: true
                    :hasIs
                    :hasAs
                    :kind
                    :startLine
                    :startCol
                )
            }
        }
        if tt == zlexer.TT.AS then {
            if hasAs then {
                return (this.mkError
                    tok: t
                    code: zast.err.BADITEM
                    msg: "Duplicate as clause".string
                )
            }
            lex.advance
            ab: this.getObjectBody :lex
            abn: ab.length
            if abn > 0 then {
                last: ab.pop
                le: this.isError node: last
                if le then return last
                ab.append last
            }
            return (this.acceptItemBodiesTail
                :lex
                :isItems
                asItems: ab
                :isNative
                :hasIs
                hasAs: true
                :kind
                :startLine
                :startCol
            )
        }
        if tt == zlexer.TT.BRACEOPEN then {
            noBodyYet: true
            if hasIs then noBodyYet = false
            if isNative then noBodyYet = false
            if noBodyYet then {
                ib: this.getObjectBody :lex
                ibn: ib.length
                if ibn > 0 then {
                    last: ib.pop
                    le: this.isError node: last
                    if le then return last
                    ib.append last
                }
                return (this.acceptItemBodiesTail
                    :lex
                    isItems: ib
                    :asItems
                    :isNative
                    hasIs: true
                    :hasAs
                    :kind
                    :startLine
                    :startCol
                )
            }
        }
        hasBody: false
        if hasIs then hasBody = true
        if isNative then hasBody = true
        if hasBody then {
            return (Node.objectdef (zast.ObjectDefData
                nodeid: this.nextId
                lineno: startLine
                colno: startCol
                :kind
                :isItems
                :asItems
                :isNative)
            )
        }
        return (this.mkError
            tok: t
            code: zast.err.BADARGUMENT
            msg: "Expected open brace or native for item body".string
        )
    }

    parseExpression: function {:this lex: zlexer.Lexer} out Node is {
        t: lex.peek
        match t.toktype case IF then {
            ifn: this.acceptIfExpression :lex
            iErr: this.isError node: ifn
            if iErr then return ifn
            return (this.wrapExpression inner: ifn)
        } case FOR then {
            forn: this.acceptForExpression :lex
            fErr: this.isError node: forn
            if fErr then return forn
            return (this.wrapExpression inner: forn)
        } case MATCH then {
            mexpr: this.acceptMatchExpression :lex
            mErr: this.isError node: mexpr
            if mErr then return mexpr
            return (this.wrapExpression inner: mexpr)
        } case DATA then {
            dn: this.acceptDataDefinition :lex
            dErr: this.isError node: dn
            if dErr then return dn
            return (this.wrapExpression inner: dn)
        } case WITH then {
            wn: this.acceptWithExpression :lex
            wErr: this.isError node: wn
            if wErr then return wn
            return (this.wrapExpression inner: wn)
        } case BRACEOPEN then {
            blk: this.acceptBareblock :lex
            bErr: this.isError node: blk
            if bErr then return blk
            return (this.wrapExpression inner: blk)
        } case YIELD then {
            yn: this.acceptYieldExpression :lex
            yErr: this.isError node: yn
            if yErr then return yn
            return (this.wrapExpression inner: yn)
        } else {
            paths: this.operationPaths :lex
            n: paths.length
            if n == 0 then {
                return (this.mkError
                    tok: t
                    code: zast.err.BADEXPRESSION
                    msg: "Expected an expression".string
                )
            }
            eqOpt: lex.accept tt: zlexer.TT.EQUALS
            match eqOpt case some then {
                ra: this.buildReassignment :paths :lex startLine: t.lineno startCol: t.colno
                raErr: this.isError node: ra
                if raErr then return ra
                return (this.wrapExpression inner: ra)
            } case none then {
                swOpt: lex.accept tt: zlexer.TT.SWAP
                match swOpt case some then {
                    sw: this.buildSwap :paths :lex startLine: t.lineno startCol: t.colno
                    swErr: this.isError node: sw
                    if swErr then return sw
                    return (this.wrapExpression inner: sw)
                } case none then {
                    inner: this.operationOrCallFromPaths :paths :lex
                    ierr: this.isError node: inner
                    if ierr then return inner
                    return (this.wrapExpression :inner)
                }
            }
        }
    }

    acceptExpression: function {:this lex: zlexer.Lexer} out Option Node is {
        la: this.exprLookahead :lex
        if la then {
            return (Option.some (this.parseExpression :lex))
        } else {
            return (Option.none Node)
        }
    }

    # True when `node` is an `error` arm carrying FILENOTFOUND. Used to
    # tell "this reference is not a subunit/unit file" (benign -- resolve
    # elsewhere) from a real parse error (propagate).
    isFileNotFound: function {node: Node} out bool is {
        match (
            node
        ) case error then {
            match (
                node.err
            ) case FILENOTFOUND then {
                return true
            } else {
                return false
            }
        } else {
            return false
        }
    }

    # Load and parse the unit file `<unitname>.z` under `parentid`, mirroring
    # zparser.py:_accept_unitfile. On success appends namedoperation(name,
    # unitdef) into `outBody`, this unit's top-level def names into `outNames`,
    # and its unresolved externs into `outExterns`; recursively loads any
    # subunit found in a same-named subdirectory (attaching them into this
    # unit's body and folding their externs back into this resolve loop).
    # Returns an `error` Node on failure (FILENOTFOUND distinguishable via
    # isFileNotFound) or a benign `atomid` "ok" sentinel on success -- so a
    # bare Node return avoids disassembling an owned result carrier.
    loadUnit: function {:this vfs: zvfs.ZVfs parentid: u32 unitname: String coreNames: List String outBody: List Node outExterns: List String outNames: List String} out Node is {
        valid: isValidUnitName name: unitname.stringview
        if (valid) == false then {
            return (Node.error (zast.ErrorData
                nodeid: this.nextId
                lineno: 0
                colno: 0
                width: 1
                err: zast.err.BADUNITNAME
                msg: "Invalid unit name".string
                fsno: 0
                note: "".string
                hint: "".string)
            )
        }
        fn: "\{unitname.stringview}.z".string
        fsid: vfs.walk parent: parentid name: fn.stringview
        fkind: vfs.arm dentryid: fsid
        isNF: false
        match (
            fkind
        ) case notfound then {
            isNF = true
        } case dir then {
        } case file then {
        }
        if isNF then {
            return (Node.error (zast.ErrorData
                nodeid: this.nextId
                lineno: 0
                colno: 0
                width: 1
                err: zast.err.FILENOTFOUND
                msg: "Unit file not found".string
                fsno: 0
                note: "".string
                hint: "".string)
            )
        }
        r: vfs.open dentryid: fsid
        match (
            r
        ) case err then {
            return (Node.error (zast.ErrorData
                nodeid: this.nextId
                lineno: 0
                colno: 0
                width: 1
                err: zast.err.IOERROR
                msg: "Could not open unit file".string
                fsno: 0
                note: "".string
                hint: "".string)
            )
        } case ok then {
            tk: zlexer.Tokenizer.create source: r.take fsno: fsid
            lx: zlexer.Lexer.create lexer: tk
            firstTok: lx.peek
            segStart9: this.nextNodeId
            body: this.acceptUnitBody lex: lx
            bn: body.length
            if bn > 0 then {
                last: body.pop
                le: this.isError node: last
                if le then return last
                body.append last
            }
            eofOpt: lx.accept tt: zlexer.TT.EOF
            match (
                eofOpt
            ) case none then {
                bad: lx.peek
                return (this.mkError
                    tok: bad
                    code: zast.err.BADUNIT
                    msg: "Expected EOF at end of unit file".string
                )
            } case some then {
            }
            this.fileSegs.append (FileSeg startId: segStart9 endId: this.nextNodeId fsno: fsid)
            ewBindNames scope: outNames items: body
            raw: collectExterns :body
            dirid: vfs.walk parent: parentid name: unitname.stringview
            dkind: vfs.arm dentryid: dirid
            hasSubdir: false
            match (
                dkind
            ) case dir then {
                hasSubdir = true
            } case file then {
            } case notfound then {
            }
            for raw.length > 0 loop {
                rname: raw.pop
                inCore: coreNames.contains item: rname
                if (inCore) == false then {
                    handled: false
                    if hasSubdir then {
                        subNames: (List String)
                        sub: (this.loadUnit
                            :vfs
                            parentid: dirid
                            unitname: rname
                            :coreNames
                            outBody: body
                            outExterns: raw
                            outNames: subNames
                        )
                        subErr: this.isError node: sub
                        if subErr then {
                            nf: this.isFileNotFound node: sub
                            if (nf) == false then {
                                return sub
                            }
                        } else {
                            handled = true
                        }
                    }
                    if (handled) == false then {
                        outExterns.append rname.copy
                    }
                }
            }
            root: Node.unitdef (zast.UnitData
                nodeid: this.nextId
                lineno: firstTok.lineno
                colno: firstTok.colno
                :body
            )
            outBody.append (this.mkNamedOp
                name: (Option.some unitname.copy)
                operation: root
                line: firstTok.lineno
                col: firstTok.colno
            )
            return (Node.atomid (zast.AtomIdData
                nodeid: this.nextId
                lineno: 0
                colno: 0
                name: "ok".string)
            )
        }
    }

    # Top-level entry: load the main unit and every transitively-referenced
    # unit, returning a `program` Node (or an `error` arm). Mirrors
    # zparser.py:parse. core is loaded first so its definitions suppress
    # externs; the worklist is drained LIFO via List.pop (matching Python's
    # dict popitem). Definitions/queue are parallel String/Node lists (no
    # reftype-valued Map).
    parse: function {:this vfs: zvfs.ZVfs rootid: u32 mainUnitName: String} out Node is {
        units: (List Node)
        coreNames: (List String)
        coreNamesOut: (List String)
        coreExterns: (List String)
        coreRes: (this.loadUnit
            :vfs
            parentid: rootid
            unitname: "core".string
            :coreNames
            outBody: units
            outExterns: coreExterns
            outNames: coreNamesOut
        )
        coreErr: this.isError node: coreRes
        coreOk: false
        if coreErr then {
            coreNF: this.isFileNotFound node: coreRes
            if (coreNF) == false then {
                return coreRes
            }
        } else {
            coreOk = true
        }
        defNames: (List String)
        if coreOk then {
            defNames.append "core".string
            cnIt: coreNamesOut.iterate
            for cn: cnIt loop {
                coreNames.append cn.copy
            }
        }
        loadQueue: (List String)
        loadQueue.append mainUnitName.copy
        ceIt: coreExterns.iterate
        for ce: ceIt loop {
            enqueueUnit queue: loadQueue :defNames name: ce.copy
        }
        for loadQueue.length > 0 loop {
            name: loadQueue.pop
            already: defNames.contains item: name
            if (already) == false then {
                unitExterns: (List String)
                throwNames: (List String)
                res: (this.loadUnit
                    :vfs
                    parentid: rootid
                    unitname: name
                    :coreNames
                    outBody: units
                    outExterns: unitExterns
                    outNames: throwNames
                )
                rErr: this.isError node: res
                if rErr then {
                    nf: this.isFileNotFound node: res
                    if nf then {
                        return (Node.error (zast.ErrorData
                            nodeid: this.nextId
                            lineno: 0
                            colno: 0
                            width: 1
                            err: zast.err.BADREFERENCE
                            msg: "Unknown reference".string
                            fsno: 0
                            note: "".string
                            hint: "".string)
                        )
                    } else {
                        return res
                    }
                } else {
                    defNames.append name.copy
                    eIt: unitExterns.iterate
                    for e: eIt loop {
                        enqueueUnit queue: loadQueue :defNames name: e.copy
                    }
                }
            }
        }
        return (Node.program (zast.ProgramData
            nodeid: this.nextId
            lineno: 1
            colno: 1
            :units
            mainUnitName: mainUnitName.copy)
        )
    }
}

# ---------------------------------------------------------------------------
# Extern (free-variable) walk.
#
# The ported parsers do not thread externs during parsing (the .z AST has
# no extern field). Instead this single post-parse walk recovers the set
# of referenced names not bound within a unit, mirroring zast.printNode's
# arms and child order. Only valid, loadable unit names are kept
# (operators, numbers, and dotted-member selectors never name a unit), so
# the set drives which sibling units and subunits parse() loads.
#
# `externs` and `scope` are threaded as borrowed list params (appending to
# a borrowed reftype mutates the caller's list -- the lib `extendraw`
# pattern), so the child loops never move an owned accumulator across an
# iteration (no E0200) and collectExterns returns a plain owned local.
#
# Bias: keep a name unless it is provably bound. A spurious extern fails
# to resolve to a file and is harmless; a missed extern would drop a unit.
# ---------------------------------------------------------------------------

# Record `name` as an extern unless it is bound, not a valid unit name, or
# already recorded.
ewEmit: function {externs: List String scope: List String name: String.take} is {
    inScope: scope.contains item: name
    if inScope then return
    valid: isValidUnitName name: name.stringview
    if valid then {
        dup: externs.contains item: name
        if dup then return
        externs.append name.copy
    }
}

# Push an optional bound name (a namedoperation / param / loop label).
ewBindOptName: function {scope: List String o: Option String} is {
    match (
        o
    ) case some then {
        scope.append o.copy
    } case none then {
    }
}

# Bind one namedoperation arm's name. `item` is taken by value (like
# zast.printNode's node param) so reading its `name` Option does not free
# a field still owned by the parent list -- extracting an Option field
# directly from a borrowed list-iterator element frees the shallow temp.
ewBindOneName: function {scope: List String item: Node} is {
    match (
        item
    ) case namedoperation then {
        ewBindOptName :scope o: item.name
    } else {
    }
}

# Bind the names of a namedoperation-arm list (params, as-items, object
# members) before their bodies are walked.
ewBindNames: function {scope: List String items: List Node} is {
    it: items.iterate
    for el: it loop {
        ewBindOneName :scope item: el
    }
}

# Drop bindings introduced since depth `n` (block / scope exit).
ewTruncate: function {scope: List String n: u64} is {
    for scope.length > n loop {
        dropped: scope.pop
    }
}

# Walk an optional child node if present.
ewWalkOpt: function {externs: List String scope: List String o: Option Node} is {
    match (
        o
    ) case some then {
        ewWalk :externs :scope node: o
    } case none then {
    }
}

# Walk a list of child nodes.
ewWalkList: function {externs: List String scope: List String items: List Node} is {
    it: items.iterate
    for el: it loop {
        ewWalk :externs :scope node: el
    }
}

# A statement-block line. Block lines are `statementline` nodes wrapping
# the real form (assignment / reassignment / swap / bare expression);
# unwrap one level, then dispatch. An assignment binds its name for the
# lines that follow (but not for its own value).
ewWalkLine: function {externs: List String scope: List String line: Node} is {
    match (
        line
    ) case statementline then {
        ewWalkStmtInner :externs :scope inner: line.statementline
    } else {
        ewWalkStmtInner :externs :scope inner: line
    }
}

# The unwrapped statement form. `inner` is taken by value so reading its
# fields does not free anything still owned by the enclosing statement.
ewWalkStmtInner: function {externs: List String scope: List String inner: Node} is {
    match (
        inner
    ) case assignment then {
        ewWalk :externs :scope node: inner.value
        scope.append inner.name.copy
    } case reassignment then {
        ewWalk :externs :scope node: inner.topath
        ewWalk :externs :scope node: inner.value
    } case swapstmt then {
        ewWalk :externs :scope node: inner.lhs
        ewWalk :externs :scope node: inner.rhs
    } else {
        ewWalk :externs :scope node: inner
    }
}

# A for-loop condition arm: a named arm (`label op`) binds the loop
# variable for the body after its iterable is walked; an unnamed arm
# (a `while` / leading condition) is just walked.
ewWalkForCond: function {externs: List String scope: List String cond: Node} is {
    match (
        cond
    ) case namedoperation then {
        ewWalk :externs :scope node: cond.operation
        ewBindOptName :scope o: cond.name
    } else {
        ewWalk :externs :scope node: cond
    }
}

# The core recursive walk: same arms and child order as zast.printNode.
# Emits atomid references; threads the bound scope through nested
# definitions and blocks.
ewWalk: function {externs: List String scope: List String node: Node} is {
    match (
        node
    ) case error then {
    } case atomid then {
        ewEmit :externs :scope name: node.name.copy
    } case labelvalue then {
    } case stringchunk then {
    } case binop then {
        ewWalk :externs :scope node: node.lhs
        ewWalk :externs :scope node: node.operator
        ewWalk :externs :scope node: node.rhs
    } case atomstring then {
        ewWalkList :externs :scope items: node.stringparts
    } case dottedpath then {
        ewWalk :externs :scope node: node.parent
    } case call then {
        ewWalk :externs :scope node: node.callable
        ewWalkList :externs :scope items: node.arguments
    } case typeofexpr then {
        ewWalk :externs :scope node: node.source
    } case namedoperation then {
        ewWalk :externs :scope node: node.operation
    } case datablock then {
        ewWalkList :externs :scope items: node.elements
        ewWalkOpt :externs :scope o: node.outType
    } case yieldexpr then {
        ewWalk :externs :scope node: node.expr
    } case statement then {
        base: scope.length
        sit: node.statements.iterate
        for line: sit loop {
            ewWalkLine :externs :scope :line
        }
        ewTruncate :scope n: base
    } case statementline then {
        ewWalk :externs :scope node: node.statementline
    } case assignment then {
        ewWalk :externs :scope node: node.value
    } case reassignment then {
        ewWalk :externs :scope node: node.topath
        ewWalk :externs :scope node: node.value
    } case swapstmt then {
        ewWalk :externs :scope node: node.lhs
        ewWalk :externs :scope node: node.rhs
    } case expression then {
        ewWalk :externs :scope node: node.expression
    } case ifexpr then {
        ewWalkList :externs :scope items: node.clauses
        ewWalkOpt :externs :scope o: node.elseclause
    } case ifclause then {
        ewWalkList :externs :scope items: node.conditions
        ewWalk :externs :scope node: node.statement
    } case forexpr then {
        base: scope.length
        fit: node.conditions.iterate
        for fc: fit loop {
            ewWalkForCond :externs :scope cond: fc
        }
        ewWalkOpt :externs :scope o: node.body
        ewWalkList :externs :scope items: node.postconditions
        ewTruncate :scope n: base
    } case doexpr then {
        ewWalk :externs :scope node: node.statement
    } case withexpr then {
        base: scope.length
        ewWalk :externs :scope node: node.value
        scope.append node.name.copy
        ewWalk :externs :scope node: node.body
        ewTruncate :scope n: base
    } case caseexpr then {
        ewWalk :externs :scope node: node.subject
        ewWalkList :externs :scope items: node.clauses
        ewWalkOpt :externs :scope o: node.elseclause
    } case caseclause then {
        ewWalk :externs :scope node: node.statement
    } case functiondef then {
        base: scope.length
        ewBindNames :scope items: node.parameters
        ewBindNames :scope items: node.asItems
        ewWalkOpt :externs :scope o: node.returntype
        ewWalkList :externs :scope items: node.parameters
        ewWalkOpt :externs :scope o: node.body
        ewWalkList :externs :scope items: node.asItems
        ewTruncate :scope n: base
    } case objectdef then {
        base: scope.length
        scope.append "this".string
        scope.append "type".string
        scope.append "meta".string
        ewBindNames :scope items: node.isItems
        ewBindNames :scope items: node.asItems
        ewWalkList :externs :scope items: node.isItems
        ewWalkList :externs :scope items: node.asItems
        ewTruncate :scope n: base
    } case unitdef then {
        base: scope.length
        scope.append "this".string
        scope.append "type".string
        scope.append "meta".string
        ewBindNames :scope items: node.body
        ewWalkList :externs :scope items: node.body
        ewTruncate :scope n: base
    } case program then {
    }
}

# Recover the extern (free-reference) set of a parsed unit body. Seeds the
# scope with {this,type,meta} and every top-level definition name (so
# forward references resolve), then walks the body. Returns the deduped
# extern names in source-reference order; parse() loads them as units.
collectExterns: function {body: List Node} out List String is {
    externs: (List String)
    scope: (List String)
    scope.append "this".string
    scope.append "type".string
    scope.append "meta".string
    ewBindNames :scope items: body
    ewWalkList :externs :scope items: body
    return externs
}

# Enqueue `name` as a unit to load unless it is already loaded
# (defNames) or already queued. Consumes `name` (appends it or frees it).
enqueueUnit: function {queue: List String defNames: List String name: String.take} is {
    inDef: defNames.contains item: name
    if (inDef) == false then {
        inQ: queue.contains item: name
        if (inQ) == false then {
            queue.append name
        }
    }
}

# Smoke harness: parse each inline snippet and dump the resulting node
# tree via zast.printNode. Atom snippets drive acceptPath; operation
# and call snippets drive acceptOperationOrCall (the named-argument
# entry).
runPath: function {label: StringView src: String.take} is {
    print "=== \{label} ==="
    p: Parser.create
    tk: zlexer.Tokenizer.create source: src fsno: 0
    lx: zlexer.Lexer.create lexer: tk
    r: p.acceptPath lex: lx
    match r case some then {
        zast.printNode r
    } case none then {
        print "<no atom>"
    }
}

runOp: function {label: StringView src: String.take} is {
    print "=== \{label} ==="
    p: Parser.create
    tk: zlexer.Tokenizer.create source: src fsno: 0
    lx: zlexer.Lexer.create lexer: tk
    paths: p.operationPaths lex: lx
    r: p.acceptOperationOrCall :paths lex: lx
    match r case some then {
        zast.printNode r
    } case none then {
        print "<none>"
    }
}

runExpr: function {label: StringView src: String.take} is {
    print "=== \{label} ==="
    p: Parser.create
    tk: zlexer.Tokenizer.create source: src fsno: 0
    lx: zlexer.Lexer.create lexer: tk
    r: p.acceptExpression lex: lx
    match r case some then {
        zast.printNode r
    } case none then {
        print "<none>"
    }
}

# Like runExpr but simulates being inside a function body (depth 1) so a
# yield-expression parses to a yieldexpr rather than the depth-0 error.
runYieldBody: function {label: StringView src: String.take} is {
    print "=== \{label} ==="
    p: Parser.create
    p.functionBodyDepth = 1
    tk: zlexer.Tokenizer.create source: src fsno: 0
    lx: zlexer.Lexer.create lexer: tk
    r: p.acceptExpression lex: lx
    match r case some then {
        zast.printNode r
    } case none then {
        print "<none>"
    }
}

# Drive acceptFunctionDefinition over an inline snippet and dump the
# resulting node tree.
runFunc: function {label: StringView src: String.take} is {
    print "=== \{label} ==="
    p: Parser.create
    tk: zlexer.Tokenizer.create source: src fsno: 0
    lx: zlexer.Lexer.create lexer: tk
    r: p.acceptFunctionDefinition lex: lx
    match r case some then {
        zast.printNode r
    } case none then {
        print "<none>"
    }
}

# Drive the type-definition dispatcher over an inline snippet and dump
# the resulting node tree (units, methods, operation definitions).
runDef: function {label: StringView src: String.take} is {
    print "=== \{label} ==="
    p: Parser.create
    tk: zlexer.Tokenizer.create source: src fsno: 0
    lx: zlexer.Lexer.create lexer: tk
    r: p.acceptTypeDefinition lex: lx
    zast.printNode r
}

# Inline smoke harness: parse each snippet and dump its node tree.
# Driven from main when no file argument is given.
runSmoke: function is {
    runPath label: "foo" src: "foo".string
    runPath label: "a.b.c" src: "a.b.c".string
    runPath label: "string" src: "\"hello\"".string
    runOp label: "f x" src: "f x".string
    runOp label: "f x y" src: "f x y".string
    runOp label: "f label: x" src: "f label: x".string
    runOp label: "f x label: y" src: "f x label: y".string
    runOp label: "a + b" src: "a + b".string
    runOp label: "a + b + c" src: "a + b + c".string
    runOp label: "f a + b" src: "f a + b".string
    runOp label: "a.b x" src: "a.b x".string
    runOp label: "a.b + c" src: "a.b + c".string
    runPath label: "(a)" src: "(a)".string
    runPath label: "(a + b)" src: "(a + b)".string
    runPath label: "(f x)" src: "(f x)".string
    runExpr label: "block1" src: "{ a }".string
    runExpr label: "block2" src: "{ a; b }".string
    runExpr label: "blockbind" src: "{ x: a + b }".string
    runExpr label: "if1" src: "if c then x".string
    runExpr label: "if2" src: "if c then { a } else { b }".string
    runExpr label: "if3" src: "if a when b then x else y".string
    runExpr label: "match1" src: "match x case a then b".string
    runExpr label: "match2" src: "match on x case a then { p } else { q }".string
    runExpr label: "match3" src: "match x case a then p case b then q".string
    runExpr label: "for1" src: "for ready loop a".string
    runExpr label: "for2" src: "for i: items while more loop { a }".string
    runExpr label: "for3" src: "for while c loop a while d".string
    runExpr label: "with1" src: "with x: v do e".string
    runExpr label: "with2" src: "with y: a + b do { c }".string
    runExpr label: "data1" src: "data { :lo a b }".string
    runExpr label: "data2" src: "data { x: 1 y: 2 } out u8".string
    runExpr label: "data3" src: "data { x: 1 x: 2 }".string
    runYieldBody label: "yield1" src: "yield x".string
    runExpr label: "yield2" src: "yield x".string
    runExpr label: "reassign1" src: "a = b".string
    runExpr label: "reassign2" src: "p.x = a + b".string
    runExpr label: "swap1" src: "a swap b".string
    runExpr label: "rsblock" src: "{ a = b }".string
    runFunc label: "func1" src: "function { x: i64 }".string
    runFunc label: "func2" src: "function { :T }".string
    runFunc label: "func3" src: "function out i64 is { x }".string
    runFunc label: "func4" src: "function is native".string
    runFunc label: "func5" src: "function { x: i64 } out i64 is { x }".string
    runFunc label: "func6" src: "function { x: i64 x: i64 }".string
    runFunc label: "func7" src: "function { x: t } as { t: i64 }".string
    runFunc label: "func8" src: "function as { :a :b }".string
    runFunc label: "func9" src: "function as { }".string
    runFunc label: "func10" src: "function as { r: record { x: i64 } }".string
    runFunc label: "func11" src: "function as { a: i64 } as { b: i64 }".string
    runDef label: "unit1" src: "unit { x: 5 y: 6 }".string
    runDef label: "unit2" src: "unit { inner: unit { a: 1 } }".string
    runDef label: "unit3" src: "unit { greet: function { x: i64 } out i64 is { x } }".string
    runDef label: "unit4" src: "unit { }".string
    runDef label: "unit5" src: "unit { a: 1 a: 2 }".string
    runDef label: "defop" src: "a + b".string
    runDef label: "record1" src: "record { x: i64 y: i64 }".string
    runDef label: "record2" src: "record { x: i64 } as { m: measurable }".string
    runDef label: "class1" src: "class is native".string
    runDef label: "class2" src: "class native".string
    runDef label: "variant1" src: "variant { red: 0 green: 1 }".string
    runDef label: "union1" src: "union { a: i64 b: i64 }".string
    runDef label: "protocol1" src: "protocol { foo: function {:this} out i64 }".string
    runDef label: "facet1" src: "facet { measure: function {:this b: i64} out i64 }".string
    runDef label: "reorder1" src: "class as { t: i64 } is { x: i64 }".string
    runDef label: "generic1" src: "class { v: t } as { t: i64 }".string
    runDef label: "err1" src: "record as { x: i64 }".string
    runDef label: "defif" src: "if c then x".string
    runDef label: "defmatch" src: "match x case a then b".string
    runDef label: "defdata" src: "data { x: 1 } out u8".string
    runPath label: "interp" src: "\"a\\{x}b\"".string
}

main: function is {
    # Three modes: no argument -> inline smoke harness; a single `.z` path
    # -> parse that file's unit body and dump the canonical (id-stripped)
    # AST (the per-file parser differential, mirrors zlexer.z); `--program
    # <dir> <mainunit>` -> load the whole program over a filesystem VFS
    # rooted at <dir> and dump the canonical Program (the multi-unit
    # differential).
    argv: os.args
    n: argv.length
    if n < 2 then {
        runSmoke
    } else {
        a1: argv.get i: 1
        isProg: a1.stringview == "--program"
        if isProg then {
            if n < 4 then {
                io.eprintln "usage: zparser --program <dir> <mainunit>"
                os.exit code: 2
            }
            dir: argv.get i: 2
            mainName: argv.get i: 3
            vfs: (zvfs.ZVfs
                providers: (List zvfs.ProviderBox)
                entrytable: (zvfs.DentryTable entries: (List zvfs.dentry))
                file_names: (List String)
                walk_cache: (Map String value: u32)
                rootid: 0
            )
            rootid: vfs.registerFS rootpath: dir.copy parentpath: "".string
            vfs.rootid = rootid
            p: Parser.create
            prog: p.parse :vfs :rootid mainUnitName: mainName
            zast.printNodeCanonical prog
        } else {
            path: argv.get i: 1
            r: io.readText path: path.stringview
            match (
                r
            ) case ok then {
                p: Parser.create
                tk: zlexer.Tokenizer.create source: r.take fsno: 0
                lx: zlexer.Lexer.create lexer: tk
                firstTok: lx.peek
                body: p.acceptUnitBody lex: lx
                root: Node.unitdef (zast.UnitData
                    nodeid: p.nextId
                    lineno: firstTok.lineno
                    colno: firstTok.colno
                    :body
                )
                zast.printNodeCanonical root
            } case err then {
                io.eprintln "zparser: could not read source file"
                os.exit code: 1
            }
        }
    }
}

                match (
                    ffo
                ) case some then {
                    if (st.reg.typetypeOf typeId: ffo) == ztypes.ztypetype.FUNCTION then {
                        if (methodHasNoUserArgs st: st mid: ffo) then {
                            fro: methodReturnOf st: st mid: ffo

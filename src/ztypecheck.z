            # constructs through its own leg: t inferred from the value.
            isBox: false
            if isGen then {
                if (st.reg.typetypeOf typeId: funcId) == ztypes.ztypetype.CLASS then {
                    bxn: typeNameOf :st tid: funcId
                    if bxn.stringview == "Box" then {

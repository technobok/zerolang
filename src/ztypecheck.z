        } case none then null
        funcId: u64
        if cn.length > 0 then {
            # A local variable of FUNCTION type (a spec-typed param or a
            # function reference) is callable; locals shadow unit names.
            lvo: st.lookup name: cn.stringview
            match (
                lvo
            ) case some then {
                if (st.reg.typetypeOf typeId: lvo) == ztypes.ztypetype.functionType then {
                    funcId = lvo
                    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.callable
                }
            } case none then null
            if funcId <= 0 then {
                fo: (walkLookupTyperef
                    :ast
                    ty: st.typing
                    reg: st.reg
                    currentUnit: unitName
                    base: cn.stringview
                )
                match (
                    fo
                ) case some then {
                    funcId = fo
                } case none then {

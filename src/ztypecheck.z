                                consumes: pjTake
                                borrows: pjBorrow
                            )
                        }
                    }
                    mcm: st.pushCall
                    # Dotted on a value in scope = the receiver is implicit;
                    # dotted on the type (`Counter.increment c`) passes the
                    # receiver as an ordinary positional arg.
                    recvVal9: false
                    rrn9: rootNameOf :ast n: (ast.nodes.get i: (call.callable - 1).u64)
                    if rrn9.length > 0 then {
                        rlo9: st.lookup name: rrn9.stringview
                        match (
                            rlo9
                        ) case some then {
                            recvVal9 = true
                        } case none then null
                    }
                    mlr: (walkCallArgsHoist
                        :st
                        :unitName
                        :ast :unitBody
                        :call
                        funcId: dro
                        isCtor: false
                        reportUnknown: false
                        recvImplicit: recvVal9
                    )
                    checkMissingCallArgs :ast :st :call funcId: dro isCtor: false
                    # The receiver locks for the call's duration too (after
                    # the args, matching the oracle's entry order).
                    rro: methodReceiverRoot :ast n: (ast.nodes.get i: (call.callable - 1).u64)
                    if rro.length > 0 then {
                        rvo2: st.lookupVarId name: rro.stringview
                        match (
                            rvo2
                        ) case some then {
                            rvt2: st.lookup name: rro.stringview
                            match (
                                rvt2
                            ) case some then {
                                # A receiver-bound method locks reftype
                                # receivers; a this-less function member is a
                                # callable field -- its receiver locks
                                # unconditionally (mirrors _lock_receiver).
                                doLock: false
                                rtt: st.reg.typetypeOf typeId: rvt2
                                isFP: false
                                if rtt == ztypes.ztypetype.facetType then isFP = true
                                if rtt == ztypes.ztypetype.protocolType then isFP = true
                                if isFP then {
                                    doLock = true
                                } else {
                                    if (methodHasThisReceiver :st mid: dro) then {
                                        if (typeIsReftype :st tid: rvt2) then doLock = true
                                    } else {
                                        doLock = true
                                    }
                                }
                                if doLock then {
                                    xq89: ast.nodes.get i: (call.callable - 1).u64
                                    rmn9: dottedChildName :ast n: xq89
                                    shr9: (isContainerReaderCall
                                        :ast
                                        :st
                                        recvTid: rvt2
                                        mname: rmn9.stringview
                                    )
                                    (lockCallArg
                                        :st
                                        name: rro.stringview
                                        callId: call.nodeid.u64
                                        shared: shr9
                                        nodeid: call.nodeid
                                        lineno: call.lineno
                                        colno: call.colno
                                    )
                                }
                            } case none then null
                        } case none then null
                    }
                    if rro.length == 0 then {
                        # Nested receiver (st.reg.map.get ...): the root-name
                        # block above cannot see it. Lock the full receiver
                        # tuple; the immediate receiver type (the stamped
                        # parent) drives the reader/writer kind.
                        rtupC: (List String)
                        xq79: ast.nodes.get i: (call.callable - 1).u64
                        methodReceiverTuple :ast n: xq79 dst: rtupC
                        if rtupC.length > 1 then {
                            rvoN: st.lookupVarId name: (rtupC.get i: 0).stringview
                            match (
                                rvoN
                            ) case some then {
                                xq69: ast.nodes.get i: (call.callable - 1).u64
                                rpidN: dottedParentNodeId :ast n: xq69
                                rvtN: optU64Or o: (st.typing.nodeType.get key: rpidN.u64) d: 0
                                if rvtN > 0 when (typeIsReftype :st tid: rvtN) then {
                                    xq59: ast.nodes.get i: (call.callable - 1).u64
                                    rmnN: dottedChildName :ast n: xq59
                                    shrN9: (isContainerReaderCall
                                        :ast
                                        :st

# checkProjectionCreate -- `F.create from: expr` / `P.borrow from: expr` on a
# facet or protocol: a projection, not a call. No CALL scope; the from-argument
# walks in the current scope (a facet copies its source -- nothing is consumed);
# the value is the facet/protocol type.
checkProjectionCreate: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) call: zast.CallData pjId: u64 consumes: bool borrows: bool} out u64 is {
    found: false
    aiter: call.arguments.iterate
    for arg: aiter loop {
        match (
            arg
        ) case namedoperation then {
            if found then {} else {
                an: unitLabel o: arg.name
                isFrom: false
                if an.length == 0.u64 then {
                    isFrom = true
                } else {
                    if an.stringview == "from" then {
                        isFrom = true
                    } else {}
                }
                if isFrom then {
                    found = true
                    pvt: checkValue st: st unitName: unitName unitBody: unitBody node: arg.operation
                    if pvt > 0.u64 then {
                        if borrows then {
                            # The from-path's root is the borrow origin (a
                            # bare name or a `.lock`/`.borrow` projection) --
                            # the projection borrows, it never hoists.
                            pbr: rootNameOf n: arg.operation
                            if pbr.length > 0.u64 then {
                                pbv2: st.lookupVarId name: pbr.stringview
                                match (
                                    pbv2
                                ) case some then {
                                    drainPendingBorrow st: st
                                    pbc2: pbr.copy
                                    st.typing.pendingBorrowPath.append pbc2
                                } case none then {}
                            } else {}
                        } else {
                            if (argIsTrivial op: arg.operation) then {
                                pbn: bareAtomName n: arg.operation
                                if pbn.length > 0.u64 then {
                                    pbv: st.lookupVarId name: pbn.stringview
                                    match (
                                        pbv
                                    ) case some then {
                                        if consumes then {
                                            st.invalidate name: pbn.stringview loc: (optionval.none ztypes.zsrcpos)
                                        } else {}
                                    } case none then {}
                                } else {}
                            } else {
                                tnm3: hoistArg st: st argNode: arg.operation argType: pvt paramType: 0.u64 consumes: consumes
                            }
                        }
                    } else {}
                } else {}
            }
        } else {}
    }
    setpj: pjId
    st.typing.nodeType.set key: call.nodeid.u64 value: setpj
    return pjId
}


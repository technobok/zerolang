                            (lockCallArg
                                :st
                                name: tnm.stringview
                                callId: call.nodeid.u64
                                shared: false
                                nodeid: (nodeId n: arg.operation)
                                lineno: (nodeLine n: arg.operation)
                                colno: (nodeCol n: arg.operation)
                            )
                        }
                    }
                }
            }
            argIdx = argIdx + 1
        } else {
        }
    }
    return lockRoot
}

# checkBoxConstruction -- `Box from: val`: the value's (materialised) type
# binds t; the argument is consumed (hoisted first when non-trivial); the
# instance carries create plus the element type's children copied for
# transparent member access. Heap passthrough (List/Map boxing) lands when
# an example needs it.
checkBoxConstruction: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    call: zast.CallData
    tplId: u64
} out u64 is {
    fnd: false
    vt: 0.u64
    with aiter: call.arguments.iterate do for arg: aiter loop {
        match (
            arg
        ) case namedoperation then {
            if (fnd) == false then {
                an: unitLabel o: arg.name
                if an.stringview != "t" then {
                    if an.stringview != "from" then {
                        anc7: an.copy
                        mbx7: "the builtin Box constructs with 'from:'; unknown argument '\{anc7}'"
                        bxid7: nodeId n: arg.operation
                        bxln7: nodeLine n: arg.operation
                        bxcl7: nodeCol n: arg.operation
                        (addError
                            :st
                            nodeid: bxid7
                            lineno: bxln7
                            colno: bxcl7
                            e: zast.err.CALLERROR
                            msg: mbx7
                        )
                    }
                    fnd = true
                    avt: checkValue :st :unitName :unitBody node: arg.operation
                    vt = materialiseLiteral :st :unitName t: avt
                    if vt > 0 then {
                        if (argIsTrivial op: arg.operation) then {
                            iid: innermostNodeId n: arg.operation
                            if iid > 0 then {
                                setbl: vt
                                st.typing.nodeType.set key: iid.u64 value: setbl
                            }
                            bn: bareAtomName n: arg.operation
                            if bn.length > 0 when (typeIsReftype :st tid: vt) then {
                                bvo8: st.lookupVarId name: bn.stringview
                                match (
                                    bvo8
                                ) case some then {
                                    if (isViewVar :st vid: bvo8) then {
                                        bnc8: bn.copy
                                        mb8: "Cannot move borrowed variable '\{bnc8}' into a box — borrowed names stay bound to their source for the full scope; copy with '.copy' to keep the source"
                                        aid8: nodeId n: arg.operation
                                        aln8: nodeLine n: arg.operation
                                        acl8: nodeCol n: arg.operation
                                        (addError
                                            :st
                                            nodeid: aid8
                                            lineno: aln8
                                            colno: acl8
                                            e: zast.err.OWNERERROR
                                            msg: mb8
                                        )
                                    } else {
                                        st.invalidate name: bn.stringview loc: takenHere
                                    }
                                } case none then {
                                    st.invalidate name: bn.stringview loc: takenHere
                                }
                            }
                        } else {
                            (hoistArg
                                :st
                                argNode: arg.operation
                                argType: vt
                                paramType: 0
                                consumes: true
                            )
                        }
                    }
                }
            }
        } else {
        }
    }
    if vt == 0 then return 0
    tn: typeNameOf :st tid: vt
    mname: "Box_\{tn}"
    subs: (Map String value: u64)
    sk: "t".string
    sv: vt
    subs.set key: sk value: sv
    vsJ9: (Map String value: u64)
    mid: (getOrMintSpec
        ty: st.typing
        reg: st.reg
        mainName: unitName
        name: mname.stringview
        templateId: tplId
        :subs
        valSubs: vsJ9
        fallbackArg: 0
    )
    if mid == 0 then return 0
    st.reg.setIsBox typeId: mid
    st.reg.setIsHeapAllocated typeId: mid
    bdtor9: "z_\{mname}_destroy"
    st.reg.setDestructorName typeId: mid name: bdtor9.stringview
    if (st.typing.childCount parentTypeId: mid) <= 0 then {
        crn: "\{mname}.create"
        crId: st.reg.newType name: crn.stringview typetype: ztypes.ztypetype.FUNCTION
        st.typing.setChild parentTypeId: mid childName: "create" childTypeId: crId
        # Stage the element's children first: setChild appends to the very
        # table being iterated.
        cNames2: (List String)
        cIds2: (List u64)
        {
            bxb9: st.typing.childIndex.get key: vt
            match (
                bxb9
            ) case some then {
                with bxit9: bxb9.rows.iterate do for bxr9: bxit9 loop {
                    tc2: st.typing.typeChild.get i: bxr9
                    cto2: st.typing.childTypeById.get key: tc2.childNameId
                    match (
                        cto2
                    ) case some then {
                        cnv2: tc2.childName.stringview
                        cn2: cnv2.string
                        cNames2.append cn2
                        cid3: cto2
                        cIds2.append cid3
                    } case none then {
                    }
                }
            } case none then {}
        }
        bi: 0.u64
        bn2: cNames2.length
        for bi < bn2 loop {
            chn: cNames2.get i: bi
            chi: cIds2.get i: bi
            ext9: st.typing.childOf parentTypeId: mid name: chn.stringview
            match (
                ext9
            ) case some then {
            } case none then {
                st.typing.setChild parentTypeId: mid childName: chn.stringview childTypeId: chi
            }
            bi = bi + 1
        }
    }
    bcal: nodeId n: call.callable
    if bcal > 0 then {
        setbt: tplId
        st.typing.nodeType.set key: bcal.u64 value: setbt
    }
    setbc: mid
    st.typing.nodeType.set key: call.nodeid.u64 value: setbc
    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.BOX_CREATE
    return mid
}

# callableDottedResult -- a dotted callable resolves through the dotted-path
# walk (no auto-call coercion -- callable position wants the function itself);
# the base is typed and stamped there. none = the callable is not a dotted
# path; some 0 = dotted but unresolved (e.g. a data block's `.index`), which
# leaves the call untyped with its arguments unwalked, like the reference.
callableDottedResult: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    n: Node
} out optionval u64 is {
    match (
        n
    ) case dottedpath then {
        r: checkDotted :st :unitName :unitBody dp: n coerce: false
        return (optionval.some r)
    } else {
        return (optionval.none u64)
    }
}

# returnedBareFieldName -- `return <base>.<field>` where the member is a
# non-FUNCTION field whose type is a reftype or a generic param: the bare
# read escapes a shallow copy of storage the owner still frees (and a
# generic param may instantiate to one). Returns the field name for the
# diagnostic; "" when the return shape is fine.
returnedBareFieldName: function {st: zenv.ZSymbolTable n: Node} out String is {
    match (
        n
    ) case expression then {
        return (returnedBareFieldName :st n: n.expression)
    } case dottedpath then {
        bfc9: atomName n: n.child
        if bfc9.length == 0 then return "".string
        if (isStripMarker name: bfc9.stringview) then return "".string
        bfp9: nodeId n: n.parent
        bft9: optU64Or o: (st.typing.nodeType.get key: bfp9.u64) d: 0
        if bft9 == 0 then return "".string
        bfo9: st.typing.childOf parentTypeId: bft9 name: bfc9.stringview
        match (
            bfo9
        ) case some then {
            if (st.reg.typetypeOf typeId: bfo9) == ztypes.ztypetype.FUNCTION then return "".string
            if (st.reg.typetypeOf typeId: bfo9) == ztypes.ztypetype.GENERIC_PARAM then return (bfc9.copy)
            if (typeIsReftype :st tid: bfo9) then return (bfc9.copy)
            return "".string
        } case none then {
            return "".string
        }
    } else {
        return "".string
    }
}

# unresolvedBareCallable -- the bare-atom callable name of a call-shaped
# value that resolves to NOTHING (no local, no own-unit function, no system
# name, no walkable type): the checker's silent args-walked fallthrough
# otherwise leaves the binding untyped and the emitter prints a marker.
unresolvedBareCallable: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    n: Node
} out String is {
    match (
        n
    ) case expression then {
        return (unresolvedBareCallable :st :unitName n: n.expression)
    } case call then {
        ubc9: atomName n: n.callable
        if ubc9.length == 0 then return "".string
        ubv9: st.lookupVarId name: ubc9.stringview
        match (
            ubv9
        ) case some then {
            return "".string
        } case none then {}
        ubk9: "\{unitName}.\{ubc9}"
        ubr9: resolvedByKey ty: st.typing reg: st.reg key: ubk9
        match (
            ubr9
        ) case some then {
            return "".string
        } case none then {}
        ubw9: (walkLookupTyperef
            ty: st.typing
            reg: st.reg
            currentUnit: unitName
            base: ubc9.stringview
        )
        match (
            ubw9
        ) case some then {
            return "".string
        } case none then {}
        ubs9: resolveSystemChild ty: st.typing reg: st.reg name: ubc9.stringview
        match (
            ubs9
        ) case some then {
            return "".string
        } case none then {}
        return (ubc9.copy)
    } else {
        return "".string
    }
}

# checkCall -- type a call. C1 handles the `return <value>` control-flow form:
# stamp the callable atom with return's type, mark the call RETURN, walk the
# return value, and resolve the call to `never`. Other call kinds land later.
checkCall: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    call: zast.CallData
} out u64 is {
    result: 0.u64
    cn: atomName n: call.callable
    if cn.stringview == "return" then {
        rtOpt: walkLookupTyperef ty: st.typing reg: st.reg currentUnit: unitName base: "return"
        match (
            rtOpt
        ) case some then {
            calid: nodeId n: call.callable
            st.typing.nodeType.set key: calid.u64 value: rtOpt
        } case none then {
        }
        st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.RETURN
        aiter: call.arguments.iterate
        for arg: aiter loop {
            match (
                arg
            ) case namedoperation then {
                argT9: checkValue :st :unitName :unitBody node: arg.operation
                bfn9: returnedBareFieldName :st n: arg.operation
                if st.typing.currentReturnsBorrow then bfn9 = "".string
                if bfn9.length > 0 then {
                    mbf9: "Cannot return field '\{bfn9}' as a bare read — the owner still frees it; return '\{bfn9}.copy' (duplicate) or '\{bfn9}.take' (move out)"
                    bfid9: nodeId n: arg.operation
                    bfln9: nodeLine n: arg.operation
                    bfcl9: nodeCol n: arg.operation
                    (addError
                        :st
                        nodeid: bfid9
                        lineno: bfln9
                        colno: bfcl9
                        e: zast.err.OWNERERROR
                        msg: mbf9
                    )
                }
                expR9: st.typing.currentReturnTypeId
                if expR9 > 0 when argT9 > 0 then {
                    if (typesCompatible :st :unitName a: argT9 b: expR9) == false then {
                        en9: typeNameOf :st tid: expR9
                        an9: typeNameOf :st tid: argT9
                        enc9: en9.copy
                        anc9: an9.copy
                        m4: "return type mismatch: function expects \{enc9}, got \{anc9}"
                        rvid9: nodeId n: arg.operation
                        rvln9: nodeLine n: arg.operation
                        rvcl9: nodeCol n: arg.operation
                        (addError
                            :st
                            nodeid: rvid9
                            lineno: rvln9
                            colno: rvcl9
                            e: zast.err.TYPEERROR
                            msg: m4
                        )
                    }
                }
            } else {
            }
        }
        nvOpt: walkLookupTyperef ty: st.typing reg: st.reg currentUnit: unitName base: "never"
        match (
            nvOpt
        ) case some then {
            result = nvOpt
            setk: result
            st.typing.nodeType.set key: call.nodeid.u64 value: setk
        } case none then {
        }
    } else {
        # A regular call. A dotted callable resolves through the dotted-path
        # walk first; an unresolved member bails with the args unwalked. A
        # bare-name callable: a non-generic user function pushes a call scope
        # and resolves to its return type; a generic callee (e.g. print) infers
        # a clone; an unresolvable callable just has its args walked (its
        # callable/result/mono are out of the own+system+collections filter).
        # A parenthesized construction in callable position re-applies its
        # init arguments: the value is the constructed type.
        isWrapCall: false
        match (
            call.callable
        ) case expression then {
            isWrapCall = true
        } else {}
        if isWrapCall then {
            wcv: checkValue :st :unitName :unitBody node: call.callable
            if wcv > 0 then {
                # A non-FUNCTION wrapped callee is the paren-mono construction
                # form: value args ride the standard ctor walk (call scope,
                # hoists, consumption); arg-less stays a bare construction.
                isWType: true
                if (st.reg.typetypeOf typeId: wcv) == ztypes.ztypetype.FUNCTION then isWType = false
                # List/Map have their own create paths in the reference --
                # no standard ctor scope for their paren-construction args.
                wgix9: 0.u64
                {
                    wgo9: st.reg.typeById.get key: wcv
                    match (
                        wgo9
                    ) case some then {
                        wgi9: wgo9.genericOriginId
                        match (
                            wgi9
                        ) case some then {
                            wgix9 = wgi9
                        } case none then {
                        }
                    } case none then {
                    }
                }
                if wgix9 > 0 then {
                    if wgix9 == (builtinTidTc :st base: "List") then isWType = false
                    if wgix9 == (builtinTidTc :st base: "Map") then isWType = false
                }
                if isWType when call.arguments.length > 0 then {
                    wcm: st.pushCall
                    _wlr09: (walkCallArgsHoist
                        :st
                        :unitName
                        :unitBody
                        :call
                        funcId: wcv
                        isCtor: true
                        reportUnknown: false
                        recvImplicit: false
                    )
                    checkMissingCallArgs :st :call funcId: wcv isCtor: true
                    st.popTo marker: wcm
                    wck: wcv
                    wcvv: true
                    st.typing.constructedTypes.set key: wck value: wcvv
                } else {
                    witer: call.arguments.iterate
                    for warg: witer loop {
                        match (
                            warg

                    # through the standard ctor flow (mirrors the reference's
                    # generic record/class construction).
                    # an invalid type-argument list (unknown/duplicate already
                    # diagnosed) never drives field-bound inference; the
                    # single-diagnostic template resolution below stands
                    gmid: 0.u64
                    if vok9 then {
                        gmid = (inferGenericConstruction
                            :st
                            :unitName
                            :unitBody
                            :call
                            tplId: funcId
                            reportMissing: vok9
                        )
                    }
                    if gmid > 0 then {
                        calid9: nodeId n: call.callable
                        if calid9 > 0 then {
                            setc9: gmid
                            st.typing.nodeType.set key: calid9.u64 value: setc9
                        }
                        cm9: st.pushCall
                        _wlr29: (walkCallArgsHoist
                            :st
                            :unitName
                            :unitBody
                            :call
                            funcId: gmid
                            isCtor: true
                            reportUnknown: false
                            recvImplicit: false
                        )
                        checkMissingCallArgs :st :call funcId: gmid isCtor: true
                        st.popTo marker: cm9
                        ctk9: gmid
                        ctv9: true
                        st.typing.constructedTypes.set key: ctk9 value: ctv9
                        setr9: gmid
                        st.typing.nodeType.set key: call.nodeid.u64 value: setr9
                        return gmid
                    }
                    # Construction failed AND a type-argument diagnostic was
                    # emitted (unknown/duplicate by validation, or cannot-infer
                    # by inferGenericConstruction): resolve to the template so a
                    # single diagnostic stands without a downstream cascade.
                    if st.typing.errors.length > errB9 then {
                        sttE9: funcId
                        st.typing.nodeType.set key: call.nodeid.u64 value: sttE9
                        return funcId
                    }
                }
                gr: checkGenericCall :st :unitName :unitBody :call :funcId
                result = gr
                if gr > 0 then {
                    setgc: gr
                    st.typing.nodeType.set key: call.nodeid.u64 value: setgc
                }
                if cn.stringview == "panic" then {
                    calid2: nodeId n: call.callable
                    setpk: funcId
                    st.typing.nodeType.set key: calid2.u64 value: setpk
                    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.PANIC
                }
                if cn.stringview == "error" then {
                    calid3: nodeId n: call.callable
                    seter: funcId
                    st.typing.nodeType.set key: calid3.u64 value: seter
                    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.ERROR
                }
            } else {
                giter: call.arguments.iterate
                for garg: giter loop {
                    match (
                        garg
                    ) case namedoperation then {
                        checkValue :st :unitName :unitBody node: garg.operation
                    } else {
                    }
                }
            }
        }
    }
    return result
}

# checkGenericCall -- a call to a generic user function: walk the value args,
# infer the type-param bindings (explicit `param: Type` args, else each value
# arg's materialised type through the parameter it feeds), mint the instance
# (children substituted; return substituted from the recorded `out` placeholder
# name), synthesize the clone scope on first instantiation (empty, named by the
# instance, unreachable per the template body's syntactic divergence -- bodied
# templates only, so native generics like print add no scope), stamp the
# callable with the instance, and resolve to the instance's return. Nested
# control flow inside generic bodies needs a real clone walk and is deferred.
checkGenericCall: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    call: zast.CallData
    funcId: u64
} out u64 is {
    gparams: (List String)
    with gpiter: st.typing.typeGenericArg.iterate do for gp: gpiter loop {
        if gp.parentTypeId == funcId then {
            gpn: gp.paramName.copy
            gparams.append gpn
        }
    }
    pNames: (List String)
    pHolderIds: (List u64)
    {
        gcb9: st.typing.childIndex.get key: funcId
        match (
            gcb9
        ) case some then {
            with gcit9: gcb9.rows.iterate do for gcr9: gcit9 loop {
                tc: st.typing.typeChild.get i: gcr9
                cto: st.typing.childTypeById.get key: tc.childNameId
                match (
                    cto
                ) case some then {
                    pn2: tc.childName.copy
                    pNames.append pn2
                    cto2: cto
                    pHolderIds.append cto2
                } case none then {
                }
            }
        } case none then {}
    }
    pHolders: (List String)
    phi: 0.u64
    phn: pHolderIds.length
    for phi < phn loop {
        hid: pHolderIds.get i: phi
        hn: typeNameOf :st tid: hid
        pHolders.append hn
        phi = phi + 1
    }
    subs: (Map String value: u64)
    posIdx: 0.u64
    aiter: call.arguments.iterate
    for arg: aiter loop {
        match (
            arg
        ) case namedoperation then {
            an2: unitLabel o: arg.name
            isTypeArg: false
            tgi: gparams.iterate
            for gp2: tgi loop {
                if an2.stringview == gp2.stringview then isTypeArg = true
            }
            if isTypeArg then {
                tn3: atomName n: arg.operation
                to3: (walkLookupTyperef
                    ty: st.typing
                    reg: st.reg
                    currentUnit: unitName
                    base: tn3.stringview
                )
                match (
                    to3
                ) case some then {
                    sk: an2.copy
                    sv: to3
                    subs.set key: sk value: sv
                } case none then {
                }
            } else {
                avt: checkValue :st :unitName :unitBody node: arg.operation
                mat: materialiseLiteral :st :unitName t: avt
                holder: ""
                if an2.length > 0 then {
                    hi: 0.u64
                    hn2: pNames.length
                    for hi < hn2 loop {
                        pn3: pNames.get i: hi
                        if an2.stringview == pn3.stringview then {
                            hv: pHolders.get i: hi
                            holder = hv.stringview
                        }
                        hi = hi + 1
                    }
                } else {
                    if posIdx < pHolders.length then {
                        hv2: pHolders.get i: posIdx
                        holder = hv2.stringview
                    }
                }
                posIdx = posIdx + 1
                if holder.length > 0 when mat > 0 then {
                    hk: holder.string
                    hgot: subs.get key: hk
                    match (
                        hgot
                    ) case some then {
                    } case none then {
                        sk2: holder.string
                        sv2: mat
                        subs.set key: sk2 value: sv2
                    }
                }
            }
        } else {
        }
    }
    mname: typeNameOf :st tid: funcId
    if mname.length == 0 then return 0
    allOk: true
    gtk4: genericTypeKey ty: st.typing reg: st.reg tid: funcId
    giter2: gparams.iterate
    for gp3: giter2 loop {
        gv: gp3.stringview
        gk: gv.string
        ggot: subs.get key: gk
        match (
            ggot
        ) case some then {
            (checkConstraintSat
                ty: st.typing
                reg: st.reg
                typeKey: gtk4.stringview
                paramName: gv
                argTid: ggot
            )
            an4: typeNameOf :st tid: ggot
            mname.append s: "_"
            mname.append s: an4.stringview
        } case none then {
            allOk = false
        }
    }
    if allOk == false then return 0
    if gparams.length == 0 then return 0
    wasNew: false
    nk: mname.copy
    ngot: resolveSystemChild ty: st.typing reg: st.reg name: mname.stringview
    match (
        ngot
    ) case some then {
    } case none then {
        wasNew = true
    }
    vsI9: (Map String value: u64)
    mid: (getOrMintSpec
        ty: st.typing
        reg: st.reg
        mainName: unitName
        name: mname.stringview
        templateId: funcId
        :subs
        valSubs: vsI9
        fallbackArg: 0
    )
    rno: st.typing.funcReturnNode.get key: funcId
    match (
        rno
    ) case some then {
        rbn: st.typing.pendingTyperef.get key: rno
        match (
            rbn
        ) case some then {
            rv: rbn.stringview
            rk: rv.string
            rgot2: subs.get key: rk
            match (
                rgot2
            ) case some then {
                st.reg.setReturnType typeId: mid value: rgot2
            } case none then {
                rconc: walkLookupTyperef ty: st.typing reg: st.reg currentUnit: unitName base: rv
                match (
                    rconc
                ) case some then {
                    st.reg.setReturnType typeId: mid value: rconc
                } case none then {
                }
            }
        } case none then {
        }
    } case none then {
    }
    # A generic-instance return (`out (optionval t: u64)`) has no bare
    # pendingTyperef name, so the sub/name path above leaves the mono's
    # return unset -- a native template has no body walk to heal it later.
    # Heal from the template's resolved return type, respecializing a spec
    # that mentions generic params (mirrors the generic-class method path).
    rhas9: false
    {
        mz9: st.reg.typeById.get key: mid
        match (
            mz9
        ) case some then {
            rmo9: mz9.returnTypeId
            match (
                rmo9
            ) case some then {
                rhas9 = true
            } case none then {}
        } case none then {}
    }
    if (rhas9) == false then {
        rto9: 0.u64
        {
            rns9: st.typing.funcReturnNode.get key: funcId
            match (
                rns9
            ) case some then {
                rst9: st.typing.nodeType.get key: rns9
                match (
                    rst9
                ) case some then {
                    rto9 = rst9
                } case none then {}
            } case none then {}
        }
        if rto9 == 0 then {
            tz9: st.reg.typeById.get key: funcId
            match (
                tz9
            ) case some then {
                tro9: tz9.returnTypeId
                match (
                    tro9
                ) case some then {
                    rto9 = tro9
                } case none then {}
            } case none then {}
        }
        if rto9 > 0 then {
            idSubs9: (Map u64 value: u64)
            rr9: (respecialize
                ty: st.typing
                reg: st.reg
                mainName: unitName
                specTid: rto9
                idSubs: idSubs9
            )
            rt9: rto9
            if rr9 > 0 then rt9 = rr9
            if (st.reg.typetypeOf typeId: rt9) != ztypes.ztypetype.GENERIC_PARAM then {
                st.reg.setReturnType typeId: mid value: rt9
            }
        }
    }
    if wasNew then {
        dvo: st.typing.fnBodyDiverges.get key: funcId
        match (
            dvo
        ) case some then {
            csname: "function:\{mname}"
            cm2: st.pushBlock name: csname.stringview
            if dvo then st.markUnreachable
            st.popTo marker: cm2
        } case none then {
        }
    }
    # The arg walk above (checkValue per value arg) can leave a pending
    # borrow from a projection argument (s.stringview): drain it -- the
    # call's result is an OWNED value, so a binding of it must not borrow
    # the argument's source. A view-returning generic native would need to
    # propagate its own borrow here instead.
    drainPendingBorrow :st
    calid2: nodeId n: call.callable
    setc2: mid
    st.typing.nodeType.set key: calid2.u64 value: setc2
    return (optU64Or o: (methodReturnOf :st :mid) d: 0)
}

# subjectAtomName -- a match subject's bare-atom name (narrowing requires a
# simple addressable name): unwrap expression wrappers, "" for dotted/complex
# subjects and numeric atoms.
subjectAtomName: function {n: Node} out String is {
    match (
        n
    ) case expression then {
        return (subjectAtomName n: n.expression)
    } case atomid then {
        if (isNumericLiteralName name: n.name.stringview) then {
            return "".string
        } else {
            return n.name.copy
        }
    } else {
        return "".string
    }
}

# sumSubtypeNames -- a union/variant's arm names: its children minus the
# synthesized members (functions, the tag data record, enums).
sumSubtypeNames: function {st: zenv.ZSymbolTable sid: u64} out List String is {
    names: (List String)
    cids: (List u64)
    bs9: st.typing.childIndex.get key: sid
    match (
        bs9
    ) case some then {
        with rsit9: bs9.rows.iterate do for rsi9: rsit9 loop {
            tc: st.typing.typeChild.get i: rsi9
            cto: st.typing.childTypeById.get key: tc.childNameId
            match (
                cto
            ) case some then {
                nm2: tc.childName.copy
                names.append nm2
                cto2: cto
                cids.append cto2
            } case none then {
            }
        }
    } case none then {}
    arms: (List String)
    i: 0.u64
    n: names.length
    for i < n loop {
        cid: cids.get :i
        tt: st.reg.typetypeOf typeId: cid
        keep: true
        if tt == ztypes.ztypetype.FUNCTION then keep = false
        if tt == ztypes.ztypetype.DATA then keep = false
        if tt == ztypes.ztypetype.TAG then keep = false
        if tt == ztypes.ztypetype.ENUM then keep = false
        if keep then {
            nm3: names.get :i
            nm4: nm3.copy
            arms.append nm4
        }
        i = i + 1
    }
    return arms
}

# lastStmtTypeOpt -- lastStmtType over an optional block (0 when absent).
lastStmtTypeOpt: function {st: zenv.ZSymbolTable bodyOpt: Option Node} out u64 is {
    match (
        bodyOpt
    ) case some then {
        return (lastStmtType :st block: bodyOpt)
    } case none then {
        return 0
    }
}

# checkCase -- walk a match: push the `match` scope, type the subject, push
# `match_body` (resetting the bare-name subject's narrowing), then per arm an
# `arm:{name}` scope with a shadow-narrowing overlay (the subject resolves to
# the arm payload in the body), tracking diverging arms; an else arm excludes
# the covered subtypes. After popping, an exhaustive all-diverging match
# resolves to `never` (a completing-arm result type lands with a value-match
# example) and each diverging arm's subtype is excluded from the subject in
# the enclosing scope (all-excluded marks it unreachable).
checkCase: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    casenode: zast.CaseData
} out u64 is {
    matchMarker: st.pushBlock name: "match"
    subjT: checkValue :st :unitName :unitBody node: casenode.subject
    isSum: false
    if subjT > 0 then {
        stt: st.reg.typetypeOf typeId: subjT
        if stt == ztypes.ztypetype.UNION then isSum = true
        if stt == ztypes.ztypetype.VARIANT then isSum = true
    }
    targetName: "".string
    if isSum then {
        tn: subjectAtomName n: casenode.subject
        targetName = tn
    }
    neverId: 0.u64
    nvOpt: walkLookupTyperef ty: st.typing reg: st.reg currentUnit: unitName base: "never"
    match (
        nvOpt
    ) case some then {
        neverId = nvOpt
    } case none then {
    }
    st.pushBlock name: "match_body"
    if targetName.length > 0 then st.resetNarrowing name: targetName.stringview
    covered: (List String)
    diverging: (List String)
    armTypes: (List u64)
    allDiverge: true
    cliter: casenode.clauses.iterate
    for clause: cliter loop {
        match (
            clause
        ) case caseclause then {
            armName: atomName n: clause.matcharm
            # A value-match literal arm wears the subject's concrete type.
            if (isSum) == false then {
                if (isNumericLiteralName name: armName.stringview) when subjT > 0 then {
                    if (isLiteralTypeId :st tid: subjT) == false then {
                        amid9: nodeId n: clause.matcharm
                        if amid9 > 0 then {
                            seta9: subjT
                            st.typing.nodeType.set key: amid9.u64 value: seta9
                        }
                    }
                }
            }
            asname: "arm:\{armName}"
            armMarker: st.pushBlock name: asname.stringview
            if targetName.length > 0 when subjT > 0 then {
                po: st.typing.childOf parentTypeId: subjT name: armName.stringview
                match (
                    po
                ) case some then {
                    (st.narrow
                        name: targetName.stringview
                        toTypeId: po
                        subtypeName: armName.stringview
                        shadow: true
                    )
                } case none then {
                }
            }
            checkStatement :st :unitName :unitBody block: clause.statement
            at: lastStmtType :st block: clause.statement
            atc: at
            armTypes.append atc
            if at > 0 when at == neverId then {
                dn: armName.copy
                diverging.append dn
            } else {
                allDiverge = false
            }
            cn2: armName.copy
            covered.append cn2
            if st.isUnreachable then st.discardTakenInCurrentScope
            st.popTo marker: armMarker
        } else {
        }
    }
    hasElse: false
    match (
        casenode.elseclause
    ) case some then {
        hasElse = true
    } case none then {
    }
    if hasElse then {
        elseMarker: st.pushBlock name: "arm:else"
        if targetName.length > 0 when subjT > 0 then {
            eiter: covered.iterate
            for en2: eiter loop {
                st.exclude name: targetName.stringview subtypeName: en2.stringview fullTypeId: subjT
            }
        }
        walkBody :st :unitName :unitBody bodyOpt: casenode.elseclause
        et: lastStmtTypeOpt :st bodyOpt: casenode.elseclause
        armTypes.append et
        if st.isUnreachable then st.discardTakenInCurrentScope
        st.popTo marker: elseMarker
    }
    st.popTo marker: matchMarker
    exhaustive: hasElse
    if (exhaustive) == false then {
        if isSum then {
            arms2: sumSubtypeNames :st sid: subjT
            allCovered: true
            a2iter: arms2.iterate
            for an3: a2iter loop {
                found: false
                c2iter: covered.iterate
                for cn3: c2iter loop {
                    if an3.stringview == cn3.stringview then found = true
                }
                if (found) == false then allCovered = false
            }
            exhaustive = allCovered
        }
    }
    if targetName.length > 0 when subjT > 0 then {
        diter: diverging.iterate
        for dn2: diter loop {
            st.exclude name: targetName.stringview subtypeName: dn2.stringview fullTypeId: subjT
        }
    }
    if exhaustive when allDiverge when neverId > 0 then {
        if casenode.clauses.length > 0 then {
            setn2: neverId
            st.typing.nodeType.set key: casenode.nodeid.u64 value: setn2
            return neverId
        } else {
            return 0
        }
    }
    if exhaustive then {
        # the first completing (non-diverging) arm's type is the match value;
        # an untyped completing arm leaves the match unstamped.
        ti: 0.u64
        tn4: armTypes.length
        for ti < tn4 loop {
            at2: armTypes.get i: ti
            if at2 != neverId then {
                if at2 > 0 then {
                    setc3: at2
                    st.typing.nodeType.set key: casenode.nodeid.u64 value: setc3
                    return at2
                } else {
                    return 0
                }
            }
            ti = ti + 1
        }
        return 0
    } else {
        return 0
    }
}

# checkValue -- type an expression-value node, dispatching by kind. Returns the
# resolved type id, or 0 when unhandled.
checkValue: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    node: Node
} out u64 is {
    match (
        node
    ) case call then {
        return (checkCall :st :unitName :unitBody call: node)
    } case binop then {
        return (checkBinop :st :unitName :unitBody binop: node)
    } case atomid then {
        return (checkAtomid :st :unitName :unitBody :node)
    } case atomstring then {
        return (checkString :st :unitName :unitBody :node)
    } case dottedpath then {
        return (checkDotted :st :unitName :unitBody dp: node coerce: true)
    } case caseexpr then {
        return (checkCase :st :unitName :unitBody casenode: node)
    } case ifexpr then {
        return (checkIf :st :unitName :unitBody ifnode: node)
    } case forexpr then {
        return (checkFor :st :unitName :unitBody fornode: node)
    } case labelvalue then {
        # the `:x` shorthand in value position reads the local x
        lvo9: st.lookup name: node.name.stringview
        match (
            lvo9
        ) case some then {
            setlv9: lvo9
            st.typing.nodeType.set key: node.nodeid.u64 value: setlv9
            lvv9: st.lookupVarId name: node.name.stringview
            match (
                lvv9
            ) case some then {
                setlvv9: lvv9
                st.typing.atomVariableId.set key: node.nodeid.u64 value: setlvv9
            } case none then {}
            return lvo9
        } case none then {
            return 0
        }
    } case yieldexpr then {
        # a suspension point: the yielded value walks for diagnostics. A
        # bidirectional generator's yield carries the resumed value -- the
        # synth `.call`'s `value` parameter's type (the node itself stays
        # unstamped; the expression wrapper takes the type). A reftype
        # resume value is a borrow into the caller's argument: the
        # surrounding binding becomes BORROWED origin value.
        checkValue :st :unitName :unitBody node: node.expr
        yvo: st.lookup name: "value"
        match (
            yvo
        ) case some then {
            if (typeIsReftype :st tid: yvo) then {
                drainPendingBorrow :st
                yvc: "value".string
                st.typing.pendingBorrowPath.append yvc
            }
            return yvo
        } case none then {
            return 0
        }
    } case doexpr then {
        return (checkDo :st :unitName :unitBody donode: node)
    } case withexpr then {
        return (checkWith :st :unitName :unitBody withnode: node)
    } case reassignment then {
        checkReassignment :st :unitName :unitBody rasgn: node
        return 0
    } case swapstmt then {
        checkSwap :st :unitName :unitBody swapnode: node
        return 0
    } case expression then {
        t: checkValue :st :unitName :unitBody node: node.expression
        if t > 0 then stampGate :st nid: node.nodeid tid: t
        return t
    } else {
        return 0
    }
}

# checkExpression -- type an expression wrapper from its inner value; returns
# true when the inner is a return terminator (so the caller marks the scope
# unreachable).
checkExpression: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    expr: zast.ExpressionData
} out bool is {
    isRet: false
    t: checkValue :st :unitName :unitBody node: expr.expression
    if t > 0 then st.typing.nodeType.set key: expr.nodeid.u64 value: t
    innerNid: nodeId n: expr.expression
    ckOpt: st.typing.callKind.get key: innerNid.u64
    isRet = isReturnCallKind o: ckOpt
    return isRet
}

# checkStmtInner -- dispatch a statement line's inner node (C1: expressions).
checkStmtInner: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    inner: Node
} out bool is {
    match (
        inner
    ) case expression then {
        isR0: checkExpression :st :unitName :unitBody expr: inner
        bn0: bareAtomName n: inner.expression
        if bn0.stringview == "break" then isR0 = true
        if bn0.stringview == "continue" then isR0 = true
        return isR0
    } case assignment then {
        checkAssignment :st :unitName :unitBody asgn: inner
        return false
    } case reassignment then {
        checkReassignment :st :unitName :unitBody rasgn: inner
        return false
    } else {
        return false
    }
}

# checkStatementLine -- type a statement line; propagate the inner type to the
# line wrapper. Returns true for a return terminator.
checkStatementLine: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    sline: Node
} out bool is {
    isRet: false
    match (
        sline
    ) case statementline then {
        isRet = checkStmtInner :st :unitName :unitBody inner: sline.statementline
        inid: nodeId n: sline.statementline
        itOpt: st.typing.nodeType.get key: inid.u64
        match (
            itOpt
        ) case some then {
            st.typing.nodeType.set key: sline.nodeid.u64 value: itOpt
        } case none then {
        }
    } else {
    }
    return isRet
}

# checkStatement -- walk a function-body statement block, marking the scope
# unreachable after a control-flow terminator (return).
checkStatement: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    block: Node
} is {
    match (
        block
    ) case statement then {
        siter: block.statements.iterate
        for sline: siter loop {
            isRet: checkStatementLine :st :unitName :unitBody :sline
            drainPendingBorrow :st
            if isRet then st.markUnreachable
        }
    } else {
    }
}

# walkBody -- walk an optional function body (none for spec methods).
walkBody: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    bodyOpt: Option Node
} is {
    match (
        bodyOpt
    ) case some then {
        checkStatement :st :unitName :unitBody block: bodyOpt
    } case none then {
    }
}

# nodeIsFunctiondef -- kind test that keeps the caller's un-narrowed handle.
nodeIsFunctiondef: function {o: Node} out bool is {
    match (
        o
    ) case functiondef then {
        return true
    } else {
        return false
    }
}

# objectdefIsGeneric -- a type definition with a generic as-block parameter;
# generic templates are never body-walked (instances clone at call sites).
objectdefIsGeneric: function {o: Node} out bool is {
    match (
        o
    ) case objectdef then {
        return (hasGenericParam items: o.asItems)
    } else {
        return false
    }
}

# scanTypeNameOpt -- recurse the method-walk trigger into an optional typeref
# (a function's return type).
scanTypeNameOpt: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    o: Option Node
} is {
    match (
        o
    ) case some then {
        bn: baseTypeName n: o
        if bn.length > 0 then maybeWalkMethods :st :unitName :unitBody name: bn.stringview
    } case none then {
    }
}

# scanFnSig -- recurse the method-walk trigger through a function signature in
# resolution order: the return type first, then parameters in declaration order.
scanFnSig: function {st: zenv.ZSymbolTable unitName: StringView unitBody: List Node op: Node} is {
    match (
        op
    ) case functiondef then {
        scanTypeNameOpt :st :unitName :unitBody o: op.returntype
        piter: op.parameters.iterate
        for pm: piter loop {
            match (
                pm
            ) case namedoperation then {
                bn: baseTypeName n: pm.operation
                if bn.length > 0 then maybeWalkMethods :st :unitName :unitBody name: bn.stringview
            } else {
            }
        }
    } else {
    }
}

# scanMemberSignatures -- replay one definition's signature-resolution order:
# an objectdef resolves its field typerefs, then its is- and as-block method
# signatures; a function resolves its own signature. Each name recurses the
# trigger, so transitively referenced types walk their methods first.
scanMemberSignatures: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    op: Node
} is {
    if (nodeIsFunctiondef o: op) then {
        scanFnSig :st :unitName :unitBody :op
    } else {
        match (
            op
        ) case objectdef then {
            with fiter: op.isItems.iterate do for fm: fiter loop {
                match (
                    fm
                ) case namedoperation then {
                    if (nodeIsFunctiondef o: fm.operation) == false then {
                        bn: baseTypeName n: fm.operation
                        if bn.length > 0 then {
                            maybeWalkMethods :st :unitName :unitBody name: bn.stringview
                        }
                    }
                } else {
                }
            }
            with iiter: op.isItems.iterate do for im: iiter loop {
                match (
                    im
                ) case namedoperation then {
                    scanFnSig :st :unitName :unitBody op: im.operation
                } else {
                }
            }
            with aiter: op.asItems.iterate do for am: aiter loop {
                match (
                    am
                ) case namedoperation then {
                    scanFnSig :st :unitName :unitBody op: am.operation
                } else {
                }
            }
        } else {
        }
    }
}

# maybeWalkMethods -- the resolution-time method-walk trigger: the first time
# a body walk resolves a main-unit definition's name, replay the reference
# resolver's side effects at the current scope position -- scan the signature
# typerefs (recursing per name), then body-check the type's methods. The
# early mark stops re-entry (a method constructing its own type).
maybeWalkMethods: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    name: StringView
} is {
    nk: name.string
    got: st.typing.walkedMethodOwners.get key: nk
    match (
        got
    ) case some then {
        return
    } case none then {
    }
    io: st.typing.mainMemberIndex.get key: nk
    idx: 0.u64
    match (
        io
    ) case some then {
        idx = io
    } case none then {
        return
    }
    mv: true
    st.typing.walkedMethodOwners.set key: nk value: mv
    mem: unitBody.get i: idx
    match (
        mem
    ) case namedoperation then {
        scanMemberSignatures :st :unitName :unitBody op: mem.operation
        canWalk: objectdefHasMethodBodies op: mem.operation
        if canWalk then {
            prev: st.typing.synthLabel.copy
            prevThis: st.typing.currentThisName.copy
            checkMethodBodies :st :unitName :unitBody typeName: name op: mem.operation
            st.typing.synthLabel = prev
            st.typing.currentThisName = prevThis
        }
        rko: "\{unitName}.\{name}"
        rgo9: resolvedByKey ty: st.typing reg: st.reg key: rko
        match (
            rgo9
        ) case some then {
            runUnitMonoWalks :st :unitName :unitBody monoId: rgo9
        } case none then {}
    } else {
    }
}

# objectdefHasMethodBodies -- a unit member whose operation is an objectdef
# with at least one functiondef-with-body item.
objectdefHasMethodBodies: function {op: Node} out bool is {
    match (
        op
    ) case objectdef then {
        iiter: op.isItems.iterate
        for im: iiter loop {
            match (
                im
            ) case namedoperation then {
                if (isFunctionDefWithBody o: im.operation) then return true
            } else {
            }
        }
        aiter: op.asItems.iterate
        for am: aiter loop {
            match (
                am
            ) case namedoperation then {
                if (isFunctionDefWithBody o: am.operation) then return true
            } else {
            }
        }
        return false
    } else {
        return false
    }
}

# checkMethodBodies -- body-check every method of one type definition (is- and
# as-block functiondefs, declaration order). The scopes land under the walk's
# current scope, mirroring the oracle's resolve-at-first-demand placement.
checkMethodBodies: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    typeName: StringView
    op: Node
} is {
    match (
        op
    ) case objectdef then {
        iiter: op.isItems.iterate
        for im: iiter loop {
            match (
                im
            ) case namedoperation then {
                if (isFunctionDefWithBody o: im.operation) then {
                    mname: unitLabel o: im.name
                    qn: "\{typeName}.\{mname}"
                    ed7: (List Node)
                    (checkFunctionBody
                        :st
                        :unitName
                        defName: qn.stringview
                        defn: im.operation
                        thisName: typeName
                        :unitBody
                        depUnits: ed7
                    )
                }
            } else {
            }
        }
        aiter: op.asItems.iterate
        for am: aiter loop {
            match (
                am
            ) case namedoperation then {
                if (isFunctionDefWithBody o: am.operation) then {
                    mname2: unitLabel o: am.name
                    qn2: "\{typeName}.\{mname2}"
                    ed6: (List Node)
                    (checkFunctionBody
                        :st
                        :unitName
                        defName: qn2.stringview
                        defn: am.operation
                        thisName: typeName
                        :unitBody
                        depUnits: ed6
                    )
                }
            } else {
            }
        }
    } else {
    }
}

# lastStmtLineId / lastStmtLineIdOpt -- the node id of a function body's last
# statement line (the implicit-return position), or 0 when absent.
lastStmtLineId: function {block: Node} out u32 is {
    match (
        block
    ) case statement then {
        ne: block.statements.length
        if ne > 0 then {
            last: block.statements.get i: (ne - 1)
            match (
                last
            ) case statementline then {
                return last.nodeid
            } else {
            }
        }
    } else {
    }
    return 0
}

lastStmtLineIdOpt: function {o: Option Node} out u32 is {
    match (
        o
    ) case some then {
        return (lastStmtLineId block: o)
    } case none then {
        return 0
    }
}

# checkFunctionBody -- type-check one function body. Pushes a scope, binds each
# parameter as a runtime variable, walks the body, then pops (the pop snapshots
# the scope's entries + unreachable flag for the SQL dump).
checkFunctionBody: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    defName: StringView
    defn: Node
    thisName: StringView
    unitBody: List Node
    depUnits: List Node
} is {
    match (
        defn
    ) case functiondef then {
        maybeWalkMethods :st :unitName :unitBody name: defName
        hasBody: false
        match (
            defn.body
        ) case some then {
            hasBody = true
        } case none then {
        }
        isGenDef: false
        rkey: "\{unitName}.\{defName}"
        rgot: resolvedByKey ty: st.typing reg: st.reg key: rkey
        match (
            rgot
        ) case some then {
            {
                gz: st.reg.typeById.get key: rgot
                match (
                    gz
                ) case some then {
                    if gz.isgeneric then isGenDef = true
                } case none then {
                }
            }
        } case none then {
        }
        if hasBody then {
            # A generic template body is checked ONCE, for diagnostics; the
            # emitter re-walks the shared AST per instance, so
            # GENERIC_PARAM-valued stamps are suppressed for the walk (and
            # its scopes/entries stay out of the dump log).
            prevSup9: st.typing.suppressParamStamps
            if isGenDef then st.typing.suppressParamStamps = true
            sname: "function:\{defName}"
            st.push name: sname.stringview
            piter: defn.parameters.iterate
            for pm: piter loop {
                match (
                    pm
                ) case namedoperation then {
                    pname: unitLabel o: pm.name
                    pnid: nodeId n: pm.operation
                    ptid: paramTypeId typing: st.typing reg: st.reg :unitName op: pm.operation
                    if ptid == 0 when isGenDef then {
                        # a template's own bare param carries no stamp; bind
                        # the canonical param tid from the FUNCTION child so
                        # the walk types it (stampGate suppresses the stamp)
                        fgo3: resolvedByKey ty: st.typing reg: st.reg key: rkey
                        match (
                            fgo3
                        ) case some then {
                            fco3: st.typing.childOf parentTypeId: fgo3 name: pname.stringview
                            match (
                                fco3
                            ) case some then {
                                if (st.reg.typetypeOf typeId: fco3) == ztypes.ztypetype.GENERIC_PARAM then {
                                    ptid = fco3
                                }
                            } case none then {}
                        } case none then {}
                    }
                    if ptid > 0 then {
                        noSt: optBoolOr o: (st.typing.noStampNode.get key: pnid.u64) d: false
                        if (noSt) == false then {
                            ppre: st.typing.nodeType.get key: pnid.u64
                            match (
                                ppre
                            ) case some then {
                            } case none then {
                                setpp: ptid
                                stampGate :st nid: pnid tid: setpp
                            }
                        }
                    }
                    if thisName.length > 0 when (paramIsThisReceiver op: pm.operation) then {
                        thOpt: (walkLookupTyperef
                            ty: st.typing
                            reg: st.reg
                            currentUnit: unitName
                            base: thisName
                        )
                        match (
                            thOpt
                        ) case some then {
                            ptid = thOpt
                        } case none then {
                        }
                    }
                    pown9: pathOwnership n: pm.operation
                    isLockP9: false
                    match (
                        pown9
                    ) case some then {
                        if pown9 == ztypes.zparamownership.LOCK then isLockP9 = true
                    } case none then {
                    }
                    isGenP9: false
                    if (st.reg.typetypeOf typeId: ptid) == ztypes.ztypetype.GENERIC_PARAM then isGenP9 = true
                    if isLockP9 when (paramIsThisReceiver op: pm.operation) == false when (typeIsValtype
                        ty: st.typing
                        reg: st.reg
                        tid: ptid
                    ) when (isGenP9) == false then {
                        ptn9: typeNameOf :st tid: ptid
                        ptnc9: ptn9.copy
                        pnc9: pname.copy
                        plln9: nodeLine n: pm.operation
                        plcl9: nodeCol n: pm.operation
                        ml9: "Cannot use '.lock' on valtype parameter '\{pnc9}' (type '\{ptnc9}') — locking requires identity (use a class)"
                        (addError
                            :st
                            nodeid: pnid
                            lineno: plln9
                            colno: plcl9
                            e: zast.err.OWNERERROR
                            msg: ml9
                        )
                    }
                    own: ownershipOfParam o: (pathOwnership n: pm.operation)
                    v: st.reg.newVariable ztypeId: ptid ownership: own
                    vid2: v.variableId
                    st.defineVar name: pname.stringview var: v
                    st.typing.defVariableId.set key: pnid.u64 value: vid2
                } else {
                }
            }
            # Synth rows carry the unit member's dump label: a method's nodes
            # live inside its TYPE's subtree, so the label is the type name.
            # Nested method walks save and restore it around their bodies.
            lbl: "\{unitName}.\{defName}"
            if thisName.length > 0 then lbl = "\{unitName}.\{thisName}"
            st.typing.synthLabel = lbl
            tnl: thisName.string
            st.typing.currentThisName = tnl
            if depUnits.length > 0 then runDepUnitWalks :st mainName: unitName :depUnits
            prevRet9: st.typing.currentReturnTypeId
            fitid9: optU64Or o: (resolvedByKey ty: st.typing reg: st.reg key: rkey) d: 0
            crt9: 0.u64
            if fitid9 > 0 then crt9 = optU64Or o: (methodReturnOf :st mid: fitid9) d: 0
            st.typing.currentReturnTypeId = crt9
            prevRb9: st.typing.currentReturnsBorrow
            st.typing.currentReturnsBorrow = (optBoolOr
                o: (st.typing.funcReturnsBorrow.get key: fitid9)
                d: false
            )
            walkBody :st :unitName :unitBody bodyOpt: defn.body
            st.typing.currentReturnTypeId = prevRet9
            st.typing.currentReturnsBorrow = prevRb9
            # Implicit-return coercion: a literal-typed last statement takes
            # the function's concrete return type, stamped on the statement
            # line (the node the reference coerces by id).
            ftid: 0.u64
            ftid = optU64Or o: (resolvedByKey ty: st.typing reg: st.reg key: rkey) d: ftid
            if ftid > 0 then {
                ro: methodReturnOf :st mid: ftid
                match (
                    ro
                ) case some then {
                    lsid: lastStmtLineIdOpt o: defn.body
                    if lsid > 0 then {
                        cur: st.typing.nodeType.get key: lsid.u64
                        match (
                            cur
                        ) case some then {
                            if (isLiteralTypeId :st tid: cur) then stampGate :st nid: lsid tid: ro
                        } case none then {
                        }
                    }
                } case none then {
                }
            }
            st.pop
            st.typing.suppressParamStamps = prevSup9
        }
    } else {
    }
}

# runDepUnitWalks -- full-mode dependency-unit body walks: the reference
# checks a demanded user unit's function bodies on first touch, inside the
# using function's scope. Walks every resolved function-with-body member of
# each non-system dependency unit, scoped function:{unit}.{fn}.
runDepUnitWalks: function {st: zenv.ZSymbolTable mainName: StringView depUnits: List Node} is {
    diter: depUnits.iterate
    for du: diter loop {
        match (
            du
        ) case namedoperation then {
            dn: unitLabel o: du.name
            isKnownD: false
            if dn.stringview == mainName then isKnownD = true
            if dn.stringview == "io" then isKnownD = true
            if dn.stringview == "collections" then isKnownD = true
            if dn.stringview == "system" then isKnownD = true
            if dn.stringview == "core" then isKnownD = true
            if dn.stringview == "os" then isKnownD = true
            if dn.stringview == "cli" then isKnownD = true
            if (isKnownD) == false then depWalkUnit :st depName: dn.stringview unitOp: du.operation
        } else {
        }
    }
}

# depWalkUnit -- walk one dependency unit's resolved function bodies (two
# passes: indices first, so the body list is free for the walk itself).
depWalkUnit: function {st: zenv.ZSymbolTable depName: StringView unitOp: Node} is {
    match (
        unitOp
    ) case unitdef then {
        if (hasGenericParam items: unitOp.body) then return
        emptyD: (List Node)
        idxs: (List u64)
        di0: 0.u64
        with biter: unitOp.body.iterate do for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                if (isFunctionDefWithBody o: bm.operation) then {
                    dv0: di0
                    idxs.append dv0
                } else {
                    hasm0: objectdefHasMethodBodies op: bm.operation
                    if hasm0 when (objectdefIsGeneric o: bm.operation) then hasm0 = false
                    if hasm0 then {
                        dv1: di0
                        idxs.append dv1
                    }
                }
            } else {}
            di0 = di0 + 1
        }
        wi: 0.u64
        for wi < idxs.length loop {
            bidx: idxs.get i: wi
            bm2: unitOp.body.get i: bidx
            match (
                bm2
            ) case namedoperation then {
                if (isFunctionDefWithBody o: bm2.operation) then {
                    fn: unitLabel o: bm2.name
                    rk: "\{depName}.\{fn}"
                    rgo: resolvedByKey ty: st.typing reg: st.reg key: rk
                    match (
                        rgo
                    ) case some then {
                        walked: optBoolOr o: (st.typing.walkedMethodOwners.get key: rk) d: false
                        if (walked) == false then {
                            wv: true
                            wk2: "\{depName}.\{fn}"
                            st.typing.walkedMethodOwners.set key: wk2 value: wv
                            dq: "\{depName}.\{fn}"
                            (checkFunctionBody
                                :st
                                unitName: depName
                                defName: dq.stringview
                                defn: bm2.operation
                                thisName: ""
                                unitBody: unitOp.body
                                depUnits: emptyD
                            )
                        }
                    } case none then {}
                } else {
                    cls: unitLabel o: bm2.name
                    crk: "\{depName}.\{cls}"
                    crgo: resolvedByKey ty: st.typing reg: st.reg key: crk
                    match (
                        crgo
                    ) case some then {
                        cwalked: optBoolOr o: (st.typing.walkedMethodOwners.get key: crk) d: false
                        if (cwalked) == false then {
                            cwv: true
                            cwk: "\{depName}.\{cls}"
                            st.typing.walkedMethodOwners.set key: cwk value: cwv
                            cprev: st.typing.synthLabel.copy
                            cprevThis: st.typing.currentThisName.copy
                            (checkMethodBodies
                                :st
                                unitName: depName
                                unitBody: unitOp.body
                                typeName: cls.stringview
                                op: bm2.operation
                            )
                            st.typing.synthLabel = cprev
                            st.typing.currentThisName = cprevThis
                        }
                    } case none then {}
                }
            } else {}
            wi = wi + 1
        }
    } else {}
}

# checkUnitBodies -- walk every function definition with a body in one unit.
checkUnitBodies: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitdef: Node
    depUnits: List Node
} is {
    match (
        unitdef
    ) case unitdef then {
        emptyDeps9: (List Node)
        mi: 0.u64
        with niter: unitdef.body.iterate do for nm: niter loop {
            match (
                nm
            ) case namedoperation then {
                mnm: unitLabel o: nm.name
                miv: mi
                st.typing.mainMemberIndex.set key: mnm value: miv
            } else {
            }
            mi = mi + 1
        }
        with miter: unitdef.body.iterate do for mm: miter loop {
            match (
                mm
            ) case namedoperation then {
                mainName: unitLabel o: mm.name
                if mainName.stringview == "main" then {
                    (checkFunctionBody
                        :st
                        :unitName
                        defName: mainName.stringview
                        defn: mm.operation
                        thisName: ""
                        unitBody: unitdef.body
                        :depUnits
                    )
                }
            } else {
            }
        }
        with biter: unitdef.body.iterate do for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                defName: unitLabel o: bm.name
                if defName.stringview != "main" then {
                    (checkFunctionBody
                        :st
                        :unitName
                        defName: defName.stringview
                        defn: bm.operation
                        thisName: ""
                        unitBody: unitdef.body
                        depUnits: emptyDeps9
                    )
                }
            } else {
            }
        }
    } else {
    }
}

# checkBodies -- the body-walk pass (full mode), mirroring check()'s top-level
# loop: walk the main unit's function bodies, main first, then the others in
# body order. Runs after demand resolution so referenced types are already
# resolved.
checkBodies: function {st: zenv.ZSymbolTable program: Node} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        mainIdx: 0.u64
        found0: false
        i0: 0.u64
        with uiter: program.units.iterate do for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                nm: unitLabel o: u.name
                if nm.stringview == mainName then {
                    if (found0) == false then {
                        mainIdx = i0
                        found0 = true
                    }
                }
            } else {
            }
            i0 = i0 + 1
        }
        if found0 then {
            mu: program.units.get i: mainIdx
            match (
                mu
            ) case namedoperation then {
                checkUnitBodies :st unitName: mainName unitdef: mu.operation depUnits: program.units
            } else {
            }
        }
    } else {
    }
}

# foldLiteralStamps -- replace literal-typed node stamps with their concrete
# defaults (i64 / f64) after the body walk: the unregistered pseudo ids and the
# data blocks' registered literal_int/literal_float element shells. Symbol-table
# entries keep their literal ids (the oracle's entry/variable rows read
# literal_int there too).
foldLiteralStamps: function {st: zenv.ZSymbolTable program: Node} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        intId: 0.u64
        li: walkLookupTyperef ty: st.typing reg: st.reg currentUnit: mainName base: "i64"
        match (
            li
        ) case some then {
            intId = li
        } case none then {
        }
        floatId: 0.u64
        lf: walkLookupTyperef ty: st.typing reg: st.reg currentUnit: mainName base: "f64"
        match (
            lf
        ) case some then {
            floatId = lf
        } case none then {
        }
        intShells: (List u64)
        floatShells: (List u64)
        nshell: st.reg.nextTypeId
        ti: 0.u64
        for ti < nshell loop {
            snm: typeNameOf :st tid: ti
            if snm.stringview == "literal_int" then {
                sid: ti
                intShells.append sid
            } else {
                if snm.stringview == "literal_float" then {
                    sid2: ti
                    floatShells.append sid2
                }
            }
            ti = ti + 1
        }
        iks: (List u64)
        fks: (List u64)
        with it: st.typing.nodeType.iterateItems do for e: it loop {
            isInt: e.value == literalIntId
            if (intShells.contains item: e.value) then isInt = true
            isFloat: e.value == literalFloatId
            if (floatShells.contains item: e.value) then isFloat = true
            if isInt then {
                k: e.key
                iks.append k
            }
            if isFloat then {
                k2: e.key
                fks.append k2
            }
        }
        if intId > 0 then {
            kiter: iks.iterate
            for k3: kiter loop {
                kc: k3
                setv: intId
                st.typing.nodeType.set key: kc value: setv
            }
        }
        if floatId > 0 then {
            fiter: fks.iterate
            for k4: fiter loop {
                kc2: k4
                setv2: floatId
                st.typing.nodeType.set key: kc2 value: setv2
            }
        }
    } else {
    }
}

# isBinopNode -- kind test without narrowing (the caller keeps the Node handle).
isBinopNode: function {n: Node} out bool is {
    match (
        n
    ) case binop then {
        return true
    } else {
        return false
    }
}

# constantOperandType -- type one operand of a unit-level constant expression,
# stamping as it walks: a numeric literal wears the pseudo id (folded to its
# visible default later), a name reads an already-materialised constant from
# resolved (body order), and a binop takes the first concretely-typed operand
# (else the literal pseudo). 0 = not a constant shape.
constantOperandType: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    n: Node
} out u64 is {
    match (
        n
    ) case expression then {
        return (constantOperandType :ty :reg :mainName n: n.expression)
    } case atomid then {
        result: 0.u64
        if (isNumericLiteralName name: n.name.stringview) then {
            if (isFloatLiteralName name: n.name.stringview) then {
                result = literalFloatId
            } else {
                result = literalIntId
            }
        } else {
            ro: walkLookupTyperef :ty :reg currentUnit: mainName base: n.name.stringview
            match (
                ro
            ) case some then {
                result = ro
            } case none then {
            }
        }
        if result > 0 then {
            seto: result
            ty.nodeType.set key: n.nodeid.u64 value: seto
        }
        return result
    } case binop then {
        lt: constantOperandType :ty :reg :mainName n: n.lhs
        rt: constantOperandType :ty :reg :mainName n: n.rhs
        opn9: atomName n: n.operator
        if (isComparisonOp name: opn9.stringview) then {
            # A comparison condition: the result is bool and a literal
            # operand coerces (restamps) at the concrete side's type.
            lLit: false
            if lt == literalIntId then lLit = true
            if lt == literalFloatId then lLit = true
            rLit: false
            if rt == literalIntId then rLit = true
            if rt == literalFloatId then rLit = true
            conc: 0.u64
            if (lLit) == false then {
                if lt > 0 then conc = lt
            }
            if conc == 0 then {
                if (rLit) == false then {
                    if rt > 0 then conc = rt
                }
            }
            if lLit when conc > 0 then {
                lid9: innermostNodeId n: n.lhs
                if lid9 > 0 then {
                    setl9: conc
                    ty.nodeType.set key: lid9.u64 value: setl9
                }
            }
            if rLit when conc > 0 then {
                rid9: innermostNodeId n: n.rhs
                if rid9 > 0 then {
                    setr9: conc
                    ty.nodeType.set key: rid9.u64 value: setr9
                }
            }
            bres9: 0.u64
            bo9: walkLookupTyperef :ty :reg currentUnit: mainName base: "bool"
            match (
                bo9
            ) case some then {
                bres9 = bo9
                setb9: bres9
                ty.nodeType.set key: n.nodeid.u64 value: setb9
            } case none then {
            }
            return bres9
        }
        result: lt
        if lt == 0 then result = rt
        if lt == literalIntId then {
            if rt > 0 when rt != literalIntId when rt != literalFloatId then result = rt
        }
        if lt == literalFloatId then {
            if rt > 0 when rt != literalIntId when rt != literalFloatId then result = rt
        }
        if result > 0 then {
            setb: result
            ty.nodeType.set key: n.nodeid.u64 value: setb
        }
        return result
    } else {
        return 0
    }
}

# constantBranchWalk -- walk one unit-level-if branch block: each statement's
# expression types through the constant walk; literal results materialise to
# their defaults (i64/f64) on the statement, its expression wrapper, and the
# atom. Returns the (materialised) last-statement type.
constantBranchWalk: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    block: Node
} out u64 is {
    match (
        block
    ) case statement then {
        result: 0.u64
        siter: block.statements.iterate
        for s9: siter loop {
            match (
                s9
            ) case statementline then {
                bt0: constantOperandType :ty :reg :mainName n: s9.statementline
                mt0: 0.u64
                if bt0 == literalIntId then {
                    mt0 = (optU64Or
                        o: (walkLookupTyperef :ty :reg currentUnit: mainName base: "i64")
                        d: 0
                    )
                }
                if bt0 == literalFloatId then {
                    mt0 = (optU64Or
                        o: (walkLookupTyperef :ty :reg currentUnit: mainName base: "f64")
                        d: 0
                    )
                }
                if mt0 > 0 then {
                    sets0: mt0
                    ty.nodeType.set key: s9.nodeid.u64 value: sets0
                    eid0: nodeId n: s9.statementline
                    if eid0 > 0 then {
                        sete0: mt0
                        ty.nodeType.set key: eid0.u64 value: sete0
                    }
                    iid0: innermostNodeId n: s9.statementline
                    if iid0 > 0 then {
                        seti0: mt0
                        ty.nodeType.set key: iid0.u64 value: seti0
                    }
                    result = mt0
                } else {
                    if bt0 > 0 then {
                        sets1: bt0
                        ty.nodeType.set key: s9.nodeid.u64 value: sets1
                        result = bt0
                    }
                }
            } else {
            }
        }
        return result
    } else {
        return 0
    }
}

# constantBranchWalkOpt -- constantBranchWalk over an optional block.
constantBranchWalkOpt: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    bodyOpt: Option Node
} out u64 is {
    match (
        bodyOpt
    ) case some then {
        return (constantBranchWalk :ty :reg :mainName block: bodyOpt)
    } case none then {
        return 0
    }
}

# resolveUnitIfDef -- a unit-level `if` definition (compile-time conditional):
# conditions walk through the constant machinery (comparisons stamp bool and
# coerce literal operands), branches walk + materialise, and the definition
# resolves to the first branch's type -- stamped on the If, its Expression
# wrapper, and resolved[unit.name].
resolveUnitIfDef: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    defName: StringView
    wrapperId: u32
    n: Node
} is {
    match (
        n
    ) case ifexpr then {
        t9: 0.u64
        cliter: n.clauses.iterate
        for clause: cliter loop {
            match (
                clause
            ) case ifclause then {
                coiter: clause.conditions.iterate
                for cond: coiter loop {
                    match (
                        cond
                    ) case namedoperation then {
                        constantOperandType :ty :reg :mainName n: cond.operation
                    } else {
                    }
                }
                bt9: constantBranchWalk :ty :reg :mainName block: clause.statement
                if t9 == 0 then t9 = bt9
            } else {
            }
        }
        et9: constantBranchWalkOpt :ty :reg :mainName bodyOpt: n.elseclause
        if t9 == 0 then t9 = et9
        if t9 > 0 then {
            setw9: t9
            ty.nodeType.set key: wrapperId.u64 value: setw9
            seti9: t9
            ty.nodeType.set key: n.nodeid.u64 value: seti9
            cu9: reg.unitNameTid.get key: mainName.string
            match (
                cu9
            ) case some then {
                ty.setChild parentTypeId: cu9 childName: defName childTypeId: t9
            } case none then {}
        }
    } else {
    }
}

# resolveConstantDef -- one definition: an (expression-wrapped) numeric-literal
# atomid is a unit constant. Record resolved[unit.name] as the literal's concrete
# default (i64 / f64 -- both pre-demanded by seedSystemDemands). The definition's
# own nodes stay unstamped: the oracle's stamps there carry its unregistered
# literal pseudo-type (NULL in the dump), invisible to every projection.
resolveConstantDef: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    defName: StringView
    defn: Node
} is {
    match (
        defn
    ) case expression then {
        resolveUnitIfDef :ty :reg :mainName :defName wrapperId: defn.nodeid n: defn.expression
        resolveConstantDef :ty :reg :mainName :defName defn: defn.expression
    } case atomid then {
        if (isNumericLiteralName name: defn.name.stringview) then {
            base: "i64"
            if (isFloatLiteralName name: defn.name.stringview) then base = "f64"
            tOpt: walkLookupTyperef :ty :reg currentUnit: mainName :base
            match (
                tOpt
            ) case some then {
                cu: reg.unitNameTid.get key: mainName.string
                match (
                    cu
                ) case some then {
                    ty.setChild parentTypeId: cu childName: defName childTypeId: tOpt
                } case none then {}
            } case none then {
            }
        }
    } else {
        if (isBinopNode n: defn) then {
            # A constant expression (`COMBINED: OFFSET + SCALE`): the operand
            # walk stamps the refs and the binop; a literal result materialises
            # to its default, a concrete one (an already-materialised constant)
            # keeps it.
            bt: constantOperandType :ty :reg :mainName n: defn
            base2: ""
            if bt == literalIntId then base2 = "i64"
            if bt == literalFloatId then base2 = "f64"
            if base2.length > 0 then {
                mOpt: walkLookupTyperef :ty :reg currentUnit: mainName base: base2
                match (
                    mOpt
                ) case some then {
                    cu2: reg.unitNameTid.get key: mainName.string
                    match (
                        cu2
                    ) case some then {
                        ty.setChild parentTypeId: cu2 childName: defName childTypeId: mOpt
                    } case none then {}
                } case none then {
                }
            } else {
                if bt > 0 then {
                    cu3: reg.unitNameTid.get key: mainName.string
                    match (
                        cu3
                    ) case some then {
                        ty.setChild parentTypeId: cu3 childName: defName childTypeId: bt
                    } case none then {}
                }
            }
        }
    }
}

resolveConstantDefsInUnit: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    unitdef: Node
} is {
    match (
        unitdef
    ) case unitdef then {
        biter: unitdef.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                defName: unitLabel o: bm.name
                if defName.length > 0 then {
                    (resolveConstantDef
                        :ty
                        :reg
                        :mainName
                        defName: defName.stringview
                        defn: bm.operation
                    )
                }
            } else {
            }
        }
    } else {
    }
}

# resolveConstantDefs -- under the full driver, materialise the main unit's numeric
# constant definitions the way the oracle resolves them on first name lookup. Runs
# post-demand so the numeric defaults are already in resolved.
resolveConstantDefs: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry program: Node} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        uiter: program.units.iterate
        for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                nm: unitLabel o: u.name
                if nm.stringview == mainName then {
                    resolveConstantDefsInUnit :ty :reg :mainName unitdef: u.operation
                }
            } else {
            }
        }
    } else {
    }
}

# unitHasYieldFn -- any function member of this unit whose body suspends.
unitHasYieldFn: function {unitdef: Node} out bool is {
    match (
        unitdef
    ) case unitdef then {
        biter: unitdef.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                if (zgenerator.fnBodyHasYield n: bm.operation) then return true
                if (objectHasYieldMethod n: bm.operation) then return true
            } else {
            }
        }
        return false
    } else {
        return false
    }
}

# objectHasYieldMethod -- any is/as member of an object definition whose
# body suspends.
objectHasYieldMethod: function {n: Node} out bool is {
    match (
        n
    ) case objectdef then {
        aiter: n.asItems.iterate
        for am: aiter loop {
            match (
                am
            ) case namedoperation then {
                if (zgenerator.fnBodyHasYield n: am.operation) then return true
            } else {
            }
        }
        iiter: n.isItems.iterate
        for im: iiter loop {
            match (
                im
            ) case namedoperation then {
                if (zgenerator.fnBodyHasYield n: im.operation) then return true
            } else {
            }
        }
        return false
    } else {
        return false
    }
}

# resolveNamedDefsIn -- resolve exactly the named top-level defs of one
# unit. The generator pass runs pre-index (no node finder, no descent), so
# it walks the unitdef it already holds instead of the demand machinery.
resolveNamedDefsIn: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    unitdef: Node
    wantA: StringView
    wantB: StringView
} is {
    match (
        unitdef
    ) case unitdef then {
        biter: unitdef.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                dn: unitLabel o: bm.name
                hit: false
                if dn.stringview == wantA then hit = true
                if dn.stringview == wantB then hit = true
                if hit then {
                    rkey: "\{unitName}.\{dn}"
                    if (ty.definedKeys.has item: rkey) == false then {
                        (resolveDef
                            :ty
                            :reg
                            :units
                            :unitName
                            defName: dn.stringview
                            defn: bm.operation
                        )
                    }
                }
            } else {}
        }
    } else {}
}

# lowerGenerators -- the generator lowering pass (the reference's
# _lower_generators): for each unit, rewrite every yield-function whose
# declared return head resolves to the stdlib Iterator protocol into a
# synth iterator class + a factory. Runs before main-unit resolution so
# the rewritten definitions flow through the normal walk; the Iterator
# protocol resolves through a targeted demand only when a suspending
# function exists, so non-generator programs never touch it.
lowerGenerators: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry program: Node} is {
    match (
        program
    ) case program then {
        anyYield: false
        with yiter: program.units.iterate do for yu: yiter loop {
            match (
                yu
            ) case namedoperation then {
                if (unitHasYieldFn unitdef: yu.operation) then anyYield = true
            } else {
            }
        }
        if (anyYield) == false then return
        suN0: program.units.length
        suI0: 0.u64
        for suI0 < suN0 loop {
            su: program.units.get i: suI0
            suI0 = suI0 + 1
            match (
                su
            ) case namedoperation then {
                snm: unitLabel o: su.name
                if snm.stringview == "system" then {
                    (resolveNamedDefsIn
                        :ty
                        :reg
                        units: program.units
                        unitName: "system"
                        unitdef: su.operation
                        wantA: "Iterator"
                        wantB: "optionval"
                    )
                }
            } else {
            }
        }
        ik: "system.Iterator".string
        iterTid: optU64Or o: (resolvedByKey :ty :reg key: ik) d: 0
        if iterTid == 0 then return
        ids: zgenerator.newGenIds
        ui: 0.u64
        un: program.units.length
        for ui < un loop {
            uel: program.units.get i: ui
            match (
                uel
            ) case namedoperation then {
                lowerGeneratorsInUnit :ty :ids unitdef: uel.operation
            } else {
            }
            ui = ui + 1
        }
    } else {
    }
}

# lowerGeneratorsInUnit -- candidates collect first (indexes + names),
# then each lowers by index: the functiondef moves out of its
# namedoperation slot, the factory moves in, and the synth class appends
# to the unit body under `{name}_iter`.
lowerGeneratorsInUnit: function {ty: ztyping.ZTyping ids: zgenerator.GenIds unitdef: Node} is {
    match (
        unitdef
    ) case unitdef then {
        cIdx: (List u64)
        bi: 0.u64
        bn: unitdef.body.length
        for bi < bn loop {
            bm: unitdef.body.get i: bi
            isCand: false
            match (
                bm
            ) case namedoperation then {
                if (zgenerator.fnBodyHasYield n: bm.operation) then {
                    hd: zgenerator.returnHeadName n: bm.operation
                    if hd.stringview == "Iterator" then {
                        if (zgenerator.canLowerNow n: bm.operation hasReceiver: false) then {
                            isCand = true
                        }
                    }
                }
            } else {
            }
            if isCand then {
                bic: bi
                cIdx.append bic
            }
            bi = bi + 1
        }
        stagedCls: (List Node)
        ci: 0.u64
        cn: cIdx.length
        for ci < cn loop {
            idx: cIdx.get i: ci
            uel2: unitdef.body.get i: idx
            match (
                uel2
            ) case namedoperation then {
                dnm: unitLabel o: uel2.name
                sname: "\{dnm}_iter"
                fnNode: uel2.operation.take
                lowOpt: (zgenerator.lowerOne
                    :ids
                    fn: fnNode
                    synthName: sname.stringview
                    receiverType: ""
                )
                match (
                    lowOpt
                ) case some then {
                    wfid: lowOpt.wrapperNodeId
                    wfv: true
                    ty.generatorWrapper.set key: wfid.u64 value: wfv
                    # the create-param and field-path clones must not stamp:
                    # the reference shares those nodes with the factory, so
                    # each ref carries exactly one stamp.
                    nsi: 0.u64
                    nsn: lowOpt.noStamp.length
                    for nsi < nsn loop {
                        ns0: lowOpt.noStamp.get i: nsi
                        nsk: ns0.u64
                        nsv: true
                        ty.noStampNode.set key: nsk value: nsv
                        nsi = nsi + 1
                    }
                    fac: lowOpt.factory.take
                    uel2.operation = fac
                    cls: lowOpt.synthClass.take
                    clsN: zgenerator.mkNamedOp :ids line: 0 col: 0 name: sname.stringview op: cls
                    stagedCls.append clsN
                } case none then {
                }
            } else {
            }
            ci = ci + 1
        }
        # staged synth classes append after the loop: uel2's element view
        # ends with each iteration, and the list must not grow under it.
        for stagedCls.length > 0 loop {
            sc0: stagedCls.pop
            unitdef.body.append sc0
        }
        # method generators: each object definition's members lower the
        # same way, named {Type}_{method}_iter, with the receiver context.
        # Synth classes stage locally; the double-pop drain preserves order.
        pendingCls: (List Node)
        ogi: 0.u64
        ogn: unitdef.body.length
        for ogi < ogn loop {
            oel: unitdef.body.get i: ogi
            match (
                oel
            ) case namedoperation then {
                tnm: unitLabel o: oel.name
                if tnm.length > 0 then {
                    (lowerGeneratorMethods
                        :ty
                        :ids
                        typeName: tnm.stringview
                        defn: oel.operation
                        dst: pendingCls
                    )
                }
            } else {
            }
            ogi = ogi + 1
        }
        revCls: (List Node)
        for pendingCls.length > 0 loop {
            pc0: pendingCls.pop
            revCls.append pc0
        }
        for revCls.length > 0 loop {
            rc0: revCls.pop
            unitdef.body.append rc0
        }
    } else {
    }
}

# lowerGeneratorMethods -- lower the generator methods of one object
# definition (as-block first, then is-block), replacing each method with
# its factory in place and appending the synth class to the unit body.
lowerGeneratorMethods: function {
    ty: ztyping.ZTyping
    ids: zgenerator.GenIds
    typeName: StringView
    defn: Node
    dst: List Node
} is {
    match (
        defn
    ) case objectdef then {
        lowerGeneratorItems :ty :ids :typeName items: defn.asItems :dst
        lowerGeneratorItems :ty :ids :typeName items: defn.isItems :dst
    } else {
    }
}

lowerGeneratorItems: function {
    ty: ztyping.ZTyping
    ids: zgenerator.GenIds
    typeName: StringView
    items: List Node
    dst: List Node
} is {
    bi: 0.u64
    bn: items.length
    for bi < bn loop {
        bm: items.get i: bi
        isCand: false
        match (
            bm
        ) case namedoperation then {
            if (zgenerator.fnBodyHasYield n: bm.operation) then {
                hd: zgenerator.returnHeadName n: bm.operation
                if hd.stringview == "Iterator" then {
                    if (zgenerator.canLowerNow n: bm.operation hasReceiver: true) then isCand = true
                }
            }
        } else {
        }
        if isCand then {
            bm2: items.get i: bi
            match (
                bm2
            ) case namedoperation then {
                mnm: unitLabel o: bm2.name
                sname: "\{typeName}_\{mnm}_iter"
                fnNode: bm2.operation.take
                lowOpt: (zgenerator.lowerOne
                    :ids
                    fn: fnNode
                    synthName: sname.stringview
                    receiverType: typeName
                )
                match (
                    lowOpt
                ) case some then {
                    wfid: lowOpt.wrapperNodeId
                    wfv: true
                    ty.generatorWrapper.set key: wfid.u64 value: wfv
                    nsi: 0.u64
                    nsn: lowOpt.noStamp.length
                    for nsi < nsn loop {
                        ns0: lowOpt.noStamp.get i: nsi
                        nsk: ns0.u64
                        nsv: true
                        ty.noStampNode.set key: nsk value: nsv
                        nsi = nsi + 1
                    }
                    iri: 0.u64
                    irn: lowOpt.innerRefs.length
                    for iri < irn loop {
                        ir0: lowOpt.innerRefs.get i: iri
                        irk: ir0.u64
                        irk2: ir0.u64
                        irv: typeName.string
                        ty.pendingTyperef.set key: irk value: irv
                        iru: "".string
                        ty.pendingTyperefUnit.set key: irk2 value: iru
                        iri = iri + 1
                    }
                    fac: lowOpt.factory.take
                    bm2.operation = fac
                    cls: lowOpt.synthClass.take
                    clsN: zgenerator.mkNamedOp :ids line: 0 col: 0 name: sname.stringview op: cls
                    dst.append clsN
                } case none then {
                }
            } else {
            }
        }
        bi = bi + 1
    }
}

# Resolve a bare type name to its id through the units-as-containers hierarchy,
# over the bare-name visibility order (the current unit shadows the stdlib
# units: system, collections, io, core, os, cli) -- the SOLE encoding of that
# order. It serves internal/mangled queries (mono names, dotted member keys)
# beyond the source-level prelude surface, so it keeps the full root list
# where the index side (definingUnitFor) narrowed to current-unit + prelude.
walkLookupTyperef: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    currentUnit: StringView
    base: StringView
} out optionval u64 is {
    units: (List String)
    units.append currentUnit.string
    units.append "system".string
    units.append "collections".string
    units.append "io".string
    units.append "core".string
    units.append "os".string
    units.append "cli".string
    found: (optionval.none u64)
    done: false
    uit: units.iterate
    for u: uit loop {
        if (done) == false then {
            uc: u.copy
            uido: reg.unitNameTid.get key: uc
            match (
                uido
            ) case some then {
                co: ty.childOf parentTypeId: uido name: base
                match (
                    co
                ) case some then {
                    found = (optionval.some co)
                    done = true
                } case none then {}
            } case none then {}
        }
    }
    return found
}

# resolvedByKey -- resolve a "unit.name[.member]" key by walking childOf from the
# unit root; falls back to the flat resolved map for keys not yet mirrored in
# childOf (during-resolution reads) or non-type binding keys. The read path off
# the flat map (Stage A). Free fn (not a ZTyping method) so smoke-built low-level
# modules never pull in .split.
# resolveUnitChild -- the (unit, name) form of resolvedByKey's two-segment
# walk: no composed key, no split. resolveSystemChild probes the cached
# system unit root with no allocation at all.
resolveUnitChild: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    name: StringView
} out optionval u64 is {
    ro: reg.unitNameTid.get key: unitName.string
    match (
        ro
    ) case some then {
        co: ty.childOf parentTypeId: ro :name
        match (
            co
        ) case some then {
            return (optionval.some co)
        } case none then {}
    } case none then {}
    # miss: the composed-key path follows unit-level aliases and lays the
    # unit->alias edge, so the next probe resolves through childOf above
    ck9: "\{unitName}.\{name}"
    return (resolvedByKey :ty :reg key: ck9)
}

resolveSystemChild: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    name: StringView
} out optionval u64 is {
    if ty.systemUnitTid > 0 then {
        co: ty.childOf parentTypeId: ty.systemUnitTid :name
        match (
            co
        ) case some then {
            return (optionval.some co)
        } case none then {}
    }
    ck9: "system.\{name}"
    return (resolvedByKey :ty :reg key: ck9)
}

childOfWalk: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    key: String
} out optionval u64 is {
    cur: 0.u64
    started: false
    ok: true
    with it: (key.stringview.split sep: ".") do for seg: it loop {
        if ok then {
            if started == false then {
                ro: reg.unitNameTid.get key: seg.string
                match (
                    ro
                ) case some then {
                    cur = ro
                    started = true
                } case none then {
                    ok = false
                }
            } else {
                co: ty.childOf parentTypeId: cur name: seg
                match (
                    co
                ) case some then {
                    cur = co
                } case none then {
                    ok = false
                }
            }
        }
    }
    if ok when started then return (optionval.some cur)
    return (optionval.none u64)
}

resolvedByKey: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    key: String
} out optionval u64 is {
    wo: childOfWalk :ty :reg :key
    match (
        wo
    ) case some then {
        return (optionval.some wo)
    } case none then {}
    # On-demand alias resolution (no descend, no units): if `key` is a unit-level type
    # alias, resolve its target with a childOf-only walk and lay the unit->alias edge,
    # so this and future lookups resolve through childOf instead of the flat map. The
    # target walk does NOT recurse through this alias-follow, so it always terminates
    # and a cyclic alias (whose target never has a childOf edge) falls through to the
    # existing cycle diagnostic rather than being silently followed.
    aok: key.copy
    ao: ty.funcAliases.get key: aok
    match (
        ao
    ) case some then {
        tgo: childOfWalk :ty :reg key: ao.copy
        match (
            tgo
        ) case some then {
            au: "".string
            an: "".string
            with sk: (key.stringview.split sep: ".") do for sg: sk loop {
                if au.length == 0 then {
                    au = sg.string
                } else {
                    an = sg.string
                }
            }
            uro: reg.unitNameTid.get key: au
            match (
                uro
            ) case some then {
                ty.setChild parentTypeId: uro childName: an.stringview childTypeId: tgo
            } case none then {}
            return (optionval.some tgo)
        } case none then {}
    } case none then {}
    return (optionval.none u64)
}

# shellScalarName -- a shell named like a C scalar stays a shell: the
# emitter spells those by NAME (cTypeOf) before any canonicalization, so
# rebinding them would change shadow semantics. Mirrors cTypeOf's set.
shellScalarName: function {name: StringView} out bool is {
    if name == "i8" then return true
    if name == "i16" then return true
    if name == "i32" then return true
    if name == "i64" then return true
    if name == "u8" then return true
    if name == "u16" then return true
    if name == "u32" then return true
    if name == "u64" then return true
    if name == "i128" then return true
    if name == "u128" then return true
    if name == "f32" then return true
    if name == "f64" then return true
    if name == "bool" then return true
    if name == "literal_int" then return true
    return false
}

# shellResolveByName -- the emitter's shell resolution order for `name` seen
# from `unit`: the unit-local key, the system key, the walk list, then the
# registry-wide cross-unit scan. 0 when nothing resolves.
# canonShellTid -- the canonical id for a SHELL stamp value, 0 to leave
# the stamp alone. Mirrors canonicalizeShellChildren's shell detection
# (no defining unit, not a generic param / scalar shell / as-const clone
# / typeof shell); memoized per shell id.
canonShellTid: function {
    st: zenv.ZSymbolTable
    cache9: (Map u64 value: u64)
    tid: u64
    mainName: StringView
} out u64 is {
    if tid == 0 then return 0
    co9: cache9.get key: tid
    match (
        co9
    ) case some then {
        return co9
    } case none then {}
    res9: 0.u64
    ok9: (st.reg.typetypeOf typeId: tid) != ztypes.ztypetype.GENERIC_PARAM
    if ok9 then {
        duo9: st.typing.definedInUnit.get key: tid
        match (
            duo9
        ) case some then {
            ok9 = false
        } case none then {}
    }
    if ok9 then {
        nm9: regTypeNameOf reg: st.reg :tid
        if (shellScalarName name: nm9.stringview) then nm9 = "".string
        aco9: st.typing.asConstClone.get key: tid
        match (
            aco9
        ) case some then {
            if aco9 then nm9 = "".string
        } case none then {}
        tso9: st.typing.typeofShell.get key: tid
        match (
            tso9
        ) case some then {
            nm9 = "".string
        } case none then {}
        if nm9.length > 0 then {
            rid9: (shellResolveByName
                ty: st.typing
                reg: st.reg
                fromUnit: mainName
                name: nm9.stringview
            )
            if rid9 > 0 when rid9 != tid then res9 = rid9
        }
    }
    kc9: tid
    vc9: res9
    cache9.set key: kc9 value: vc9
    return res9
}

# canonicalizeShellNodeStamps -- checkBodies runs BEFORE the shell-child
# canonicalization, so expression nodes typed through a then-shell edge
# carry the shell id in nodeType (and memberOwnerTid): the emitter reads
# receiver types from those stamps, and a shell has no origin/children
# to dispatch on. Rebind them to the canonical type like the child edges.
canonicalizeShellNodeStamps: function {st: zenv.ZSymbolTable mainName: StringView} is {
    cache9: (Map u64 value: u64)
    nids9: (List u64)
    vals9: (List u64)
    with it9: st.typing.nodeType.iterateItems do for e9: it9 loop {
        rid9: canonShellTid :st :cache9 tid: e9.value :mainName
        if rid9 > 0 then {
            nids9.append e9.key
            vals9.append rid9
        }
    }
    i9: 0.u64
    for i9 < nids9.length loop {
        k9: nids9.get i: i9
        v9: vals9.get i: i9
        st.typing.nodeType.set key: k9 value: v9
        i9 = i9 + 1
    }
    mnids9: (List u64)
    mvals9: (List u64)
    with mt9: st.typing.memberOwnerTid.iterateItems do for m9: mt9 loop {
        rid2: canonShellTid :st :cache9 tid: m9.value :mainName
        if rid2 > 0 then {
            mnids9.append m9.key
            mvals9.append rid2
        }
    }
    j9: 0.u64
    for j9 < mnids9.length loop {
        k2: mnids9.get i: j9
        v2: mvals9.get i: j9
        st.typing.memberOwnerTid.set key: k2 value: v2
        j9 = j9 + 1
    }
}

shellResolveByName: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    fromUnit: StringView
    name: StringView
} out u64 is {
    r1: resolveUnitChild :ty :reg unitName: fromUnit :name
    match (
        r1
    ) case some then {
        return r1
    } case none then {}
    r2: resolveSystemChild :ty :reg :name
    match (
        r2
    ) case some then {
        return r2
    } case none then {}
    r3: walkLookupTyperef :ty :reg currentUnit: fromUnit base: name
    match (
        r3
    ) case some then {
        return r3
    } case none then {}
    unames9: (List String)
    with uit9: reg.unitNameTid.iterateItems do for ue9: uit9 loop {
        uk9: ue9.key.copy
        unames9.append uk9
    }
    found9: 0.u64
    ui9: 0.u64
    for ui9 < unames9.length loop {
        if found9 == 0 then {
            un9: unames9.get i: ui9
            k9: "\{un9}.\{name}"
            r9: resolvedByKey :ty :reg key: k9
            match (
                r9
            ) case some then {
                found9 = r9
            } case none then {}
        }
        ui9 = ui9 + 1
    }
    return found9
}

# canonicalizeShellChildren -- rebind every childTypeById edge whose value is
# a SHELL id (a name-minted reference with no defining unit) to the canonical
# type, resolved in the edge's parent's defining unit with the emitter's
# resolution order. Runs post-resolution so the emitter reads canonical child
# ids and never re-resolves a child by name.
canonicalizeShellChildren: function {st: zenv.ZSymbolTable mainName: StringView} is {
    ri9: 0.u64
    rn9: st.typing.typeChild.length
    for ri9 < rn9 loop {
        row: st.typing.typeChild.get i: ri9
        cto9: 0.u64
        {
            ctoO9: st.typing.childTypeById.get key: row.childNameId
            match (
                ctoO9
            ) case some then {
                cto9 = ctoO9
            } case none then {}
        }
        ok9: cto9 > 0
        if ok9 when (st.reg.typetypeOf typeId: cto9) == ztypes.ztypetype.GENERIC_PARAM then {
            ok9 = false
        }
        if ok9 then {
            duo9: st.typing.definedInUnit.get key: cto9
            match (
                duo9
            ) case some then {
                ok9 = false
            } case none then {}
        }
        if ok9 then {
            pu9: mainName.string
            {
                puo9: st.typing.definedInUnit.get key: row.parentTypeId
                match (
                    puo9
                ) case some then {
                    pu9 = puo9.copy
                } case none then {}
            }
            nm9: regTypeNameOf reg: st.reg tid: cto9
            if (shellScalarName name: nm9.stringview) then nm9 = "".string
            {
                aco9: st.typing.asConstClone.get key: cto9
                match (
                    aco9
                ) case some then {
                    if aco9 then nm9 = "".string
                } case none then {}
            }
            {
                tso9: st.typing.typeofShell.get key: cto9
                match (
                    tso9
                ) case some then {
                    nm9 = "".string
                } case none then {}
            }
            if nm9.length > 0 then {
                rid9: (shellResolveByName
                    ty: st.typing
                    reg: st.reg
                    fromUnit: pu9.stringview
                    name: nm9.stringview
                )
                if rid9 > 0 when rid9 != cto9 then {
                    setc9: rid9
                    st.typing.childTypeById.set key: row.childNameId value: setc9
                }
            }
        }
        ri9 = ri9 + 1
    }
}


typecheck: function {
    program: Node
    reg: ztypes.ZTypeRegistry.take
    full: bool
} out zenv.ZSymbolTable is {
    ty: ztyping.newTyping
    match (
        program
    ) case program then {
        reg.setMainUnit name: program.mainUnitName.stringview
    } else {}
    # id 0 is the no-type / unresolved sentinel that checkValue returns on failure.
    # The null VALUE-type is a normal canonical id resolved by name; a `null` arm's
    # child type is always that canonical id, never 0.
    reg.newType name: "notype" typetype: ztypes.ztypetype.NULL
    st: zenv.newSymbolTable :reg typing: ty
    # Stage D: mint every unit's root + fill unitNameTid BEFORE any demand
    # resolution (lowerGenerators pre-resolves system.Iterator/optionval when a
    # generator is present), so childOf-at-mint always sees a populated unit root.
    registerUnitRoots ty: st.typing reg: st.reg :program
    {
        sysUo9: st.reg.unitNameTid.get key: "system".string
        match (
            sysUo9
        ) case some then {
            st.typing.systemUnitTid = sysUo9
        } case none then {}
    }
    (declareCanonicalType
        ty: st.typing
        reg: st.reg
        defUnit: "system"
        name: "never"
        typetype: ztypes.ztypetype.NEVER
    )
    (declareCanonicalType
        ty: st.typing
        reg: st.reg
        defUnit: "system"
        name: "null"
        typetype: ztypes.ztypetype.NULL
    )
    populatePrelude ty: st.typing reg: st.reg :program
    lowerGenerators ty: st.typing reg: st.reg :program
    indexUnitDefs ty: st.typing :program
    registerAndResolveMain ty: st.typing reg: st.reg :program :full
    resolveMainUnitInstantiations ty: st.typing reg: st.reg :program
    if full then scanMainBodyCalls reg: st.reg :program
    resolveDemandsByDescent ty: st.typing reg: st.reg :program :full
    resolveTypeAliases ty: st.typing reg: st.reg
    match (
        program
    ) case program then {
        fixupCustomTags ty: st.typing reg: st.reg mainName: program.mainUnitName.stringview
    } else {}
    if full then {
        resolveConstantDefs ty: st.typing reg: st.reg :program
        completeUnitInstantiations ty: st.typing reg: st.reg :program
    }
    stampTyperefs ty: st.typing reg: st.reg :program
    if full then {
        checkBodies :st :program
        match (
            program
        ) case program then {
            stampCtorDefaults :st unitName: program.mainUnitName.stringview
        } else {}
        foldLiteralStamps :st :program
        match (
            program
        ) case program then {
            canonicalizeShellChildren :st mainName: program.mainUnitName.stringview
            canonicalizeShellNodeStamps :st mainName: program.mainUnitName.stringview
        } else {}
    }
    return st
}

                    # (a construction inside a method body, walked before the
                    # constructed type). Resolve it on demand, then retry --
                    # otherwise the construction returns 0 and the binding goes
                    # unstamped.
                    maybeWalkMethods :st :unitName :ast :unitBody name: cn.stringview
                    fo2: (walkLookupTyperef
                        :ast
                        ty: st.typing
                        reg: st.reg
                        currentUnit: unitName
                        base: cn.stringview
                    )
                    match (
                        fo2
                    ) case some then {
                        funcId = fo2
                    } case none then null
                }
            }
        }
        if funcId > 0 then maybeWalkMethods :st :unitName :ast :unitBody name: cn.stringview
        isUser: false
        isGen: false
        isCtor: false
        if funcId > 0 then {
            zo: st.reg.typeById.get key: funcId
            match (
                zo
            ) case some then {
                if zo.isgeneric then {
                    isGen = true
                } else {
                    isUser = true
                    if zo.typetype != ztypes.ztypetype.functionType then isCtor = true
                }
            } case none then null
        }
        tdb0: u64
        if isCtor then tdb0 = typedefBaseOf :ast :st :unitName tid: funcId
        if tdb0 > 0 then return (checkTypedefCreate
            :st
            :unitName
            :ast
            :unitBody
            :call
            tdId: funcId
        )
        if isUser then {
            calid: nodeId n: (ast.nodes.get i: (call.callable - 1).u64)
            setc: funcId
            st.typing.nodeType.set key: calid.u64 value: setc
            # tooling: a bare callable resolving to a unit FUNCTION is a
            # def reference like any bare read (constructors excluded)
            if (isCtor) == false then {
                setu9: funcId
                st.typing.atomUnitDefId.set key: calid.u64 value: setu9
            }
            cm: st.pushCall
            lockRoot: (walkCallArgsHoist
                :st
                :unitName
                :ast :unitBody
                :call
                :funcId
                :isCtor
                reportUnknown: true
                recvImplicit: false
            )
            checkMissingCallArgs :ast :st :call :funcId :isCtor
            st.popTo marker: cm
            if isCtor then {
                # a type in callable position constructs: the call's value is
                # the type itself.
                ctk: funcId
                ctv: true
                st.typing.constructedTypes.set key: ctk value: ctv
                result = funcId
                setr2: result
                st.typing.nodeType.set key: call.nodeid.u64 value: setr2
                ctt9: st.reg.typetypeOf typeId: funcId
                if ctt9 == ztypes.ztypetype.recordType then {
                    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.recordCreate
                }
                if ctt9 == ztypes.ztypetype.classType then {
                    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.classCreate
                }
                if ctt9 == ztypes.ztypetype.unionType then {
                    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.unionCreate
                }
            } else {
                rnOpt: st.typing.funcReturnNode.get key: funcId
                match (
                    rnOpt
                ) case some then {
                    rtOpt: st.typing.nodeType.get key: rnOpt
                    match (
                        rtOpt
                    ) case some then {
                        result = rtOpt
                        setr: result
                        st.typing.nodeType.set key: call.nodeid.u64 value: setr
                    } case none then null
                } case none then null
                # A `.borrow`-marked return borrows from the lock parameter's
                # argument: report the source for the binding site. Argument
                # evaluation residue drains first (owning calls consume it).
                drainPendingBorrow :st
                xroot2: st.typing.lastLockParamRoot.copy
                if xroot2.length > 0 then {
                    st.typing.lastLockParamRoot = "".string
                    drainPendingBorrow :st
                    st.typing.pendingBorrowPath.append xroot2
                }
                if (optBoolOr
                    o: (st.typing.funcReturnsBorrow.get key: funcId)
                    d: false
                ) when lockRoot.length > 0 then {
                    drainPendingBorrow :st

                osubs0: (Map key: String value: u64)
                ok0: "t".string
                ov0: payId0
                osubs0.set key: ok0 value: ov0
                omn0: "optionval_\{vtn0}"
                omid0: mintMono st: st mainName: unitName name: omn0.stringview templateId: ovo0 subs: osubs0 fallbackArg: 0.u64
                if omid0 > 0.u64 then {
                    result = omid0
                } else {
                }
            } case none then {
            }
        } else {
        }
    } else {
    }
    if result > 0.u64 then {
        setk: result
        st.typing.nodeType.set key: donode.nodeid.u64 value: setk
    } else {
    }
    return result
}


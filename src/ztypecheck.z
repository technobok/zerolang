                                        upo: (st.typing.childOf
                                            pool: ast.names
                                            parentTypeId: dtp
                                            name: ucArm2.stringview
                                        )
                                        upid: optU64Or o: upo d: 0
                                        if upid > 0 then {
                                            uiid: (innermostNodeId
                                                :ast
                                                n: (ast.nodes.get i: (arg2.operation - 1).u64)
                                            )
                                            if uiid > 0 then {
                                                setup: upid

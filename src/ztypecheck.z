            # `Box from: val` -- the system box (empty generic class body)
            # constructs through its own leg: t inferred from the value.
            isBox: false
            if isGen then {
                if (st.reg.typetypeOf typeId: funcId) == ztypes.ztypetype.classType then {
                    bxn: typeNameOf :st tid: funcId
                    if bxn.stringview == "Box" then {
                        if (st.typing.childCount parentTypeId: funcId) == 0 then isBox = true
                    }
                }
            }
            if isBox then {
                bres: checkBoxConstruction :st :unitName :ast :unitBody :call tplId: funcId
                if bres > 0 then return bres
            }
            if isGen then {
                gtt: st.reg.typetypeOf typeId: funcId
                if gtt != ztypes.ztypetype.functionType then {
                    errB9: st.typing.errors.length
                    vok9: (validateGenericTypeArgs
                        :ast
                        :st
                        :unitName
                        :call
                        tplId: funcId
                        allowFrom: false
                    )

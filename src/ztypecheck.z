                            # exactly like the concrete-method path: a generic
                            # method's writer receiver must conflict with live
                            # views. The lock lives in its own call scope (the
                            # conflict check happens at take; the pop releases
                            # it before the next statement). A unit-member
                            # callee (io.eprintln) has no value root and skips.
                            mcmG9: st.pushCall
                            xq29: ast.nodes.get i: (call.callable - 1).u64
                            rroG9: methodReceiverRoot :ast n: xq29
                            if rroG9.length > 0 then {
                                rvoG9: st.lookupVarId name: rroG9.stringview
                                match (
                                    rvoG9
                                ) case some then {
                                    rvtG9: st.lookup name: rroG9.stringview
                                    match (
                                        rvtG9
                                    ) case some then {
                                        doLockG9: false
                                        rttG9: st.reg.typetypeOf typeId: rvtG9
                                        isFPG9: false
                                        if rttG9 == ztypes.ztypetype.facetType then isFPG9 = true
                                        if rttG9 == ztypes.ztypetype.protocolType then isFPG9 = true
                                        if isFPG9 then {
                                            doLockG9 = true
                                        } else {
                                            if (methodHasThisReceiver :st mid: dro) then {
                                                if (typeIsReftype
                                                    :st
                                                    tid: rvtG9
                                                ) then doLockG9 = true
                                            } else {
                                                doLockG9 = true
                                            }
                                        }
                                        if doLockG9 then {
                                            xq19: ast.nodes.get i: (call.callable - 1).u64
                                            rmnG9: dottedChildName :ast n: xq19
                                            shrG9: (isContainerReaderCall
                                                :ast
                                                :st
                                                recvTid: rvtG9
                                                mname: rmnG9.stringview
                                            )
                                            (lockCallArg
                                                :st
                                                name: rroG9.stringview
                                                callId: call.nodeid.u64
                                                shared: shrG9
                                                nodeid: call.nodeid
                                                lineno: call.lineno
                                                colno: call.colno
                                            )
                                        }
                                    } case none then null
                                } case none then null
                            }
                            st.popTo marker: mcmG9

            }
        } else {
        }
        setmk: bt
        st.typing.nodeType.set key: dp.nodeid.u64 value: setmk
        return bt
    } else {
    }
    # A compile-time numeric index on an array instance projects the element
    # type (`a.0` reads / reassigns element zero).
    if (isNumericLiteralName name: cn.stringview) then {
        isArr9: false
        {
            bz8: st.reg.typeById.get key: bt
            match (
                bz8
            ) case some then {
                bgo8: bz8.genericOriginId
                match (
                    bgo8
                ) case some then {
                    gn8: typeNameOf st: st tid: bgo8
                    if gn8.stringview == "array" then { isArr9 = true } else {
                    }
                } case none then {
                }
            } case none then {
            }
        }
        if isArr9 then {
            go8: st.typing.childOf parentTypeId: bt name: "get"
            match (
                go8
            ) case some then {
                ro8: methodReturnOf st: st mid: go8
                match (
                    ro8
                ) case some then {
                    seta8: ro8
                    st.typing.nodeType.set key: dp.nodeid.u64 value: seta8
                    return ro8
                } case none then {
                }
            } case none then {
            }
        } else {
        }
    } else {
    }
    # `.array` on a data block copies the elements into the sized array
    # instance (array_{elem}_{count}), minting it on first access. The
    # element type rides the data's `tag__{elem}` tag-child name.
    if cn.stringview == "array" then {
        if (st.reg.typetypeOf typeId: bt) == ztypes.ztypetype.DATA then {
            tgo: st.typing.childOf parentTypeId: bt name: "tag"
            match (
                tgo
            ) case some then {
                tagn: typeNameOf st: st tid: tgo
                eno: tagn.stringview.stripPrefix p: "tag__"
                match (
                    eno
                ) case some then {
                    den: eno.string
                    elo: lookupTyperef resolved: st.typing.resolved mainName: unitName base: den.stringview
                    match (
                        elo
                    ) case some then {
                        ecnt: (st.typing.childCount parentTypeId: bt) - 1.u64
                        ato: lookupTyperef resolved: st.typing.resolved mainName: unitName base: "array"
                        match (
                            ato
                        ) case some then {
                            amn: "array_\{den}_\{ecnt}"
                            asubs: (Map key: String value: u64)
                            sk0: "of".string
                            sv0: elo
                            asubs.set key: sk0 value: sv0
                            amid: mintMono st: st mainName: unitName name: amn.stringview templateId: ato subs: asubs fallbackArg: 0.u64
                            asfx: "_\{den}_\{ecnt}"
                            mintCollectionChildren st: st mainName: unitName monoName: amn.stringview monoId: amid templateName: "array" suffix: asfx.stringview elemArg: elo valArg: 0.u64
                            setar: amid
                            st.typing.nodeType.set key: dp.nodeid.u64 value: setar
                            return amid
                        } case none then {
                        }
                    } case none then {
                    }
                } case none then {
                }
            } case none then {
            }
        } else {
        }
    } else {
    }
    mo: st.typing.childOf parentTypeId: bt name: cn.stringview
    match (
        mo

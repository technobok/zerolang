            }
            vt: u64
            if useNC then {
                opf49: ast.nodes.get i: (arg.operation - 1).u64
                vt = valueNoCoerce :st :unitName :ast :unitBody n: opf49
            } else {
                opf59: ast.nodes.get i: (arg.operation - 1).u64
                vt = checkValue :st :unitName :ast :unitBody node: opf59
            }
            if vt > 0 then {
                pn: zast.nameTextCopy :ast ref: arg.name
                if (isCtor) == false when pn.length > 0 when funcId > 0 then {
                    if (st.typing.childCount parentTypeId: funcId) > 0 then {
                        pco9: (st.typing.childOf
                            pool: ast.names
                            parentTypeId: funcId
                            name: pn.stringview
                        )
                        pcidX9: optU64Or o: pco9 d: 0
                        if pcidX9 == 0 then {
                            pnc9: pn.copy
                            m2: "unknown argument '\{pnc9}'"
                            anid9: arg.nodeid
                            anln9: arg.lineno
                            ancl9: arg.colno
                            sug2: suggestSimilar :ast :st parentTypeId: funcId name: pn.stringview
                            h2: String
                            if sug2.length > 0 then {
                                sgc2: sug2.copy
                                hh2: "did you mean '\{sgc2}'?"
                                h2 = hh2
                            }
                            en2: String
                            (addErrorH
                                :st
                                nodeid: anid9
                                lineno: anln9
                                colno: ancl9
                                e: zast.err.callError
                                msg: m2
                                note: en2
                                hint: h2
                                width: pn.length.u32.orPanic
                            )
                        } else {
                            ptid9: pcidX9
                            if ptid9 > 0 when vt > 0 then {
                                if (typesCompatible
                                    :ast
                                    :st
                                    :unitName
                                    a: vt
                                    b: ptid9
                                ) == false then {
                                    skipMM9: false
                                    if (isNumericTid
                                        :ast
                                        ty: st.typing
                                        reg: st.reg
                                        tid: vt
                                    ) when (isNumericTid
                                        :ast
                                        ty: st.typing
                                        reg: st.reg
                                        tid: ptid9
                                    ) then skipMM9 = true
                                    ptt9: st.reg.typetypeOf typeId: ptid9
                                    if ptt9 == ztypes.ztypetype.protocolType then skipMM9 = true
                                    if ptt9 == ztypes.ztypetype.facetType then skipMM9 = true
                                    if ptt9 == ztypes.ztypetype.genericParam then skipMM9 = true
                                    if ptt9 == ztypes.ztypetype.functionType then skipMM9 = true
                                    if (skipMM9) == false then {
                                        en7: typeNameOf :st tid: ptid9
                                        an7: typeNameOf :st tid: vt
                                        enc7: en7.copy
                                        anc7: an7.copy
                                        pnc7: pn.copy
                                        mm7: "argument '\{pnc7}' type mismatch: expected \{enc7}, got \{anc7}"
                                        en7b: String
                                        eh7: String
                                        (addErrorH
                                            :st
                                            nodeid: arg.nodeid
                                            lineno: arg.lineno
                                            colno: arg.colno
                                            e: zast.err.callError
                                            msg: mm7
                                            note: en7b
                                            hint: eh7
                                            width: pn.length.u32.orPanic
                                        )
                                    }
                                }
                            }
                        }
                    }
                }
                if reportUnknown when (isCtor) == false when pn.length == 0 when funcId > 0 then {
                    if (st.typing.childCount parentTypeId: funcId) == 0 then {
                        if (st.reg.typetypeOf typeId: funcId) == ztypes.ztypetype.functionType then {
                            tmm9: "too many arguments: function takes no parameters".string
                            (addError
                                :st
                                nodeid: arg.nodeid
                                lineno: arg.lineno
                                colno: arg.colno
                                e: zast.err.callError
                                msg: tmm9
                            )
                        }
                    }
                }
                wasPos9: false
                if pn.length == 0 then {
                    wasPos9 = true
                    pp: positionalParamName :ast :st :funcId idx: argIdx skipRecv: recvImplicit
                    pn = pp
                }
                if funcId > 0 when pn.length > 0 then {
                    dcnid9: (st.typing.childIdFor
                        pool: ast.names
                        parentTypeId: funcId
                        name: pn.stringview
                    )
                    dupSeen9: false
                    with bIt9: boundArgIds.iterate do for bId9: bIt9 loop {
                        if bId9 == dcnid9 then dupSeen9 = true
                    }
                    if dupSeen9 when reportUnknown then {
                        pncD9: pn.copy
                        dmm9: "argument '\{pncD9}' specified more than once"
                        (addError
                            :st
                            nodeid: arg.nodeid
                            lineno: arg.lineno
                            colno: arg.colno
                            e: zast.err.callError
                            msg: dmm9
                        )
                    } else {
                        boundArgIds.append dcnid9
                    }
                    if wasPos9 when (isCtor) == false then {
                        cpidP9: (optU64Or
                            o: (st.typing.childOf
                                pool: ast.names
                                parentTypeId: funcId
                                name: pn.stringview
                            )
                            d: 0
                        )
                        if cpidP9 > 0 then {
                            ptidP9: cpidP9
                            if ptidP9 > 0 when vt > 0 then {
                                if (typesCompatible
                                    :ast
                                    :st
                                    :unitName
                                    a: vt
                                    b: ptidP9
                                ) == false then {
                                    skipP9: false
                                    if (isNumericTid
                                        :ast
                                        ty: st.typing
                                        reg: st.reg
                                        tid: vt
                                    ) when (isNumericTid
                                        :ast
                                        ty: st.typing
                                        reg: st.reg
                                        tid: ptidP9
                                    ) then skipP9 = true
                                    pttP9: st.reg.typetypeOf typeId: ptidP9
                                    if pttP9 == ztypes.ztypetype.protocolType then skipP9 = true
                                    if pttP9 == ztypes.ztypetype.facetType then skipP9 = true
                                    if pttP9 == ztypes.ztypetype.genericParam then skipP9 = true
                                    if pttP9 == ztypes.ztypetype.functionType then skipP9 = true
                                    if (skipP9) == false then {
                                        enP9: typeNameOf :st tid: ptidP9
                                        anP9: typeNameOf :st tid: vt
                                        encP9: enP9.copy
                                        ancP9: anP9.copy
                                        tmmP9: "argument type mismatch: expected \{encP9}, got \{ancP9}"
                                        enP9b: String
                                        ehP9: String
                                        (addErrorH
                                            :st
                                            nodeid: arg.nodeid
                                            lineno: arg.lineno
                                            colno: arg.colno
                                            e: zast.err.callError
                                            msg: tmmP9
                                            note: enP9b
                                            hint: ehP9
                                            width: pn.length.u32.orPanic
                                        )
                                    }
                                }
                            }
                        }
                    }
                }
                isTake: false
                isLockish: false
                isDeclLock: false
                pt: u64
                if funcId > 0 when pn.length > 0 then {
                    if (isLiteralTypeId :st tid: vt) then {
                        po: (st.typing.childOf
                            pool: ast.names
                            parentTypeId: funcId
                            name: pn.stringview
                        )
                        match (
                            po
                        ) case some then {
                            pt = po
                        } case none then null
                    }
                    cnid: (st.typing.childIdFor
                        pool: ast.names
                        parentTypeId: funcId
                        name: pn.stringview
                    )
                    oo: st.typing.childOwnership.get key: cnid
                    match (
                        oo
                    ) case some then {
                        if oo == ztypes.zparamownership.takeMode then isTake = true
                        if oo == ztypes.zparamownership.lockMode then {
                            isLockish = true
                            isDeclLock = true
                        }
                        if oo == ztypes.zparamownership.borrowMode then isLockish = true
                    } case none then {
                        # Unrecorded ownership: the effective default is
                        # borrow (ctor field params keep their recorded flow).
                        if (isCtor) == false then isLockish = true
                    }
                    if isCtor then {
                        # Field ownership flows to the constructor param:
                        # a `.lock` field locks the caller's argument, any
                        # other reftype field takes it.
                        if (st.typing.isChildLockField
                            pool: ast.names
                            parentTypeId: funcId
                            name: pn.stringview
                        ) then {
                            isLockish = true
                        } else {
                            if (typeIsReftype :st tid: vt) then isTake = true
                        }
                    }
                }
                dispHit9: false
                if isTake then dispHit9 = true
                if isLockish then dispHit9 = true
                if dispHit9 when (typeIsReftype :st tid: vt) then {
                    dispVal9: ztypes.zparamownership.borrowMode
                    if isDeclLock then dispVal9 = ztypes.zparamownership.lockMode
                    if isTake then dispVal9 = ztypes.zparamownership.takeMode
                    dispNid9: innermostNodeId :ast n: (ast.nodes.get i: (arg.operation - 1).u64)
                    if dispNid9 > 0 then {
                        st.typing.argDisposition.set key: dispNid9.u64 value: dispVal9
                    }
                }
                if (argIsTrivial :ast op: (ast.nodes.get i: (arg.operation - 1).u64)) then {

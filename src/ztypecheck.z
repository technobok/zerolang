                # in an empty call scope (the reference's rewrite walks it
                # once); gated on the value being an iterator wrapper.
                if (isCallNode n: cond.operation) then {
                    doProbe9: false
                    pw9: iterWrapperElem st: st unitName: unitName wid: vt
                    match (
                        pw9
                    ) case some then {
                        doProbe9 = true
                    } case none then {
                        ico9: st.typing.childOf parentTypeId: vt name: "call"
                        match (
                            ico9
                        ) case some then {
                            doProbe9 = true
                        } case none then {
                        }
                    }
                    if doProbe9 then {
                        ecm9: st.pushCall
                        st.popTo marker: ecm9
                    } else {
                    }
                } else {
                }
                elem: 0.u64
                isView: false
                w1: iterWrapperElem st: st unitName: unitName wid: vt
                match (
                    w1
                ) case some then {
                    elem = w1
                    isView = isOptionViewMono st: st unitName: unitName wid: vt
                } case none then {
                }
                if elem == 0.u64 then {
                    if (st.reg.typetypeOf typeId: vt) == ztypes.ztypetype.FUNCTION then {
                        r1: methodReturnOf st: st mid: vt
                        match (
                            r1
                        ) case some then {
                            w2: iterWrapperElem st: st unitName: unitName wid: r1
                            match (
                                w2
                            ) case some then {
                                elem = w2
                                isView = isOptionViewMono st: st unitName: unitName wid: r1
                            } case none then {
                            }
                        } case none then {
                        }
                    } else {
                        c1: st.typing.childOf parentTypeId: vt name: "call"
                        match (
                            c1
                        ) case some then {
                            r2: methodReturnOf st: st mid: c1
                            match (
                                r2
                            ) case some then {
                                w3: iterWrapperElem st: st unitName: unitName wid: r2
                                match (
                                    w3
                                ) case some then {
                                    elem = w3
                                    isView = isOptionViewMono st: st unitName: unitName wid: r2
                                } case none then {
                                }
                            } case none then {
                            }
                        } case none then {
                        }
                    }
                } else {
                }
                if elem > 0.u64 then {
                    if isView then {
                        srcName: atomName n: cond.operation
                        bo: "<iterator>".string
                        if srcName.length > 0.u64 then {
                            bo = srcName.copy
                        } else {
                        }
                        v: st.reg.newVariable ztypeId: elem ownership: ztypes.zownership.BORROWED
                        v.borrowOrigin = (Option.some bo)

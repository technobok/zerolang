                    # _dispatch_call_construction). Generic templates infer
                    # their mono separately.
                    calid2: nodeId n: (ast.nodes.get i: (call.callable - 1).u64)
                    dtp: optU64Or o: (st.typing.dpTaggedParent.get key: calid2.u64) d: 0
                    if dtp > 0 then {
                        isGenT: false
                        {
                            gzo: st.reg.typeById.get key: dtp
                            match (
                                gzo
                            ) case some then {
                                if gzo.isgeneric then isGenT = true
                            } case none then null
                        }
                        if isGenT then {
                            (validateGenericTypeArgs
                                :ast
                                :st
                                :unitName
                                :call
                                tplId: dtp
                                allowFrom: true
                            )
                            # Generic template: infer the mono (mirrors
                            # _infer_generic_union_construction). A NULL-payload
                            # arm with an argument names the type EXPLICITLY
                            # (resolved as a type, never value-walked); a
                            # param-payload arm infers from the value's type.
                            armnId9: (dottedChildNameId
                                :ast
                                n: (ast.nodes.get i: (call.callable - 1).u64)
                            )
                            co: st.typing.childOfId parentTypeId: dtp nameId: armnId9
                            payId: optU64Or o: co d: 0
                            if payId > 0 then {
                                pn0: typeNameOf :st tid: payId
                                isNullPay: false
                                if pn0.stringview == "null" then isNullPay = true
                                subT: u64
                                fiter2: call.arguments.iterate
                                argFound: false
                                for fargId9: fiter2 loop {
                                    farg: ast.nodes.get i: (fargId9 - 1).u64
                                    match (
                                        farg
                                    ) case namedoperation then {
                                        if (argFound) == false then {
                                            argFound = true
                                            if isNullPay then {
                                                etn: (paramTypeBaseName
                                                    :ast
                                                    op: (ast.nodes.get i: (farg.operation - 1).u64)
                                                )
                                                subT = (optU64Or
                                                    o: (walkLookupTyperef
                                                        :ast
                                                        ty: st.typing
                                                        reg: st.reg
                                                        currentUnit: unitName
                                                        base: etn.stringview
                                                    )
                                                    d: 0

                                        return mintedT
                                    }
                                }
                            }
                        } else {
                            ucArm2: (dottedChildName
                                :ast
                                n: (ast.nodes.get i: (call.callable - 1).u64)
                            )
                            aiter2: call.arguments.iterate
                            for arg2Id9: aiter2 loop {
                                arg2: ast.nodes.get i: (arg2Id9 - 1).u64
                                match (
                                    arg2
                                ) case namedoperation then {
                                    uan9: zast.nameTextCopy :ast ref: arg2.name
                                    if uan9.length > 0 when uan9.stringview != "from" then {
                                        uanc9: uan9.copy
                                        uum9: "unknown argument '\{uanc9}'"
                                        (addError
                                            :st
                                            nodeid: arg2.nodeid
                                            lineno: arg2.lineno
                                            colno: arg2.colno
                                            e: zast.err.callError
                                            msg: uum9
                                        )
                                    }
                                    uvt: (checkValue
                                        :st
                                        :unitName
                                        :ast
                                        :unitBody
                                        node: (ast.nodes.get i: (arg2.operation - 1).u64)
                                    )

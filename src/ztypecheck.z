                if ctt9 == ztypes.ztypetype.CLASS then {
                    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.CLASS_CREATE
                }
                if ctt9 == ztypes.ztypetype.UNION then {
                    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.UNION_CREATE
                }
            } else {
                rnOpt: st.typing.funcReturnNode.get key: funcId
                match (
                    rnOpt
                ) case some then {

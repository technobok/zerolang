# Type checker, ported from src/ztypecheck.py.
#
# Slice 4.5a: registers one UNIT type per unit (the `unit` table) and resolves
# the MAIN unit's top-level FUNCTION definition signatures into the type
# registry -- each function plus its parameter children, with referenced
# parameter types registered as shallow named shells. Mirrors the reference
# `resolve_only_main` capability (no body walk, no generics, no system-wide
# resolution); the SQL `types` / `type_children` tables read the result,
# filtered to the example's own unit. Data blocks, records, variants, classes,
# generics and body checking arrive in later slices.
#
# The registry is created by the caller and threaded in (not stored on the
# ZTyping container), mirroring the reference's module-level type table: the
# SQL dumper reads it as a separate argument.

Node: zast.Node

# unitLabel -- a unit/definition namedoperation label as an owned String
# ("" when the operation carries no label).
unitLabel: function {o: (Option t: String)} out String is {
    match (
        o
    ) case some then {
        return o.string
    } case none then {
        return "".string
    }
}

# unitdefNodeId -- the nodeid of a unitdef Node (0 when not a unitdef).
unitdefNodeId: function {n: Node} out u32 is {
    match (
        n
    ) case unitdef then {
        return n.nodeid
    } else {
        return 0.u32
    }
}

# nodeId -- the nodeid of an arbitrary type-ref / definition Node. Covers the
# kinds a type expression or method def can take (atom / labelvalue / dotted /
# expression / call / functiondef); 0 otherwise (the stamp is then a no-op row
# the typed_nodes JOIN drops).
nodeId: function {n: Node} out u32 is {
    match (
        n
    ) case atomid then {
        return n.nodeid
    } case labelvalue then {
        return n.nodeid
    } case binop then {
        return n.nodeid
    } case dottedpath then {
        return n.nodeid
    } case expression then {
        return n.nodeid
    } case call then {
        return n.nodeid
    } case functiondef then {
        return n.nodeid
    } case assignment then {
        return n.nodeid
    } case reassignment then {
        return n.nodeid
    } else {
        return 0.u32
    }
}

# nodeLine / nodeCol -- the source position of a value-expression Node. Covers
# the operation kinds a call argument can take; 0 otherwise.
nodeLine: function {n: Node} out u32 is {
    match (
        n
    ) case atomid then {
        return n.lineno
    } case labelvalue then {
        return n.lineno
    } case dottedpath then {
        return n.lineno
    } case expression then {
        return n.lineno
    } case call then {
        return n.lineno
    } case binop then {
        return n.lineno
    } case atomstring then {
        return n.lineno
    } else {
        return 0.u32
    }
}

nodeCol: function {n: Node} out u32 is {
    match (
        n
    ) case atomid then {
        return n.colno
    } case labelvalue then {
        return n.colno
    } case dottedpath then {
        return n.colno
    } case expression then {
        return n.colno
    } case call then {
        return n.colno
    } case binop then {
        return n.colno
    } case atomstring then {
        return n.colno
    } else {
        return 0.u32
    }
}

# atomName -- the name of an atom Node (atomid / labelvalue) as an owned String,
# "" for anything else. Matching the Node param narrows it cleanly (the proven
# simple-param pattern), so callers pass a field/arg projection without worrying
# about path-subject narrowing.
atomName: function {n: Node} out String is {
    match (
        n
    ) case atomid then {
        return n.name.string
    } case labelvalue then {
        return n.name.string
    } else {
        return "".string
    }
}

# resolveAtomType -- map a type-atom name to a SHALLOW shell type id. `this`
# resolves to the enclosing record (passed as thisName); a leading-digit name is
# a numeric-literal field/param default and resolves to f64 (has a dot) or i64;
# otherwise the name is taken verbatim. Shells carry no members, no definedInUnit.
resolveAtomType: function {reg: ztypes.ZTypeRegistry nm: StringView thisName: StringView} out u64 is {
    if nm == "this" then {
        return (reg.newType name: thisName typetype: ztypes.ztypetype.RECORD)
    } else {}
    if nm == "type" then {
        if thisName.length == 0.u64 then {} else {
            return (reg.newType name: thisName typetype: ztypes.ztypetype.RECORD)
        }
    } else {}
    b0: nm.byteAt 0.u64
    isnum: false
    match (
        b0
    ) case some then {
        if b0 >= 48.u8 when b0 <= 57.u8 then {
            isnum = true
        } else {}
    } case none then {}
    if isnum then {
        if (nm.contains ".") then {
            return (reg.newType name: "f64" typetype: ztypes.ztypetype.RECORD)
        } else {}
        return (reg.newType name: "i64" typetype: ztypes.ztypetype.RECORD)
    } else {}
    return (reg.newType name: nm typetype: ztypes.ztypetype.RECORD)
}

# literalIntId -- pseudo-type id worn by bare numeric literals during the body
# walk. Never registered, so symbol-table and node rows carrying it drop out of
# the dump projections' types join; foldLiteralStamps rewrites surviving node
# stamps to i64 before the dump.
literalIntId: 0x7FFFFFFFFFFFFFFF.u64
literalFloatId: 0x7FFFFFFFFFFFFFFE.u64

# isNumericLiteralName -- true when a name begins with a digit: a numeric-literal
# atom (an `as`-block static constant like `version: 1`), as opposed to a type-name
# atom (a conformance marker). 48..57 are the ASCII digits.
isNumericLiteralName: function {name: StringView} out bool is {
    b0: name.byteAt 0.u64
    match (
        b0
    ) case some then {
        if b0 >= 48.u8 when b0 <= 57.u8 then {
            return true
        } else {}
        if b0 == 45.u8 then {
            b1: name.byteAt 1.u64
            match (
                b1
            ) case some then {
                if b1 >= 48.u8 when b1 <= 57.u8 then {
                    return true
                } else {}
            } case none then {}
        } else {}
    } case none then {}
    return false
}

# isStripMarker -- true for a dotted-path leaf that is an ownership or access marker
# (`.lock`/`.borrow`/`.take`/`.private`/`.public`); a type reference peels these to
# reach the underlying base type.
isStripMarker: function {name: StringView} out bool is {
    if name == "lock" then { return true } else {}
    if name == "borrow" then { return true } else {}
    if name == "take" then { return true } else {}
    if name == "private" then { return true } else {}
    if name == "public" then { return true } else {}
    return false
}

# isLabelValue -- true when a node is a bare `:X` label-value (an anonymous
# conformance marker in an as-block parses as a namedoperation wrapping one).
isLabelValue: function {op: Node} out bool is {
    match (
        op
    ) case labelvalue then {
        return true
    } else {
        return false
    }
}

# isBareGenericParam -- a generic-param definition in direct dotted form
# (`t: Any.generic`); wrapped shapes (a def whose payload merely contains a
# constraint) are not unit-level generic params.
isBareGenericParam: function {op: Node} out bool is {
    match (
        op
    ) case dottedpath then {
        leaf: atomName n: op.child
        if leaf.stringview == "generic" then { return true } else {}
        if leaf.stringview == "valtype" then { return true } else {}
        if leaf.stringview == "reftype" then { return true } else {}
        return false
    } else {
        return false
    }
}

# isGenericParam -- true when a type-expr is a generic-parameter constraint
# (`Any.generic` / `u64.generic` / `Any.valtype`): a dottedpath whose leaf is
# `generic` or `valtype`, peeling an `expression` / parameterized `call` wrapper.
isGenericParam: function {op: Node} out bool is {
    match (
        op
    ) case expression then {
        return (isGenericParam op: op.expression)
    } case call then {
        return (isGenericParam op: op.callable)
    } case dottedpath then {
        leaf: atomName n: op.child
        if leaf.stringview == "generic" then { return true } else {}
        if leaf.stringview == "valtype" then { return true } else {}
        if leaf.stringview == "reftype" then { return true } else {}
        return false
    } else {
        return false
    }
}

# registerGenericParams -- record a type's generic-param names (keyed
# `{unit}.{type}.{param}`) so method-param resolution can drop params typed by them.
registerGenericParams: function {reg: ztypes.ZTypeRegistry typeKey: StringView items: (List of: Node)} is {
    iter: items.iterate
    for m: iter loop {
        match (
            m
        ) case namedoperation then {
            if (isGenericParam op: m.operation) then {
                pn: unitLabel o: m.name
                reg.addGenericParam typeKey: typeKey paramName: pn.stringview
            } else {}
        } else {}
    }
}

# hasGenericParam -- true when any item in the block is a generic-param declaration.
# Takes the list by value so its iterator's lock is released on return (the scan is
# sequenced before any persistent iterator over the same list).
hasGenericParam: function {items: (List of: Node)} out bool is {
    it: items.iterate
    for m: it loop {
        match (
            m
        ) case namedoperation then {
            if (isGenericParam op: m.operation) then { return true } else {}
        } else {}
    }
    return false
}

# pathOwnership -- the ownership a param/field type expr declares via a `.lock`/
# `.borrow`/`.take` dotted-path leaf, or none. (Only `.lock` is valid on a field; all
# three on a param.)
pathOwnership: function {n: Node} out (optionval t: ztypes.zparamownership) is {
    match (
        n
    ) case dottedpath then {
        cn: atomName n: n.child
        if cn.stringview == "lock" then {
            return (optionval.some ztypes.zparamownership.LOCK)
        } else {}
        if cn.stringview == "borrow" then {
            return (optionval.some ztypes.zparamownership.BORROW)
        } else {}
        if cn.stringview == "take" then {
            return (optionval.some ztypes.zparamownership.TAKE)
        } else {}
        return (optionval.none ztypes.zparamownership)
    } else {
        return (optionval.none ztypes.zparamownership)
    }
}

# baseTypeName -- the underlying base type name of a type expr, peeling `.lock`/
# `.private`/etc. dotted-path markers (`Container.private.lock` -> `Container`,
# `this.lock` -> `this`); the atom name for a bare atom; "" otherwise.
baseTypeName: function {n: Node} out String is {
    match (
        n
    ) case atomid then {
        return n.name.string
    } case labelvalue then {
        return n.name.string
    } case dottedpath then {
        cn: atomName n: n.child
        if (isStripMarker name: cn.stringview) then {
            return (baseTypeName n: n.parent)
        } else {
            return "".string
        }
    } else {
        return "".string
    }
}

# resolveTyperefShell -- register a SHALLOW named shell for a referenced type
# (e.g. the `i64` in `n: i64`), routing atom names through resolveAtomType so
# `this`/numeric-default atoms resolve correctly. A parenthesized parameterized
# type `(T arg: N)` (an expression wrapping a call) mangles to a `T_N` shell.
# Source-type rows never include these shells (they fall outside `defined_in_unit`),
# but a `type_children` row joins to the shell's name. Returns the shell's type id.
recordNodeName: function {ty: ztyping.ZTyping name: StringView nid: u64} is {
    if name.length == 0.u64 then {} else {
        kc: nid
        ty.pendingTyperef.set key: kc value: name.string
    }
}

# recordResolvedName -- record (nid -> name) for post-demand resolution; the `this` and
# `type` self-keywords record as the enclosing type (thisName).
recordResolvedName: function {ty: ztyping.ZTyping thisName: StringView name: StringView nid: u64} is {
    if name == "this" then {
        recordNodeName ty: ty name: thisName nid: nid
    } else {
        if name == "type" then {
            recordNodeName ty: ty name: thisName nid: nid
        } else {
            if (isNumericLiteralName name: name) then {
                if (name.contains ".") then {
                    recordNodeName ty: ty name: "f64" nid: nid
                } else {
                    recordNodeName ty: ty name: "i64" nid: nid
                }
            } else {
                recordNodeName ty: ty name: name nid: nid
            }
        }
    }
}

# monoArgName -- a pending-instantiation argument's recorded name: `this` and
# `type` map to the enclosing type (the recordResolvedName mapping); "" when
# there is no enclosing type.
monoArgName: function {an: StringView thisName: StringView} out String is {
    if an == "this" then {
        return thisName.string
    } else {
    }
    if an == "type" then {
        return thisName.string
    } else {
    }
    return an.string
}

# recordPendingMono -- record a pending generic instantiation for a call-shaped
# parameterized type-ref, keyed to the EXPRESSION wrapper node `nid` (the
# reference stamps the wrapper with the instance type). Args must be bare atoms
# (`this` / `type` map to the enclosing type); numeric size args or an empty
# callable skip the record.
recordPendingMono: function {ty: ztyping.ZTyping thisName: StringView op: Node nid: u32} is {
    match (
        op
    ) case call then {
        tname: atomName n: op.callable
        margs: (List of: String)
        margNames: (List of: String)
        allAtoms: true
        aiter: op.arguments.iterate
        for arg: aiter loop {
            match (
                arg
            ) case namedoperation then {
                an: atomName n: arg.operation
                if (isNumericLiteralName name: an.stringview) then {
                    allAtoms = false
                } else {
                    if an.length == 0.u64 then {
                        allAtoms = false
                    } else {
                        anc: monoArgName an: an.stringview thisName: thisName
                        if anc.length == 0.u64 then {
                            allAtoms = false
                        } else {
                            margs.append anc
                            pn: unitLabel o: arg.name
                            margNames.append pn
                        }
                    }
                }
            } else {}
        }
        if tname.length > 0.u64 when allAtoms when margs.length > 0.u64 then {
            pm: (ztyping.PendingMono nodeid: nid template: tname args: margs argNames: margNames)
            ty.pendingMono.append pm
        } else {}
    } else {}
}

# recordTyperef -- record a signature type-ref node (param / field / arm / return) for
# post-demand stamping. resolveTyperefShell yields only a NULL-unit shell and the real
# type may be unresolved here (system / forward refs), so the base name is resolved to its
# real type later by stampTyperefs. Recurses parameterized args and strip-marker dotted
# paths; `this`/`type` record as the enclosing type (thisName).
recordTyperef: function {ty: ztyping.ZTyping thisName: StringView node: Node} is {
    match (
        node
    ) case expression then {
        recordPendingMono ty: ty thisName: thisName op: node.expression nid: node.nodeid
        recordTyperef ty: ty thisName: thisName node: node.expression
    } case call then {
        # Parameterized type `(T arg: U ...)`: the outer node resolves to a NULL-defined
        # mono (filtered out); record each argument's inner TYPE-ref (e.g. the `u32` in
        # `(optionval t: u32)`), but skip numeric-literal size args (the `16` in
        # `(str to: 16)`) -- they are const values, not type references. The pending
        # instantiation is recorded by the enclosing expression arm (the wrapper node
        # carries the reference's instance stamp).
        aiter: node.arguments.iterate
        for arg: aiter loop {
            match (
                arg
            ) case namedoperation then {
                an: atomName n: arg.operation
                if (isNumericLiteralName name: an.stringview) then {} else {
                    recordTyperef ty: ty thisName: thisName node: arg.operation
                }
            } else {}
        }
    } case dottedpath then {
        # Ownership/access strip marker (this.lock / StringView.borrow / Container.private):
        # record the dotted node with its peeled base AND recurse on the parent so the
        # stripped inner atom is stamped too (the reference stamps both ppath + stripped).
        # A `.typedef` marker only recurses -- the dotted node itself resolves to a
        # NULL-defined typedef wrapper the dump filters out.
        cn: atomName n: node.child
        if (isStripMarker name: cn.stringview) then {
            bn: baseTypeName n: node.parent
            recordResolvedName ty: ty thisName: thisName name: bn.stringview nid: node.nodeid.u64
            # Ownership markers peel and stamp the inner ref; `.private` /
            # `.public` resolve the pair atomically (no base-atom stamp).
            if cn.stringview == "private" then {
            } else {
                if cn.stringview == "public" then {
                } else {
                    recordTyperef ty: ty thisName: thisName node: node.parent
                }
            }
        } else {
            if cn.stringview == "typedef" then {
                recordTyperef ty: ty thisName: thisName node: node.parent
            } else {}
        }
    } case atomid then {
        recordResolvedName ty: ty thisName: thisName name: node.name.stringview nid: node.nodeid.u64
    } case labelvalue then {
        recordResolvedName ty: ty thisName: thisName name: node.name.stringview nid: node.nodeid.u64
    } else {}
}

# stampGenericParamRef -- a return typeref naming one of the enclosing
# template's generic params stamps the unit's generic-param type directly
# (generic params live outside the name-resolution table).
stampGenericParamRef: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView enclKey: StringView o: (Option t: Node)} is {
    match (
        o
    ) case some then {
        bn: atomName n: o
        if (reg.isGenericParamOf typeKey: enclKey name: bn.stringview) then {
            uk3: unitName.string
            ugo3: ty.unitGenericParamId.get key: uk3
            match (
                ugo3
            ) case some then {
                gnid3: nodeId n: o
                ugv3: ugo3
                ty.nodeType.set key: gnid3.u64 value: ugv3
            } case none then {}
        } else {}
    } case none then {}
}

# recordFuncReturnNode -- map a function type id to its return type-ref's node id
# so a call site can read the resolved return type (node_type, post stampTyperefs).
recordFuncReturnNode: function {ty: ztyping.ZTyping fid: u64 o: (Option t: Node)} is {
    match (
        o
    ) case some then {
        rn: nodeId n: o
        fidc: fid
        ty.funcReturnNode.set key: fidc value: rn.u64
    } case none then {
    }
}

# recordReturnType -- record a function's `out T` return type-ref (mirrors
# demandReturnType's extraction). A parameterized return (out (Result ...)) yields no
# bare base name and is skipped (its mono is NULL-defined, filtered out anyway).
recordReturnType: function {ty: ztyping.ZTyping thisName: StringView o: (Option t: Node)} is {
    match (
        o
    ) case some then {
        recordTyperef ty: ty thisName: thisName node: o
    } case none then {}
}

resolveTyperefShell: function {reg: ztypes.ZTypeRegistry typeExpr: Node thisName: StringView} out u64 is {
    match (
        typeExpr
    ) case atomid then {
        reg.recordDemand name: typeExpr.name.stringview
        return (resolveAtomType reg: reg nm: typeExpr.name.stringview thisName: thisName)
    } case labelvalue then {
        return (resolveAtomType reg: reg nm: typeExpr.name.stringview thisName: thisName)
    } case expression then {
        return (resolveTyperefShell reg: reg typeExpr: typeExpr.expression thisName: thisName)
    } case call then {
        suffix: atomName n: typeExpr.callable
        reg.recordDemand name: suffix.stringview
        aiter: typeExpr.arguments.iterate
        for arg: aiter loop {
            match (
                arg
            ) case namedoperation then {
                an: atomName n: arg.operation
                suffix.append "_"
                suffix.append an.stringview
            } else {}
        }
        return (reg.newType name: suffix.stringview typetype: ztypes.ztypetype.RECORD)
    } case dottedpath then {
        # A dotted type-expr peels to its parent: an ownership/access strip marker
        # (Container.private.lock) or a variant/union subtype default where the arm is
        # the default value and the type is the parent (direction.north -> direction).
        return (resolveTyperefShell reg: reg typeExpr: typeExpr.parent thisName: thisName)
    } else {
        return (reg.newType name: "?" typetype: ztypes.ztypetype.RECORD)
    }
}

# nameIsInUnitReftype -- true when a type name resolves to an in-unit reference type
# (class or union). Drives the reftype-param BORROW default and class field cleanup.
# Native heap params (String/List/Map) are pointer-typed already and get no BORROW
# default (mirrors the reference's `not is_heap_allocated` guard), so they are NOT
# matched here -- only user class/union types defined in this unit.
nameIsInUnitReftype: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView name: StringView} out bool is {
    rkey: "\{unitName}.\{name}".string
    rr: ty.resolved.get key: rkey
    match (
        rr
    ) case some then {
        tt: reg.typetypeOf typeId: rr
        match (
            tt
        ) case CLASS then {
            return true
        } case UNION then {
            return true
        } else {
            return false
        }
    } case none then {
        return false
    }
}

# paramTypeBaseName -- the base type name of a (possibly parameterized) param type
# expression: an atom name directly, or the callable of a parenthesized
# `(List of: i64)` form (an expression wrapping a call). "" for anything else.
# returnHasBorrowMarkerNode / returnHasBorrowMarker -- the function's return
# type carries the `.borrow` marker (`out StringView.borrow`).
returnHasBorrowMarkerNode: function {n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (returnHasBorrowMarkerNode n: n.expression)
    } case dottedpath then {
        cn: atomName n: n.child
        return cn.stringview == "borrow"
    } else {
        return false
    }
}

returnHasBorrowMarker: function {o: (Option t: Node)} out bool is {
    match (
        o
    ) case some then {
        return (returnHasBorrowMarkerNode n: o)
    } case none then {
        return false
    }
}

# paramIsThisReceiver -- the parameter's type names the receiver: bare `this`
# or a marker-suffixed `this.lock` / `this.borrow`.
paramIsThisReceiver: function {op: Node} out bool is {
    match (
        op
    ) case expression then {
        return (paramIsThisReceiver op: op.expression)
    } case atomid then {
        return op.name.stringview == "this"
    } case dottedpath then {
        pn: atomName n: op.parent
        return pn.stringview == "this"
    } else {
        return false
    }
}

paramTypeBaseName: function {op: Node} out String is {
    match (
        op
    ) case atomid then {
        return op.name.string
    } case labelvalue then {
        return op.name.string
    } case expression then {
        return (paramTypeBaseName op: op.expression)
    } case call then {
        return (atomName n: op.callable)
    } else {
        return "".string
    }
}

# isBorrowReftypeCollection -- true for a parameterized collection whose mono is a
# non-heap-allocated reftype, which takes the reftype-param BORROW default: List and
# ListView (stack struct + heap buffer). Set/Map monos are heap-allocated (no BORROW);
# the native iterator views have no destructor (no BORROW); str/array are valtypes.
# Mirrors the is_heap_allocated the reference stamps on collection monos.
isBorrowReftypeCollection: function {name: StringView} out bool is {
    if name == "List" then {
        return true
    } else {}
    if name == "ListView" then {
        return true
    } else {}
    return false
}

# isBorrowNativeReftype -- true for native heap-owning reftypes (currently String)
# that take the BORROW default as an unannotated param. Keyed by name, like the
# classifiers above: the oracle decides by metadata (a native CLASS that owns heap,
# not is_heap_allocated), but native types resolve AFTER the main unit, so that
# metadata is not yet populated when a param resolves.
isBorrowNativeReftype: function {name: StringView} out bool is {
    if name == "String" then {
        return true
    } else {}
    return false
}

# isNativeValueView -- true for StringView, the native immutable string view (subtype
# STRINGVIEW): a param of this type stays unowned (a value-passed copy of a borrowed
# view), so it takes no BORROW default. Other reftypes -- String (native, owns heap),
# the mutable iterators (CpIter/Splitter/LinesIter), and non-native views (ListView/
# OptionView) -- take the normal reftype-param BORROW default.
isNativeValueView: function {name: StringView} out bool is {
    if name == "StringView" then {
        return true
    } else {}
    return false
}

# demandReturnType -- record cross-unit demand for a function's return-type base
# name (`out (Result t: u64 e: IoError)` -> demand "Result"), so a type named only
# in a return position is resolved. The Option is borrowed, never bound.
demandReturnType: function {reg: ztypes.ZTypeRegistry o: (Option t: Node)} is {
    match (
        o
    ) case some then {
        bn: paramTypeBaseName op: o
        if bn.length == 0.u64 then {} else {
            reg.recordDemand name: bn.stringview
        }
    } case none then {}
}

# resolveFunction -- resolve a function definition signature into a FUNCTION
# type: a child per parameter (param name -> type-ref shell, `this` params bound
# to thisName), its defining unit (source-types filter), and a `{unit}.{name}`
# entry in the resolved name-view. Returns the FUNCTION type id (a record method
# binds it as a child; a free function discards it). The map `set`s TAKE the u64,
# so copies are threaded for `definedInUnit.set` and the returned id.
resolveFunction: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView defName: StringView fnode: zast.FunctionData thisName: StringView skipThisType: bool} out u64 is {
    fid: reg.newType name: defName typetype: ztypes.ztypetype.FUNCTION
    dfid: fid
    rfid: fid
    isgen: hasGenericParam items: fnode.asItems
    if isgen then {
        reg.setGeneric typeId: fid value: true
        aiter2: fnode.asItems.iterate
        for am: aiter2 loop {
            match (
                am
            ) case namedoperation then {
                if (isGenericParam op: am.operation) then {
                    apn: unitLabel o: am.name
                    ty.setGenericArg parentTypeId: fid paramName: apn.stringview argTypeId: 0
                } else {}
            } else {}
        }
        hasB: false
        match (
            fnode.body
        ) case some then {
            hasB = true
        } case none then {}
        if hasB then {
            dvg: bodyEndsInReturn bodyOpt: fnode.body
            fidd: fid
            ty.fnBodyDiverges.set key: fidd value: dvg
        } else {}
    } else {}
    enclKey: unitName.string
    if thisName.length == 0.u64 then {} else {
        enclKey = "\{unitName}.\{thisName}".string
    }
    piter: fnode.parameters.iterate
    for pm: piter loop {
        match (
            pm
        ) case namedoperation then {
            skipParam: false
            genParam: false
            ptn: atomName n: pm.operation
            if skipThisType then {
                if ptn.stringview == "this" then {
                    skipParam = true
                } else {}
            } else {}
            if (reg.isGenericParamOf typeKey: enclKey.stringview name: ptn.stringview) then {
                skipParam = true
                genParam = true
            } else {}
            if skipParam then {
                if genParam then {
                    uk2: unitName.string
                    ugo2: ty.unitGenericParamId.get key: uk2
                    match (
                        ugo2
                    ) case some then {
                        pnid2: nodeId n: pm.operation
                        ugv2: ugo2
                        ty.nodeType.set key: pnid2.u64 value: ugv2
                    } case none then {}
                } else {}
            } else {
                pname: unitLabel o: pm.name
                cid: resolveTyperefShell reg: reg typeExpr: pm.operation thisName: thisName
                ty.setChild parentTypeId: fid childName: pname.stringview childTypeId: cid
                if (paramIsThisReceiver op: pm.operation) then {
                    reg.setThisParamName typeId: fid name: pname.stringview
                } else {
                }
                recordTyperef ty: ty thisName: thisName node: pm.operation
                pown: pathOwnership n: pm.operation
                match (
                    pown
                ) case some then {
                    ty.setChildOwnership parentTypeId: fid name: pname.stringview ownership: pown
                } case none then {
                    isref: paramIsBorrowReftype ty: ty reg: reg unitName: unitName thisName: thisName op: pm.operation
                    if isref then {
                        ty.setChildOwnership parentTypeId: fid name: pname.stringview ownership: ztypes.zparamownership.BORROW
                    } else {}
                }
            }
        } else {}
    }
    demandReturnType reg: reg o: fnode.returntype
    recordReturnType ty: ty thisName: thisName o: fnode.returntype
    recordFuncReturnNode ty: ty fid: fid o: fnode.returntype
    stampGenericParamRef ty: ty reg: reg unitName: unitName enclKey: enclKey.stringview o: fnode.returntype
    if (returnHasBorrowMarker o: fnode.returntype) then {
        fbk: fid
        fbv: true
        ty.funcReturnsBorrow.set key: fbk value: fbv
    } else {
    }
    ty.definedInUnit.set key: dfid value: unitName.string
    key: "\{unitName}.\{defName}".string
    ty.resolved.set key: key value: fid
    return rfid
}

# paramIsBorrowReftype -- the default-ownership rule for a parameter with no
# explicit suffix: user reftypes (and the borrow-default native reftypes /
# collections) borrow; native value views do not.
paramIsBorrowReftype: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView thisName: StringView op: Node} out bool is {
    tn: atomName n: op
    isref: false
    if tn.stringview == "this" then {
        isref = nameIsInUnitReftype ty: ty reg: reg unitName: unitName name: thisName
        if (isNativeValueView name: thisName) then {
            isref = false
        } else {}
    } else {
        if tn.length == 0.u64 then {
            base: paramTypeBaseName op: op
            isref = isBorrowReftypeCollection name: base.stringview
        } else {
            isref = nameIsInUnitReftype ty: ty reg: reg unitName: unitName name: tn.stringview
            if (isBorrowNativeReftype name: tn.stringview) then {
                isref = true
            } else {}
            if (isNativeValueView name: tn.stringview) then {
                isref = false
            } else {}
        }
    }
    return isref
}

# fixupDemandedParamOwnership -- under the full body-walk driver, a main-unit
# reftype may resolve AFTER the functions that reference it (demand order, not
# body order), so resolveFunction's default-ownership rule missed it. Re-run
# the rule for top-level main-unit function params with no recorded ownership.
fixupDemandedParamOwnership: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView unitdef: Node} is {
    match (
        unitdef
    ) case unitdef then {
        biter: unitdef.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                if (isFunctionDefOp op: bm.operation) then {
                    dn: unitLabel o: bm.name
                    rkey: "\{unitName}.\{dn}".string
                    fo: ty.resolved.get key: rkey
                    match (
                        fo
                    ) case some then {
                        fixupFnParamOwnership ty: ty reg: reg unitName: unitName fid: fo defn: bm.operation
                    } case none then {
                    }
                } else {
                }
            } else {}
        }
    } else {}
}

fixupFnParamOwnership: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView fid: u64 defn: Node} is {
    match (
        defn
    ) case functiondef then {
        piter: defn.parameters.iterate
        for pm: piter loop {
            match (
                pm
            ) case namedoperation then {
                pname: unitLabel o: pm.name
                hasOwn: ty.hasChildOwnership parentTypeId: fid name: pname.stringview
                if hasOwn then {
                } else {
                    pown: pathOwnership n: pm.operation
                    match (
                        pown
                    ) case some then {
                    } case none then {
                        isref: paramIsBorrowReftype ty: ty reg: reg unitName: unitName thisName: "" op: pm.operation
                        if isref then {
                            ty.setChildOwnership parentTypeId: fid name: pname.stringview ownership: ztypes.zparamownership.BORROW
                        } else {}
                    }
                }
            } else {}
        }
    } else {}
}

# resolveMethodFn -- resolve one record-method as-item (a namedoperation whose
# operation is a functiondef) into a qualified `{record}.{method}` FUNCTION type,
# `this` params bound to thisName (the record). Returns its type id, or none for a
# non-function as-item (tag spec / generic param), which the caller skips.
resolveMethodFn: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView qname: StringView thisName: StringView op: Node} out (optionval t: u64) is {
    match (
        op
    ) case functiondef then {
        mid: resolveFunction ty: ty reg: reg unitName: unitName defName: qname fnode: op thisName: thisName skipThisType: false
        midS: mid
        ty.nodeType.set key: op.nodeid.u64 value: midS
        return (optionval.some mid)
    } else {
        return (optionval.none u64)
    }
}

# isFunctionDefOp -- true when an is-block item's operation is a functiondef (a
# method), false for a field type-ref. Gates generic-class method production without
# resolving the function -- mirrors the oracle's isgeneric gate, which never builds a
# method FUNCTION type for a generic class (so no spurious collections FUNCTION row).
isFunctionDefOp: function {op: Node} out bool is {
    match (
        op
    ) case functiondef then {
        return true
    } else {
        return false
    }
}

# resolveSpecFn -- resolve one facet/protocol is-block spec method (a namedoperation
# whose operation is a functiondef) into a qualified `{type}.{spec}` FUNCTION. Like
# resolveMethodFn but drops the `:this` receiver: a facet/protocol `this` resolves to
# nothing (the reference returns no type), so the spec keeps only its real params.
resolveSpecFn: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView qname: StringView thisName: StringView op: Node skipThis: bool} out (optionval t: u64) is {
    match (
        op
    ) case functiondef then {
        sid: resolveFunction ty: ty reg: reg unitName: unitName defName: qname fnode: op thisName: thisName skipThisType: skipThis
        sidS: sid
        ty.nodeType.set key: op.nodeid.u64 value: sidS
        return (optionval.some sid)
    } else {
        return (optionval.none u64)
    }
}

# markerTargetId -- the FACET/PROTOCOL type a conformance as-item points at
# (`m: measurable` / `myreader: Reader`), or none for a method / `create: null` /
# any other as-item. The target must already be resolved (defined earlier in the unit).
markerTargetId: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView op: Node} out (optionval t: u64) is {
    tn: atomName n: op
    if tn.length == 0.u64 then {
        return (optionval.none u64)
    } else {}
    rkey: "\{unitName}.\{tn}".string
    rr: ty.resolved.get key: rkey
    match (
        rr
    ) case some then {
        tt: reg.typetypeOf typeId: rr
        match (
            tt
        ) case FACET then {
            return (optionval.some rr)
        } case PROTOCOL then {
            return (optionval.some rr)
        } case RECORD then {
            return (optionval.some rr)
        } else {
            return (optionval.none u64)
        }
    } case none then {
        return (optionval.none u64)
    }
}

# attachMethods -- resolve an as-block's method items (namedoperation -> functiondef)
# as children of `parentId`, returning whether one is named `create` (so the caller
# skips the synth create). Takes the item list by value so its iterator's lock is
# released on return -- letting attachMarkers re-scan the same list (cf. resolveUnion).
attachMethods: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView defName: StringView parentId: u64 asItems: (List of: Node)} out bool is {
    hasCreate: false
    aiter: asItems.iterate
    for am: aiter loop {
        match (
            am
        ) case namedoperation then {
            mname: unitLabel o: am.name
            if mname.stringview == "create" then {
                hasCreate = true
            } else {}
            qname: "\{defName}.\{mname}".string
            mido: resolveMethodFn ty: ty reg: reg unitName: unitName qname: qname.stringview thisName: defName op: am.operation
            match (
                mido
            ) case some then {
                ty.setChild parentTypeId: parentId childName: mname.stringview childTypeId: mido
            } case none then {
                cn: atomName n: am.operation
                if (isNumericLiteralName name: cn.stringview) then {
                    # A static constant's child is a per-constant NULL-unit
                    # clone of the literal's default type: named through the
                    # type_children join, filtered from typed_nodes.
                    clname: "i64"
                    if (isFloatLiteralName name: cn.stringview) then {
                        clname = "f64"
                    } else {}
                    cid: reg.newType name: clname typetype: ztypes.ztypetype.RECORD
                    ty.setChild parentTypeId: parentId childName: mname.stringview childTypeId: cid
                    ty.markAsConstClone typeId: cid
                    cnid3: nodeId n: am.operation
                    cidc: cid
                    ty.nodeType.set key: cnid3.u64 value: cidc
                } else {}
            }
            gfn: "\{defName}_\{mname}".string
            synthGeneratorForMethod ty: ty reg: reg unitName: unitName fnName: gfn.stringview thisName: defName op: am.operation
        } else {}
    }
    return hasCreate
}

# attachMarkers -- resolve an as-block's facet/protocol conformance markers
# (`m: measurable` / `myreader: Reader`) as children of `parentId`, run AFTER the
# methods so markers take later positions. Returns whether any marker target owns a
# destructor (a protocol), so a class holder keeps its own.
# recordConformance -- record an impl-satisfies-spec conformance, but only when the
# spec resolves to a FACET or PROTOCOL (a RECORD marker like a numeric's `tag: tag` is a
# discriminator child, NOT a conformance). Mirrors _record_conformance (ztypecheck.py:3516);
# the helper C names (vtable/create/destroy/wrapper) are emitter-set and stay empty here.
recordConformance: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry implTypeId: u64 specTypeId: u64 label: StringView} is {
    tt: reg.typetypeOf typeId: specTypeId
    recordIt: false
    isFacetC: false
    match (
        tt
    ) case FACET then {
        recordIt = true
        isFacetC = true
    } case PROTOCOL then {
        recordIt = true
    } else {}
    if recordIt then {
        cf: reg.newConformance implTypeId: implTypeId specTypeId: specTypeId label: label isFacet: isFacetC
        ty.conformance.append cf
    } else {}
}

attachMarkers: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView parentId: u64 asItems: (List of: Node)} out bool is {
    needsDtor: false
    miter: asItems.iterate
    for mm: miter loop {
        match (
            mm
        ) case namedoperation then {
            cnm: atomName n: mm.operation
            if (isNumericLiteralName name: cnm.stringview) then {} else {
                recordTyperef ty: ty thisName: "" node: mm.operation
            }
            mtid: markerTargetId ty: ty reg: reg unitName: unitName op: mm.operation
            match (
                mtid
            ) case some then {
                mlbl: unitLabel o: mm.name
                ty.setChild parentTypeId: parentId childName: mlbl.stringview childTypeId: mtid
                if (reg.hasDestructorName typeId: mtid) then {
                    needsDtor = true
                } else {}
                recordConformance ty: ty reg: reg implTypeId: parentId specTypeId: mtid label: mlbl.stringview
            } case none then {
                if (isLabelValue op: mm.operation) then {
                    amlbl: unitLabel o: mm.name
                    amlid: resolveAtomType reg: reg nm: amlbl.stringview thisName: ""
                    ty.setChild parentTypeId: parentId childName: amlbl.stringview childTypeId: amlid
                    acf: reg.newConformance implTypeId: parentId specTypeId: amlid label: amlbl.stringview isFacet: false
                    ty.conformance.append acf
                } else {}
            }
        } else {}
    }
    return needsDtor
}

# dataOutTypeName -- the element-type name from a data block's optional `out T`
# (an atom type-expr), or "" when absent. The Option is BORROWED (param), never
# bound to a local: a bare bind would move the Option out of the shared AST node
# and free its payload, corrupting the later dump walk.
dataOutTypeName: function {o: (Option t: Node)} out String is {
    match (
        o
    ) case some then {
        return (atomName n: o)
    } case none then {
        return "".string
    }
}

# resolveData -- resolve a data-block definition into a DATA type: one `literal_int`
# child per element (the element's own label when present, else its ordinal) plus a
# `tag` child typed `tag__{element-type}` -- the `out T` width when declared, else
# i64 -- mark it a non-valtype, then record its defining unit + `{unit}.{name}` view.
# Elements stay literal_int (coerced per use); typed / float elements arrive with the
# examples that exercise them.
resolveData: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView defName: StringView dnode: zast.DataBlockData} is {
    did: reg.newType name: defName typetype: ztypes.ztypetype.DATA
    ddid: did
    reg.setValtype typeId: did value: false
    litId: reg.newType name: "literal_int" typetype: ztypes.ztypetype.RECORD
    ordinal: 0.u64
    eiter: dnode.elements.iterate
    for el: eiter loop {
        match (
            el
        ) case namedoperation then {
            nm: unitLabel o: el.name
            if nm.length == 0.u64 then {
                ord: "\{ordinal}".string
                ty.setChild parentTypeId: did childName: ord.stringview childTypeId: litId
            } else {
                ty.setChild parentTypeId: did childName: nm.stringview childTypeId: litId
            }
        } else {}
        ordinal = ordinal + 1.u64
    }
    etn: dataOutTypeName o: dnode.outType
    tagName: "tag__i64".string
    if etn.length == 0.u64 then {} else {
        tagName = "tag__\{etn.stringview}".string
    }
    tagId: reg.newType name: tagName.stringview typetype: ztypes.ztypetype.RECORD
    ty.setChild parentTypeId: did childName: "tag" childTypeId: tagId
    ty.definedInUnit.set key: ddid value: unitName.string
    key: "\{unitName}.\{defName}".string
    ty.resolved.set key: key value: did
}

# isTypedefField -- true when a type-expr Node is an `X.typedef` dottedpath (the
# marker that makes a record a zero-overhead typedef wrapper). Matching the Node
# param narrows it cleanly.
isTypedefField: function {n: Node} out bool is {
    match (
        n
    ) case dottedpath then {
        cn: atomName n: n.child
        return (cn.stringview == "typedef")
    } else {
        return false
    }
}

# recordIsTypedef -- true when a record's `is` body carries a single `X.typedef`
# field. Such a record gets no field child and synthesizes `create`+`borrow`
# instead of `create`/`==`/`!=`.
recordIsTypedef: function {rnode: zast.ObjectDefData} out bool is {
    fiter: rnode.isItems.iterate
    for fm: fiter loop {
        match (
            fm
        ) case namedoperation then {
            if (isTypedefField n: fm.operation) then {
                return true
            } else {}
        } else {}
    }
    return false
}

# typedefFieldBaseName -- the base type name of an `X.typedef` field's `X`
# (e.g. `(List of: u8).typedef` -> "List"). Borrows the Node, never binds it (a
# bare bind would move the type-expr out of the shared AST).
typedefFieldBaseName: function {n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        return (paramTypeBaseName op: n.parent)
    } else {
        return "".string
    }
}

# objectTypedefBase -- the base type name of an objectdef's single `X.typedef`
# field (the typedef wrapper base), or "" when the object is not a typedef.
objectTypedefBase: function {onode: zast.ObjectDefData} out String is {
    fiter: onode.isItems.iterate
    for fm: fiter loop {
        match (
            fm
        ) case namedoperation then {
            if (isTypedefField n: fm.operation) then {
                return (typedefFieldBaseName n: fm.operation)
            } else {}
        } else {}
    }
    return "".string
}

# resolveRecord -- resolve a record ObjectDef into a RECORD valtype. A normal
# record: a child per field (field name -> type-ref shell), a child per as-block
# method, then synthesized `create`/`==`/`!=`. A typedef record (single
# `X.typedef` field): no field child, the methods, then `create`+`borrow`. Synth
# children are shallow FUNCTION shells (JOIN-only). Generics arrive later.
resolveRecord: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView defName: StringView rnode: zast.ObjectDefData} is {
    rid: reg.newType name: defName typetype: ztypes.ztypetype.RECORD
    rrid: rid
    reg.setValtype typeId: rid value: true
    isgen: hasGenericParam items: rnode.asItems
    if isgen then {
        reg.setGeneric typeId: rid value: true
        rtk: "\{unitName}.\{defName}".string
        registerGenericParams reg: reg typeKey: rtk.stringview items: rnode.asItems
    } else {}
    istd: recordIsTypedef rnode: rnode
    if istd then {
        tdb: objectTypedefBase onode: rnode
        if tdb.length > 0.u64 then {
            tdk: rid
            ty.typedefBaseName.set key: tdk value: tdb
        } else {}
    } else {}
    hasCreateIs: false
    hasEqIs: false
    if istd then {} else {
        fiter: rnode.isItems.iterate
        for fm: fiter loop {
            match (
                fm
            ) case namedoperation then {
                fname: unitLabel o: fm.name
                qname: "\{defName}.\{fname}".string
                mido: resolveMethodFn ty: ty reg: reg unitName: unitName qname: qname.stringview thisName: defName op: fm.operation
                match (
                    mido
                ) case some then {
                    if fname.stringview == "create" then {
                        hasCreateIs = true
                    } else {}
                    if fname.stringview == "==" then {
                        hasEqIs = true
                    } else {}
                    ty.setChild parentTypeId: rid childName: fname.stringview childTypeId: mido
                } case none then {
                    cid: resolveTyperefShell reg: reg typeExpr: fm.operation thisName: ""
                    ty.setChild parentTypeId: rid childName: fname.stringview childTypeId: cid
                    recordTyperef ty: ty thisName: "" node: fm.operation
                }
            } else {}
        }
    }
    hasCreateAs: attachMethods ty: ty reg: reg unitName: unitName defName: defName parentId: rid asItems: rnode.asItems
    hasCreate: hasCreateIs
    if hasCreateAs then {
        hasCreate = true
    } else {}
    attachMarkers ty: ty reg: reg unitName: unitName parentId: rid asItems: rnode.asItems
    if hasCreate then {} else {
        createName: "\{defName}.create".string
        createId: reg.newType name: createName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: rid childName: "create" childTypeId: createId
    }
    if istd then {
        borrowName: "\{defName}.borrow".string
        borrowId: reg.newType name: borrowName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: rid childName: "borrow" childTypeId: borrowId
    } else {
        if isgen then {} else {
            if hasEqIs then {} else {
                eqName: "\{defName}.==".string
                eqId: reg.newType name: eqName.stringview typetype: ztypes.ztypetype.FUNCTION
                ty.setChild parentTypeId: rid childName: "==" childTypeId: eqId
                neqName: "\{defName}.!=".string
                neqId: reg.newType name: neqName.stringview typetype: ztypes.ztypetype.FUNCTION
                ty.setChild parentTypeId: rid childName: "!=" childTypeId: neqId
            }
        }
    }
    ty.definedInUnit.set key: rrid value: unitName.string
    key: "\{unitName}.\{defName}".string
    ty.resolved.set key: key value: rid
}

# resolveVariant -- resolve a variant ObjectDef into a VARIANT valtype: a child per
# arm (arm name -> payload type-ref shell; a `null` arm -> the `null` shell), a
# synthesized `tag` child (the `{name}:tag:data` discriminator wrapper), any as-block
# methods, then synthesized `==`/`!=`. Variants have no `create` (bare construction is
# disabled). Custom-DATA tags + generics arrive later.
resolveVariant: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView defName: StringView vnode: zast.ObjectDefData} is {
    vid: reg.newType name: defName typetype: ztypes.ztypetype.VARIANT
    vvid: vid
    reg.setValtype typeId: vid value: true
    isgen: hasGenericParam items: vnode.asItems
    if isgen then {
        reg.setGeneric typeId: vid value: true
    } else {}
    fiter: vnode.isItems.iterate
    for fm: fiter loop {
        match (
            fm
        ) case namedoperation then {
            aname: unitLabel o: fm.name
            cid: resolveTyperefShell reg: reg typeExpr: fm.operation thisName: ""
            ty.setChild parentTypeId: vid childName: aname.stringview childTypeId: cid
            recordTyperef ty: ty thisName: "" node: fm.operation
        } else {}
    }
    if isgen then {} else {
        tagName: "\{defName}:tag:data".string
        tagId: reg.newType name: tagName.stringview typetype: ztypes.ztypetype.DATA
        ty.setChild parentTypeId: vid childName: "tag" childTypeId: tagId
    }
    aiter: vnode.asItems.iterate
    for am: aiter loop {
        match (
            am
        ) case namedoperation then {
            mname: unitLabel o: am.name
            qname: "\{defName}.\{mname}".string
            mido: resolveMethodFn ty: ty reg: reg unitName: unitName qname: qname.stringview thisName: defName op: am.operation
            match (
                mido
            ) case some then {
                ty.setChild parentTypeId: vid childName: mname.stringview childTypeId: mido
            } else {}
        } else {}
    }
    if isgen then {} else {
        eqName: "\{defName}.==".string
        eqId: reg.newType name: eqName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: vid childName: "==" childTypeId: eqId
        neqName: "\{defName}.!=".string
        neqId: reg.newType name: neqName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: vid childName: "!=" childTypeId: neqId
    }
    ty.definedInUnit.set key: vvid value: unitName.string
    key: "\{unitName}.\{defName}".string
    ty.resolved.set key: key value: vid
}

# dottedParentName -- the parent atom name of a `parent.child` dottedpath Node, ""
# for anything else. Matching the Node param narrows it cleanly.
dottedParentName: function {n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        return (atomName n: n.parent)
    } else {
        return "".string
    }
}

# unionCustomTagId -- a union's custom DATA tag, if any: an `as { tag: <data>.tag }`
# item whose `<data>` resolves to an in-unit DATA type. Returns that DATA's type id;
# none when absent or not a DATA (the union then synthesizes its own tag wrapper).
unionCustomTagId: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView asItems: (List of: Node)} out (optionval t: u64) is {
    iter: asItems.iterate
    for am: iter loop {
        match (
            am
        ) case namedoperation then {
            nm: unitLabel o: am.name
            if nm.stringview == "tag" then {
                pn: dottedParentName n: am.operation
                if pn.length == 0.u64 then {} else {
                    rkey: "\{unitName}.\{pn}".string
                    rr: ty.resolved.get key: rkey
                    match (
                        rr
                    ) case some then {
                        tt: reg.typetypeOf typeId: rr
                        isdata: false
                        match (
                            tt
                        ) case DATA then {
                            isdata = true
                        } else {}
                        if isdata then {
                            return (optionval.some rr)
                        } else {}
                    } case none then {}
                }
            } else {}
        } else {}
    }
    return (optionval.none u64)
}

# resolveUnion -- resolve a union ObjectDef into a UNION reference type: a child
# per arm (arm name -> payload type-ref shell; a `null` arm -> the `null` shell),
# a synthesized `tag` child (the `{name}:tag:data` discriminator wrapper), then any
# as-block methods. Unions are reference types (is_valtype false); they have no
# `create` (bare construction is disabled) and no `==`/`!=`. A union keeps a
# destructor unless every arm is `null` (Priority elides it; IntResult/Result/Typed
# keep it). A custom DATA tag (`as { tag: <data>.tag }`) becomes the `tag` child in
# place of the synth wrapper; generics arrive later.
resolveUnion: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView defName: StringView vnode: zast.ObjectDefData} is {
    uid: reg.newType name: defName typetype: ztypes.ztypetype.UNION
    uuid: uid
    reg.setValtype typeId: uid value: false
    isgen: hasGenericParam items: vnode.asItems
    if isgen then {
        reg.setGeneric typeId: uid value: true
    } else {}
    allNull: true
    fiter: vnode.isItems.iterate
    for fm: fiter loop {
        match (
            fm
        ) case namedoperation then {
            aname: unitLabel o: fm.name
            an: atomName n: fm.operation
            if an.stringview == "null" then {} else {
                allNull = false
            }
            cid: resolveTyperefShell reg: reg typeExpr: fm.operation thisName: ""
            ty.setChild parentTypeId: uid childName: aname.stringview childTypeId: cid
            recordTyperef ty: ty thisName: "" node: fm.operation
        } else {}
    }
    if isgen then {} else {
        customTag: unionCustomTagId ty: ty reg: reg unitName: unitName asItems: vnode.asItems
        tagId: 0.u64
        match (
            customTag
        ) case some then {
            tagId = customTag
        } case none then {
            tagName: "\{defName}:tag:data".string
            tagId = reg.newType name: tagName.stringview typetype: ztypes.ztypetype.DATA
        }
        ty.setChild parentTypeId: uid childName: "tag" childTypeId: tagId
    }
    aiter: vnode.asItems.iterate
    for am: aiter loop {
        match (
            am
        ) case namedoperation then {
            mname: unitLabel o: am.name
            qname: "\{defName}.\{mname}".string
            mido: resolveMethodFn ty: ty reg: reg unitName: unitName qname: qname.stringview thisName: defName op: am.operation
            match (
                mido
            ) case some then {
                ty.setChild parentTypeId: uid childName: mname.stringview childTypeId: mido
            } else {}
        } else {}
    }
    if allNull then {} else {
        dn: "\{defName}_destroy".string
        reg.setDestructorName typeId: uid name: dn.stringview
    }
    ty.definedInUnit.set key: uuid value: unitName.string
    key: "\{unitName}.\{defName}".string
    ty.resolved.set key: key value: uid
}

# fieldTypeNeedsCleanup -- true when a class field needs cleanup (so the holder keeps
# a destructor): a `.lock` field (its borrow is released at scope exit), a native heap
# type (String/List/Map/Set), or an in-unit type that itself HAS a destructor
# (`reg.hasDestructorName`). A scalar field, or an owned class/union field whose type
# has no destructor, needs none. Name check for the natives is a scaffold-stage
# approximation (system types carry no real id under resolve-only-main).
fieldTypeNeedsCleanup: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView name: StringView isLock: bool} out bool is {
    if isLock then { return true } else {}
    if name == "String" then { return true } else {}
    if name == "List" then { return true } else {}
    if name == "Map" then { return true } else {}
    if name == "Set" then { return true } else {}
    rkey: "\{unitName}.\{name}".string
    rr: ty.resolved.get key: rkey
    match (
        rr
    ) case some then {
        return (reg.hasDestructorName typeId: rr)
    } case none then {
        return false
    }
}

# resolveClass -- resolve a class ObjectDef into a CLASS reference type: a child per
# field (field name -> type-ref shell), a child per as-block method, then a synthesized
# `create` child (LAST). Classes are reference types (is_valtype false); they get
# `create` but NO `==`/`!=` (unlike records). A class keeps a destructor when any field
# owns heap data (fieldTypeNeedsCleanup), else none. A typedef class (single
# `X.typedef` field) gets no field child, synth `create`+`borrow`, and inherits
# needs_destructor from the wrapped base (List -> yes, ListView -> no). Custom /
# `null` create, generics + protocols come later.
resolveClass: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView defName: StringView cnode: zast.ObjectDefData} is {
    cid: reg.newType name: defName typetype: ztypes.ztypetype.CLASS
    ccid: cid
    rcid: cid
    reg.setValtype typeId: cid value: false
    rkey: "\{unitName}.\{defName}".string
    ty.resolved.set key: rkey value: rcid
    needsDtor: false
    isgen: hasGenericParam items: cnode.asItems
    if isgen then {
        reg.setGeneric typeId: cid value: true
    } else {}
    istd: recordIsTypedef rnode: cnode
    if istd then {
        tdbase: objectTypedefBase onode: cnode
        if (fieldTypeNeedsCleanup ty: ty reg: reg unitName: unitName name: tdbase.stringview isLock: false) then {
            needsDtor = true
        } else {}
    } else {}
    fiter: cnode.isItems.iterate
    for fm: fiter loop {
        match (
            fm
        ) case namedoperation then {
            if (isFunctionDefOp op: fm.operation) then {
                if isgen then {} else {
                    fname: unitLabel o: fm.name
                    qname: "\{defName}.\{fname}".string
                    mido: resolveMethodFn ty: ty reg: reg unitName: unitName qname: qname.stringview thisName: defName op: fm.operation
                    match (
                        mido
                    ) case some then {
                        ty.setChild parentTypeId: cid childName: fname.stringview childTypeId: mido
                    } case none then {}
                }
            } else {
                fname: unitLabel o: fm.name
                ftn: baseTypeName n: fm.operation
                lockField: false
                flock0: pathOwnership n: fm.operation
                match (
                    flock0
                ) case some then {
                    lockField = true
                } case none then {}
                mkey: "\{unitName}.\{defName}.\{ftn}".string
                mref: ty.resolved.get key: mkey
                match (
                    mref
                ) case some then {
                    ty.setChild parentTypeId: cid childName: fname.stringview childTypeId: mref
                    if lockField then {
                        ty.setChildLockField parentTypeId: cid name: fname.stringview
                    } else {}
                } case none then {
                    if (isTypedefField n: fm.operation) then {
                        # No field child for the wrapper, but the inner refs
                        # (the u8 in `(List of: u8).typedef`) still stamp.
                        recordTyperef ty: ty thisName: "" node: fm.operation
                    } else {
                        if (fieldTypeNeedsCleanup ty: ty reg: reg unitName: unitName name: ftn.stringview isLock: lockField) then {
                            needsDtor = true
                        } else {}
                        cidf: resolveTyperefShell reg: reg typeExpr: fm.operation thisName: ""
                        ty.setChild parentTypeId: cid childName: fname.stringview childTypeId: cidf
                        if lockField then {
                            ty.setChildLockField parentTypeId: cid name: fname.stringview
                        } else {}
                        recordTyperef ty: ty thisName: "" node: fm.operation
                    }
                }
            }
        } else {}
    }
    hasCreate: false
    if isgen then {} else {
        hcAs: attachMethods ty: ty reg: reg unitName: unitName defName: defName parentId: cid asItems: cnode.asItems
        if hcAs then {
            hasCreate = true
        } else {}
        mNeedsDtor: attachMarkers ty: ty reg: reg unitName: unitName parentId: cid asItems: cnode.asItems
        if mNeedsDtor then {
            needsDtor = true
        } else {}
    }
    if hasCreate then {} else {
        if isgen then {} else {
            createName: "\{defName}.create".string
            createId: reg.newType name: createName.stringview typetype: ztypes.ztypetype.FUNCTION
            ty.setChild parentTypeId: cid childName: "create" childTypeId: createId
        }
    }
    if istd then {
        borrowName: "\{defName}.borrow".string
        borrowId: reg.newType name: borrowName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: cid childName: "borrow" childTypeId: borrowId
    } else {}
    if defName == "String" then {
        needsDtor = true
    } else {}
    if needsDtor then {
        dn: "\{defName}_destroy".string
        reg.setDestructorName typeId: cid name: dn.stringview
    } else {}
    ty.definedInUnit.set key: ccid value: unitName.string
}

# resolveFacet -- resolve a facet ObjectDef into a FACET valtype: a child per
# is-block spec method (the `:this` receiver dropped), then synthesized `create` +
# `borrow` FUNCTION shells (JOIN-only, no own row). Facets are value types
# (is_valtype true), no destructor, no `==`/`!=`. Generic facets arrive later.
resolveFacet: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView defName: StringView fnode: zast.ObjectDefData} is {
    fid: reg.newType name: defName typetype: ztypes.ztypetype.FACET
    ffid: fid
    rfid: fid
    reg.setValtype typeId: fid value: true
    rkey: "\{unitName}.\{defName}".string
    ty.resolved.set key: rkey value: rfid
    isgen: hasGenericParam items: fnode.isItems
    if isgen then {
        reg.setGeneric typeId: fid value: true
    } else {}
    siter: fnode.isItems.iterate
    for sm: siter loop {
        match (
            sm
        ) case namedoperation then {
            mname: unitLabel o: sm.name
            qname: "\{defName}.\{mname}".string
            sido: resolveSpecFn ty: ty reg: reg unitName: unitName qname: qname.stringview thisName: defName op: sm.operation skipThis: true
            match (
                sido
            ) case some then {
                ty.setChild parentTypeId: fid childName: mname.stringview childTypeId: sido
            } else {}
        } else {}
    }
    if isgen then {} else {
        createName: "\{defName}.create".string
        createId: reg.newType name: createName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: fid childName: "create" childTypeId: createId
        borrowName: "\{defName}.borrow".string
        borrowId: reg.newType name: borrowName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: fid childName: "borrow" childTypeId: borrowId
    }
    ty.definedInUnit.set key: ffid value: unitName.string
}

# resolveProtocol -- resolve a protocol ObjectDef into a PROTOCOL reftype: a child
# per is-block spec method (the `:this` receiver dropped), then synth `create` +
# `borrow` FUNCTION shells, then an unconditional destructor (a protocol wraps heap
# data). Reference type (is_valtype false), no `==`/`!=`. Generic protocols arrive later.
resolveProtocol: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView defName: StringView fnode: zast.ObjectDefData} is {
    pid: reg.newType name: defName typetype: ztypes.ztypetype.PROTOCOL
    ppid: pid
    rpid: pid
    reg.setValtype typeId: pid value: false
    rkey: "\{unitName}.\{defName}".string
    ty.resolved.set key: rkey value: rpid
    isgen: hasGenericParam items: fnode.isItems
    if isgen then {
        reg.setGeneric typeId: pid value: true
    } else {}
    # A protocol spec receiver is normally dropped (resolves to nothing). The reference
    # resolves Text NESTED inside String's `:Text` marker, so Text's spec `:this` binds
    # to the enclosing String -- mirror that for the system Text protocol.
    specThisName: defName
    dropThis: true
    if unitName == "system" then {
        if defName == "Text" then {
            specThisName = "String"
            dropThis = false
        } else {}
    } else {}
    siter: fnode.isItems.iterate
    for sm: siter loop {
        match (
            sm
        ) case namedoperation then {
            mname: unitLabel o: sm.name
            qname: "\{defName}.\{mname}".string
            sido: resolveSpecFn ty: ty reg: reg unitName: unitName qname: qname.stringview thisName: specThisName op: sm.operation skipThis: dropThis
            match (
                sido
            ) case some then {
                ty.setChild parentTypeId: pid childName: mname.stringview childTypeId: sido
            } else {}
        } else {}
    }
    if isgen then {} else {
        createName: "\{defName}.create".string
        createId: reg.newType name: createName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: pid childName: "create" childTypeId: createId
        borrowName: "\{defName}.borrow".string
        borrowId: reg.newType name: borrowName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: pid childName: "borrow" childTypeId: borrowId
    }
    dn: "\{defName}_destroy".string
    reg.setDestructorName typeId: pid name: dn.stringview
    ty.definedInUnit.set key: ppid value: unitName.string
}

# registerEmptyType -- register a native bottom type (null -> NULL, never -> NEVER) as a
# valtype with a single synth `create` child. The reference special-cases these: they are
# `record is native` in source but carry a distinct typetype and only a create child.
registerEmptyType: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView name: StringView tt: ztypes.ztypetype} is {
    nid: reg.newType name: name typetype: tt
    nnid: nid
    reg.setValtype typeId: nid value: true
    ccname: "\{name}.create".string
    ccid: reg.newType name: ccname.stringview typetype: ztypes.ztypetype.FUNCTION
    ty.setChild parentTypeId: nid childName: "create" childTypeId: ccid
    ty.definedInUnit.set key: nnid value: unitName.string
    rk: "\{unitName}.\{name}".string
    ty.resolved.set key: rk value: nid
}

# resolveDef -- dispatch a main-unit definition by kind. Resolves functions, data
# blocks, records, variants, unions, classes, facets and protocols; a top-level data
# block parses as an `expression` wrapping a `datablock`, so unwrap one level and
# re-dispatch. Enums and generics arrive in later slices.
resolveDef: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView defName: StringView defn: Node} is {
    match (
        defn
    ) case functiondef then {
        fid: resolveFunction ty: ty reg: reg unitName: unitName defName: defName fnode: defn thisName: "" skipThisType: false
        ty.nodeType.set key: defn.nodeid.u64 value: fid
        if (isGeneratorReturn o: defn.returntype) then {
            synthGeneratorIterClass ty: ty reg: reg unitName: unitName fnName: defName thisName: "" fnode: defn
        } else {}
    } case expression then {
        resolveDef ty: ty reg: reg unitName: unitName defName: defName defn: defn.expression
        exprKey: "\{unitName}.\{defName}".string
        exprid: ty.resolved.get key: exprKey
        match (
            exprid
        ) case some then {
            ty.nodeType.set key: defn.nodeid.u64 value: exprid
        } case none then {}
    } case datablock then {
        resolveData ty: ty reg: reg unitName: unitName defName: defName dnode: defn
        dbKey: "\{unitName}.\{defName}".string
        dbrid: ty.resolved.get key: dbKey
        match (
            dbrid
        ) case some then {
            ty.nodeType.set key: defn.nodeid.u64 value: dbrid
        } case none then {}
    } case objectdef then {
        match (
            defn.kind
        ) case RECORD then {
            if defName == "null" then {
                registerEmptyType ty: ty reg: reg unitName: unitName name: "null" tt: ztypes.ztypetype.NULL
            } else {
                if defName == "never" then {
                    registerEmptyType ty: ty reg: reg unitName: unitName name: "never" tt: ztypes.ztypetype.NEVER
                } else {
                    resolveRecord ty: ty reg: reg unitName: unitName defName: defName rnode: defn
                }
            }
        } case VARIANT then {
            resolveVariant ty: ty reg: reg unitName: unitName defName: defName vnode: defn
        } case UNION then {
            resolveUnion ty: ty reg: reg unitName: unitName defName: defName vnode: defn
        } case CLASS then {
            resolveClass ty: ty reg: reg unitName: unitName defName: defName cnode: defn
        } case FACET then {
            resolveFacet ty: ty reg: reg unitName: unitName defName: defName fnode: defn
        } case PROTOCOL then {
            resolveProtocol ty: ty reg: reg unitName: unitName defName: defName fnode: defn
        } else {}
        objKey: "\{unitName}.\{defName}".string
        objrid: ty.resolved.get key: objKey
        match (
            objrid
        ) case some then {
            ty.nodeType.set key: defn.nodeid.u64 value: objrid
        } case none then {}
    } else {}
}

# resolveUnitBody -- resolve every top-level definition signature in a unit.
# resolveUnitBody -- resolve a unit's definition signatures. Signature-only
# resolves every member; the full body-walk mode mirrors check()'s eager set
# (functions and units only -- other definitions resolve on demand, so unused
# main-unit records/classes/unions drop out of the full dump).
resolveUnitBody: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView unitdef: Node full: bool} is {
    match (
        unitdef
    ) case unitdef then {
        if (hasGenericParam items: unitdef.body) then {
            registerGenericParams reg: reg typeKey: unitName items: unitdef.body
            gpid: reg.newType name: "__generic_param" typetype: ztypes.ztypetype.GENERIC_PARAM
            gpidK: gpid
            ty.definedInUnit.set key: gpidK value: unitName.string
            uk0: unitName.string
            gpv0: gpid
            ty.unitGenericParamId.set key: uk0 value: gpv0
            # Each generic-param name resolves to the unit's generic-param
            # type, so template signatures and bodies stamp it; the param
            # definition's value node carries it too.
            with gpiter: unitdef.body.iterate do for gm: gpiter loop {
                match (
                    gm
                ) case namedoperation then {
                    if (isBareGenericParam op: gm.operation) then {
                        gpnid: nodeId n: gm.operation
                        gpv2: gpid
                        ty.nodeType.set key: gpnid.u64 value: gpv2
                    } else {}
                } else {}
            }
        } else {}
        biter: unitdef.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                defName: unitLabel o: bm.name
                eager: true
                if full then {
                    if (isFunctionDefOp op: bm.operation) then {
                    } else {
                        if (isUnitOp op: bm.operation) then {
                        } else {
                            eager = false
                        }
                    }
                } else {
                }
                if eager then {
                    if (isUnitOp op: bm.operation) then {
                        resolveInlineGenericUnit ty: ty reg: reg unitName: unitName defName: defName.stringview unitOp: bm.operation
                    } else {
                        resolveDef ty: ty reg: reg unitName: unitName defName: defName.stringview defn: bm.operation
                    }
                } else {
                }
            } else {}
        }
    } else {}
}

# typecheck -- entry point. Registers a UNIT type per unit (the `unit` table)
# and resolves the main unit's definition signatures into the registry. The
# registry is supplied by the caller and read by the SQL dumper.
# registerAndResolveMain -- register a UNIT type per unit, then resolve the main
# unit's definition signatures. Iterates program.units transiently so the demand
# pass can re-iterate it without an overlapping exclusive lock.
registerAndResolveMain: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry program: Node full: bool} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        uiter: program.units.iterate
        for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                nm: unitLabel o: u.name
                uid: reg.newType name: nm.stringview typetype: ztypes.ztypetype.UNIT
                opid: unitdefNodeId n: u.operation
                ty.unitTypesById.set key: opid.u64 value: uid
                if nm.stringview == mainName then {
                    resolveUnitBody ty: ty reg: reg unitName: nm.stringview unitdef: u.operation full: full
                } else {}
            } else {}
        }
    } else {}
}

# resolveDemandedUnitBody -- resolve the definitions of a non-main unit that a
# main-unit signature referenced (reg.isDemanded) and that aren't resolved yet,
# stamping them with that unit's name (mirrors the oracle's on-demand resolution).
resolveDemandedUnitBody: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView shadowUnit: StringView unitdef: Node} out bool is {
    anyDemanded: false
    match (
        unitdef
    ) case unitdef then {
        biter: unitdef.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                dn: unitLabel o: bm.name
                if (reg.isDemanded name: dn.stringview) then {
                    shadowed: false
                    if shadowUnit.length == 0.u64 then {} else {
                        skey: "\{shadowUnit}.\{dn}".string
                        sgot: ty.resolved.get key: skey
                        match (
                            sgot
                        ) case some then {
                            shadowed = true
                        } case none then {}
                    }
                    if shadowed then {} else {
                        anyDemanded = true
                        rkey: "\{unitName}.\{dn}".string
                        got: ty.resolved.get key: rkey
                        match (
                            got
                        ) case some then {} case none then {
                            resolveDef ty: ty reg: reg unitName: unitName defName: dn.stringview defn: bm.operation
                        }
                    }
                } else {}
            } else {}
        }
    } else {}
    return anyDemanded
}

# isConformanceMarker -- true when an as-item operation is a bare type reference
# (atomid / labelvalue), i.e. a conformance marker like `:Text` or `m: Reader`.
isConformanceMarker: function {op: Node} out bool is {
    match (
        op
    ) case atomid then {
        return true
    } case labelvalue then {
        return true
    } else {
        return false
    }
}

# declaresConformance -- true when an objectdef declares conformance via an as-item
# (the oracle eager-resolves such collections types on first touch of the unit).
declaresConformance: function {op: Node} out bool is {
    match (
        op
    ) case objectdef then {
        citer: op.asItems.iterate
        for cm: citer loop {
            match (
                cm
            ) case namedoperation then {
                if (isConformanceMarker op: cm.operation) then {
                    return true
                } else {}
            } else {}
        }
        return false
    } else {
        return false
    }
}

# resolveConformanceDefs -- resolve every not-yet-resolved unit def that declares a
# conformance marker, mirroring the oracle's eager conformance pass. Only `str`
# (`:Text`) qualifies in collections today; called when the unit was demanded at all.
resolveConformanceDefs: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView unitdef: Node} is {
    match (
        unitdef
    ) case unitdef then {
        biter: unitdef.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                if (declaresConformance op: bm.operation) then {
                    dn: unitLabel o: bm.name
                    rkey: "\{unitName}.\{dn}".string
                    got: ty.resolved.get key: rkey
                    match (
                        got
                    ) case some then {} case none then {
                        resolveDef ty: ty reg: reg unitName: unitName defName: dn.stringview defn: bm.operation
                    }
                } else {}
            } else {}
        }
    } else {}
}

# seedIteratorDemands -- a generic collection CLASS template carries no method
# children (gated in resolveClass), so its sibling iterator/view templates are not
# reached by ordinary type-ref demand. When a collection is demanded, demand its
# iterators too, so the forward demand pass resolves them as bare generic templates.
seedIteratorDemands: function {reg: ztypes.ZTypeRegistry} is {
    if (reg.isDemanded name: "Set") then {
        reg.recordDemand name: "SetIter"
    } else {}
    if (reg.isDemanded name: "List") then {
        reg.recordDemand name: "ListIter"
        reg.recordDemand name: "ListView"
    } else {}
    if (reg.isDemanded name: "Map") then {
        reg.recordDemand name: "MapKeyIter"
        reg.recordDemand name: "MapItemIter"
        reg.recordDemand name: "MapEntry"
    } else {}
}

# seedSystemDemands -- demand the system-unit types the i64/f64 pre-seed pulls into
# resolve_only_main's closure. The .z side has no monomorphizer / return-type walk, so
# it demands them by name (like seedIteratorDemands), grown by dependency layer.
seedSystemDemands: function {reg: ztypes.ZTypeRegistry} is {
    reg.recordDemand name: "i8"
    reg.recordDemand name: "i16"
    reg.recordDemand name: "i32"
    reg.recordDemand name: "i64"
    reg.recordDemand name: "i128"
    reg.recordDemand name: "u8"
    reg.recordDemand name: "u16"
    reg.recordDemand name: "u32"
    reg.recordDemand name: "u64"
    reg.recordDemand name: "u128"
    reg.recordDemand name: "f32"
    reg.recordDemand name: "f64"
    reg.recordDemand name: "tag"
    reg.recordDemand name: "bool"
    reg.recordDemand name: "optionval"
    reg.recordDemand name: "parseerror"
    reg.recordDemand name: "resultval"
    reg.recordDemand name: "String"
    reg.recordDemand name: "StringView"
    reg.recordDemand name: "CpIter"
    reg.recordDemand name: "Splitter"
    reg.recordDemand name: "LinesIter"
    reg.recordDemand name: "Text"
    reg.recordDemand name: "Iterator"
    reg.recordDemand name: "Any"
    reg.recordDemand name: "Option"
    reg.recordDemand name: "OptionView"
}

# seedIoDemands -- demand the io-unit closure the reference's full typecheck pulls
# reference-driven: the stream protocols (conformance-marker targets), IoError
# (the Result err arms), and seekorigin (Seeker.seek). The .z demand pass is
# name-driven, so the closure is seeded explicitly (like seedSystemDemands);
# IoError/seekorigin precede the protocols in io.z body order, so demands recorded
# while resolving the protocols would arrive after the pass already walked them.
seedIoDemands: function {reg: ztypes.ZTypeRegistry} is {
    reg.recordDemand name: "Reader"
    reg.recordDemand name: "Writer"
    reg.recordDemand name: "Seeker"
    reg.recordDemand name: "Closer"
    reg.recordDemand name: "IoError"
    reg.recordDemand name: "seekorigin"
}

# bodyEndsInReturn -- true when an optional body block's last statement is a
# bare `return ...` call (the syntactic divergence the clone-scope synthesis
# needs; no stamps are made).
bodyEndsInReturn: function {bodyOpt: (Option t: Node)} out bool is {
    match (
        bodyOpt
    ) case some then {
        return (blockEndsInReturn block: bodyOpt)
    } case none then {
        return false
    }
}

blockEndsInReturn: function {block: Node} out bool is {
    match (
        block
    ) case statement then {
        ne: block.statements.length
        if ne > 0.u64 then {
            last: block.statements.get i: (ne - 1.u64)
            match (
                last
            ) case statementline then {
                return (stmtExprIsReturn op: last.statementline)
            } else {
                return false
            }
        } else {
            return false
        }
    } else {
        return false
    }
}

# stmtExprIsReturn -- an expression statement whose inner call's callable is
# the `return` builtin.
stmtExprIsReturn: function {op: Node} out bool is {
    match (
        op
    ) case expression then {
        return (exprCallIsReturn op: op.expression)
    } else {
        return false
    }
}

exprCallIsReturn: function {op: Node} out bool is {
    match (
        op
    ) case call then {
        cn: atomName n: op.callable
        return cn.stringview == "return"
    } else {
        return false
    }
}

# isFunctionDefWithBody -- true when a node is a functiondef carrying a non-empty body
# (a real method, not a facet/protocol spec signature whose body is none).
isFunctionDefWithBody: function {o: Node} out bool is {
    match (
        o
    ) case functiondef then {
        match (
            o.body
        ) case some then {
            return true
        } case none then {
            return false
        }
    } else {
        return false
    }
}

# objectHasMethodBody -- true when an objectdef holds at least one is/as-item method
# with a body. Scans both blocks (transient iterators over different lists).
objectHasMethodBody: function {op: Node} out bool is {
    match (
        op
    ) case objectdef then {
        iiter: op.isItems.iterate
        for im: iiter loop {
            match (
                im
            ) case namedoperation then {
                if (isFunctionDefWithBody o: im.operation) then {
                    return true
                } else {}
            } else {}
        }
        aiter: op.asItems.iterate
        for am: aiter loop {
            match (
                am
            ) case namedoperation then {
                if (isFunctionDefWithBody o: am.operation) then {
                    return true
                } else {}
            } else {}
        }
        return false
    } else {
        return false
    }
}

# unitHasObjectMethodBody -- true when a unit body holds an objectdef with a method-body.
unitHasObjectMethodBody: function {def: Node} out bool is {
    match (
        def
    ) case unitdef then {
        biter: def.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                if (objectHasMethodBody op: bm.operation) then {
                    return true
                } else {}
            } else {}
        }
        return false
    } else {
        return false
    }
}

# seedBodyWalkDemands -- the reference WALKS objectdef method bodies during
# resolve-only-main (records/classes/facets/protocols), and those bodies use the `return`
# builtin, so the closure pulls `return` + its `out never` type. The .z resolver does
# signatures only, so when the MAIN unit has any objectdef with a method-with-body,
# demand `return` + `never` to match.
# scanCallsInNode -- recursively record demands for the call targets in an
# expression/statement subtree (full-mode body-walk pre-pass): `return` pulls
# return+never, any other bare-atom callable (e.g. `print`) is demanded by name
# so the cross-unit pass resolves it before the walk runs.
scanCallsInNode: function {reg: ztypes.ZTypeRegistry node: Node} is {
    match (
        node
    ) case statement then {
        for stm: node.statements.iterate loop {
            scanCallsInNode reg: reg node: stm
        }
    } case statementline then {
        scanCallsInNode reg: reg node: node.statementline
    } case expression then {
        scanCallsInNode reg: reg node: node.expression
    } case call then {
        cn: atomName n: node.callable
        if cn.stringview == "return" then {
            reg.recordDemand name: "return"
            reg.recordDemand name: "never"
        } else {
            if cn.length > 0.u64 then {
                reg.recordDemand name: cn.stringview
            } else {
            }
        }
        scanCallsInNode reg: reg node: node.callable
        for arg: node.arguments.iterate loop {
            match (
                arg
            ) case namedoperation then {
                scanCallsInNode reg: reg node: arg.operation
            } else {
            }
        }
    } case atomstring then {
        for sp: node.stringparts.iterate loop {
            scanCallsInNode reg: reg node: sp
        }
    } case atomid then {
        # bare body identifiers demand main-unit definitions (unit constants,
        # data blocks); non-definition names never match a demanded def.
        if (isNumericLiteralName name: node.name.stringview) then {
        } else {
            reg.recordDemand name: node.name.stringview
        }
    } case binop then {
        scanCallsInNode reg: reg node: node.lhs
        scanCallsInNode reg: reg node: node.rhs
    } case assignment then {
        scanCallsInNode reg: reg node: node.value
    } case reassignment then {
        scanCallsInNode reg: reg node: node.topath
        scanCallsInNode reg: reg node: node.value
    } case ifexpr then {
        for cl: node.clauses.iterate loop {
            scanCallsInNode reg: reg node: cl
        }
        scanBodyOpt reg: reg bodyOpt: node.elseclause
    } case forexpr then {
        reg.recordDemand name: "never"
        for fc: node.conditions.iterate loop {
            match (
                fc
            ) case namedoperation then {
                scanCallsInNode reg: reg node: fc.operation
            } else {
            }
        }
        scanBodyOpt reg: reg bodyOpt: node.body
        for fp: node.postconditions.iterate loop {
            match (
                fp
            ) case namedoperation then {
                scanCallsInNode reg: reg node: fp.operation
            } else {
            }
        }
    } case doexpr then {
        reg.recordDemand name: "never"
        scanCallsInNode reg: reg node: node.statement
    } case withexpr then {
        scanCallsInNode reg: reg node: node.value
        scanCallsInNode reg: reg node: node.body
    } case dottedpath then {
        bn: atomName n: node.parent
        if bn.length > 0.u64 then {
            reg.recordDemand name: bn.stringview
        } else {
        }
        scanCallsInNode reg: reg node: node.parent
    } case caseexpr then {
        scanCallsInNode reg: reg node: node.subject
        for cl: node.clauses.iterate loop {
            scanCallsInNode reg: reg node: cl
        }
        scanBodyOpt reg: reg bodyOpt: node.elseclause
    } case caseclause then {
        scanCallsInNode reg: reg node: node.statement
    } case ifclause then {
        for cnd: node.conditions.iterate loop {
            match (
                cnd
            ) case namedoperation then {
                scanCallsInNode reg: reg node: cnd.operation
            } else {
            }
        }
        scanCallsInNode reg: reg node: node.statement
    } else {
    }
}

# scanBodyOpt -- scan an optional function body for call demands.
scanBodyOpt: function {reg: ztypes.ZTypeRegistry bodyOpt: (Option t: Node)} is {
    match (
        bodyOpt
    ) case some then {
        scanCallsInNode reg: reg node: bodyOpt
    } case none then {
    }
}

# scanDefCalls -- scan a functiondef's body for call demands.
scanDefCalls: function {reg: ztypes.ZTypeRegistry op: Node} is {
    match (
        op
    ) case functiondef then {
        scanBodyOpt reg: reg bodyOpt: op.body
    } else {
    }
}

# scanMainBodyCalls -- record call-target demands for every function body in the
# main unit (the full-mode body walk reaches them; demand must precede the pass).
scanMainBodyCalls: function {reg: ztypes.ZTypeRegistry program: Node} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        uiter: program.units.iterate
        for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                nm: unitLabel o: u.name
                if nm.stringview == mainName then {
                    scanUnitCalls reg: reg unitdef: u.operation
                } else {
                }
            } else {
            }
        }
    } else {
    }
}

# scanUnitCalls -- scan each function definition's body in a unit for call demands.
scanUnitCalls: function {reg: ztypes.ZTypeRegistry unitdef: Node} is {
    match (
        unitdef
    ) case unitdef then {
        for bm: unitdef.body.iterate loop {
            match (
                bm
            ) case namedoperation then {
                scanDefCalls reg: reg op: bm.operation
            } else {
            }
        }
    } else {
    }
}

seedBodyWalkDemands: function {reg: ztypes.ZTypeRegistry program: Node} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        found: false
        uiter: program.units.iterate
        for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                nm: unitLabel o: u.name
                if nm.stringview == mainName then {
                    if (unitHasObjectMethodBody def: u.operation) then {
                        found = true
                    } else {}
                } else {}
            } else {}
        }
        if found then {
            reg.recordDemand name: "return"
            reg.recordDemand name: "never"
        } else {}
    } else {}
}

# resolveCrossUnitDemand -- resolve the cross-unit types main-unit signatures
# referenced (io / collections / system, each by demanded name plus its
# conformance declarers). Under full, an io demand also seeds the io-internal
# closure (stream protocols / IoError / seekorigin); the signature-only
# reference resolves no io at all, so the seed must stay sigonly-silent.
resolveCrossUnitDemand: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry program: Node full: bool} is {
    seedBodyWalkDemands reg: reg program: program
    # print is generic over StringLike; its signature closure pulls StringLike
    # (system) + str + List (collections, which seeds ListIter/ListView and the
    # str->Text conformance). Seed it like the iterator/system closures.
    if (reg.isDemanded name: "print") then {
        reg.recordDemand name: "StringLike"
        reg.recordDemand name: "str"
        reg.recordDemand name: "List"
    } else {
    }
    match (
        program
    ) case program then {
        if full then {
            with miter2: program.units.iterate do for mu: miter2 loop {
                match (
                    mu
                ) case namedoperation then {
                    mnm: unitLabel o: mu.name
                    if mnm.stringview == program.mainUnitName.stringview then {
                        # main-unit demand fixpoint: signatures and body scans
                        # demand main-unit definitions transitively (a demanded
                        # record's fields demand further records), so iterate
                        # until no new types mint.
                        again: true
                        for while again loop {
                            before: reg.nextTypeId
                            resolveDemandedUnitBody ty: ty reg: reg unitName: mnm.stringview shadowUnit: "" unitdef: mu.operation
                            if reg.nextTypeId == before then {
                                again = false
                            } else {
                            }
                        }
                        fixupDemandedParamOwnership ty: ty reg: reg unitName: mnm.stringview unitdef: mu.operation
                    } else {
                    }
                } else {
                }
            }
        } else {
        }
        uiter: program.units.iterate
        for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                nm: unitLabel o: u.name
                if nm.stringview == "io" then {
                    anyDemandedIo: resolveDemandedUnitBody ty: ty reg: reg unitName: "io" shadowUnit: program.mainUnitName.stringview unitdef: u.operation
                    if anyDemandedIo then {
                        if full then {
                            seedIoDemands reg: reg
                            resolveDemandedUnitBody ty: ty reg: reg unitName: "io" shadowUnit: program.mainUnitName.stringview unitdef: u.operation
                        } else {}
                        resolveConformanceDefs ty: ty reg: reg unitName: "io" unitdef: u.operation
                    } else {}
                } else {}
                if nm.stringview == "collections" then {
                    seedIteratorDemands reg: reg
                    anyDemanded: resolveDemandedUnitBody ty: ty reg: reg unitName: "collections" shadowUnit: program.mainUnitName.stringview unitdef: u.operation
                    if anyDemanded then {
                        resolveConformanceDefs ty: ty reg: reg unitName: "collections" unitdef: u.operation
                    } else {}
                } else {}
                if nm.stringview == "system" then {
                    seedSystemDemands reg: reg
                    anyDemandedSys: resolveDemandedUnitBody ty: ty reg: reg unitName: "system" shadowUnit: program.mainUnitName.stringview unitdef: u.operation
                    if anyDemandedSys then {
                        resolveConformanceDefs ty: ty reg: reg unitName: "system" unitdef: u.operation
                    } else {}
                } else {}
            } else {}
        }
    } else {}
}

# callableUnitName -- the callable's name when a binding value is a (possibly
# expression-wrapped) call, else "". Spots a generic-unit instantiation binding
# (intmath: (genmath t: i64)).
callableUnitName: function {op: Node} out String is {
    match (
        op
    ) case expression then {
        return (callableUnitName op: op.expression)
    } case call then {
        return (atomName n: op.callable)
    } else {
        return "".string
    }
}

# firstArgTypeName -- the type-name of a call's first argument (the instantiation type
# argument, e.g. i64 in (genmath t: i64)), else "".
firstArgTypeName: function {op: Node} out String is {
    match (
        op
    ) case expression then {
        return (firstArgTypeName op: op.expression)
    } case call then {
        aiter: op.arguments.iterate
        for arg: aiter loop {
            match (
                arg
            ) case namedoperation then {
                return (atomName n: arg.operation)
            } else {}
        }
        return "".string
    } else {
        return "".string
    }
}

# collectMainInstantiations -- scan a unit body for generic-unit instantiation bindings
# and append the mono name ({template}_{arg}) + template name to the parallel lists.
collectMainInstantiations: function {o: Node reqMono: (List of: String) reqTemplate: (List of: String)} is {
    match (
        o
    ) case unitdef then {
        biter: o.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                tn: callableUnitName op: bm.operation
                if tn.length == 0.u64 then {} else {
                    at: firstArgTypeName op: bm.operation
                    mono: "\{tn}_\{at}".string
                    reqMono.append mono
                    reqTemplate.append tn
                }
            } else {}
        }
    } else {}
}

# scanMainForInstantiations -- find the main unit and collect its instantiation requests.
# Its own function scope bounds the program.units iterator so it releases before the
# mono-creation pass (which iterates program.units again).
scanMainForInstantiations: function {program: Node reqMono: (List of: String) reqTemplate: (List of: String)} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        uiter: program.units.iterate
        for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                un: unitLabel o: u.name
                if un.stringview == mainName then {
                    collectMainInstantiations o: u.operation reqMono: reqMono reqTemplate: reqTemplate
                } else {}
            } else {}
        }
    } else {}
}

# attachMonoUnitFuncs -- add a JOIN-only `{mono}.{fn}` FUNCTION shell child per function
# in the template unit's body. The mono function rows are defined_in_unit=NULL (excluded
# from the filtered dump), so no params are resolved -- only the names matter for the JOIN.
attachMonoUnitFuncs: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry monoId: u64 monoName: StringView templateOp: Node} is {
    match (
        templateOp
    ) case unitdef then {
        fiter: templateOp.body.iterate
        for fm: fiter loop {
            match (
                fm
            ) case namedoperation then {
                if (isFunctionDefOp op: fm.operation) then {
                    fn: unitLabel o: fm.name
                    shellName: "\{monoName}.\{fn}".string
                    shellId: reg.newType name: shellName.stringview typetype: ztypes.ztypetype.FUNCTION
                    ty.setChild parentTypeId: monoId childName: fn.stringview childTypeId: shellId
                } else {}
            } else {}
        }
    } else {}
}

# resolveUnitMono -- create a mono UNIT (mangled name, defined_in_unit=the instantiating
# unit) with JOIN-only function-shell children from the template's body, then seed
# return/never demand (the template functions have bodies). Skips when already resolved
# or the template unit is not found.
# isIteratorCall -- true when a type-expr is a call to `Iterator` (a generator's
# `out (Iterator gives: T)` return), peeling an expression wrapper.
isIteratorCall: function {op: Node} out bool is {
    match (
        op
    ) case expression then {
        return (isIteratorCall op: op.expression)
    } case call then {
        cn: atomName n: op.callable
        return (cn.stringview == "Iterator")
    } else {
        return false
    }
}

# isGeneratorReturn -- true when a function's return type is the Iterator protocol
# (i.e. the function is a generator that lowers to a synth iterator class).
isGeneratorReturn: function {o: (Option t: Node)} out bool is {
    match (
        o
    ) case some then {
        return (isIteratorCall op: o)
    } case none then {
        return false
    }
}

# subtreeHasYield -- true if a node subtree contains a yield expression.
subtreeHasYield: function {node: Node} out bool is {
    match (
        node
    ) case yieldexpr then {
        return true
    } case statement then {
        siter: node.statements.iterate
        for st: siter loop {
            if (subtreeHasYield node: st) then {
                return true
            } else {}
        }
        return false
    } case statementline then {
        return (subtreeHasYield node: node.statementline)
    } case expression then {
        return (subtreeHasYield node: node.expression)
    } case forexpr then {
        return (optHasYield o: node.body)
    } case ifexpr then {
        cliter: node.clauses.iterate
        for cl: cliter loop {
            if (subtreeHasYield node: cl) then {
                return true
            } else {}
        }
        return (optHasYield o: node.elseclause)
    } case ifclause then {
        return (subtreeHasYield node: node.statement)
    } else {
        return false
    }
}

# optHasYield -- subtreeHasYield over an optional node (a for-loop body).
optHasYield: function {o: (Option t: Node)} out bool is {
    match (
        o
    ) case some then {
        return (subtreeHasYield node: o)
    } case none then {
        return false
    }
}

# nodeIsYieldingLoop -- true when a statement (peeling statementline/expression) is a
# for-loop whose body contains a yield.
nodeIsYieldingLoop: function {node: Node} out bool is {
    match (
        node
    ) case statementline then {
        return (nodeIsYieldingLoop node: node.statementline)
    } case expression then {
        return (nodeIsYieldingLoop node: node.expression)
    } case forexpr then {
        return (optHasYield o: node.body)
    } else {
        return false
    }
}

# bodyHasYieldingLoop -- true when a function body (optional statement block) contains a
# yielding loop. Generators with one promote their straight-line locals to fields.
bodyHasYieldingLoop: function {body: (Option t: Node)} out bool is {
    match (
        body
    ) case some then {
        return (blockHasYieldingLoop blk: body)
    } case none then {
        return false
    }
}
blockHasYieldingLoop: function {blk: Node} out bool is {
    match (
        blk
    ) case statement then {
        siter: blk.statements.iterate
        for st: siter loop {
            if (nodeIsYieldingLoop node: st) then {
                return true
            } else {}
        }
        return false
    } else {
        return false
    }
}

# assignmentLocalName -- the local name a statement-line binds via `name: value`, or "".
assignmentLocalName: function {line: Node} out String is {
    match (
        line
    ) case statementline then {
        return (assignmentInnerName s: line.statementline)
    } else {
        return "".string
    }
}
assignmentInnerName: function {s: Node} out String is {
    match (
        s
    ) case assignment then {
        return s.name.string
    } else {
        return "".string
    }
}

# addPromotedLocals -- add a field (i64) per top-level local binding in a generator body
# (the loop-carried counters promoted to iter-class fields).
addPromotedLocals: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry iterId: u64 body: (Option t: Node)} is {
    match (
        body
    ) case some then {
        addPromotedLocalsBlk ty: ty reg: reg iterId: iterId blk: body
    } case none then {}
}
addPromotedLocalsBlk: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry iterId: u64 blk: Node} is {
    match (
        blk
    ) case statement then {
        siter: blk.statements.iterate
        for st: siter loop {
            nm: assignmentLocalName line: st
            if nm.length == 0.u64 then {} else {
                lf: resolveAtomType reg: reg nm: "i64" thisName: ""
                ty.setChild parentTypeId: iterId childName: nm.stringview childTypeId: lf
            }
        }
    } else {}
}

# synthGeneratorIterClass -- synthesize the `<fn>_iter` CLASS the oracle lowers a
# generator to: a `state: i64` field, a `create` method (param `state: i64`), and a
# `call` method (receiver `this`, BORROW). All defined_in_unit=the example; seed
# return/never demand (the lowered methods have bodies). No-param / no-promoted-local
# generators only (counter); captured params + promoted locals arrive later.
# addResumeInput -- for a bidirectional generator (`accepts: U` in the Iterator
# return), add the `_resume_input: U` field to the iter class and a `value: U` param
# (with the annotated ownership) to its `call` method.
addResumeInput: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry iterId: u64 callId: u64 returntype: (Option t: Node)} is {
    match (
        returntype
    ) case some then {
        addResumeInputExpr ty: ty reg: reg iterId: iterId callId: callId rt: returntype
    } case none then {}
}
addResumeInputExpr: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry iterId: u64 callId: u64 rt: Node} is {
    match (
        rt
    ) case expression then {
        addResumeInputExpr ty: ty reg: reg iterId: iterId callId: callId rt: rt.expression
    } case call then {
        aiter: rt.arguments.iterate
        for arg: aiter loop {
            match (
                arg
            ) case namedoperation then {
                an: unitLabel o: arg.name
                if an.stringview == "accepts" then {
                    tn: baseTypeName n: arg.operation
                    rf: resolveAtomType reg: reg nm: tn.stringview thisName: ""
                    ty.setChild parentTypeId: iterId childName: "_resume_input" childTypeId: rf
                    vf: resolveAtomType reg: reg nm: tn.stringview thisName: ""
                    ty.setChild parentTypeId: callId childName: "value" childTypeId: vf
                    own: pathOwnership n: arg.operation
                    match (
                        own
                    ) case some then {
                        ty.setChildOwnership parentTypeId: callId name: "value" ownership: own
                    } case none then {}
                } else {}
            } else {}
        }
    } else {}
}

# condIterableCallable -- the callable name of a for-loop's inline iterable (a
# `binding: (gen ...)` condition), or "". A `while` condition (no binding) yields "".
condIterableCallable: function {conds: (List of: Node)} out String is {
    citer: conds.iterate
    for c: citer loop {
        match (
            c
        ) case namedoperation then {
            cb: callableUnitName op: c.operation
            if cb.length == 0.u64 then {} else {
                return cb
            }
        } else {}
    }
    return "".string
}

# forIterableCallable -- for a yielding for-loop whose iterable is a generator call,
# the callable name; "" otherwise (peels statementline/expression).
forIterableCallable: function {e: Node} out String is {
    match (
        e
    ) case statementline then {
        return (forIterableCallable e: e.statementline)
    } case expression then {
        return (forIterableCallable e: e.expression)
    } case forexpr then {
        if (optHasYield o: e.body) then {
            return (condIterableCallable conds: e.conditions)
        } else {
            return "".string
        }
    } else {
        return "".string
    }
}

# addInlineIterFields -- add an `_iterN: <callable>_iter` field per yielding for-loop
# whose iterable is an inline generator call (chain/map_filter's nested pipeline). The
# field is typed by the nested generator's iter class; no create param (that lives on
# the excluded NULL-unit create).
addInlineIterFields: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry iterId: u64 body: (Option t: Node)} is {
    match (
        body
    ) case some then {
        addInlineIterFieldsBlk ty: ty reg: reg iterId: iterId blk: body
    } case none then {}
}
addInlineIterFieldsBlk: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry iterId: u64 blk: Node} is {
    match (
        blk
    ) case statement then {
        n: 0.u64
        siter: blk.statements.iterate
        for st: siter loop {
            cb: forIterableCallable e: st
            if cb.length == 0.u64 then {} else {
                fieldName: "_iter\{n}".string
                fieldType: "\{cb.stringview}_iter".string
                ft: resolveAtomType reg: reg nm: fieldType.stringview thisName: ""
                ty.setChild parentTypeId: iterId childName: fieldName.stringview childTypeId: ft
                n = n + 1.u64
            }
        }
    } else {}
}

# synthGeneratorForMethod -- synthesize the iter class for a generator METHOD (an
# as-block method whose return is the Iterator protocol). thisName is the enclosing
# type, so a `this`-typed captured param (b: this.private.lock) resolves to it.
synthGeneratorForMethod: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView fnName: StringView thisName: StringView op: Node} is {
    match (
        op
    ) case functiondef then {
        if (isGeneratorReturn o: op.returntype) then {
            synthGeneratorIterClass ty: ty reg: reg unitName: unitName fnName: fnName thisName: thisName fnode: op
        } else {}
    } else {}
}

synthGeneratorIterClass: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView fnName: StringView thisName: StringView fnode: zast.FunctionData} is {
    iterName: "\{fnName}_iter".string
    iterId: reg.newType name: iterName.stringview typetype: ztypes.ztypetype.CLASS
    iid: iterId
    reg.setValtype typeId: iterId value: false
    ty.definedInUnit.set key: iid value: unitName.string
    needsDtor: false
    st1: resolveAtomType reg: reg nm: "i64" thisName: ""
    ty.setChild parentTypeId: iterId childName: "state" childTypeId: st1
    createName: "\{iterName}.create".string
    createId: reg.newType name: createName.stringview typetype: ztypes.ztypetype.FUNCTION
    cdid: createId
    ty.definedInUnit.set key: cdid value: unitName.string
    callName: "\{iterName}.call".string
    callId: reg.newType name: callName.stringview typetype: ztypes.ztypetype.FUNCTION
    clid: callId
    ty.definedInUnit.set key: clid value: unitName.string
    ty.setChild parentTypeId: callId childName: "this" childTypeId: iterId
    ty.setChildOwnership parentTypeId: callId name: "this" ownership: ztypes.zparamownership.BORROW
    piter: fnode.parameters.iterate
    for pm: piter loop {
        match (
            pm
        ) case namedoperation then {
            pn: unitLabel o: pm.name
            ptn: baseTypeName n: pm.operation
            f1: resolveAtomType reg: reg nm: ptn.stringview thisName: thisName
            ty.setChild parentTypeId: iterId childName: pn.stringview childTypeId: f1
            f2: resolveAtomType reg: reg nm: ptn.stringview thisName: thisName
            ty.setChild parentTypeId: createId childName: pn.stringview childTypeId: f2
            pown: pathOwnership n: pm.operation
            match (
                pown
            ) case some then {
                ty.setChildOwnership parentTypeId: createId name: pn.stringview ownership: pown
                needsDtor = true
            } case none then {}
        } else {}
    }
    addResumeInput ty: ty reg: reg iterId: iterId callId: callId returntype: fnode.returntype
    if (bodyHasYieldingLoop body: fnode.body) then {
        addPromotedLocals ty: ty reg: reg iterId: iterId body: fnode.body
    } else {}
    addInlineIterFields ty: ty reg: reg iterId: iterId body: fnode.body
    ty.setChild parentTypeId: iterId childName: "create" childTypeId: createId
    ty.setChild parentTypeId: iterId childName: "call" childTypeId: callId
    if needsDtor then {
        dn: "\{iterName}_destroy".string
        reg.setDestructorName typeId: iterId name: dn.stringview
    } else {}
    reg.recordDemand name: "return"
    reg.recordDemand name: "never"
}

# isUnitOp -- true when a binding's operation is an inline `unit as {...}` definition.
isUnitOp: function {op: Node} out bool is {
    match (
        op
    ) case unitdef then {
        return true
    } else {
        return false
    }
}

# resolveInlineGenericUnit -- resolve an inline generic unit (mathops: unit as { t:
# Any.generic; add; double }) into a UNIT type (is_generic) whose functions are mangled
# {unit}_{fn} FUNCTION children (with their generic-param types KEPT -- unlike a generic
# FILE unit, an inline template's params are not suppressed).
resolveInlineGenericUnit: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView defName: StringView unitOp: Node} is {
    match (
        unitOp
    ) case unitdef then {
        uid: reg.newType name: defName typetype: ztypes.ztypetype.UNIT
        did: uid
        rid: uid
        if (hasGenericParam items: unitOp.body) then {
            reg.setGeneric typeId: uid value: true
        } else {}
        ty.definedInUnit.set key: did value: unitName.string
        rk: "\{unitName}.\{defName}".string
        ty.resolved.set key: rk value: rid
        biter: unitOp.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                fn: unitLabel o: bm.name
                qn: "\{defName}_\{fn}".string
                mido: resolveMethodFn ty: ty reg: reg unitName: unitName qname: qn.stringview thisName: "" op: bm.operation
                match (
                    mido
                ) case some then {
                    ty.setChild parentTypeId: uid childName: fn.stringview childTypeId: mido
                } case none then {}
            } else {}
        }
    } else {}
}

# createUnitMono -- create a mono UNIT (defined_in_unit=the instantiating unit) with
# JOIN-only function-shell children from a template unit body, then seed return/never
# demand. Dedups on the mono's resolved key.
createUnitMono: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView monoName: StringView templateOp: Node} is {
    rkey: "\{unitName}.\{monoName}".string
    got: ty.resolved.get key: rkey
    exists: false
    match (
        got
    ) case some then {
        exists = true
    } case none then {}
    if exists then {} else {
        monoId: reg.newType name: monoName typetype: ztypes.ztypetype.UNIT
        did: monoId
        rid: monoId
        ty.definedInUnit.set key: did value: unitName.string
        rk2: "\{unitName}.\{monoName}".string
        ty.resolved.set key: rk2 value: rid
        attachMonoUnitFuncs ty: ty reg: reg monoId: monoId monoName: monoName templateOp: templateOp
        reg.recordDemand name: "return"
        reg.recordDemand name: "never"
    }
}

# resolveInlineMono -- create the mono for an INLINE template: scan the main unit body
# for the inline `unit as {...}` binding named templateName and build the mono from it.
resolveInlineMono: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitName: StringView monoName: StringView templateName: StringView mainOp: Node} is {
    match (
        mainOp
    ) case unitdef then {
        biter: mainOp.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                bn: unitLabel o: bm.name
                if bn.stringview == templateName then {
                    if (isUnitOp op: bm.operation) then {
                        createUnitMono ty: ty reg: reg unitName: unitName monoName: monoName templateOp: bm.operation
                    } else {}
                } else {}
            } else {}
        }
    } else {}
}

# resolveUnitMono -- create the mono UNIT for a generic-unit instantiation. The template
# is either a FILE unit (in program.units) or an INLINE unit in the main body
# (unitName == the main unit name for these instantiations).
resolveUnitMono: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry program: Node unitName: StringView monoName: StringView templateName: StringView} is {
    match (
        program
    ) case program then {
        uiter: program.units.iterate
        for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                un: unitLabel o: u.name
                if un.stringview == templateName then {
                    createUnitMono ty: ty reg: reg unitName: unitName monoName: monoName templateOp: u.operation
                } else {}
                if un.stringview == unitName then {
                    resolveInlineMono ty: ty reg: reg unitName: unitName monoName: monoName templateName: templateName mainOp: u.operation
                } else {}
            } else {}
        }
    } else {}
}

# resolveMainUnitInstantiations -- resolve generic-unit instantiation bindings in the main
# unit (intmath: (genmath t: i64)) into mono UNIT types. Two passes avoid nested
# program.units iteration: collect requests (separate fn), then create each mono.
# programMainName -- the main unit's name as an owned copy (no lingering lock on
# program, so program stays freely passable as a Node).
programMainName: function {program: Node} out String is {
    match (
        program
    ) case program then {
        return (program.mainUnitName.string)
    } else {
        return "".string
    }
}

resolveMainUnitInstantiations: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry program: Node} is {
    mainName: programMainName program: program
    reqMono: (List of: String)
    reqTemplate: (List of: String)
    scanMainForInstantiations program: program reqMono: reqMono reqTemplate: reqTemplate
    i: 0.u64
    for while i < reqMono.length loop {
        mono: reqMono.get i: i
        tmpl: reqTemplate.get i: i
        resolveUnitMono ty: ty reg: reg program: program unitName: mainName.stringview monoName: mono.stringview templateName: tmpl.stringview
        i = i + 1.u64
    }
}

# typecheck -- entry point. Registers a UNIT type per unit and resolves the main
# unit's definition signatures, then demand-resolves the cross-unit types those
# signatures referenced. The registry is supplied by the caller, read by the dumper.
# lookupTyperef -- resolve a recorded base name to its real type id, searching the main
# unit then the system units (first match wins, so a main-unit type shadows a same-named
# system type). none when unresolved (e.g. a numeric-literal shell name).
lookupTyperef: function {resolved: (Map key: String value: u64) mainName: StringView base: StringView} out (optionval t: u64) is {
    units: (List of: String)
    units.append mainName.string
    units.append "system".string
    units.append "collections".string
    units.append "io".string
    units.append "core".string
    units.append "os".string
    units.append "cli".string
    found: (optionval.none u64)
    done: false
    uit: units.iterate
    for u: uit loop {
        if done then {} else {
            k: "\{u}.\{base}".string
            r: resolved.get key: k
            match (
                r
            ) case some then {
                found = (optionval.some r)
                done = true
            } case none then {}
        }
    }
    return found
}

# stampTyperefs -- post-demand pass: stamp every recorded type-ref node with its real
# resolved type. Runs after resolveCrossUnitDemand, so system + forward refs are present
# in ty.resolved. pendingTyperef is a sibling field of resolved / nodeType (no lock
# conflict). The widened typed_nodes differential reads the resulting nodeType rows.
stampTyperefs: function {ty: ztyping.ZTyping program: Node} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        with it: ty.pendingTyperef.iterateItems do for e: it loop {
            r: lookupTyperef resolved: ty.resolved mainName: mainName base: e.value.stringview
            match (
                r
            ) case some then {
                nid: e.key
                ty.nodeType.set key: nid value: r
            } case none then {}
        }
    } else {}
}

# ownershipOfParam -- a parameter's binding ownership from its path annotation:
# an explicit .take binds OWNED, everything else (.borrow / .lock / default)
# binds BORROWED (mirrors _check_function_body_inner's param-ownership mapping).
ownershipOfParam: function {o: (optionval t: ztypes.zparamownership)} out ztypes.zownership is {
    match (
        o
    ) case some then {
        po: o
        match (
            po
        ) case TAKE then {
            return ztypes.zownership.OWNED
        } case BORROW then {
            return ztypes.zownership.BORROWED
        } case LOCK then {
            return ztypes.zownership.BORROWED
        }
    } case none then {
        return ztypes.zownership.BORROWED
    }
}

# paramTypeId -- the resolved type id of a parameter's type-expr. Reads the
# post-demand node stamp (stampTyperefs), falling back to a cross-unit name
# lookup for a bare-atom base.
paramTypeId: function {typing: ztyping.ZTyping unitName: StringView op: Node} out u64 is {
    onid: nodeId n: op
    r: typing.nodeType.get key: onid.u64
    match (
        r
    ) case some then {
        return r
    } case none then {
        an: atomName n: op
        return (optU64Or o: (lookupTyperef resolved: typing.resolved mainName: unitName base: an.stringview) d: 0.u64)
    }
}

# isReturnCallKind -- true iff the stamped call-kind is a diverging control
# statement (return / panic / error); the statement walk marks the scope
# unreachable after one.
isReturnCallKind: function {o: (optionval t: zast.callkind)} out bool is {
    match (
        o
    ) case some then {
        ck: o
        match (
            ck
        ) case RETURN then {
            return true
        } case PANIC then {
            return true
        } case ERROR then {
            return true
        } else {
            return false
        }
    } case none then {
        return false
    }
}

# checkString -- a non-interpolated string literal types as StringView; an
# interpolated one (any non-chunk part) types as String, since it must allocate
# to splice the values, and each interpolated sub-expression is walked + stamped.
checkString: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) node: zast.AtomStringData} out u64 is {
    result: 0.u64
    hasInterp: false
    for part: node.stringparts.iterate loop {
        match (
            part
        ) case stringchunk then {
        } else {
            hasInterp = true
            checkValue st: st unitName: unitName unitBody: unitBody node: part
        }
    }
    tyOpt: (optionval.none u64)
    if hasInterp then {
        tyOpt = lookupTyperef resolved: st.typing.resolved mainName: unitName base: "String"
    } else {
        tyOpt = lookupTyperef resolved: st.typing.resolved mainName: unitName base: "StringView"
    }
    match (
        tyOpt
    ) case some then {
        result = tyOpt
        setk: result
        st.typing.nodeType.set key: node.nodeid.u64 value: setk
    } case none then {
    }
    return result
}

# checkAtomid -- type a name-atom in value position: a local variable resolves
# via the symbol table. (Numeric literals + unit-def atoms land in later slices.)
# typeNameOf -- a registered type's name as an owned String ("" when absent).
typeNameOf: function {st: zenv.ZSymbolTable tid: u64} out String is {
    t: st.reg.typeById.get key: tid
    match (
        t
    ) case some then {
        return t.name.copy
    } case none then {
        return "".string
    }
}

# mintMono -- register one generic-instance type (deduped by mono name): the
# template's typetype and valtype flag, genericOriginId linking back, and the
# instance's children -- the template's children with generic-param targets
# substituted (matched by arg name; fallbackArg substitutes every child, the
# single-type-param call-site inference) -- plus the synthesized members: a
# per-instance tag data type (variants and unions) and the autogen ==/!=
# functions (variants). Childless templates (the collection classes) produce
# no children; their cloned method children land with the class-mono slice.
mintMono: function {st: zenv.ZSymbolTable mainName: StringView name: StringView templateId: u64 subs: (Map key: String value: u64) fallbackArg: u64} out u64 is {
    kn: name.string
    got: st.typing.monoByName.get key: kn
    match (
        got
    ) case some then {
        return got
    } case none then {
    }
    tt: ztypes.ztypetype.RECORD
    vto: (optionval.none bool)
    {
        tpl: st.reg.typeById.get key: templateId
        match (
            tpl
        ) case some then {
            tt = tpl.typetype
            vto = tpl.isValtype
        } case none then {
        }
    }
    mid: st.reg.newType name: name typetype: tt
    match (
        vto
    ) case some then {
        st.reg.setValtype typeId: mid value: vto
    } case none then {
    }
    st.reg.setGenericOrigin typeId: mid value: templateId
    setk: name.string
    setv: mid
    st.typing.monoByName.set key: setk value: setv
    cNames: (List of: String)
    cIds: (List of: u64)
    with citer: st.typing.typeChild.iterate do for tc: citer loop {
        if tc.parentTypeId == templateId then {
            cto: st.typing.childTypeById.get key: tc.childNameId
            match (
                cto
            ) case some then {
                cn: tc.childName.copy
                cNames.append cn
                cid2: cto
                cIds.append cid2
            } case none then {
            }
        } else {
        }
    }
    ci: 0.u64
    cn3: cNames.length
    for while ci < cn3 loop {
        chName: cNames.get i: ci
        chId: cIds.get i: ci
        target: chId
        ctn: typeNameOf st: st tid: chId
        target = optU64Or o: (subs.get key: ctn) d: target
        if fallbackArg > 0.u64 then {
            cko: lookupTyperef resolved: st.typing.resolved mainName: mainName base: ctn.stringview
            match (
                cko
            ) case some then {
            } case none then {
                target = fallbackArg
            }
        } else {
        }
        st.typing.setChild parentTypeId: mid childName: chName.stringview childTypeId: target
        ci = ci + 1.u64
    }
    wantTag: false
    if tt == ztypes.ztypetype.VARIANT then {
        wantTag = true
    } else {
    }
    if tt == ztypes.ztypetype.UNION then {
        wantTag = true
    } else {
    }
    if wantTag then {
        tagName: "\{name}:tag:data"
        tagId: st.reg.newType name: tagName.stringview typetype: ztypes.ztypetype.DATA
        st.typing.setChild parentTypeId: mid childName: "tag" childTypeId: tagId
    } else {
    }
    if tt == ztypes.ztypetype.VARIANT then {
        eqName: "\{name}.=="
        eqId: st.reg.newType name: eqName.stringview typetype: ztypes.ztypetype.FUNCTION
        st.typing.setChild parentTypeId: mid childName: "==" childTypeId: eqId
        neName: "\{name}.!="
        neId: st.reg.newType name: neName.stringview typetype: ztypes.ztypetype.FUNCTION
        st.typing.setChild parentTypeId: mid childName: "!=" childTypeId: neId
    } else {
    }
    return mid
}

# isContainsEligible / isSortEligible -- element types List.contains /
# List.sort support (the hardcoded equality / ordering dispatch): numerics +
# bool + the String/StringView/str family; sort excludes bool (no ordering).
isContainsEligible: function {name: StringView} out bool is {
    if name == "bool" then { return true } else {
    }
    return (isSortEligible name: name)
}

isSortEligible: function {name: StringView} out bool is {
    if name == "i8" then { return true } else {
    }
    if name == "i16" then { return true } else {
    }
    if name == "i32" then { return true } else {
    }
    if name == "i64" then { return true } else {
    }
    if name == "i128" then { return true } else {
    }
    if name == "u8" then { return true } else {
    }
    if name == "u16" then { return true } else {
    }
    if name == "u32" then { return true } else {
    }
    if name == "u64" then { return true } else {
    }
    if name == "u128" then { return true } else {
    }
    if name == "f32" then { return true } else {
    }
    if name == "f64" then { return true } else {
    }
    if name == "String" then { return true } else {
    }
    if name == "StringView" then { return true } else {
    }
    if name == "str" then { return true } else {
    }
    return false
}

# mintCollectionMethod -- one synthesized `{mono}.{m}` FUNCTION child; returns
# the method's type id so callers can link its return type.
mintCollectionMethod: function {st: zenv.ZSymbolTable monoName: StringView monoId: u64 m: StringView} out u64 is {
    fname: "\{monoName}.\{m}"
    fid: st.reg.newType name: fname.stringview typetype: ztypes.ztypetype.FUNCTION
    st.typing.setChild parentTypeId: monoId childName: m childTypeId: fid
    return fid
}

# linkMonoReturn -- point a synthesized method's return at an already-minted
# instance (by mono name); no-op when the target is absent.
linkMonoReturn: function {st: zenv.ZSymbolTable methodId: u64 targetMono: StringView} is {
    tk: targetMono.string
    got: st.typing.monoByName.get key: tk
    match (
        got
    ) case some then {
        st.reg.setReturnType typeId: methodId value: got
    } case none then {
    }
}

# mintCollectionChildren -- the collection-class instance children, mirroring
# the reference's programmatic synthesis (length/capacity as direct u64 value
# children, then the method family in synthesis order; create only where the
# template declares none; contains/sort gated on element eligibility). The
# Set/Map/array/str tables land when an example needs them. No-op for other
# templates or when the instance already has children (re-mint dedup).
mintCollectionChildren: function {st: zenv.ZSymbolTable mainName: StringView monoName: StringView monoId: u64 templateName: StringView elemArg: u64} is {
    isColl: false
    if templateName == "List" then { isColl = true } else {
    }
    if templateName == "ListIter" then { isColl = true } else {
    }
    if templateName == "ListView" then { isColl = true } else {
    }
    if isColl then {
    } else {
        return
    }
    if (st.typing.childCount parentTypeId: monoId) > 0.u64 then {
        return
    } else {
    }
    u64id: 0.u64
    uo: lookupTyperef resolved: st.typing.resolved mainName: mainName base: "u64"
    match (
        uo
    ) case some then {
        u64id = uo
    } case none then {
    }
    en: typeNameOf st: st tid: elemArg
    if templateName == "List" then {
        st.typing.setChild parentTypeId: monoId childName: "length" childTypeId: u64id
        st.typing.setChild parentTypeId: monoId childName: "capacity" childTypeId: u64id
        mintCollectionMethod st: st monoName: monoName monoId: monoId m: "append"
        mintCollectionMethod st: st monoName: monoName monoId: monoId m: "insert"
        mintCollectionMethod st: st monoName: monoName monoId: monoId m: "extend"
        mintCollectionMethod st: st monoName: monoName monoId: monoId m: "get"
        mintCollectionMethod st: st monoName: monoName monoId: monoId m: "set"
        mintCollectionMethod st: st monoName: monoName monoId: monoId m: "pop"
        if (isContainsEligible name: en.stringview) then {
            mintCollectionMethod st: st monoName: monoName monoId: monoId m: "contains"
        } else {
        }
        if (isSortEligible name: en.stringview) then {
            mintCollectionMethod st: st monoName: monoName monoId: monoId m: "sort"
        } else {
        }
        mintCollectionMethod st: st monoName: monoName monoId: monoId m: "listview"
        mintCollectionMethod st: st monoName: monoName monoId: monoId m: "extendView"
        itid: mintCollectionMethod st: st monoName: monoName monoId: monoId m: "iterate"
        itTarget: "ListIter_\{en}"
        linkMonoReturn st: st methodId: itid targetMono: itTarget.stringview
    } else {
    }
    if templateName == "ListIter" then {
        clid: mintCollectionMethod st: st monoName: monoName monoId: monoId m: "call"
        clTarget: "OptionView_\{en}"
        linkMonoReturn st: st methodId: clid targetMono: clTarget.stringview
        mintCollectionMethod st: st monoName: monoName monoId: monoId m: "create"
    } else {
    }
    if templateName == "ListView" then {
        st.typing.setChild parentTypeId: monoId childName: "length" childTypeId: u64id
        mintCollectionMethod st: st monoName: monoName monoId: monoId m: "get"
        mintCollectionMethod st: st monoName: monoName monoId: monoId m: "create"
    } else {
    }
}

# mintChain -- mint one iterator-family instance (`{tpl}{suffix}`) when the
# chain template resolves.
mintChain: function {st: zenv.ZSymbolTable mainName: StringView chainTpl: StringView suffix: StringView elemArg: u64} is {
    co: lookupTyperef resolved: st.typing.resolved mainName: mainName base: chainTpl
    match (
        co
    ) case some then {
        mname: "\{chainTpl}\{suffix}"
        eSubs: (Map key: String value: u64)
        cid: mintMono st: st mainName: mainName name: mname.stringview templateId: co subs: eSubs fallbackArg: elemArg
        mintCollectionChildren st: st mainName: mainName monoName: mname.stringview monoId: cid templateName: chainTpl elemArg: elemArg
    } case none then {
    }
}

# One resolved instantiation staged for minting: the mono name parts, the
# template id, the wrapper node to stamp, and the by-name substitution map.
ResolvedMono: class {
    template:   String
    suffix:     String
    templateId: u64
    nodeid:     u32
    firstArgId: u64
    subs:       (Map key: String value: u64)
}

# resolveMonos -- the full-mode monomorphization pass: mint an instance type
# per recorded parameterized signature ref whose template and args all resolve
# by name (an unresolved arg -- e.g. the unbound T in a template's own
# `(ListIter of: T)` -- skips the ref), build its children, and stamp the ref's
# expression wrapper with the instance. Staged through a local list so nothing
# holds the pendingMono iterator while minting mutates the registry. Minting a
# List / ListView / ListIter instance also mints its iterator-family instances,
# mirroring the reference's transitive method-signature instantiation; the
# Set/Map chains land when an example needs them.
resolveMonos: function {st: zenv.ZSymbolTable program: Node} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        staged: (List of: ResolvedMono)
        with piter: st.typing.pendingMono.iterate do for pm: piter loop {
            tplOpt: lookupTyperef resolved: st.typing.resolved mainName: mainName base: pm.template.stringview
            match (
                tplOpt
            ) case some then {
                allOk: true
                sfx: "".string
                subs: (Map key: String value: u64)
                firstA: 0.u64
                j: 0.u64
                na: pm.args.length
                for while j < na loop {
                    an: pm.args.get i: j
                    ao: lookupTyperef resolved: st.typing.resolved mainName: mainName base: an.stringview
                    match (
                        ao
                    ) case some then {
                        sfx.append s: "_"
                        sfx.append s: an.stringview
                        if j == 0.u64 then {
                            firstA = ao
                        } else {
                        }
                        if j < pm.argNames.length then {
                            pn: pm.argNames.get i: j
                            sk: pn.copy
                            sv: ao
                            subs.set key: sk value: sv
                        } else {
                        }
                    } case none then {
                        allOk = false
                    }
                    j = j + 1.u64
                }
                if allOk when sfx.length > 0.u64 then {
                    tn: pm.template.copy
                    tid: tplOpt
                    pnid: pm.nodeid
                    rm: (ResolvedMono template: tn suffix: sfx templateId: tid nodeid: pnid firstArgId: firstA subs: subs)
                    staged.append rm
                } else {
                }
            } case none then {
            }
        }
        riter: staged.iterate
        for rm2: riter loop {
            mname: "\{rm2.template}\{rm2.suffix}"
            mid: mintMono st: st mainName: mainName name: mname.stringview templateId: rm2.templateId subs: rm2.subs fallbackArg: 0.u64
            setn: mid
            st.typing.nodeType.set key: rm2.nodeid.u64 value: setn
            # iterator-family chain instances mint before the primary's children
            # so the synthesized method return links can resolve by mono name
            # (dependency order: OptionView, then the views, then the primary).
            if rm2.template.stringview == "List" then {
                mintChain st: st mainName: mainName chainTpl: "OptionView" suffix: rm2.suffix.stringview elemArg: rm2.firstArgId
                mintChain st: st mainName: mainName chainTpl: "ListView" suffix: rm2.suffix.stringview elemArg: rm2.firstArgId
                mintChain st: st mainName: mainName chainTpl: "ListIter" suffix: rm2.suffix.stringview elemArg: rm2.firstArgId
            } else {
            }
            if rm2.template.stringview == "ListView" then {
                mintChain st: st mainName: mainName chainTpl: "OptionView" suffix: rm2.suffix.stringview elemArg: rm2.firstArgId
            } else {
            }
            if rm2.template.stringview == "ListIter" then {
                mintChain st: st mainName: mainName chainTpl: "OptionView" suffix: rm2.suffix.stringview elemArg: rm2.firstArgId
            } else {
            }
            mintCollectionChildren st: st mainName: mainName monoName: mname.stringview monoId: mid templateName: rm2.template.stringview elemArg: rm2.firstArgId
        }
    } else {
    }
}

# methodReturnOf -- a method FUNCTION type's return type id: the synthesized
# returnTypeId link when set, else the AST method's recorded `out T` ref node
# (funcReturnNode) read through the post-demand stamp.
methodReturnOf: function {st: zenv.ZSymbolTable mid: u64} out (optionval t: u64) is {
    rto: (optionval.none u64)
    {
        t: st.reg.typeById.get key: mid
        match (
            t
        ) case some then {
            rto = t.returnTypeId
        } case none then {
        }
    }
    match (
        rto
    ) case some then {
        return (optionval.some rto)
    } case none then {
    }
    rn: st.typing.funcReturnNode.get key: mid
    match (
        rn
    ) case some then {
        nt: st.typing.nodeType.get key: rn
        match (
            nt
        ) case some then {
            return (optionval.some nt)
        } case none then {
        }
    } case none then {
    }
    return (optionval.none u64)
}

# iterWrapperElem -- when a type is an Option / optionval / OptionView instance,
# its element (`some` child) type id.
iterWrapperElem: function {st: zenv.ZSymbolTable unitName: StringView wid: u64} out (optionval t: u64) is {
    origin: 0.u64
    goo: (optionval.none u64)
    {
        t: st.reg.typeById.get key: wid
        match (
            t
        ) case some then {
            goo = t.genericOriginId
        } case none then {
        }
    }
    match (
        goo
    ) case some then {
        origin = goo
    } case none then {
    }
    if origin == 0.u64 then {
        return (optionval.none u64)
    } else {
    }
    isWrapper: false
    oo: lookupTyperef resolved: st.typing.resolved mainName: unitName base: "Option"
    match (
        oo
    ) case some then {
        if origin == oo then { isWrapper = true } else {
        }
    } case none then {
    }
    vo: lookupTyperef resolved: st.typing.resolved mainName: unitName base: "optionval"
    match (
        vo
    ) case some then {
        if origin == vo then { isWrapper = true } else {
        }
    } case none then {
    }
    wo: lookupTyperef resolved: st.typing.resolved mainName: unitName base: "OptionView"
    match (
        wo
    ) case some then {
        if origin == wo then { isWrapper = true } else {
        }
    } case none then {
    }
    if isWrapper then {
        return (st.typing.childOf parentTypeId: wid name: "some")
    } else {
    }
    return (optionval.none u64)
}

# isOptionViewMono -- true when a type is an OptionView instance (its per-
# iteration values are borrowed views, so the loop var binds BORROWED).
isOptionViewMono: function {st: zenv.ZSymbolTable unitName: StringView wid: u64} out bool is {
    origin: 0.u64
    goo: (optionval.none u64)
    {
        t: st.reg.typeById.get key: wid
        match (
            t
        ) case some then {
            goo = t.genericOriginId
        } case none then {
        }
    }
    match (
        goo
    ) case some then {
        origin = goo
    } case none then {
    }
    if origin == 0.u64 then {
        return false
    } else {
    }
    wo: lookupTyperef resolved: st.typing.resolved mainName: unitName base: "OptionView"
    match (
        wo
    ) case some then {
        return origin == wo
    } case none then {
        return false
    }
}

# methodHasNoUserArgs -- true when a method type has no user-visible parameters
# beyond the implicit receiver: no children at all (synthesized collection
# methods), or a single child that IS the receiver -- `this`, or the long-form
# receiver recorded in thisParamName (`stringview: function {t: this.lock}`).
# optStrIsSome -- whether an optional string is present.
optStrIsSome: function {o: (Option t: String)} out bool is {
    match (
        o
    ) case some then {
        return true
    } case none then {
        return false
    }
}

optStrEquals: function {o: (Option t: String) s: StringView} out bool is {
    match (
        o
    ) case some then {
        return o.stringview == s
    } case none then {
        return false
    }
}

# optU64Or / optBoolOr -- the option's payload, or the given default. Collapse
# the some/none match at get-or-default sites (match narrowing needs a
# bare-name subject, so inline gets can't match directly).
optU64Or: function {o: (optionval t: u64) d: u64} out u64 is {
    match (
        o
    ) case some then {
        return o
    } case none then {
        return d
    }
}

optBoolOr: function {o: (optionval t: bool) d: bool} out bool is {
    match (
        o
    ) case some then {
        return o
    } case none then {
        return d
    }
}

# createDottedBaseId -- the base atom's node id when a dotted path's child is
# `create` (explicit construction: `T.create` is bare-name construction).
createDottedBaseId: function {n: Node} out (optionval t: u32) is {
    match (
        n
    ) case dottedpath then {
        ccn: atomName n: n.child
        if ccn.stringview == "create" then {
            return (optionval.some (nodeId n: n.parent))
        } else {
        }
    } else {
    }
    return (optionval.none u32)
}

# metaCreateBaseId -- the base atom's node id when a callable is the dotted
# `meta.create` (the enclosing type's raw allocator), or none.
metaCreateBaseId: function {n: Node} out (optionval t: u32) is {
    match (
        n
    ) case dottedpath then {
        pn: atomName n: n.parent
        cn2: atomName n: n.child
        if pn.stringview == "meta" when cn2.stringview == "create" then {
            return (optionval.some (nodeId n: n.parent))
        } else {
        }
    } else {
    }
    return (optionval.none u32)
}

# typedefBaseOf -- a typedef type's base type id (the recorded base name,
# resolved at read time -- the resolver runs before the base's unit), or 0.
typedefBaseOf: function {st: zenv.ZSymbolTable unitName: StringView tid: u64} out u64 is {
    bo: st.typing.typedefBaseName.get key: tid
    match (
        bo
    ) case some then {
        return (optU64Or o: (lookupTyperef resolved: st.typing.resolved mainName: unitName base: bo.stringview) d: 0.u64)
    } case none then {
        return 0.u64
    }
}

# checkTypedefCreate -- `T.create from: expr` / bare `T expr` on a typedef:
# an owned cast, not a call. No CALL scope; the from-argument walks in the
# current scope (a non-trivial one hoists there) and is consumed; the value
# is the typedef type.
checkTypedefCreate: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) call: zast.CallData tdId: u64} out u64 is {
    found: false
    aiter: call.arguments.iterate
    for arg: aiter loop {
        match (
            arg
        ) case namedoperation then {
            if found then {} else {
                an: unitLabel o: arg.name
                isFrom: false
                if an.length == 0.u64 then {
                    isFrom = true
                } else {
                    if an.stringview == "from" then {
                        isFrom = true
                    } else {}
                }
                if isFrom then {
                    found = true
                    vt: checkValue st: st unitName: unitName unitBody: unitBody node: arg.operation
                    if vt > 0.u64 then {
                        if (argIsTrivial op: arg.operation) then {
                            bn: bareAtomName n: arg.operation
                            if bn.length > 0.u64 then {
                                bvo: st.lookupVarId name: bn.stringview
                                match (
                                    bvo
                                ) case some then {
                                    st.invalidate name: bn.stringview loc: (optionval.none ztypes.zsrcpos)
                                } case none then {}
                            } else {}
                        } else {
                            tnm: hoistArg st: st argNode: arg.operation argType: vt paramType: 0.u64 consumes: true
                        }
                    } else {}
                } else {}
            }
        } else {}
    }
    settd: tdId
    st.typing.nodeType.set key: call.nodeid.u64 value: settd
    return tdId
}

# methodHasThisReceiver -- a FUNCTION child bound to a receiver: a declared
# `this` param (shorthand) or a recorded long-form receiver name. A this-less
# function member is a callable field, not a method.
methodHasThisReceiver: function {st: zenv.ZSymbolTable mid: u64} out bool is {
    if (st.typing.hasChild parentTypeId: mid name: "this") then {
        return true
    } else {
    }
    zo: st.reg.typeById.get key: mid
    match (
        zo
    ) case some then {
        return (optStrIsSome o: zo.thisParamName)
    } case none then {
        return false
    }
}

methodHasNoUserArgs: function {st: zenv.ZSymbolTable mid: u64} out bool is {
    cnt: st.typing.childCount parentTypeId: mid
    if cnt == 0.u64 then {
        return true
    } else {
    }
    if cnt != 1.u64 then {
        return false
    } else {
    }
    soleName: "".string
    with citer: st.typing.typeChild.iterate do for tc: citer loop {
        if tc.parentTypeId == mid then {
            soleName = tc.childName.copy
        } else {
        }
    }
    if soleName.stringview == "this" then {
        return true
    } else {
    }
    zo: st.reg.typeById.get key: mid
    match (
        zo
    ) case some then {
        return (optStrEquals o: zo.thisParamName s: soleName.stringview)
    } case none then {
        return false
    }
}

# checkDotted -- a dotted method reference in a body: type the base, look the
# member up on the base's type, and stamp the dotted node -- with the method's
# return when the method takes no user parameters beyond the receiver (the
# auto-call coercion), else with the method FUNCTION type itself.
checkDotted: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) dp: zast.DottedPathData coerce: bool} out u64 is {
    # Numeric dotted suffix (`1.u8`): when the child names a non-function
    # type, the path is a typed-literal cast -- the parent atom coerces to
    # the suffix type and the path carries it.
    castBase: atomName n: dp.parent
    if (isNumericLiteralName name: castBase.stringview) then {
        castChild: atomName n: dp.child
        castOpt: lookupTyperef resolved: st.typing.resolved mainName: unitName base: castChild.stringview
        match (
            castOpt
        ) case some then {
            if (st.reg.typetypeOf typeId: castOpt) == ztypes.ztypetype.FUNCTION then {
            } else {
                castPid: nodeId n: dp.parent
                setcp: castOpt
                st.typing.nodeType.set key: castPid.u64 value: setcp
                setcd: castOpt
                st.typing.nodeType.set key: dp.nodeid.u64 value: setcd
                return castOpt
            }
        } case none then {
        }
    } else {
    }
    bt: checkValue st: st unitName: unitName unitBody: unitBody node: dp.parent
    if bt == 0.u64 then {
        return 0.u64
    } else {
    }
    cn: atomName n: dp.child
    if cn.length == 0.u64 then {
        return 0.u64
    } else {
    }
    # `.private` / `.public` access markers: the path carries the base's
    # type (the access view is a dump-filtered shell, not a member).
    if cn.stringview == "private" then {
        setpv: bt
        st.typing.nodeType.set key: dp.nodeid.u64 value: setpv
        return bt
    } else {
    }
    if cn.stringview == "public" then {
        setpb: bt
        st.typing.nodeType.set key: dp.nodeid.u64 value: setpb
        return bt
    } else {
    }
    # `.take` / `.release`: ownership transfer markers, not members. The path
    # carries the base's type; a bare-name source releases its held locks and
    # invalidates (the taken overlay propagates out of popped scopes).
    isXferMarker: false
    if cn.stringview == "take" then {
        isXferMarker = true
    } else {
    }
    if cn.stringview == "release" then {
        isXferMarker = true
    } else {
    }
    if isXferMarker then {
        mkRoot: bareAtomName n: dp.parent
        if mkRoot.length > 0.u64 then {
            mvo: st.lookupVarId name: mkRoot.stringview
            match (
                mvo
            ) case some then {
                mh: (ztypes.zlockholder kind: ztypes.zlockholderkind.VAR id: mvo)
                st.releaseHeldLocks holder: mh
                st.invalidate name: mkRoot.stringview loc: takenHere
            } case none then {
            }
        } else {
        }
        setmk: bt
        st.typing.nodeType.set key: dp.nodeid.u64 value: setmk
        return bt
    } else {
    }
    mo: st.typing.childOf parentTypeId: bt name: cn.stringview
    match (
        mo
    ) case some then {
        if (st.typing.isAsConstClone typeId: mo) then {
            setcc: mo
            st.typing.nodeType.set key: dp.nodeid.u64 value: setcc
            return mo
        } else {
        }
        rm: resolveChildPayload st: st unitName: unitName cid: mo
        result: 0.u64
        result = rm
        if coerce when (methodHasNoUserArgs st: st mid: mo) then {
            ro: methodReturnOf st: st mid: mo
            match (
                ro
            ) case some then {
                result = ro
                fb: st.typing.funcReturnsBorrow.get key: mo
                match (
                    fb
                ) case some then {
                    if fb then {
                        # Build locally, then append through the full field
                        # path (a field list passed as an argument is a
                        # non-owning shallow copy -- appends would be lost).
                        tup: (List of: String)
                        appendValueTuple n: dp.parent dst: tup
                        drainPendingBorrow st: st
                        ti: 0.u64
                        tn: tup.length
                        for while ti < tn loop {
                            te: tup.get i: ti
                            tec: te.copy
                            st.typing.pendingBorrowPath.append tec
                            ti = ti + 1.u64
                        }
                    } else {
                    }
                } case none then {
                }
            } case none then {
            }
        } else {
        }
        setd: result
        st.typing.nodeType.set key: dp.nodeid.u64 value: setd
        return result
    } case none then {
        return 0.u64
    }
}

checkAtomid: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) node: zast.AtomIdData} out u64 is {
    result: 0.u64
    vtOpt: st.lookup name: node.name.stringview
    match (
        vtOpt
    ) case some then {
        result = vtOpt
        setk: result
        st.typing.nodeType.set key: node.nodeid.u64 value: setk
    } case none then {
        if (isNumericLiteralName name: node.name.stringview) then {
            if (isFloatLiteralName name: node.name.stringview) then {
                result = literalFloatId
            } else {
                result = literalIntId
            }
            setl: result
            st.typing.nodeType.set key: node.nodeid.u64 value: setl
        } else {
            fo: lookupTyperef resolved: st.typing.resolved mainName: unitName base: node.name.stringview
            match (
                fo
            ) case some then {
                result = fo
                setu: result
                st.typing.nodeType.set key: node.nodeid.u64 value: setu
                maybeWalkMethods st: st unitName: unitName unitBody: unitBody name: node.name.stringview
            } case none then {
            }
        }
    }
    return result
}

# isFloatLiteralName -- a numeric-literal atom carrying a decimal point (the
# float default; hex/binary stay integer literals).
isFloatLiteralName: function {name: StringView} out bool is {
    i: 0.u64
    n: name.length
    for while i < n loop {
        b: name.byteAt i
        match (
            b
        ) case some then {
            if b == 46.u8 then {
                return true
            } else {
            }
        } case none then {
        }
        i = i + 1.u64
    }
    return false
}

# isComparisonOp -- a binop operator whose result is bool (not the operand type).
isComparisonOp: function {name: StringView} out bool is {
    if name == "<" then { return true } else {
    }
    if name == ">" then { return true } else {
    }
    if name == "<=" then { return true } else {
    }
    if name == ">=" then { return true } else {
    }
    if name == "==" then { return true } else {
    }
    if name == "!=" then { return true } else {
    }
    return false
}

# checkClause -- walk one if-clause: its condition(s) (namedoperation-wrapped)
# then its then-statement block.
checkClause: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) clause: Node} is {
    match (
        clause
    ) case ifclause then {
        coiter: clause.conditions.iterate
        for cond: coiter loop {
            match (
                cond
            ) case namedoperation then {
                checkValue st: st unitName: unitName unitBody: unitBody node: cond.operation
            } else {
            }
        }
        checkStatement st: st unitName: unitName unitBody: unitBody block: clause.statement
    } else {
    }
}

# lastStmtType -- the resolved type id of a statement block's last statement
# (the value of a do-block), or 0 when empty/untyped.
lastStmtType: function {st: zenv.ZSymbolTable block: Node} out u64 is {
    result: 0.u64
    match (
        block
    ) case statement then {
        ne: block.statements.length
        if ne > 0.u64 then {
            last: block.statements.get i: (ne - 1.u64)
            match (
                last
            ) case statementline then {
                result = optU64Or o: (st.typing.nodeType.get key: last.nodeid.u64) d: result
            } else {
            }
        } else {
        }
    } else {
    }
    return result
}

# materialiseLiteral -- fold a literal pseudo-type id to its concrete default
# (i64 / f64); concrete ids pass through.
materialiseLiteral: function {st: zenv.ZSymbolTable unitName: StringView t: u64} out u64 is {
    base: ""
    if t == literalIntId then {
        base = "i64"
    } else {
    }
    if t == literalFloatId then {
        base = "f64"
    } else {
    }
    if base.length == 0.u64 then {
        return t
    } else {
    }
    return (optU64Or o: (lookupTyperef resolved: st.typing.resolved mainName: unitName base: base) d: t)
}

# checkAssignment -- a local binding `name: value`: walk the value, materialise a
# literal-typed value to its concrete default (the binding takes i64, unlike a
# for-loop binding which keeps the pseudo id), define the local (owned for a plain
# value), and stamp the assignment node + def-variable.
checkAssignment: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) asgn: zast.AssignmentData} is {
    vt: checkValue st: st unitName: unitName unitBody: unitBody node: asgn.value
    mvt: materialiseLiteral st: st unitName: unitName t: vt
    vt = mvt
    if vt > 0.u64 then {
        bsrc: (List of: String)
        takePendingBorrow st: st dst: bsrc
        own: ztypes.zownership.OWNED
        if bsrc.length > 0.u64 when (typeIsReftype st: st tid: vt) then {
            own = ztypes.zownership.BORROWED
        } else {
        }
        v: st.reg.newVariable ztypeId: vt ownership: own
        vid: v.variableId
        if own == ztypes.zownership.BORROWED then {
            r0: bsrc.get i: 0.u64
            bo: r0.copy
            v.borrowOrigin = (Option.some bo)
        } else {
        }
        st.defineVar name: asgn.name.stringview var: v
        vid2: vid
        st.typing.defVariableId.set key: asgn.nodeid.u64 value: vid2
        setk: vt
        st.typing.nodeType.set key: asgn.nodeid.u64 value: setk
        if own == ztypes.zownership.BORROWED then {
            installBorrowLocks st: st src: bsrc vid: vid
        } else {
        }
    } else {
    }
}

# checkReassignment -- `lhs = value`: resolve the target path and the value, then
# reset any narrowing on a bare-name target (appends a non-definition overlay
# entry, mirroring _check_reassignment_inner's reset_narrowing).
checkReassignment: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) rasgn: zast.ReassignmentData} is {
    lvt: checkValue st: st unitName: unitName unitBody: unitBody node: rasgn.topath
    rvt: checkValue st: st unitName: unitName unitBody: unitBody node: rasgn.value
    # A literal RHS at a concretely-typed target coerces: restamp the RHS's
    # innermost node (wrappers derive through the dump's descent). A
    # literal-typed target (a literal-init loop binding) keeps the pseudo.
    if lvt > 0.u64 when rvt > 0.u64 when (isLiteralTypeId st: st tid: rvt) then {
        if (isLiteralTypeId st: st tid: lvt) then {
        } else {
            iid: innermostNodeId n: rasgn.value
            if iid > 0.u32 then {
                setc: lvt
                st.typing.nodeType.set key: iid.u64 value: setc
            } else {
            }
        }
    } else {
    }
    nm: atomName n: rasgn.topath
    if nm.length > 0.u64 then {
        st.resetNarrowing name: nm.stringview
    } else {
    }
    # A bare-name reftype RHS is a move: the source invalidates (the symtab
    # appends its taken overlay entry).
    rn: bareAtomName n: rasgn.value
    if rn.length > 0.u64 when rvt > 0.u64 when (typeIsReftype st: st tid: rvt) then {
        vo: st.lookupVarId name: rn.stringview
        match (
            vo
        ) case some then {
            st.invalidate name: rn.stringview loc: (optionval.none ztypes.zsrcpos)
        } case none then {
        }
    } else {
    }
}

# checkSwap -- `lhs swap rhs`: resolve both operand paths (stamping them). The swap
# carries no type (the expression wrapper is null, like reassignment) and does no
# narrowing. Operand ownership/lock/type-match validation produces no dump rows -- deferred.
checkSwap: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) swapnode: zast.SwapStmtData} is {
    checkValue st: st unitName: unitName unitBody: unitBody node: swapnode.lhs
    checkValue st: st unitName: unitName unitBody: unitBody node: swapnode.rhs
}

# withValueOwnership -- the with-binding's ownership from the bound value's
# syntactic shape, mirroring the reference's function-argument rules: a bare
# name bound to a runtime variable or a plain dotted path borrows; `.take`
# transfers; calls, literals and constructions are fresh owned values.
withValueOwnership: function {st: zenv.ZSymbolTable v: Node} out ztypes.zownership is {
    match (
        v
    ) case expression then {
        return (withValueOwnership st: st v: v.expression)
    } case atomid then {
        vo: st.lookupVarId name: v.name.stringview
        match (
            vo
        ) case some then {
            return ztypes.zownership.BORROWED
        } case none then {
            return ztypes.zownership.OWNED
        }
    } case dottedpath then {
        cn: atomName n: v.child
        if cn.stringview == "take" then {
            return ztypes.zownership.OWNED
        } else {
            return ztypes.zownership.BORROWED
        }
    } else {
        return ztypes.zownership.OWNED
    }
}

# checkWith -- walk `with name: value do body`: push the `with` scope, bind the
# alias variable (BORROWED for a plain-path value), walk the body, then pop. The
# with node carries the bound value's type; the with-expression's value is the
# body's value.
checkWith: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) withnode: zast.WithData} out u64 is {
    withMarker: st.pushBlock name: "with"
    vt: checkValue st: st unitName: unitName unitBody: unitBody node: withnode.value
    if vt > 0.u64 then {
        own: withValueOwnership st: st v: withnode.value
        # The borrow target: a BORROW-returning auto-call reported the receiver
        # source; a plain-path value locks its full dotted tuple. Valtype
        # borrows are copies -- no lock.
        btgt: (List of: String)
        takePendingBorrow st: st dst: btgt
        if btgt.length == 0.u64 then {
            if own == ztypes.zownership.BORROWED then {
                appendValueTuple n: withnode.value dst: btgt
            } else {
            }
        } else {
        }
        v: st.reg.newVariable ztypeId: vt ownership: own
        vid: v.variableId
        st.defineVar name: withnode.name.stringview var: v
        vid2: vid
        st.typing.defVariableId.set key: withnode.nodeid.u64 value: vid2
        if (typeIsReftype st: st tid: vt) then {
            installBorrowLocks st: st src: btgt vid: vid
        } else {
        }
        setk: vt
        st.typing.nodeType.set key: withnode.nodeid.u64 value: setk
    } else {
    }
    dt: checkValue st: st unitName: unitName unitBody: unitBody node: withnode.body
    st.popTo marker: withMarker
    return dt
}

# checkDo -- walk a do-block: push the `block` scope, define break (an entry
# position placeholder with an unregistered type id, so it never joins the dump),
# walk the statements, then pop. The do resolves to its last statement's value type.
checkDo: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) donode: zast.DoData} out u64 is {
    doMarker: st.pushBlock name: "block"
    dbk: st.reg.allocType
    st.define name: "break" ztypeId: dbk
    checkStatement st: st unitName: unitName unitBody: unitBody block: donode.statement
    result: lastStmtType st: st block: donode.statement
    st.popTo marker: doMarker
    if result > 0.u64 then {
        setk: result
        st.typing.nodeType.set key: donode.nodeid.u64 value: setk
    } else {
    }
    return result
}

# checkFor -- walk a for-loop: push the `for` scope, define break/continue (entry
# position placeholders with unregistered type ids, so they never join the dump),
# then walk the conditions, postconditions, and body, and pop. A named condition
# is a binding: define the loop var with the condition value's type (the value of
# a bare literal init stays the literal pseudo-type, keeping the entry out of the
# dump joins). Iterator-wrapper element extraction needs monomorphization and is
# not implemented. The for itself resolves to null (filtered) in statement position.
checkFor: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) fornode: zast.ForData} is {
    forMarker: st.pushBlock name: "for"
    bk: st.reg.allocType
    st.define name: "break" ztypeId: bk
    ct: st.reg.allocType
    st.define name: "continue" ztypeId: ct
    citer: fornode.conditions.iterate
    for cond: citer loop {
        match (
            cond
        ) case namedoperation then {
            vt: checkValue st: st unitName: unitName unitBody: unitBody node: cond.operation
            nm: unitLabel o: cond.name
            if nm.length > 0.u64 when vt > 0.u64 then {
                elem: 0.u64
                isView: false
                w1: iterWrapperElem st: st unitName: unitName wid: vt
                match (
                    w1
                ) case some then {
                    elem = w1
                    isView = isOptionViewMono st: st unitName: unitName wid: vt
                } case none then {
                }
                if elem == 0.u64 then {
                    if (st.reg.typetypeOf typeId: vt) == ztypes.ztypetype.FUNCTION then {
                        r1: methodReturnOf st: st mid: vt
                        match (
                            r1
                        ) case some then {
                            w2: iterWrapperElem st: st unitName: unitName wid: r1
                            match (
                                w2
                            ) case some then {
                                elem = w2
                                isView = isOptionViewMono st: st unitName: unitName wid: r1
                            } case none then {
                            }
                        } case none then {
                        }
                    } else {
                        c1: st.typing.childOf parentTypeId: vt name: "call"
                        match (
                            c1
                        ) case some then {
                            r2: methodReturnOf st: st mid: c1
                            match (
                                r2
                            ) case some then {
                                w3: iterWrapperElem st: st unitName: unitName wid: r2
                                match (
                                    w3
                                ) case some then {
                                    elem = w3
                                    isView = isOptionViewMono st: st unitName: unitName wid: r2
                                } case none then {
                                }
                            } case none then {
                            }
                        } case none then {
                        }
                    }
                } else {
                }
                if elem > 0.u64 then {
                    if isView then {
                        srcName: atomName n: cond.operation
                        bo: "<iterator>".string
                        if srcName.length > 0.u64 then {
                            bo = srcName.copy
                        } else {
                        }
                        v: st.reg.newVariable ztypeId: elem ownership: ztypes.zownership.BORROWED
                        v.borrowOrigin = (Option.some bo)
                        vid: v.variableId
                        st.defineVar name: nm.stringview var: v
                        condNid: nodeId n: cond.operation
                        st.typing.defVariableId.set key: condNid.u64 value: vid
                    } else {
                        st.define name: nm.stringview ztypeId: elem
                    }
                } else {
                    st.define name: nm.stringview ztypeId: vt
                }
            } else {
            }
        } else {
        }
    }
    piter: fornode.postconditions.iterate
    for pc: piter loop {
        match (
            pc
        ) case namedoperation then {
            checkValue st: st unitName: unitName unitBody: unitBody node: pc.operation
        } else {
        }
    }
    walkBody st: st unitName: unitName unitBody: unitBody bodyOpt: fornode.body
    st.popTo marker: forMarker
}

# checkIf -- walk an if: push the `if` scope, then a `if_branch` scope per clause
# and an `if_else` scope for the else; when every branch diverges (returns) the
# if resolves to never and marks the enclosing scope unreachable.
checkIf: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) ifnode: zast.IfData} out u64 is {
    ifMarker: st.pushBlock name: "if"
    allDiverge: true
    cliter: ifnode.clauses.iterate
    for clause: cliter loop {
        bm: st.pushBlock name: "if_branch"
        checkClause st: st unitName: unitName unitBody: unitBody clause: clause
        if (st.isUnreachable) then {
        } else {
            allDiverge = false
        }
        st.popTo marker: bm
    }
    match (
        ifnode.elseclause
    ) case some then {
        ebm: st.pushBlock name: "if_else"
        walkBody st: st unitName: unitName unitBody: unitBody bodyOpt: ifnode.elseclause
        if (st.isUnreachable) then {
        } else {
            allDiverge = false
        }
        st.popTo marker: ebm
    } case none then {
        allDiverge = false
    }
    result: 0.u64
    if allDiverge then {
        nvOpt: lookupTyperef resolved: st.typing.resolved mainName: unitName base: "never"
        match (
            nvOpt
        ) case some then {
            result = nvOpt
            setk: result
            st.typing.nodeType.set key: ifnode.nodeid.u64 value: setk
        } case none then {
        }
    } else {
    }
    st.popTo marker: ifMarker
    if allDiverge then {
        st.markUnreachable
    } else {
    }
    return result
}

# checkBinop -- type an arithmetic binop. Both operands are walked (so their
# nodes are stamped); the result is the lhs operand type (correct for same-type
# arithmetic -- full operator-method dispatch lands with a comparison example).
checkBinop: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) binop: zast.BinOpData} out u64 is {
    result: 0.u64
    lt: checkValue st: st unitName: unitName unitBody: unitBody node: binop.lhs
    checkValue st: st unitName: unitName unitBody: unitBody node: binop.rhs
    opn: atomName n: binop.operator
    if (isComparisonOp name: opn.stringview) then {
        boOpt: lookupTyperef resolved: st.typing.resolved mainName: unitName base: "bool"
        match (
            boOpt
        ) case some then {
            result = boOpt
        } case none then {
            result = lt
        }
    } else {
        result = lt
    }
    tdb2: typedefBaseOf st: st unitName: unitName tid: result
    if tdb2 > 0.u64 then {
        result = tdb2
    } else {
    }
    if result > 0.u64 when (st.reg.typetypeOf typeId: result) == ztypes.ztypetype.GENERIC_PARAM then {
        return 0.u64
    } else {
    }
    if result > 0.u64 then {
        setk: result
        st.typing.nodeType.set key: binop.nodeid.u64 value: setk
    } else {
    }
    return result
}

# argIsTrivial -- true when a call argument's operation is a hoisting no-op: a
# bare atom, a labelvalue, a string literal without interpolation, or an
# expression wrapping a bare atom / labelvalue. Anything else (binop, call,
# dotted path, interpolated string) hoists into a synth temp.
argIsTrivial: function {op: Node} out bool is {
    match (
        op
    ) case atomid then {
        return true
    } case labelvalue then {
        return true
    } case atomstring then {
        spiter: op.stringparts.iterate
        for sp: spiter loop {
            match (
                sp
            ) case stringchunk then {
            } else {
                return false
            }
        }
        return true
    } case expression then {
        match (
            op.expression
        ) case atomid then {
            return true
        } case labelvalue then {
            return true
        } else {
            return false
        }
    } else {
        return false
    }
}

# hoistArg -- hoist a non-trivial call argument into a fresh `_tN` synth temp:
# define the temp (OWNED, synth origin anf) in the open CALL scope and record
# the synth Assignment / value-Expression / AtomId rows + their type stamps so
# the dump matches the reference's hoisted tree. The parsed argument keeps its
# own stamps; only the dump rows are synthesised (no AST mutation).
# typeIsReftype -- a registered type whose isValtype flag is explicitly false
# (classes, unions, protocols, heap natives like String). Unset or unregistered
# ids are not reftypes.
typeIsReftype: function {st: zenv.ZSymbolTable tid: u64} out bool is {
    zo: st.reg.typeById.get key: tid
    match (
        zo
    ) case some then {
        vt: zo.isValtype
        match (
            vt
        ) case some then {
            return vt == false
        } case none then {
            return false
        }
    } case none then {
        return false
    }
}

# innermostNodeId -- the node id of a value with its expression wrappers
# stripped (the node the dump's descent reads first); 0 for uncovered kinds.
innermostNodeId: function {n: Node} out u32 is {
    match (
        n
    ) case expression then {
        return (innermostNodeId n: n.expression)
    } else {
        return (nodeId n: n)
    }
}

# bareAtomName -- the (expression-unwrapped) bare atom name of a value node,
# or "" when the value is any other shape.
bareAtomName: function {n: Node} out String is {
    match (
        n
    ) case expression then {
        return (bareAtomName n: n.expression)
    } case atomid then {
        return n.name.copy
    } else {
        return "".string
    }
}

# methodReceiverRoot -- the bare root name of a dotted callable's receiver
# (`a.compare` -> a), "" for non-dotted or non-bare receivers.
methodReceiverRoot: function {n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        return (bareAtomName n: n.parent)
    } else {
        return "".string
    }
}

# positionalParamName -- the funcId's parameter name at `idx` (typeChild
# position order), "" when absent. Positional call args map to it.
positionalParamName: function {st: zenv.ZSymbolTable funcId: u64 idx: u64} out String is {
    result: "".string
    found: false
    with citer: st.typing.typeChild.iterate do for tc: citer loop {
        if found then {} else {
            if tc.parentTypeId == funcId when tc.position == idx then {
                result = tc.childName.copy
                found = true
            } else {
            }
        }
    }
    return result
}

# lockCallArg -- the call-scoped EXCLUSIVE lock a lock/borrow parameter takes
# on its argument's root for the call's duration (the symtab appends the lock
# overlay entry in the open call scope; it vanishes when the scope pops).
lockCallArg: function {st: zenv.ZSymbolTable name: StringView callId: u64} is {
    pth: (List of: String)
    nm: name.string
    pth.append nm
    h: (ztypes.zlockholder kind: ztypes.zlockholderkind.CALL id: callId)
    h2: (ztypes.zlockholder kind: ztypes.zlockholderkind.CALL id: callId)
    r: st.tryLock path: pth lockType: ztypes.zlockstate.EXCLUSIVE holder: h hasSelfHolder: true selfHolder: h2
}

# takenHere -- the location stamp an ownership-transfer overlay carries (pop
# propagates only located takes into the enclosing scope).
takenHere: function {} out (optionval t: ztypes.zsrcpos) is {
    return (optionval.some (ztypes.zsrcpos fsno: 0 lineno: 0 colno: 0))
}

# appendValueTuple -- the dotted-path tuple of a value node (root first),
# appended onto dst; non-path shapes contribute nothing.
appendValueTuple: function {n: Node dst: (List of: String)} is {
    match (
        n
    ) case expression then {
        appendValueTuple n: n.expression dst: dst
    } case atomid then {
        nm: n.name.copy
        dst.append nm
    } case dottedpath then {
        appendValueTuple n: n.parent dst: dst
        cn: atomName n: n.child
        if cn.length > 0.u64 then {
            dst.append cn
        } else {
        }
    } else {
    }
}

# drainPendingBorrow / takePendingBorrow -- clear the borrow side-channel /
# move it into a local list (root-first order preserved).
drainPendingBorrow: function {st: zenv.ZSymbolTable} is {
    for while st.typing.pendingBorrowPath.length > 0.u64 loop {
        pd: st.typing.pendingBorrowPath.pop
    }
}

takePendingBorrow: function {st: zenv.ZSymbolTable dst: (List of: String)} is {
    n: st.typing.pendingBorrowPath.length
    i: 0.u64
    for while i < n loop {
        e: st.typing.pendingBorrowPath.get i: i
        ec: e.copy
        dst.append ec
        i = i + 1.u64
    }
    drainPendingBorrow st: st
}

# installBorrowLocks -- SHARED on every path prefix, EXCLUSIVE on the leaf
# (the symtab appends one lock overlay entry per acquisition, keyed by the
# path root -- the oracle's non-definition rows). Holder = the binding var.
installBorrowLocks: function {st: zenv.ZSymbolTable src: (List of: String) vid: u64} is {
    n: src.length
    if n == 0.u64 then {
        return
    } else {
    }
    end: 1.u64
    for while end < n loop {
        sub: (List of: String)
        i: 0.u64
        for while i < end loop {
            e: src.get i: i
            ec: e.copy
            sub.append ec
            i = i + 1.u64
        }
        hs: (ztypes.zlockholder kind: ztypes.zlockholderkind.VAR id: vid)
        hs2: (ztypes.zlockholder kind: ztypes.zlockholderkind.VAR id: vid)
        rs: st.tryLock path: sub lockType: ztypes.zlockstate.SHARED holder: hs hasSelfHolder: false selfHolder: hs2
        end = end + 1.u64
    }
    full: (List of: String)
    j: 0.u64
    for while j < n loop {
        e2: src.get i: j
        ec2: e2.copy
        full.append ec2
        j = j + 1.u64
    }
    he: (ztypes.zlockholder kind: ztypes.zlockholderkind.VAR id: vid)
    he2: (ztypes.zlockholder kind: ztypes.zlockholderkind.VAR id: vid)
    re: st.tryLock path: full lockType: ztypes.zlockstate.EXCLUSIVE holder: he hasSelfHolder: false selfHolder: he2
}

# isLiteralTypeId -- a literal-typed value: the unregistered int/float pseudo
# ids, or a data block's registered literal_int/literal_float element shell.
isLiteralTypeId: function {st: zenv.ZSymbolTable tid: u64} out bool is {
    if tid == literalIntId then {
        return true
    } else {
    }
    if tid == literalFloatId then {
        return true
    } else {
    }
    nm: typeNameOf st: st tid: tid
    if nm.stringview == "literal_int" then {
        return true
    } else {
    }
    return nm.stringview == "literal_float"
}

hoistArg: function {st: zenv.ZSymbolTable argNode: Node argType: u64 paramType: u64 consumes: bool} out String is {
    tn: st.typing.nextTempId
    st.typing.nextTempId = tn + 1.u64
    tname: "_t\{tn}"
    ln: nodeLine n: argNode
    co: nodeCol n: argNode
    assignId: st.typing.nextSynthNodeId
    exprId: assignId + 1.u32
    atomId: assignId + 2.u32
    st.typing.nextSynthNodeId = assignId + 3.u32
    st.typing.synthNodes.append (ztyping.SynthNode
        nodeid: assignId
        kind: "Assignment".string
        label: st.typing.synthLabel.copy
        lineno: ln
        colno: co)
    st.typing.synthNodes.append (ztyping.SynthNode
        nodeid: exprId
        kind: "Expression".string
        label: st.typing.synthLabel.copy
        lineno: ln
        colno: co)
    st.typing.synthNodes.append (ztyping.SynthNode
        nodeid: atomId
        kind: "AtomId".string
        label: st.typing.synthLabel.copy
        lineno: ln
        colno: co)
    seta: argType
    st.typing.nodeType.set key: assignId.u64 value: seta
    sete: argType
    st.typing.nodeType.set key: exprId.u64 value: sete
    atomT: argType
    if paramType > 0.u64 then {
        atomT = paramType
    } else {
    }
    setm: atomT
    st.typing.nodeType.set key: atomId.u64 value: setm
    v: st.reg.newVariable ztypeId: argType ownership: ztypes.zownership.OWNED
    v.synthOrigin = (Option.some "anf".string)
    vid: v.variableId
    st.defineVar name: tname.stringview var: v
    st.typing.defVariableId.set key: assignId.u64 value: vid
    if consumes then {
        st.invalidate name: tname.stringview loc: (optionval.none ztypes.zsrcpos)
    } else {
    }
    return tname
}

# walkCallArgsHoist -- the user-call argument walk: type each argument, then
# hoist non-trivial ones into synth temps (mirrors _check_call_arguments).
walkCallArgsHoist: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) call: zast.CallData funcId: u64 isCtor: bool} out String is {
    lockRoot: "".string
    st.typing.lastLockParamRoot = "".string
    argIdx: 0.u64
    aiter: call.arguments.iterate
    for arg: aiter loop {
        match (
            arg
        ) case namedoperation then {
            vt: checkValue st: st unitName: unitName unitBody: unitBody node: arg.operation
            if vt > 0.u64 then {
                pn: unitLabel o: arg.name
                if pn.length == 0.u64 then {
                    pp: positionalParamName st: st funcId: funcId idx: argIdx
                    pn = pp
                } else {
                }
                isTake: false
                isLockish: false
                isDeclLock: false
                pt: 0.u64
                if funcId > 0.u64 when pn.length > 0.u64 then {
                    if (isLiteralTypeId st: st tid: vt) then {
                        po: st.typing.childOf parentTypeId: funcId name: pn.stringview
                        match (
                            po
                        ) case some then {
                            pt = resolveChildPayload st: st unitName: unitName cid: po
                        } case none then {
                        }
                    } else {
                    }
                    cnid: st.typing.childIdFor parentTypeId: funcId name: pn.stringview
                    oo: st.typing.childOwnership.get key: cnid
                    match (
                        oo
                    ) case some then {
                        if oo == ztypes.zparamownership.TAKE then {
                            isTake = true
                        } else {
                        }
                        if oo == ztypes.zparamownership.LOCK then {
                            isLockish = true
                            isDeclLock = true
                        } else {
                        }
                        if oo == ztypes.zparamownership.BORROW then {
                            isLockish = true
                        } else {
                        }
                    } case none then {
                        # Unrecorded ownership: the effective default is
                        # borrow (ctor field params keep their recorded flow).
                        if isCtor then {
                        } else {
                            isLockish = true
                        }
                    }
                    if isCtor then {
                        # Field ownership flows to the constructor param:
                        # a `.lock` field locks the caller's argument, any
                        # other reftype field takes it.
                        if (st.typing.isChildLockField parentTypeId: funcId name: pn.stringview) then {
                            isLockish = true
                        } else {
                            if (typeIsReftype st: st tid: vt) then {
                                isTake = true
                            } else {
                            }
                        }
                    } else {
                    }
                } else {
                }
                if (argIsTrivial op: arg.operation) then {
                    # A trivial literal argument coerces in place at the
                    # parameter boundary (no hoist: restamp its bare node).
                    if pt > 0.u64 then {
                        iid2: innermostNodeId n: arg.operation
                        if iid2 > 0.u32 then {
                            seta2: pt
                            st.typing.nodeType.set key: iid2.u64 value: seta2
                        } else {
                        }
                    } else {
                    }
                    # A bare-name reftype argument: a take parameter consumes
                    # it (the overlay propagates out on pop); a lock/borrow
                    # parameter locks it for the call.
                    bn: bareAtomName n: arg.operation
                    if bn.length > 0.u64 when (typeIsReftype st: st tid: vt) then {
                        bvo: st.lookupVarId name: bn.stringview
                        match (
                            bvo
                        ) case some then {
                            if isTake then {
                                st.invalidate name: bn.stringview loc: takenHere
                            } else {
                                if isLockish then {
                                    lockCallArg st: st name: bn.stringview callId: call.nodeid.u64
                                    if lockRoot.length == 0.u64 then {
                                        lockRoot = bn.copy
                                    } else {
                                    }
                                    if isDeclLock then {
                                        xlc: bn.copy
                                        st.typing.lastLockParamRoot = xlc
                                    } else {
                                    }
                                } else {
                                }
                            }
                        } case none then {
                        }
                    } else {
                    }
                } else {
                    # A construction or take parameter consumes the hoisted
                    # temp inside the call scope; a lock/borrow parameter
                    # locks it there.
                    consumes: false
                    if isTake then {
                        consumes = true
                    } else {
                    }
                    tnm: hoistArg st: st argNode: arg.operation argType: vt paramType: pt consumes: consumes
                    if isLockish when (typeIsReftype st: st tid: vt) then {
                        lockCallArg st: st name: tnm.stringview callId: call.nodeid.u64
                    } else {
                    }
                }
            } else {
            }
            argIdx = argIdx + 1.u64
        } else {
        }
    }
    return lockRoot
}

# callableDottedResult -- a dotted callable resolves through the dotted-path
# walk (no auto-call coercion -- callable position wants the function itself);
# the base is typed and stamped there. none = the callable is not a dotted
# path; some 0 = dotted but unresolved (e.g. a data block's `.index`), which
# leaves the call untyped with its arguments unwalked, like the reference.
callableDottedResult: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) n: Node} out (optionval t: u64) is {
    match (
        n
    ) case dottedpath then {
        r: checkDotted st: st unitName: unitName unitBody: unitBody dp: n coerce: false
        return (optionval.some r)
    } else {
        return (optionval.none u64)
    }
}

# checkCall -- type a call. C1 handles the `return <value>` control-flow form:
# stamp the callable atom with return's type, mark the call RETURN, walk the
# return value, and resolve the call to `never`. Other call kinds land later.
checkCall: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) call: zast.CallData} out u64 is {
    result: 0.u64
    cn: atomName n: call.callable
    if cn.stringview == "return" then {
        rtOpt: lookupTyperef resolved: st.typing.resolved mainName: unitName base: "return"
        match (
            rtOpt
        ) case some then {
            calid: nodeId n: call.callable
            st.typing.nodeType.set key: calid.u64 value: rtOpt
        } case none then {
        }
        st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.RETURN
        aiter: call.arguments.iterate
        for arg: aiter loop {
            match (
                arg
            ) case namedoperation then {
                checkValue st: st unitName: unitName unitBody: unitBody node: arg.operation
            } else {
            }
        }
        nvOpt: lookupTyperef resolved: st.typing.resolved mainName: unitName base: "never"
        match (
            nvOpt
        ) case some then {
            result = nvOpt
            setk: result
            st.typing.nodeType.set key: call.nodeid.u64 value: setk
        } case none then {
        }
    } else {
        # A regular call. A dotted callable resolves through the dotted-path
        # walk first; an unresolved member bails with the args unwalked. A
        # bare-name callable: a non-generic user function pushes a call scope
        # and resolves to its return type; a generic callee (e.g. print) infers
        # a clone; an unresolvable callable just has its args walked (its
        # callable/result/mono are out of the own+system+collections filter).
        mcb: metaCreateBaseId n: call.callable
        mcid: 0.u32
        match (
            mcb
        ) case some then {
            mcid = mcb
        } case none then {
        }
        if mcid > 0.u32 when st.typing.currentThisName.length > 0.u64 then {
            # `meta.create` constructs the enclosing type: the raw allocator's
            # params are the type's field children, so the ctor arg walk
            # (hoists, coercion, field consumption) rides funcId = the type.
            mctn: st.typing.currentThisName.copy
            mto: lookupTyperef resolved: st.typing.resolved mainName: unitName base: mctn.stringview
            mtid: optU64Or o: mto d: 0.u64
            if mtid > 0.u64 then {
                setmb: mtid
                st.typing.nodeType.set key: mcid.u64 value: setmb
                mcm: st.pushCall
                mclr: walkCallArgsHoist st: st unitName: unitName unitBody: unitBody call: call funcId: mtid isCtor: true
                st.popTo marker: mcm
                setmc: mtid
                st.typing.nodeType.set key: call.nodeid.u64 value: setmc
                return mtid
            } else {
            }
        } else {
        }
        dro: callableDottedResult st: st unitName: unitName unitBody: unitBody n: call.callable
        match (
            dro
        ) case some then {
            if dro == 0.u64 then {
                return 0.u64
            } else {
                # A non-generic FUNCTION member dispatches as a user method
                # call: call scope, arg walk, the callee's return, and the
                # borrow-return report.
                isMethodFn: false
                {
                    mzo: st.reg.typeById.get key: dro
                    match (
                        mzo
                    ) case some then {
                        if mzo.typetype == ztypes.ztypetype.FUNCTION then {
                            if mzo.isgeneric then {
                            } else {
                                isMethodFn = true
                            }
                        } else {
                        }
                    } case none then {
                    }
                }
                if isMethodFn then {
                    tdcb: createDottedBaseId n: call.callable
                    tdcid: 0.u32
                    match (
                        tdcb
                    ) case some then {
                        tdcid = tdcb
                    } case none then {}
                    if tdcid > 0.u32 then {
                        tdo: optU64Or o: (st.typing.nodeType.get key: tdcid.u64) d: 0.u64
                        tdb: typedefBaseOf st: st unitName: unitName tid: tdo
                        if tdb > 0.u64 then {
                            return (checkTypedefCreate st: st unitName: unitName unitBody: unitBody call: call tdId: tdo)
                        } else {}
                    } else {}
                    mcm: st.pushCall
                    mlr: walkCallArgsHoist st: st unitName: unitName unitBody: unitBody call: call funcId: dro isCtor: false
                    # The receiver locks for the call's duration too (after
                    # the args, matching the oracle's entry order).
                    rro: methodReceiverRoot n: call.callable
                    if rro.length > 0.u64 then {
                        rvo2: st.lookupVarId name: rro.stringview
                        match (
                            rvo2
                        ) case some then {
                            rvt2: st.lookup name: rro.stringview
                            match (
                                rvt2
                            ) case some then {
                                # A receiver-bound method locks reftype
                                # receivers; a this-less function member is a
                                # callable field -- its receiver locks
                                # unconditionally (mirrors _lock_receiver).
                                doLock: false
                                if (methodHasThisReceiver st: st mid: dro) then {
                                    if (typeIsReftype st: st tid: rvt2) then {
                                        doLock = true
                                    } else {
                                    }
                                } else {
                                    doLock = true
                                }
                                if doLock then {
                                    lockCallArg st: st name: rro.stringview callId: call.nodeid.u64
                                } else {
                                }
                            } case none then {
                            }
                        } case none then {
                        }
                    } else {
                    }
                    st.popTo marker: mcm
                    mres: 0.u64
                    mro: methodReturnOf st: st mid: dro
                    match (
                        mro
                    ) case some then {
                        mres = mro
                        setmr: mres
                        st.typing.nodeType.set key: call.nodeid.u64 value: setmr
                    } case none then {
                    }
                    # A synthesized `create` has no recorded return: explicit
                    # `.create` constructs, so the result is the base type.
                    if mres == 0.u64 then {
                        cdb: createDottedBaseId n: call.callable
                        cdbid: 0.u32
                        match (
                            cdb
                        ) case some then {
                            cdbid = cdb
                        } case none then {
                        }
                        if cdbid > 0.u32 then {
                            btid: optU64Or o: (st.typing.nodeType.get key: cdbid.u64) d: 0.u64
                            if btid > 0.u64 then {
                                mres = btid
                                setmr2: mres
                                st.typing.nodeType.set key: call.nodeid.u64 value: setmr2
                            } else {
                            }
                        } else {
                        }
                    }
                    xroot: st.typing.lastLockParamRoot.copy
                    if xroot.length > 0.u64 then {
                        st.typing.lastLockParamRoot = "".string
                        drainPendingBorrow st: st
                        st.typing.pendingBorrowPath.append xroot
                    } else {
                    }
                    if (optBoolOr o: (st.typing.funcReturnsBorrow.get key: dro) d: false) when mlr.length > 0.u64 then {
                        drainPendingBorrow st: st
                        mlrc: mlr.copy
                        st.typing.pendingBorrowPath.append mlrc
                    } else {
                    }
                    return mres
                } else {
                }
            }
        } case none then {
        }
        funcId: 0.u64
        if cn.length > 0.u64 then {
            # A local variable of FUNCTION type (a spec-typed param or a
            # function reference) is callable; locals shadow unit names.
            lvo: st.lookup name: cn.stringview
            match (
                lvo
            ) case some then {
                if (st.reg.typetypeOf typeId: lvo) == ztypes.ztypetype.FUNCTION then {
                    funcId = lvo
                } else {
                }
            } case none then {
            }
            if funcId > 0.u64 then {
            } else {
                fo: lookupTyperef resolved: st.typing.resolved mainName: unitName base: cn.stringview
                match (
                    fo
                ) case some then {
                    funcId = fo
                } case none then {
                }
            }
        } else {
        }
        if funcId > 0.u64 then {
            maybeWalkMethods st: st unitName: unitName unitBody: unitBody name: cn.stringview
        } else {
        }
        isUser: false
        isGen: false
        isCtor: false
        if funcId > 0.u64 then {
            zo: st.reg.typeById.get key: funcId
            match (
                zo
            ) case some then {
                if zo.isgeneric then {
                    isGen = true
                } else {
                    isUser = true
                    if zo.typetype == ztypes.ztypetype.FUNCTION then {
                    } else {
                        isCtor = true
                    }
                }
            } case none then {
            }
        } else {
        }
        tdb0: 0.u64
        if isCtor then {
            tdb0 = typedefBaseOf st: st unitName: unitName tid: funcId
        } else {
        }
        if tdb0 > 0.u64 then {
            return (checkTypedefCreate st: st unitName: unitName unitBody: unitBody call: call tdId: funcId)
        } else {
        }
        if isUser then {
            calid: nodeId n: call.callable
            setc: funcId
            st.typing.nodeType.set key: calid.u64 value: setc
            cm: st.pushCall
            lockRoot: walkCallArgsHoist st: st unitName: unitName unitBody: unitBody call: call funcId: funcId isCtor: isCtor
            st.popTo marker: cm
            if isCtor then {
                # a type in callable position constructs: the call's value is
                # the type itself.
                result = funcId
                setr2: result
                st.typing.nodeType.set key: call.nodeid.u64 value: setr2
            } else {
                rnOpt: st.typing.funcReturnNode.get key: funcId
                match (
                    rnOpt
                ) case some then {
                    rtOpt: st.typing.nodeType.get key: rnOpt
                    match (
                        rtOpt
                    ) case some then {
                        result = rtOpt
                        setr: result
                        st.typing.nodeType.set key: call.nodeid.u64 value: setr
                    } case none then {
                    }
                } case none then {
                }
                # A `.borrow`-marked return borrows from the lock parameter's
                # argument: report the source for the binding site.
                xroot2: st.typing.lastLockParamRoot.copy
                if xroot2.length > 0.u64 then {
                    st.typing.lastLockParamRoot = "".string
                    drainPendingBorrow st: st
                    st.typing.pendingBorrowPath.append xroot2
                } else {
                }
                if (optBoolOr o: (st.typing.funcReturnsBorrow.get key: funcId) d: false) when lockRoot.length > 0.u64 then {
                    drainPendingBorrow st: st
                    lrc: lockRoot.copy
                    st.typing.pendingBorrowPath.append lrc
                } else {
                }
            }
        } else {
            if isGen then {
                gr: checkGenericCall st: st unitName: unitName unitBody: unitBody call: call funcId: funcId
                result = gr
                if gr > 0.u64 then {
                    setgc: gr
                    st.typing.nodeType.set key: call.nodeid.u64 value: setgc
                } else {
                }
                if cn.stringview == "panic" then {
                    calid2: nodeId n: call.callable
                    setpk: funcId
                    st.typing.nodeType.set key: calid2.u64 value: setpk
                    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.PANIC
                } else {
                }
                if cn.stringview == "error" then {
                    calid3: nodeId n: call.callable
                    seter: funcId
                    st.typing.nodeType.set key: calid3.u64 value: seter
                    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.ERROR
                } else {
                }
            } else {
                giter: call.arguments.iterate
                for garg: giter loop {
                    match (
                        garg
                    ) case namedoperation then {
                        checkValue st: st unitName: unitName unitBody: unitBody node: garg.operation
                    } else {
                    }
                }
            }
        }
    }
    return result
}

# checkGenericCall -- a call to a generic user function: walk the value args,
# infer the type-param bindings (explicit `param: Type` args, else each value
# arg's materialised type through the parameter it feeds), mint the instance
# (children substituted; return substituted from the recorded `out` placeholder
# name), synthesize the clone scope on first instantiation (empty, named by the
# instance, unreachable per the template body's syntactic divergence -- bodied
# templates only, so native generics like print add no scope), stamp the
# callable with the instance, and resolve to the instance's return. Nested
# control flow inside generic bodies needs a real clone walk and is deferred.
checkGenericCall: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) call: zast.CallData funcId: u64} out u64 is {
    gparams: (List of: String)
    with gpiter: st.typing.typeGenericArg.iterate do for gp: gpiter loop {
        if gp.parentTypeId == funcId then {
            gpn: gp.paramName.copy
            gparams.append gpn
        } else {
        }
    }
    pNames: (List of: String)
    pHolderIds: (List of: u64)
    with pciter: st.typing.typeChild.iterate do for tc: pciter loop {
        if tc.parentTypeId == funcId then {
            cto: st.typing.childTypeById.get key: tc.childNameId
            match (
                cto
            ) case some then {
                pn2: tc.childName.copy
                pNames.append pn2
                cto2: cto
                pHolderIds.append cto2
            } case none then {
            }
        } else {
        }
    }
    pHolders: (List of: String)
    phi: 0.u64
    phn: pHolderIds.length
    for while phi < phn loop {
        hid: pHolderIds.get i: phi
        hn: typeNameOf st: st tid: hid
        pHolders.append hn
        phi = phi + 1.u64
    }
    subs: (Map key: String value: u64)
    posIdx: 0.u64
    aiter: call.arguments.iterate
    for arg: aiter loop {
        match (
            arg
        ) case namedoperation then {
            an2: unitLabel o: arg.name
            isTypeArg: false
            tgi: gparams.iterate
            for gp2: tgi loop {
                if an2.stringview == gp2.stringview then {
                    isTypeArg = true
                } else {
                }
            }
            if isTypeArg then {
                tn3: atomName n: arg.operation
                to3: lookupTyperef resolved: st.typing.resolved mainName: unitName base: tn3.stringview
                match (
                    to3
                ) case some then {
                    sk: an2.copy
                    sv: to3
                    subs.set key: sk value: sv
                } case none then {
                }
            } else {
                avt: checkValue st: st unitName: unitName unitBody: unitBody node: arg.operation
                mat: materialiseLiteral st: st unitName: unitName t: avt
                holder: ""
                if an2.length > 0.u64 then {
                    hi: 0.u64
                    hn2: pNames.length
                    for while hi < hn2 loop {
                        pn3: pNames.get i: hi
                        if an2.stringview == pn3.stringview then {
                            hv: pHolders.get i: hi
                            holder = hv.stringview
                        } else {
                        }
                        hi = hi + 1.u64
                    }
                } else {
                    if posIdx < pHolders.length then {
                        hv2: pHolders.get i: posIdx
                        holder = hv2.stringview
                    } else {
                    }
                }
                posIdx = posIdx + 1.u64
                if holder.length > 0.u64 when mat > 0.u64 then {
                    hk: holder.string
                    hgot: subs.get key: hk
                    match (
                        hgot
                    ) case some then {
                    } case none then {
                        sk2: holder.string
                        sv2: mat
                        subs.set key: sk2 value: sv2
                    }
                } else {
                }
            }
        } else {
        }
    }
    mname: typeNameOf st: st tid: funcId
    if mname.length == 0.u64 then {
        return 0.u64
    } else {
    }
    allOk: true
    giter2: gparams.iterate
    for gp3: giter2 loop {
        gv: gp3.stringview
        gk: gv.string
        ggot: subs.get key: gk
        match (
            ggot
        ) case some then {
            an4: typeNameOf st: st tid: ggot
            mname.append s: "_"
            mname.append s: an4.stringview
        } case none then {
            allOk = false
        }
    }
    if allOk == false then {
        return 0.u64
    } else {
    }
    if gparams.length == 0.u64 then {
        return 0.u64
    } else {
    }
    wasNew: false
    nk: mname.string
    ngot: st.typing.monoByName.get key: nk
    match (
        ngot
    ) case some then {
    } case none then {
        wasNew = true
    }
    mid: mintMono st: st mainName: unitName name: mname.stringview templateId: funcId subs: subs fallbackArg: 0.u64
    rno: st.typing.funcReturnNode.get key: funcId
    match (
        rno
    ) case some then {
        rbn: st.typing.pendingTyperef.get key: rno
        match (
            rbn
        ) case some then {
            rv: rbn.stringview
            rk: rv.string
            rgot2: subs.get key: rk
            match (
                rgot2
            ) case some then {
                st.reg.setReturnType typeId: mid value: rgot2
            } case none then {
                rconc: lookupTyperef resolved: st.typing.resolved mainName: unitName base: rv
                match (
                    rconc
                ) case some then {
                    st.reg.setReturnType typeId: mid value: rconc
                } case none then {
                }
            }
        } case none then {
        }
    } case none then {
    }
    if wasNew then {
        dvo: st.typing.fnBodyDiverges.get key: funcId
        match (
            dvo
        ) case some then {
            csname: "function:\{mname}"
            cm2: st.pushBlock name: csname.stringview
            if dvo then {
                st.markUnreachable
            } else {
            }
            st.popTo marker: cm2
        } case none then {
        }
    } else {
    }
    calid2: nodeId n: call.callable
    setc2: mid
    st.typing.nodeType.set key: calid2.u64 value: setc2
    return (optU64Or o: (methodReturnOf st: st mid: mid) d: 0.u64)
}

# subjectAtomName -- a match subject's bare-atom name (narrowing requires a
# simple addressable name): unwrap expression wrappers, "" for dotted/complex
# subjects and numeric atoms.
subjectAtomName: function {n: Node} out String is {
    match (
        n
    ) case expression then {
        return (subjectAtomName n: n.expression)
    } case atomid then {
        if (isNumericLiteralName name: n.name.stringview) then {
            return "".string
        } else {
            return n.name.copy
        }
    } else {
        return "".string
    }
}

# sumSubtypeNames -- a union/variant's arm names: its children minus the
# synthesized members (functions, the tag data record, enums).
sumSubtypeNames: function {st: zenv.ZSymbolTable sid: u64} out (List of: String) is {
    names: (List of: String)
    cids: (List of: u64)
    with citer: st.typing.typeChild.iterate do for tc: citer loop {
        if tc.parentTypeId == sid then {
            cto: st.typing.childTypeById.get key: tc.childNameId
            match (
                cto
            ) case some then {
                nm2: tc.childName.copy
                names.append nm2
                cto2: cto
                cids.append cto2
            } case none then {
            }
        } else {
        }
    }
    arms: (List of: String)
    i: 0.u64
    n: names.length
    for while i < n loop {
        cid: cids.get i: i
        tt: st.reg.typetypeOf typeId: cid
        keep: true
        if tt == ztypes.ztypetype.FUNCTION then { keep = false } else {
        }
        if tt == ztypes.ztypetype.DATA then { keep = false } else {
        }
        if tt == ztypes.ztypetype.TAG then { keep = false } else {
        }
        if tt == ztypes.ztypetype.ENUM then { keep = false } else {
        }
        if keep then {
            nm3: names.get i: i
            nm4: nm3.copy
            arms.append nm4
        } else {
        }
        i = i + 1.u64
    }
    return arms
}

# resolveChildPayload -- a sum-type arm child resolves through a NULL-unit
# reference shell; re-resolve it by name to the real type so arm-body stamps
# survive the dump's unit filter. Falls back to the shell id.
resolveChildPayload: function {st: zenv.ZSymbolTable unitName: StringView cid: u64} out u64 is {
    cn: typeNameOf st: st tid: cid
    if cn.length == 0.u64 then {
        return cid
    } else {
    }
    return (optU64Or o: (lookupTyperef resolved: st.typing.resolved mainName: unitName base: cn.stringview) d: cid)
}

# lastStmtTypeOpt -- lastStmtType over an optional block (0 when absent).
lastStmtTypeOpt: function {st: zenv.ZSymbolTable bodyOpt: (Option t: Node)} out u64 is {
    match (
        bodyOpt
    ) case some then {
        return (lastStmtType st: st block: bodyOpt)
    } case none then {
        return 0.u64
    }
}

# checkCase -- walk a match: push the `match` scope, type the subject, push
# `match_body` (resetting the bare-name subject's narrowing), then per arm an
# `arm:{name}` scope with a shadow-narrowing overlay (the subject resolves to
# the arm payload in the body), tracking diverging arms; an else arm excludes
# the covered subtypes. After popping, an exhaustive all-diverging match
# resolves to `never` (a completing-arm result type lands with a value-match
# example) and each diverging arm's subtype is excluded from the subject in
# the enclosing scope (all-excluded marks it unreachable).
checkCase: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) casenode: zast.CaseData} out u64 is {
    matchMarker: st.pushBlock name: "match"
    subjT: checkValue st: st unitName: unitName unitBody: unitBody node: casenode.subject
    isSum: false
    if subjT > 0.u64 then {
        stt: st.reg.typetypeOf typeId: subjT
        if stt == ztypes.ztypetype.UNION then { isSum = true } else {
        }
        if stt == ztypes.ztypetype.VARIANT then { isSum = true } else {
        }
    } else {
    }
    targetName: "".string
    if isSum then {
        tn: subjectAtomName n: casenode.subject
        targetName = tn
    } else {
    }
    neverId: 0.u64
    nvOpt: lookupTyperef resolved: st.typing.resolved mainName: unitName base: "never"
    match (
        nvOpt
    ) case some then {
        neverId = nvOpt
    } case none then {
    }
    bodyMarker: st.pushBlock name: "match_body"
    if targetName.length > 0.u64 then {
        st.resetNarrowing name: targetName.stringview
    } else {
    }
    covered: (List of: String)
    diverging: (List of: String)
    armTypes: (List of: u64)
    allDiverge: true
    cliter: casenode.clauses.iterate
    for clause: cliter loop {
        match (
            clause
        ) case caseclause then {
            armName: atomName n: clause.matcharm
            asname: "arm:\{armName}"
            armMarker: st.pushBlock name: asname.stringview
            if targetName.length > 0.u64 when subjT > 0.u64 then {
                po: st.typing.childOf parentTypeId: subjT name: armName.stringview
                match (
                    po
                ) case some then {
                    rp: resolveChildPayload st: st unitName: unitName cid: po
                    st.narrow name: targetName.stringview toTypeId: rp subtypeName: armName.stringview shadow: true
                } case none then {
                }
            } else {
            }
            checkStatement st: st unitName: unitName unitBody: unitBody block: clause.statement
            at: lastStmtType st: st block: clause.statement
            atc: at
            armTypes.append atc
            if at > 0.u64 when at == neverId then {
                dn: armName.copy
                diverging.append dn
            } else {
                allDiverge = false
            }
            cn2: armName.copy
            covered.append cn2
            st.popTo marker: armMarker
        } else {
        }
    }
    hasElse: false
    match (
        casenode.elseclause
    ) case some then {
        hasElse = true
    } case none then {
    }
    if hasElse then {
        elseMarker: st.pushBlock name: "arm:else"
        if targetName.length > 0.u64 when subjT > 0.u64 then {
            eiter: covered.iterate
            for en2: eiter loop {
                st.exclude name: targetName.stringview subtypeName: en2.stringview fullTypeId: subjT
            }
        } else {
        }
        walkBody st: st unitName: unitName unitBody: unitBody bodyOpt: casenode.elseclause
        et: lastStmtTypeOpt st: st bodyOpt: casenode.elseclause
        armTypes.append et
        st.popTo marker: elseMarker
    } else {
    }
    st.popTo marker: matchMarker
    exhaustive: hasElse
    if exhaustive then {
    } else {
        if isSum then {
            arms2: sumSubtypeNames st: st sid: subjT
            allCovered: true
            a2iter: arms2.iterate
            for an3: a2iter loop {
                found: false
                c2iter: covered.iterate
                for cn3: c2iter loop {
                    if an3.stringview == cn3.stringview then {
                        found = true
                    } else {
                    }
                }
                if found then {
                } else {
                    allCovered = false
                }
            }
            exhaustive = allCovered
        } else {
        }
    }
    if targetName.length > 0.u64 when subjT > 0.u64 then {
        diter: diverging.iterate
        for dn2: diter loop {
            st.exclude name: targetName.stringview subtypeName: dn2.stringview fullTypeId: subjT
        }
    } else {
    }
    if exhaustive when allDiverge when neverId > 0.u64 then {
        if casenode.clauses.length > 0.u64 then {
            setn2: neverId
            st.typing.nodeType.set key: casenode.nodeid.u64 value: setn2
            return neverId
        } else {
            return 0.u64
        }
    } else {
    }
    if exhaustive then {
        # the first completing (non-diverging) arm's type is the match value;
        # an untyped completing arm leaves the match unstamped.
        ti: 0.u64
        tn4: armTypes.length
        for while ti < tn4 loop {
            at2: armTypes.get i: ti
            if at2 == neverId then {
            } else {
                if at2 > 0.u64 then {
                    setc3: at2
                    st.typing.nodeType.set key: casenode.nodeid.u64 value: setc3
                    return at2
                } else {
                    return 0.u64
                }
            }
            ti = ti + 1.u64
        }
        return 0.u64
    } else {
        return 0.u64
    }
}

# checkValue -- type an expression-value node, dispatching by kind. Returns the
# resolved type id, or 0 when unhandled.
checkValue: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) node: Node} out u64 is {
    match (
        node
    ) case call then {
        return (checkCall st: st unitName: unitName unitBody: unitBody call: node)
    } case binop then {
        return (checkBinop st: st unitName: unitName unitBody: unitBody binop: node)
    } case atomid then {
        return (checkAtomid st: st unitName: unitName unitBody: unitBody node: node)
    } case atomstring then {
        return (checkString st: st unitName: unitName unitBody: unitBody node: node)
    } case dottedpath then {
        return (checkDotted st: st unitName: unitName unitBody: unitBody dp: node coerce: true)
    } case caseexpr then {
        return (checkCase st: st unitName: unitName unitBody: unitBody casenode: node)
    } case ifexpr then {
        return (checkIf st: st unitName: unitName unitBody: unitBody ifnode: node)
    } case forexpr then {
        checkFor st: st unitName: unitName unitBody: unitBody fornode: node
        return 0.u64
    } case doexpr then {
        return (checkDo st: st unitName: unitName unitBody: unitBody donode: node)
    } case withexpr then {
        return (checkWith st: st unitName: unitName unitBody: unitBody withnode: node)
    } case reassignment then {
        checkReassignment st: st unitName: unitName unitBody: unitBody rasgn: node
        return 0.u64
    } case swapstmt then {
        checkSwap st: st unitName: unitName unitBody: unitBody swapnode: node
        return 0.u64
    } case expression then {
        t: checkValue st: st unitName: unitName unitBody: unitBody node: node.expression
        if t > 0.u64 then {
            setk: t
            st.typing.nodeType.set key: node.nodeid.u64 value: setk
        } else {
        }
        return t
    } else {
        return 0.u64
    }
}

# checkExpression -- type an expression wrapper from its inner value; returns
# true when the inner is a return terminator (so the caller marks the scope
# unreachable).
checkExpression: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) expr: zast.ExpressionData} out bool is {
    isRet: false
    t: checkValue st: st unitName: unitName unitBody: unitBody node: expr.expression
    if t > 0.u64 then {
        st.typing.nodeType.set key: expr.nodeid.u64 value: t
    } else {
    }
    innerNid: nodeId n: expr.expression
    ckOpt: st.typing.callKind.get key: innerNid.u64
    isRet = isReturnCallKind o: ckOpt
    return isRet
}

# checkStmtInner -- dispatch a statement line's inner node (C1: expressions).
checkStmtInner: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) inner: Node} out bool is {
    match (
        inner
    ) case expression then {
        return (checkExpression st: st unitName: unitName unitBody: unitBody expr: inner)
    } case assignment then {
        checkAssignment st: st unitName: unitName unitBody: unitBody asgn: inner
        return false
    } case reassignment then {
        checkReassignment st: st unitName: unitName unitBody: unitBody rasgn: inner
        return false
    } else {
        return false
    }
}

# checkStatementLine -- type a statement line; propagate the inner type to the
# line wrapper. Returns true for a return terminator.
checkStatementLine: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) sline: Node} out bool is {
    isRet: false
    match (
        sline
    ) case statementline then {
        isRet = checkStmtInner st: st unitName: unitName unitBody: unitBody inner: sline.statementline
        inid: nodeId n: sline.statementline
        itOpt: st.typing.nodeType.get key: inid.u64
        match (
            itOpt
        ) case some then {
            st.typing.nodeType.set key: sline.nodeid.u64 value: itOpt
        } case none then {
        }
    } else {
    }
    return isRet
}

# checkStatement -- walk a function-body statement block, marking the scope
# unreachable after a control-flow terminator (return).
checkStatement: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) block: Node} is {
    match (
        block
    ) case statement then {
        siter: block.statements.iterate
        for sline: siter loop {
            isRet: checkStatementLine st: st unitName: unitName unitBody: unitBody sline: sline
            drainPendingBorrow st: st
            if isRet then {
                st.markUnreachable
            } else {
            }
        }
    } else {
    }
}

# walkBody -- walk an optional function body (none for spec methods).
walkBody: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) bodyOpt: (Option t: Node)} is {
    match (
        bodyOpt
    ) case some then {
        checkStatement st: st unitName: unitName unitBody: unitBody block: bodyOpt
    } case none then {
    }
}

# nodeIsFunctiondef -- kind test that keeps the caller's un-narrowed handle.
nodeIsFunctiondef: function {o: Node} out bool is {
    match (
        o
    ) case functiondef then {
        return true
    } else {
        return false
    }
}

# objectdefIsGeneric -- a type definition with a generic as-block parameter;
# generic templates are never body-walked (instances clone at call sites).
objectdefIsGeneric: function {o: Node} out bool is {
    match (
        o
    ) case objectdef then {
        return (hasGenericParam items: o.asItems)
    } else {
        return false
    }
}

# scanTypeNameOpt -- recurse the method-walk trigger into an optional typeref
# (a function's return type).
scanTypeNameOpt: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) o: (Option t: Node)} is {
    match (
        o
    ) case some then {
        bn: baseTypeName n: o
        if bn.length > 0.u64 then {
            maybeWalkMethods st: st unitName: unitName unitBody: unitBody name: bn.stringview
        } else {
        }
    } case none then {
    }
}

# scanFnSig -- recurse the method-walk trigger through a function signature in
# resolution order: the return type first, then parameters in declaration order.
scanFnSig: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) op: Node} is {
    match (
        op
    ) case functiondef then {
        scanTypeNameOpt st: st unitName: unitName unitBody: unitBody o: op.returntype
        piter: op.parameters.iterate
        for pm: piter loop {
            match (
                pm
            ) case namedoperation then {
                bn: baseTypeName n: pm.operation
                if bn.length > 0.u64 then {
                    maybeWalkMethods st: st unitName: unitName unitBody: unitBody name: bn.stringview
                } else {
                }
            } else {
            }
        }
    } else {
    }
}

# scanMemberSignatures -- replay one definition's signature-resolution order:
# an objectdef resolves its field typerefs, then its is- and as-block method
# signatures; a function resolves its own signature. Each name recurses the
# trigger, so transitively referenced types walk their methods first.
scanMemberSignatures: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) op: Node} is {
    if (nodeIsFunctiondef o: op) then {
        scanFnSig st: st unitName: unitName unitBody: unitBody op: op
    } else {
        match (
            op
        ) case objectdef then {
            with fiter: op.isItems.iterate do for fm: fiter loop {
                match (
                    fm
                ) case namedoperation then {
                    if (nodeIsFunctiondef o: fm.operation) then {
                    } else {
                        bn: baseTypeName n: fm.operation
                        if bn.length > 0.u64 then {
                            maybeWalkMethods st: st unitName: unitName unitBody: unitBody name: bn.stringview
                        } else {
                        }
                    }
                } else {
                }
            }
            with iiter: op.isItems.iterate do for im: iiter loop {
                match (
                    im
                ) case namedoperation then {
                    scanFnSig st: st unitName: unitName unitBody: unitBody op: im.operation
                } else {
                }
            }
            with aiter: op.asItems.iterate do for am: aiter loop {
                match (
                    am
                ) case namedoperation then {
                    scanFnSig st: st unitName: unitName unitBody: unitBody op: am.operation
                } else {
                }
            }
        } else {
        }
    }
}

# maybeWalkMethods -- the resolution-time method-walk trigger: the first time
# a body walk resolves a main-unit definition's name, replay the reference
# resolver's side effects at the current scope position -- scan the signature
# typerefs (recursing per name), then body-check the type's methods. The
# early mark stops re-entry (a method constructing its own type).
maybeWalkMethods: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) name: StringView} is {
    nk: name.string
    got: st.typing.walkedMethodOwners.get key: nk
    match (
        got
    ) case some then {
        return
    } case none then {
    }
    io: st.typing.mainMemberIndex.get key: nk
    idx: 0.u64
    match (
        io
    ) case some then {
        idx = io
    } case none then {
        return
    }
    mv: true
    st.typing.walkedMethodOwners.set key: nk value: mv
    mem: unitBody.get i: idx
    match (
        mem
    ) case namedoperation then {
        scanMemberSignatures st: st unitName: unitName unitBody: unitBody op: mem.operation
        canWalk: objectdefHasMethodBodies op: mem.operation
        if canWalk when (objectdefIsGeneric o: mem.operation) then {
            canWalk = false
        } else {
        }
        if canWalk then {
            prev: st.typing.synthLabel.copy
            prevThis: st.typing.currentThisName.copy
            checkMethodBodies st: st unitName: unitName unitBody: unitBody typeName: name op: mem.operation
            st.typing.synthLabel = prev
            st.typing.currentThisName = prevThis
        } else {
        }
    } else {
    }
}

# objectdefHasMethodBodies -- a unit member whose operation is an objectdef
# with at least one functiondef-with-body item.
objectdefHasMethodBodies: function {op: Node} out bool is {
    match (
        op
    ) case objectdef then {
        iiter: op.isItems.iterate
        for im: iiter loop {
            match (
                im
            ) case namedoperation then {
                if (isFunctionDefWithBody o: im.operation) then {
                    return true
                } else {
                }
            } else {
            }
        }
        aiter: op.asItems.iterate
        for am: aiter loop {
            match (
                am
            ) case namedoperation then {
                if (isFunctionDefWithBody o: am.operation) then {
                    return true
                } else {
                }
            } else {
            }
        }
        return false
    } else {
        return false
    }
}

# checkMethodBodies -- body-check every method of one type definition (is- and
# as-block functiondefs, declaration order). The scopes land under the walk's
# current scope, mirroring the oracle's resolve-at-first-demand placement.
checkMethodBodies: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) typeName: StringView op: Node} is {
    match (
        op
    ) case objectdef then {
        iiter: op.isItems.iterate
        for im: iiter loop {
            match (
                im
            ) case namedoperation then {
                if (isFunctionDefWithBody o: im.operation) then {
                    mname: unitLabel o: im.name
                    qn: "\{typeName}.\{mname}"
                    checkFunctionBody st: st unitName: unitName defName: qn.stringview defn: im.operation thisName: typeName unitBody: unitBody
                } else {
                }
            } else {
            }
        }
        aiter: op.asItems.iterate
        for am: aiter loop {
            match (
                am
            ) case namedoperation then {
                if (isFunctionDefWithBody o: am.operation) then {
                    mname2: unitLabel o: am.name
                    qn2: "\{typeName}.\{mname2}"
                    checkFunctionBody st: st unitName: unitName defName: qn2.stringview defn: am.operation thisName: typeName unitBody: unitBody
                } else {
                }
            } else {
            }
        }
    } else {
    }
}

# lastStmtLineId / lastStmtLineIdOpt -- the node id of a function body's last
# statement line (the implicit-return position), or 0 when absent.
lastStmtLineId: function {block: Node} out u32 is {
    match (
        block
    ) case statement then {
        ne: block.statements.length
        if ne > 0.u64 then {
            last: block.statements.get i: (ne - 1.u64)
            match (
                last
            ) case statementline then {
                return last.nodeid
            } else {
            }
        } else {
        }
    } else {
    }
    return 0.u32
}

lastStmtLineIdOpt: function {o: (Option t: Node)} out u32 is {
    match (
        o
    ) case some then {
        return (lastStmtLineId block: o)
    } case none then {
        return 0.u32
    }
}

# checkFunctionBody -- type-check one function body. Pushes a scope, binds each
# parameter as a runtime variable, walks the body, then pops (the pop snapshots
# the scope's entries + unreachable flag for the SQL dump).
checkFunctionBody: function {st: zenv.ZSymbolTable unitName: StringView defName: StringView defn: Node thisName: StringView unitBody: (List of: Node)} is {
    match (
        defn
    ) case functiondef then {
        maybeWalkMethods st: st unitName: unitName unitBody: unitBody name: defName
        hasBody: false
        match (
            defn.body
        ) case some then {
            hasBody = true
        } case none then {
        }
        isGenDef: false
        rkey: "\{unitName}.\{defName}".string
        rgot: st.typing.resolved.get key: rkey
        match (
            rgot
        ) case some then {
            {
                gz: st.reg.typeById.get key: rgot
                match (
                    gz
                ) case some then {
                    if gz.isgeneric then {
                        isGenDef = true
                    } else {
                    }
                } case none then {
                }
            }
        } case none then {
        }
        if isGenDef then {
            return
        } else {
        }
        if hasBody then {
            sname: "function:\{defName}"
            dpush: st.push name: sname.stringview
            piter: defn.parameters.iterate
            for pm: piter loop {
                match (
                    pm
                ) case namedoperation then {
                    pname: unitLabel o: pm.name
                    pnid: nodeId n: pm.operation
                    ptid: paramTypeId typing: st.typing unitName: unitName op: pm.operation
                    if thisName.length > 0.u64 when (paramIsThisReceiver op: pm.operation) then {
                        thOpt: lookupTyperef resolved: st.typing.resolved mainName: unitName base: thisName
                        match (
                            thOpt
                        ) case some then {
                            ptid = thOpt
                        } case none then {
                        }
                    } else {
                    }
                    own: ownershipOfParam o: (pathOwnership n: pm.operation)
                    v: st.reg.newVariable ztypeId: ptid ownership: own
                    vid2: v.variableId
                    st.defineVar name: pname.stringview var: v
                    st.typing.defVariableId.set key: pnid.u64 value: vid2
                } else {
                }
            }
            # Synth rows carry the unit member's dump label: a method's nodes
            # live inside its TYPE's subtree, so the label is the type name.
            # Nested method walks save and restore it around their bodies.
            lbl: "\{unitName}.\{defName}"
            if thisName.length > 0.u64 then {
                lbl = "\{unitName}.\{thisName}"
            } else {
            }
            st.typing.synthLabel = lbl
            tnl: thisName.string
            st.typing.currentThisName = tnl
            walkBody st: st unitName: unitName unitBody: unitBody bodyOpt: defn.body
            # Implicit-return coercion: a literal-typed last statement takes
            # the function's concrete return type, stamped on the statement
            # line (the node the reference coerces by id).
            ftid: 0.u64
            ftid = optU64Or o: (st.typing.resolved.get key: rkey) d: ftid
            if ftid > 0.u64 then {
                ro: methodReturnOf st: st mid: ftid
                match (
                    ro
                ) case some then {
                    lsid: lastStmtLineIdOpt o: defn.body
                    if lsid > 0.u32 then {
                        cur: st.typing.nodeType.get key: lsid.u64
                        match (
                            cur
                        ) case some then {
                            if (isLiteralTypeId st: st tid: cur) then {
                                setr: ro
                                st.typing.nodeType.set key: lsid.u64 value: setr
                            } else {
                            }
                        } case none then {
                        }
                    } else {
                    }
                } case none then {
                }
            } else {
            }
            dpop: st.pop
        } else {
        }
    } else {
    }
}

# checkUnitBodies -- walk every function definition with a body in one unit.
checkUnitBodies: function {st: zenv.ZSymbolTable unitName: StringView unitdef: Node} is {
    match (
        unitdef
    ) case unitdef then {
        mi: 0.u64
        with niter: unitdef.body.iterate do for nm: niter loop {
            match (
                nm
            ) case namedoperation then {
                mnm: unitLabel o: nm.name
                miv: mi
                st.typing.mainMemberIndex.set key: mnm value: miv
            } else {
            }
            mi = mi + 1.u64
        }
        with miter: unitdef.body.iterate do for mm: miter loop {
            match (
                mm
            ) case namedoperation then {
                mainName: unitLabel o: mm.name
                if mainName.stringview == "main" then {
                    checkFunctionBody st: st unitName: unitName defName: mainName.stringview defn: mm.operation thisName: "" unitBody: unitdef.body
                } else {
                }
            } else {
            }
        }
        with biter: unitdef.body.iterate do for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                defName: unitLabel o: bm.name
                if defName.stringview == "main" then {
                } else {
                    checkFunctionBody st: st unitName: unitName defName: defName.stringview defn: bm.operation thisName: "" unitBody: unitdef.body
                }
            } else {
            }
        }
    } else {
    }
}

# checkBodies -- the body-walk pass (full mode), mirroring check()'s top-level
# loop: walk the main unit's function bodies, main first, then the others in
# body order. Runs after demand resolution so referenced types are already
# resolved.
checkBodies: function {st: zenv.ZSymbolTable program: Node} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        uiter: program.units.iterate
        for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                nm: unitLabel o: u.name
                if nm.stringview == mainName then {
                    checkUnitBodies st: st unitName: nm.stringview unitdef: u.operation
                } else {
                }
            } else {
            }
        }
    } else {
    }
}

# foldLiteralStamps -- replace literal-typed node stamps with their concrete
# defaults (i64 / f64) after the body walk: the unregistered pseudo ids and the
# data blocks' registered literal_int/literal_float element shells. Symbol-table
# entries keep their literal ids (the oracle's entry/variable rows read
# literal_int there too).
foldLiteralStamps: function {st: zenv.ZSymbolTable program: Node} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        intId: 0.u64
        li: lookupTyperef resolved: st.typing.resolved mainName: mainName base: "i64"
        match (
            li
        ) case some then {
            intId = li
        } case none then {
        }
        floatId: 0.u64
        lf: lookupTyperef resolved: st.typing.resolved mainName: mainName base: "f64"
        match (
            lf
        ) case some then {
            floatId = lf
        } case none then {
        }
        intShells: (List of: u64)
        floatShells: (List of: u64)
        nshell: st.reg.nextTypeId
        ti: 0.u64
        for while ti < nshell loop {
            snm: typeNameOf st: st tid: ti
            if snm.stringview == "literal_int" then {
                sid: ti
                intShells.append sid
            } else {
                if snm.stringview == "literal_float" then {
                    sid2: ti
                    floatShells.append sid2
                } else {
                }
            }
            ti = ti + 1.u64
        }
        iks: (List of: u64)
        fks: (List of: u64)
        with it: st.typing.nodeType.iterateItems do for e: it loop {
            isInt: e.value == literalIntId
            if (intShells.contains item: e.value) then {
                isInt = true
            } else {
            }
            isFloat: e.value == literalFloatId
            if (floatShells.contains item: e.value) then {
                isFloat = true
            } else {
            }
            if isInt then {
                k: e.key
                iks.append k
            } else {
            }
            if isFloat then {
                k2: e.key
                fks.append k2
            } else {
            }
        }
        if intId > 0.u64 then {
            kiter: iks.iterate
            for k3: kiter loop {
                kc: k3
                setv: intId
                st.typing.nodeType.set key: kc value: setv
            }
        } else {
        }
        if floatId > 0.u64 then {
            fiter: fks.iterate
            for k4: fiter loop {
                kc2: k4
                setv2: floatId
                st.typing.nodeType.set key: kc2 value: setv2
            }
        } else {
        }
    } else {
    }
}

# isBinopNode -- kind test without narrowing (the caller keeps the Node handle).
isBinopNode: function {n: Node} out bool is {
    match (
        n
    ) case binop then {
        return true
    } else {
        return false
    }
}

# constantOperandType -- type one operand of a unit-level constant expression,
# stamping as it walks: a numeric literal wears the pseudo id (folded to its
# visible default later), a name reads an already-materialised constant from
# resolved (body order), and a binop takes the first concretely-typed operand
# (else the literal pseudo). 0 = not a constant shape.
constantOperandType: function {ty: ztyping.ZTyping mainName: StringView n: Node} out u64 is {
    match (
        n
    ) case expression then {
        return (constantOperandType ty: ty mainName: mainName n: n.expression)
    } case atomid then {
        result: 0.u64
        if (isNumericLiteralName name: n.name.stringview) then {
            if (isFloatLiteralName name: n.name.stringview) then {
                result = literalFloatId
            } else {
                result = literalIntId
            }
        } else {
            ro: lookupTyperef resolved: ty.resolved mainName: mainName base: n.name.stringview
            match (
                ro
            ) case some then {
                result = ro
            } case none then {
            }
        }
        if result > 0.u64 then {
            seto: result
            ty.nodeType.set key: n.nodeid.u64 value: seto
        } else {
        }
        return result
    } case binop then {
        lt: constantOperandType ty: ty mainName: mainName n: n.lhs
        rt: constantOperandType ty: ty mainName: mainName n: n.rhs
        result: lt
        if lt == 0.u64 then {
            result = rt
        } else {
        }
        if lt == literalIntId then {
            if rt > 0.u64 when rt != literalIntId when rt != literalFloatId then {
                result = rt
            } else {
            }
        } else {
        }
        if lt == literalFloatId then {
            if rt > 0.u64 when rt != literalIntId when rt != literalFloatId then {
                result = rt
            } else {
            }
        } else {
        }
        if result > 0.u64 then {
            setb: result
            ty.nodeType.set key: n.nodeid.u64 value: setb
        } else {
        }
        return result
    } else {
        return 0.u64
    }
}

# resolveConstantDef -- one definition: an (expression-wrapped) numeric-literal
# atomid is a unit constant. Record resolved[unit.name] as the literal's concrete
# default (i64 / f64 -- both pre-demanded by seedSystemDemands). The definition's
# own nodes stay unstamped: the oracle's stamps there carry its unregistered
# literal pseudo-type (NULL in the dump), invisible to every projection.
resolveConstantDef: function {ty: ztyping.ZTyping mainName: StringView defName: StringView defn: Node} is {
    match (
        defn
    ) case expression then {
        resolveConstantDef ty: ty mainName: mainName defName: defName defn: defn.expression
    } case atomid then {
        if (isNumericLiteralName name: defn.name.stringview) then {
            base: "i64"
            if (isFloatLiteralName name: defn.name.stringview) then {
                base = "f64"
            } else {
            }
            tOpt: lookupTyperef resolved: ty.resolved mainName: mainName base: base
            match (
                tOpt
            ) case some then {
                k: "\{mainName}.\{defName}".string
                setv: tOpt
                ty.resolved.set key: k value: setv
            } case none then {
            }
        } else {
        }
    } else {
        if (isBinopNode n: defn) then {
            # A constant expression (`COMBINED: OFFSET + SCALE`): the operand
            # walk stamps the refs and the binop; a literal result materialises
            # to its default, a concrete one (an already-materialised constant)
            # keeps it.
            bt: constantOperandType ty: ty mainName: mainName n: defn
            base2: ""
            if bt == literalIntId then {
                base2 = "i64"
            } else {
            }
            if bt == literalFloatId then {
                base2 = "f64"
            } else {
            }
            if base2.length > 0.u64 then {
                mOpt: lookupTyperef resolved: ty.resolved mainName: mainName base: base2
                match (
                    mOpt
                ) case some then {
                    k2: "\{mainName}.\{defName}".string
                    setv2: mOpt
                    ty.resolved.set key: k2 value: setv2
                } case none then {
                }
            } else {
                if bt > 0.u64 then {
                    k3: "\{mainName}.\{defName}".string
                    setv3: bt
                    ty.resolved.set key: k3 value: setv3
                } else {
                }
            }
        } else {
        }
    }
}

resolveConstantDefsInUnit: function {ty: ztyping.ZTyping mainName: StringView unitdef: Node} is {
    match (
        unitdef
    ) case unitdef then {
        biter: unitdef.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                defName: unitLabel o: bm.name
                if defName.length > 0.u64 then {
                    resolveConstantDef ty: ty mainName: mainName defName: defName.stringview defn: bm.operation
                } else {
                }
            } else {
            }
        }
    } else {
    }
}

# resolveConstantDefs -- under the full driver, materialise the main unit's numeric
# constant definitions the way the oracle resolves them on first name lookup. Runs
# post-demand so the numeric defaults are already in resolved.
resolveConstantDefs: function {ty: ztyping.ZTyping program: Node} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        uiter: program.units.iterate
        for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                nm: unitLabel o: u.name
                if nm.stringview == mainName then {
                    resolveConstantDefsInUnit ty: ty mainName: mainName unitdef: u.operation
                } else {
                }
            } else {
            }
        }
    } else {
    }
}

typecheck: function {program: Node reg: ztypes.ZTypeRegistry.take full: bool} out zenv.ZSymbolTable is {
    ty: ztyping.newTyping
    # null is the reference's first registered type.
    reg.newType name: "null" typetype: ztypes.ztypetype.NULL
    registerAndResolveMain ty: ty reg: reg program: program full: full
    resolveMainUnitInstantiations ty: ty reg: reg program: program
    if full then {
        scanMainBodyCalls reg: reg program: program
    } else {
    }
    resolveCrossUnitDemand ty: ty reg: reg program: program full: full
    if full then {
        resolveConstantDefs ty: ty program: program
    } else {
    }
    stampTyperefs ty: ty program: program
    st: zenv.newSymbolTable reg: reg typing: ty
    if full then {
        resolveMonos st: st program: program
        checkBodies st: st program: program
        foldLiteralStamps st: st program: program
    } else {
    }
    return st
}

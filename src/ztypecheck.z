                # A no-`out` METHOD auto-call resolves to null (the
                # reference's auto-call rule for out-less methods). Non-
                # function members (field shells) keep their re-resolved
                # type.
                if (st.reg.typetypeOf typeId: mo) == ztypes.ztypetype.functionType then {
                    # an unregistered shell id: the stamp never joins the
                    # dump (the reference's t_null carries no unit either)
                    result = st.reg.allocType
                }
            }
        }
        if (st.typing.isChildPrivate pool: ast.names parentTypeId: bt name: cn.stringview) then {
            baseN9: ast.nodes.get i: (dp.parent - 1).u64
            if (baseIsPrivateCapable :st :ast :bt baseNode: baseN9) == false then {
                cnidP9: nodeId n: (ast.nodes.get i: (dp.child - 1).u64)
                cnlnP9: nodeLine n: (ast.nodes.get i: (dp.child - 1).u64)
                cnclP9: nodeCol n: (ast.nodes.get i: (dp.child - 1).u64)
                btNmP9: typeNameOf :st tid: bt
                cnCp9: cn.copy
                pmsgP9: "'\{cnCp9}' is not public on type '\{btNmP9}'"
                (addErrorH
                    :st
                    nodeid: cnidP9
                    lineno: cnlnP9
                    colno: cnclP9
                    e: zast.err.notPublic
                    msg: pmsgP9
                    note: "".string
                    hint: "".string
                    width: cn.length.u32.orPanic
                )
            }
        }
        stampGate :st nid: dp.nodeid tid: result
        return result
    } case none then {
        if (st.reg.typetypeOf typeId: bt) == ztypes.ztypetype.genericParam then {
            # `.copy` is an ownership primitive, not a constrained member:
            # every instantiation copies, so a generic-param receiver types
            # it t -> t (the per-instance clone emits the concrete copy).
            if cn.stringview == "copy" then {
                stampGate :st nid: dp.nodeid tid: bt
                return bt
            }
            btn9x: typeNameOf :st tid: bt
            mgp9: "type parameter '\{btn9x}' has no member '\{cn}' (its constraint provides none)"
            (addError
                :st
                nodeid: dp.nodeid
                lineno: dp.lineno
                colno: dp.colno
                e: zast.err.genericError
                msg: mgp9
            )
        }
        # `.copy` on a receiver with no copy member is a hard error: deep
        # copy exists for strings, containers, and generic type parameters
        # only. Without this the emitter has no clone to emit and the
        # miss would surface as invalid C.
        if cn.stringview == "copy" when (st.reg.typetypeOf typeId: bt) != ztypes.ztypetype.genericParam then {
            btnCp9: typeNameOf :st tid: bt
            bttCp9: st.reg.typetypeOf typeId: bt
            isValCp9: false
            if bttCp9 == ztypes.ztypetype.recordType then isValCp9 = true
            if bttCp9 == ztypes.ztypetype.variantType then isValCp9 = true
            if bttCp9 == ztypes.ztypetype.facetType then isValCp9 = true
            mCp9: "type '\{btnCp9}' has no '.copy': deep copy of user-defined reftypes is not implemented (move with '.take', or copy field-by-field)"
            if isValCp9 then {
                mCp9 = "type '\{btnCp9}' has no '.copy': valtypes copy by assignment (drop '.copy')"
            }
            (addError
                :st
                nodeid: dp.nodeid
                lineno: dp.lineno
                colno: dp.colno
                e: zast.err.typeError
                msg: mCp9
            )
            return 0
        }
        # unknown member on a concrete user-defined type: hard error.
        # Shells (no defining unit), stdlib/native types, and template
        # walks stay silent -- their members resolve through later
        # passes or per-instantiation.
        bttMm9: st.reg.typetypeOf typeId: bt
        isConcMm9: false
        if bttMm9 == ztypes.ztypetype.recordType then isConcMm9 = true
        if bttMm9 == ztypes.ztypetype.classType then isConcMm9 = true
        if bttMm9 == ztypes.ztypetype.unionType then isConcMm9 = true
        if bttMm9 == ztypes.ztypetype.variantType then isConcMm9 = true
        if isConcMm9 when (memberStrictType :st :bt) then {
            if st.typing.suppressParamStamps == false then {
                # demand-order safety: walk the type's methods once and
                # re-probe before declaring the member unknown
                btnMm0: typeNameOf :st tid: bt
                maybeWalkMethods :st :unitName :ast :unitBody name: btnMm0.stringview
                moMm9: st.typing.childOfId parentTypeId: bt nameId: cnId9
                stillMiss9: true
                match (
                    moMm9
                ) case some then {
                    stillMiss9 = false
                } case none then null
                # a numeric-type-named member on a numeric base is a width
                # conversion; the identity form (x.T where x is already T) is
                # not a declared child but is a valid (redundant) cast.
                if stillMiss9 then {
                    baseNum9: false
                    if (isNumericTypeName name: btnMm0.stringview) then baseNum9 = true
                    if btnMm0.stringview == "literal_int" then baseNum9 = true
                    if btnMm0.stringview == "literal_float" then baseNum9 = true
                    if (isNumericTypeName name: cn.stringview) when baseNum9 then stillMiss9 = false
                }
                if stillMiss9 then {
                    btnMm9: typeNameOf :st tid: bt
                    cnMm9: cn.copy
                    mMm9: "type '\{btnMm9}' has no member '\{cnMm9}'"
                    sugMm9: suggestSimilar :ast :st parentTypeId: bt name: cn.stringview
                    hMm9: String
                    if sugMm9.length > 0 then {
                        sgMm9: sugMm9.copy
                        hhMm9: "did you mean '\{sgMm9}'?"
                        hMm9 = hhMm9
                    }
                    cnidMm9: nodeId n: (ast.nodes.get i: (dp.child - 1).u64)
                    cnlnMm9: nodeLine n: (ast.nodes.get i: (dp.child - 1).u64)
                    cnclMm9: nodeCol n: (ast.nodes.get i: (dp.child - 1).u64)
                    (addErrorH
                        :st
                        nodeid: cnidMm9
                        lineno: cnlnMm9
                        colno: cnclMm9
                        e: zast.err.typeError
                        msg: mMm9
                        note: "".string
                        hint: hMm9
                        width: cn.length.u32.orPanic
                    )
                }
            }
        }
        return 0
    }
}

checkAtomid: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    node: zast.AtomIdData
} out u64 is {
    ndNm9: ast.names.texts.get i: (node.name - 1).u64
    result: u64
    vtOpt: st.lookup name: ndNm9.stringview
    match (
        vtOpt
    ) case some then {
        result = vtOpt
        # break/continue diverge: the atom's value is never (the scope
        # entry stays the unregistered placeholder).
        isBrk9: false
        if node.name == wkBreak then isBrk9 = true
        if node.name == wkContinue then isBrk9 = true
        if isBrk9 then {
            result = (optU64Or
                o: (walkLookupTyperef
                    :ast
                    ty: st.typing
                    reg: st.reg
                    currentUnit: unitName
                    base: "never"
                )
                d: result
            )
        }
        stampGate :st nid: node.nodeid tid: result
        # atom-use variable id: stamped even during template walks (variable
        # ids are valid there; stampGate only gates GENERIC_PARAM types)
        avo9: st.lookupVarId name: ndNm9.stringview
        match (
            avo9
        ) case some then {
            setav9: avo9
            st.typing.atomVariableId.set key: node.nodeid.u64 value: setav9
        } case none then null
    } case none then {
        if node.name == wkReturn then {
            mrt9: st.typing.currentReturnTypeId
            if mrt9 > 0 then {
                mtt9: st.reg.typetypeOf typeId: mrt9
                isVoidRet9: false
                if mtt9 == ztypes.ztypetype.nullType then isVoidRet9 = true
                if mtt9 == ztypes.ztypetype.neverType then isVoidRet9 = true
                if (isVoidRet9) == false then {
                    rtn9: typeNameOf :st tid: mrt9
                    rtnc9: rtn9.copy
                    mm9: "missing return value: function expects '\{rtnc9}'"
                    en6: String
                    eh6: String
                    (addErrorH
                        :st
                        nodeid: node.nodeid
                        lineno: node.lineno
                        colno: node.colno
                        e: zast.err.typeError
                        msg: mm9
                        note: en6
                        hint: eh6
                        width: 6
                    )
                }
            }
        }
        if (st.isTakenName name: ndNm9.stringview) then {
            nmc9: ndNm9.copy
            eh5: String
            m5: "cannot use '\{nmc9}' after ownership transfer"
            nt5: "this name no longer owns a value; it was moved earlier".string
            (addErrorH
                :st
                nodeid: node.nodeid
                lineno: node.lineno
                colno: node.colno
                e: zast.err.ownerError
                msg: m5
                note: nt5
                hint: eh5
                width: ndNm9.length.u32.orPanic
            )
            return 0
        }
        if (isNumericLiteralName name: ndNm9.stringview) then {
            if (isFloatLiteralName name: ndNm9.stringview) then {
                result = literalFloatId
            } else {
                result = literalIntId
            }
            setl: result
            st.typing.nodeType.set key: node.nodeid.u64 value: setl
        } else {
            fo: (walkLookupTyperef
                :ast
                ty: st.typing
                reg: st.reg
                currentUnit: unitName
                base: ndNm9.stringview
            )
            match (
                fo
            ) case some then {
                result = fo
                # A bare no-arg non-generic FUNCTION name is a call: the
                # value is its return (an unregistered shell when out-less).
                isAutoFn: false
                {
                    fz9: st.reg.typeById.get key: fo
                    match (
                        fz9
                    ) case some then {
                        if fz9.typetype == ztypes.ztypetype.functionType then {
                            if (fz9.isgeneric) == false then isAutoFn = true
                        }
                    } case none then null
                }
                if isAutoFn when (st.typing.suppressFnAutoCall) == false then {
                    if (fnAutoCallable :ast :st mid: fo) == false then {
                        isAutoFn = false
                        (bareFnRefError
                            :ast
                            :st
                            nodeid: node.nodeid
                            lineno: node.lineno
                            colno: node.colno
                            width: ndNm9.length.u32.orPanic
                            fid: fo
                        )
                    }
                } else {
                    isAutoFn = false
                }
                if isAutoFn then {
                    ro9: methodReturnOf :st mid: fo
                    match (
                        ro9
                    ) case some then {
                        result = ro9
                    } case none then {
                        result = st.reg.allocType
                    }
                }
                if (st.typing.suppressBareCtor) == false then {
                    # only an atom NAMING the type is a bare construction; a
                    # value alias typed as it (true: bool.true) is a value use
                    tnq9: typeNameOf :st tid: fo
                    if tnq9.stringview == ndNm9.stringview then {
                        if (isImplicitZeroCreateTid :ast :st tid: fo) then {
                            icv9: fo
                            st.typing.implicitCreate.set key: node.nodeid.u64 value: icv9
                        } else {
                            checkBareTypeConstruction :st :unitName :ast :node tid: fo
                        }
                    }
                }
                setu: result
                st.typing.nodeType.set key: node.nodeid.u64 value: setu
                # atom-use unit-def id: the DEF's tid (nodeType carries the
                # auto-call RETURN type above, which is not the referent)
                setud9: fo
                st.typing.atomUnitDefId.set key: node.nodeid.u64 value: setud9
                maybeWalkMethods :st :unitName :ast :unitBody name: ndNm9.stringview
            } case none then null
        }
    }
    return result
}

# isFloatLiteralName -- a numeric-literal atom carrying a decimal point (the
# float default; hex/binary stay integer literals).
isFloatLiteralName: function {name: StringView} out bool is {
    i: u64
    n: name.length
    for i < n loop {
        b: name.byteAt i
        match (
            b
        ) case some then {
            if b == 46 then return true
        } case none then null
        i = i + 1
    }
    return false
}

# isComparisonOp -- a binop operator whose result is bool (not the operand type).
isComparisonOp: function {name: StringView} out bool is {
    if name == "<" then return true
    if name == ">" then return true
    if name == "<=" then return true
    if name == ">=" then return true
    if name == "==" then return true
    if name == "!=" then return true
    return false
}

# ArmPredFact -- one bare arm predicate recognized in an if condition: the
# subject variable, the arm, the sum type, and whether the condition form
# is negated (`(x.a) == false` / trailing `.false`).
ArmPredFact: class {
    subject: String
    armName: String
    fullTid: u64
    negated: bool
}

# predDottedCore -- an ArmPredFact from an exploded predicate dotted node
# (`x.a` carrying a dpArmPredicate stamp on a non-bool receiver with a
# bare-variable subject), or none.
predDottedCore: function {ast: Ast
    st: zenv.ZSymbolTable
    nid: u64
    parent: Node
    childName: StringView
    boolId: u64
    negated: bool
} out Option ArmPredFact is {
    ptid9: optU64Or o: (st.typing.dpArmPredicate.get key: nid) d: 0
    if ptid9 == 0 then return (Option.none ArmPredFact)
    if ptid9 == boolId then return (Option.none ArmPredFact)
    sn9: bareAtomName :ast n: parent
    if sn9.length == 0 then return (Option.none ArmPredFact)
    if childName.length == 0 then return (Option.none ArmPredFact)
    an9: childName.string
    return (Option.some (ArmPredFact
        subject: sn9
        armName: an9
        fullTid: ptid9
        :negated
    ))
}

# predDottedFact -- predDottedCore over a Node (expression wrappers peeled).
predDottedFact: function {ast: Ast
    st: zenv.ZSymbolTable
    n: Node
    boolId: u64
    negated: bool
} out Option ArmPredFact is {
    match (
        n
    ) case expression then {
        return (predDottedFact
            :ast
            :st
            n: (ast.nodes.get i: (n.expression - 1).u64)
            :boolId
            :negated
        )
    } case dottedpath then {
        cnc9: atomName :ast n: (ast.nodes.get i: (n.child - 1).u64)
        return (predDottedCore
            :ast
            :st
            nid: n.nodeid.u64
            parent: (ast.nodes.get i: (n.parent - 1).u64)
            childName: cnc9.stringview
            :boolId
            :negated
        )
    } else {
        return (Option.none ArmPredFact)
    }
}

# predFactOf -- recognize an if-condition operation as an arm predicate:
# bare `x.a`, trailing-bool `x.a.true` / `x.a.false`, or the comparison
# `(x.a) == true` / `(x.a) == false`. none otherwise.
predFactOf: function {
    ast: Ast
    st: zenv.ZSymbolTable
    n: Node
    boolId: u64
} out Option ArmPredFact is {
    match (
        n
    ) case expression then {
        return (predFactOf :ast :st n: (ast.nodes.get i: (n.expression - 1).u64) :boolId)
    } case dottedpath then {
        cn9: atomName :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if cn9.stringview == "true" then return (predDottedFact
            :ast
            :st
            n: (ast.nodes.get i: (n.parent - 1).u64)
            :boolId
            negated: false
        )
        if cn9.stringview == "false" then return (predDottedFact
            :ast
            :st
            n: (ast.nodes.get i: (n.parent - 1).u64)
            :boolId
            negated: true
        )
        return (predDottedCore
            :ast
            :st
            nid: n.nodeid.u64
            parent: (ast.nodes.get i: (n.parent - 1).u64)
            childName: cn9.stringview
            :boolId
            negated: false
        )
    } case binop then {
        opn9: bareAtomName :ast n: (ast.nodes.get i: (n.operator - 1).u64)
        if opn9.stringview == "==" then {
            ln9: bareAtomName :ast n: (ast.nodes.get i: (n.lhs - 1).u64)
            rn9: bareAtomName :ast n: (ast.nodes.get i: (n.rhs - 1).u64)
            if rn9.stringview == "true" then return (predDottedFact
                :st
                :ast
                n: (ast.nodes.get i: (n.lhs - 1).u64)
                :boolId
                negated: false
            )
            if rn9.stringview == "false" then return (predDottedFact
                :st
                :ast
                n: (ast.nodes.get i: (n.lhs - 1).u64)
                :boolId
                negated: true
            )
            if ln9.stringview == "true" then return (predDottedFact
                :st
                :ast
                n: (ast.nodes.get i: (n.rhs - 1).u64)
                :boolId
                negated: false
            )
            if ln9.stringview == "false" then return (predDottedFact
                :st
                :ast
                n: (ast.nodes.get i: (n.rhs - 1).u64)
                :boolId
                negated: true
            )
        }
        return (Option.none ArmPredFact)
    } else {
        return (Option.none ArmPredFact)
    }
}

# shadowCollapseIfSingle -- when exclusions have collapsed `name` to a
# single PAYLOAD arm (the sidecar form), upgrade to the shadow narrowing:
# the bare name becomes the payload, exactly as in a match arm. A null
# payload keeps the outer type (nothing to read). Condition-derived
# call sites only -- construction narrowing never routes through here.
shadowCollapseIfSingle: function {ast: Ast st: zenv.ZSymbolTable name: StringView fullTid: u64} is {
    arm9: st.narrowedArmOf :name fullTypeId: fullTid
    if arm9.length == 0 then return
    po9: st.typing.childOf pool: ast.names parentTypeId: fullTid name: arm9.stringview
    match (
        po9
    ) case some then {
        if (st.reg.typetypeOf typeId: po9) == ztypes.ztypetype.nullType then return
        (st.narrow
            pool: ast.names
            :name
            toTypeId: po9
            subtypeName: arm9.stringview
            shadow: true
        )
    } case none then null
}

# applyPredFact -- record one predicate fact on its subject in the current
# branch scope. `holds` is the branch's knowledge of the condition: true
# on the then path, false on else/later-clause paths. A holding positive
# (or failing negated) fact SHADOW-narrows to the arm (the bare name is
# the payload); the opposite excludes it, and an exclusion that leaves a
# single payload arm collapses to the same shadow form.
applyPredFact: function {ast: Ast st: zenv.ZSymbolTable f: ArmPredFact holds: bool} is {
    doNarrow9: false
    if holds when (f.negated) == false then doNarrow9 = true
    if (holds) == false when f.negated then doNarrow9 = true
    if doNarrow9 then {
        po9: st.typing.childOf pool: ast.names parentTypeId: f.fullTid name: f.armName.stringview
        match (
            po9
        ) case some then {
            (st.narrow
                pool: ast.names
                name: f.subject.stringview
                toTypeId: po9
                subtypeName: f.armName.stringview
                shadow: true
            )
        } case none then null
    } else {
        (st.exclude
            pool: ast.names
            name: f.subject.stringview
            subtypeName: f.armName.stringview
            fullTypeId: f.fullTid
        )
        shadowCollapseIfSingle :ast :st name: f.subject.stringview fullTid: f.fullTid
    }
}

# postGuardRecord -- record the post-guard narrowing of `subject` under the
# guarding statement's node id when the applied facts left it SHADOW-
# narrowed to a payload arm: the emitter aliases the bare name for the
# rest of the enclosing block.
postGuardRecord: function {
    ast: Ast
    st: zenv.ZSymbolTable
    stmtNid: u32
    subject: StringView
    fullTid: u64
} is {
    if (st.isShadowNarrowed name: subject) == false then return
    arm9: st.getSubtypeName name: subject
    if arm9.length == 0 then return
    po9: st.typing.childOf pool: ast.names parentTypeId: fullTid name: arm9.stringview
    match (
        po9
    ) case some then {
        if (st.reg.typetypeOf typeId: po9) == ztypes.ztypetype.nullType then return
        sn9: subject.string
        st.typing.postGuardName.set key: stmtNid.u64 value: sn9
        rv9: ztypes.mangleVarName name: subject
        st.typing.postGuardRecv.set key: stmtNid.u64 value: rv9
        st.typing.postGuardTid.set key: stmtNid.u64 value: fullTid
        av9: arm9.copy
        st.typing.postGuardArm.set key: stmtNid.u64 value: av9
    } case none then null
}

# checkClause -- walk one if-clause: its condition(s) (namedoperation-wrapped),
# then this clause's predicate facts as condition-true knowledge (appended to
# factsOut), then its then-statement block.
checkClause: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    clause: Node
    factsOut: List ArmPredFact
    boolId: u64
} out u64 is {
    match (
        clause
    ) case ifclause then {
        with coiter: clause.conditions.iterate do for condId9: coiter loop {
            cond: ast.nodes.get i: (condId9 - 1).u64
            match (
                cond
            ) case namedoperation then {
                ctv9: (checkValue
                    :st
                    :unitName
                    :ast
                    :unitBody
                    node: (ast.nodes.get i: (cond.operation - 1).u64)
                )
                # An if-condition must be a boolean. A non-bool value (a
                # resultval, an aggregate, a raw numeric) is a type error rather
                # than invalid C. Bare arm predicates (`o.none`, `b.false`) type
                # as bool already; a diverging never-typed condition is allowed.
                if ctv9 > 0 when boolId > 0 when ctv9 != boolId then {
                    ctt9: st.reg.typetypeOf typeId: ctv9
                    if ctt9 != ztypes.ztypetype.neverType then {
                        conode9: ast.nodes.get i: (cond.operation - 1).u64
                        ctnm9: typeNameOf :st tid: ctv9
                        cmsg9: "condition must be bool, got '\{ctnm9}'"
                        (addError
                            :st
                            nodeid: (nodeId n: conode9)
                            lineno: (nodeLine n: conode9)
                            colno: (nodeCol n: conode9)
                            e: zast.err.typeError
                            msg: cmsg9
                        )
                    }
                }
            } else null
        }
        with cfit9: clause.conditions.iterate do for cnd9Id9: cfit9 loop {
            cnd9: ast.nodes.get i: (cnd9Id9 - 1).u64
            match (
                cnd9
            ) case namedoperation then {
                fo9: predFactOf :ast :st n: (ast.nodes.get i: (cnd9.operation - 1).u64) :boolId
                match (
                    fo9
                ) case some then {
                    factsOut.append fo9.take
                } case none then null
            } else null
        }
        with afit9: factsOut.iterate do for af9: afit9 loop (applyPredFact
            :ast
            :st
            f: af9
            holds: true
        )
        cs9: ast.nodes.get i: (clause.statement - 1).u64
        checkStatement :st :unitName :ast :unitBody block: cs9
        return (lastStmtType :st :ast block: cs9)
    } else {
        return 0
    }
}

# lastStmtType -- the resolved type id of a statement block's last statement
# (the value of a do-block), or 0 when empty/untyped.
lastStmtType: function {st: zenv.ZSymbolTable ast: Ast block: Node} out u64 is {
    result: u64
    match (
        block
    ) case statement then {
        ne: block.statements.length
        if ne > 0 then {
            lastId9: block.statements.get i: (ne - 1)
            last: ast.nodes.get i: (lastId9 - 1).u64
            match (
                last
            ) case statementline then {
                result = optU64Or o: (st.typing.nodeType.get key: last.nodeid.u64) d: result
            } else null
        }
    } else {
        # An expression-shaped body (a bare `then 10` branch) carries its
        # value on its own node.
        bid9: nodeId n: block
        if bid9 > 0 then result = optU64Or o: (st.typing.nodeType.get key: bid9.u64) d: result
    }
    return result
}

# materialiseLiteral -- fold a literal pseudo-type id to its concrete default
# (i64 / f64); concrete ids pass through.
materialiseLiteral: function {
    ast: Ast
    st: zenv.ZSymbolTable
    unitName: StringView
    t: u64
} out u64 is {
    base: ""
    if t == literalIntId then base = "i64"
    if t == literalFloatId then base = "f64"
    if base.length == 0 then return t
    return (optU64Or
        o: (walkLookupTyperef :ast ty: st.typing reg: st.reg currentUnit: unitName :base)
        d: t
    )
}

# checkAssignment -- a local binding `name: value`: walk the value, materialise a
# literal-typed value to its concrete default (the binding takes i64, unlike a
# for-loop binding which keeps the pseudo id), define the local (owned for a plain
# value), and stamp the assignment node + def-variable.
checkAssignment: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    asgn: zast.AssignmentData
} is {
    drainPendingBorrow :st
    av9: ast.nodes.get i: (asgn.value - 1).u64
    vt: checkValue :st :unitName :ast :unitBody node: av9
    if vt == 0 then {
        ubn9: unresolvedBareCallable :ast :st :unitName n: av9
        if ubn9.length > 0 then {
            ubm9: "Unknown reference '\{ubn9}'"
            ubid9: nodeId n: av9
            ubln9: nodeLine n: av9
            ubcl9: nodeCol n: av9
            (addError
                :st
                nodeid: ubid9
                lineno: ubln9
                colno: ubcl9
                e: zast.err.badReference
                msg: ubm9
            )
        }
    }
    mvt: materialiseLiteral :ast :st :unitName t: vt
    vt = mvt
    if vt > 0 when (st.reg.typetypeOf typeId: vt) == ztypes.ztypetype.nullType then {
        m1: "'null' cannot be used as a value — null must be wrapped in a union or variant (eg. option.none)".string
        vln1: nodeLine n: av9
        vcl1: nodeCol n: av9
        vid1: nodeId n: av9
        en1: String
        eh1: String
        (addErrorH
            :st
            nodeid: vid1
            lineno: vln1
            colno: vcl1
            e: zast.err.typeError
            msg: m1
            note: en1
            hint: eh1
            width: 4
        )
        return
    }
    if vt > 0 then {
        bsrc: (List String)
        takePendingBorrow :st dst: bsrc
        own: ztypes.zownership.owned
        if bsrc.length > 0 when (typeIsReftype :st tid: vt) then own = ztypes.zownership.borrowed
        v: st.reg.newVariable ztypeId: vt ownership: own
        vid: v.variableId
        if own == ztypes.zownership.borrowed then {
            r0: bsrc.get i: 0
            bo: r0.copy
            v.borrowOrigin = (Option.some bo)
        }
        st.defineVar name: asgn.name.stringview var: v
        vid2: vid
        st.typing.defVariableId.set key: asgn.nodeid.u64 value: vid2
        st.typing.variableOrigin.set key: vid2 value: false
        setk: vt
        st.typing.nodeType.set key: asgn.nodeid.u64 value: setk
        rn5: bareAtomName :ast n: av9
        if rn5.length > 0 when (typeIsReftype
            :st
            tid: vt
        ) when (st.reg.hasDestructorName typeId: vt) then {
            vo5: st.lookupVarId name: rn5.stringview
            match (
                vo5
            ) case some then {
                if (isBorrowedVar :st vid: vo5) then {
                    rnc5: rn5.copy
                    mb5: "Cannot move borrowed variable '\{rnc5}' into an owned binding — borrowed names stay bound to their source for the full scope"
                    (addError
                        :st
                        nodeid: asgn.nodeid
                        lineno: asgn.lineno
                        colno: asgn.colno
                        e: zast.err.ownerError
                        msg: mb5
                    )
                } else {
                    st.invalidate name: rn5.stringview loc: (optionval.none ztypes.zsrcpos)
                }
            } case none then null
        }
        if own == ztypes.zownership.borrowed then {
            lfsA9: isViewFamilyTid :ast :st tid: vt
            if st.typing.pendingBorrowShared then lfsA9 = true
            st.typing.pendingBorrowShared = false
            (installBorrowLocks
                :st
                src: bsrc
                :vid
                leafShared: lfsA9
                nodeid: asgn.nodeid
                lineno: asgn.lineno
                colno: asgn.colno
            )
        }
        # Binding a tagged-subtype construction narrows the name to the
        # constructed arm (assignment-based narrowing: the overlay keeps the
        # subject's type with the narrowed-subtype sidecar).
        ucArm: unionCreateArmName :ast :st n: av9
        if ucArm.length > 0 then {
            (st.narrow
                pool: ast.names
                name: asgn.name.stringview
                toTypeId: vt
                subtypeName: ucArm.stringview
                shadow: false
            )
        }
    }
}

# checkReassignment -- `lhs = value`: resolve the target path and the value, then
# reset any narrowing on a bare-name target (appends a non-definition overlay
# entry, mirroring _check_reassignment_inner's reset_narrowing).
checkReassignment: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    rasgn: zast.ReassignmentData
} is {
    st.typing.inAssignTarget = true
    tpn9: ast.nodes.get i: (rasgn.topath - 1).u64
    rvn9: ast.nodes.get i: (rasgn.value - 1).u64
    lvt: checkValue :st :unitName :ast :unitBody node: tpn9
    st.typing.inAssignTarget = false
    rvt: checkValue :st :unitName :ast :unitBody node: rvn9
    mrv0: materialiseLiteral :ast :st :unitName t: rvt
    if mrv0 > 0 when (st.reg.typetypeOf typeId: mrv0) == ztypes.ztypetype.nullType then {
        m0n: "'null' cannot be used as a value — null must be wrapped in a union or variant (eg. option.none)".string
        vln0: nodeLine n: rvn9
        vcl0: nodeCol n: rvn9
        vid0: nodeId n: rvn9
        en0: String
        eh0: String
        (addErrorH
            :st
            nodeid: vid0
            lineno: vln0
            colno: vcl0
            e: zast.err.typeError
            msg: m0n
            note: en0
            hint: eh0
            width: 4
        )
        return
    }
    # A typeof-placeholder field resolves at its first write: swap the
    # field child to the RHS's type and restamp the target path.
    if lvt > 0 when rvt > 0 then {
        tso: st.typing.typeofShell.get key: lvt
        match (
            tso
        ) case some then {
            troot: methodReceiverRoot :ast n: tpn9
            if troot.length > 0 then {
                tto: st.lookup name: troot.stringview
                match (
                    tto
                ) case some then {
                    tfn: dottedChildName :ast n: tpn9
                    if tfn.length > 0 then {
                        mrvt: materialiseLiteral :ast :st :unitName t: rvt
                        (st.typing.setChildId
                            parentTypeId: tto
                            nameId: (zast.poolFind pool: ast.names text: tfn.stringview).u64
                            childTypeId: mrvt
                        )
                        settof: mrvt
                        st.typing.nodeType.set key: tso.u64 value: settof
                        tpid: nodeId n: tpn9
                        if tpid > 0 then {
                            settp: mrvt
                            st.typing.nodeType.set key: tpid.u64 value: settp
                        }
                    }
                } case none then null
            }
        } case none then null
    }
    # A literal RHS at a concretely-typed target coerces: restamp the RHS's
    # innermost node (wrappers derive through the dump's descent). A
    # literal-typed target (a literal-init loop binding) keeps the pseudo.
    if lvt > 0 when rvt > 0 when (isLiteralTypeId :st tid: rvt) then {
        if (isLiteralTypeId :st tid: lvt) == false then {
            iid: innermostNodeId :ast n: rvn9
            if iid > 0 then {
                setc: lvt
                st.typing.nodeType.set key: iid.u64 value: setc
            }
        }
    }
    # The RHS value must be assignable to the target's declared type. Numeric
    # coercion (a literal, or a concrete-to-concrete numeric) is permitted here
    # exactly as at a call argument; a non-numeric type mismatch -- a resultval
    # where a scalar is expected, a String into a numeric field -- is an error
    # rather than invalid C downstream.
    if lvt > 0 when rvt > 0 then {
        # Validate against the target's declared type: a narrowed bare-name
        # target accepts a fresh value of its whole type (reassignment resets
        # narrowing). A field target has no bare name and keeps lvt.
        chkT9: lvt
        {
            nmC9: atomName :ast n: tpn9
            if nmC9.length > 0 then {
                dtoC9: st.declaredTypeOf name: nmC9.stringview
                match (
                    dtoC9
                ) case some then {
                    chkT9 = dtoC9
                } case none then null
            }
        }
        if (typesCompatible :ast :st :unitName a: rvt b: chkT9) == false then {
            skipR9: false
            if (isNumericTid
                :ast
                ty: st.typing
                reg: st.reg
                tid: rvt
            ) when (isNumericTid :ast ty: st.typing reg: st.reg tid: chkT9) then skipR9 = true
            lttR9: st.reg.typetypeOf typeId: chkT9
            if lttR9 == ztypes.ztypetype.protocolType then skipR9 = true
            if lttR9 == ztypes.ztypetype.facetType then skipR9 = true
            if lttR9 == ztypes.ztypetype.genericParam then skipR9 = true
            if lttR9 == ztypes.ztypetype.functionType then skipR9 = true
            tsoR9: st.typing.typeofShell.get key: chkT9
            if tsoR9.some then skipR9 = true
            if (skipR9) == false then {
                enR9: typeNameOf :st tid: chkT9
                anR9: typeNameOf :st tid: rvt
                encR9: enR9.copy
                ancR9: anR9.copy
                mmR9: "cannot assign value of type '\{ancR9}' to '\{encR9}' target"
                (addError
                    :st
                    nodeid: rasgn.nodeid
                    lineno: rasgn.lineno
                    colno: rasgn.colno
                    e: zast.err.callError
                    msg: mmR9
                )
            }
        }
    }
    nm: atomName :ast n: tpn9
    if nm.length > 0 then {
        st.resetNarrowing name: nm.stringview
        nvo9: st.lookupVarId name: nm.stringview
        match (
            nvo9
        ) case some then {
            if (isBorrowedVar :st vid: nvo9) then {
                nmc9: nm.copy
                ma9: "Cannot reassign borrowed variable '\{nmc9}'"
                ha9: "borrowed names are bound for their full scope; shadow in an inner scope instead".string
                ena9: String
                (addErrorH
                    :st
                    nodeid: rasgn.nodeid
                    lineno: rasgn.lineno
                    colno: rasgn.colno
                    e: zast.err.ownerError
                    msg: ma9
                    note: ena9
                    hint: ha9
                    width: nm.length.u32.orPanic
                )
            }
        } case none then null
    }
    troot9: methodReceiverRoot :ast n: tpn9
    tfn9: dottedChildName :ast n: tpn9
    if troot9.length > 0 when tfn9.length > 0 then {
        tto9: st.lookup name: troot9.stringview
        match (
            tto9
        ) case some then {
            if (st.typing.isChildLockField
                pool: ast.names
                parentTypeId: tto9
                name: tfn9.stringview
            ) then {
                tfnc9: tfn9.copy
                md9: "Cannot reassign '.lock' field '\{tfnc9}' — lock fields are set at construction time and immutable"
                (addError
                    :st
                    nodeid: rasgn.nodeid
                    lineno: rasgn.lineno
                    colno: rasgn.colno
                    e: zast.err.ownerError
                    msg: md9
                )
            }
        } case none then null
    }
    # A bare-name reftype RHS is a move: the source invalidates (the symtab
    # appends its taken overlay entry).
    rn: bareAtomName :ast n: rvn9
    if rn.length > 0 when rvt > 0 when (typeIsReftype :st tid: rvt) then {
        vo: st.lookupVarId name: rn.stringview
        match (
            vo
        ) case some then {
            if (isBorrowedVar :st vid: vo) then {
                rnc9: rn.copy
                mc9: "Cannot move borrowed variable '\{rnc9}' by reassignment — borrowed names stay bound to their source for the full scope; copy with '.copy' to keep the source"
                (addError
                    :st
                    nodeid: rasgn.nodeid
                    lineno: rasgn.lineno
                    colno: rasgn.colno
                    e: zast.err.ownerError
                    msg: mc9
                )
            } else {
                st.invalidate name: rn.stringview loc: (optionval.none ztypes.zsrcpos)
            }
        } case none then null
    }
}

# checkSwap -- `lhs swap rhs`: resolve both operand paths (stamping them). The swap
# carries no type (the expression wrapper is null, like reassignment) and does no
# narrowing. Operand ownership/lock/type-match validation produces no dump rows -- deferred.
checkSwap: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    swapnode: zast.SwapStmtData
} is {
    checkValue :st :unitName :ast :unitBody node: (ast.nodes.get i: (swapnode.lhs - 1).u64)
    checkValue :st :unitName :ast :unitBody node: (ast.nodes.get i: (swapnode.rhs - 1).u64)
}

# withValueOwnership -- the with-binding's ownership from the bound value's
# syntactic shape, mirroring the reference's function-argument rules: a bare
# name bound to a runtime variable or a plain dotted path borrows; `.take`
# transfers; calls, literals and constructions are fresh owned values.
withValueOwnership: function {
    ast: Ast
    st: zenv.ZSymbolTable
    v: Node
} out ztypes.zownership is {
    match (
        v
    ) case expression then {
        return (withValueOwnership :ast :st v: (ast.nodes.get i: (v.expression - 1).u64))
    } case atomid then {
        vNm9: ast.names.texts.get i: (v.name - 1).u64
        vo: st.lookupVarId name: vNm9.stringview
        match (
            vo
        ) case some then {
            return ztypes.zownership.borrowed
        } case none then {
            return ztypes.zownership.owned
        }
    } case dottedpath then {
        cn: atomName :ast n: (ast.nodes.get i: (v.child - 1).u64)
        if cn.stringview == "take" then {
            return ztypes.zownership.owned
        } else {
            return ztypes.zownership.borrowed
        }
    } else {
        return ztypes.zownership.owned
    }
}

# checkWith -- walk `with name: value do body`: push the `with` scope, bind the
# alias variable (BORROWED for a plain-path value), walk the body, then pop. The
# with node carries the bound value's type; the with-expression's value is the
# body's value.
checkWith: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    withnode: zast.WithData
} out u64 is {
    withMarker: st.pushBlock name: "with"
    vt: checkValue :st :unitName :ast :unitBody node: (ast.nodes.get i: (withnode.value - 1).u64)
    if vt > 0 then {
        own: withValueOwnership :ast :st v: (ast.nodes.get i: (withnode.value - 1).u64)
        # The borrow target: a BORROW-returning auto-call reported the receiver
        # source; a plain-path value locks its full dotted tuple. Valtype
        # borrows are copies -- no lock.
        btgt: (List String)
        takePendingBorrow :st dst: btgt
        if btgt.length == 0 then {
            if own == ztypes.zownership.borrowed then {
                appendValueTuple :ast n: (ast.nodes.get i: (withnode.value - 1).u64) dst: btgt
            }
        } else {
            # A pending borrow from the value's call (a lock-param transfer
            # or a borrow-marked return) makes the with-binding borrowed.
            own = ztypes.zownership.borrowed
        }
        v: st.reg.newVariable ztypeId: vt ownership: own
        vid: v.variableId
        st.defineVar name: withnode.name.stringview var: v
        vid2: vid
        st.typing.defVariableId.set key: withnode.nodeid.u64 value: vid2
        if (typeIsReftype :st tid: vt) then {
            lfsW9: isViewFamilyTid :ast :st tid: vt
            if st.typing.pendingBorrowShared then lfsW9 = true
            st.typing.pendingBorrowShared = false
            (installBorrowLocks
                :st
                src: btgt
                :vid
                leafShared: lfsW9
                nodeid: withnode.nodeid
                lineno: withnode.lineno
                colno: withnode.colno
            )
        }
        setk: vt
        st.typing.nodeType.set key: withnode.nodeid.u64 value: setk
    }
    dt: checkValue :st :unitName :ast :unitBody node: (ast.nodes.get i: (withnode.body - 1).u64)
    st.popTo marker: withMarker
    return dt
}

# blockHasBreak -- a bare `break` statement somewhere in this block's own
# control flow (descending if/match/with bodies but NOT nested do/for, whose
# breaks bind to them). Drives the do-block's optionval wrapping.
blockHasBreak: function {ast: Ast n: Node} out bool is {
    match (
        n
    ) case statement then {
        siter: n.statements.iterate
        for s0Id9: siter loop {
            if (blockHasBreak :ast n: (ast.nodes.get i: (s0Id9 - 1).u64)) then return true
        }
        return false
    } case statementline then {
        return (blockHasBreak :ast n: (ast.nodes.get i: (n.statementline - 1).u64))
    } case expression then {
        return (blockHasBreak :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case atomid then {
        return n.name == wkBreak
    } case ifexpr then {
        cliter: n.clauses.iterate
        for cl0Id9: cliter loop {
            cl0: ast.nodes.get i: (cl0Id9 - 1).u64
            match (
                cl0
            ) case ifclause then {
                if (blockHasBreak
                    :ast
                    n: (ast.nodes.get i: (cl0.statement - 1).u64)
                ) then return true
            } else null
        }
        if n.elseclause == 0 then return false
        return (blockHasBreak :ast n: (ast.nodes.get i: (n.elseclause - 1).u64))
    } case caseexpr then {
        mliter: n.clauses.iterate
        for ml0Id9: mliter loop {
            ml0: ast.nodes.get i: (ml0Id9 - 1).u64
            match (
                ml0
            ) case caseclause then {
                if (blockHasBreak
                    :ast
                    n: (ast.nodes.get i: (ml0.statement - 1).u64)
                ) then return true
            } else null
        }
        if n.elseclause == 0 then return false
        return (blockHasBreak :ast n: (ast.nodes.get i: (n.elseclause - 1).u64))
    } case withexpr then {
        return (blockHasBreak :ast n: (ast.nodes.get i: (n.body - 1).u64))
    } else {
        return false
    }
}

# checkDo -- walk a do-block: push the `block` scope, define break (an entry
# position placeholder with an unregistered type id, so it never joins the dump),
# walk the statements, then pop. The do resolves to its last statement's value type.
checkDo: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    donode: zast.DoData
} out u64 is {
    doMarker: st.pushBlock name: "block"
    dbk: st.reg.allocType
    st.define name: "break" ztypeId: dbk
    checkStatement :st :unitName :ast :unitBody block: (ast.nodes.get i: (donode.statement - 1).u64)
    result: lastStmtType :st :ast block: (ast.nodes.get i: (donode.statement - 1).u64)
    st.popTo marker: doMarker
    # A break-carrying do-block's value wraps in optionval (early exit =
    # none); the literal pseudo keys the instance as literal_int/float.
    # A REFTYPE block value wraps in Option instead (boxed payload).
    if result > 0 when (blockHasBreak :ast n: (ast.nodes.get i: (donode.statement - 1).u64)) then {
        vtn0: typeNameOf :st tid: result
        payId0: result
        if result == literalIntId then {
            vtn0 = "literal_int".string
            if st.typing.literalIntShellId == 0 then {
                nli0: st.reg.newType name: "literal_int" typetype: ztypes.ztypetype.recordType
                st.reg.setValtype typeId: nli0 value: true
                st.typing.literalIntShellId = nli0
            }
            payId0 = st.typing.literalIntShellId
        }
        if result == literalFloatId then {
            vtn0 = "literal_float".string
            if st.typing.literalFloatShellId == 0 then {
                nlf0: st.reg.newType name: "literal_float" typetype: ztypes.ztypetype.recordType
                st.reg.setValtype typeId: nlf0 value: true
                st.typing.literalFloatShellId = nlf0
            }
            payId0 = st.typing.literalFloatShellId
        }
        if vtn0.length > 0 then {
            wrapB0: "optionval"
            if (typeIsReftype :st tid: payId0) then wrapB0 = "Option"
            ovo0: (walkLookupTyperef
                :ast
                ty: st.typing
                reg: st.reg
                currentUnit: unitName
                base: wrapB0
            )
            match (
                ovo0
            ) case some then {
                osubs0: (Map String value: u64)
                ok0: "t".string
                ov0: payId0
                osubs0.set key: ok0 value: ov0
                omn0: "\{wrapB0}_\{vtn0}"
                vsF9: (Map String value: u64)
                omid0: (getOrMintSpec
                    :ast
                    ty: st.typing
                    reg: st.reg
                    mainName: unitName
                    name: omn0.stringview
                    templateId: ovo0
                    subs: osubs0
                    valSubs: vsF9
                    fallbackArg: 0
                )
                if omid0 > 0 then result = omid0
            } case none then null
        }
    }
    if result > 0 then {
        setk: result
        st.typing.nodeType.set key: donode.nodeid.u64 value: setk
    }
    return result
}

# isCallNode -- the node is a (possibly expression-wrapped) call.
isCallNode: function {ast: Ast n: Node} out bool is {
    match (
        n
    ) case call then {
        return true
    } case expression then {
        return (isCallNode :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } else {
        return false
    }
}

# checkFor -- walk a for-loop: push the `for` scope, define break/continue (entry
# position placeholders with unregistered type ids, so they never join the dump),
# then walk the conditions, postconditions, and body, and pop. A named condition
# is a binding: define the loop var with the condition value's type (the value of
# a bare literal init stays the literal pseudo-type, keeping the entry out of the
# dump joins). Iterator-wrapper element extraction needs monomorphization and is
# not implemented. The for itself resolves to null (filtered) in statement position.
checkFor: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    fornode: zast.ForData
} out u64 is {
    forMarker: st.pushBlock name: "for"
    bk: st.reg.allocType
    st.define name: "break" ztypeId: bk
    ct: st.reg.allocType
    st.define name: "continue" ztypeId: ct
    citer: fornode.conditions.iterate
    for condId9: citer loop {
        cond: ast.nodes.get i: (condId9 - 1).u64
        match (
            cond
        ) case namedoperation then {
            # A bare 0-arg function returning an iterator class auto-invokes
            # (the reference rewrites the condition to a synthetic call):
            # its walk runs in a call scope and the atom keeps the FUNCTION
            # stamp rather than the auto-call's coerced return.
            facId: u64
            fbn: bareAtomName :ast n: (ast.nodes.get i: (cond.operation - 1).u64)
            if fbn.length > 0 then {
                ffo: (walkLookupTyperef
                    :ast
                    ty: st.typing
                    reg: st.reg
                    currentUnit: unitName
                    base: fbn.stringview
                )
                match (
                    ffo
                ) case some then {
                    if (st.reg.typetypeOf typeId: ffo) == ztypes.ztypetype.functionType then {
                        if (methodHasNoUserArgs :ast :st mid: ffo) then {
                            fro: methodReturnOf :st mid: ffo
                            match (
                                fro
                            ) case some then {
                                if (st.reg.typetypeOf typeId: fro) == ztypes.ztypetype.classType then {
                                    fco: st.typing.childOfId parentTypeId: fro nameId: wkCall
                                    match (
                                        fco
                                    ) case some then {
                                        facId = ffo
                                    } case none then null
                                }
                            } case none then null
                        }
                    }
                } case none then null
            }
            vt: u64
            if facId > 0 then {
                # the factory's lazy walks (its body + the iterator class's
                # methods via return-first transitivity) fire before the
                # synthetic invocation's call scope opens.
                maybeWalkMethods :st :unitName :ast :unitBody name: fbn.stringview
                fcm: st.pushCall
                opf29: ast.nodes.get i: (cond.operation - 1).u64
                vt = checkValue :st :unitName :ast :unitBody node: opf29
                st.popTo marker: fcm
                fiid: innermostNodeId :ast n: (ast.nodes.get i: (cond.operation - 1).u64)
                if fiid > 0 then {
                    setff: facId
                    st.typing.nodeType.set key: fiid.u64 value: setff
                }
            } else {
                opf39: ast.nodes.get i: (cond.operation - 1).u64
                vt = checkValue :st :unitName :ast :unitBody node: opf39
            }
            nm: zast.nameTextCopy :ast ref: cond.name
            # A bare `for while <cond> loop` (no binding, no iterator factory)
            # must be boolean; a non-bool, non-iterable value is a type error
            # rather than invalid C. Iterator bindings (`for e: it`) carry a
            # name; iterable inits expose an element wrapper or a `call` child.
            if nm.length == 0 when vt > 0 when facId == 0 then {
                fbId9: builtinTidTc :ast :st base: "bool"
                fIter9: false
                {
                    fpw9: iterWrapperElem :ast :st :unitName wid: vt
                    match (
                        fpw9
                    ) case some then {
                        fIter9 = true
                    } case none then null
                }
                {
                    fico9: st.typing.childOfId parentTypeId: vt nameId: wkCall
                    match (
                        fico9
                    ) case some then {
                        fIter9 = true
                    } case none then null
                }
                fTt9: st.reg.typetypeOf typeId: vt
                if fbId9 > 0 when vt != fbId9 when (fIter9) == false when fTt9 != ztypes.ztypetype.neverType then {
                    fcn9: ast.nodes.get i: (cond.operation - 1).u64
                    fctn9: typeNameOf :st tid: vt
                    fcmsg9: "loop condition must be bool, got '\{fctn9}'"
                    (addError
                        :st
                        nodeid: (nodeId n: fcn9)
                        lineno: (nodeLine n: fcn9)
                        colno: (nodeCol n: fcn9)
                        e: zast.err.typeError
                        msg: fcmsg9
                    )
                }
            }
            if nm.length > 0 when vt > 0 then {
                # A call-shaped iterator init probes its per-iteration call
                # in an empty call scope (the reference's rewrite walks it
                # once); gated on the value being an iterator wrapper.
                if (isCallNode :ast n: (ast.nodes.get i: (cond.operation - 1).u64)) then {
                    doProbe9: false
                    pw9: iterWrapperElem :ast :st :unitName wid: vt
                    match (
                        pw9
                    ) case some then {
                        doProbe9 = true
                    } case none then {
                        ico9: st.typing.childOfId parentTypeId: vt nameId: wkCall
                        match (
                            ico9
                        ) case some then {
                            doProbe9 = true
                        } case none then null
                    }
                    if doProbe9 then {
                        ecm9: st.pushCall
                        st.popTo marker: ecm9
                    }
                }
                elem: u64
                isView: false
                w1: iterWrapperElem :ast :st :unitName wid: vt
                match (
                    w1
                ) case some then {
                    elem = w1
                    isView = isOptionViewMono :ast :st :unitName wid: vt
                } case none then null
                if elem == 0 then {
                    if (st.reg.typetypeOf typeId: vt) == ztypes.ztypetype.functionType then {
                        r1: methodReturnOf :st mid: vt
                        match (
                            r1
                        ) case some then {
                            w2: iterWrapperElem :ast :st :unitName wid: r1
                            match (
                                w2
                            ) case some then {
                                elem = w2
                                isView = isOptionViewMono :ast :st :unitName wid: r1
                            } case none then null
                        } case none then null
                    } else {
                        c1: st.typing.childOfId parentTypeId: vt nameId: wkCall
                        match (
                            c1
                        ) case some then {
                            r2: methodReturnOf :st mid: c1
                            match (
                                r2
                            ) case some then {
                                w3: iterWrapperElem :ast :st :unitName wid: r2
                                match (
                                    w3
                                ) case some then {
                                    elem = w3
                                    isView = isOptionViewMono :ast :st :unitName wid: r2
                                } case none then null
                            } case none then null
                        } case none then null
                    }
                }
                if elem > 0 then {
                    if isView then {
                        srcName: atomName :ast n: (ast.nodes.get i: (cond.operation - 1).u64)
                        bo: "<iterator>".string
                        if srcName.length > 0 then bo = srcName.copy
                        v: st.reg.newVariable ztypeId: elem ownership: ztypes.zownership.borrowed
                        v.borrowOrigin = (Option.some bo)
                        vid: v.variableId
                        st.defineVar name: nm.stringview var: v
                        condNid: nodeId n: (ast.nodes.get i: (cond.operation - 1).u64)
                        st.typing.defVariableId.set key: condNid.u64 value: vid
                    } else {
                        st.define name: nm.stringview ztypeId: elem
                    }
                } else {
                    st.define name: nm.stringview ztypeId: vt
                }
            }
        } else null
    }
    piter: fornode.postconditions.iterate
    for pcId9: piter loop {
        pc: ast.nodes.get i: (pcId9 - 1).u64
        match (
            pc
        ) case namedoperation then {
            checkValue :st :unitName :ast :unitBody node: (ast.nodes.get i: (pc.operation - 1).u64)
        } else {
            checkValue :st :unitName :ast :unitBody node: pc
        }
    }
    walkBodyAt :st :unitName :ast :unitBody bodyId: fornode.body
    elemT9: u64
    if fornode.body > 0 then {
        fb9: ast.nodes.get i: (fornode.body - 1).u64
        elemT9 = lastStmtType :st :ast block: fb9
    }
    if st.isUnreachable then st.discardTakenInCurrentScope
    st.popTo marker: forMarker
    # for-as-expression: a value-producing body makes the loop a List of
    # that element type (the comprehension form).
    if elemT9 > 0 then {
        en9: typeNameOf :st tid: elemT9
        isNull9: false
        if en9.stringview == "null" then isNull9 = true
        if en9.length == 0 then isNull9 = true
        if (isNull9) == false then {
            lto9: (walkLookupTyperef
                :ast
                ty: st.typing
                reg: st.reg
                currentUnit: unitName
                base: "List"
            )
            match (
                lto9
            ) case some then {
                lsubs9: (Map String value: u64)
                lk9: "of".string
                lv9: elemT9
                lsubs9.set key: lk9 value: lv9
                lsfx9: "_\{en9}"
                lmn9: "List\{lsfx9}"
                vsG9: (Map String value: u64)
                lmid9: (getOrMintSpec
                    :ast
                    ty: st.typing
                    reg: st.reg
                    mainName: unitName
                    name: lmn9.stringview
                    templateId: lto9
                    subs: lsubs9
                    valSubs: vsG9
                    fallbackArg: 0
                )
                if lmid9 > 0 then {
                    setf9: lmid9
                    st.typing.nodeType.set key: fornode.nodeid.u64 value: setf9
                    return lmid9
                }
            } case none then null
        }
    }
    return 0
}

# checkIf -- walk an if: push the `if` scope, then a `if_branch` scope per clause
# and an `if_else` scope for the else; when every branch diverges (returns) the
# if resolves to never and marks the enclosing scope unreachable.
# restoreTakenArm -- after a NON-diverging if arm, undo any takes of outer-scope
# owned vars (clearTaken) so the next arm + the restore see them live, recording
# them in `taken` for a single post-if invalidate. Without this a take in one arm
# propagates (via popTo) into the sibling arm, which then sees the var as gone and
# never stamps its type (e.g. an else-arm's `childpath.take` emitting `.take` on a
# String). Mirrors the reference _check_if_inner per-arm restore; the port's take
# is an overlay over a persisting entry, so clearTaken alone restores (no redefine).
restoreTakenArm: function {st: zenv.ZSymbolTable liveBefore: Set String taken: Set String} is {
    liveAfter: st.getLiveOwnedVars
    for vn: liveBefore.iterate loop {
        if (liveAfter.has item: vn) == false then {
            taken.add item: vn.copy
            st.clearTaken name: vn.stringview
        }
    }
}

# invalidateTakenAcross -- after the whole if, mark every var taken in some arm as
# taken in the enclosing scope (it is consumed on at least one path, so a later use
# is use-after-take).
invalidateTakenAcross: function {st: zenv.ZSymbolTable names: Set String} is {
    for vn: names.iterate loop {
        st.invalidate name: vn.stringview loc: (optionval.none ztypes.zsrcpos)
    }
}

checkIf: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    ifnode: zast.IfData
} out u64 is {
    ifMarker: st.pushBlock name: "if"
    liveBefore: st.getLiveOwnedVars
    takenAcross: (Set String)
    nvId: (optU64Or
        o: (walkLookupTyperef :ast ty: st.typing reg: st.reg currentUnit: unitName base: "never")
        d: 0
    )
    nullId: (optU64Or
        o: (walkLookupTyperef :ast ty: st.typing reg: st.reg currentUnit: unitName base: "null")
        d: 0
    )
    pBool9: (optU64Or
        o: (walkLookupTyperef :ast ty: st.typing reg: st.reg currentUnit: unitName base: "bool")
        d: 0
    )
    accFacts: (List ArmPredFact)
    guardFacts9: (List ArmPredFact)
    elseDvg9: false
    anyEmpty: false
    branchTypes: (List u64)
    allDiverge: true
    cliter: ifnode.clauses.iterate
    for clauseId9: cliter loop {
        clause: ast.nodes.get i: (clauseId9 - 1).u64
        match (
            clause
        ) case ifclause then {
            if (isEmptyBody n: (ast.nodes.get i: (clause.statement - 1).u64)) then anyEmpty = true
        } else null
        bm: st.pushBlock name: "if_branch"
        with pfit9: accFacts.iterate do for pf9: pfit9 loop (applyPredFact
            :ast
            :st
            f: pf9
            holds: false
        )
        cfacts9: (List ArmPredFact)
        bt9: checkClause :st :unitName :ast :unitBody :clause factsOut: cfacts9 boolId: pBool9
        dvgC9: st.isUnreachable
        btc: bt9
        branchTypes.append btc
        if st.isUnreachable then {
            # a diverging arm transfers ownership on a path that never reaches
            # fall-through: drop its take overlays before pop so they don't
            # bubble into the parent scope (where post-if uses would see the
            # variable as taken).
            st.discardTakenInCurrentScope
        } else {
            allDiverge = false
            restoreTakenArm :st :liveBefore taken: takenAcross
        }
        st.popTo marker: bm
        cn1c9: u64
        match (
            clause
        ) case ifclause then {
            cn1c9 = clause.conditions.length
        } else null
        if cn1c9 == 1 when cfacts9.length == 1 then {
            mvf9: cfacts9.pop
            if dvgC9 then {
                gf9: (ArmPredFact
                    subject: mvf9.subject.copy
                    armName: mvf9.armName.copy
                    fullTid: mvf9.fullTid
                    negated: mvf9.negated
                )
                guardFacts9.append gf9
            }
            accFacts.append mvf9
        }
    }
    hasElse: false
    if ifnode.elseclause > 0 then {
        hasElse = true
        if (isEmptyBody n: (ast.nodes.get i: (ifnode.elseclause - 1).u64)) then anyEmpty = true
        ebm: st.pushBlock name: "if_else"
        with efit9: accFacts.iterate do for ef9: efit9 loop (applyPredFact
            :ast
            :st
            f: ef9
            holds: false
        )
        walkBodyAt :st :unitName :ast :unitBody bodyId: ifnode.elseclause
        et9: lastStmtType :st :ast block: (ast.nodes.get i: (ifnode.elseclause - 1).u64)
        if st.isUnreachable then elseDvg9 = true
        etc9: et9
        branchTypes.append etc9
        if st.isUnreachable then {
            st.discardTakenInCurrentScope
        } else {
            allDiverge = false
            restoreTakenArm :st :liveBefore taken: takenAcross
        }
        st.popTo marker: ebm
    } else {
        allDiverge = false
    }
    result: u64
    if allDiverge then {
        if nvId > 0 then {
            result = nvId
            setk: result
            st.typing.nodeType.set key: ifnode.nodeid.u64 value: setk
        }
    } else {
        # An exhaustive (else-carrying) if is a value: the first completing
        # branch's type, diverging branches skipped (mirrors the match rule).
        if hasElse when anyEmpty then {
            # an empty (`{}` / null) branch body makes the if valueless:
            # stamp null so consuming it as a value is rejected.
            if nullId > 0 then {
                result = nullId
                setnv0: result
                st.typing.nodeType.set key: ifnode.nodeid.u64 value: setnv0
            }
        }
        if hasElse when (anyEmpty) == false then {
            ti9: u64
            tn9: branchTypes.length
            for ti9 < tn9 loop {
                bt2: branchTypes.get i: ti9
                if bt2 != nvId then {
                    if bt2 > 0 then {
                        result = bt2
                        setv9: result
                        st.typing.nodeType.set key: ifnode.nodeid.u64 value: setv9
                        ti9 = tn9
                    } else {
                        ti9 = tn9
                    }
                }
                ti9 = ti9 + 1
            }
        }
    }
    st.popTo marker: ifMarker
    # post-guard flow typing: a diverging clause's condition was FALSE for
    # the remainder of the enclosing scope; a diverging else of a single-
    # clause if means its condition was TRUE. Apply that knowledge (the
    # exclusion collapse shadows to the payload where one arm remains) and
    # record it for the emitter's block aliasing.
    pgSubj9: String
    pgTid9: u64
    pgApplied9: u64
    with gfit9: guardFacts9.iterate do for gf2: gfit9 loop {
        applyPredFact :ast :st f: gf2 holds: false
        pgs9: gf2.subject.copy
        pgSubj9 = pgs9
        pgTid9 = gf2.fullTid
        pgApplied9 = pgApplied9 + 1
    }
    if elseDvg9 when ifnode.clauses.length == 1 when accFacts.length == 1 then {
        af0: accFacts.get i: 0
        applyPredFact :ast :st f: af0 holds: true
        pga9: af0.subject.copy
        pgSubj9 = pga9
        pgTid9 = af0.fullTid
        pgApplied9 = pgApplied9 + 1
    }
    if pgApplied9 == 1 when pgSubj9.length > 0 then {
        (postGuardRecord
            :ast
            :st
            stmtNid: ifnode.nodeid
            subject: pgSubj9.stringview
            fullTid: pgTid9
        )
    }
    invalidateTakenAcross :st names: takenAcross
    if allDiverge then st.markUnreachable
    return result
}

# comparisonCoerceTarget -- the type a literal comparison operand coerces at:
# the concrete side's operator-child first-param type when resolvable (a
# boxed value's == is the element's, so the literal wears the element type),
# else the concrete side itself.
comparisonCoerceTarget: function {
    ast: Ast
    st: zenv.ZSymbolTable
    unitName: StringView
    concrete: u64
    op: StringView
} out u64 is {
    opo9: st.typing.childOf pool: ast.names parentTypeId: concrete name: op
    match (
        opo9
    ) case some then {
        p0n9: positionalParamName :ast :st funcId: opo9 idx: 0 skipRecv: true
        if p0n9.length > 0 then {
            ppo9: st.typing.childOf pool: ast.names parentTypeId: opo9 name: p0n9.stringview
            match (
                ppo9
            ) case some then {
                return ppo9
            } case none then null
        }
    } case none then null
    return concrete
}

# checkBinopMethodDispatch -- resolve a binary operator as a declared method on
# the lhs type: materialise a bare-literal lhs for dispatch, chase typedef bases
# to the type that declares the operator, arg-check the rhs against the method's
# first parameter, and return the result type. For a comparison (isCmp9) an
# undeclared operator falls back to bool -- structural `==`/`!=` on records and
# variants; for arithmetic an undeclared operator on a concrete type is an error
# and a bare-literal lhs keeps its coercible literal result. Returns 0 on an
# emitted arg-mismatch.
checkBinopMethodDispatch: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast
    binop: zast.BinOpData
    opn: StringView
    opnId9: u64
    lt: u64
    rt: u64
    isCmp9: bool
} out u64 is {
    ltLit9: isLiteralTypeId :st tid: lt
    dt9: lt
    if ltLit9 then dt9 = materialiseLiteral :ast :st :unitName t: lt
    opo: st.typing.childOfId parentTypeId: dt9 nameId: opnId9
    for opo.none while (typedefBaseOf :ast :st :unitName tid: dt9) > 0 loop {
        dt9 = typedefBaseOf :ast :st :unitName tid: dt9
        opo = st.typing.childOfId parentTypeId: dt9 nameId: opnId9
    }
    match (
        opo
    ) case some then {
        oParamT9: u64
        p0n9: positionalParamName :ast :st funcId: opo idx: 0 skipRecv: true
        if p0n9.length > 0 then {
            ppo9: st.typing.childOf pool: ast.names parentTypeId: opo name: p0n9.stringview
            match (
                ppo9
            ) case some then {
                oParamT9 = ppo9
            } case none then null
        }
        if oParamT9 > 0 when rt > 0 then {
            if (typesCompatible :ast :st :unitName a: rt b: oParamT9) == false then {
                skipA9: false
                if (isNumericTid
                    :ast
                    ty: st.typing
                    reg: st.reg
                    tid: rt
                ) when (isNumericTid
                    :ast
                    ty: st.typing
                    reg: st.reg
                    tid: oParamT9
                ) then skipA9 = true
                strT9x: builtinTidTc :ast :st base: "String"
                svT9x: builtinTidTc :ast :st base: "StringView"
                rSty9: false
                if rt == strT9x then rSty9 = true
                if rt == svT9x then rSty9 = true
                pSty9: false
                if oParamT9 == strT9x then pSty9 = true
                if oParamT9 == svT9x then pSty9 = true
                if rSty9 when pSty9 then skipA9 = true
                ptt9: st.reg.typetypeOf typeId: oParamT9
                if ptt9 == ztypes.ztypetype.protocolType then skipA9 = true
                if ptt9 == ztypes.ztypetype.facetType then skipA9 = true
                if ptt9 == ztypes.ztypetype.genericParam then skipA9 = true
                if ptt9 == ztypes.ztypetype.functionType then skipA9 = true
                if (skipA9) == false then {
                    ea9: typeNameOf :st tid: oParamT9
                    aa9: typeNameOf :st tid: rt
                    eac9: ea9.copy
                    aac9: aa9.copy
                    mma9: "argument type mismatch: expected \{eac9}, got \{aac9}"
                    (addError
                        :st
                        nodeid: binop.nodeid
                        lineno: binop.lineno
                        colno: binop.colno
                        e: zast.err.callError
                        msg: mma9
                    )
                    return 0
                }
            }
        }
        if isCmp9 then {
            cb9: builtinTidTc :ast :st base: "bool"
            if cb9 > 0 then return cb9
            return lt
        }
        if ltLit9 then return lt
        oro: methodReturnOf :st mid: opo
        match (
            oro
        ) case some then {
            return oro
        } case none then null
        return lt
    } case none then {
        if isCmp9 then {
            # `!=` derives from `==`: only error when `==` is also unavailable.
            if opn == "!=" then {
                eqEdge9: st.typing.childOfId parentTypeId: dt9 nameId: wkOpEq
                if eqEdge9.some then {
                    boD9: builtinTidTc :ast :st base: "bool"
                    if boD9 > 0 then return boD9
                    return lt
                }
            }
            # Ordering comparisons have no structural fallback: unlike `==` /
            # `!=` there is no structural ordering, so the operand type must
            # declare the operator (numerics declare all six). An undeclared
            # `<` / `>` / `<=` / `>=` -- on a resultval or any other aggregate --
            # is a hard error, not invalid C.
            isOrd9: false
            if opn == "<" then isOrd9 = true
            if opn == ">" then isOrd9 = true
            if opn == "<=" then isOrd9 = true
            if opn == ">=" then isOrd9 = true
            if isOrd9 then {
                lnOr9: typeNameOf :st tid: dt9
                mgOr9: "type '\{lnOr9}' has no '\{opn}' method"
                (addError
                    :st
                    nodeid: binop.nodeid
                    lineno: binop.lineno
                    colno: binop.colno
                    e: zast.err.typeError
                    msg: mgOr9
                )
                return 0
            }
            # A concrete type that declares no comparison method -- a class or
            # union without `==`, or a record/variant that opted out with
            # `==: null` -- is a hard error rather than invalid C.
            if (memberStrictType :st bt: dt9) then {
                lnc9: typeNameOf :st tid: dt9
                mgc9: "type '\{lnc9}' has no '\{opn}' method"
                (addError
                    :st
                    nodeid: binop.nodeid
                    lineno: binop.lineno
                    colno: binop.colno
                    e: zast.err.typeError
                    msg: mgc9
                )
                return 0
            }
            bo9: builtinTidTc :ast :st base: "bool"
            if bo9 > 0 then return bo9
            return lt
        }
        # A concrete aggregate (record / class / union / variant, including a
        # generic mono like resultval) that declares no arithmetic operator is a
        # type error rather than invalid C. Type params, protocols, facets and
        # non-aggregates resolve elsewhere and keep the coercible lhs result.
        aTt9: st.reg.typetypeOf typeId: dt9
        aAgg9: false
        if aTt9 == ztypes.ztypetype.recordType then aAgg9 = true
        if aTt9 == ztypes.ztypetype.classType then aAgg9 = true
        if aTt9 == ztypes.ztypetype.unionType then aAgg9 = true
        if aTt9 == ztypes.ztypetype.variantType then aAgg9 = true
        if aAgg9 then {
            ln9: typeNameOf :st tid: dt9
            msg9: "type '\{ln9}' has no '\{opn}' method"
            (addError
                :st
                nodeid: binop.nodeid
                lineno: binop.lineno
                colno: binop.colno
                e: zast.err.typeError
                msg: msg9
            )
            return 0
        }
        return lt
    }
}

# checkBinop -- type a binary operator expression. Both operands are walked (so
# their nodes are stamped), then the operator resolves as a declared method on
# the operand type via checkBinopMethodDispatch (comparisons yield bool; an
# undeclared comparison falls back to structural equality).
checkBinop: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    binop: zast.BinOpData
} out u64 is {
    result: u64
    lt: checkValue :st :unitName :ast :unitBody node: (ast.nodes.get i: (binop.lhs - 1).u64)
    rt: checkValue :st :unitName :ast :unitBody node: (ast.nodes.get i: (binop.rhs - 1).u64)
    opn: atomName :ast n: (ast.nodes.get i: (binop.operator - 1).u64)
    opnId9: atomNameId :ast n: (ast.nodes.get i: (binop.operator - 1).u64)
    if (isComparisonOp name: opn.stringview) then {
        # A literal operand coerces (restamps) at the concrete side's type.
        lLit9: false
        if lt == literalIntId then lLit9 = true
        if lt == literalFloatId then lLit9 = true
        rLit9: false
        if rt == literalIntId then rLit9 = true
        if rt == literalFloatId then rLit9 = true
        if lLit9 when rLit9 then {} else {
            if lLit9 when rt > 0 then {
                lct9: comparisonCoerceTarget :ast :st :unitName concrete: rt op: opn.stringview
                lid9: innermostNodeId :ast n: (ast.nodes.get i: (binop.lhs - 1).u64)
                if lid9 > 0 then {
                    setlc9: lct9
                    st.typing.nodeType.set key: lid9.u64 value: setlc9
                }
            }
            if rLit9 when lt > 0 then {
                rct9: comparisonCoerceTarget :ast :st :unitName concrete: lt op: opn.stringview
                rid9: innermostNodeId :ast n: (ast.nodes.get i: (binop.rhs - 1).u64)
                if rid9 > 0 then {
                    setrc9: rct9
                    st.typing.nodeType.set key: rid9.u64 value: setrc9
                }
            }
        }
        result = (checkBinopMethodDispatch
            :st
            :unitName
            :ast
            :binop
            opn: opn.stringview
            :opnId9
            :lt
            :rt
            isCmp9: true
        )
    } else {
        result = (checkBinopMethodDispatch
            :st
            :unitName
            :ast
            :binop
            opn: opn.stringview
            :opnId9
            :lt
            :rt
            isCmp9: false
        )
    }
    tdb2: typedefBaseOf :ast :st :unitName tid: result
    if tdb2 > 0 then result = tdb2
    if result > 0 when (st.reg.typetypeOf typeId: result) == ztypes.ztypetype.genericParam then {
        # Structural pass-through: the SAME parameter on both sides flows
        # through arithmetic as itself (the per-instance clone checks remain
        # the arithmetic backstop); mixed operands stay untyped.
        if (result == rt) == false then return 0
    }
    if result > 0 then stampGate :st nid: binop.nodeid tid: result
    return result
}

# argIsTrivial -- true when a call argument's operation is a hoisting no-op: a
# bare atom, a labelvalue, a string literal without interpolation, or an
# expression wrapping a bare atom / labelvalue. Anything else (binop, call,
# dotted path, interpolated string) hoists into a synth temp.
argIsTrivial: function {ast: Ast op: Node} out bool is {
    match (
        op
    ) case atomid then {
        return true
    } case labelvalue then {
        return true
    } case atomstring then {
        spiter: op.stringparts.iterate
        for spId9: spiter loop {
            sp: ast.nodes.get i: (spId9 - 1).u64
            match (
                sp
            ) case stringchunk then null else {
                return false
            }
        }
        return true
    } case expression then {
        opx9: ast.nodes.get i: (op.expression - 1).u64
        match (
            opx9
        ) case atomid then {
            return true
        } case labelvalue then {
            return true
        } else {
            return false
        }
    } else {
        return false
    }
}

# hoistArg -- hoist a non-trivial call argument into a fresh `_tN` synth temp:
# define the temp (OWNED, synth origin anf) in the open CALL scope and record
# the synth Assignment / value-Expression / AtomId rows + their type stamps so
# the dump matches the reference's hoisted tree. The parsed argument keeps its
# own stamps; only the dump rows are synthesised (no AST mutation).
# typeIsReftype -- a registered type whose isValtype flag is explicitly false
# (classes, unions, protocols, heap natives like String). Unset or unregistered
# ids are not reftypes.
typeIsReftype: function {st: zenv.ZSymbolTable tid: u64} out bool is {
    zo: st.reg.typeById.get key: tid
    match (
        zo
    ) case some then {
        vt: zo.isValtype
        match (
            vt
        ) case some then {
            return vt == false
        } case none then {
            return false
        }
    } case none then {
        return false
    }
}

# typeIsValtype -- a registered type whose isValtype flag is explicitly true
# (records, variants, facets, primitives). Unset or unregistered ids are not
# valtypes.
typeIsValtype: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry tid: u64} out bool is {
    zo: reg.typeById.get key: tid
    match (
        zo
    ) case some then {
        vt: zo.isValtype
        match (
            vt
        ) case some then {
            return vt == true
        } case none then {
            return false
        }
    } case none then {
        return false
    }
}

# innermostNodeId -- the node id of a value with its expression wrappers
# stripped (the node the dump's descent reads first); 0 for uncovered kinds.
innermostNodeId: function {ast: Ast n: Node} out u32 is {
    match (
        n
    ) case expression then {
        return (innermostNodeId :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } else {
        return (nodeId :n)
    }
}

# pathRootName -- the leftmost bare atom of a value path (`a.b.c` -> a,
# through expression wrappers), "" when the root is not a bare atom.
pathRootName: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case expression then {
        return (pathRootName :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case dottedpath then {
        return (pathRootName :ast n: (ast.nodes.get i: (n.parent - 1).u64))
    } case atomid then {
        return (zast.nameTextCopy :ast ref: n.name)
    } else {
        return "".string
    }
}

# taggedRecvIsValue -- the dotted receiver denotes a VALUE (a variable at
# the path root, or a call result), not a type/unit reference.
taggedRecvIsValue: function {ast: Ast st: zenv.ZSymbolTable n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (taggedRecvIsValue :ast :st n: (ast.nodes.get i: (n.expression - 1).u64))
    } case call then {
        return true
    } else {
        rn0: pathRootName :ast :n
        if rn0.length == 0 then return false
        rvo0: st.lookupVarId name: rn0.stringview
        match (
            rvo0
        ) case some then {
            return true
        } case none then {
            return false
        }
    }
}

# bareAtomName -- the (expression-unwrapped) bare atom name of a value node,
# or "" when the value is any other shape.
bareAtomName: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case expression then {
        return (bareAtomName :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case atomid then {
        return (zast.nameTextCopy :ast ref: n.name)
    } else {
        return "".string
    }
}

# methodReceiverRoot -- the bare root name of a dotted callable's receiver
# (`a.compare` -> a), "" for non-dotted or non-bare receivers.
methodReceiverRoot: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        return (bareAtomName :ast n: (ast.nodes.get i: (n.parent - 1).u64))
    } else {
        return "".string
    }
}

# methodReceiverTuple -- the full dotted path of a method call's receiver
# (everything before the method name): `st.reg.unitNameTid.get` -> [st, reg,
# unitNameTid]. Empty when the callable is not a dotted path or the receiver
# is not a plain path. Path-scoped locks need the full tuple so sibling
# fields stay independent.
methodReceiverTuple: function {ast: Ast n: Node dst: List String} is {
    match (
        n
    ) case dottedpath then {
        appendValueTuple :ast n: (ast.nodes.get i: (n.parent - 1).u64) :dst
    } else null
}

# dottedParentNodeId -- the nodeid of a dotted callable's receiver expression
# (its stamped type is the immediate receiver type); 0 otherwise.
dottedParentNodeId: function {ast: Ast n: Node} out u32 is {
    match (
        n
    ) case dottedpath then {
        return (nodeId n: (ast.nodes.get i: (n.parent - 1).u64))
    } else {
        return 0
    }
}

# positionalParamName -- the funcId's parameter name at `idx` (typeChild
# position order), "" when absent. Positional call args map to it. With
# skipRecv, receiver rows (`this` or the fn's thisParamName) are excluded
# from the count: a dotted method call supplies the receiver implicitly, so
# its positional args map onto the remaining params.
positionalParamName: function {
    ast: Ast
    st: zenv.ZSymbolTable
    funcId: u64
    idx: u64
    skipRecv: bool
} out String is {
    result: String
    found: false
    seen: u64
    bp9: st.typing.childIndex.get key: funcId
    match (
        bp9
    ) case some then {
        with rpit9: bp9.rows.iterate do for rpi9: rpit9 loop {
            tc: st.typing.typeChild.get i: rpi9
            if (found) == false then {
                tnB9: ast.names.texts.get i: (tc.nameId - 1).u64
                isRecv9: false
                if skipRecv then {
                    if tnB9.stringview == "this" then isRecv9 = true
                    zoR9: st.reg.typeById.get key: funcId
                    match (
                        zoR9
                    ) case some then {
                        if (optStrEquals o: zoR9.thisParamName s: tnB9.stringview) then {
                            isRecv9 = true
                        }
                    } case none then null
                }
                if (isRecv9) == false then {
                    if seen == idx then {
                        result = tnB9.copy
                        found = true
                    }
                    seen = seen + 1
                }
            }
        }
    } case none then null
    return result
}

# lockCallArg -- the call-scoped EXCLUSIVE lock a lock/borrow parameter takes
# on its argument's root for the call's duration (the symtab appends the lock
# overlay entry in the open call scope; it vanishes when the scope pops).
lockCallArg: function {
    st: zenv.ZSymbolTable
    name: StringView
    callId: u64
    shared: bool
    nodeid: u32
    lineno: u32
    colno: u32
} is {
    pth: (List String)
    nm: name.string
    pth.append nm
    h: (ztypes.zlockholder kind: ztypes.zlockholderkind.callKind id: callId)
    h2: (ztypes.zlockholder kind: ztypes.zlockholderkind.callKind id: callId)
    clk9: ztypes.zlockstate.exclusive
    if shared then clk9 = ztypes.zlockstate.shared
    r: st.tryLock path: pth lockType: clk9 holder: h hasSelfHolder: true selfHolder: h2
    if r.length > 0 then addError :st :nodeid :lineno :colno e: zast.err.ownerError msg: r
}

# lockCallPath -- call-scoped path lock over a full receiver tuple: SHARED
# on the strict prefixes, reader/writer kind on the leaf. Same-call locks
# share the CALL holder identity (self-idempotent).
lockCallPath: function {
    st: zenv.ZSymbolTable
    path: List String
    callId: u64
    shared: bool
    nodeid: u32
    lineno: u32
    colno: u32
} is {
    n: path.length
    if n == 0 then return
    end: 1.u64
    for end < n loop {
        sub: (List String)
        i: u64
        for i < end loop {
            e: path.get :i
            ec: e.copy
            sub.append ec
            i = i + 1
        }
        hs: (ztypes.zlockholder kind: ztypes.zlockholderkind.callKind id: callId)
        hs2: (ztypes.zlockholder kind: ztypes.zlockholderkind.callKind id: callId)
        rs: (st.tryLock
            path: sub
            lockType: ztypes.zlockstate.shared
            holder: hs
            hasSelfHolder: true
            selfHolder: hs2
        )
        if rs.length > 0 then addError :st :nodeid :lineno :colno e: zast.err.ownerError msg: rs
        end = end + 1
    }
    full: (List String)
    j: u64
    for j < n loop {
        e2: path.get i: j
        ec2: e2.copy
        full.append ec2
        j = j + 1
    }
    he: (ztypes.zlockholder kind: ztypes.zlockholderkind.callKind id: callId)
    he2: (ztypes.zlockholder kind: ztypes.zlockholderkind.callKind id: callId)
    clk9: ztypes.zlockstate.exclusive
    if shared then clk9 = ztypes.zlockstate.shared
    re: st.tryLock path: full lockType: clk9 holder: he hasSelfHolder: true selfHolder: he2
    if re.length > 0 then addError :st :nodeid :lineno :colno e: zast.err.ownerError msg: re
}

# lockSuffixBase -- the bare base name of a `<atom>.lock` argument, ""
# otherwise.
lockSuffixBase: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case expression then {
        return (lockSuffixBase :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case dottedpath then {
        ln: atomName :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if ln.stringview == "lock" then {
            return (bareAtomName :ast n: (ast.nodes.get i: (n.parent - 1).u64))
        } else {
            return "".string
        }
    } else {
        return "".string
    }
}

# takenHere -- the location stamp an ownership-transfer overlay carries (pop
# propagates only located takes into the enclosing scope).
takenHere: function {} out optionval ztypes.zsrcpos is {
    return (optionval.some (ztypes.zsrcpos fsno: 0 lineno: 0 colno: 0))
}

# appendValueTuple -- the dotted-path tuple of a value node (root first),
# appended onto dst; non-path shapes contribute nothing.
appendValueTuple: function {ast: Ast n: Node dst: List String} is {
    match (
        n
    ) case expression then {
        appendValueTuple :ast n: (ast.nodes.get i: (n.expression - 1).u64) :dst
    } case atomid then {
        nm: zast.nameTextCopy :ast ref: n.name
        dst.append nm
    } case dottedpath then {
        appendValueTuple :ast n: (ast.nodes.get i: (n.parent - 1).u64) :dst
        cn: atomName :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if cn.length > 0 then dst.append cn
    } else null
}

# drainPendingBorrow / takePendingBorrow -- clear the borrow side-channel /
# move it into a local list (root-first order preserved).
drainPendingBorrow: function {st: zenv.ZSymbolTable} is {
    for st.typing.pendingBorrowPath.length > 0 loop {
        pd: st.typing.pendingBorrowPath.pop
    }
    st.typing.pendingBorrowShared = false
}

takePendingBorrow: function {st: zenv.ZSymbolTable dst: List String} is {
    n: st.typing.pendingBorrowPath.length
    i: u64
    for i < n loop {
        e: st.typing.pendingBorrowPath.get :i
        ec: e.copy
        dst.append ec
        i = i + 1
    }
    sh9: st.typing.pendingBorrowShared
    drainPendingBorrow :st
    st.typing.pendingBorrowShared = sh9
}

# installBorrowLocks -- SHARED on every path prefix, EXCLUSIVE on the leaf
# (the symtab appends one lock overlay entry per acquisition, keyed by the
# path root -- the oracle's non-definition rows). Holder = the binding var.
installBorrowLocks: function {
    st: zenv.ZSymbolTable
    src: List String
    vid: u64
    leafShared: bool
    nodeid: u32
    lineno: u32
    colno: u32
} is {
    n: src.length
    if n == 0 then return
    end: 1.u64
    for end < n loop {
        sub: (List String)
        i: u64
        for i < end loop {
            e: src.get :i
            ec: e.copy
            sub.append ec
            i = i + 1
        }
        hs: (ztypes.zlockholder kind: ztypes.zlockholderkind.varKind id: vid)
        hs2: (ztypes.zlockholder kind: ztypes.zlockholderkind.varKind id: vid)
        rs: (st.tryLock
            path: sub
            lockType: ztypes.zlockstate.shared
            holder: hs
            hasSelfHolder: false
            selfHolder: hs2
        )
        if rs.length > 0 then addError :st :nodeid :lineno :colno e: zast.err.ownerError msg: rs
        end = end + 1
    }
    full: (List String)
    j: u64
    for j < n loop {
        e2: src.get i: j
        ec2: e2.copy
        full.append ec2
        j = j + 1
    }
    he: (ztypes.zlockholder kind: ztypes.zlockholderkind.varKind id: vid)
    he2: (ztypes.zlockholder kind: ztypes.zlockholderkind.varKind id: vid)
    lk9: ztypes.zlockstate.exclusive
    if leafShared then lk9 = ztypes.zlockstate.shared
    re: st.tryLock path: full lockType: lk9 holder: he hasSelfHolder: false selfHolder: he2
    if re.length > 0 then addError :st :nodeid :lineno :colno e: zast.err.ownerError msg: re
}

# isLiteralTypeId -- a literal-typed value: the unregistered int/float pseudo
# ids, or a data block's registered literal_int/literal_float element shell.
isLiteralTypeId: function {st: zenv.ZSymbolTable tid: u64} out bool is {
    if tid == literalIntId then return true
    if tid == literalFloatId then return true
    nm: typeNameOf :st :tid
    if nm.stringview == "literal_int" then return true
    return nm.stringview == "literal_float"
}

hoistArg: function {ast: Ast
    st: zenv.ZSymbolTable
    argNode: Node
    argType: u64
    paramType: u64
    consumes: bool
} out String is {
    tn: st.typing.nextTempId
    st.typing.nextTempId = tn + 1
    tname: "_t\{tn}"
    ln: nodeLine n: argNode
    co: nodeCol n: argNode
    assignId: st.typing.nextSynthNodeId
    exprId: assignId + 1
    atomId: assignId + 2
    st.typing.nextSynthNodeId = assignId + 3
    st.typing.synthNodes.append (ztyping.SynthNode
        nodeid: assignId
        kind: "Assignment".string
        label: st.typing.synthLabel.copy
        lineno: ln
        colno: co)
    st.typing.synthNodes.append (ztyping.SynthNode
        nodeid: exprId
        kind: "Expression".string
        label: st.typing.synthLabel.copy
        lineno: ln
        colno: co)
    st.typing.synthNodes.append (ztyping.SynthNode
        nodeid: atomId
        kind: "AtomId".string
        label: st.typing.synthLabel.copy
        lineno: ln
        colno: co)
    seta: argType
    st.typing.nodeType.set key: assignId.u64 value: seta
    sete: argType
    st.typing.nodeType.set key: exprId.u64 value: sete
    atomT: argType
    if paramType > 0 then atomT = paramType
    setm: atomT
    st.typing.nodeType.set key: atomId.u64 value: setm
    hbsrc: (List String)
    takePendingBorrow :st dst: hbsrc
    hown: ztypes.zownership.owned
    if hbsrc.length > 0 when (typeIsReftype :st tid: argType) then hown = ztypes.zownership.borrowed
    v: st.reg.newVariable ztypeId: argType ownership: hown
    v.synthOrigin = (Option.some "anf".string)
    if hown == ztypes.zownership.borrowed then {
        hr0: hbsrc.get i: 0
        hbo: hr0.copy
        v.borrowOrigin = (Option.some hbo)
    }
    vid: v.variableId
    st.defineVar name: tname.stringview var: v
    # the hoisted temp is the user-written hoist made explicit: it borrows
    # its source path for the call scope (SHARED prefixes, leaf kind from
    # the side channel), so aliasing between arguments -- or with a live
    # view of the source -- conflicts exactly as the call-scoped locking
    # algorithm in ownership.pdoc requires
    # install only when the consumed side-channel path belongs to THIS
    # argument (its root atom): a stale residue from receiver evaluation
    # must stay drained-without-locks, or it would double the call's own
    # receiver locks under a temp holder
    if hown == ztypes.zownership.borrowed then {
        hrt9: rootNameOf :ast n: argNode
        okInstall9: false
        if hrt9.length > 0 when hbsrc.length > 0 then {
            h0c9: (hbsrc.get i: 0).copy
            if h0c9.stringview == hrt9.stringview then okInstall9 = true
        }
        if okInstall9 then {
            (installBorrowLocks
                :st
                src: hbsrc
                :vid
                leafShared: st.typing.pendingBorrowShared
                nodeid: (nodeId n: argNode)
                lineno: (nodeLine n: argNode)
                colno: (nodeCol n: argNode)
            )
        }
    }
    st.typing.defVariableId.set key: assignId.u64 value: vid
    if consumes then st.invalidate name: tname.stringview loc: (optionval.none ztypes.zsrcpos)
    return tname
}

# walkCallArgsHoist -- the user-call argument walk: type each argument, then
# hoist non-trivial ones into synth temps (mirrors _check_call_arguments).
# isConfMarkerId -- the (tid, name) child is an as-block conformance/satisfaction
# marker (not a data field) when a conformance row records it.
isConfMarkerId: function {conf: List ztypes.ZConformance tid: u64 name: StringView} out bool is {
    found: false
    with citer: conf.iterate do for row: citer loop {
        if row.implTypeId == tid when row.label.stringview == name then found = true
    }
    return found
}

# dataFieldNames -- a type's user-supplied data fields/params in order (the
# ztypecheck-side mirror of the emitter's recFieldLists): for a FUNCTION, all
# params; for a record/class, fnptr fields plus non-FUNCTION fields, excluding
# as-block constants (asConstClone) and conformance markers.
dataFieldNames: function {
    ast: Ast
    st: zenv.ZSymbolTable
    tid: u64
    names: List String
    ids: List u64
    nameIds: List u64
} is {
    isFn: false
    if (st.reg.typetypeOf typeId: tid) == ztypes.ztypetype.functionType then isFn = true
    # this type's conformance-marker labels, collected once (the per-field
    # probe below is a scan over these few names, not the whole table)
    mkNames8: (List String)
    if isFn == false then {
        with cfit8: st.typing.conformance.iterate do for crow8: cfit8 loop {
            if crow8.implTypeId == tid then mkNames8.append crow8.label.copy
        }
    }
    bd9: st.typing.childIndex.get key: tid
    match (
        bd9
    ) case some then {
        with rdit9: bd9.rows.iterate do for rdi9: rdit9 loop {
            tc: st.typing.typeChild.get i: rdi9
            cto: optU64Or o: (st.typing.childTypeById.get key: tc.childNameId) d: 0
            inc: false
            if isFn then {
                inc = true
            } else {
                fptr: false
                fpo: st.typing.childIsFnptrField.get key: tc.childNameId
                match (
                    fpo
                ) case some then {
                    fptr = fpo
                } case none then null
                if fptr then {
                    inc = true
                } else {
                    if cto > 0 when (st.reg.typetypeOf typeId: cto) != ztypes.ztypetype.functionType then {
                        isC: false
                        aco: st.typing.asConstClone.get key: cto
                        match (
                            aco
                        ) case some then {
                            isC = aco
                        } case none then null
                        isMk8: false
                        mi8: u64
                        cnBm8: ast.names.texts.get i: (tc.nameId - 1).u64
                        mn8: mkNames8.length
                        for mi8 < mn8 loop {
                            mv8: mkNames8.get i: mi8
                            if mv8.stringview == cnBm8.stringview then isMk8 = true
                            mi8 = mi8 + 1
                        }
                        if isC == false when isMk8 == false then inc = true
                    }
                }
            }
            if inc then {
                cnBx9: ast.names.texts.get i: (tc.nameId - 1).u64
                cnx: cnBx9.copy
                names.append cnx
                idx0: cto
                ids.append idx0
                nid0: tc.nameId
                nameIds.append nid0
            }
        }
    } case none then null
}

# missingCtorFields -- collect each required field/param (no default) of
# `funcId` that the provided labels / positional count do not cover, into
# missingNames/missingIds. The method receiver is implicitly bound; a
# construction's body-carrying FUNCTION-typed (fnptr) fields are auto-bound;
# native types have no required fields.
missingCtorFields: function {
    ast: Ast
    st: zenv.ZSymbolTable
    funcId: u64
    isCtor: bool
    provided: List String
    posCount: u64
    missingNames: List String
    missingIds: List u64
} is {
    fzNat9: false
    {
        fzo9: st.reg.typeById.get key: funcId
        match (
            fzo9
        ) case some then {
            if fzo9.isNative then fzNat9 = true
        } case none then null
    }
    if fzNat9 then return
    effId: funcId
    if isCtor then {
        crId: optU64Or o: (st.typing.childOfId parentTypeId: funcId nameId: wkCreate) d: 0
        if crId > 0 when (st.reg.typetypeOf typeId: crId) == ztypes.ztypetype.functionType then {
            crBody9: false
            crn9: st.typing.funcReturnNode.get key: crId
            match (
                crn9
            ) case some then {
                crBody9 = true
            } case none then null
            if crBody9 then effId = crId
        }
    }
    names: (List String)
    ids: (List u64)
    idsNm: (List u64)
    dataFieldNames :ast :st tid: effId :names :ids nameIds: idsNm
    pcnt: names.length
    if pcnt == 0 then return
    thisPn9: String
    {
        zoR: st.reg.typeById.get key: effId
        match (
            zoR
        ) case some then {
            thisPn9 = optStrOrEmpty o: zoR.thisParamName
        } case none then null
    }
    vpos: u64
    i: u64
    for i < pcnt loop {
        pname: names.get :i
        pcid: ids.get :i
        pnameId: idsNm.get :i
        i = i + 1
        isRecv9: false
        if pnameId == wkThis.u64 then isRecv9 = true
        if thisPn9.length > 0 when thisPn9.stringview == pname.stringview then isRecv9 = true
        if (isRecv9) == false then {
            posI: vpos
            vpos = vpos + 1
            need: true
            if isCtor when (st.reg.typetypeOf typeId: pcid) == ztypes.ztypetype.functionType then {
                # only a body-carrying fn type defaults the field (a bodyless
                # SPEC field requires the reference); record and class
                # constructions fill the omitted slot with the field type's
                # symbol (the fnptr-field fill in the emitter's create path)
                fhbOk9: optBoolOr o: (st.typing.fnHasBody.get key: pcid) d: false
                effTT9: st.reg.typetypeOf typeId: effId
                ctorFill9: false
                if effTT9 == ztypes.ztypetype.recordType then ctorFill9 = true
                if effTT9 == ztypes.ztypetype.classType then ctorFill9 = true
                if fhbOk9 when ctorFill9 then need = false
            }
            if (st.typing.hasChildDefaultId parentTypeId: effId nameId: pnameId) then need = false
            if need then {
                prov: false
                if posI < posCount then prov = true
                with piter: provided.iterate do for pv: piter loop {
                    if pv.stringview == pname.stringview then prov = true
                }
                if (prov) == false then {
                    missingNames.append pname.copy
                    missingIds.append pcid
                }
            }
        }
    }
}

# checkMissingCallArgs -- report each required field/param (no default) a call or
# construction did not provide, via missingCtorFields over the call's labeled
# and positional arguments.
checkMissingCallArgs: function {ast: Ast
    st: zenv.ZSymbolTable
    call: zast.CallData
    funcId: u64
    isCtor: bool
} is {
    mcb0: metaCreateBaseId :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    match (
        mcb0
    ) case some then {
        return
    } case none then null
    posCount: u64
    provided: (List String)
    with aiter: call.arguments.iterate do for argId9: aiter loop {
        arg: ast.nodes.get i: (argId9 - 1).u64
        match (
            arg
        ) case namedoperation then {
            an: zast.nameTextCopy :ast ref: arg.name
            if an.length == 0 then posCount = posCount + 1
            if an.length > 0 then provided.append an
        } else null
    }
    missingNames: (List String)
    missingIds: (List u64)
    missingCtorFields :ast :st :funcId :isCtor :provided :posCount :missingNames :missingIds
    mi: u64
    mn: missingNames.length
    for mi < mn loop {
        pname: missingNames.get i: mi
        pcid: missingIds.get i: mi
        mi = mi + 1
        tnm: typeNameOf :st tid: pcid
        tnc: tnm.copy
        pnc: pname.copy
        mm: "missing required argument '\{pnc}' (type: \{tnc})"
        (addError
            :st
            nodeid: call.nodeid
            lineno: call.lineno
            colno: call.colno
            e: zast.err.callError
            msg: mm
        )
    }
}

walkCallArgsHoist: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    call: zast.CallData
    funcId: u64
    isCtor: bool
    reportUnknown: bool
    recvImplicit: bool
} out String is {
    lockRoot: String
    st.typing.lastLockParamRoot = "".string
    argIdx: u64
    boundArgIds: (List u64)
    aiter: call.arguments.iterate
    for argId9: aiter loop {
        arg: ast.nodes.get i: (argId9 - 1).u64
        match (
            arg
        ) case namedoperation then {
            # a FUNCTION-typed field takes a method REFERENCE: its ctor
            # argument walks without the value-position auto-call coercion.
            useNC: false
            if isCtor then {
                pn0: zast.nameTextCopy :ast ref: arg.name
                if pn0.length > 0 then {
                    fco: st.typing.childOf pool: ast.names parentTypeId: funcId name: pn0.stringview
                    fcid: optU64Or o: fco d: 0
                    if fcid > 0 then {
                        if (st.reg.typetypeOf typeId: fcid) == ztypes.ztypetype.functionType then {
                            useNC = true

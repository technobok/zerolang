    return 0.u64
}

# checkIf -- walk an if: push the `if` scope, then a `if_branch` scope per clause
# and an `if_else` scope for the else; when every branch diverges (returns) the
# if resolves to never and marks the enclosing scope unreachable.
checkIf: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) ifnode: zast.IfData} out u64 is {
    ifMarker: st.pushBlock name: "if"
    nvId: optU64Or o: (lookupTyperef resolved: st.typing.resolved mainName: unitName base: "never") d: 0.u64
    branchTypes: (List of: u64)
    allDiverge: true
    cliter: ifnode.clauses.iterate
    for clause: cliter loop {
        bm: st.pushBlock name: "if_branch"
        bt9: checkClause st: st unitName: unitName unitBody: unitBody clause: clause
        btc: bt9
        branchTypes.append btc
        if (st.isUnreachable) then {
        } else {
            allDiverge = false
        }
        st.popTo marker: bm
    }
    hasElse: false
    match (
        ifnode.elseclause
    ) case some then {
        hasElse = true
        ebm: st.pushBlock name: "if_else"
        walkBody st: st unitName: unitName unitBody: unitBody bodyOpt: ifnode.elseclause
        et9: lastStmtTypeOpt st: st bodyOpt: ifnode.elseclause
        etc9: et9
        branchTypes.append etc9
        if (st.isUnreachable) then {
        } else {
            allDiverge = false
        }
        st.popTo marker: ebm
    } case none then {
        allDiverge = false
    }
    result: 0.u64
    if allDiverge then {
        if nvId > 0.u64 then {
            result = nvId
            setk: result
            st.typing.nodeType.set key: ifnode.nodeid.u64 value: setk
        } else {
        }
    } else {
        # An exhaustive (else-carrying) if is a value: the first completing
        # branch's type, diverging branches skipped (mirrors the match rule).
        if hasElse then {
            ti9: 0.u64
            tn9: branchTypes.length
            for while ti9 < tn9 loop {
                bt2: branchTypes.get i: ti9
                if bt2 == nvId then {
                } else {
                    if bt2 > 0.u64 then {
                        result = bt2
                        setv9: result
                        st.typing.nodeType.set key: ifnode.nodeid.u64 value: setv9
                        ti9 = tn9
                    } else {
                        ti9 = tn9
                    }
                }
                ti9 = ti9 + 1.u64
            }
        } else {
        }
    }
    st.popTo marker: ifMarker
    if allDiverge then {
        st.markUnreachable
    } else {
    }
    return result
}

# comparisonCoerceTarget -- the type a literal comparison operand coerces at:

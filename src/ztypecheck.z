                        # A generic non-FUNCTION dotted callee constructs its
                        # instance in place: the .str conversion form resolves
                        # the dotted path to the sized template, and the call
                        # mints/stamps the instance (only the Call node).
                        isGenD: false
                        {
                            gz2: st.reg.typeById.get key: dro
                            match (
                                gz2
                            ) case some then {
                                if gz2.isgeneric then {
                                    if gz2.typetype != ztypes.ztypetype.functionType then isGenD = true
                                }
                            } case none then null
                        }
                        if isGenD then {
                            (validateGenericTypeArgs
                                :ast
                                :st
                                :unitName
                                :call
                                tplId: dro
                                allowFrom: false
                            )
                            gres2: genericTypeConstruction :ast :st :unitName :call tplId: dro
                            if gres2 > 0 then return gres2
                        }
                        # A plain cross-unit class/record dotted construction
                        # (`unit.Type field: val`): the dotted callee resolved to
                        # a constructible type (not a function / tagged subtype /
                        # generic). Walk the ctor args (hoist + consume) and the
                        # value IS the constructed type, so the binding stamps.
                        dctt9: st.reg.typetypeOf typeId: dro
                        isCtorT9: false
                        if dctt9 == ztypes.ztypetype.classType then isCtorT9 = true
                        if dctt9 == ztypes.ztypetype.recordType then isCtorT9 = true
                        if isCtorT9 then {
                            if call.arguments.length > 0 then {
                                dcm9: st.pushCall
                                _wlr19: (walkCallArgsHoist
                                    :st
                                    :unitName
                                    :ast :unitBody
                                    :call
                                    funcId: dro
                                    isCtor: true
                                    reportUnknown: false
                                    recvImplicit: false
                                )
                                checkMissingCallArgs :ast :st :call funcId: dro isCtor: true
                                (st.typing.callKind.set
                                    key: call.nodeid.u64
                                    value: zast.callkind.recordCreate
                                )
                                st.popTo marker: dcm9

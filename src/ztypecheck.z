    if elemT9 > 0.u64 then {
        en9: typeNameOf st: st tid: elemT9
        isNull9: false
        if en9.stringview == "null" then { isNull9 = true } else {
        }
        if en9.length == 0.u64 then { isNull9 = true } else {
        }
        if isNull9 then {} else {
            lto9: lookupTyperef resolved: st.typing.resolved mainName: unitName base: "List"
            match (
                lto9
            ) case some then {
                lsubs9: (Map key: String value: u64)
                lk9: "of".string
                lv9: elemT9
                lsubs9.set key: lk9 value: lv9
                lsfx9: "_\{en9}"
                lmn9: "List\{lsfx9}"
                lmid9: mintMono st: st mainName: unitName name: lmn9.stringview templateId: lto9 subs: lsubs9 fallbackArg: 0.u64
                if lmid9 > 0.u64 then {
                    mintTemplateChains st: st mainName: unitName tname: "List" suffix: lsfx9.stringview firstA: elemT9 valA: 0.u64
                    mintCollectionChildren st: st mainName: unitName monoName: lmn9.stringview monoId: lmid9 templateName: "List" suffix: lsfx9.stringview elemArg: elemT9 valArg: 0.u64
                    setf9: lmid9

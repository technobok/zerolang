                    # through the standard ctor flow (mirrors the reference's
                    # generic record/class construction).
                    # an invalid type-argument list (unknown/duplicate already
                    # diagnosed) never drives field-bound inference; the
                    # single-diagnostic template resolution below stands
                    gmid: u64

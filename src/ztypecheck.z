                    # it (the overlay propagates out on pop); a lock/borrow
                    # parameter locks it for the call.
                    bn: bareAtomName :ast n: (ast.nodes.get i: (arg.operation - 1).u64)
                    if bn.length > 0 when (typeIsReftype :st tid: vt) then {
                        bvo: st.lookupVarId name: bn.stringview
                        match (
                            bvo
                        ) case some then {
                            if isTake then {
                                # ANY borrowed binding refuses the move (the
                                # view-family test predates element borrows)
                                if (isBorrowedVar :st vid: bvo) then {
                                    bnc7: bn.copy
                                    mb7: "Cannot move borrowed variable '\{bnc7}' into a taking argument — borrowed names stay bound to their source for the full scope; copy with '.copy' to keep the source"
                                    aid7: nodeId n: (ast.nodes.get i: (arg.operation - 1).u64)
                                    aln7: nodeLine n: (ast.nodes.get i: (arg.operation - 1).u64)
                                    acl7: nodeCol n: (ast.nodes.get i: (arg.operation - 1).u64)
                                    (addError
                                        :st
                                        nodeid: aid7
                                        lineno: aln7
                                        colno: acl7
                                        e: zast.err.ownerError
                                        msg: mb7
                                    )
                                } else {
                                    st.invalidate name: bn.stringview loc: takenHere
                                }
                            } else {
                                if isLockish then {
                                    (lockCallArg
                                        :st
                                        name: bn.stringview
                                        callId: call.nodeid.u64
                                        shared: false
                                        nodeid: (nodeId n: (ast.nodes.get i: (arg.operation - 1).u64))
                                        lineno: (nodeLine n: (ast.nodes.get i: (arg.operation - 1).u64))
                                        colno: (nodeCol n: (ast.nodes.get i: (arg.operation - 1).u64))
                                    )
                                    if lockRoot.length == 0 then lockRoot = bn.copy
                                    if isDeclLock then {
                                        xlc: bn.copy
                                        st.typing.lastLockParamRoot = xlc
                                    }
                                }
                            }
                        } case none then null
                    }
                } else {
                    # A construction or take parameter consumes the hoisted
                    # temp inside the call scope; a lock/borrow parameter
                    # locks it there.
                    consumes: false
                    if isTake then consumes = true
                    # a `.lock`-suffixed argument at a lock parameter locks
                    # its base and hoists a BORROWED view of it (the synth
                    # temp's origin is the base; the base's lock row lands
                    # in the call scope via the borrow-lock install).
                    if isLockish then {
                        lsb9: lockSuffixBase :ast n: (ast.nodes.get i: (arg.operation - 1).u64)
                        if lsb9.length > 0 then {
                            drainPendingBorrow :st
                            lsbc9: lsb9.copy
                            st.typing.pendingBorrowPath.append lsbc9
                            if lockRoot.length == 0 then lockRoot = lsb9.copy
                            if isDeclLock then {
                                xlc9: lsb9.copy
                                st.typing.lastLockParamRoot = xlc9
                            }
                        }
                    }
                    # a plain field-path argument behaves as its user-
                    # written hoist would: seed the borrow side channel with
                    # the real source tuple so the synth temp installs the
                    # spec's SHARED-prefix + EXCLUSIVE-leaf locks on it
                    if isLockish when (typeIsReftype :st tid: vt) then {
                        if st.typing.pendingBorrowPath.length == 0 then {
                            an9: ast.nodes.get i: (arg.operation - 1).u64
                            src9: (List String)
                            appendValueTuple :ast n: an9 dst: src9
                            if src9.length > 0 then {
                                rt9: rootNameOf :ast n: an9
                                rvo9: st.lookupVarId name: rt9.stringview
                                match (
                                    rvo9
                                ) case some then {
                                    drainPendingBorrow :st
                                    si9: u64
                                    sn9: src9.length
                                    for si9 < sn9 loop {
                                        se9: src9.get i: si9
                                        sec9: se9.copy
                                        st.typing.pendingBorrowPath.append sec9
                                        si9 = si9 + 1
                                    }
                                } case none then null
                            }
                        }
                    }
                    hadPending: false
                    if st.typing.pendingBorrowPath.length > 0 then hadPending = true
                    tnm: (hoistArg
                        :ast
                        :st
                        argNode: (ast.nodes.get i: (arg.operation - 1).u64)
                        argType: vt
                        paramType: pt
                        :consumes
                    )
                    if (hadPending) == false then {
                        if isLockish when (typeIsReftype :st tid: vt) then {
                            (lockCallArg
                                :st
                                name: tnm.stringview
                                callId: call.nodeid.u64
                                shared: false
                                nodeid: (nodeId n: (ast.nodes.get i: (arg.operation - 1).u64))
                                lineno: (nodeLine n: (ast.nodes.get i: (arg.operation - 1).u64))
                                colno: (nodeCol n: (ast.nodes.get i: (arg.operation - 1).u64))
                            )
                        }
                    }
                }
            }
            argIdx = argIdx + 1
        } else null
    }
    return lockRoot
}

# checkBoxConstruction -- `Box from: val`: the value's (materialised) type
# binds t; the argument is consumed (hoisted first when non-trivial); the
# instance carries create plus the element type's children copied for
# transparent member access. Heap passthrough (List/Map boxing) lands when
# an example needs it.
checkBoxConstruction: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    call: zast.CallData
    tplId: u64
} out u64 is {
    fnd: false
    vt: u64
    with aiter: call.arguments.iterate do for argId9: aiter loop {
        arg: ast.nodes.get i: (argId9 - 1).u64
        match (
            arg
        ) case namedoperation then {
            if (fnd) == false then {
                an: zast.nameTextCopy :ast ref: arg.name
                if an.stringview != "t" then {
                    if an.stringview != "from" then {
                        anc7: an.copy
                        mbx7: "the builtin Box constructs with 'from:'; unknown argument '\{anc7}'"
                        bxid7: nodeId n: (ast.nodes.get i: (arg.operation - 1).u64)
                        bxln7: nodeLine n: (ast.nodes.get i: (arg.operation - 1).u64)
                        bxcl7: nodeCol n: (ast.nodes.get i: (arg.operation - 1).u64)
                        (addError
                            :st
                            nodeid: bxid7
                            lineno: bxln7
                            colno: bxcl7
                            e: zast.err.callError
                            msg: mbx7
                        )
                    }
                    fnd = true
                    avt: (checkValue
                        :st
                        :unitName
                        :ast
                        :unitBody
                        node: (ast.nodes.get i: (arg.operation - 1).u64)
                    )
                    vt = materialiseLiteral :ast :st :unitName t: avt
                    if vt > 0 then {
                        if (argIsTrivial :ast op: (ast.nodes.get i: (arg.operation - 1).u64)) then {
                            iid: innermostNodeId :ast n: (ast.nodes.get i: (arg.operation - 1).u64)
                            if iid > 0 then {
                                setbl: vt
                                st.typing.nodeType.set key: iid.u64 value: setbl
                            }
                            bn: bareAtomName :ast n: (ast.nodes.get i: (arg.operation - 1).u64)
                            if bn.length > 0 when (typeIsReftype :st tid: vt) then {
                                bvo8: st.lookupVarId name: bn.stringview
                                match (
                                    bvo8
                                ) case some then {
                                    if (isViewVar :ast :st vid: bvo8) then {
                                        bnc8: bn.copy
                                        mb8: "Cannot move borrowed variable '\{bnc8}' into a box — borrowed names stay bound to their source for the full scope; copy with '.copy' to keep the source"
                                        aid8: nodeId n: (ast.nodes.get i: (arg.operation - 1).u64)
                                        aln8: nodeLine n: (ast.nodes.get i: (arg.operation - 1).u64)
                                        acl8: nodeCol n: (ast.nodes.get i: (arg.operation - 1).u64)
                                        (addError
                                            :st
                                            nodeid: aid8
                                            lineno: aln8
                                            colno: acl8
                                            e: zast.err.ownerError
                                            msg: mb8
                                        )
                                    } else {
                                        st.invalidate name: bn.stringview loc: takenHere
                                    }
                                } case none then {
                                    st.invalidate name: bn.stringview loc: takenHere
                                }
                            }
                        } else {
                            (hoistArg
                                :ast
                                :st
                                argNode: (ast.nodes.get i: (arg.operation - 1).u64)
                                argType: vt
                                paramType: 0
                                consumes: true
                            )
                        }
                    }
                }
            }
        } else null
    }
    if vt == 0 then return 0
    tn: typeNameOf :st tid: vt
    mname: "Box_\{tn}"
    subs: (Map String value: u64)
    sk: "t".string
    sv: vt
    subs.set key: sk value: sv
    vsJ9: (Map String value: u64)
    mid: (getOrMintSpec
        :ast
        ty: st.typing
        reg: st.reg
        mainName: unitName
        name: mname.stringview
        templateId: tplId
        :subs
        valSubs: vsJ9
        fallbackArg: 0
    )
    if mid == 0 then return 0
    st.reg.setIsBox typeId: mid
    st.reg.setIsHeapAllocated typeId: mid
    bdtor9: "z_\{mname}_destroy"
    st.reg.setDestructorName typeId: mid name: bdtor9.stringview
    if (st.typing.childCount parentTypeId: mid) <= 0 then {
        crn: "\{mname}.create"
        crId: st.reg.newType name: crn.stringview typetype: ztypes.ztypetype.functionType
        st.typing.setChildId parentTypeId: mid nameId: wkCreate childTypeId: crId
        # Stage the element's children first: setChild appends to the very
        # table being iterated.
        cNames2: (List String)
        cIds2: (List u64)
        cNid2: (List u64)
        {
            bxb9: st.typing.childIndex.get key: vt
            match (
                bxb9
            ) case some then {
                with bxit9: bxb9.rows.iterate do for bxr9: bxit9 loop {
                    tc2: st.typing.typeChild.get i: bxr9
                    cto2: st.typing.childTypeById.get key: tc2.childNameId
                    match (
                        cto2
                    ) case some then {
                        cnB4: ast.names.texts.get i: (tc2.nameId - 1).u64
                        cn2: cnB4.copy
                        cNames2.append cn2
                        cid3: cto2
                        cIds2.append cid3
                        nid2: tc2.nameId
                        cNid2.append nid2
                    } case none then null
                }
            } case none then null
        }
        bi: u64
        bn2: cNames2.length
        for bi < bn2 loop {
            chn: cNames2.get i: bi
            chi: cIds2.get i: bi
            chnId: cNid2.get i: bi
            ext9: st.typing.childOfId parentTypeId: mid nameId: chnId
            match (
                ext9
            ) case some then null case none then {
                (st.typing.setChildId
                    parentTypeId: mid
                    nameId: (zast.poolFind pool: ast.names text: chn.stringview).u64
                    childTypeId: chi
                )
            }
            bi = bi + 1
        }
    }
    bcal: nodeId n: (ast.nodes.get i: (call.callable - 1).u64)
    if bcal > 0 then {
        setbt: tplId
        st.typing.nodeType.set key: bcal.u64 value: setbt
    }
    setbc: mid
    st.typing.nodeType.set key: call.nodeid.u64 value: setbc
    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.boxCreate
    return mid
}

# callableDottedResult -- a dotted callable resolves through the dotted-path
# walk (no auto-call coercion -- callable position wants the function itself);
# the base is typed and stamped there. none = the callable is not a dotted
# path; some 0 = dotted but unresolved (e.g. a data block's `.index`), which
# leaves the call untyped with its arguments unwalked, like the reference.
callableDottedResult: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    n: Node
} out optionval u64 is {
    match (
        n
    ) case dottedpath then {
        r: checkDotted :st :unitName :ast :unitBody dp: n coerce: false
        return (optionval.some r)
    } else {
        return (optionval.none u64)
    }
}

# returnedBareFieldName -- `return <base>.<field>` where the member is a
# non-FUNCTION field whose type is a reftype or a generic param: the bare
# read escapes a shallow copy of storage the owner still frees (and a
# generic param may instantiate to one). Returns the field name for the
# diagnostic; "" when the return shape is fine.
returnedBareFieldName: function {ast: Ast st: zenv.ZSymbolTable n: Node} out String is {
    match (
        n
    ) case expression then {
        return (returnedBareFieldName :ast :st n: (ast.nodes.get i: (n.expression - 1).u64))
    } case dottedpath then {
        bfc9: atomName :ast n: (ast.nodes.get i: (n.child - 1).u64)
        bfcId9: atomNameId :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if bfc9.length == 0 then return "".string
        if (isStripMarker name: bfc9.stringview) then return "".string
        bfp9: nodeId n: (ast.nodes.get i: (n.parent - 1).u64)
        bft9: optU64Or o: (st.typing.nodeType.get key: bfp9.u64) d: 0
        if bft9 == 0 then return "".string
        bfo9: st.typing.childOfId parentTypeId: bft9 nameId: bfcId9
        match (
            bfo9
        ) case some then {
            if (st.reg.typetypeOf typeId: bfo9) == ztypes.ztypetype.functionType then return "".string
            if (st.reg.typetypeOf typeId: bfo9) == ztypes.ztypetype.genericParam then return (bfc9.copy)
            if (typeIsReftype :st tid: bfo9) then return (bfc9.copy)
            return "".string
        } case none then {
            return "".string
        }
    } else {
        return "".string
    }
}

# unresolvedBareCallable -- the bare-atom callable name of a call-shaped
# value that resolves to NOTHING (no local, no own-unit function, no system
# name, no walkable type): the checker's silent args-walked fallthrough
# otherwise leaves the binding untyped and the emitter prints a marker.
unresolvedBareCallable: function {ast: Ast
    st: zenv.ZSymbolTable
    unitName: StringView
    n: Node
} out String is {
    match (
        n
    ) case expression then {
        return (unresolvedBareCallable
            :ast
            :st
            :unitName
            n: (ast.nodes.get i: (n.expression - 1).u64)
        )
    } case call then {
        ubc9: atomName :ast n: (ast.nodes.get i: (n.callable - 1).u64)
        if ubc9.length == 0 then return "".string
        ubv9: st.lookupVarId name: ubc9.stringview
        match (
            ubv9
        ) case some then {
            return "".string
        } case none then null
        ubk9: "\{unitName}.\{ubc9}"
        ubr9: resolvedByKey :ast ty: st.typing reg: st.reg key: ubk9
        match (
            ubr9
        ) case some then {
            return "".string
        } case none then null
        ubw9: (walkLookupTyperef
            :ast
            ty: st.typing
            reg: st.reg
            currentUnit: unitName
            base: ubc9.stringview
        )
        match (
            ubw9
        ) case some then {
            return "".string
        } case none then null
        ubs9: resolveSystemChild :ast ty: st.typing reg: st.reg name: ubc9.stringview
        match (
            ubs9
        ) case some then {
            return "".string
        } case none then null
        return (ubc9.copy)
    } else {
        return "".string
    }
}

# checkCall -- type a call. C1 handles the `return <value>` control-flow form:
# stamp the callable atom with return's type, mark the call RETURN, walk the
# return value, and resolve the call to `never`. Other call kinds land later.
checkCall: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    call: zast.CallData
} out u64 is {
    result: u64
    cn: atomName :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    if cn.stringview == "return" then {
        rtOpt: walkLookupTyperef :ast ty: st.typing reg: st.reg currentUnit: unitName base: "return"
        match (
            rtOpt
        ) case some then {
            calid: nodeId n: (ast.nodes.get i: (call.callable - 1).u64)
            st.typing.nodeType.set key: calid.u64 value: rtOpt
        } case none then null
        st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.returnCall
        aiter: call.arguments.iterate
        for argId9: aiter loop {
            arg: ast.nodes.get i: (argId9 - 1).u64
            match (
                arg
            ) case namedoperation then {
                argT9: (checkValue
                    :st
                    :unitName
                    :ast
                    :unitBody
                    node: (ast.nodes.get i: (arg.operation - 1).u64)
                )
                bfn9: returnedBareFieldName :ast :st n: (ast.nodes.get i: (arg.operation - 1).u64)
                if st.typing.currentReturnsBorrow then bfn9 = "".string
                if bfn9.length > 0 then {
                    mbf9: "Cannot return field '\{bfn9}' as a bare read — the owner still frees it; return '\{bfn9}.copy' (duplicate) or '\{bfn9}.take' (move out)"
                    bfid9: nodeId n: (ast.nodes.get i: (arg.operation - 1).u64)
                    bfln9: nodeLine n: (ast.nodes.get i: (arg.operation - 1).u64)
                    bfcl9: nodeCol n: (ast.nodes.get i: (arg.operation - 1).u64)
                    (addError
                        :st
                        nodeid: bfid9
                        lineno: bfln9
                        colno: bfcl9
                        e: zast.err.ownerError
                        msg: mbf9
                    )
                }
                expR9: st.typing.currentReturnTypeId
                if expR9 > 0 when argT9 > 0 then {
                    if (typesCompatible :ast :st :unitName a: argT9 b: expR9) == false then {
                        en9: typeNameOf :st tid: expR9
                        an9: typeNameOf :st tid: argT9
                        enc9: en9.copy
                        anc9: an9.copy
                        m4: "return type mismatch: function expects \{enc9}, got \{anc9}"
                        rvid9: nodeId n: (ast.nodes.get i: (arg.operation - 1).u64)
                        rvln9: nodeLine n: (ast.nodes.get i: (arg.operation - 1).u64)
                        rvcl9: nodeCol n: (ast.nodes.get i: (arg.operation - 1).u64)
                        (addError
                            :st
                            nodeid: rvid9
                            lineno: rvln9
                            colno: rvcl9
                            e: zast.err.typeError
                            msg: m4
                        )
                    }
                }
            } else null
        }
        nvOpt: walkLookupTyperef :ast ty: st.typing reg: st.reg currentUnit: unitName base: "never"
        match (
            nvOpt
        ) case some then {
            result = nvOpt
            setk: result
            st.typing.nodeType.set key: call.nodeid.u64 value: setk
        } case none then null
    } else {
        # A regular call. A dotted callable resolves through the dotted-path
        # walk first; an unresolved member bails with the args unwalked. A
        # bare-name callable: a non-generic user function pushes a call scope
        # and resolves to its return type; a generic callee (e.g. print) infers
        # a clone; an unresolvable callable just has its args walked (its
        # callable/result/mono are out of the own+system+collections filter).
        # A parenthesized construction in callable position re-applies its
        # init arguments: the value is the constructed type.
        isWrapCall: (zast.kindOf :ast id: call.callable) == zast.astkind.expression
        if isWrapCall then {
            xq119: ast.nodes.get i: (call.callable - 1).u64
            wcv: checkValue :st :unitName :ast :unitBody node: xq119
            if wcv > 0 then {
                # A non-FUNCTION wrapped callee is the paren-mono construction
                # form: value args ride the standard ctor walk (call scope,
                # hoists, consumption); arg-less stays a bare construction.
                isWType: true
                if (st.reg.typetypeOf typeId: wcv) == ztypes.ztypetype.functionType then isWType = false
                # List/Map have their own create paths in the reference --
                # no standard ctor scope for their paren-construction args.
                wgix9: u64
                {
                    wgo9: st.reg.typeById.get key: wcv
                    match (
                        wgo9
                    ) case some then {
                        wgi9: wgo9.genericOriginId
                        match (
                            wgi9
                        ) case some then {
                            wgix9 = wgi9
                        } case none then null
                    } case none then null
                }
                if wgix9 > 0 then {
                    if wgix9 == (builtinTidTc :ast :st base: "List") then isWType = false
                    if wgix9 == (builtinTidTc :ast :st base: "Map") then isWType = false
                }
                if isWType when call.arguments.length > 0 then {
                    wcm: st.pushCall
                    _wlr09: (walkCallArgsHoist
                        :st
                        :unitName
                        :ast :unitBody
                        :call
                        funcId: wcv
                        isCtor: true
                        reportUnknown: false
                        recvImplicit: false
                    )
                    checkMissingCallArgs :ast :st :call funcId: wcv isCtor: true
                    st.popTo marker: wcm
                    wck: wcv
                    wcvv: true
                    st.typing.constructedTypes.set key: wck value: wcvv
                } else {
                    witer: call.arguments.iterate
                    for wargId9: witer loop {
                        warg: ast.nodes.get i: (wargId9 - 1).u64
                        match (
                            warg
                        ) case namedoperation then {
                            (checkValue
                                :st
                                :unitName
                                :ast
                                :unitBody
                                node: (ast.nodes.get i: (warg.operation - 1).u64)
                            )
                        } else null
                    }
                }
                setwc: wcv
                st.typing.nodeType.set key: call.nodeid.u64 value: setwc
                return wcv
            }
        }
        mcb: metaCreateBaseId :ast n: (ast.nodes.get i: (call.callable - 1).u64)
        mcid: u32
        match (
            mcb
        ) case some then {
            mcid = mcb
        } case none then null
        if mcid > 0 when st.typing.currentThisName.length > 0 then {
            # `meta.create` constructs the enclosing type: the raw allocator's
            # params are the type's field children, so the ctor arg walk
            # (hoists, coercion, field consumption) rides funcId = the type.
            mctn: st.typing.currentThisName.copy
            mto: (walkLookupTyperef
                :ast
                ty: st.typing
                reg: st.reg
                currentUnit: unitName
                base: mctn.stringview
            )
            mtid: optU64Or o: mto d: 0
            if mtid > 0 then {
                setmb: mtid
                st.typing.nodeType.set key: mcid.u64 value: setmb
                mcm: st.pushCall
                mclr: (walkCallArgsHoist
                    :st
                    :unitName
                    :ast :unitBody
                    :call
                    funcId: mtid
                    isCtor: true
                    reportUnknown: false
                    recvImplicit: false
                )
                checkMissingCallArgs :ast :st :call funcId: mtid isCtor: true
                st.popTo marker: mcm
                setmc: mtid
                st.typing.nodeType.set key: call.nodeid.u64 value: setmc
                return mtid
            }
        }
        xq109: ast.nodes.get i: (call.callable - 1).u64
        dro: callableDottedResult :st :unitName :ast :unitBody n: xq109
        match (
            dro
        ) case some then {
            if dro == 0 then {
                return 0
            } else {
                # A non-generic FUNCTION member dispatches as a user method
                # call: call scope, arg walk, the callee's return, and the
                # borrow-return report.
                isMethodFn: false
                {
                    mzo: st.reg.typeById.get key: dro
                    match (
                        mzo
                    ) case some then {
                        if mzo.typetype == ztypes.ztypetype.functionType then {
                            if (mzo.isgeneric) == false then isMethodFn = true
                        }
                    } case none then null
                }
                if isMethodFn then {
                    tdcb: createDottedBaseId :ast n: (ast.nodes.get i: (call.callable - 1).u64)
                    tdcid: u32
                    match (
                        tdcb
                    ) case some then {
                        tdcid = tdcb
                    } case none then null
                    isBorrowForm: false
                    bdcb: borrowDottedBaseId :ast n: (ast.nodes.get i: (call.callable - 1).u64)
                    match (
                        bdcb
                    ) case some then {
                        tdcid = bdcb
                        isBorrowForm = true
                    } case none then null
                    if tdcid > 0 then {
                        tdo: optU64Or o: (st.typing.nodeType.get key: tdcid.u64) d: 0
                        isTd: false
                        if (typedefBaseOf :ast :st :unitName tid: tdo) > 0 then isTd = true
                        if (typedefBaseMangledOf :ast :st :unitName tid: tdo) > 0 then isTd = true
                        if isTd when isBorrowForm then {
                            return (checkTypedefBorrow
                                :st
                                :unitName
                                :ast
                                :unitBody
                                :call
                                tdId: tdo
                            )
                        }
                        if isTd then {
                            return (checkTypedefCreate
                                :st
                                :unitName
                                :ast
                                :unitBody
                                :call
                                tdId: tdo
                            )
                        }
                        pjtt: st.reg.typetypeOf typeId: tdo
                        isProj: false
                        if pjtt == ztypes.ztypetype.facetType then isProj = true
                        if pjtt == ztypes.ztypetype.protocolType then isProj = true
                        if isProj then {
                            pjTake: false
                            pjBorrow: false
                            if pjtt == ztypes.ztypetype.protocolType then {
                                xq99: ast.nodes.get i: (call.callable - 1).u64
                                pjcn: dottedChildName :ast n: xq99
                                if pjcn.stringview == "create" then pjTake = true
                                if pjcn.stringview == "borrow" then pjBorrow = true
                            }
                            return (checkProjectionCreate
                                :st
                                :unitName
                                :ast :unitBody
                                :call

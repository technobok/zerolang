# Type checker, ported from src/ztypecheck.py.
#
# Slice 4.5a: registers one UNIT type per unit (the `unit` table) and resolves
# the MAIN unit's top-level FUNCTION definition signatures into the type
# registry -- each function plus its parameter children, with referenced
# parameter types registered as shallow named shells. Mirrors the reference
# `resolve_only_main` capability (no body walk, no generics, no system-wide
# resolution); the SQL `types` / `type_children` tables read the result,
# filtered to the example's own unit. Data blocks, records, variants, classes,
# generics and body checking arrive in later slices.
#
# The registry is created by the caller and threaded in (not stored on the
# ZTyping container), mirroring the reference's module-level type table: the
# SQL dumper reads it as a separate argument.

Node: zast.Node

# unitLabel -- a unit/definition namedoperation label as an owned String
# ("" when the operation carries no label).
unitLabel: function {o: Option String} out String is {
    match (
        o
    ) case some then {
        return o.copy
    } case none then {
        return "".string
    }
}

# unitdefNodeId -- the nodeid of a unitdef Node (0 when not a unitdef).
unitdefNodeId: function {n: Node} out u32 is {
    match (
        n
    ) case unitdef then {
        return n.nodeid
    } else {
        return 0
    }
}

# nodeId -- the nodeid of an arbitrary type-ref / definition Node. Covers the
# kinds a type expression or method def can take (atom / labelvalue / dotted /
# expression / call / functiondef); 0 otherwise (the stamp is then a no-op row
# the typed_nodes JOIN drops).
nodeId: function {n: Node} out u32 is {
    match (
        n
    ) case atomid then {
        return n.nodeid
    } case labelvalue then {
        return n.nodeid
    } case binop then {
        return n.nodeid
    } case dottedpath then {
        return n.nodeid
    } case expression then {
        return n.nodeid
    } case call then {
        return n.nodeid
    } case functiondef then {
        return n.nodeid
    } case assignment then {
        return n.nodeid
    } case reassignment then {
        return n.nodeid
    } else {
        return 0
    }
}

# nodeLine / nodeCol -- the source position of a value-expression Node. Covers
# the operation kinds a call argument can take; 0 otherwise.
nodeLine: function {n: Node} out u32 is {
    match (
        n
    ) case atomid then {
        return n.lineno
    } case labelvalue then {
        return n.lineno
    } case dottedpath then {
        return n.lineno
    } case expression then {
        return n.lineno
    } case call then {
        return n.lineno
    } case binop then {
        return n.lineno
    } case atomstring then {
        return n.lineno
    } else {
        return 0
    }
}

nodeCol: function {n: Node} out u32 is {
    match (
        n
    ) case atomid then {
        return n.colno
    } case labelvalue then {
        return n.colno
    } case dottedpath then {
        return n.colno
    } case expression then {
        return n.colno
    } case call then {
        return n.colno
    } case binop then {
        return n.colno
    } case atomstring then {
        return n.colno
    } else {
        return 0
    }
}

# atomName -- the name of an atom Node (atomid / labelvalue) as an owned String,
# "" for anything else. Matching the Node param narrows it cleanly (the proven
# simple-param pattern), so callers pass a field/arg projection without worrying
# about path-subject narrowing.
atomName: function {n: Node} out String is {
    match (
        n
    ) case atomid then {
        return n.name.copy
    } case labelvalue then {
        return n.name.copy
    } else {
        return "".string
    }
}

# addError -- append a typecheck diagnostic to the typing's error list,
# deduped by node position so a spec resolved more than once reports once.
# addResolveError -- a diagnostic raised from the resolution core, which
# holds no source node: location-free, deduped by message.
addResolveError: function {ty: ztyping.ZTyping e: zast.err msg: String} is {
    dup9: false
    with eit9: ty.errors.iterate do for pe9: eit9 loop {
        if pe9.msg.stringview == msg.stringview then dup9 = true
    }
    if (dup9) == false then {
        en9: "".string
        eh9: "".string
        ty.errors.append (zast.ErrorData
            nodeid: 0
            lineno: 0
            colno: 0
            width: 1
            err: e
            msg: msg.copy
            fsno: 0
            note: en9
            hint: eh9
        )
        ty.isError = true
    }
}

# stampGate -- a body-walk node stamp that suppresses GENERIC_PARAM values
# during a generic template walk: the emitter re-walks the shared template
# AST per instance and must not see template-time param stamps.
stampGate: function {st: zenv.ZSymbolTable nid: u32 tid: u64} is {
    if st.typing.suppressParamStamps then {
        if (st.reg.typetypeOf typeId: tid) == ztypes.ztypetype.GENERIC_PARAM then return
    }
    sv9: tid
    st.typing.nodeType.set key: nid.u64 value: sv9
}

addErrorH: function {
    st: zenv.ZSymbolTable
    nodeid: u32
    lineno: u32
    colno: u32
    e: zast.err
    msg: String
    note: String
    hint: String
    width: u32
} is {
    dup: false
    with it: st.typing.errors.iterate do for prev: it loop {
        if prev.nodeid == nodeid when prev.lineno == lineno when prev.colno == colno when prev.msg.stringview == msg.stringview then {
            dup = true
        }
    }
    if (dup) == false then {
        st.typing.errors.append (zast.ErrorData
            :nodeid
            :lineno
            :colno
            :width
            err: e
            msg: msg.copy
            fsno: 0
            note: note.copy
            hint: hint.copy
        )
        st.typing.isError = true
    }
}

addError: function {
    st: zenv.ZSymbolTable
    nodeid: u32
    lineno: u32
    colno: u32
    e: zast.err
    msg: String
} is {
    en9: "".string
    eh9: "".string
    addErrorH :st :nodeid :lineno :colno :e :msg note: en9 hint: eh9 width: 1
}

# isBorrowedVar -- true when the variable id is bound BORROWED (a borrowed
# parameter or a genuine borrowed local). Reliable now that pendingBorrowPath
# no longer leaks a sub-expression's borrow into an owned binding.
isBorrowedVar: function {st: zenv.ZSymbolTable vid: u64} out bool is {
    ow: st.typing.variableOwnership.get key: vid
    isB9: false
    match (
        ow
    ) case some then {
        if ow == ztypes.zownership.BORROWED then isB9 = true
    } case none then {
    }
    return isB9
}

# isNumericTid -- a concrete integer/float type id (literal-coercion target).
isNumericTid: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry tid: u64} out bool is {
    if tid == 0 then return false
    if tid == (builtinTidT :ty :reg base: "i8") then return true
    if tid == (builtinTidT :ty :reg base: "i16") then return true
    if tid == (builtinTidT :ty :reg base: "i32") then return true
    if tid == (builtinTidT :ty :reg base: "i64") then return true
    if tid == (builtinTidT :ty :reg base: "i128") then return true
    if tid == (builtinTidT :ty :reg base: "u8") then return true
    if tid == (builtinTidT :ty :reg base: "u16") then return true
    if tid == (builtinTidT :ty :reg base: "u32") then return true
    if tid == (builtinTidT :ty :reg base: "u64") then return true
    if tid == (builtinTidT :ty :reg base: "u128") then return true
    if tid == (builtinTidT :ty :reg base: "f32") then return true
    if tid == (builtinTidT :ty :reg base: "f64") then return true
    return false
}

# isViewFamilyTid -- a borrowed-view type: OptionView/ListView/MapEntry monos
# (generic-origin keyed) or the non-generic StringView/ByteView views. A view
# result is a borrow into its parent container/string: the binding holds a
# SHARED lock on the parent and the payload cannot be moved out.
isViewFamilyTid: function {st: zenv.ZSymbolTable tid: u64} out bool is {
    if tid == 0 then return false
    if tid == (builtinTidT ty: st.typing reg: st.reg base: "StringView") then return true
    if tid == (builtinTidT ty: st.typing reg: st.reg base: "ByteView") then return true
    vog9: 0.u64
    {
        vt9: st.reg.typeById.get key: tid
        match (
            vt9
        ) case some then {
            vgo9: vt9.genericOriginId
            match (
                vgo9
            ) case some then {
                vog9 = vgo9
            } case none then {}
        } case none then {}
    }
    if vog9 == 0 then return false
    if vog9 == (builtinTidT ty: st.typing reg: st.reg base: "OptionView") then return true
    if vog9 == (builtinTidT ty: st.typing reg: st.reg base: "ListView") then return true
    if vog9 == (builtinTidT ty: st.typing reg: st.reg base: "MapEntry") then return true
    return false
}

# isViewVar -- a borrowed binding whose DECLARED type is a view (OptionView
# from Map.get, StringView, ...): its payload aliases the parent's storage,
# so moving the (narrowed) payload out would drain the parent. Borrowed
# non-view bindings (a protocol call's fresh result bound conservatively)
# keep the pre-existing move semantics.
isViewVar: function {st: zenv.ZSymbolTable vid: u64} out bool is {
    if (isBorrowedVar :st :vid) == false then return false
    vzo9: st.typing.variableZtype.get key: vid
    match (
        vzo9
    ) case some then {
        return (isViewFamilyTid :st tid: vzo9)
    } case none then {
        return false
    }
}

# isContainerReaderCall -- a synthesized container method known not to
# mutate its receiver: the call's receiver lock is SHARED so readers
# coexist with live views (many readers XOR one writer XOR one exclusive
# iterator). Writers and user methods (opaque bodies) stay EXCLUSIVE.
isContainerReaderCall: function {st: zenv.ZSymbolTable recvTid: u64 mname: StringView} out bool is {
    if recvTid == 0 then return false
    base9: recvTid
    {
        rt9: st.reg.typeById.get key: recvTid
        match (
            rt9
        ) case some then {
            rg9: rt9.genericOriginId
            match (
                rg9
            ) case some then {
                base9 = rg9
            } case none then {}
        } case none then {}
    }
    if base9 == (builtinTidT ty: st.typing reg: st.reg base: "Map") then {
        if mname == "get" then return true
        if mname == "has" then return true
        if mname == "length" then return true
        if mname == "capacity" then return true
        if mname == "copy" then return true
        return false
    }
    if base9 == (builtinTidT ty: st.typing reg: st.reg base: "Set") then {
        if mname == "has" then return true
        if mname == "length" then return true
        if mname == "capacity" then return true
        if mname == "copy" then return true
        return false
    }
    if base9 == (builtinTidT ty: st.typing reg: st.reg base: "List") then {
        if mname == "get" then return true
        if mname == "contains" then return true
        if mname == "length" then return true
        if mname == "capacity" then return true
        if mname == "copy" then return true
        return false
    }
    if base9 == (builtinTidT ty: st.typing reg: st.reg base: "String") then {
        if mname == "length" then return true
        if mname == "compare" then return true
        if mname == "copy" then return true
        return false
    }
    return false
}

# typesCompatible -- compare two type ids: identity, never (divergent) actual,
# generic-param pairs, literal/numeric coercion (literal_int/float -> concrete
# numerics), and an asymmetric typedef-base walk on `a`.
typesCompatible: function {st: zenv.ZSymbolTable unitName: StringView a: u64 b: u64} out bool is {
    if a == b then return true
    if (st.reg.typetypeOf typeId: a) == ztypes.ztypetype.NEVER then return true
    if (st.reg.typetypeOf typeId: a) == ztypes.ztypetype.GENERIC_PARAM when (st.reg.typetypeOf typeId: b) == ztypes.ztypetype.GENERIC_PARAM then {
        # Any two type parameters are template-compatible: params resolve to
        # canonical per-(template,param) tids and the per-instance clone
        # checks are the concrete backstop.
        return true
    }
    aLit9: isLiteralTypeId :st tid: a
    bLit9: isLiteralTypeId :st tid: b
    if aLit9 when bLit9 then return true
    if aLit9 then {
        if (isNumericTid ty: st.typing reg: st.reg tid: b) then return true
    }
    if bLit9 then {
        if (isNumericTid ty: st.typing reg: st.reg tid: a) then return true
    }
    cur9: a
    for cur9 > 0 loop {
        nb9: typedefBaseOf :st :unitName tid: cur9
        if nb9 == 0 then return false
        if nb9 == b then return true
        cur9 = nb9
    }
    return false
}

# byteOf -- the byte at index i (0 when out of range).
byteOf: function {s: StringView i: u64} out u8 is {
    bo: s.byteAt i
    match (
        bo
    ) case some then {
        return bo
    } case none then {
    }
    return 0
}

# levenshtein -- byte-level edit distance (two-row DP), for did-you-mean.
levenshtein: function {a: StringView b: StringView} out u64 is {
    na: a.length
    nb: b.length
    if na == 0 then return nb
    if nb == 0 then return na
    prev: (List u64)
    j0: 0.u64
    for j0 <= nb loop {
        jv: j0
        prev.append jv
        j0 = j0 + 1
    }
    i: 0.u64
    for i < na loop {
        cur: (List u64)
        cur.append (i + 1)
        ab: byteOf s: a :i
        j: 0.u64
        for j < nb loop {
            bb: byteOf s: b i: j
            cost: 1.u64
            if ab == bb then cost = 0
            delc: (prev.get i: (j + 1)) + 1
            insc: (cur.get i: j) + 1
            subc: (prev.get i: j) + cost
            best: delc
            if insc < best then best = insc
            if subc < best then best = subc
            cur.append best
            j = j + 1
        }
        prev = cur
        i = i + 1
    }
    return (prev.get i: nb)
}

# suggestSimilar -- the closest child name of parentTypeId to `name` (edit
# distance <= 2 and unique); "" if none. Powers the did-you-mean hint.
suggestSimilar: function {st: zenv.ZSymbolTable parentTypeId: u64 name: StringView} out String is {
    best: "".string
    bestDist: 3.u64
    tied: false
    with citer: st.typing.typeChild.iterate do for tc: citer loop {
        if tc.parentTypeId == parentTypeId then {
            cn: tc.childName.stringview
            if (cn == name) == false then {
                d: levenshtein a: name b: cn
                if d < bestDist then {
                    best = tc.childName.copy
                    bestDist = d
                    tied = false
                } else {
                    if d == bestDist then tied = true
                }
            }
        }
    }
    if bestDist <= 2 when (tied) == false when best.length > 0 then return best
    return "".string
}

# populatePreludeBody -- record one unit body's unit-rooted dotted aliases as
# prelude entries (bare name -> defining unit). Type-rooted targets
# (true: bool.true) are value re-exports, never asked of the index side.
populatePreludeBody: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry unitop: Node} is {
    match (
        unitop
    ) case unitdef then {
        with bit: unitop.body.iterate do for bm: bit loop {
            match (
                bm
            ) case namedoperation then {
                dn: unitLabel o: bm.name
                atgt0: dottedDefTarget n: bm.operation
                if atgt0.length > 0 then {
                    ps0: "".string
                    with pit: (atgt0.stringview.split sep: ".") do for pseg: pit loop {
                        if ps0.length == 0 then ps0 = pseg.string
                    }
                    pchk0: ps0.copy
                    if (reg.unitNameTid.has key: pchk0) then {
                        pk0: dn.copy
                        ty.preludeUnit.set key: pk0 value: ps0
                    }
                }
            } else {}
        }
    } else {}
}

# populatePrelude -- fill ty.preludeUnit from core's re-exports BEFORE any
# demand resolution (lowerGenerators pre-resolves system types, whose defs
# already ask definingUnitFor for prelude names).
populatePrelude: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry program: Node} is {
    match (
        program
    ) case program then {
        with uit: program.units.iterate do for ru: uit loop {
            match (
                ru
            ) case namedoperation then {
                unm: unitLabel o: ru.name
                if unm.stringview == "core" then populatePreludeBody :ty :reg unitop: ru.operation
            } else {}
        }
    } else {}
}

# indexUnitDefs -- pre-scan every unit's top-level definitions into a
# (unit.name) -> typetype index BEFORE resolution, so a reference can declare the
# ONE canonical record id (declare-before-bind) instead of an anonymous shell. No
# ids minted here. Dotted-path aliases and the null/never empty types keep their
# existing post-demand handling (defTypetypeOf returns none for them).
indexUnitDefs: function {ty: ztyping.ZTyping program: Node} is {
    match (
        program
    ) case program then {
        uidx0: 0.u64
        with uit: program.units.iterate do for ru: uit loop {
            match (
                ru
            ) case namedoperation then {
                unm: unitLabel o: ru.name
                indexUnitBody :ty unitName: unm.stringview unitIdx: uidx0 unitop: ru.operation
            } else {}
            uidx0 = uidx0 + 1
        }
        ty.defNodeIndexBuilt = true
    } else {}
}

# indexUnitBody -- index one unit's top-level defs (mirrors resolveDemandedUnitBody's
# unitdef.body walk).
indexUnitBody: function {ty: ztyping.ZTyping unitName: StringView unitIdx: u64 unitop: Node} is {
    match (
        unitop
    ) case unitdef then {
        bidx0: 0.u64
        with bit: unitop.body.iterate do for bm: bit loop {
            match (
                bm
            ) case namedoperation then {
                dn: unitLabel o: bm.name
                tto: defTypetypeOf defn: bm.operation name: dn.stringview
                match (
                    tto
                ) case some then {
                    k: "\{unitName}.\{dn}"
                    ty.defTypetype.set key: k value: tto
                } case none then {}
                sk0: "\{unitName}.\{dn}"
                uv0: unitIdx
                ty.defNodeUnitIdx.set key: sk0 value: uv0
                atgt0: dottedDefTarget n: bm.operation
                if atgt0.length > 0 then {
                    ak0: "\{unitName}.\{dn}"
                    ty.funcAliases.set key: ak0 value: atgt0
                    adn0: "\{unitName}.\{dn}"
                    adnid0: nodeId n: bm.operation
                    adv0: adnid0.u64
                    ty.aliasDefNode.set key: adn0 value: adv0
                }
                sk1: "\{unitName}.\{dn}"
                bv1: bidx0
                ty.defNodeBodyIdx.set key: sk1 value: bv1
            } else {}
            bidx0 = bidx0 + 1
        }
    } else {}
}

# defTypetypeOf -- the typetype a top-level definition node declares, mirroring
# resolveDef's dispatch. None for nodes that mint no canonical type here (dotted-
# path aliases, the null/never empty types, enums/generics in later slices).
defTypetypeOf: function {defn: Node name: StringView} out optionval ztypes.ztypetype is {
    match (
        defn
    ) case functiondef then {
        return (optionval.some ztypes.ztypetype.FUNCTION)
    } case expression then {
        return (defTypetypeOf defn: defn.expression :name)
    } case datablock then {
        return (optionval.some ztypes.ztypetype.DATA)
    } case objectdef then {
        match (
            defn.kind
        ) case RECORD then {
            if name == "null" then return (optionval.none ztypes.ztypetype)
            if name == "never" then return (optionval.none ztypes.ztypetype)
            return (optionval.some ztypes.ztypetype.RECORD)
        } case VARIANT then {
            return (optionval.some ztypes.ztypetype.VARIANT)
        } case UNION then {
            return (optionval.some ztypes.ztypetype.UNION)
        } case CLASS then {
            return (optionval.some ztypes.ztypetype.CLASS)
        } case FACET then {
            return (optionval.some ztypes.ztypetype.FACET)
        } case PROTOCOL then {
            return (optionval.some ztypes.ztypetype.PROTOCOL)
        } else {
            return (optionval.none ztypes.ztypetype)
        }
    } else {
        return (optionval.none ztypes.ztypetype)
    }
}

# definingUnitFor -- the unit that defines `name` for a reference in
# `currentUnit`: the current unit's own defs (declare-before-bind index),
# else the prelude surface (core's unit-rooted re-exports, ty.preludeUnit).
# "" when neither indexes it (generic params, this/numerics, forward refs
# to a nonexistent type) -- the caller then mints a shell exactly as
# before. Scope-shaped: the current unit shadows the prelude. The id-side
# bare walk (walkLookupTyperef) keeps its own full root order for
# internal/mangled queries.
definingUnitFor: function {
    ty: ztyping.ZTyping
    currentUnit: StringView
    name: StringView
} out String is {
    k0: "\{currentUnit}.\{name}"
    k0b: "\{currentUnit}.\{name}"
    hitk0: ty.defTypetype.has key: k0
    if (hitk0) == false then hitk0 = ty.defNodeUnitIdx.has key: k0b
    if hitk0 then return currentUnit.string
    pgo0: ty.preludeUnit.get key: name.string
    match (
        pgo0
    ) case some then {
        return pgo0.copy
    } case none then {}
    return "".string
}

# declareCanonicalType -- get-or-declare the ONE canonical id for `unit.name` as a
# childOf edge under its unit (with definedInUnit set). The single convergence point for both a
# reference (resolveAtomType) and the definition (the resolveX resolvers): whoever
# runs first mints; the rest reuse the same id. Does NOT touch definedKeys (the
# body-resolved marker), so demanded bodies still resolve lazily.
declareCanonicalType: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    defUnit: StringView
    name: StringView
    typetype: ztypes.ztypetype
} out u64 is {
    cudm: reg.unitNameTid.get key: defUnit.string
    match (
        cudm
    ) case some then {
        exm: ty.childOf parentTypeId: cudm :name
        match (
            exm
        ) case some then {
            return exm
        } case none then {}
    } case none then {}
    id: reg.newType :name :typetype
    cud0: reg.unitNameTid.get key: defUnit.string
    match (
        cud0
    ) case some then {
        ty.setChild parentTypeId: cud0 childName: name childTypeId: id
    } case none then {}
    idu: id
    duv: defUnit.string
    ty.definedInUnit.set key: idu value: duv
    return id
}

# dottedDefTarget -- the "unit.Type" target of a cross-unit type alias
# (`Node: zast.Node`), or "" when the definition is not a dotted alias.
dottedDefTarget: function {n: Node} out String is {
    match (
        n
    ) case expression then {
        return (dottedDefTarget n: n.expression)
    } case dottedpath then {
        pn: atomName n: n.parent
        cn: atomName n: n.child
        return "\{pn}.\{cn}"
    } else {
        return "".string
    }
}

# resolveNamedType -- resolve a bare type NAME to its canonical id via the
# declare-before-bind index (definingUnitFor -> declareCanonicalType), minting a
# RECORD shell only for a numeric-literal default or an unresolved/forward name.
# `thisName` scopes the enclosing type's generic params. resolveAtomType aliases
# the self-type keywords `this`/`type` to the enclosing type name and calls here,
# so a native method's `:this` / `rhs: type` lands on the one canonical id, not a
# fresh shell.
resolveNamedType: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    name: StringView
    thisName: StringView
} out u64 is {
    if name == "null" then {
        return (declareCanonicalType
            :ty
            :reg
            defUnit: "system"
            name: "null"
            typetype: ztypes.ztypetype.NULL
        )
    }
    if name == "never" then {
        return (declareCanonicalType
            :ty
            :reg
            defUnit: "system"
            name: "never"
            typetype: ztypes.ztypetype.NEVER
        )
    }
    b0: name.byteAt 0.u64
    isnum: false
    match (
        b0
    ) case some then {
        if b0 >= 48 when b0 <= 57 then isnum = true
    } case none then {}
    if isnum then {
        # A numeric-literal name types as the literal's DEFAULT scalar (system
        # i64/f64) -- it is not a name reference, so a unit-local scalar shadow
        # must not capture it. Pre-index (defNodeIndexBuilt false) keeps the
        # named-shell fallback.
        dn7: "i64"
        if name.contains "." then dn7 = "f64"
        sid7: descendNamed :ty :reg :units defUnit: "system" name: dn7
        if sid7 > 0 then return sid7
        return (reg.newType name: dn7 typetype: ztypes.ztypetype.RECORD)
    }
    if thisName.length > 0 then {
        etk7: "\{unitName}.\{thisName}"
        if (reg.isGenericParamOf typeKey: etk7.stringview :name) then {
            pgo7: reg.genericParamTidOf typeKey: etk7.stringview paramName: name
            match (
                pgo7
            ) case some then {
                return pgo7
            } case none then {}
            ptid7: reg.newType :name typetype: ztypes.ztypetype.GENERIC_PARAM
            reg.setGenericParamTid typeKey: etk7.stringview paramName: name tid: ptid7
            return ptid7
        }
    }
    duo7: definingUnitFor :ty currentUnit: unitName :name
    if duo7.length > 0 then {
        ttk7: "\{duo7}.\{name}"
        tto7: ty.defTypetype.get key: ttk7
        match (
            tto7
        ) case some then {
            did7: descendNamed :ty :reg :units defUnit: duo7.stringview :name
            if did7 > 0 then return did7
            return (declareCanonicalType :ty :reg defUnit: duo7.stringview :name typetype: tto7)
        } case none then {
            k7b: "\{duo7}.\{name}"
            ex7: resolvedByKey :ty :reg key: k7b
            match (
                ex7
            ) case some then {
                return ex7
            } case none then {}
            k7c: "\{duo7}.\{name}"
            fa7: ty.funcAliases.get key: k7c
            match (
                fa7
            ) case some then {
                ap7: "".string
                ac7: "".string
                with sit7: (fa7.stringview.split sep: ".") do for seg7: sit7 loop {
                    if ap7.length == 0 then {
                        ap7 = seg7.string
                    } else {
                        ac7 = seg7.string
                    }
                }
                dtk7: "\{ap7}.\{ac7}"
                tt7: ty.defTypetype.get key: dtk7
                match (
                    tt7
                ) case some then {
                    return (declareCanonicalType
                        :ty
                        :reg
                        defUnit: ap7.stringview
                        name: ac7.stringview
                        typetype: tt7
                    )
                } case none then {}
            } case none then {}
            return (reg.newType :name typetype: ztypes.ztypetype.RECORD)
        }
    } else {
        return (reg.newType :name typetype: ztypes.ztypetype.RECORD)
    }
}

# resolveAtomType -- resolve a type-atom name in a method/param position. `this`
# and `type` alias the enclosing type (thisName); everything else is a plain name.
resolveAtomType: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    nm: StringView
    thisName: StringView
} out u64 is {
    if nm == "this" then {
        return (resolveNamedType :ty :reg :units :unitName name: thisName :thisName)
    }
    if nm == "type" then {
        if thisName.length != 0 then {
            return (resolveNamedType :ty :reg :units :unitName name: thisName :thisName)
        }
    }
    return (resolveNamedType :ty :reg :units :unitName name: nm :thisName)
}

# literalIntId -- pseudo-type id worn by bare numeric literals during the body
# walk. Never registered, so symbol-table and node rows carrying it drop out of
# the dump projections' types join; foldLiteralStamps rewrites surviving node
# stamps to i64 before the dump.
literalIntId: 0x7FFFFFFFFFFFFFFF.u64
literalFloatId: 0x7FFFFFFFFFFFFFFE.u64

# parseDecimalU64 -- a decimal digit string as a u64 value; none when empty
# or any byte is not a digit (signs, radix prefixes, suffixed forms stay on
# the name-keyed path).
parseDecimalU64: function {text: StringView} out optionval u64 is {
    acc9: 0.u64
    i9: 0.u64
    any9: false
    run9: true
    for run9 loop {
        bo9: text.byteAt i9
        match (
            bo9
        ) case some then {
            if bo9 >= 48 when bo9 <= 57 then {
                d9: bo9 - 48
                acc9 = acc9 * 10 + d9.u64
                any9 = true
            } else {
                any9 = false
                run9 = false
            }
        } case none then {
            run9 = false
        }
        i9 = i9 + 1
    }
    if any9 then return (optionval.some acc9)
    return (optionval.none u64)
}

# isNumericLiteralName -- true when a name begins with a digit: a numeric-literal
# atom (an `as`-block static constant like `version: 1`), as opposed to a type-name
# atom (a conformance marker). 48..57 are the ASCII digits.
isNumericLiteralName: function {name: StringView} out bool is {
    b0: name.byteAt 0.u64
    match (
        b0
    ) case some then {
        if b0 >= 48 when b0 <= 57 then return true
        if b0 == 45 then {
            b1: name.byteAt 1.u64
            match (
                b1
            ) case some then {
                if b1 >= 48 when b1 <= 57 then return true
            } case none then {}
        }
    } case none then {}
    return false
}

# isStripMarker -- true for a dotted-path leaf that is an ownership or access marker
# (`.lock`/`.borrow`/`.take`/`.private`/`.public`); a type reference peels these to
# reach the underlying base type.
isStripMarker: function {name: StringView} out bool is {
    if name == "lock" then return true
    if name == "borrow" then return true
    if name == "take" then return true
    if name == "private" then return true
    if name == "public" then return true
    return false
}

# isLabelValue -- true when a node is a bare `:X` label-value (an anonymous
# conformance marker in an as-block parses as a namedoperation wrapping one).
isLabelValue: function {op: Node} out bool is {
    match (
        op
    ) case labelvalue then {
        return true
    } else {
        return false
    }
}

# nodeMentionsName -- whether a subtree references a bare name (atom reads,
# call callables, dotted bases). Drives the conformer-context gate: the
# reference's lazy resolution only reaches a conformer the main body names.
nodeMentionsName: function {n: Node name: StringView} out bool is {
    match (
        n
    ) case atomid then {
        return n.name.stringview == name
    } case expression then {
        return (nodeMentionsName n: n.expression :name)
    } case dottedpath then {
        return (nodeMentionsName n: n.parent :name)
    } case call then {
        if (nodeMentionsName n: n.callable :name) then return true
        aiter: n.arguments.iterate
        for arg: aiter loop {
            match (
                arg
            ) case namedoperation then {
                if (nodeMentionsName n: arg.operation :name) then return true
            } else {}
        }
        return false
    } case binop then {
        if (nodeMentionsName n: n.lhs :name) then return true
        return (nodeMentionsName n: n.rhs :name)
    } case statement then {
        siter: n.statements.iterate
        for sm: siter loop {
            if (nodeMentionsName n: sm :name) then return true
        }
        return false
    } case statementline then {
        return (nodeMentionsName n: n.statementline :name)
    } case assignment then {
        return (nodeMentionsName n: n.value :name)
    } case reassignment then {
        return (nodeMentionsName n: n.value :name)
    } case caseexpr then {
        if (nodeMentionsName n: n.subject :name) then return true
        citer: n.clauses.iterate
        for cm: citer loop {
            if (nodeMentionsName n: cm :name) then return true
        }
        return false
    } case caseclause then {
        return (nodeMentionsName n: n.statement :name)
    } case ifexpr then {
        citer2: n.clauses.iterate
        for cm2: citer2 loop {
            if (nodeMentionsName n: cm2 :name) then return true
        }
        return false
    } case forexpr then {
        return (nodeMentionsNameOpt o: n.body :name)
    } case withexpr then {
        if (nodeMentionsName n: n.value :name) then return true
        return (nodeMentionsName n: n.body :name)
    } case doexpr then {
        return (nodeMentionsName n: n.statement :name)
    } else {
        return false
    }
}

# nodeMentionsNameOpt -- nodeMentionsName over an optional subtree.
nodeMentionsNameOpt: function {o: Option Node name: StringView} out bool is {
    match (
        o
    ) case some then {
        return (nodeMentionsName n: o :name)
    } case none then {
        return false
    }
}

# fnBodyMentions -- nodeMentionsName over a function definition's body.
fnBodyMentions: function {op: Node name: StringView} out bool is {
    match (
        op
    ) case functiondef then {
        return (nodeMentionsNameOpt o: op.body :name)
    } else {
        return false
    }
}

# mainBodyMentions -- whether the unit's `main` function body references a name.
mainBodyMentions: function {unitBody: List Node name: StringView} out bool is {
    {
        with miter: unitBody.iterate do for mm: miter loop {
            match (
                mm
            ) case namedoperation then {
                mn: unitLabel o: mm.name
                if mn.stringview == "main" then return (fnBodyMentions op: mm.operation :name)
            } else {}
        }
    }
    return false
}

# recordConformerContexts -- pre-record each as-block marker target's first
# conforming type (body order) so a demand-resolved protocol binds its spec
# receiver to the conformer (the reference resolves the protocol inside the
# conformer's resolution, inheriting its `this` context). Full mode only:
# signature-only resolves protocols standalone, receiver dropped.
recordConformerContexts: function {ty: ztyping.ZTyping defName: StringView op: Node} is {
    match (
        op
    ) case objectdef then {
        isRef: false
        if op.kind == zast.nodetype.CLASS then isRef = true
        if op.kind == zast.nodetype.UNION then isRef = true
        dk0: defName.string
        dv0: isRef
        ty.mainDefIsReftype.set key: dk0 value: dv0
        aiter: op.asItems.iterate
        for am: aiter loop {
            match (
                am
            ) case namedoperation then {
                cn: atomName n: am.operation
                skipIt: false
                if cn.length == 0 then skipIt = true
                if (isNumericLiteralName name: cn.stringview) then skipIt = true
                if (skipIt) == false then {
                    ck: cn.copy
                    got: ty.protocolThisContext.get key: ck
                    match (
                        got
                    ) case some then {
                    } case none then {
                        ck2: cn.copy
                        cv: defName.string
                        ty.protocolThisContext.set key: ck2 value: cv
                    }
                }
            } else {}
        }
    } else {}
}

# isBareGenericParam -- a generic-param definition in direct dotted form
# (`t: Any.generic`); wrapped shapes (a def whose payload merely contains a
# constraint) are not unit-level generic params.
isBareGenericParam: function {op: Node} out bool is {
    match (
        op
    ) case dottedpath then {
        leaf: atomName n: op.child
        if leaf.stringview == "generic" then return true
        if leaf.stringview == "valtype" then return true
        if leaf.stringview == "reftype" then return true
        return false
    } else {
        return false
    }
}

# isGenericParam -- true when a type-expr is a generic-parameter constraint
# (`Any.generic` / `u64.generic` / `Any.valtype`): a dottedpath whose leaf is
# `generic` or `valtype`, peeling an `expression` / parameterized `call` wrapper.
isGenericParam: function {op: Node} out bool is {
    match (
        op
    ) case expression then {
        return (isGenericParam op: op.expression)
    } case call then {
        return (isGenericParam op: op.callable)
    } case dottedpath then {
        leaf: atomName n: op.child
        if leaf.stringview == "generic" then return true
        if leaf.stringview == "valtype" then return true
        if leaf.stringview == "reftype" then return true
        return false
    } else {
        return false
    }
}

# registerGenericParams -- record a type's generic-param names (keyed
# `{unit}.{type}.{param}`) so method-param resolution can drop params typed by them.
registerGenericParams: function {
    reg: ztypes.ZTypeRegistry
    typeKey: StringView
    items: List Node
} is {
    iter: items.iterate
    for m: iter loop {
        match (
            m
        ) case namedoperation then {
            if (isGenericParam op: m.operation) then {
                pn: unitLabel o: m.name
                cb: genericConstraintBase n: m.operation
                ckx9: genericConstraintKind n: m.operation
                cf9x: cb.copy
                if ckx9.length > 0 then cf9x = "\{cb}.\{ckx9}"
                k9: constraintKindFor text: cf9x.stringview
                mx9: (optionval.none u64)
                if k9 == ztypes.constraintkind.NUMERIC then {
                    mx9 = constraintNumericMax cv: cf9x.stringview
                }
                reg.addGenericParam :typeKey paramName: pn.stringview kind: k9 numericMax: mx9
            }
        } else {}
    }
}

# genericConstraintKind -- the value-kind leaf of a constraint declaration
# (`Any.valtype` -> "valtype", `Any.reftype` -> "reftype"), "" for plain
# `.generic` bounds.
genericConstraintKind: function {n: Node} out String is {
    match (
        n
    ) case expression then {
        return (genericConstraintKind n: n.expression)
    } case dottedpath then {
        cn9: atomName n: n.child
        if cn9.stringview == "valtype" then return cn9
        if cn9.stringview == "reftype" then return cn9
        return "".string
    } else {
        return "".string
    }
}

# genericConstraintBase -- the constraint name of a `u64.generic`-style param
# declaration (the dotted parent), "" otherwise.
genericConstraintBase: function {n: Node} out String is {
    match (
        n
    ) case expression then {
        return (genericConstraintBase n: n.expression)
    } case dottedpath then {
        return (atomName n: n.parent)
    } else {
        return "".string
    }
}

# hasGenericParam -- true when any item in the block is a generic-param declaration.
# Takes the list by value so its iterator's lock is released on return (the scan is
# sequenced before any persistent iterator over the same list).
hasGenericParam: function {items: List Node} out bool is {
    it: items.iterate
    for m: it loop {
        match (
            m
        ) case namedoperation then {
            if (isGenericParam op: m.operation) then return true
        } else {}
    }
    return false
}

# unitDefIsGeneric -- a unit definition is generic when its body declares a generic
# param. Mirrors objectdefIsGeneric; gates dep-signature-stamp suppression off generic
# units, whose template signatures resolve differently.
unitDefIsGeneric: function {o: Node} out bool is {
    match (
        o
    ) case unitdef then {
        return (hasGenericParam items: o.body)
    } else {
        return false
    }
}

# pathOwnership -- the ownership a param/field type expr declares via a `.lock`/
# `.borrow`/`.take` dotted-path leaf, or none. (Only `.lock` is valid on a field; all
# three on a param.)
pathOwnership: function {n: Node} out optionval ztypes.zparamownership is {
    match (
        n
    ) case dottedpath then {
        cn: atomName n: n.child
        if cn.stringview == "lock" then return (optionval.some ztypes.zparamownership.LOCK)
        if cn.stringview == "borrow" then return (optionval.some ztypes.zparamownership.BORROW)
        if cn.stringview == "take" then return (optionval.some ztypes.zparamownership.TAKE)
        return (optionval.none ztypes.zparamownership)
    } else {
        return (optionval.none ztypes.zparamownership)
    }
}

# baseTypeName -- the underlying base type name of a type expr, peeling `.lock`/
# `.private`/etc. dotted-path markers (`Container.private.lock` -> `Container`,
# `this.lock` -> `this`); the atom name for a bare atom; "" otherwise.
baseTypeName: function {n: Node} out String is {
    match (
        n
    ) case atomid then {
        return n.name.copy
    } case labelvalue then {
        return n.name.copy
    } case dottedpath then {
        cn: atomName n: n.child
        if (isStripMarker name: cn.stringview) then {
            return (baseTypeName n: n.parent)
        } else {
            return "".string
        }
    } else {
        return "".string
    }
}

# genericApplHead -- the head type name of a generic application `(List of: T)` /
# `(Option t: T)` (the callable's atom name); "" for a non-application expr.
genericApplHead: function {n: Node} out String is {
    match (
        n
    ) case expression then {
        return (genericApplHead n: n.expression)
    } case call then {
        return (atomName n: n.callable)
    } else {
        return "".string
    }
}

# fieldHeadName -- a field type's head name: baseTypeName, falling back to the
# generic-application head so a `(List of: Node)` / `(Option t: Node)` field is
# recognized (List/Option) for the destructor-cleanup decision.
fieldHeadName: function {n: Node} out String is {
    b: baseTypeName :n
    if b.length > 0 then return b
    return (genericApplHead :n)
}

# resolveTyperefShell -- register a SHALLOW named shell for a referenced type
# (e.g. the `i64` in `n: i64`), routing atom names through resolveAtomType so
# `this`/numeric-default atoms resolve correctly. A parenthesized parameterized
# type `(T arg: N)` (an expression wrapping a call) mangles to a `T_N` shell.
# Source-type rows never include these shells (they fall outside `defined_in_unit`),
# but a `type_children` row joins to the shell's name. Returns the shell's type id.
recordNodeName: function {ty: ztyping.ZTyping unitName: StringView name: StringView nid: u64} is {
    if name.length != 0 then {
        kc: nid
        ty.pendingTyperef.set key: kc value: name.string
        kc2: nid
        ty.pendingTyperefUnit.set key: kc2 value: unitName.string
        if ty.suppressSigStamp then {
            kc3: nid
            sv0: true
            ty.noStampNode.set key: kc3 value: sv0
        }
    }
}

# recordResolvedName -- record (nid -> name) for post-demand resolution; the `this` and
# `type` self-keywords record as the enclosing type (thisName).
recordResolvedName: function {
    ty: ztyping.ZTyping
    unitName: StringView
    thisName: StringView
    name: StringView
    nid: u64
} is {
    if name == "this" then {
        recordNodeName :ty :unitName name: thisName :nid
    } else {
        if name == "type" then {
            recordNodeName :ty :unitName name: thisName :nid
        } else {
            if (isNumericLiteralName :name) then {
                if name.contains "." then {
                    recordNodeName :ty :unitName name: "f64" :nid
                } else {
                    recordNodeName :ty :unitName name: "i64" :nid
                }
            } else {
                recordNodeName :ty :unitName :name :nid
            }
        }
    }
}

# monoArgName -- a pending-instantiation argument's recorded name: `this` and
# `type` map to the enclosing type (the recordResolvedName mapping); "" when
# there is no enclosing type.
monoArgName: function {an: StringView thisName: StringView} out String is {
    if an == "this" then return thisName.string
    if an == "type" then return thisName.string
    return an.string
}

# resolveDottedArgTid -- a unit-qualified dotted generic argument
# (ztypes.zlockstate): descend the member in its defining unit. Marker /
# non-unit dotted shapes resolve 0 (the caller skips the record).
resolveDottedArgTid: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    dp: Node
} out u64 is {
    match (
        dp
    ) case dottedpath then {
        pq9: atomName n: dp.parent
        cq9: atomName n: dp.child
        if pq9.length > 0 when cq9.length > 0 then {
            if (reg.isUnitName name: pq9.stringview) then {
                return (descendNamed :ty :reg :units defUnit: pq9.stringview name: cq9.stringview)
            }
        }
    } else {}
    return 0
}

# ensureNativeLinkTargets -- descend the native templates the collection
# materializer links returns against by NAME (String / StringView, the
# option wrappers, the iterator/view families): inline specialization runs
# at resolve time, before the demand worklist would have pulled them.
# definedKeys makes every descent after the first a no-op.
ensureNativeLinkTargets: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
} is {
    if ty.nativeLinkTargetsDone then return
    ty.nativeLinkTargetsDone = true
    descendNamed :ty :reg :units defUnit: "system" name: "String"
    descendNamed :ty :reg :units defUnit: "system" name: "StringView"
    descendNamed :ty :reg :units defUnit: "system" name: "Option"
    descendNamed :ty :reg :units defUnit: "system" name: "OptionView"
    descendNamed :ty :reg :units defUnit: "system" name: "optionval"
    descendNamed :ty :reg :units defUnit: "system" name: "Result"
    descendNamed :ty :reg :units defUnit: "system" name: "resultval"
    descendNamed :ty :reg :units defUnit: "collections" name: "List"
    descendNamed :ty :reg :units defUnit: "collections" name: "ListIter"
    descendNamed :ty :reg :units defUnit: "collections" name: "ListView"
    descendNamed :ty :reg :units defUnit: "collections" name: "Set"
    descendNamed :ty :reg :units defUnit: "collections" name: "SetIter"
    descendNamed :ty :reg :units defUnit: "collections" name: "Map"
    descendNamed :ty :reg :units defUnit: "collections" name: "MapKeyIter"
    descendNamed :ty :reg :units defUnit: "collections" name: "MapItemIter"
    descendNamed :ty :reg :units defUnit: "collections" name: "MapEntry"
}

# resolveMonoRefInline -- resolve a call-shaped parameterized type ref at the
# point it is recorded: resolve the template and every argument now (nested
# parameterized args recurse; the descent pulls unresolved defs), then dedup /
# materialize through getOrMintSpec and stamp the wrapper node. Numeric size
# literals join the instance name only (const values, not type refs). Returns
# 0 -- recording nothing -- when the callable is empty or any argument is
# unresolvable (a template-internal generic-param name stays a shell).
resolveMonoRefInline: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    thisName: StringView
    enclKey: StringView
    op: Node
    nid: u32
} out u64 is {
    match (
        op
    ) case expression then {
        return (resolveMonoRefInline
            :ty
            :reg
            :units
            :unitName
            :thisName
            :enclKey
            op: op.expression
            :nid
        )
    } case call then {
        return (resolveMonoRefParts
            :ty
            :reg
            :units
            :unitName
            :thisName
            :enclKey
            callable: op.callable
            arguments: op.arguments
            :nid
        )
    } else {}
    return 0
}

# resolveMonoRefParts -- resolveMonoRefInline's call-shaped core, taking the
# callable and argument list directly so narrowed call subjects can feed it.
resolveMonoRefParts: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    thisName: StringView
    enclKey: StringView
    callable: Node
    arguments: List Node
    nid: u32
} out u64 is {
    {
        tname9: atomName n: callable
        if tname9.length == 0 then return 0
        sfx9: "".string
        subs9: (Map String value: u64)
        valSubsR9: (Map String value: u64)
        firstA9: 0.u64
        allOk9: true
        aiter9: arguments.iterate
        for arg9: aiter9 loop {
            match (
                arg9
            ) case namedoperation then {
                an9: atomName n: arg9.operation
                if (isNumericLiteralName name: an9.stringview) then {
                    sfx9.append s: "_"
                    sfx9.append s: an9.stringview
                    pdv9: parseDecimalU64 text: an9.stringview
                    match (
                        pdv9
                    ) case some then {
                        vpn9: unitLabel o: arg9.name
                        vsk9: vpn9.copy
                        vsv9: pdv9
                        valSubsR9.set key: vsk9 value: vsv9
                    } case none then {}
                } else {
                    aid9: 0.u64
                    if an9.length == 0 then {
                        aid9 = resolveDottedArgTid :ty :reg :units dp: arg9.operation
                        if aid9 == 0 then {
                            inner9: (resolveMonoRefInline
                                :ty
                                :reg
                                :units
                                :unitName
                                :thisName
                                :enclKey
                                op: arg9.operation
                                nid: 0
                            )
                            if inner9 > 0 then {
                                aid9 = inner9
                            } else {
                                allOk9 = false
                            }
                        }
                    } else {
                        anc9: monoArgName an: an9.stringview :thisName
                        if anc9.length == 0 then {
                            allOk9 = false
                        } else {
                            if enclKey.length > 0 when (reg.isGenericParamOf
                                typeKey: enclKey
                                name: anc9.stringview
                            ) then {
                                epo9: (reg.genericParamTidOf
                                    typeKey: enclKey
                                    paramName: anc9.stringview
                                )
                                match (
                                    epo9
                                ) case some then {
                                    aid9 = epo9
                                } case none then {
                                    aid9 = (reg.newType
                                        name: anc9.stringview
                                        typetype: ztypes.ztypetype.GENERIC_PARAM
                                    )
                                    (reg.setGenericParamTid
                                        typeKey: enclKey
                                        paramName: anc9.stringview
                                        tid: aid9
                                    )
                                }
                            }
                            # a name the CURRENT unit defines wins even when
                            # not yet declared -- the ladder walk sees only
                            # declared defs and would fall through to a
                            # same-named stdlib type (resolveAtomType's rule)
                            duo9: definingUnitFor :ty currentUnit: unitName name: anc9.stringview
                            if aid9 == 0 when duo9.stringview == unitName then {
                                aid9 = (descendNamed
                                    :ty
                                    :reg
                                    :units
                                    defUnit: duo9.stringview
                                    name: anc9.stringview
                                )
                            }
                            if aid9 == 0 then {
                                ao9: (walkLookupTyperef
                                    :ty
                                    :reg
                                    currentUnit: unitName
                                    base: anc9.stringview
                                )
                                aid9 = optU64Or o: ao9 d: 0
                            }
                            if aid9 == 0 then {
                                if duo9.length > 0 then {
                                    aid9 = (descendNamed
                                        :ty
                                        :reg
                                        :units
                                        defUnit: duo9.stringview
                                        name: anc9.stringview
                                    )
                                }
                            }
                            if aid9 == 0 then allOk9 = false
                        }
                    }
                    if aid9 > 0 then {
                        sfx9.append s: "_"
                        vn9: monoValName :ty :reg tid: aid9
                        sfx9.append s: vn9.stringview
                        if firstA9 == 0 then firstA9 = aid9
                        pn9: unitLabel o: arg9.name
                        sk9: pn9.copy
                        sv9: aid9
                        subs9.set key: sk9 value: sv9
                    }
                }
            } else {}
        }
        if allOk9 == false then return 0
        if sfx9.length == 0 then return 0
        tplId9: 0.u64
        tduo9: definingUnitFor :ty currentUnit: unitName name: tname9.stringview
        if tduo9.stringview == unitName then {
            tplId9 = descendNamed :ty :reg :units defUnit: tduo9.stringview name: tname9.stringview
        }
        if tplId9 == 0 then {
            tplO9: walkLookupTyperef :ty :reg currentUnit: unitName base: tname9.stringview
            tplId9 = optU64Or o: tplO9 d: 0
        }
        if tplId9 == 0 then {
            if tduo9.length > 0 then {
                tplId9 = (descendNamed
                    :ty
                    :reg
                    :units
                    defUnit: tduo9.stringview
                    name: tname9.stringview
                )
            }
        }
        if tplId9 == 0 then return 0
        ensureNativeLinkTargets :ty :reg :units
        # generator wrapper collapse: the synth `.call` return's Option over a
        # VALTYPE element is optionval (ownership is a physical no-op there);
        # a REFTYPE element is Option (the yielded value is owned — it must
        # outlive the `.call`, so the payload lives in a malloc'd box).
        tn9: tname9.copy
        gwv9: optBoolOr o: (ty.generatorWrapper.get key: nid.u64) d: false
        if gwv9 when firstA9 > 0 then {
            if (typeIsValtype :ty :reg tid: firstA9) then {
                ovd9: descendNamed :ty :reg :units defUnit: "system" name: "optionval"
                if ovd9 > 0 then {
                    tplId9 = ovd9
                    tn9 = "optionval".string
                }
            } else {
                obd9: descendNamed :ty :reg :units defUnit: "system" name: "Option"
                if obd9 > 0 then {
                    tplId9 = obd9
                    tn9 = "Option".string
                }
            }
        }
        mnOwn9: reg.regMainUnit.copy
    mainName9: mnOwn9.stringview
        mname9: "\{tn9}\{sfx9}"
        # firstA9 rides as the fallback: when a template's param name differs
        # from the call label (Option's `t` vs the conventional `of:`), the
        # clone fallback leg types native-union arms from it -- a spec first
        # minted from a TYPE-position ref must carry real arm payloads.
        mid9: (getOrMintSpec
            :ty
            :reg
            mainName: mainName9
            name: mname9.stringview
            templateId: tplId9
            subs: subs9
            valSubs: valSubsR9
            fallbackArg: firstA9
        )
        if mid9 == 0 then return 0
        # backstop for a sized record whose size literal did not parse as a
        # decimal (the value-keyed trie path arms sized specs centrally)
        isSized9: false
        if tn9.stringview == "str" then isSized9 = true
        if tn9.stringview == "array" then isSized9 = true
        if isSized9 then {
            (mintCollectionChildren
                :ty
                :reg
                mainName: mainName9
                monoName: mname9.stringview
                monoId: mid9
                templateId: tplId9
                suffix: sfx9.stringview
                elemArg: firstA9
                valArg: 0
            )
        }
        if nid > 0 then {
            smv9: mid9
            ty.nodeType.set key: nid.u64 value: smv9
        }
        return mid9
    }
}

# recordTyperef -- record a signature type-ref node (param / field / arm / return) for
# post-demand stamping. resolveTyperefShell yields only a NULL-unit shell and the real
# type may be unresolved here (system / forward refs), so the base name is resolved to its
# real type later by stampTyperefs. Recurses parameterized args and strip-marker dotted
# paths; `this`/`type` record as the enclosing type (thisName).
recordTyperef: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    thisName: StringView
    node: Node
} is {
    match (
        node
    ) case expression then {
        (resolveMonoRefInline
            :ty
            :reg
            :units
            :unitName
            :thisName
            enclKey: ""
            op: node.expression
            nid: node.nodeid
        )
        recordTyperef :ty :reg :units :unitName :thisName node: node.expression
    } case call then {
        # Parameterized type `(T arg: U ...)`: the outer node resolves to a NULL-defined
        # mono (filtered out); record each argument's inner TYPE-ref (e.g. the `u32` in
        # `(optionval t: u32)`), but skip numeric-literal size args (the `16` in
        # `(str to: 16)`) -- they are const values, not type references. The pending
        # instantiation is recorded by the enclosing expression arm (the wrapper node
        # carries the reference's instance stamp).
        aiter: node.arguments.iterate
        for arg: aiter loop {
            match (
                arg
            ) case namedoperation then {
                an: atomName n: arg.operation
                if (isNumericLiteralName name: an.stringview) == false then {
                    recordTyperef :ty :reg :units :unitName :thisName node: arg.operation
                }
            } else {}
        }
    } case dottedpath then {
        # Ownership/access strip marker (this.lock / StringView.borrow / Container.private):
        # record the dotted node with its peeled base AND recurse on the parent so the
        # stripped inner atom is stamped too (the reference stamps both ppath + stripped).
        # A `.typedef` marker only recurses -- the dotted node itself resolves to a
        # NULL-defined typedef wrapper the dump filters out.
        cn: atomName n: node.child
        pn: atomName n: node.parent
        if (reg.unitNameTid.has key: pn) then {
            # cross-unit qualified type ref (zlexer.Token): record the MEMBER under
            # its DEFINING unit (the parent) so stampTyperefs bridges this node.
            (recordResolvedName
                :ty
                unitName: pn.stringview
                :thisName
                name: cn.stringview
                nid: node.nodeid.u64
            )
        } else {
            if (isStripMarker name: cn.stringview) then {
                bn: baseTypeName n: node.parent
                recordResolvedName :ty :unitName :thisName name: bn.stringview nid: node.nodeid.u64
                # a parameterized parent ((List of: String).take) has no base
                # name; the marker dp wears the parent's mono stamp.
                if bn.length == 0 then {
                    (resolveMonoRefInline
                        :ty
                        :reg
                        :units
                        :unitName
                        :thisName
                        enclKey: ""
                        op: node.parent
                        nid: node.nodeid
                    )
                }
                # Ownership markers peel and stamp the inner ref; `.private` /
                # `.public` resolve the pair atomically (no base-atom stamp).
                if cn.stringview != "private" then {
                    if cn.stringview != "public" then {
                        recordTyperef :ty :reg :units :unitName :thisName node: node.parent
                    }
                }
            } else {
                if cn.stringview == "typedef" then {
                    recordTyperef :ty :reg :units :unitName :thisName node: node.parent
                }
            }
        }
    } case atomid then {
        recordResolvedName :ty :unitName :thisName name: node.name.stringview nid: node.nodeid.u64
    } case labelvalue then {
        recordResolvedName :ty :unitName :thisName name: node.name.stringview nid: node.nodeid.u64
    } else {}
}

# returnParamTid -- when a return typeref names one of the enclosing
# template's generic parameters, its canonical parameter type id; else 0.
returnParamTid: function {reg: ztypes.ZTypeRegistry enclKey: StringView o: Option Node} out u64 is {
    match (
        o
    ) case some then {
        bn: atomName n: o
        # a marker-suffixed generic return (`of.take` / `of.borrow`) reads its
        # base name through the peeled parent.
        if bn.length == 0 then bn = markerPeeledBase n: o
        if (reg.isGenericParamOf typeKey: enclKey name: bn.stringview) then {
            po: reg.genericParamTidOf typeKey: enclKey paramName: bn.stringview
            match (
                po
            ) case some then {
                return po
            } case none then {}
            rpt7: reg.newType name: bn.stringview typetype: ztypes.ztypetype.GENERIC_PARAM
            reg.setGenericParamTid typeKey: enclKey paramName: bn.stringview tid: rpt7
            return rpt7
        }
    } case none then {}
    return 0
}

# partialTyperefTid -- resolve a composite parameterized typeref inside a
# template method signature to a spec through the shared disassembly
# (resolveMonoRefParts with the template's enclKey). Returns the spec only
# when it is PARTIAL (an argument named a generic param); a fully-concrete
# composite stays 0, preserving the caller's eager-path behavior.
partialTyperefTid: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    enclKey: StringView
    n: Node
} out u64 is {
    match (
        n
    ) case expression then {
        return (partialTyperefTid :ty :reg :units :unitName :enclKey n: n.expression)
    } case dottedpath then {
        dcn6: atomName n: n.child
        if (isStripMarker name: dcn6.stringview) then {
            return (partialTyperefTid :ty :reg :units :unitName :enclKey n: n.parent)
        }
        return 0
    } case call then {
        rmp6: (resolveMonoRefParts
            :ty
            :reg
            :units
            :unitName
            thisName: ""
            :enclKey
            callable: n.callable
            arguments: n.arguments
            nid: 0
        )
        if rmp6 > 0 then {
            if (reg.typetypeOf typeId: rmp6) == ztypes.ztypetype.GENERIC_PARAM then return rmp6
        }
        return 0
    } else {}
    return 0
}

# partialReturnTid -- partialTyperefTid over a function's return typeref.
partialReturnTid: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    enclKey: StringView
    o: Option Node
} out u64 is {
    match (
        o
    ) case some then {
        return (partialTyperefTid :ty :reg :units :unitName :enclKey n: o)
    } case none then {}
    return 0
}

# returnIsIteratorTid -- the resolved return type belongs to an iterator
# family (ListIter/SetIter/MapKeyIter/MapItemIter or a generator's synth
# iterator `.call`... the collection families by generic origin). Iterator
# borrows stay EXCLUSIVE (many SHARED views XOR one writer XOR one
# exclusive iterator); other returned borrows are read-views and lock
# SHARED.
returnIsIteratorTid: function {st: zenv.ZSymbolTable tid: u64} out bool is {
    if tid == 0 then return false
    org9: 0.u64
    {
        tz9: st.reg.typeById.get key: tid
        match (
            tz9
        ) case some then {
            go9: tz9.genericOriginId
            match (
                go9
            ) case some then {
                org9 = go9
            } case none then {}
        } case none then {}
    }
    probe9: tid
    if org9 > 0 then probe9 = org9
    pn9: typeNameOf :st tid: probe9
    if pn9.stringview == "ListIter" then return true
    if pn9.stringview == "SetIter" then return true
    if pn9.stringview == "MapKeyIter" then return true
    if pn9.stringview == "MapItemIter" then return true
    return false
}

# markerPeeledBase -- the base atom name under a strip-marker dotted path
# (`of.take` -> "of"); "" for any other shape.
markerPeeledBase: function {n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        mcn3: atomName n: n.child
        if (isStripMarker name: mcn3.stringview) then return (atomName n: n.parent)
        return "".string
    } else {
        return "".string
    }
}

# stampGenericParamRef -- a return typeref naming one of the enclosing
# template's generic params stamps the unit's generic-param type directly
# (generic params live outside the name-resolution table).
stampGenericParamRef: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    enclKey: StringView
    o: Option Node
} is {
    match (
        o
    ) case some then {
        bn: atomName n: o
        # a marker-suffixed generic return (`of.take` / `of.borrow`) reads its
        # base name through the peeled parent; the marker dp wears the stamp,
        # matching recordTyperef's convention for concrete marked returns.
        if bn.length == 0 then bn = markerPeeledBase n: o
        if (reg.isGenericParamOf typeKey: enclKey name: bn.stringview) then {
            gpt3: 0.u64
            gpo3: reg.genericParamTidOf typeKey: enclKey paramName: bn.stringview
            match (
                gpo3
            ) case some then {
                gpt3 = gpo3
            } case none then {
                gpt3 = reg.newType name: bn.stringview typetype: ztypes.ztypetype.GENERIC_PARAM
                reg.setGenericParamTid typeKey: enclKey paramName: bn.stringview tid: gpt3
            }
            gnid3: nodeId n: o
            gpv3b: gpt3
            ty.nodeType.set key: gnid3.u64 value: gpv3b
        }
    } case none then {}
}

# recordGenericMarkerReturn -- a marker-suffixed generic-param return
# (`out of.take` / `out of.borrow`) records its peeled base name at the
# dotted node (pendingTyperef) so the mono-return substitution finds it:
# the plain-atom leg records inside recordTyperef, while the marker leg
# only resolution-stamps.
recordGenericMarkerReturn: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    enclKey: StringView
    o: Option Node
} is {
    match (
        o
    ) case some then {
        mpb3: markerPeeledBase n: o
        if mpb3.length > 0 when (reg.isGenericParamOf typeKey: enclKey name: mpb3.stringview) then {
            mnid3: nodeId n: o
            recordNodeName :ty :unitName name: mpb3.stringview nid: mnid3.u64
        }
    } case none then {}
}

# recordFuncReturnNode -- map a function type id to its return type-ref's node id
# so a call site can read the resolved return type (node_type, post stampTyperefs).
recordFuncReturnNode: function {ty: ztyping.ZTyping fid: u64 o: Option Node} is {
    match (
        o
    ) case some then {
        rn: nodeId n: o
        fidc: fid
        ty.funcReturnNode.set key: fidc value: rn.u64
    } case none then {
    }
}

# recordReturnType -- record a function's `out T` return type-ref (mirrors
# demandReturnType's extraction). A parameterized return (out (Result ...)) yields no
# bare base name and is skipped (its mono is NULL-defined, filtered out anyway).
recordReturnType: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    thisName: StringView
    o: Option Node
} is {
    match (
        o
    ) case some then {
        recordTyperef :ty :reg :units :unitName :thisName node: o
    } case none then {}
}

# demandTyperefNames -- record demands for every name a type-expr
# references (the head and, transitively, parameter-arg names), so the
# demand walks resolve a signature's full closure. Creates no types.
demandTyperefNames: function {reg: ztypes.ZTypeRegistry unitName: StringView typeExpr: Node} is {
    match (
        typeExpr
    ) case atomid then {
        if (isNumericLiteralName name: typeExpr.name.stringview) == false then {
            reg.recordDemand name: typeExpr.name.stringview
            reg.recordSeededDemand un: unitName name: typeExpr.name.stringview
        }
    } case expression then {
        demandTyperefNames :reg :unitName typeExpr: typeExpr.expression
    } case call then {
        hn: atomName n: typeExpr.callable
        if hn.length > 0 then {
            reg.recordDemand name: hn.stringview
            reg.recordSeededDemand un: unitName name: hn.stringview
        }
        aiter: typeExpr.arguments.iterate
        for arg: aiter loop {
            match (
                arg
            ) case namedoperation then {
                demandTyperefNames :reg :unitName typeExpr: arg.operation
            } else {}
        }
    } case dottedpath then {
        demandTyperefNames :reg :unitName typeExpr: typeExpr.parent
    } else {
    }
}

# typeArgSuffixName -- the suffix component a collection type-arg contributes to a
# shell mono name. A bare atom gives its name; a cross-unit dotted ref gives its
# MEMBER name (ztypes.zparamownership -> zparamownership) so the shell's mono name
# matches the construction path's typeNameOf-based name. Without this the dotted
# arg's atomName is "" and the shell mints `Map_u64_` (empty value), a distinct id
# from the constructed `Map_u64_zparamownership` -- the emitter's fieldMonoId
# canonicalizes by name, so divergent names leave a field/create type mismatch.
typeArgSuffixName: function {reg: ztypes.ZTypeRegistry op: Node} out String is {
    match (
        op
    ) case expression then {
        return (typeArgSuffixName :reg op: op.expression)
    } case dottedpath then {
        pNm: atomName n: op.parent
        if (reg.isUnitName name: pNm.stringview) then {
            return (atomName n: op.child)
        } else {
            return "".string
        }
    } else {
        return (atomName n: op)
    }
}

resolveTyperefShell: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    typeExpr: Node
    thisName: StringView
} out u64 is {
    match (
        typeExpr
    ) case atomid then {
        reg.recordDemand name: typeExpr.name.stringview
        reg.recordSeededDemand un: unitName name: typeExpr.name.stringview
        return (resolveAtomType :ty :reg :units :unitName nm: typeExpr.name.stringview :thisName)
    } case labelvalue then {
        return (resolveAtomType :ty :reg :units :unitName nm: typeExpr.name.stringview :thisName)
    } case expression then {
        return (resolveTyperefShell
            :ty
            :reg
            :units
            :unitName
            typeExpr: typeExpr.expression
            :thisName
        )
    } case call then {
        imid8: (resolveMonoRefParts
            :ty
            :reg
            :units
            :unitName
            :thisName
            enclKey: ""
            callable: typeExpr.callable
            arguments: typeExpr.arguments
            nid: 0
        )
        if imid8 > 0 then return imid8
        suffix: atomName n: typeExpr.callable
        reg.recordDemand name: suffix.stringview
        reg.recordSeededDemand un: unitName name: suffix.stringview
        aiter: typeExpr.arguments.iterate
        for arg: aiter loop {
            match (
                arg
            ) case namedoperation then {
                an: typeArgSuffixName :reg op: arg.operation
                suffix.append "_"
                suffix.append an.stringview
                demandTyperefNames :reg :unitName typeExpr: arg.operation
            } else {}
        }
        return (reg.newType name: suffix.stringview typetype: ztypes.ztypetype.RECORD)
    } case dottedpath then {
        # A cross-unit qualified type ref (zlexer.Token) names the MEMBER in the
        # referenced unit -- resolve the child like a bare atom. Otherwise a dotted
        # type-expr peels to its parent: an ownership/access strip marker
        # (Container.private.lock) or a variant/union subtype default where the arm
        # is the default value and the type is the parent (direction.north).
        pNm: atomName n: typeExpr.parent
        if (reg.isUnitName name: pNm.stringview) then {
            cNm: atomName n: typeExpr.child
            reg.recordDemand name: cNm.stringview
            reg.recordSeededDemand un: unitName name: cNm.stringview
            did8: descendNamed :ty :reg :units defUnit: pNm.stringview name: cNm.stringview
            if did8 > 0 then return did8
            return (resolveAtomType :ty :reg :units :unitName nm: cNm.stringview :thisName)
        } else {
            return (resolveTyperefShell
                :ty
                :reg
                :units
                :unitName
                typeExpr: typeExpr.parent
                :thisName
            )
        }
    } else {
        return (reg.newType name: "?" typetype: ztypes.ztypetype.RECORD)
    }
}

# regTypeNameOf -- a type's name (owned copy) straight off the registry.
regTypeNameOf: function {reg: ztypes.ZTypeRegistry tid: u64} out String is {
    t: reg.typeById.get key: tid
    match (
        t
    ) case some then {
        return t.name.copy
    } case none then {
        return "".string
    }
}

# typeofSourceType -- resolve a typeof field's SOURCE without a body walk
# (the reference's resolution-time method walks run its placeholder swap
# even in resolve-only mode; our sources are signature-resolvable): a bare
# atom reads the owner's already-resolved field of that name (a generator
# parameter capture), and a call to a lowered factory yields the factory's
# `{name}_iter` class. 0 when the shape needs the body walk.
typeofSourceType: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    ownerId: u64
    n: Node
} out u64 is {
    match (
        n
    ) case expression then {
        return (typeofSourceType :ty :reg :unitName :ownerId n: n.expression)
    } case atomid then {
        if ownerId == 0 then return 0
        co: ty.childOf parentTypeId: ownerId name: n.name.stringview
        match (
            co
        ) case some then {
            cn9: regTypeNameOf :reg tid: co
            if cn9.length > 0 then {
                ro9: walkLookupTyperef :ty :reg currentUnit: unitName base: cn9.stringview
                match (
                    ro9
                ) case some then {
                    return ro9
                } case none then {
                    return co
                }
            } else {
                return co
            }
        } case none then {
            return 0
        }
    } case call then {
        fn9: atomName n: n.callable
        if fn9.length > 0 then {
            sk9: "\{unitName}.\{fn9}_iter"
            so9: resolvedByKey :ty :reg key: sk9
            match (
                so9
            ) case some then {
                return so9
            } case none then {
                return 0
            }
        } else {
            return 0
        }
    } else {
        return 0
    }
}

# resolveTyperefShellMarked -- resolveTyperefShell plus the typeof handling:
# a generator-promoted local's field type is a `typeof <first-rhs>` node.
# When the source resolves from signatures alone the field types directly
# (and the typeof node stamps); otherwise the shell is marked and the
# body's first `this.<field> =` write swaps it (the reference's
# placeholder mechanism).
resolveTyperefShellMarked: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    ownerId: u64
    typeExpr: Node
    thisName: StringView
} out u64 is {
    isTof: false
    match (
        typeExpr
    ) case typeofexpr then {
        isTof = true
        rid9: typeofSourceType :ty :reg :unitName :ownerId n: typeExpr.source
        if rid9 > 0 then {
            # the node's stamp defers to the post-demand pass so it lands
            # on the globally-resolved type, not an early shell
            tnm9: regTypeNameOf :reg tid: rid9
            if tnm9.length > 0 then {
                ty.pendingTyperef.set key: typeExpr.nodeid.u64 value: tnm9
                tun9: unitName.string
                ty.pendingTyperefUnit.set key: typeExpr.nodeid.u64 value: tun9
            }
            return rid9
        }
    } else {
    }
    prevCE9: ty.inContainmentEdge
    ty.inContainmentEdge = true
    cid: resolveTyperefShell :ty :reg :units :unitName :typeExpr :thisName
    ty.inContainmentEdge = prevCE9
    if isTof then {
        match (
            typeExpr
        ) case typeofexpr then {
            tk: cid
            tv: typeExpr.nodeid
            ty.typeofShell.set key: tk value: tv
        } else {
        }
    }
    return cid
}

# nameIsInUnitReftype -- true when a type name resolves to an in-unit reference type
# (class or union). Drives the reftype-param BORROW default and class field cleanup.
# Native heap params (String/List/Map) are pointer-typed already and get no BORROW
# default (mirrors the reference's `not is_heap_allocated` guard), so they are NOT
# matched here -- only user class/union types defined in this unit.
nameIsInUnitReftype: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    name: StringView
} out bool is {
    rr: resolveUnitChild :ty :reg :unitName :name
    match (
        rr
    ) case some then {
        tt: reg.typetypeOf typeId: rr
        match (
            tt
        ) case CLASS then {
            return true
        } case UNION then {
            return true
        } else {
            return false
        }
    } case none then {
        return false
    }
}

# paramTypeBaseName -- the base type name of a (possibly parameterized) param type
# expression: an atom name directly, or the callable of a parenthesized
# `(List of: i64)` form (an expression wrapping a call). "" for anything else.
# returnHasBorrowMarkerNode / returnHasBorrowMarker -- the function's return
# type carries the `.borrow` marker (`out StringView.borrow`).
returnHasBorrowMarkerNode: function {n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (returnHasBorrowMarkerNode n: n.expression)
    } case dottedpath then {
        cn: atomName n: n.child
        return cn.stringview == "borrow"
    } else {
        return false
    }
}

returnHasBorrowMarker: function {o: Option Node} out bool is {
    match (
        o
    ) case some then {
        return (returnHasBorrowMarkerNode n: o)
    } case none then {
        return false
    }
}

# paramIsThisReceiver -- the parameter's type names the receiver: bare `this`
# or a marker-suffixed `this.lock` / `this.borrow`.
paramIsThisReceiver: function {op: Node} out bool is {
    match (
        op
    ) case expression then {
        return (paramIsThisReceiver op: op.expression)
    } case atomid then {
        return op.name.stringview == "this"
    } case dottedpath then {
        pn: atomName n: op.parent
        return pn.stringview == "this"
    } else {
        return false
    }
}

paramTypeBaseName: function {op: Node} out String is {
    match (
        op
    ) case atomid then {
        return op.name.copy
    } case labelvalue then {
        return op.name.copy
    } case expression then {
        return (paramTypeBaseName op: op.expression)
    } case call then {
        return (atomName n: op.callable)
    } else {
        return "".string
    }
}

# isBorrowReftypeCollection -- true for a parameterized collection whose mono is a
# non-heap-allocated reftype, which takes the reftype-param BORROW default: List and
# ListView (stack struct + heap buffer). Set/Map monos are heap-allocated (no BORROW);
# the native iterator views have no destructor (no BORROW); str/array are valtypes.
# Mirrors the is_heap_allocated the reference stamps on collection monos.
isBorrowReftypeCollection: function {name: StringView} out bool is {
    if name == "List" then return true
    if name == "ListView" then return true
    return false
}

# isBorrowNativeReftype -- true for native heap-owning reftypes (currently String)
# that take the BORROW default as an unannotated param. Keyed by name, like the
# classifiers above: the oracle decides by metadata (a native CLASS that owns heap,
# not is_heap_allocated), but native types resolve AFTER the main unit, so that
# metadata is not yet populated when a param resolves.
isBorrowNativeReftype: function {name: StringView} out bool is {
    if name == "String" then return true
    return false
}

# isNativeValueView -- true for StringView, the native immutable string view (subtype
# STRINGVIEW): a param of this type stays unowned (a value-passed copy of a borrowed
# view), so it takes no BORROW default. Other reftypes -- String (native, owns heap),
# the mutable iterators (CpIter/Splitter/LinesIter), and non-native views (ListView/
# OptionView) -- take the normal reftype-param BORROW default.
isNativeValueView: function {name: StringView} out bool is {
    if name == "StringView" then return true
    return false
}

# demandReturnType -- record cross-unit demand for a function's return-type base
# name (`out (Result t: u64 e: IoError)` -> demand "Result"), so a type named only
# in a return position is resolved. The Option is borrowed, never bound.
demandReturnType: function {reg: ztypes.ZTypeRegistry unitName: StringView o: Option Node} is {
    match (
        o
    ) case some then {
        demandTyperefNames :reg :unitName typeExpr: o
    } case none then {}
}

# resolveFunction -- resolve a function definition signature into a FUNCTION
# type: a child per parameter (param name -> type-ref shell, `this` params bound
# to thisName), its defining unit (source-types filter), and a `{unit}.{name}`
# entry in the resolved name-view. Returns the FUNCTION type id (a record method
# binds it as a child; a free function discards it). The map `set`s TAKE the u64,
# so copies are threaded for `definedInUnit.set` and the returned id.
resolveFunction: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    defName: StringView
    fnode: zast.FunctionData
    thisName: StringView
    skipThisType: bool
} out u64 is {
    fid: (declareCanonicalType
        :ty
        :reg
        defUnit: unitName
        name: defName
        typetype: ztypes.ztypetype.FUNCTION
    )
    reg.setNative typeId: fid value: fnode.isNative
    {
        fhbV: false
        match (
            fnode.body
        ) case some then {
            fhbV = true
        } case none then {}
        fhbK: fid
        ty.fnHasBody.set key: fhbK value: fhbV
    }
    dfid: fid
    rfid: fid
    isgen: hasGenericParam items: fnode.asItems
    if isgen then {
        reg.setGeneric typeId: fid value: true
        # Function templates register their param constraints like type
        # templates do (checkGenericCall checks satisfaction per call).
        fgtk9: "\{unitName}.\{defName}"
        registerGenericParams :reg typeKey: fgtk9.stringview items: fnode.asItems
        aiter2: fnode.asItems.iterate
        for am: aiter2 loop {
            match (
                am
            ) case namedoperation then {
                if (isGenericParam op: am.operation) then {
                    apn: unitLabel o: am.name
                    ty.setGenericArg parentTypeId: fid paramName: apn.stringview argTypeId: 0
                }
            } else {}
        }
        hasB: false
        match (
            fnode.body
        ) case some then {
            hasB = true
        } case none then {}
        if hasB then {
            dvg: bodyEndsInReturn bodyOpt: fnode.body
            fidd: fid
            ty.fnBodyDiverges.set key: fidd value: dvg
        }
    }
    enclKey: unitName.string
    if thisName.length != 0 then enclKey = "\{unitName}.\{thisName}"
    fnKey9: "".string
    if isgen then fnKey9 = "\{unitName}.\{defName}"
    piter: fnode.parameters.iterate
    for pm: piter loop {
        match (
            pm
        ) case namedoperation then {
            skipParam: false
            genParam: false
            fnParam9: false
            ptn: atomName n: pm.operation
            if skipThisType then {
                if ptn.stringview == "this" then skipParam = true
            }
            if skipParam == false when isgen then {
                if (reg.isGenericParamOf typeKey: fnKey9.stringview name: ptn.stringview) then {
                    skipParam = true
                    fnParam9 = true
                }
            }
            if skipParam == false when (reg.isGenericParamOf
                typeKey: enclKey.stringview
                name: ptn.stringview
            ) then {
                skipParam = true
                genParam = true
            }
            if skipParam then {
                if fnParam9 then {
                    # the template's own param: bind the canonical
                    # per-(template,param) tid as the child so holder
                    # inference and the idSubs clone substitution ride it.
                    # No node stamp (fn monos re-walk the SHARED template
                    # AST) and no typeref/demand recording (a user type
                    # coincidentally named like the param must not bind).
                    pnameF9: unitLabel o: pm.name
                    fpt9: 0.u64
                    fpo9: reg.genericParamTidOf typeKey: fnKey9.stringview paramName: ptn.stringview
                    match (
                        fpo9
                    ) case some then {
                        fpt9 = fpo9
                    } case none then {
                        fpt9 = (reg.newType
                            name: ptn.stringview
                            typetype: ztypes.ztypetype.GENERIC_PARAM
                        )
                        (reg.setGenericParamTid
                            typeKey: fnKey9.stringview
                            paramName: ptn.stringview
                            tid: fpt9
                        )
                    }
                    ty.setChild parentTypeId: fid childName: pnameF9.stringview childTypeId: fpt9
                }
                if genParam then {
                    # the unit's own param: stamp the param node with the
                    # canonical per-(enclosing,param) tid (get-or-mint). No
                    # setChild -- unit template methods stay childless (emit
                    # `(void)`); unit bodies clone, so the stamp is per-clone.
                    gpt2: 0.u64
                    gpo2: (reg.genericParamTidOf
                        typeKey: enclKey.stringview
                        paramName: ptn.stringview
                    )
                    match (
                        gpo2
                    ) case some then {
                        gpt2 = gpo2
                    } case none then {
                        gpt2 = (reg.newType
                            name: ptn.stringview
                            typetype: ztypes.ztypetype.GENERIC_PARAM
                        )
                        (reg.setGenericParamTid
                            typeKey: enclKey.stringview
                            paramName: ptn.stringview
                            tid: gpt2
                        )
                    }
                    pnid2: nodeId n: pm.operation
                    gpv2b: gpt2
                    ty.nodeType.set key: pnid2.u64 value: gpv2b
                }
            } else {
                pname: unitLabel o: pm.name
                cid: resolveTyperefShell :ty :reg :units :unitName typeExpr: pm.operation :thisName
                ty.setChild parentTypeId: fid childName: pname.stringview childTypeId: cid
                if (isNumericLiteralName name: ptn.stringview) then {
                    (ty.setChildDefault
                        parentTypeId: fid
                        name: pname.stringview
                        default: ptn.stringview
                    )
                } else {
                    fnRefIsFn9: false
                    fnRefOpt9: walkLookupTyperef :ty :reg currentUnit: unitName base: ptn.stringview
                    match (
                        fnRefOpt9
                    ) case some then {
                        if (reg.typetypeOf typeId: fnRefOpt9) == ztypes.ztypetype.FUNCTION then {
                            fnRefIsFn9 = true
                        }
                    } case none then {}
                    if fnRefIsFn9 then {
                        (ty.setDefaultFunction
                            parentTypeId: fid
                            name: pname.stringview
                            funcname: ptn.stringview
                        )
                    } else {
                        pdcn9: dottedChildName n: pm.operation
                        if pdcn9.length > 0 when (isStripMarker name: pdcn9.stringview) == false then {
                            prn9: rootNameOf n: pm.operation
                            if (reg.isUnitName name: prn9.stringview) == false then {
                                (ty.setDefaultVariantArm
                                    parentTypeId: fid
                                    name: pname.stringview
                                    armName: pdcn9.stringview
                                )
                            }
                        }
                    }
                }
                if (paramIsThisReceiver op: pm.operation) then {
                    reg.setThisParamName typeId: fid name: pname.stringview
                }
                recordTyperef :ty :reg :units :unitName :thisName node: pm.operation
                pown: pathOwnership n: pm.operation
                match (
                    pown
                ) case some then {
                    ty.setChildOwnership parentTypeId: fid name: pname.stringview ownership: pown
                } case none then {
                    isref: paramIsBorrowReftype :ty :reg :unitName :thisName op: pm.operation
                    if isref then {
                        (ty.setChildOwnership
                            parentTypeId: fid
                            name: pname.stringview
                            ownership: ztypes.zparamownership.BORROW
                        )
                    }
                }
            }
        } else {}
    }
    demandReturnType :reg :unitName o: fnode.returntype
    recordReturnType :ty :reg :units :unitName :thisName o: fnode.returntype
    recordFuncReturnNode :ty :fid o: fnode.returntype
    stampGenericParamRef :ty :reg enclKey: enclKey.stringview o: fnode.returntype
    (recordGenericMarkerReturn
        :ty
        :reg
        :unitName
        enclKey: enclKey.stringview
        o: fnode.returntype
    )
    rpt4: 0.u64
    if isgen then rpt4 = returnParamTid :reg enclKey: fnKey9.stringview o: fnode.returntype
    if rpt4 == 0 then rpt4 = returnParamTid :reg enclKey: enclKey.stringview o: fnode.returntype
    if rpt4 > 0 then reg.setReturnType typeId: fid value: rpt4
    if rpt4 == 0 when unitName == "collections" then {
        # collection template methods declare composite parameterized returns
        # ((ListIter of: of).borrow); they resolve to partial specs so clones
        # heal through respecialize. Map.get/remove keep their value-kind
        # wrapper projection (optionval/Option/OptionView by the value's
        # nature) and are skipped here.
        skipPr4: false
        if defName == "Map.get" then skipPr4 = true
        if defName == "Map.remove" then skipPr4 = true
        if skipPr4 == false then {
            prt4: (partialReturnTid
                :ty
                :reg
                :units
                :unitName
                enclKey: enclKey.stringview
                o: fnode.returntype
            )
            if prt4 > 0 then reg.setReturnType typeId: fid value: prt4
        }
    }
    if (returnHasBorrowMarker o: fnode.returntype) then {
        fbk: fid
        fbv: true
        ty.funcReturnsBorrow.set key: fbk value: fbv
    }
    ty.definedInUnit.set key: dfid value: unitName.string
    return rfid
}

# paramIsBorrowReftype -- the default-ownership rule for a parameter with no
# explicit suffix: user reftypes (and the borrow-default native reftypes /
# collections) borrow; native value views do not.
paramIsBorrowReftype: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    thisName: StringView
    op: Node
} out bool is {
    tn: atomName n: op
    isref: false
    if tn.stringview == "this" then {
        isref = nameIsInUnitReftype :ty :reg :unitName name: thisName
        if (isref) == false then {
            tk0: thisName.string
            rgo: ty.mainDefIsReftype.get key: tk0
            match (
                rgo
            ) case some then {
                isref = rgo
            } case none then {}
        }
        if (isNativeValueView name: thisName) then isref = false
    } else {
        if tn.length == 0 then {
            base: paramTypeBaseName :op
            isref = isBorrowReftypeCollection name: base.stringview
        } else {
            isref = nameIsInUnitReftype :ty :reg :unitName name: tn.stringview
            tdu: definingUnitFor :ty currentUnit: unitName name: tn.stringview
            if (isBorrowNativeReftype name: tn.stringview) when tdu.stringview == "system" then {
                isref = true
            }
            if (isNativeValueView name: tn.stringview) when tdu.stringview == "system" then {
                isref = false
            }
        }
    }
    return isref
}

# resolveMethodFn -- resolve one record-method as-item (a namedoperation whose
# operation is a functiondef) into a qualified `{record}.{method}` FUNCTION type,
# `this` params bound to thisName (the record). Returns its type id, or none for a
# non-function as-item (tag spec / generic param), which the caller skips.
resolveMethodFn: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    qname: StringView
    thisName: StringView
    op: Node
} out optionval u64 is {
    match (
        op
    ) case functiondef then {
        mid: (resolveFunction
            :ty
            :reg
            :units
            :unitName
            defName: qname
            fnode: op
            :thisName
            skipThisType: false
        )
        midS: mid
        ty.nodeType.set key: op.nodeid.u64 value: midS
        return (optionval.some mid)
    } else {
        return (optionval.none u64)
    }
}

# functiondefIsNative -- an is-block method marked `is native` (no body to
# check or emit; its members come from the native materializer).
functiondefIsNative: function {op: Node} out bool is {
    match (
        op
    ) case functiondef then {
        return op.isNative
    } else {
        return false
    }
}

# isFunctionDefOp -- true when an is-block item's operation is a functiondef (a
# method), false for a field type-ref. Gates generic-class method production without
# resolving the function -- mirrors the oracle's isgeneric gate, which never builds a
# method FUNCTION type for a generic class (so no spurious collections FUNCTION row).
isFunctionDefOp: function {op: Node} out bool is {
    match (
        op
    ) case functiondef then {
        return true
    } else {
        return false
    }
}

# resolveSpecFn -- resolve one facet/protocol is-block spec method (a namedoperation
# whose operation is a functiondef) into a qualified `{type}.{spec}` FUNCTION. Like
# resolveMethodFn but drops the `:this` receiver: a facet/protocol `this` resolves to
# nothing (the reference returns no type), so the spec keeps only its real params.
resolveSpecFn: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    qname: StringView
    thisName: StringView
    op: Node
    skipThis: bool
} out optionval u64 is {
    match (
        op
    ) case functiondef then {
        sid: (resolveFunction
            :ty
            :reg
            :units
            :unitName
            defName: qname
            fnode: op
            :thisName
            skipThisType: skipThis
        )
        sidS: sid
        ty.nodeType.set key: op.nodeid.u64 value: sidS
        return (optionval.some sid)
    } else {
        return (optionval.none u64)
    }
}

# markerTargetId -- the FACET/PROTOCOL type a conformance as-item points at
# (`m: measurable` / `myreader: Reader`), or none for a method / `create: null` /
# any other as-item. The target must already be resolved (defined earlier in the unit).
markerTargetId: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    op: Node
} out optionval u64 is {
    tn: atomName n: op
    if tn.length == 0 then return (optionval.none u64)
    rkey: "\{unitName}.\{tn}"
    rr: resolvedByKey :ty :reg key: rkey
    match (
        rr
    ) case some then {
        tt: reg.typetypeOf typeId: rr
        match (
            tt
        ) case FACET then {
            return (optionval.some rr)
        } case PROTOCOL then {
            return (optionval.some rr)
        } case RECORD then {
            return (optionval.some rr)
        } else {
            return (optionval.none u64)
        }
    } case none then {
        return (optionval.none u64)
    }
}

# attachMethods -- resolve an as-block's method items (namedoperation -> functiondef)
# as children of `parentId`, returning whether one is named `create` (so the caller
# skips the synth create). Takes the item list by value so its iterator's lock is
# released on return -- letting attachMarkers re-scan the same list (cf. resolveUnion).
attachMethods: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    defName: StringView
    parentId: u64
    asItems: List Node
} out bool is {
    hasCreate: false
    aiter: asItems.iterate
    for am: aiter loop {
        match (
            am
        ) case namedoperation then {
            mname: unitLabel o: am.name
            if mname.stringview == "create" then hasCreate = true
            qname: "\{defName}.\{mname}"
            mido: (resolveMethodFn
                :ty
                :reg
                :units
                :unitName
                qname: qname.stringview
                thisName: defName
                op: am.operation
            )
            match (
                mido
            ) case some then {
                ty.setChild parentTypeId: parentId childName: mname.stringview childTypeId: mido
            } case none then {
                cn: atomName n: am.operation
                if (isNumericLiteralName name: cn.stringview) then {
                    # A static constant's child is a per-constant NULL-unit
                    # clone of the literal's default type: named through the
                    # type_children join, filtered from typed_nodes.
                    clname: "i64"
                    if (isFloatLiteralName name: cn.stringview) then clname = "f64"
                    cid: reg.newType name: clname typetype: ztypes.ztypetype.RECORD
                    ty.setChild parentTypeId: parentId childName: mname.stringview childTypeId: cid
                    ty.markAsConstClone typeId: cid
                    cnid3: nodeId n: am.operation
                    cidc: cid
                    ty.nodeType.set key: cnid3.u64 value: cidc
                }
            }
            gfn: "\{defName}_\{mname}"
            (synthGeneratorForMethod
                :ty
                :reg
                :units
                :unitName
                fnName: gfn.stringview
                thisName: defName
                op: am.operation
            )
        } else {}
    }
    return hasCreate
}

# attachMarkers -- resolve an as-block's facet/protocol conformance markers
# (`m: measurable` / `myreader: Reader`) as children of `parentId`, run AFTER the
# methods so markers take later positions. Returns whether any marker target owns a
# destructor (a protocol), so a class holder keeps its own.
# recordConformance -- record an impl-satisfies-spec conformance, but only when the
# spec resolves to a FACET or PROTOCOL (a RECORD marker like a numeric's `tag: tag` is a
# discriminator child, NOT a conformance). Mirrors _record_conformance (ztypecheck.py:3516);
# the helper C names (vtable/create/destroy/wrapper) are emitter-set and stay empty here.
recordConformance: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    implTypeId: u64
    specTypeId: u64
    label: StringView
} is {
    tt: reg.typetypeOf typeId: specTypeId
    recordIt: false
    isFacetC: false
    match (
        tt
    ) case FACET then {
        recordIt = true
        isFacetC = true
    } case PROTOCOL then {
        recordIt = true
    } else {}
    if recordIt then {
        cf: reg.newConformance :implTypeId :specTypeId :label isFacet: isFacetC
        ty.conformance.append cf
    }
}

attachMarkers: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    parentId: u64
    asItems: List Node
} out bool is {
    needsDtor: false
    miter: asItems.iterate
    for mm: miter loop {
        match (
            mm
        ) case namedoperation then {
            cnm: atomName n: mm.operation
            if (isNumericLiteralName name: cnm.stringview) == false then {
                recordTyperef :ty :reg :units :unitName thisName: "" node: mm.operation
            }
            mtid: markerTargetId :ty :reg :unitName op: mm.operation
            match (
                mtid
            ) case some then {
                mlbl: unitLabel o: mm.name
                ty.setChild parentTypeId: parentId childName: mlbl.stringview childTypeId: mtid
                if (reg.hasDestructorName typeId: mtid) then needsDtor = true
                (recordConformance
                    :ty
                    :reg
                    implTypeId: parentId
                    specTypeId: mtid
                    label: mlbl.stringview
                )
            } case none then {
                if (isLabelValue op: mm.operation) then {
                    amlbl: unitLabel o: mm.name
                    amlid: (resolveAtomType
                        :ty
                        :reg
                        :units
                        :unitName
                        nm: amlbl.stringview
                        thisName: ""
                    )
                    (ty.setChild
                        parentTypeId: parentId
                        childName: amlbl.stringview
                        childTypeId: amlid
                    )
                    acf: (reg.newConformance
                        implTypeId: parentId
                        specTypeId: amlid
                        label: amlbl.stringview
                        isFacet: false
                    )
                    ty.conformance.append acf
                }
            }
        } else {}
    }
    return needsDtor
}

# dataOutTypeName -- the element-type name from a data block's optional `out T`
# (an atom type-expr), or "" when absent. The Option is BORROWED (param), never
# bound to a local: a bare bind would move the Option out of the shared AST node
# and free its payload, corrupting the later dump walk.
dataOutTypeName: function {o: Option Node} out String is {
    match (
        o
    ) case some then {
        return (atomName n: o)
    } case none then {
        return "".string
    }
}

# resolveData -- resolve a data-block definition into a DATA type: one `literal_int`
# child per element (the element's own label when present, else its ordinal) plus a
# `tag` child typed `tag__{element-type}` -- the `out T` width when declared, else
# i64 -- mark it a non-valtype, then record its defining unit + `{unit}.{name}` view.
# Elements stay literal_int (coerced per use); typed / float elements arrive with the
# examples that exercise them.
resolveData: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    defName: StringView
    dnode: zast.DataBlockData
} is {
    did: (declareCanonicalType
        :ty
        :reg
        defUnit: unitName
        name: defName
        typetype: ztypes.ztypetype.DATA
    )
    ddid: did
    reg.setValtype typeId: did value: false
    if ty.literalIntShellId == 0 then {
        ty.literalIntShellId = reg.newType name: "literal_int" typetype: ztypes.ztypetype.RECORD
        reg.setValtype typeId: ty.literalIntShellId value: true
    }
    litId: ty.literalIntShellId
    ordinal: 0.u64
    eiter: dnode.elements.iterate
    for el: eiter loop {
        match (
            el
        ) case namedoperation then {
            nm: unitLabel o: el.name
            if nm.length == 0 then {
                ord: "\{ordinal}"
                ty.setChild parentTypeId: did childName: ord.stringview childTypeId: litId
            } else {
                ty.setChild parentTypeId: did childName: nm.stringview childTypeId: litId
            }
        } else {}
        ordinal = ordinal + 1
    }
    etn: dataOutTypeName o: dnode.outType
    tagName: "tag__i64".string
    if etn.length != 0 then tagName = "tag__\{etn.stringview}"
    tagId: (declareCanonicalType
        :ty
        :reg
        defUnit: "system"
        name: tagName.stringview
        typetype: ztypes.ztypetype.RECORD
    )
    ty.setChild parentTypeId: did childName: "tag" childTypeId: tagId
    ty.definedInUnit.set key: ddid value: unitName.string
}

# isTypedefField -- true when a type-expr Node is an `X.typedef` dottedpath (the
# marker that makes a record a zero-overhead typedef wrapper). Matching the Node
# param narrows it cleanly.
isTypedefField: function {n: Node} out bool is {
    match (
        n
    ) case dottedpath then {
        cn: atomName n: n.child
        return (cn.stringview == "typedef")
    } else {
        return false
    }
}

# recordIsTypedef -- true when a record's `is` body carries a single `X.typedef`
# field. Such a record gets no field child and synthesizes `create`+`borrow`
# instead of `create`/`==`/`!=`.
recordIsTypedef: function {rnode: zast.ObjectDefData} out bool is {
    fiter: rnode.isItems.iterate
    for fm: fiter loop {
        match (
            fm
        ) case namedoperation then {
            if (isTypedefField n: fm.operation) then return true
        } else {}
    }
    return false
}

# typedefFieldBaseName -- the base type name of an `X.typedef` field's `X`
# (e.g. `(List of: u8).typedef` -> "List"). Borrows the Node, never binds it (a
# bare bind would move the type-expr out of the shared AST).
typedefFieldBaseName: function {n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        return (paramTypeBaseName op: n.parent)
    } else {
        return "".string
    }
}

# mangledTypeName -- a type ref's resolvable name: bare atoms as-is, a
# parameterized ref as its instance mangling (`(List of: u8)` ->
# "List_u8"), matching the shell/mono naming so member delegation finds
# the minted instance.
mangledTypeName: function {op: Node} out String is {
    match (
        op
    ) case atomid then {
        return op.name.copy
    } case labelvalue then {
        return op.name.copy
    } case expression then {
        return (mangledTypeName op: op.expression)
    } case call then {
        base: atomName n: op.callable
        aiter: op.arguments.iterate
        for arg: aiter loop {
            match (
                arg
            ) case namedoperation then {
                an: atomName n: arg.operation
                if an.length > 0 then {
                    base.append s: "_"
                    base.append s: an.stringview
                }
            } else {
            }
        }
        return base
    } case dottedpath then {
        return (atomName n: op.child)
    } else {
        return "".string
    }
}

# objectTypedefBase -- the base type name of an objectdef's single `X.typedef`
# field (the typedef wrapper base), or "" when the object is not a typedef.
objectTypedefBase: function {onode: zast.ObjectDefData} out String is {
    fiter: onode.isItems.iterate
    for fm: fiter loop {
        match (
            fm
        ) case namedoperation then {
            if (isTypedefField n: fm.operation) then return (typedefFieldBaseName n: fm.operation)
        } else {}
    }
    return "".string
}

# typedefFieldMangledName -- the mangled instance name of an `X.typedef`
# field's `X` (`(List of: u8).typedef` -> "List_u8"), the minted-mono key
# member delegation resolves through.
typedefFieldMangledName: function {n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        return (mangledTypeName op: n.parent)
    } else {
        return "".string
    }
}

# objectTypedefMangled -- the mangled base-instance name of an objectdef's
# single `X.typedef` field, or "" when the object is not a typedef.
objectTypedefMangled: function {onode: zast.ObjectDefData} out String is {
    fiter: onode.isItems.iterate
    for fm: fiter loop {
        match (
            fm
        ) case namedoperation then {
            if (isTypedefField n: fm.operation) then {
                return (typedefFieldMangledName n: fm.operation)
            }
        } else {}
    }
    return "".string
}

# resolveRecord -- resolve a record ObjectDef into a RECORD valtype. A normal
# record: a child per field (field name -> type-ref shell), a child per as-block
# method, then synthesized `create`/`==`/`!=`. A typedef record (single
# `X.typedef` field): no field child, the methods, then `create`+`borrow`. Synth
# children are shallow FUNCTION shells (JOIN-only). Generics arrive later.
# fnFieldFlaggableName -- an is-block FUNCTION member that should become a struct
# fnptr slot (a spec field / method / method-ref), excluding the constructor and
# comparison synthetics so they stay free functions / ctors.
fnFieldFlaggableName: function {name: StringView} out bool is {
    if name == "create" then return false
    if name == "==" then return false
    if name == "!=" then return false
    if name == "borrow" then return false
    return true
}

resolveRecord: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    defName: StringView
    rnode: zast.ObjectDefData
} is {
    rid: (declareCanonicalType
        :ty
        :reg
        defUnit: unitName
        name: defName
        typetype: ztypes.ztypetype.RECORD
    )
    rrid: rid
    reg.setValtype typeId: rid value: true
    isgen: hasGenericParam items: rnode.asItems
    if isgen then {
        reg.setGeneric typeId: rid value: true
        rtk: "\{unitName}.\{defName}"
        registerGenericParams :reg typeKey: rtk.stringview items: rnode.asItems
    }
    istd: recordIsTypedef :rnode
    if istd then {
        tdb: objectTypedefBase onode: rnode
        if tdb.length > 0 then {
            tdk: rid
            ty.typedefBaseName.set key: tdk value: tdb
        }
        tdm: objectTypedefMangled onode: rnode
        if tdm.length > 0 then {
            tdk2: rid
            ty.typedefBaseMangled.set key: tdk2 value: tdm
        }
    }
    hasCreateIs: false
    hasEqIs: false
    if (istd) == false then {
        fiter: rnode.isItems.iterate
        for fm: fiter loop {
            match (
                fm
            ) case namedoperation then {
                fname: unitLabel o: fm.name
                qname: "\{defName}.\{fname}"
                mido: (resolveMethodFn
                    :ty
                    :reg
                    :units
                    :unitName
                    qname: qname.stringview
                    thisName: defName
                    op: fm.operation
                )
                match (
                    mido
                ) case some then {
                    if fname.stringview == "create" then hasCreateIs = true
                    if fname.stringview == "==" then hasEqIs = true
                    ty.setChild parentTypeId: rid childName: fname.stringview childTypeId: mido
                    if (fnFieldFlaggableName name: fname.stringview) then {
                        ty.setChildFnptrField parentTypeId: rid name: fname.stringview
                    }
                } case none then {
                    ftnR9: fieldHeadName n: fm.operation
                    mkeyR9: "\{unitName}.\{defName}.\{ftnR9}"
                    mrefR9: resolvedByKey :ty :reg key: mkeyR9
                    handledR9: false
                    match (
                        mrefR9
                    ) case some then {
                        (ty.setChild
                            parentTypeId: rid
                            childName: fname.stringview
                            childTypeId: mrefR9
                        )
                        if (reg.typetypeOf typeId: mrefR9) == ztypes.ztypetype.FUNCTION then {
                            ty.setChildFnptrField parentTypeId: rid name: fname.stringview
                        }
                        pdkR9: nodeId n: fm.operation
                        pdoR9: rid
                        ty.pendingDefaultOwner.set key: pdkR9.u64 value: pdoR9
                        pdk2R9: nodeId n: fm.operation
                        pdiR9: mrefR9
                        ty.pendingDefaultId.set key: pdk2R9.u64 value: pdiR9
                        handledR9 = true
                    } case none then {}
                    if (handledR9) == false then {
                        cid: (resolveTyperefShellMarked
                            :ty
                            :reg
                            :units
                            :unitName
                            ownerId: 0
                            typeExpr: fm.operation
                            thisName: defName
                        )
                        ty.setChild parentTypeId: rid childName: fname.stringview childTypeId: cid
                        if (reg.typetypeOf typeId: cid) == ztypes.ztypetype.FUNCTION then {
                            ty.setChildFnptrField parentTypeId: rid name: fname.stringview
                        }
                        recordTyperef :ty :reg :units :unitName thisName: "" node: fm.operation
                        dcn1: dottedChildName n: fm.operation
                        rdnr: rootNameOf n: fm.operation
                        if (isNumericLiteralName name: rdnr.stringview) then {
                            (ty.setChildDefault
                                parentTypeId: rid
                                name: fname.stringview
                                default: rdnr.stringview
                            )
                        } else {
                            if dcn1.length > 0 when (isStripMarker name: dcn1.stringview) == false when (reg.isUnitName name: rdnr.stringview) == false then {
                                (ty.setDefaultVariantArm
                                    parentTypeId: rid
                                    name: fname.stringview
                                    armName: dcn1.stringview
                                )
                            }
                        }
                        if dcn1.length > 0 when (isStripMarker name: dcn1.stringview) then {} else {
                            if dcn1.length > 0 then {
                                rdk3: nodeId n: fm.operation
                                rdo3: rid
                                ty.pendingDefaultOwner.set key: rdk3.u64 value: rdo3
                                rdk4: nodeId n: fm.operation
                                rdn4: rootNameOf n: fm.operation
                                ty.pendingDefaultName.set key: rdk4.u64 value: rdn4
                            }
                        }
                    }
                }
            } else {}
        }
    }
    hasCreateAs: (attachMethods
        :ty
        :reg
        :units
        :unitName
        :defName
        parentId: rid
        asItems: rnode.asItems
    )
    hasCreate: hasCreateIs
    if hasCreateAs then hasCreate = true
    attachMarkers :ty :reg :units :unitName parentId: rid asItems: rnode.asItems
    if (hasCreate) == false then {
        createName: "\{defName}.create"
        createId: reg.newType name: createName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: rid childName: "create" childTypeId: createId
    }
    if istd then {
        borrowName: "\{defName}.borrow"
        borrowId: reg.newType name: borrowName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: rid childName: "borrow" childTypeId: borrowId
    } else {
        if (isgen) == false then {
            if (hasEqIs) == false then {
                eqName: "\{defName}.=="
                eqId: reg.newType name: eqName.stringview typetype: ztypes.ztypetype.FUNCTION
                ty.setChild parentTypeId: rid childName: "==" childTypeId: eqId
                neqName: "\{defName}.!="
                neqId: reg.newType name: neqName.stringview typetype: ztypes.ztypetype.FUNCTION
                ty.setChild parentTypeId: rid childName: "!=" childTypeId: neqId
            }
        }
    }
    ty.definedInUnit.set key: rrid value: unitName.string
}

# resolveVariant -- resolve a variant ObjectDef into a VARIANT valtype: a child per
# arm (arm name -> payload type-ref shell; a `null` arm -> the `null` shell), a
# synthesized `tag` child (the `{name}:tag:data` discriminator wrapper), any as-block
# methods, then synthesized `==`/`!=`. Variants have no `create` (bare construction is
# disabled). Custom-DATA tags + generics arrive later.
resolveVariant: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    defName: StringView
    vnode: zast.ObjectDefData
} is {
    vid: (declareCanonicalType
        :ty
        :reg
        defUnit: unitName
        name: defName
        typetype: ztypes.ztypetype.VARIANT
    )
    vvid: vid
    reg.setValtype typeId: vid value: true
    isgen: hasGenericParam items: vnode.asItems
    if isgen then {
        reg.setGeneric typeId: vid value: true
        gtk9: "\{unitName}.\{defName}"
        registerGenericParams :reg typeKey: gtk9.stringview items: vnode.asItems
    }
    fiter: vnode.isItems.iterate
    for fm: fiter loop {
        match (
            fm
        ) case namedoperation then {
            aname: unitLabel o: fm.name
            cid: (resolveTyperefShellMarked
                :ty
                :reg
                :units
                :unitName
                ownerId: 0
                typeExpr: fm.operation
                thisName: defName
            )
            ty.setChild parentTypeId: vid childName: aname.stringview childTypeId: cid
            recordTyperef :ty :reg :units :unitName thisName: "" node: fm.operation
        } else {}
    }
    if (isgen) == false then {
        customTagV: unionCustomTagId :ty :reg :unitName uid: vid asItems: vnode.asItems
        tagId: 0.u64
        match (
            customTagV
        ) case some then {
            tagId = customTagV
        } case none then {
            tagName: "\{defName}:tag:data"
            tagId = reg.newType name: tagName.stringview typetype: ztypes.ztypetype.DATA
        }
        ty.setChild parentTypeId: vid childName: "tag" childTypeId: tagId
    }
    aiter: vnode.asItems.iterate
    for am: aiter loop {
        match (
            am
        ) case namedoperation then {
            mname: unitLabel o: am.name
            qname: "\{defName}.\{mname}"
            mido: (resolveMethodFn
                :ty
                :reg
                :units
                :unitName
                qname: qname.stringview
                thisName: defName
                op: am.operation
            )
            match (
                mido
            ) case some then {
                ty.setChild parentTypeId: vid childName: mname.stringview childTypeId: mido
            } else {}
        } else {}
    }
    if (isgen) == false then {
        eqName: "\{defName}.=="
        eqId: reg.newType name: eqName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: vid childName: "==" childTypeId: eqId
        neqName: "\{defName}.!="
        neqId: reg.newType name: neqName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: vid childName: "!=" childTypeId: neqId
    }
    ty.definedInUnit.set key: vvid value: unitName.string
}

# dottedParentName -- the parent atom name of a `parent.child` dottedpath Node, ""
# for anything else. Matching the Node param narrows it cleanly.
dottedParentName: function {n: Node} out String is {
    match (
        n
    ) case expression then {
        return (dottedParentName n: n.expression)
    } case dottedpath then {
        return (atomName n: n.parent)
    } else {
        return "".string
    }
}

# dottedTyperefId -- the type id of a cross-unit qualified type ref `unit.Type`
# (e.g. the `zvfs.ProviderBox` element of a `(List of: zvfs.ProviderBox)`),
# resolved through the defining unit's scope. Bare-name visibility covers only
# main+system, so a dep element misses there; this bridges via unitNameTid +
# resolved. 0 when not a dotted ref or unresolved.
dottedTyperefId: function {st: zenv.ZSymbolTable op: Node} out u64 is {
    match (
        op
    ) case expression then {
        return (dottedTyperefId :st op: op.expression)
    } case dottedpath then {
        pn: atomName n: op.parent
        cn: atomName n: op.child
        if (st.reg.unitNameTid.has key: pn) then {
            k: "\{pn}.\{cn}"
            ro: resolvedByKey ty: st.typing reg: st.reg key: k
            return (optU64Or o: ro d: 0)
        } else {
            return 0
        }
    } else {
        return 0
    }
}

# unionCustomTagId -- a union's custom DATA tag, if any: an `as { tag: <data>.tag }`
# item whose `<data>` resolves to an in-unit DATA type. Returns that DATA's type id;
# none when absent or not a DATA (the union then synthesizes its own tag wrapper).
unionCustomTagId: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    uid: u64
    asItems: List Node
} out optionval u64 is {
    iter: asItems.iterate
    for am: iter loop {
        match (
            am
        ) case namedoperation then {
            nm: unitLabel o: am.name
            if nm.stringview == "tag" then {
                pn: dottedParentName n: am.operation
                if pn.length != 0 then {
                    rr: walkLookupTyperef :ty :reg currentUnit: unitName base: pn.stringview
                    match (
                        rr
                    ) case some then {
                        tt: reg.typetypeOf typeId: rr
                        isdata: false
                        match (
                            tt
                        ) case DATA then {
                            isdata = true
                        } else {}
                        if isdata then {
                            return (optionval.some rr)
                        } else {
                            # the reference stamps only the main unit's
                            # custom-tag items (system variants resolve
                            # standalone, unstamped).
                            if unitName == reg.regMainUnit.stringview then {
                                tgk: "system.tag".string
                                tgo: resolvedByKey :ty :reg key: tgk
                                match (
                                    tgo
                                ) case some then {
                                    tnid0: innermostNodeId n: am.operation
                                    ty.nodeType.set key: tnid0.u64 value: tgo
                                } case none then {}
                            }
                        }
                    } case none then {
                        # the tag base resolves later (demand order): record
                        # the demand and a pending fixup for the tag child.
                        reg.recordDemand name: pn.stringview
                        uk: uid
                        pv: pn.copy
                        ty.pendingCustomTag.set key: uk value: pv
                        uk2: uid
                        pnid9: innermostNodeId n: am.operation
                        pnv9: pnid9.u64
                        ty.pendingCustomTagNode.set key: uk2 value: pnv9
                    }
                }
            }
        } else {}
    }
    return (optionval.none u64)
}

# resolveUnion -- resolve a union ObjectDef into a UNION reference type: a child
# per arm (arm name -> payload type-ref shell; a `null` arm -> the `null` shell),
# a synthesized `tag` child (the `{name}:tag:data` discriminator wrapper), then any
# as-block methods. Unions are reference types (is_valtype false); they have no
# `create` (bare construction is disabled) and no `==`/`!=`. A union keeps a
# destructor unless every arm is `null` (Priority elides it; IntResult/Result/Typed
# keep it). A custom DATA tag (`as { tag: <data>.tag }`) becomes the `tag` child in
# place of the synth wrapper; generics arrive later.
resolveUnion: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    defName: StringView
    vnode: zast.ObjectDefData
} is {
    uid: (declareCanonicalType
        :ty
        :reg
        defUnit: unitName
        name: defName
        typetype: ztypes.ztypetype.UNION
    )
    uuid: uid
    reg.setValtype typeId: uid value: false
    isgen: hasGenericParam items: vnode.asItems
    if isgen then {
        reg.setGeneric typeId: uid value: true
        gtk9: "\{unitName}.\{defName}"
        registerGenericParams :reg typeKey: gtk9.stringview items: vnode.asItems
    }
    allNull: true
    fiter: vnode.isItems.iterate
    for fm: fiter loop {
        match (
            fm
        ) case namedoperation then {
            aname: unitLabel o: fm.name
            an: atomName n: fm.operation
            if an.stringview != "null" then allNull = false
            cid: (resolveTyperefShellMarked
                :ty
                :reg
                :units
                :unitName
                ownerId: 0
                typeExpr: fm.operation
                thisName: defName
            )
            ty.setChild parentTypeId: uid childName: aname.stringview childTypeId: cid
            recordTyperef :ty :reg :units :unitName thisName: "" node: fm.operation
        } else {}
    }
    if (isgen) == false then {
        customTag: unionCustomTagId :ty :reg :unitName :uid asItems: vnode.asItems
        tagId: 0.u64
        match (
            customTag
        ) case some then {
            tagId = customTag
        } case none then {
            tagName: "\{defName}:tag:data"
            tagId = reg.newType name: tagName.stringview typetype: ztypes.ztypetype.DATA
        }
        ty.setChild parentTypeId: uid childName: "tag" childTypeId: tagId
    }
    aiter: vnode.asItems.iterate
    for am: aiter loop {
        match (
            am
        ) case namedoperation then {
            mname: unitLabel o: am.name
            qname: "\{defName}.\{mname}"
            mido: (resolveMethodFn
                :ty
                :reg
                :units
                :unitName
                qname: qname.stringview
                thisName: defName
                op: am.operation
            )
            match (
                mido
            ) case some then {
                ty.setChild parentTypeId: uid childName: mname.stringview childTypeId: mido
            } else {}
        } else {}
    }
    if (allNull) == false then {
        dn: "\{defName}_destroy"
        reg.setDestructorName typeId: uid name: dn.stringview
    }
    ty.definedInUnit.set key: uuid value: unitName.string
}

# fieldTypeNeedsCleanup -- true when a class field needs cleanup (so the holder keeps
# a destructor): a `.lock` field (its borrow is released at scope exit), a native heap
# type (String/List/Map/Set), or an in-unit type that itself HAS a destructor
# (`reg.hasDestructorName`). A scalar field, or an owned class/union field whose type
# has no destructor, needs none. Name check for the natives is a scaffold-stage
# approximation (system types carry no real id under resolve-only-main).
fieldTypeNeedsCleanup: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    name: StringView
    isLock: bool
} out bool is {
    if isLock then return true
    if name == "String" then return true
    if name == "List" then return true
    if name == "Map" then return true
    if name == "Set" then return true
    if name == "Option" then return true
    if name == "Result" then return true
    duo8: definingUnitFor :ty currentUnit: unitName :name
    if duo8.length > 0 then {
        tto8: ty.defTypetype.get key: ("\{duo8}.\{name}")
        match (
            tto8
        ) case some then {
            boxed8: false
            if tto8 == ztypes.ztypetype.CLASS then boxed8 = true
            if tto8 == ztypes.ztypetype.UNION then boxed8 = true
            if boxed8 then {
                gk8: "\{duo8}.\{name}"
                if (ty.resolving.has item: gk8) then return true
            }
        } case none then {}
        descendNamed :ty :reg :units defUnit: duo8.stringview :name
    }
    # key by the DEFINING unit: a bare cross-unit field type (Bytes from
    # collections) resolves under its own unit, not the class's
    ku8: unitName.string
    if duo8.length > 0 then ku8 = duo8.copy
    rkey: "\{ku8.stringview}.\{name}"
    rr: resolvedByKey :ty :reg key: rkey
    match (
        rr
    ) case some then {
        return (reg.hasDestructorName typeId: rr)
    } case none then {
        return false
    }
}

# resolveClass -- resolve a class ObjectDef into a CLASS reference type: a child per
# field (field name -> type-ref shell), a child per as-block method, then a synthesized
# `create` child (LAST). Classes are reference types (is_valtype false); they get
# `create` but NO `==`/`!=` (unlike records). A class keeps a destructor when any field
# owns heap data (fieldTypeNeedsCleanup), else none. A typedef class (single
# `X.typedef` field) gets no field child, synth `create`+`borrow`, and inherits
# needs_destructor from the wrapped base (List -> yes, ListView -> no). Custom /
# `null` create, generics + protocols come later.
resolveClass: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    defName: StringView
    cnode: zast.ObjectDefData
} is {
    cid: (declareCanonicalType
        :ty
        :reg
        defUnit: unitName
        name: defName
        typetype: ztypes.ztypetype.CLASS
    )
    ccid: cid
    reg.setValtype typeId: cid value: false
    needsDtor: false
    isgen: hasGenericParam items: cnode.asItems
    if isgen then {
        reg.setGeneric typeId: cid value: true
        gtk9: "\{unitName}.\{defName}"
        registerGenericParams :reg typeKey: gtk9.stringview items: cnode.asItems
    }
    istd: recordIsTypedef rnode: cnode
    if istd then {
        tdbase: objectTypedefBase onode: cnode
        if (fieldTypeNeedsCleanup
            :ty
            :reg
            :units
            :unitName
            name: tdbase.stringview
            isLock: false
        ) then needsDtor = true
        if tdbase.length > 0 then {
            tdk3: cid
            ty.typedefBaseName.set key: tdk3 value: tdbase
        }
        tdm3: objectTypedefMangled onode: cnode
        if tdm3.length > 0 then {
            tdk4: cid
            ty.typedefBaseMangled.set key: tdk4 value: tdm3
        }
    }
    fiter: cnode.isItems.iterate
    for fm: fiter loop {
        match (
            fm
        ) case namedoperation then {
            if (isFunctionDefOp op: fm.operation) then {
                fname: unitLabel o: fm.name
                prodM4: false
                if (isgen) == false then {
                    prodM4 = true
                } else {
                    if (functiondefIsNative op: fm.operation) == false then {
                        prodM4 = true
                    } else {
                        # Flipped collection families resolve their native
                        # method decls like user template methods. create is
                        # special-cased; length/capacity stay field children
                        # (their C surface is a struct read, not a method).
                        famF3: false
                        if defName == "List" then famF3 = true
                        if defName == "ListView" then famF3 = true
                        if defName == "Set" then famF3 = true
                        if defName == "Map" then famF3 = true
                        if unitName == "collections" when famF3 then {
                            prodSkipL: false
                            if fname.stringview == "create" then prodSkipL = true
                            if fname.stringview == "length" then prodSkipL = true
                            if fname.stringview == "capacity" then prodSkipL = true
                            if (prodSkipL) == false then prodM4 = true
                        }
                    }
                }
                if prodM4 then {
                    qname: "\{defName}.\{fname}"
                    mido: (resolveMethodFn
                        :ty
                        :reg
                        :units
                        :unitName
                        qname: qname.stringview
                        thisName: defName
                        op: fm.operation
                    )
                    match (
                        mido
                    ) case some then {
                        ty.setChild parentTypeId: cid childName: fname.stringview childTypeId: mido
                        if isgen then reg.setGeneric typeId: mido value: true
                        if (fnFieldFlaggableName name: fname.stringview) then {
                            ty.setChildFnptrField parentTypeId: cid name: fname.stringview
                        }
                    } case none then {}
                }
            } else {
                fname: unitLabel o: fm.name
                ftn: fieldHeadName n: fm.operation
                lockField: false
                flock0: pathOwnership n: fm.operation
                match (
                    flock0
                ) case some then {
                    lockField = true
                } case none then {}
                mkey: "\{unitName}.\{defName}.\{ftn}"
                mref: resolvedByKey :ty :reg key: mkey
                match (
                    mref
                ) case some then {
                    ty.setChild parentTypeId: cid childName: fname.stringview childTypeId: mref
                    if (reg.typetypeOf typeId: mref) == ztypes.ztypetype.FUNCTION then {
                        ty.setChildFnptrField parentTypeId: cid name: fname.stringview
                    }
                    if lockField then ty.setChildLockField parentTypeId: cid name: fname.stringview
                    # a sibling-member ref default: the construction fill
                    # stamps the default's node with the member's type.
                    pdk: nodeId n: fm.operation
                    pdo: cid
                    ty.pendingDefaultOwner.set key: pdk.u64 value: pdo
                    pdk2: nodeId n: fm.operation
                    pdi: mref
                    ty.pendingDefaultId.set key: pdk2.u64 value: pdi
                } case none then {
                    if (isTypedefField n: fm.operation) then {
                        # No field child for the wrapper, but the inner refs
                        # (the u8 in `(List of: u8).typedef`) still stamp.
                        recordTyperef :ty :reg :units :unitName thisName: "" node: fm.operation
                    } else {
                        if fname.stringview != "_resume_input" then {
                            if (fieldTypeNeedsCleanup
                                :ty
                                :reg
                                :units
                                :unitName
                                name: ftn.stringview
                                isLock: lockField
                            ) then needsDtor = true
                        }
                        cidf: (resolveTyperefShellMarked
                            :ty
                            :reg
                            :units
                            :unitName
                            ownerId: cid
                            typeExpr: fm.operation
                            thisName: defName
                        )
                        ty.setChild parentTypeId: cid childName: fname.stringview childTypeId: cidf
                        if (reg.typetypeOf typeId: cidf) == ztypes.ztypetype.FUNCTION then {
                            ty.setChildFnptrField parentTypeId: cid name: fname.stringview
                        }
                        if lockField then {
                            ty.setChildLockField parentTypeId: cid name: fname.stringview
                        }
                        recordTyperef :ty :reg :units :unitName thisName: "" node: fm.operation
                        dcn0: dottedChildName n: fm.operation
                        rdnc: rootNameOf n: fm.operation
                        if (isNumericLiteralName name: rdnc.stringview) then {
                            (ty.setChildDefault
                                parentTypeId: cid
                                name: fname.stringview
                                default: rdnc.stringview
                            )
                        } else {
                            if dcn0.length > 0 when (isStripMarker name: dcn0.stringview) == false when (reg.isUnitName name: rdnc.stringview) == false then {
                                (ty.setDefaultVariantArm
                                    parentTypeId: cid
                                    name: fname.stringview
                                    armName: dcn0.stringview
                                )
                            }
                        }
                        if dcn0.length > 0 when (isStripMarker name: dcn0.stringview) then {} else {
                            if dcn0.length > 0 then {
                                rdk: nodeId n: fm.operation
                                rdo: cid
                                ty.pendingDefaultOwner.set key: rdk.u64 value: rdo
                                rdk2: nodeId n: fm.operation
                                rdn: rootNameOf n: fm.operation
                                ty.pendingDefaultName.set key: rdk2.u64 value: rdn
                            }
                        }
                    }
                }
            }
        } else {}
    }
    # Flipped iterator families: their only method decl (`call`) lives in
    # the as-block; produce it like the isItems loop does. attachMethods
    # stays non-generic-only (it also handles const-clone members and
    # generator synthesis, which native decls never need).
    aiterP4: cnode.asItems.iterate
    for amP4: aiterP4 loop {
        match (
            amP4
        ) case namedoperation then {
            if (isFunctionDefOp op: amP4.operation) then {
                afnP4: unitLabel o: amP4.name
                prodA4: false
                if isgen when (functiondefIsNative op: amP4.operation) then {
                    famA4: false
                    if defName == "ListIter" then famA4 = true
                    if defName == "SetIter" then famA4 = true
                    if defName == "MapKeyIter" then famA4 = true
                    if defName == "MapItemIter" then famA4 = true
                    if unitName == "collections" when famA4 then {
                        skipA4: false
                        if afnP4.stringview == "create" then skipA4 = true
                        if afnP4.stringview == "length" then skipA4 = true
                        if afnP4.stringview == "capacity" then skipA4 = true
                        if (skipA4) == false then prodA4 = true
                    }
                }
                if prodA4 then {
                    aqnP4: "\{defName}.\{afnP4}"
                    amidP4: (resolveMethodFn
                        :ty
                        :reg
                        :units
                        :unitName
                        qname: aqnP4.stringview
                        thisName: defName
                        op: amP4.operation
                    )
                    match (
                        amidP4
                    ) case some then {
                        (ty.setChild
                            parentTypeId: cid
                            childName: afnP4.stringview
                            childTypeId: amidP4
                        )
                        reg.setGeneric typeId: amidP4 value: true
                        if (fnFieldFlaggableName name: afnP4.stringview) then {
                            ty.setChildFnptrField parentTypeId: cid name: afnP4.stringview
                        }
                    } case none then {}
                }
            }
        } else {
        }
    }
    hasCreate: false
    if (isgen) == false then {
        hcAs: attachMethods :ty :reg :units :unitName :defName parentId: cid asItems: cnode.asItems
        if hcAs then hasCreate = true
        mNeedsDtor: attachMarkers :ty :reg :units :unitName parentId: cid asItems: cnode.asItems
        if mNeedsDtor then needsDtor = true
    }
    if (hasCreate) == false then {
        if (isgen) == false then {
            createName: "\{defName}.create"
            createId: reg.newType name: createName.stringview typetype: ztypes.ztypetype.FUNCTION
            ty.setChild parentTypeId: cid childName: "create" childTypeId: createId
        }
    }
    if istd then {
        borrowName: "\{defName}.borrow"
        borrowId: reg.newType name: borrowName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: cid childName: "borrow" childTypeId: borrowId
    }
    if defName == "String" then needsDtor = true
    if needsDtor then {
        dn: "\{defName}_destroy"
        reg.setDestructorName typeId: cid name: dn.stringview
    }
    ty.definedInUnit.set key: ccid value: unitName.string
}

# resolveFacet -- resolve a facet ObjectDef into a FACET valtype: a child per
# is-block spec method (the `:this` receiver dropped), then synthesized `create` +
# `borrow` FUNCTION shells (JOIN-only, no own row). Facets are value types
# (is_valtype true), no destructor, no `==`/`!=`. Generic facets arrive later.
resolveFacet: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    defName: StringView
    fnode: zast.ObjectDefData
} is {
    fid: (declareCanonicalType
        :ty
        :reg
        defUnit: unitName
        name: defName
        typetype: ztypes.ztypetype.FACET
    )
    ffid: fid
    reg.setValtype typeId: fid value: true
    isgen: hasGenericParam items: fnode.isItems
    if isgen then reg.setGeneric typeId: fid value: true
    specThisStr: defName.string
    dropThis: true
    if unitName == ty.fullMainUnit.stringview then {
        fdk: defName.string
        fcto: ty.protocolThisContext.get key: fdk
        match (
            fcto
        ) case some then {
            specThisStr = fcto.copy
            dropThis = false
        } case none then {}
    }
    siter: fnode.isItems.iterate
    for sm: siter loop {
        match (
            sm
        ) case namedoperation then {
            mname: unitLabel o: sm.name
            qname: "\{defName}.\{mname}"
            sido: (resolveSpecFn
                :ty
                :reg
                :units
                :unitName
                qname: qname.stringview
                thisName: specThisStr.stringview
                op: sm.operation
                skipThis: dropThis
            )
            match (
                sido
            ) case some then {
                ty.setChild parentTypeId: fid childName: mname.stringview childTypeId: sido
            } else {}
        } else {}
    }
    if (isgen) == false then {
        createName: "\{defName}.create"
        createId: reg.newType name: createName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: fid childName: "create" childTypeId: createId
        borrowName: "\{defName}.borrow"
        borrowId: reg.newType name: borrowName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: fid childName: "borrow" childTypeId: borrowId
    }
    ty.definedInUnit.set key: ffid value: unitName.string
}

# resolveProtocol -- resolve a protocol ObjectDef into a PROTOCOL reftype: a child
# per is-block spec method (the `:this` receiver dropped), then synth `create` +
# `borrow` FUNCTION shells, then an unconditional destructor (a protocol wraps heap
# data). Reference type (is_valtype false), no `==`/`!=`. Generic protocols arrive later.
resolveProtocol: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    defName: StringView
    fnode: zast.ObjectDefData
} is {
    pid: (declareCanonicalType
        :ty
        :reg
        defUnit: unitName
        name: defName
        typetype: ztypes.ztypetype.PROTOCOL
    )
    ppid: pid
    reg.setValtype typeId: pid value: false
    isgen: hasGenericParam items: fnode.isItems
    if isgen then reg.setGeneric typeId: pid value: true
    # A protocol spec receiver is normally dropped (resolves to nothing). The reference
    # resolves Text NESTED inside String's `:Text` marker, so Text's spec `:this` binds
    # to the enclosing String -- mirror that for the system Text protocol.
    specThisStr: defName.string
    dropThis: true
    if unitName == "system" then {
        if defName == "Text" then {
            specThisStr = "String".string
            dropThis = false
        }
    }
    if dropThis when unitName == ty.fullMainUnit.stringview then {
        dk: defName.string
        cto: ty.protocolThisContext.get key: dk
        match (
            cto
        ) case some then {
            specThisStr = cto.copy
            dropThis = false
        } case none then {}
    }
    siter: fnode.isItems.iterate
    for sm: siter loop {
        match (
            sm
        ) case namedoperation then {
            mname: unitLabel o: sm.name
            qname: "\{defName}.\{mname}"
            sido: (resolveSpecFn
                :ty
                :reg
                :units
                :unitName
                qname: qname.stringview
                thisName: specThisStr.stringview
                op: sm.operation
                skipThis: dropThis
            )
            match (
                sido
            ) case some then {
                ty.setChild parentTypeId: pid childName: mname.stringview childTypeId: sido
            } else {}
        } else {}
    }
    if (isgen) == false then {
        createName: "\{defName}.create"
        createId: reg.newType name: createName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: pid childName: "create" childTypeId: createId
        borrowName: "\{defName}.borrow"
        borrowId: reg.newType name: borrowName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: pid childName: "borrow" childTypeId: borrowId
    }
    dn: "\{defName}_destroy"
    reg.setDestructorName typeId: pid name: dn.stringview
    ty.definedInUnit.set key: ppid value: unitName.string
}

# registerEmptyType -- register a native bottom type (null -> NULL, never -> NEVER) as a
# valtype with a single synth `create` child. The reference special-cases these: they are
# `record is native` in source but carry a distinct typetype and only a create child.
registerEmptyType: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    name: StringView
    tt: ztypes.ztypetype
} out u64 is {
    rk0: "\{unitName}.\{name}"
    ex0: resolvedByKey :ty :reg key: rk0
    match (
        ex0
    ) case some then {
        reg.setValtype typeId: ex0 value: true
        ccn0: "\{name}.create"
        cci0: reg.newType name: ccn0.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: ex0 childName: "create" childTypeId: cci0
        ty.definedInUnit.set key: ex0 value: unitName.string
        return ex0
    } case none then {}
    nid: reg.newType :name typetype: tt
    nnid: nid
    reg.setValtype typeId: nid value: true
    ccname: "\{name}.create"
    ccid: reg.newType name: ccname.stringview typetype: ztypes.ztypetype.FUNCTION
    ty.setChild parentTypeId: nid childName: "create" childTypeId: ccid
    ty.definedInUnit.set key: nnid value: unitName.string
    return nid
}

# descendIntoUnit -- fetch the def node at bodyIdx inside a unit's body and
# resolve it. Split from descendNamed so the unit node arrives as a plain
# parameter (matching resolveUnitBody's narrowing shape).
descendIntoUnit: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    defName: StringView
    bodyIdx: u64
    unitdef: Node
} is {
    match (
        unitdef
    ) case unitdef then {
        bm9: unitdef.body.get i: bodyIdx
        match (
            bm9
        ) case namedoperation then {
            dn9: unitLabel o: bm9.name
            if dn9.stringview == defName then {
                resolveDef :ty :reg :units :unitName :defName defn: bm9.operation
            }
        } else {}
    } else {}
}

# descendNamed -- reference-level DFS entry: resolve a named top-level def's
# body by descending into its AST node (located via the defNodeUnitIdx /
# defNodeBodyIdx node finder) so a reference's dependency resolves before the
# referrer continues. Returns the canonical forward-decl id; a grey
# (in-progress) or already-resolved target returns it without re-descending.
# Returns 0 when the name is not an indexed top-level def, so the caller keeps
# its shell behavior.
descendNamed: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    defUnit: StringView
    name: StringView
} out u64 is {
    if ty.defNodeIndexBuilt == false then return 0
    if defUnit == "core" then return 0
    tto9: ty.defTypetype.get key: ("\{defUnit}.\{name}")
    ttv9: ztypes.ztypetype.NULL
    classified9: false
    match (
        tto9
    ) case some then {
        ttv9 = tto9
        classified9 = true
    } case none then {}
    tid9: 0.u64
    if classified9 then tid9 = declareCanonicalType :ty :reg :defUnit :name typetype: ttv9
    dk9a: "\{defUnit}.\{name}"
    if (ty.definedKeys.has item: dk9a) then return tid9
    dk9b: "\{defUnit}.\{name}"
    if (ty.resolving.has item: dk9b) then {
        # A grey hit is a back-edge. Reference-kind targets (UNION/CLASS --
        # boxed) are legal forward declarations; a VALUE-kind target reached
        # through a containment edge cannot lay out.
        if ty.inContainmentEdge then {
            cycV9: false
            if ttv9 == ztypes.ztypetype.RECORD then cycV9 = true
            if ttv9 == ztypes.ztypetype.VARIANT then cycV9 = true
            if ttv9 == ztypes.ztypetype.ENUM then cycV9 = true
            if cycV9 then {
                cem9: "containment cycle: value type '\{defUnit}.\{name}' contains itself by value; box the field behind a class, union, or Option"
                addResolveError :ty e: zast.err.TYPEERROR msg: cem9
            }
        }
        return tid9
    }
    uo9: ty.defNodeUnitIdx.get key: ("\{defUnit}.\{name}")
    uidx9: 0.u64
    match (
        uo9
    ) case some then {
        uidx9 = uo9
    } case none then {
        return tid9
    }
    bo9: ty.defNodeBodyIdx.get key: ("\{defUnit}.\{name}")
    bidx9: 0.u64
    match (
        bo9
    ) case some then {
        bidx9 = bo9
    } case none then {
        return tid9
    }
    sup9: ty.suppressSigStamp
    ty.suppressSigStamp = false
    ue9: units.get i: uidx9
    match (
        ue9
    ) case namedoperation then {
        (descendIntoUnit
            :ty
            :reg
            :units
            unitName: defUnit
            defName: name
            bodyIdx: bidx9
            unitdef: ue9.operation
        )
    } else {}
    ty.suppressSigStamp = sup9
    if classified9 == false then {
        ro9: resolveUnitChild :ty :reg unitName: defUnit :name
        return (optU64Or o: ro9 d: 0)
    }
    return tid9
}

# resolveDef -- dispatch a main-unit definition by kind. Resolves functions, data
# blocks, records, variants, unions, classes, facets and protocols; a top-level data
# block parses as an `expression` wrapping a `datablock`, so unwrap one level and
# re-dispatch. Enums and generics arrive in later slices.
resolveDef: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    defName: StringView
    defn: Node
} is {
    gk0: "\{unitName}.\{defName}"
    ty.resolving.add item: gk0
    # A containment edge is ONE hop: this def's own resolution starts a
    # fresh context (its field/arm legs re-arm the flag), so an outer field
    # bracket never taints nested param/return resolution.
    prevCE0: ty.inContainmentEdge
    ty.inContainmentEdge = false
    match (
        defn
    ) case functiondef then {
        fid: (resolveFunction
            :ty
            :reg
            :units
            :unitName
            :defName
            fnode: defn
            thisName: ""
            skipThisType: false
        )
        ty.nodeType.set key: defn.nodeid.u64 value: fid
        if (isGeneratorReturn o: defn.returntype) then {
            (synthGeneratorIterClass
                :ty
                :reg
                :units
                :unitName
                fnName: defName
                thisName: ""
                fnode: defn
            )
        }
    } case expression then {
        resolveDef :ty :reg :units :unitName :defName defn: defn.expression
        exprKey: "\{unitName}.\{defName}"
        exprid: resolvedByKey :ty :reg key: exprKey
        match (
            exprid
        ) case some then {
            ty.nodeType.set key: defn.nodeid.u64 value: exprid
        } case none then {}
    } case datablock then {
        resolveData :ty :reg :unitName :defName dnode: defn
        dbKey: "\{unitName}.\{defName}"
        dbrid: resolvedByKey :ty :reg key: dbKey
        match (
            dbrid
        ) case some then {
            ty.nodeType.set key: defn.nodeid.u64 value: dbrid
        } case none then {}
    } case objectdef then {
        match (
            defn.kind
        ) case RECORD then {
            if defName == "null" then {
                registerEmptyType :ty :reg :unitName name: "null" tt: ztypes.ztypetype.NULL
            } else {
                if defName == "never" then {
                    nvid9: (registerEmptyType
                        :ty
                        :reg
                        :unitName
                        name: "never"
                        tt: ztypes.ztypetype.NEVER
                    )
                    setnv9: nvid9
                    ty.nodeType.set key: defn.nodeid.u64 value: setnv9
                } else {
                    resolveRecord :ty :reg :units :unitName :defName rnode: defn
                }
            }
        } case VARIANT then {
            resolveVariant :ty :reg :units :unitName :defName vnode: defn
        } case UNION then {
            resolveUnion :ty :reg :units :unitName :defName vnode: defn
        } case CLASS then {
            resolveClass :ty :reg :units :unitName :defName cnode: defn
        } case FACET then {
            resolveFacet :ty :reg :units :unitName :defName fnode: defn
        } case PROTOCOL then {
            resolveProtocol :ty :reg :units :unitName :defName fnode: defn
        } else {}
        objKey: "\{unitName}.\{defName}"
        objrid: resolvedByKey :ty :reg key: objKey
        match (
            objrid
        ) case some then {
            ty.nodeType.set key: defn.nodeid.u64 value: objrid
        } case none then {}
    } case dottedpath then {
        # A unit-level type alias (`Node: zast.Node`): resolve the cross-unit dotted
        # ref to a (shell) type id and register it under the unit's name, so bare-alias
        # return types and value uses resolve. Replicates resolveTyperefShell's
        # cross-unit leg; mirrors the reference's _type_of_definition dotted-path
        # fallback (ztypecheck.py:1184).
        apNm9: atomName n: defn.parent
        if (reg.isUnitName name: apNm9.stringview) then {
            acNm9: atomName n: defn.child
            reg.recordDemand name: acNm9.stringview
            reg.recordSeededDemand un: unitName name: acNm9.stringview
            tgtKey9: "\{apNm9}.\{acNm9}"
            ark9: "\{unitName}.\{defName}"
            # Record alias -> target; resolveTypeAliases repoints the alias to the
            # target's canonical id once the demand fixpoint has resolved it. The
            # target is usually still unresolved here, so the placeholder below would
            # otherwise leave the alias a phantom RECORD shell (a second empty `Node`
            # beside the real zast.Node union).
            fk9: ark9.copy
            fv9: tgtKey9.copy
            ty.funcAliases.set key: fk9 value: fv9
            # Use the canonical id if already resolved; else a shell placeholder
            # (overwritten by resolveTypeAliases) so the demand fixpoint terminates.
            if (ty.resolving.has item: tgtKey9) then {
                aem9: "alias cycle: '\{unitName}.\{defName}' aliases '\{tgtKey9}' which is still resolving"
                addResolveError :ty e: zast.err.TYPEERROR msg: aem9
            }
            descendNamed :ty :reg :units defUnit: apNm9.stringview name: acNm9.stringview
            tgo9: resolvedByKey :ty :reg key: tgtKey9
            aid9: 0.u64
            match (
                tgo9
            ) case some then {
                aid9 = tgo9
            } case none then {
                aid9 = resolveAtomType :ty :reg :units :unitName nm: acNm9.stringview thisName: ""
            }
            sda9: aid9
            ty.nodeType.set key: defn.nodeid.u64 value: sda9
        }
    } else {}
    # Unit -> def childOf edges are built at mint (declareCanonicalType) for real
    # defs and on demand (resolvedByKey's alias-follow) for aliases; no tail pass.
    ty.inContainmentEdge = prevCE0
    gk1: "\{unitName}.\{defName}"
    ty.resolving.delete item: gk1
    dkk0: "\{unitName}.\{defName}"
    ty.definedKeys.add item: dkk0
}

# resolveTypeAliases -- repoint each unit-level type alias (recorded in funcAliases
# during resolveDef as "{unit}.{alias}" -> "{targetUnit}.{target}") to its target's
# canonical type id, now that the cross-unit demand fixpoint has resolved targets.
# Without this an alias whose target was unresolved when first walked stays bound to a
# phantom RECORD shell (a second empty `Node` beside the real zast.Node union), which
# breaks cross-unit return types and union-arm construction.
resolveTypeAliases: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry} is {
    akeys9: (List String)
    avals9: (List String)
    with it: ty.funcAliases.iterateItems do for e: it loop {
        ek9: e.key.copy
        akeys9.append ek9
        ev9: e.value.copy
        avals9.append ev9
    }
    ai9: 0.u64
    an9: akeys9.length
    for ai9 < an9 loop {
        aek9: akeys9.get i: ai9
        aev9: avals9.get i: ai9
        ai9 = ai9 + 1
        tgo: resolvedByKey :ty :reg key: aev9.copy
        match (
            tgo
        ) case some then {
            tv: tgo
            au: "".string
            an: "".string
            with skit: (aek9.stringview.split sep: ".") do for kseg: skit loop {
                if au.length == 0 then {
                    au = kseg.string
                } else {
                    an = kseg.string
                }
            }
            uro: reg.unitNameTid.get key: au
            match (
                uro
            ) case some then {
                ty.setChild parentTypeId: uro childName: an.stringview childTypeId: tv
            } case none then {}
        } case none then {
            vau: "".string
            van: "".string
            with vkit: (aek9.stringview.split sep: ".") do for vseg: vkit loop {
                if vau.length == 0 then {
                    vau = vseg.string
                } else {
                    van = vseg.string
                }
            }
            vroot: "".string
            vmem: "".string
            with vvit: (aev9.stringview.split sep: ".") do for vvseg: vvit loop {
                if vroot.length == 0 then {
                    vroot = vvseg.string
                } else {
                    vmem = vvseg.string
                }
            }
            tto: walkLookupTyperef :ty :reg currentUnit: vau.stringview base: vroot.stringview
            match (
                tto
            ) case some then {
                memo: ty.childOf parentTypeId: tto name: vmem.stringview
                match (
                    memo
                ) case some then {
                    rtt: reg.typetypeOf typeId: tto
                    isTag: false
                    if rtt == ztypes.ztypetype.VARIANT then isTag = true
                    if rtt == ztypes.ztypetype.UNION then isTag = true
                    if isTag then {
                        mtt: reg.typetypeOf typeId: memo
                        isMem: true
                        if mtt == ztypes.ztypetype.FUNCTION then isMem = false
                        if mtt == ztypes.ztypetype.DATA then isMem = false
                        if isMem then {
                            vuro: reg.unitNameTid.get key: vau.copy
                            match (
                                vuro
                            ) case some then {
                                (ty.setChild
                                    parentTypeId: vuro
                                    childName: van.stringview
                                    childTypeId: tto
                                )
                            } case none then {}
                            vno: ty.aliasDefNode.get key: aek9.copy
                            match (
                                vno
                            ) case some then {
                                vrn: vroot.copy
                                ty.pendingTyperef.set key: vno value: vrn
                                vun: vau.copy
                                ty.pendingTyperefUnit.set key: vno value: vun
                            } case none then {}
                        }
                    }
                } case none then {}
            } case none then {}
        }
    }
}

# resolveUnitBody -- resolve every top-level definition signature in a unit.
# resolveUnitBody -- resolve a unit's definition signatures. Signature-only
# resolves every member; the full body-walk mode mirrors check()'s eager set
# (functions and units only -- other definitions resolve on demand, so unused
# main-unit records/classes/unions drop out of the full dump).
resolveUnitBody: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    unitdef: Node
    full: bool
} is {
    match (
        unitdef
    ) case unitdef then {
        if (hasGenericParam items: unitdef.body) then {
            registerGenericParams :reg typeKey: unitName items: unitdef.body
            # Each generic-param name gets a canonical per-(unit,param)
            # GENERIC_PARAM tid (get-or-mint), attributed to the unit; the
            # param definition's value node carries it so template signatures
            # and bodies stamp it.
            with gpiter: unitdef.body.iterate do for gm: gpiter loop {
                match (
                    gm
                ) case namedoperation then {
                    if (isBareGenericParam op: gm.operation) then {
                        gpn0: unitLabel o: gm.name
                        gtid0: 0.u64
                        gpo0: reg.genericParamTidOf typeKey: unitName paramName: gpn0.stringview
                        match (
                            gpo0
                        ) case some then {
                            gtid0 = gpo0
                        } case none then {
                            gtid0 = (reg.newType
                                name: gpn0.stringview
                                typetype: ztypes.ztypetype.GENERIC_PARAM
                            )
                            (reg.setGenericParamTid
                                typeKey: unitName
                                paramName: gpn0.stringview
                                tid: gtid0
                            )
                        }
                        gtidK0: gtid0
                        ty.definedInUnit.set key: gtidK0 value: unitName.string
                        gpnid: nodeId n: gm.operation
                        gtidV0: gtid0
                        ty.nodeType.set key: gpnid.u64 value: gtidV0
                    }
                } else {}
            }
        }
        if full then {
            # The reference binds a spec receiver only when the conformer's
            # resolution triggers the protocol's; a main body that never
            # names the conformer resolves the protocol context-free (e.g.
            # through a function signature). Collect member names first --
            # the body list cannot be passed while its iterator is live.
            fmu: unitName.string
            ty.fullMainUnit = fmu
            ccNames: (List String)
            with cmiter: unitdef.body.iterate do for cmm: cmiter loop {
                ccn0: "".string
                match (
                    cmm
                ) case namedoperation then {
                    ccn1: unitLabel o: cmm.name
                    ccn0 = ccn1
                } else {}
                ccNames.append ccn0
            }
            cci: 0.u64
            ccTotal: ccNames.length
            for cci < ccTotal loop {
                cnm2: ccNames.get i: cci
                if cnm2.length > 0 then {
                    if (mainBodyMentions unitBody: unitdef.body name: cnm2.stringview) then {
                        mem2: unitdef.body.get i: cci
                        match (
                            mem2
                        ) case namedoperation then {
                            recordConformerContexts :ty defName: cnm2.stringview op: mem2.operation
                        } else {}
                    }
                }
                cci = cci + 1
            }
        }
        biter: unitdef.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                defName: unitLabel o: bm.name
                eager: true
                if full then {
                    if (isFunctionDefOp op: bm.operation) == false then {
                        if (isUnitOp op: bm.operation) == false then eager = false
                    }
                }
                if eager then {
                    if (isUnitOp op: bm.operation) then {
                        (resolveInlineGenericUnit
                            :ty
                            :reg
                            :units
                            :unitName
                            defName: defName.stringview
                            unitOp: bm.operation
                        )
                    } else {
                        rkeyE: "\{unitName}.\{defName}"
                        if (ty.definedKeys.has item: rkeyE) == false then {
                            (resolveDef
                                :ty
                                :reg
                                :units
                                :unitName
                                defName: defName.stringview
                                defn: bm.operation
                            )
                        }
                    }
                }
            } else {}
        }
    } else {}
}

# typecheck -- entry point. Registers a UNIT type per unit (the `unit` table)
# and resolves the main unit's definition signatures into the registry. The
# registry is supplied by the caller and read by the SQL dumper.
# registerAndResolveMain -- register a UNIT type per unit, then resolve the main
# unit's definition signatures. Iterates program.units transiently so the demand
# pass can re-iterate it without an overlapping exclusive lock.
# isFileUnit -- a user FILE unit (main or a loaded dependency like zlexer/zast/
# zvfs) whose body must be fully resolved + checked so its types/functions emit;
# system library units ride the demand pass + native fragments instead.
isFileUnit: function {name: StringView} out bool is {
    if name == "system" then return false
    if name == "core" then return false
    if name == "collections" then return false
    if name == "io" then return false
    if name == "os" then return false
    if name == "cli" then return false
    return true
}

# registerUnitRoots -- Stage D: register a UNIT type + name for EVERY unit up
# front, before lowerGenerators / indexUnitDefs / demand resolution, so
# reg.unitNameTid is complete and childOf-at-mint (declareCanonicalType) always sees
# a populated unit root. The main unit precedes its deps in unit order, so a
# cross-unit qualified type ref (zlexer.Token) sees the dep as a unit; member
# paths type their base as the UNIT type via this name-keyed side map -- never the
# resolution chain, where a main unit sharing a type's name (str.z, panic.z) would
# shadow it. Formerly registerAndResolveMain Pass 1.
registerUnitRoots: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry program: Node} is {
    match (
        program
    ) case program then {
        with riter: program.units.iterate do for ru: riter loop {
            match (
                ru
            ) case namedoperation then {
                nm: unitLabel o: ru.name
                uid: reg.newType name: nm.stringview typetype: ztypes.ztypetype.UNIT
                opid: unitdefNodeId n: ru.operation
                ty.unitTypesById.set key: opid.u64 value: uid
                uid3: uid
                reg.setUnitName name: nm.stringview uid: uid3
            } else {}
        }
    } else {}
}

registerAndResolveMain: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    program: Node
    full: bool
} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        # Pass 1 (unit-root minting) hoisted to registerUnitRoots, run before lowerGenerators.
        # Pass 2: resolve EVERY file unit's definition signatures (main + deps
        # like zlexer/zast/zvfs), so cross-unit type refs resolve to the dep's
        # own type and the dep's type/fn def nodes get stamped for emission.
        muN0: program.units.length
        muI0: 0.u64
        for muI0 < muN0 loop {
            mu: program.units.get i: muI0
            muI0 = muI0 + 1
            match (
                mu
            ) case namedoperation then {
                nm: unitLabel o: mu.name
                if (isFileUnit name: nm.stringview) then {
                    # Skeleton mode (full=false): the reference resolves dep
                    # signatures lazily and never stamps their type-ref atoms, so
                    # suppress the dep sig stamps to match. Full mode stamps them
                    # (the reference does too), so leave it on there.
                    supp: false
                    if (full) == false then {
                        if (nm.stringview == mainName) == false then {
                            if (unitDefIsGeneric o: mu.operation) == false then supp = true
                        }
                    }
                    ty.suppressSigStamp = supp
                    (resolveUnitBody
                        :ty
                        :reg
                        units: program.units
                        unitName: nm.stringview
                        unitdef: mu.operation
                        :full
                    )
                    ty.suppressSigStamp = false
                }
            } else {}
        }
    } else {}
}

# resolveDemandedUnitBody -- resolve the definitions of a non-main unit that a
# main-unit signature referenced (reg.isDemanded) and that aren't resolved yet,
# stamping them with that unit's name (mirrors the oracle's on-demand resolution).
resolveDemandedUnitBody: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    shadowUnit: StringView
    unitdef: Node
} out bool is {
    anyDemanded: false
    match (
        unitdef
    ) case unitdef then {
        biter: unitdef.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                dn: unitLabel o: bm.name
                if (reg.isDemanded name: dn.stringview) then {
                    # A name the main unit defines shadows this unit's def --
                    # unless the unit's own internals demand it (seeded io
                    # names): the reference resolves those io-locally.
                    shadowed: false
                    if shadowUnit.length != 0 then {
                        skey: "\{shadowUnit}.\{dn}"
                        sgot: resolvedByKey :ty :reg key: skey
                        match (
                            sgot
                        ) case some then {
                            shadowed = true
                        } case none then {}
                    }
                    if shadowed when (reg.isSeededDemand un: unitName name: dn.stringview) then {
                        shadowed = false
                    }
                    if shadowed when (reg.isSeededDemand un: "*" name: dn.stringview) then {
                        shadowed = false
                    }
                    if (shadowed) == false then {
                        anyDemanded = true
                        rkey: "\{unitName}.\{dn}"
                        if (ty.definedKeys.has item: rkey) == false then {
                            (resolveDef
                                :ty
                                :reg
                                :units
                                :unitName
                                defName: dn.stringview
                                defn: bm.operation
                            )
                        }
                    }
                }
            } else {}
        }
    } else {}
    return anyDemanded
}

# isConformanceMarker -- true when an as-item operation is a bare type reference
# (atomid / labelvalue), i.e. a conformance marker like `:Text` or `m: Reader`.
isConformanceMarker: function {op: Node} out bool is {
    match (
        op
    ) case atomid then {
        return true
    } case labelvalue then {
        return true
    } else {
        return false
    }
}

# declaresConformance -- true when an objectdef declares conformance via an as-item
# (the oracle eager-resolves such collections types on first touch of the unit).
declaresConformance: function {op: Node} out bool is {
    match (
        op
    ) case objectdef then {
        citer: op.asItems.iterate
        for cm: citer loop {
            match (
                cm
            ) case namedoperation then {
                if (isConformanceMarker op: cm.operation) then return true
            } else {}
        }
        return false
    } else {
        return false
    }
}

# resolveConformanceDefs -- resolve every not-yet-resolved unit def that declares a
# conformance marker, mirroring the oracle's eager conformance pass. Only `str`
# (`:Text`) qualifies in collections today; called when the unit was demanded at all.
resolveConformanceDefs: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    unitdef: Node
} is {
    match (
        unitdef
    ) case unitdef then {
        biter: unitdef.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                if (declaresConformance op: bm.operation) then {
                    dn: unitLabel o: bm.name
                    rkey: "\{unitName}.\{dn}"
                    if (ty.definedKeys.has item: rkey) == false then {
                        (resolveDef
                            :ty
                            :reg
                            :units
                            :unitName
                            defName: dn.stringview
                            defn: bm.operation
                        )
                    }
                }
            } else {}
        }
    } else {}
}

# seedIteratorDemands -- a collection template's produced methods carry
# shell returns (chain returns link per-instance via the family fixup arms),
# so the sibling iterator/view templates are still unreachable by reference
# descent. When a collection is demanded, demand its iterators too.
seedIteratorDemands: function {reg: ztypes.ZTypeRegistry} is {
    if (reg.isDemanded name: "Set") then reg.recordDemand name: "SetIter"
    if (reg.isDemanded name: "List") then {
        reg.recordDemand name: "ListIter"
        reg.recordDemand name: "ListView"
    }
    if (reg.isDemanded name: "Map") then {
        reg.recordDemand name: "MapKeyIter"
        reg.recordDemand name: "MapItemIter"
        reg.recordDemand name: "MapEntry"
    }
}

# seedSystemDemands -- the literal-materialization set: the system types a
# program can require without ever writing a resolvable reference to them.
# Numeric scalars + tag back per-use literal shells (resolveAtomType mints
# them by name; the canonical defs must exist as typedef/emission bases),
# and bool backs core's true/false re-exports (resolveTypeAliases resolves
# them against the already-resolved system.bool). Every other system type is
# reached by reference descent at its first use.
seedSystemDemands: function {reg: ztypes.ZTypeRegistry} is {
    reg.recordDemand name: "i8"
    reg.recordDemand name: "i16"
    reg.recordDemand name: "i32"
    reg.recordDemand name: "i64"
    reg.recordDemand name: "i128"
    reg.recordDemand name: "u8"
    reg.recordDemand name: "u16"
    reg.recordDemand name: "u32"
    reg.recordDemand name: "u64"
    reg.recordDemand name: "u128"
    reg.recordDemand name: "f32"
    reg.recordDemand name: "f64"
    reg.recordDemand name: "tag"
    reg.recordDemand name: "bool"
}

# seedIoDemands -- demand the io-unit closure the reference's full typecheck pulls
# reference-driven: the stream protocols (conformance-marker targets), IoError
# (the Result err arms), and seekorigin (Seeker.seek). The .z demand pass is
# name-driven, so the closure is seeded explicitly (like seedSystemDemands);
# IoError/seekorigin precede the protocols in io.z body order, so demands recorded
# while resolving the protocols would arrive after the pass already walked them.
seedIoDemands: function {reg: ztypes.ZTypeRegistry} is {
    reg.recordDemand name: "Reader"
    reg.recordSeededDemand un: "io" name: "Reader"
    reg.recordDemand name: "Writer"
    reg.recordSeededDemand un: "io" name: "Writer"
    reg.recordDemand name: "Seeker"
    reg.recordSeededDemand un: "io" name: "Seeker"
    reg.recordDemand name: "Closer"
    reg.recordSeededDemand un: "io" name: "Closer"
    reg.recordDemand name: "IoError"
    reg.recordSeededDemand un: "io" name: "IoError"
    reg.recordDemand name: "seekorigin"
    reg.recordSeededDemand un: "io" name: "seekorigin"
}

# stampCtorDefaults -- a construction fills unprovided defaulted fields: the
# default's node stamps its resolved member/parent type, once the owner has
# actually been constructed (full-mode body walk).
stampCtorDefaults: function {st: zenv.ZSymbolTable unitName: StringView} is {
    nodes: (List u64)
    owners: (List u64)
    with diter: st.typing.pendingDefaultOwner.iterateItems do for de: diter loop {
        dk: de.key
        nodes.append dk
        dv: de.value
        owners.append dv
    }
    di: 0.u64
    dn: nodes.length
    for di < dn loop {
        ow: owners.get i: di
        cgot: st.typing.constructedTypes.get key: ow
        isCon: optBoolOr o: cgot d: false
        if isCon then {
            nd: nodes.get i: di
            ido: st.typing.pendingDefaultId.get key: nd
            idv: optU64Or o: ido d: 0
            if idv > 0 then {
                nd2: nodes.get i: di
                setd2: idv
                st.typing.nodeType.set key: nd2 value: setd2
            } else {
                nd3: nodes.get i: di
                ngo: st.typing.pendingDefaultName.get key: nd3
                match (
                    ngo
                ) case some then {
                    nrt: (optU64Or
                        o: (walkLookupTyperef
                            ty: st.typing
                            reg: st.reg
                            currentUnit: unitName
                            base: ngo.stringview
                        )
                        d: 0
                    )
                    if nrt > 0 then {
                        nd4: nodes.get i: di
                        setd4: nrt
                        st.typing.nodeType.set key: nd4 value: setd4
                    }
                } case none then {}
            }
        }
        di = di + 1
    }
}

# fixupCustomTags -- bind deferred custom union tags: a `tag: X.tag` as-item
# whose data block resolved after the union (demand order) overrides the
# synthesized tag child once both exist.
fixupCustomTags: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry mainName: StringView} is {
    pend: (List u64)
    pnames: (List String)
    with citer: ty.pendingCustomTag.iterateItems do for ce: citer loop {
        ck: ce.key
        pend.append ck
        cvv: ce.value.stringview
        cv: cvv.string
        pnames.append cv
    }
    ci: 0.u64
    cn: pend.length
    for ci < cn loop {
        cuid: pend.get i: ci
        cnm: pnames.get i: ci
        co: walkLookupTyperef :ty :reg currentUnit: mainName base: cnm.stringview
        ctid: optU64Or o: co d: 0
        if ctid > 0 then {
            if (reg.typetypeOf typeId: ctid) == ztypes.ztypetype.DATA then {
                cuidc: cuid
                ty.setChild parentTypeId: cuidc childName: "tag" childTypeId: ctid
            } else {
                cuidn: cuid
                cngo: ty.pendingCustomTagNode.get key: cuidn
                cnid9: optU64Or o: cngo d: 0
                if cnid9 > 0 then {
                    tgk2: "system.tag".string
                    tgo2: resolvedByKey :ty :reg key: tgk2
                    match (
                        tgo2
                    ) case some then {
                        ty.nodeType.set key: cnid9 value: tgo2
                    } case none then {}
                }
            }
        }
        ci = ci + 1
    }
}

# bodyEndsInReturn -- true when an optional body block's last statement is a
# bare `return ...` call (the syntactic divergence the clone-scope synthesis
# needs; no stamps are made).
bodyEndsInReturn: function {bodyOpt: Option Node} out bool is {
    match (
        bodyOpt
    ) case some then {
        return (blockEndsInReturn block: bodyOpt)
    } case none then {
        return false
    }
}

blockEndsInReturn: function {block: Node} out bool is {
    match (
        block
    ) case statement then {
        ne: block.statements.length
        if ne > 0 then {
            last: block.statements.get i: (ne - 1)
            match (
                last
            ) case statementline then {
                return (stmtExprIsReturn op: last.statementline)
            } else {
                return false
            }
        } else {
            return false
        }
    } else {
        return false
    }
}

# stmtExprIsReturn -- an expression statement whose inner call's callable is
# the `return` builtin.
stmtExprIsReturn: function {op: Node} out bool is {
    match (
        op
    ) case expression then {
        return (exprCallIsReturn op: op.expression)
    } else {
        return false
    }
}

exprCallIsReturn: function {op: Node} out bool is {
    match (
        op
    ) case call then {
        cn: atomName n: op.callable
        return cn.stringview == "return"
    } else {
        return false
    }
}

# isFunctionDefWithBody -- true when a node is a functiondef carrying a non-empty body
# (a real method, not a facet/protocol spec signature whose body is none).
isFunctionDefWithBody: function {o: Node} out bool is {
    match (
        o
    ) case functiondef then {
        match (
            o.body
        ) case some then {
            return true
        } case none then {
            return false
        }
    } else {
        return false
    }
}

# objectHasMethodBody -- true when an objectdef holds at least one is/as-item method
# with a body. Scans both blocks (transient iterators over different lists).
objectHasMethodBody: function {op: Node} out bool is {
    match (
        op
    ) case objectdef then {
        iiter: op.isItems.iterate
        for im: iiter loop {
            match (
                im
            ) case namedoperation then {
                if (isFunctionDefWithBody o: im.operation) then return true
            } else {}
        }
        aiter: op.asItems.iterate
        for am: aiter loop {
            match (
                am
            ) case namedoperation then {
                if (isFunctionDefWithBody o: am.operation) then return true
            } else {}
        }
        return false
    } else {
        return false
    }
}

# unitHasObjectMethodBody -- true when a unit body holds an objectdef with a method-body.
unitHasObjectMethodBody: function {def: Node} out bool is {
    match (
        def
    ) case unitdef then {
        biter: def.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                if (objectHasMethodBody op: bm.operation) then return true
            } else {}
        }
        return false
    } else {
        return false
    }
}

# seedBodyWalkDemands -- the reference WALKS objectdef method bodies during
# resolve-only-main (records/classes/facets/protocols), and those bodies use the `return`
# builtin, so the closure pulls `return` + its `out never` type. The .z resolver does
# signatures only, so when the MAIN unit has any objectdef with a method-with-body,
# demand `return` + `never` to match.
# scanCallsInNode -- recursively record demands for the call targets in an
# expression/statement subtree (full-mode body-walk pre-pass): `return` pulls
# return+never, any other bare-atom callable (e.g. `print`) is demanded by name
# so the cross-unit pass resolves it before the walk runs.
scanCallsInNode: function {reg: ztypes.ZTypeRegistry node: Node} is {
    match (
        node
    ) case statement then {
        for stm: node.statements.iterate loop scanCallsInNode :reg node: stm
    } case statementline then {
        scanCallsInNode :reg node: node.statementline
    } case expression then {
        scanCallsInNode :reg node: node.expression
    } case call then {
        cn: atomName n: node.callable
        if cn.stringview == "return" then {
            reg.recordDemand name: "return"
            reg.recordDemand name: "never"
        } else {
            # error/panic return never; the demand must land before the
            # system sweep passes never's definition.
            if cn.stringview == "error" then reg.recordDemand name: "never"
            if cn.stringview == "panic" then reg.recordDemand name: "never"
            if cn.length > 0 then reg.recordDemand name: cn.stringview
        }
        scanCallsInNode :reg node: node.callable
        for arg: node.arguments.iterate loop {
            match (
                arg
            ) case namedoperation then {
                scanCallsInNode :reg node: arg.operation
            } else {
            }
        }
    } case atomstring then {
        for sp: node.stringparts.iterate loop scanCallsInNode :reg node: sp
    } case atomid then {
        # bare body identifiers demand main-unit definitions (unit constants,
        # data blocks); non-definition names never match a demanded def.
        if (isNumericLiteralName name: node.name.stringview) == false then {
            reg.recordDemand name: node.name.stringview
        }
    } case binop then {
        scanCallsInNode :reg node: node.lhs
        scanCallsInNode :reg node: node.rhs
    } case assignment then {
        scanCallsInNode :reg node: node.value
    } case reassignment then {
        scanCallsInNode :reg node: node.topath
        scanCallsInNode :reg node: node.value
    } case ifexpr then {
        for cl: node.clauses.iterate loop scanCallsInNode :reg node: cl
        scanBodyOpt :reg bodyOpt: node.elseclause
    } case forexpr then {
        reg.recordDemand name: "never"
        for fc: node.conditions.iterate loop {
            match (
                fc
            ) case namedoperation then {
                scanCallsInNode :reg node: fc.operation
            } else {
            }
        }
        scanBodyOpt :reg bodyOpt: node.body
        for fp: node.postconditions.iterate loop {
            match (
                fp
            ) case namedoperation then {
                scanCallsInNode :reg node: fp.operation
            } else {
            }
        }
    } case doexpr then {
        reg.recordDemand name: "never"
        if (blockHasBreak n: node.statement) then reg.recordDemand name: "optionval"
        scanCallsInNode :reg node: node.statement
    } case withexpr then {
        scanCallsInNode :reg node: node.value
        scanCallsInNode :reg node: node.body
    } case dottedpath then {
        bn: atomName n: node.parent
        if bn.length > 0 then {
            reg.recordDemand name: bn.stringview
            # a unit-qualified member (io.stdout) demands the member name
            # so the unit's demand walk resolves it
            isUnitQ: false
            if bn.stringview == "io" then isUnitQ = true
            if bn.stringview == "os" then isUnitQ = true
            if bn.stringview == "cli" then isUnitQ = true
            if (reg.isUnitName name: bn.stringview) then isUnitQ = true
            if isUnitQ then {
                mn0: atomName n: node.child
                if mn0.length > 0 then reg.recordDemand name: mn0.stringview
            }
        }
        scanCallsInNode :reg node: node.parent
    } case caseexpr then {
        scanCallsInNode :reg node: node.subject
        for cl: node.clauses.iterate loop scanCallsInNode :reg node: cl
        scanBodyOpt :reg bodyOpt: node.elseclause
    } case caseclause then {
        scanCallsInNode :reg node: node.statement
    } case ifclause then {
        for cnd: node.conditions.iterate loop {
            match (
                cnd
            ) case namedoperation then {
                scanCallsInNode :reg node: cnd.operation
            } else {
            }
        }
        scanCallsInNode :reg node: node.statement
    } else {
    }
}

# scanBodyOpt -- scan an optional function body for call demands.
scanBodyOpt: function {reg: ztypes.ZTypeRegistry bodyOpt: Option Node} is {
    match (
        bodyOpt
    ) case some then {
        scanCallsInNode :reg node: bodyOpt
    } case none then {
    }
}

# scanDefCalls -- scan a functiondef's body, or an objectdef's is/as method
# bodies, for call demands. A type constructed only inside a method body must be
# demanded here or it never resolves and the construction stamps type 0.
scanDefCalls: function {reg: ztypes.ZTypeRegistry op: Node} is {
    match (
        op
    ) case functiondef then {
        scanBodyOpt :reg bodyOpt: op.body
    } case objectdef then {
        iiter: op.isItems.iterate
        for im: iiter loop {
            match (
                im
            ) case namedoperation then {
                if (isFunctionDefWithBody o: im.operation) then scanDefCalls :reg op: im.operation
            } else {}
        }
        aiter: op.asItems.iterate
        for am: aiter loop {
            match (
                am
            ) case namedoperation then {
                if (isFunctionDefWithBody o: am.operation) then scanDefCalls :reg op: am.operation
            } else {}
        }
    } else {
    }
}

# scanDemandedDepClassBodies -- a dependency unit's DEMANDED class methods are
# body-walked (depWalkUnit), so a type constructed only inside those methods
# (e.g. zvfs ProviderTable.registerNull -> NullProvider) must be demanded here
# or it never resolves and the construction stamps type 0. Mirrors scanDefCalls
# over the reached (isDemanded) non-generic objectdef members; the cross-unit
# demand fixpoint then resolves the newly-demanded types and depWalkUnit walks
# them. The isDemanded gate matches the reference's reached-only closure.
scanDemandedDepClassBodies: function {reg: ztypes.ZTypeRegistry unitdef: Node} is {
    match (
        unitdef
    ) case unitdef then {
        for bm: unitdef.body.iterate loop {
            match (
                bm
            ) case namedoperation then {
                cn: unitLabel o: bm.name
                if (reg.isDemanded name: cn.stringview) then {
                    hasm: objectdefHasMethodBodies op: bm.operation
                    if hasm when (objectdefIsGeneric o: bm.operation) then hasm = false
                    if hasm then scanDefCalls :reg op: bm.operation
                }
            } else {
            }
        }
    } else {
    }
}


# scanMainBodyCalls -- record call-target demands for every function body in the
# main unit (the full-mode body walk reaches them; demand must precede the pass).
scanMainBodyCalls: function {reg: ztypes.ZTypeRegistry program: Node} is {
    match (
        program
    ) case program then {
        uiter: program.units.iterate
        for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                nm: unitLabel o: u.name
                if (isFileUnit name: nm.stringview) then scanUnitCalls :reg unitdef: u.operation
            } else {
            }
        }
    } else {
    }
}

# scanUnitCalls -- scan each function definition's body in a unit for call demands.
scanUnitCalls: function {reg: ztypes.ZTypeRegistry unitdef: Node} is {
    match (
        unitdef
    ) case unitdef then {
        for bm: unitdef.body.iterate loop {
            match (
                bm
            ) case namedoperation then {
                scanDefCalls :reg op: bm.operation
            } else {
            }
        }
    } else {
    }
}

seedBodyWalkDemands: function {reg: ztypes.ZTypeRegistry program: Node} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        found: false
        uiter: program.units.iterate
        for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                nm: unitLabel o: u.name
                if nm.stringview == mainName then {
                    if (unitHasObjectMethodBody def: u.operation) then found = true
                }
            } else {}
        }
        if found then {
            reg.recordDemand name: "return"
            reg.recordDemand name: "never"
        }
    } else {}
}

# onFirstEntry -- run a stdlib / dependency unit's one-time demand machinery the
# first time the descent worklist resolves a def in it: seed io's internal
# closure (under the full body-walk driver), resolve the conformance declarers
# reference-following cannot reach (io / collections / system), and prime a user
# dependency unit's return / never demands plus its class-body call scan.
onFirstEntry: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    mainName: StringView
    unitdef: Node
    full: bool
    entered: Set String
} is {
    if (entered.has item: unitName.string) then return
    entered.add item: unitName.string
    if unitName == "io" then {
        if full then seedIoDemands :reg
        resolveConformanceDefs :ty :reg :units unitName: "io" :unitdef
        return
    }
    if unitName == "collections" then {
        resolveConformanceDefs :ty :reg :units unitName: "collections" :unitdef
        return
    }
    if unitName == "system" then {
        resolveConformanceDefs :ty :reg :units unitName: "system" :unitdef
        return
    }
    if unitName == "os" then return
    if unitName == "cli" then return
    if unitName == mainName then return
    reg.recordDemand name: "return"
    reg.recordDemand name: "never"
    scanDemandedDepClassBodies :reg :unitdef
}

# resolveDemandsByDescent -- the descent-era demand worklist. Seeds the body-walk
# demands, then body-drains the main unit (full mode) and every dependency unit
# except core to a joint fixpoint; each resolved def's own references descend
# inline (resolveAtomType -> descendNamed), so per-unit body order only decides
# trigger order, not dependency order. The tail resolves core's bool
# re-exports explicitly (descent skips core).
resolveDemandsByDescent: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    program: Node
    full: bool
} is {
    seedBodyWalkDemands :reg :program
    if (reg.isDemanded name: "print") then {
        reg.recordDemand name: "StringLike"
        reg.recordDemand name: "str"
        reg.recordDemand name: "List"
    }
    entered9: (Set String)
    mnOwn9: reg.regMainUnit.copy
    mainName9: mnOwn9.stringview
    match (
        program
    ) case program then {
        if full then {
            mdN9: program.units.length
            mdI9: 0.u64
            for mdI9 < mdN9 loop {
                mu9: program.units.get i: mdI9
                mdI9 = mdI9 + 1
                match (
                    mu9
                ) case namedoperation then {
                    mnm9: unitLabel o: mu9.name
                    if mnm9.stringview == mainName9 then {
                        againM9: true
                        for againM9 loop {
                            beforeM9: reg.nextTypeId
                            (resolveDemandedUnitBody
                                :ty
                                :reg
                                units: program.units
                                unitName: mainName9
                                shadowUnit: ""
                                unitdef: mu9.operation
                            )
                            if reg.nextTypeId == beforeM9 then againM9 = false
                        }
                    }
                } else {}
            }
        }
        againU9: true
        for againU9 loop {
            beforeU9: reg.nextTypeId
            seedSystemDemands :reg
            seedIteratorDemands :reg
            udN9: program.units.length
            udI9: 0.u64
            for udI9 < udN9 loop {
                u9: program.units.get i: udI9
                udI9 = udI9 + 1
                match (
                    u9
                ) case namedoperation then {
                    un9: unitLabel o: u9.name
                    isDep9: true
                    if un9.stringview == mainName9 then isDep9 = false
                    if un9.stringview == "core" then isDep9 = false
                    if isDep9 then {
                        anyDem9: (resolveDemandedUnitBody
                            :ty
                            :reg
                            units: program.units
                            unitName: un9.stringview
                            shadowUnit: mainName9
                            unitdef: u9.operation
                        )
                        if anyDem9 then {
                            (onFirstEntry
                                :ty
                                :reg
                                units: program.units
                                unitName: un9.stringview
                                mainName: mainName9
                                unitdef: u9.operation
                                :full
                                entered: entered9
                            )
                        }
                    }
                } else {}
            }
            if reg.nextTypeId == beforeU9 then againU9 = false
        }
    } else {}
}

# callableUnitName -- the callable's name when a binding value is a (possibly
# expression-wrapped) call, else "". Spots a generic-unit instantiation binding
# (intmath: (genmath t: i64)).
callableUnitName: function {op: Node} out String is {
    match (
        op
    ) case expression then {
        return (callableUnitName op: op.expression)
    } case call then {
        return (atomName n: op.callable)
    } else {
        return "".string
    }
}

# firstArgTypeName -- the type-name of a call's first argument (the instantiation type
# argument, e.g. i64 in (genmath t: i64)), else "".
firstArgTypeName: function {op: Node} out String is {
    match (
        op
    ) case expression then {
        return (firstArgTypeName op: op.expression)
    } case call then {
        aiter: op.arguments.iterate
        for arg: aiter loop {
            match (
                arg
            ) case namedoperation then {
                return (atomName n: arg.operation)
            } else {}
        }
        return "".string
    } else {
        return "".string
    }
}

# collectMainInstantiations -- scan a unit body for generic-unit instantiation bindings
# and append the mono name ({template}_{arg}) + template name to the parallel lists.
# InstReq -- one generic-unit instantiation binding (intmath: (mathops t: i64)):
# the names the mint needs plus the binding's node ids for full-mode stamps.
InstReq: class {
    bind: String
    mono: String
    tmpl: String
    argn: String
    exprId: u64
    callId: u64
    calId: u64
    argAtomId: u64
}

# instFillIds -- record the instantiation's expression/call/callable/arg node
# ids on the request (the reference stamps all four at binding resolution).
instFillIds: function {r: InstReq op: Node} is {
    match (
        op
    ) case expression then {
        r.exprId = op.nodeid.u64
        instFillIds :r op: op.expression
    } case call then {
        r.callId = op.nodeid.u64
        instFillCallable :r op: op.callable
        aiter: op.arguments.iterate
        for a9: aiter loop {
            match (
                a9
            ) case namedoperation then {
                if r.argAtomId == 0 then instFillArg :r op: a9.operation
            } else {}
        }
    } else {}
}

instFillCallable: function {r: InstReq op: Node} is {
    match (
        op
    ) case atomid then {
        r.calId = op.nodeid.u64
    } else {}
}

instFillArg: function {r: InstReq op: Node} is {
    match (
        op
    ) case expression then {
        instFillArg :r op: op.expression
    } case atomid then {
        r.argAtomId = op.nodeid.u64
    } else {}
}

collectMainInstantiations: function {o: Node reqs: List InstReq} is {
    match (
        o
    ) case unitdef then {
        biter: o.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                tn: callableUnitName op: bm.operation
                if tn.length != 0 then {
                    at: firstArgTypeName op: bm.operation
                    bindn: unitLabel o: bm.name
                    mono: "\{tn}_\{at}"
                    r9: (InstReq
                        bind: bindn
                        :mono
                        tmpl: tn
                        argn: at
                        exprId: 0
                        callId: 0
                        calId: 0
                        argAtomId: 0
                    )
                    instFillIds r: r9 op: bm.operation
                    reqs.append r9
                }
            } else {}
        }
    } else {}
}

# scanMainForInstantiations -- find the main unit and collect its instantiation requests.
# Its own function scope bounds the program.units iterator so it releases before the
# mono-creation pass (which iterates program.units again).
scanMainForInstantiations: function {program: Node reqs: List InstReq} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        uiter: program.units.iterate
        for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                un: unitLabel o: u.name
                if un.stringview == mainName then collectMainInstantiations o: u.operation :reqs
            } else {}
        }
    } else {}
}

# attachMonoUnitFuncs -- add a JOIN-only `{mono}.{fn}` FUNCTION shell child per function
# in the template unit's body. The mono function rows are defined_in_unit=NULL (excluded
# from the filtered dump), so no params are resolved -- only the names matter for the JOIN.
attachMonoUnitFuncs: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    monoId: u64
    monoName: StringView
    templateOp: Node
} is {
    match (
        templateOp
    ) case unitdef then {
        fiter: templateOp.body.iterate
        for fm: fiter loop {
            match (
                fm
            ) case namedoperation then {
                if (isFunctionDefOp op: fm.operation) then {
                    fn: unitLabel o: fm.name
                    shellName: "\{monoName}.\{fn}"
                    shellId: (reg.newType
                        name: shellName.stringview
                        typetype: ztypes.ztypetype.FUNCTION
                    )
                    ty.setChild parentTypeId: monoId childName: fn.stringview childTypeId: shellId
                }
            } else {}
        }
    } else {}
}

# resolveUnitMono -- create a mono UNIT (mangled name, defined_in_unit=the instantiating
# unit) with JOIN-only function-shell children from the template's body, then seed
# return/never demand (the template functions have bodies). Skips when already resolved
# or the template unit is not found.
# isIteratorCall -- true when a type-expr is a call to `Iterator` (a generator's
# `out (Iterator gives: T)` return), peeling an expression wrapper.
isIteratorCall: function {op: Node} out bool is {
    match (
        op
    ) case expression then {
        return (isIteratorCall op: op.expression)
    } case call then {
        cn: atomName n: op.callable
        return (cn.stringview == "Iterator")
    } else {
        return false
    }
}

# isGeneratorReturn -- true when a function's return type is the Iterator protocol
# (i.e. the function is a generator that lowers to a synth iterator class).
isGeneratorReturn: function {o: Option Node} out bool is {
    match (
        o
    ) case some then {
        return (isIteratorCall op: o)
    } case none then {
        return false
    }
}

# subtreeHasYield -- true if a node subtree contains a yield expression.
subtreeHasYield: function {node: Node} out bool is {
    match (
        node
    ) case yieldexpr then {
        return true
    } case statement then {
        siter: node.statements.iterate
        for st: siter loop {
            if (subtreeHasYield node: st) then return true
        }
        return false
    } case statementline then {
        return (subtreeHasYield node: node.statementline)
    } case expression then {
        return (subtreeHasYield node: node.expression)
    } case forexpr then {
        return (optHasYield o: node.body)
    } case ifexpr then {
        cliter: node.clauses.iterate
        for cl: cliter loop {
            if (subtreeHasYield node: cl) then return true
        }
        return (optHasYield o: node.elseclause)
    } case ifclause then {
        return (subtreeHasYield node: node.statement)
    } else {
        return false
    }
}

# optHasYield -- subtreeHasYield over an optional node (a for-loop body).
optHasYield: function {o: Option Node} out bool is {
    match (
        o
    ) case some then {
        return (subtreeHasYield node: o)
    } case none then {
        return false
    }
}

# nodeIsYieldingLoop -- true when a statement (peeling statementline/expression) is a
# for-loop whose body contains a yield.
nodeIsYieldingLoop: function {node: Node} out bool is {
    match (
        node
    ) case statementline then {
        return (nodeIsYieldingLoop node: node.statementline)
    } case expression then {
        return (nodeIsYieldingLoop node: node.expression)
    } case forexpr then {
        return (optHasYield o: node.body)
    } else {
        return false
    }
}

# bodyHasYieldingLoop -- true when a function body (optional statement block) contains a
# yielding loop. Generators with one promote their straight-line locals to fields.
bodyHasYieldingLoop: function {body: Option Node} out bool is {
    match (
        body
    ) case some then {
        return (blockHasYieldingLoop blk: body)
    } case none then {
        return false
    }
}
blockHasYieldingLoop: function {blk: Node} out bool is {
    match (
        blk
    ) case statement then {
        siter: blk.statements.iterate
        for st: siter loop {
            if (nodeIsYieldingLoop node: st) then return true
        }
        return false
    } else {
        return false
    }
}

# assignmentLocalName -- the local name a statement-line binds via `name: value`, or "".
assignmentLocalName: function {line: Node} out String is {
    match (
        line
    ) case statementline then {
        return (assignmentInnerName s: line.statementline)
    } else {
        return "".string
    }
}
assignmentInnerName: function {s: Node} out String is {
    match (
        s
    ) case assignment then {
        return s.name.copy
    } else {
        return "".string
    }
}

# addPromotedLocals -- add a field (i64) per top-level local binding in a generator body
# (the loop-carried counters promoted to iter-class fields).
addPromotedLocals: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    iterId: u64
    body: Option Node
} is {
    match (
        body
    ) case some then {
        addPromotedLocalsBlk :ty :reg :units :iterId blk: body
    } case none then {}
}
addPromotedLocalsBlk: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    iterId: u64
    blk: Node
} is {
    match (
        blk
    ) case statement then {
        siter: blk.statements.iterate
        for st: siter loop {
            nm: assignmentLocalName line: st
            if nm.length != 0 then {
                lf: resolveAtomType :ty :reg :units unitName: "" nm: "i64" thisName: ""
                ty.setChild parentTypeId: iterId childName: nm.stringview childTypeId: lf
            }
        }
    } else {}
}

# synthGeneratorIterClass -- synthesize the `<fn>_iter` CLASS the oracle lowers a
# generator to: a `state: i64` field, a `create` method (param `state: i64`), and a
# `call` method (receiver `this`, BORROW). All defined_in_unit=the example; seed
# return/never demand (the lowered methods have bodies). No-param / no-promoted-local
# generators only (counter); captured params + promoted locals arrive later.
# addResumeInput -- for a bidirectional generator (`accepts: U` in the Iterator
# return), add the `_resume_input: U` field to the iter class and a `value: U` param
# (with the annotated ownership) to its `call` method.
addResumeInput: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    iterId: u64
    callId: u64
    returntype: Option Node
} is {
    match (
        returntype
    ) case some then {
        addResumeInputExpr :ty :reg :units :iterId :callId rt: returntype
    } case none then {}
}
addResumeInputExpr: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    iterId: u64
    callId: u64
    rt: Node
} is {
    match (
        rt
    ) case expression then {
        addResumeInputExpr :ty :reg :units :iterId :callId rt: rt.expression
    } case call then {
        aiter: rt.arguments.iterate
        for arg: aiter loop {
            match (
                arg
            ) case namedoperation then {
                an: unitLabel o: arg.name
                if an.stringview == "accepts" then {
                    tn: baseTypeName n: arg.operation
                    rf: resolveAtomType :ty :reg :units unitName: "" nm: tn.stringview thisName: ""
                    ty.setChild parentTypeId: iterId childName: "_resume_input" childTypeId: rf
                    vf: resolveAtomType :ty :reg :units unitName: "" nm: tn.stringview thisName: ""
                    ty.setChild parentTypeId: callId childName: "value" childTypeId: vf
                    own: pathOwnership n: arg.operation
                    match (
                        own
                    ) case some then {
                        ty.setChildOwnership parentTypeId: callId name: "value" ownership: own
                    } case none then {}
                }
            } else {}
        }
    } else {}
}

# condIterableCallable -- the callable name of a for-loop's inline iterable (a
# `binding: (gen ...)` condition), or "". A `while` condition (no binding) yields "".
condIterableCallable: function {conds: List Node} out String is {
    citer: conds.iterate
    for c: citer loop {
        match (
            c
        ) case namedoperation then {
            cb: callableUnitName op: c.operation
            if cb.length != 0 then return cb
        } else {}
    }
    return "".string
}

# forIterableCallable -- for a yielding for-loop whose iterable is a generator call,
# the callable name; "" otherwise (peels statementline/expression).
forIterableCallable: function {e: Node} out String is {
    match (
        e
    ) case statementline then {
        return (forIterableCallable e: e.statementline)
    } case expression then {
        return (forIterableCallable e: e.expression)
    } case forexpr then {
        if (optHasYield o: e.body) then {
            return (condIterableCallable conds: e.conditions)
        } else {
            return "".string
        }
    } else {
        return "".string
    }
}

# addInlineIterFields -- add an `_iterN: <callable>_iter` field per yielding for-loop
# whose iterable is an inline generator call (chain/map_filter's nested pipeline). The
# field is typed by the nested generator's iter class; no create param (that lives on
# the excluded NULL-unit create).
addInlineIterFields: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    iterId: u64
    body: Option Node
} is {
    match (
        body
    ) case some then {
        addInlineIterFieldsBlk :ty :reg :units :iterId blk: body
    } case none then {}
}
addInlineIterFieldsBlk: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    iterId: u64
    blk: Node
} is {
    match (
        blk
    ) case statement then {
        n: 0.u64
        siter: blk.statements.iterate
        for st: siter loop {
            cb: forIterableCallable e: st
            if cb.length != 0 then {
                fieldName: "_iter\{n}"
                fieldType: "\{cb.stringview}_iter"
                ft: (resolveAtomType
                    :ty
                    :reg
                    :units
                    unitName: ""
                    nm: fieldType.stringview
                    thisName: ""
                )
                ty.setChild parentTypeId: iterId childName: fieldName.stringview childTypeId: ft
                n = n + 1
            }
        }
    } else {}
}

# synthGeneratorForMethod -- synthesize the iter class for a generator METHOD (an
# as-block method whose return is the Iterator protocol). thisName is the enclosing
# type, so a `this`-typed captured param (b: this.private.lock) resolves to it.
synthGeneratorForMethod: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    fnName: StringView
    thisName: StringView
    op: Node
} is {
    match (
        op
    ) case functiondef then {
        if (isGeneratorReturn o: op.returntype) then {
            synthGeneratorIterClass :ty :reg :units :unitName :fnName :thisName fnode: op
        }
    } else {}
}

synthGeneratorIterClass: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    fnName: StringView
    thisName: StringView
    fnode: zast.FunctionData
} is {
    iterName: "\{fnName}_iter"
    iterId: reg.newType name: iterName.stringview typetype: ztypes.ztypetype.CLASS
    iid: iterId
    reg.setValtype typeId: iterId value: false
    ty.definedInUnit.set key: iid value: unitName.string
    needsDtor: false
    st1: resolveAtomType :ty :reg :units :unitName nm: "i64" thisName: ""
    ty.setChild parentTypeId: iterId childName: "state" childTypeId: st1
    createName: "\{iterName}.create"
    createId: reg.newType name: createName.stringview typetype: ztypes.ztypetype.FUNCTION
    cdid: createId
    ty.definedInUnit.set key: cdid value: unitName.string
    callName: "\{iterName}.call"
    callId: reg.newType name: callName.stringview typetype: ztypes.ztypetype.FUNCTION
    clid: callId
    ty.definedInUnit.set key: clid value: unitName.string
    ty.setChild parentTypeId: callId childName: "this" childTypeId: iterId
    ty.setChildOwnership parentTypeId: callId name: "this" ownership: ztypes.zparamownership.BORROW
    piter: fnode.parameters.iterate
    for pm: piter loop {
        match (
            pm
        ) case namedoperation then {
            pn: unitLabel o: pm.name
            ptn: baseTypeName n: pm.operation
            f1: resolveAtomType :ty :reg :units :unitName nm: ptn.stringview :thisName
            ty.setChild parentTypeId: iterId childName: pn.stringview childTypeId: f1
            f2: resolveAtomType :ty :reg :units :unitName nm: ptn.stringview :thisName
            ty.setChild parentTypeId: createId childName: pn.stringview childTypeId: f2
            pown: pathOwnership n: pm.operation
            match (
                pown
            ) case some then {
                ty.setChildOwnership parentTypeId: createId name: pn.stringview ownership: pown
                needsDtor = true
            } case none then {}
        } else {}
    }
    addResumeInput :ty :reg :units :iterId :callId returntype: fnode.returntype
    if (bodyHasYieldingLoop body: fnode.body) then {
        addPromotedLocals :ty :reg :units :iterId body: fnode.body
    }
    addInlineIterFields :ty :reg :units :iterId body: fnode.body
    ty.setChild parentTypeId: iterId childName: "create" childTypeId: createId
    ty.setChild parentTypeId: iterId childName: "call" childTypeId: callId
    if needsDtor then {
        dn: "\{iterName}_destroy"
        reg.setDestructorName typeId: iterId name: dn.stringview
    }
    reg.recordDemand name: "return"
    reg.recordDemand name: "never"
}

# isUnitOp -- true when a binding's operation is an inline `unit as {...}` definition.
isUnitOp: function {op: Node} out bool is {
    match (
        op
    ) case unitdef then {
        return true
    } else {
        return false
    }
}

# resolveInlineGenericUnit -- resolve an inline generic unit (mathops: unit as { t:
# Any.generic; add; double }) into a UNIT type (is_generic) whose functions are mangled
# {unit}_{fn} FUNCTION children (with their generic-param types KEPT -- unlike a generic
# FILE unit, an inline template's params are not suppressed).
resolveInlineGenericUnit: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    unitName: StringView
    defName: StringView
    unitOp: Node
} is {
    match (
        unitOp
    ) case unitdef then {
        uid: reg.newType name: defName typetype: ztypes.ztypetype.UNIT
        did: uid
        rid: uid
        if (hasGenericParam items: unitOp.body) then {
            reg.setGeneric typeId: uid value: true
            if ty.fullMainUnit.length > 0 then {
                # full mode mirrors the reference's inline-template touch:
                # the unit node and each bare generic-param def stamp, and
                # the param name resolves so signature t-refs stamp.
                udnid: unitOp.nodeid
                uidv: uid
                ty.nodeType.set key: udnid.u64 value: uidv
                with gpiter: unitOp.body.iterate do for gm: gpiter loop {
                    match (
                        gm
                    ) case namedoperation then {
                        if (isBareGenericParam op: gm.operation) then {
                            gpn5: unitLabel o: gm.name
                            ik5: "\{unitName}.\{defName}"
                            gtid5: 0.u64
                            gpo5: (reg.genericParamTidOf
                                typeKey: ik5.stringview
                                paramName: gpn5.stringview
                            )
                            match (
                                gpo5
                            ) case some then {
                                gtid5 = gpo5
                            } case none then {
                                gtid5 = (reg.newType
                                    name: gpn5.stringview
                                    typetype: ztypes.ztypetype.GENERIC_PARAM
                                )
                                (reg.setGenericParamTid
                                    typeKey: ik5.stringview
                                    paramName: gpn5.stringview
                                    tid: gtid5
                                )
                            }
                            gpnid: nodeId n: gm.operation
                            gtidV5: gtid5
                            ty.nodeType.set key: gpnid.u64 value: gtidV5
                        }
                    } else {}
                }
            }
        }
        ty.definedInUnit.set key: did value: unitName.string
        # A non-generic inline unit is a real type; lay its unit->def childOf edge
        # (a generic template must NOT get one -- its id is the pre-instantiation
        # template, which would shadow instance lookups).
        if (hasGenericParam items: unitOp.body) == false then {
            icu0: reg.unitNameTid.get key: unitName.string
            match (
                icu0
            ) case some then {
                ty.setChild parentTypeId: icu0 childName: defName childTypeId: rid
            } case none then {}
        }
        biter: unitOp.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                fn: unitLabel o: bm.name
                qn: "\{defName}_\{fn}"
                mido: (resolveMethodFn
                    :ty
                    :reg
                    :units
                    :unitName
                    qname: qn.stringview
                    thisName: ""
                    op: bm.operation
                )
                match (
                    mido
                ) case some then {
                    ty.setChild parentTypeId: uid childName: fn.stringview childTypeId: mido
                } case none then {}
            } else {}
        }
    } else {}
}

# createUnitMono -- create a mono UNIT (defined_in_unit=the instantiating unit) with
# JOIN-only function-shell children from a template unit body, then seed return/never
# demand. Dedups on the mono's resolved key.
createUnitMono: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    monoName: StringView
    templateName: StringView
    templateOp: Node
} is {
    rkey: "\{unitName}.\{monoName}"
    got: resolvedByKey :ty :reg key: rkey
    exists: false
    match (
        got
    ) case some then {
        exists = true
    } case none then {}
    if (exists) == false then {
        monoId: reg.newType name: monoName typetype: ztypes.ztypetype.UNIT
        did: monoId
        rid: monoId
        ty.definedInUnit.set key: did value: unitName.string
        iur: monoId
        reg.setUnitName name: monoName uid: iur
        ccu2: reg.unitNameTid.get key: unitName.string
        match (
            ccu2
        ) case some then {
            ty.setChild parentTypeId: ccu2 childName: monoName childTypeId: rid
        } case none then {}
        # link the mono to its template (inline templates register under
        # the main unit; file templates carry the per-unit UNIT type).
        tplKey: "\{unitName}.\{templateName}"
        tplGot: resolvedByKey :ty :reg key: tplKey
        match (
            tplGot
        ) case some then {
            reg.setGenericOrigin typeId: monoId value: tplGot
        } case none then {
            tplK2: templateName.string
            utGot: reg.unitNameTid.get key: tplK2
            match (
                utGot
            ) case some then {
                reg.setGenericOrigin typeId: monoId value: utGot
            } case none then {
                # inline generic template: no childOf edge and not a unit
                # root -- its id lives only in the full-mode def-node stamp
                # laid by resolveInlineGenericUnit.
                itnid: unitdefNodeId n: templateOp
                itso: ty.nodeType.get key: itnid.u64
                match (
                    itso
                ) case some then {
                    reg.setGenericOrigin typeId: monoId value: itso
                } case none then {}
            }
        }
        attachMonoUnitFuncs :ty :reg :monoId :monoName :templateOp
        reg.recordDemand name: "return"
        reg.recordDemand name: "never"
    }
}

# resolveInlineMono -- create the mono for an INLINE template: scan the main unit body
# for the inline `unit as {...}` binding named templateName and build the mono from it.
resolveInlineMono: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    monoName: StringView
    templateName: StringView
    mainOp: Node
} is {
    match (
        mainOp
    ) case unitdef then {
        biter: mainOp.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                bn: unitLabel o: bm.name
                if bn.stringview == templateName then {
                    if (isUnitOp op: bm.operation) then {
                        (createUnitMono
                            :ty
                            :reg
                            :unitName
                            :monoName
                            :templateName
                            templateOp: bm.operation
                        )
                    }
                }
            } else {}
        }
    } else {}
}

# resolveUnitMono -- create the mono UNIT for a generic-unit instantiation. The template
# is either a FILE unit (in program.units) or an INLINE unit in the main body
# (unitName == the main unit name for these instantiations).
resolveUnitMono: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    program: Node
    unitName: StringView
    monoName: StringView
    templateName: StringView
} is {
    match (
        program
    ) case program then {
        uiter: program.units.iterate
        for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                un: unitLabel o: u.name
                if un.stringview == templateName then {
                    (createUnitMono
                        :ty
                        :reg
                        :unitName
                        :monoName
                        :templateName
                        templateOp: u.operation
                    )
                }
                if un.stringview == unitName then {
                    resolveInlineMono :ty :reg :unitName :monoName :templateName mainOp: u.operation
                }
            } else {}
        }
    } else {}
}

# typeNameOfReg -- typeNameOf without a symbol table (registry-only callers).
typeNameOfReg: function {reg: ztypes.ZTypeRegistry tid: u64} out String is {
    t: reg.typeById.get key: tid
    match (
        t
    ) case some then {
        return t.name.copy
    } case none then {
        return "".string
    }
}

# fnReturnBaseName -- the base type name of a function's return typeref
# ("" when absent), for completing substituted signatures whose template
# return was still unresolved at signature time.
fnReturnBaseName: function {o: Option Node} out String is {
    match (
        o
    ) case some then {
        return (baseTypeName n: o)
    } case none then {
        return "".string
    }
}

fnReturnBaseNameOf: function {op: Node} out String is {
    match (
        op
    ) case functiondef then {
        return (fnReturnBaseName o: op.returntype)
    } else {
        return "".string
    }
}

# cloneUnitMethod -- deep-clone a template method functiondef with fresh synth
# nodeids. The clone never registers in ast_nodes, so its body's stamps stay
# out of the dump; only its walk's scope/entry/variable rows are visible.
cloneUnitMethod: function {ids: zgenerator.GenIds op: Node} out Option Node is {
    match (
        op
    ) case functiondef then {
        pm9: (Map String value: bool)
        params9: (List Node)
        with piter: op.parameters.iterate do for pp: piter loop {
            pc: zgenerator.clonePath :ids n: pp
            params9.append pc
        }
        rt9: zgenerator.rewriteOptToThis :ids o: op.returntype promoted: pm9
        body9: zgenerator.rewriteOptToThis :ids o: op.body promoted: pm9
        ln9: op.lineno
        cn9: op.colno
        fnew: (Node.functiondef (zast.FunctionData
            nodeid: ids.mint
            lineno: ln9
            colno: cn9
            returntype: rt9
            parameters: params9
            body: body9
            isNative: false
            asItems: (List Node))
        )
        return (Option.some fnew)
    } else {
        return (Option.none Node)
    }
}

# buildUnitMonoFull -- full-mode unit-mono completion: substituted method
# children ({mono}.{fn} FUNCTION types whose generic-param-named child types
# and return are replaced by the instantiation arg) plus a cloned body per
# method, stashed for the lazy first-use walk. One build per mono.
# registerMonoFnParams -- register a mono unit fn's generic-param-typed params
# (a: t -> a: argId) on the mono FUNCTION type, sourced from the template fn's
# AST. The template fn stays childless -- only the instance carries substituted
# param children, matching the reference (which carries them via the clone).
registerMonoFnParams: function {
    ty: ztyping.ZTyping
    op: Node
    fnId: u64
    gpNames: (Map String value: bool)
    argId: u64
} is {
    match (
        op
    ) case functiondef then {
        ppiter: op.parameters.iterate
        for ppm: ppiter loop {
            match (
                ppm
            ) case namedoperation then {
                pptn: atomName n: ppm.operation
                ppgo: gpNames.get key: pptn
                match (
                    ppgo
                ) case some then {
                    if argId > 0 then {
                        ppnm: unitLabel o: ppm.name
                        ty.setChild parentTypeId: fnId childName: ppnm.stringview childTypeId: argId
                    }
                } case none then {}
            } else {}
        }
    } else {}
}

buildUnitMonoFull: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    tmplUnitName: StringView
    tmplName: StringView
    monoId: u64
    monoName: StringView
    tplId: u64
    argId: u64
    templateOp: Node
} is {
    bgot9: ty.collectionChildrenBuilt.get key: monoId
    if (optBoolOr o: bgot9 d: false) then return
    bk0: monoId
    ty.collectionChildrenBuilt.set key: bk0 value: true
    gpNames: (Map String value: bool)
    gpFirst: "".string
    match (
        templateOp
    ) case unitdef then {
        with giter: templateOp.body.iterate do for gm: giter loop {
            match (
                gm
            ) case namedoperation then {
                if (isGenericParam op: gm.operation) then {
                    gn: unitLabel o: gm.name
                    if gpFirst.length == 0 then {
                        gnv9: gn.stringview
                        gpc9: gnv9.string
                        gpFirst = gpc9
                    }
                    gv: true
                    gpNames.set key: gn value: gv
                }
            } else {}
        }
        ids9: (zgenerator.GenIds nextId: ty.nextSynthNodeId)
        fiter: templateOp.body.iterate
        for fm: fiter loop {
            match (
                fm
            ) case namedoperation then {
                if (isFunctionDefOp op: fm.operation) then {
                    fn: unitLabel o: fm.name
                    qn: "\{monoName}.\{fn}"
                    srcId: 0.u64
                    tfo: ty.childOf parentTypeId: tplId name: fn.stringview
                    match (
                        tfo
                    ) case some then {
                        srcId = tfo
                    } case none then {
                        tq: "\{tmplName}_\{fn}"
                        mo0: (resolveMethodFn
                            :ty
                            :reg
                            :units
                            unitName: tmplUnitName
                            qname: tq.stringview
                            thisName: ""
                            op: fm.operation
                        )
                        match (
                            mo0
                        ) case some then {
                            srcId = mo0
                            (ty.setChild
                                parentTypeId: tplId
                                childName: fn.stringview
                                childTypeId: mo0
                            )
                        } case none then {}
                    }
                    newFnId: reg.newType name: qn.stringview typetype: ztypes.ztypetype.FUNCTION
                    if srcId > 0 then {
                        cNames: (List String)
                        cIds: (List u64)
                        {
                            bmb9: ty.childIndex.get key: srcId
                            match (
                                bmb9
                            ) case some then {
                                with bmit9: bmb9.rows.iterate do for bmr9: bmit9 loop {
                                    tc: ty.typeChild.get i: bmr9
                                    cto: ty.childTypeById.get key: tc.childNameId
                                    match (
                                        cto
                                    ) case some then {
                                        cn0: tc.childName.copy
                                        cNames.append cn0
                                        cid2: cto
                                        cIds.append cid2
                                    } case none then {}
                                }
                            } case none then {}
                        }
                        ci: 0.u64
                        cn3: cNames.length
                        for ci < cn3 loop {
                            chName: cNames.get i: ci
                            chId: cIds.get i: ci
                            target: chId
                            ctn: typeNameOfReg :reg tid: chId
                            cgo: gpNames.get key: ctn
                            match (
                                cgo
                            ) case some then {
                                if argId > 0 then target = argId
                            } case none then {}
                            (ty.setChild
                                parentTypeId: newFnId
                                childName: chName.stringview
                                childTypeId: target
                            )
                            ci = ci + 1
                        }
                        rto9: (optionval.none u64)
                        {
                            tf2: reg.typeById.get key: srcId
                            match (
                                tf2
                            ) case some then {
                                rto9 = tf2.returnTypeId
                            } case none then {}
                        }
                        match (
                            rto9
                        ) case some then {
                            rtv: rto9
                            rtn: typeNameOfReg :reg tid: rtv
                            rgo: gpNames.get key: rtn
                            match (
                                rgo
                            ) case some then {
                                if argId > 0 then rtv = argId
                            } case none then {}
                            reg.setReturnType typeId: newFnId value: rtv
                        } case none then {
                            # template return unresolved at signature time
                            # (out t): derive from the method's AST typeref.
                            rnm: fnReturnBaseNameOf op: fm.operation
                            if rnm.length > 0 then {
                                rgo2: gpNames.get key: rnm
                                rid2: 0.u64
                                match (
                                    rgo2
                                ) case some then {
                                    rid2 = argId
                                } case none then {
                                    rlo2: (walkLookupTyperef
                                        :ty
                                        :reg
                                        currentUnit: tmplUnitName
                                        base: rnm.stringview
                                    )
                                    match (
                                        rlo2
                                    ) case some then {
                                        rid2 = rlo2
                                    } case none then {}
                                }
                                if rid2 > 0 then reg.setReturnType typeId: newFnId value: rid2
                            }
                        }
                    }
                    registerMonoFnParams :ty op: fm.operation fnId: newFnId :gpNames :argId
                    ty.setChild parentTypeId: monoId childName: fn.stringview childTypeId: newFnId
                    co9: cloneUnitMethod ids: ids9 op: fm.operation
                    match (
                        co9
                    ) case some then {
                        gpv9: gpFirst.stringview
                        gpn9: gpv9.string
                        mn9: monoName.string
                        rec9: (ztyping.PendingUnitWalk
                            :monoId
                            monoName: mn9
                            qualified: qn
                            gpName: gpn9
                            :argId
                            fn: co9.take
                        )
                        ty.pendingUnitWalk.append rec9
                        mk9: monoId
                        pw9: true
                        ty.unitMonoWalksPending.set key: mk9 value: pw9
                    } case none then {}
                }
            } else {}
        }
        ty.nextSynthNodeId = ids9.nextId
    } else {}
}

# completeInlineReq -- locate an inline template member by name in the main
# unit body and build its mono's full-mode completion.
completeInlineReq: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    units: List Node
    mainName: StringView
    monoId: u64
    monoName: StringView
    tmplName: StringView
    tplId: u64
    argId: u64
    mainOp: Node
} is {
    match (
        mainOp
    ) case unitdef then {
        biter: mainOp.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                bn: unitLabel o: bm.name
                if bn.stringview == tmplName then {
                    if (isUnitOp op: bm.operation) then {
                        (buildUnitMonoFull
                            :ty
                            :reg
                            :units
                            tmplUnitName: mainName
                            :tmplName
                            :monoId
                            :monoName
                            :tplId
                            :argId
                            templateOp: bm.operation
                        )
                    }
                }
            } else {}
        }
    } else {}
}

# inlineTemplateTid -- the canonical id of an inline generic-unit template
# (mathops: unit as {...} in the main body). A generic inline template has no
# unit->def childOf edge (it would shadow instance lookups) and is not a unit
# root, so the only durable record of its id is the full-mode def-node stamp
# laid by resolveInlineGenericUnit; 0 when no such binding is stamped.
inlineTemplateTid: function {ty: ztyping.ZTyping mainOp: Node tmplName: StringView} out u64 is {
    found: 0.u64
    match (
        mainOp
    ) case unitdef then {
        biter: mainOp.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                bn: unitLabel o: bm.name
                if bn.stringview == tmplName then {
                    if (isUnitOp op: bm.operation) then {
                        tnid: unitdefNodeId n: bm.operation
                        tso: ty.nodeType.get key: tnid.u64
                        match (
                            tso
                        ) case some then {
                            found = tso
                        } case none then {}
                    }
                }
            } else {}
        }
    } else {}
    return found
}

# completeUnitInstantiations -- post-demand full-mode pass: with system types
# resolved, finish each generic-unit instantiation (substituted children +
# clone stash), register the binding name, and stamp the instantiation's
# expression/call/callable/arg nodes (the reference stamps all four).
completeUnitInstantiations: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    program: Node
} is {
    mainName: programMainName :program
    reqs: (List InstReq)
    scanMainForInstantiations :program :reqs
    i: 0.u64
    for i < reqs.length loop {
        r: reqs.get :i
        rbv1: r.bind.stringview
        rb: rbv1.string
        rmv1: r.mono.stringview
        rm: rmv1.string
        rtv1: r.tmpl.stringview
        rt: rtv1.string
        rav1: r.argn.stringview
        ra: rav1.string
        re: r.exprId
        rc: r.callId
        rl: r.calId
        rg: r.argAtomId
        mk: "\{mainName}.\{rm}"
        mgo: resolvedByKey :ty :reg key: mk
        match (
            mgo
        ) case some then {
            mid9: mgo
            br9: mid9
            reg.setUnitName name: rb.stringview uid: br9
            tplId: 0.u64
            tk: "\{mainName}.\{rt}"
            tgo: resolvedByKey :ty :reg key: tk
            match (
                tgo
            ) case some then {
                tplId = tgo
            } case none then {
                tnv9: rt.stringview
                tn9: tnv9.string
                ugo: reg.unitNameTid.get key: tn9
                match (
                    ugo
                ) case some then {
                    tplId = ugo
                } case none then {}
            }
            argId: 0.u64
            ago: walkLookupTyperef :ty :reg currentUnit: mainName.stringview base: ra.stringview
            match (
                ago
            ) case some then {
                argId = ago
            } case none then {}
            if tplId == 0 then {
                match (
                    program
                ) case program then {
                    tuiter: program.units.iterate
                    for tu: tuiter loop {
                        match (
                            tu
                        ) case namedoperation then {
                            tun: unitLabel o: tu.name
                            if tun.stringview == mainName.stringview then {
                                tplId = (inlineTemplateTid
                                    :ty
                                    mainOp: tu.operation
                                    tmplName: rt.stringview
                                )
                            }
                        } else {}
                    }
                } else {}
            }
            if tplId > 0 then {
                match (
                    program
                ) case program then {
                    uN9: program.units.length
                    uI9: 0.u64
                    for uI9 < uN9 loop {
                        u9: program.units.get i: uI9
                        uI9 = uI9 + 1
                        match (
                            u9
                        ) case namedoperation then {
                            un9: unitLabel o: u9.name
                            if un9.stringview == rt.stringview then {
                                (buildUnitMonoFull
                                    :ty
                                    :reg
                                    units: program.units
                                    tmplUnitName: un9.stringview
                                    tmplName: rt.stringview
                                    monoId: mid9
                                    monoName: rm.stringview
                                    :tplId
                                    :argId
                                    templateOp: u9.operation
                                )
                            }
                            if un9.stringview == mainName.stringview then {
                                (completeInlineReq
                                    :ty
                                    :reg
                                    units: program.units
                                    mainName: mainName.stringview
                                    monoId: mid9
                                    monoName: rm.stringview
                                    tmplName: rt.stringview
                                    :tplId
                                    :argId
                                    mainOp: u9.operation
                                )
                            }
                        } else {}
                    }
                } else {}
            }
            if re > 0 then {
                ev: mid9
                ty.nodeType.set key: re value: ev
            }
            if rc > 0 then {
                cv: mid9
                ty.nodeType.set key: rc value: cv
            }
            if rl > 0 when tplId > 0 then {
                lv: tplId
                ty.nodeType.set key: rl value: lv
            }
            if rg > 0 when argId > 0 then {
                av: argId
                ty.nodeType.set key: rg value: av
            }
        } case none then {}
        i = i + 1
    }
}

# runUnitMonoWalks -- first body-walk use of a generic-unit mono: walk each
# stashed method clone under a unitgeneric scope. The generic param name
# temporarily resolves to the arg type for the walk (param typerefs resolve
# by name); clone scopes parent under the current (using) scope, matching
# the reference's lazy clone-and-check.
runUnitMonoWalks: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    monoId: u64
} is {
    pgo: st.typing.unitMonoWalksPending.get key: monoId
    match (
        pgo
    ) case some then {} case none then {
        return
    }
    dk: monoId
    st.typing.unitMonoWalksPending.remove key: dk
    n9: st.typing.pendingUnitWalk.length
    i9: 0.u64
    for i9 < n9 loop {
        rmid: (st.typing.pendingUnitWalk.get i: i9).monoId
        if rmid == monoId then {
            rqual: "".string
            rgp: "".string
            rmn: "".string
            raid: 0.u64
            {
                rec: st.typing.pendingUnitWalk.get i: i9
                rqual = rec.qualified.copy
                rgp = rec.gpName.copy
                rmn = rec.monoName.copy
                raid = rec.argId
            }
            sn: "unitgeneric:\{rmn}"
            st.push name: sn.stringview
            st.define name: rgp.stringview ztypeId: raid
            prevL: st.typing.synthLabel.copy
            prevT: st.typing.currentThisName.copy
            ed8: (List Node)
            (checkFunctionBody
                :st
                :unitName
                defName: rqual.stringview
                defn: (st.typing.pendingUnitWalk.get i: i9).fn
                thisName: ""
                :unitBody
                depUnits: ed8
            )
            st.typing.synthLabel = prevL
            st.typing.currentThisName = prevT
            st.pop
        }
        i9 = i9 + 1
    }
}

# resolveMainUnitInstantiations -- resolve generic-unit instantiation bindings in the main
# unit (intmath: (genmath t: i64)) into mono UNIT types. Two passes avoid nested
# program.units iteration: collect requests (separate fn), then create each mono.
# programMainName -- the main unit's name as an owned copy (no lingering lock on
# program, so program stays freely passable as a Node).
programMainName: function {program: Node} out String is {
    match (
        program
    ) case program then {
        return (program.mainUnitName.copy)
    } else {
        return "".string
    }
}

resolveMainUnitInstantiations: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    program: Node
} is {
    mainName: programMainName :program
    reqs: (List InstReq)
    scanMainForInstantiations :program :reqs
    i: 0.u64
    for i < reqs.length loop {
        r: reqs.get :i
        rmv0: r.mono.stringview
        rm: rmv0.string
        rtv0: r.tmpl.stringview
        rt: rtv0.string
        (resolveUnitMono
            :ty
            :reg
            :program
            unitName: mainName.stringview
            monoName: rm.stringview
            templateName: rt.stringview
        )
        i = i + 1
    }
}

# typecheck -- entry point. Registers a UNIT type per unit and resolves the main
# unit's definition signatures, then demand-resolves the cross-unit types those
# signatures referenced. The registry is supplied by the caller, read by the dumper.
# builtinTidTc -- the canonical registry id of a stdlib builtin by base name
# (mainName "" so a user type of the same name never shadows it). 0 when absent.
builtinTidT: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry base: StringView} out u64 is {
    bk: base.string
    m: ty.builtinTidMemo.get key: bk
    match (
        m
    ) case some then {
        return m
    } case none then {}
    r: (optU64Or o: (walkLookupTyperef :ty :reg currentUnit: "" :base) d: 0)
    if r == 0 then return r
    ty.builtinTidMemo.set key: bk.take value: r
    return r
}

builtinTidTc: function {st: zenv.ZSymbolTable base: StringView} out u64 is {
    return (builtinTidT ty: st.typing reg: st.reg :base)
}

# stampTyperefs -- post-demand pass: stamp every recorded type-ref node with its real
# resolved type. Runs after the demand descent, so system + forward refs are present
# in childOf. pendingTyperef is a sibling field of nodeType (no lock
# conflict). The widened typed_nodes differential reads the resulting nodeType rows.
stampTyperefs: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry program: Node} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        pkeys9: (List u64)
        pvals9: (List String)
        with it: ty.pendingTyperef.iterateItems do for e: it loop {
            pk9: e.key
            pkeys9.append pk9
            pv9: e.value.copy
            pvals9.append pv9
        }
        pi9: 0.u64
        pcnt9: pkeys9.length
        for pi9 < pcnt9 loop {
            uk: pkeys9.get i: pi9
            pval9: pvals9.get i: pi9
            pi9 = pi9 + 1
            originOwn9: "".string
            {
                uo: ty.pendingTyperefUnit.get key: uk
                match (
                    uo
                ) case some then {
                    if uo.length > 0 then originOwn9 = uo.copy
                } case none then {}
            }
            origin: mainName
            if originOwn9.length > 0 then origin = originOwn9.stringview
            skip0: false
            {
                sk0: ty.noStampNode.get key: uk
                match (
                    sk0
                ) case some then {
                    if sk0 then skip0 = true
                } case none then {
                }
            }
            if (skip0) == false then {
                r: walkLookupTyperef :ty :reg currentUnit: origin base: pval9.stringview
                match (
                    r
                ) case some then {
                    nid: uk
                    ty.nodeType.set key: nid value: r
                } case none then {}
            }
        }
    } else {}
}

# ownershipOfParam -- a parameter's binding ownership from its path annotation:
# an explicit .take binds OWNED, everything else (.borrow / .lock / default)
# binds BORROWED (mirrors _check_function_body_inner's param-ownership mapping).
ownershipOfParam: function {o: optionval ztypes.zparamownership} out ztypes.zownership is {
    match (
        o
    ) case some then {
        po: o
        match (
            po
        ) case TAKE then {
            return ztypes.zownership.OWNED
        } case BORROW then {
            return ztypes.zownership.BORROWED
        } case LOCK then {
            return ztypes.zownership.BORROWED
        }
    } case none then {
        return ztypes.zownership.BORROWED
    }
}

# paramTypeId -- the resolved type id of a parameter's type-expr. Reads the
# post-demand node stamp (stampTyperefs), falling back to a cross-unit name
# lookup for a bare-atom base.
paramTypeId: function {
    typing: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    op: Node
} out u64 is {
    # A parameter type carrying an ownership marker (ztypes.ZTypeRegistry.take)
    # resolves through its peeled base: the marker node is recorded under the
    # current unit and left unstamped, so read the inner cross-unit ref that
    # stampTyperefs resolved. Mirrors the reference's _strip_path_ownership.
    match (
        op
    ) case dottedpath then {
        ocn: atomName n: op.child
        if (isStripMarker name: ocn.stringview) then {
            return (paramTypeId :typing :reg :unitName op: op.parent)
        }
    } else {
    }
    onid: nodeId n: op
    r: typing.nodeType.get key: onid.u64
    match (
        r
    ) case some then {
        return r
    } case none then {
        an: atomName n: op
        ano: walkLookupTyperef ty: typing :reg currentUnit: unitName base: an.stringview
        anid: optU64Or o: ano d: 0
        if anid > 0 then return anid
        # a dotted typeref naming a variant/union ARM is an arm DEFAULT:
        # the parameter's type is the tagged parent.
        bn: rootNameOf n: op
        if bn.length > 0 then {
            return (optU64Or
                o: (walkLookupTyperef ty: typing :reg currentUnit: unitName base: bn.stringview)
                d: 0
            )
        }
        return 0
    }
}

# isReturnCallKind -- true iff the stamped call-kind is a diverging control
# statement (return / panic / error); the statement walk marks the scope
# unreachable after one.
isReturnCallKind: function {o: optionval zast.callkind} out bool is {
    match (
        o
    ) case some then {
        ck: o
        match (
            ck
        ) case RETURN then {
            return true
        } case PANIC then {
            return true
        } case ERROR then {
            return true
        } else {
            return false
        }
    } case none then {
        return false
    }
}

# checkString -- a non-interpolated string literal types as StringView; an
# interpolated one (any non-chunk part) types as String, since it must allocate
# to splice the values, and each interpolated sub-expression is walked + stamped.
checkString: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    node: zast.AtomStringData
} out u64 is {
    result: 0.u64
    hasInterp: false
    for part: node.stringparts.iterate loop {
        match (
            part
        ) case stringchunk then {
        } else {
            hasInterp = true
            checkValue :st :unitName :unitBody node: part
        }
    }
    # the runtime value is always the SYSTEM String/StringView (the interp
    # machinery and the literal pool build system strings), so the stamp is
    # canonical even in a unit that shadows the name
    tyOpt: (optionval.none u64)
    if hasInterp then {
        tyOpt = walkLookupTyperef ty: st.typing reg: st.reg currentUnit: "" base: "String"
    } else {
        tyOpt = walkLookupTyperef ty: st.typing reg: st.reg currentUnit: "" base: "StringView"
    }
    match (
        tyOpt
    ) case some then {
        result = tyOpt
        setk: result
        st.typing.nodeType.set key: node.nodeid.u64 value: setk
    } case none then {
    }
    drainPendingBorrow :st
    return result
}

# checkAtomid -- type a name-atom in value position: a local variable resolves
# via the symbol table. (Numeric literals + unit-def atoms land in later slices.)
# typeNameOf -- a registered type's name as an owned String ("" when absent).
typeNameOf: function {st: zenv.ZSymbolTable tid: u64} out String is {
    t: st.reg.typeById.get key: tid
    match (
        t
    ) case some then {
        return t.name.copy
    } case none then {
        return "".string
    }
}

# cloneMethodInto -- specialize one template method for an instance: a fresh
# FUNCTION type named {spec}.{m} whose param children and return substitute
# the template parameters (id-first, then re-specialization). genericOriginId
# points at the TEMPLATE METHOD so the emitter's mono-instance sweep emits the
# template body against this signature.
cloneMethodInto: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    specName: StringView
    specId: u64
    tplClassId: u64
    m: StringView
    tplFnId: u64
    idSubs: (Map u64 value: u64)
} is {
    fn5: "\{specName}.\{m}"
    fid5: reg.newType name: fn5.stringview typetype: ztypes.ztypetype.FUNCTION
    reg.setGenericOrigin typeId: fid5 value: tplFnId
    # The clone answers call-site questions the same way the template does:
    # isNative gates arg validation, thisParamName drives receiver auto-fill
    # and the no-paren auto-call, funcReturnsBorrow carries the `.borrow`
    # return marker, and funcReturnNode backs methodReturnOf for concrete
    # (non-generic) returns.
    tpn0: "".string
    isNat0: false
    {
        tz0: reg.typeById.get key: tplFnId
        match (
            tz0
        ) case some then {
            if tz0.isNative then isNat0 = true
            tpn0 = optStrOrEmpty o: tz0.thisParamName
        } case none then {}
    }
    if isNat0 then reg.setNative typeId: fid5 value: true
    if tpn0.length > 0 then reg.setThisParamName typeId: fid5 name: tpn0.stringview
    if (optBoolOr o: (ty.funcReturnsBorrow.get key: tplFnId) d: false) then {
        ty.funcReturnsBorrow.set key: fid5 value: true
    }
    frn0: optU64Or o: (ty.funcReturnNode.get key: tplFnId) d: 0
    if frn0 > 0 then ty.funcReturnNode.set key: fid5 value: frn0
    cN5: (List String)
    cI5: (List u64)
    cOh5: (List bool)
    cOv5: (List ztypes.zparamownership)
    {
        cmb9: ty.childIndex.get key: tplFnId
        match (
            cmb9
        ) case some then {
            with cit5: cmb9.rows.iterate do for cmr9: cit5 loop {
                tc5: ty.typeChild.get i: cmr9
                co5: ty.childTypeById.get key: tc5.childNameId
                match (
                    co5
                ) case some then {
                    nm5: tc5.childName.copy
                    cN5.append nm5
                    cv5: co5
                    cI5.append cv5
                    oo5: ty.childOwnership.get key: tc5.childNameId
                    match (
                        oo5
                    ) case some then {
                        cOh5.append true
                        ov5c: oo5
                        cOv5.append ov5c
                    } case none then {
                        cOh5.append false
                        cOv5.append ztypes.zparamownership.BORROW
                    }
                } case none then {}
            }
        } case none then {}
    }
    tplNm5: regTypeNameOf :reg tid: tplClassId
    pi5: 0.u64
    pn5: cN5.length
    for pi5 < pn5 loop {
        pnm5: cN5.get i: pi5
        ptid5: cI5.get i: pi5
        tgt5: ptid5
        if ptid5 == tplClassId then tgt5 = specId
        if pnm5.stringview == "this" then tgt5 = specId
        if tpn0.length > 0 when pnm5.stringview == tpn0.stringview then tgt5 = specId
        if tgt5 == ptid5 then {
            # `this`/`type`-typed params carry fresh shells named after the
            # class; shell-name identity marks the self type.
            ptn5: regTypeNameOf :reg tid: ptid5
            if ptn5.stringview == tplNm5.stringview then tgt5 = specId
        }
        if tgt5 == ptid5 then {
            ido5: idSubs.get key: ptid5
            match (
                ido5
            ) case some then {
                tgt5 = ido5
            } case none then {
                rs5: respecialize :ty :reg :mainName specTid: ptid5 :idSubs
                if rs5 > 0 then tgt5 = rs5
            }
        }
        ty.setChild parentTypeId: fid5 childName: pnm5.stringview childTypeId: tgt5
        if (cOh5.get i: pi5) then {
            pov5: cOv5.get i: pi5
            ty.setChildOwnership parentTypeId: fid5 name: pnm5.stringview ownership: pov5
        }
        pi5 = pi5 + 1
    }
    rto5: 0.u64
    {
        tz5: reg.typeById.get key: tplFnId
        match (
            tz5
        ) case some then {
            ro5: tz5.returnTypeId
            match (
                ro5
            ) case some then {
                rto5 = ro5
            } case none then {}
        } case none then {}
    }
    if rto5 > 0 then {
        rt5: rto5
        if rto5 == tplClassId then rt5 = specId
        if rt5 == rto5 then {
            rtn5: regTypeNameOf :reg tid: rto5
            if rtn5.stringview == tplNm5.stringview then rt5 = specId
        }
        rdo5: idSubs.get key: rto5
        match (
            rdo5
        ) case some then {
            rt5 = rdo5
        } case none then {
            rr5: respecialize :ty :reg :mainName specTid: rto5 :idSubs
            if rr5 > 0 then rt5 = rr5
        }
        # a return still GENERIC_PARAM-typed (a partial the subs could not
        # complete -- multi-param chains mint with empty subs) stays unset;
        # the name-keyed fixup arms heal it after minting
        if (reg.typetypeOf typeId: rt5) != ztypes.ztypetype.GENERIC_PARAM then {
            reg.setReturnType typeId: fid5 value: rt5
        }
    }
    ty.setChild parentTypeId: specId childName: m childTypeId: fid5
}

# respecialize -- a type that is itself a specialization (nonempty genericArgs)
# re-specializes when any of its arguments is substituted: the origin template
# specializes again with the mapped argument list. 0 when nothing changes.
respecialize: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    specTid: u64
    idSubs: (Map u64 value: u64)
} out u64 is {
    an9: reg.genericArgCount specId: specTid
    if an9 == 0 then return 0
    origin9: 0.u64
    {
        zo9: reg.typeById.get key: specTid
        match (
            zo9
        ) case some then {
            og9: zo9.genericOriginId
            match (
                og9
            ) case some then {
                origin9 = og9
            } case none then {}
        } case none then {}
    }
    if origin9 == 0 then return 0
    changed9: false
    mapped9: (List u64)
    ai9: 0.u64
    for ai9 < an9 loop {
        av9: reg.genericArgAt specId: specTid ordinal: ai9
        if (reg.genericArgIsValueAt specId: specTid ordinal: ai9) then {
            # a numeric VALUE ordinal has nothing to substitute
            av9v: av9
            mapped9.append av9v
        } else {
            mo9: idSubs.get key: av9
            match (
                mo9
            ) case some then {
                mapped9.append mo9
                changed9 = true
            } case none then {
                # an arg that is itself a spec may carry substitutable args one
                # level down (OptionView over a MapEntry partial) -- recurse
                rec9: respecialize :ty :reg :mainName specTid: av9 :idSubs
                if rec9 > 0 then {
                    mapped9.append rec9
                    changed9 = true
                } else {
                    av9b: av9
                    mapped9.append av9b
                }
            }
        }
        ai9 = ai9 + 1
    }
    if changed9 == false then return 0
    tk9: genericTypeKey :ty :reg tid: origin9
    pn9: reg.genericParamNamesOf typeKey: tk9.stringview
    if pn9.length != an9 then return 0
    subs9: (Map String value: u64)
    rvSubs9: (Map String value: u64)
    sfx9: "".string
    on9: regTypeNameOf :reg tid: origin9
    mi9: 0.u64
    for mi9 < an9 loop {
        mp9: pn9.get i: mi9
        mv9: mapped9.get i: mi9
        sfx9.append s: "_"
        if (reg.genericArgIsValueAt specId: specTid ordinal: mi9) then {
            vk9: mp9.copy
            vv9r: mv9
            rvSubs9.set key: vk9 value: vv9r
            nvs9: "\{mv9}"
            sfx9.append s: nvs9.stringview
        } else {
            sk9: mp9.copy
            sv9: mv9
            subs9.set key: sk9 value: sv9
            vn9: monoValName :ty :reg tid: mv9
            sfx9.append s: vn9.stringview
        }
        mi9 = mi9 + 1
    }
    mn9: "\{on9}\{sfx9}"
    return (getOrMintSpec
        :ty
        :reg
        :mainName
        name: mn9.stringview
        templateId: origin9
        subs: subs9
        valSubs: rvSubs9
        fallbackArg: 0
    )
}

# mintMono -- register one generic-instance type (deduped by mono name): the
# template's typetype and valtype flag, genericOriginId linking back, and the
# instance's children -- the template's children with generic-param targets
# substituted (matched by arg name; fallbackArg substitutes every child, the
# single-type-param call-site inference) -- plus the synthesized members: a
# per-instance tag data type (variants and unions) and the autogen ==/!=
# functions (variants). Childless templates (the collection classes) produce
# no children; their cloned method children land with the class-mono slice.
mintMono: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    name: StringView
    templateId: u64
    subs: (Map String value: u64)
    idSubs: (Map u64 value: u64)
    fallbackArg: u64
} out u64 is {
    kn: name.string
    got: resolveSystemChild :ty :reg :name
    match (
        got
    ) case some then {
        return got
    } case none then {
    }
    tt: ztypes.ztypetype.RECORD
    vto: (optionval.none bool)
    tplNative: false
    {
        tpl: reg.typeById.get key: templateId
        match (
            tpl
        ) case some then {
            tt = tpl.typetype
            vto = tpl.isValtype
            tplNative = tpl.isNative
        } case none then {
        }
    }
    mid: reg.newType :name typetype: tt
    match (
        vto
    ) case some then {
        reg.setValtype typeId: mid value: vto
    } case none then {
    }
    reg.setGenericOrigin typeId: mid value: templateId
    reg.setNative typeId: mid value: tplNative
    if tt == ztypes.ztypetype.CLASS then reg.setIsHeapAllocated typeId: mid
    # Register under <unit>.<mangled> so name lookups (field/arm shells named
    # by the mangled form) resolve to the instance once minted.
    mcu9: reg.unitNameTid.get key: mainName.string
    match (
        mcu9
    ) case some then {
        ty.setChild parentTypeId: mcu9 childName: name childTypeId: mid
    } case none then {}
    # monos are global (defined_in_unit NULL): the system-keyed alias makes
    # them resolvable from every unit's lookup chain (a pending instantiation
    # staged while resolving io.z resolves nested args with mainName "io").
    mcu8: reg.unitNameTid.get key: "system".string
    match (
        mcu8
    ) case some then {
        ty.setChild parentTypeId: mcu8 childName: name childTypeId: mid
    } case none then {}
    # A heap-owning generic instance carries a destructor (so a holder/local
    # frees it; the emitter builds the cname). Collections own native heap;
    # Option/Result own a heap box. A user generic whose template already has a
    # destructor inherits one. Map/Set own native heap too (freed via a `&`-less
    # heap-pointer destroy). Views (ListView/OptionView) own no heap -- excluded.
    tplNmD: regTypeNameOf :reg tid: templateId
    needsDtorM: false
    if templateId == (builtinTidT :ty :reg base: "List") then needsDtorM = true
    if templateId == (builtinTidT :ty :reg base: "Option") then needsDtorM = true
    if templateId == (builtinTidT :ty :reg base: "Result") then needsDtorM = true
    if templateId == (builtinTidT :ty :reg base: "Map") then needsDtorM = true
    if templateId == (builtinTidT :ty :reg base: "Set") then needsDtorM = true
    if needsDtorM then {
        mdnM: "\{name}_destroy"
        reg.setDestructorName typeId: mid name: mdnM.stringview
    }
    # An elided leading type argument stages under the empty name; rebind it
    # to the template's primary generic parameter so the substituted children
    # resolve (`(List String)` == `(List of: String)`).
    {
        emptyKey: "".string
        ev: subs.get key: emptyKey
        match (
            ev
        ) case some then {
            prnm: firstGenericParamName :ty :reg :templateId
            if prnm.length > 0 then subs.set key: prnm value: ev
        } case none then {
        }
    }
    cNames: (List String)
    cIds: (List u64)
    {
        mmb9: ty.childIndex.get key: templateId
        match (
            mmb9
        ) case some then {
            with mmit9: mmb9.rows.iterate do for mmr9: mmit9 loop {
                tc: ty.typeChild.get i: mmr9
                cto: ty.childTypeById.get key: tc.childNameId
                match (
                    cto
                ) case some then {
                    cn: tc.childName.copy
                    cNames.append cn
                    cid2: cto
                    cIds.append cid2
                } case none then {
                }
            }
        } case none then {}
    }
    listTplT5: builtinTidT :ty :reg base: "List"
    monoNeedsDtor9: false
    ci: 0.u64
    cn3: cNames.length
    for ci < cn3 loop {
        chName: cNames.get i: ci
        chId: cIds.get i: ci
        target: chId
        ido9: idSubs.get key: chId
        match (
            ido9
        ) case some then {
            target = ido9
        } case none then {
            rsp9: respecialize :ty :reg :mainName specTid: chId :idSubs
            if rsp9 > 0 then target = rsp9
        }
        ctn: regTypeNameOf :reg tid: chId
        if target == chId then target = optU64Or o: (subs.get key: ctn) d: target
        # Generic FUNCTION children are clone candidates: the elided-arg
        # fallback must not swallow them (a method child's dotted name never
        # resolves, so the lookup-miss leg would replace the method with the
        # element type).
        chGen5: false
        if (reg.typetypeOf typeId: chId) == ztypes.ztypetype.FUNCTION then {
            cz5: reg.typeById.get key: chId
            match (
                cz5
            ) case some then {
                chGen5 = cz5.isgeneric
            } case none then {}
        }
        if fallbackArg > 0 when (ctn.stringview == "null") == false when target == chId when (chGen5) == false then {
            cko: walkLookupTyperef :ty :reg currentUnit: mainName base: ctn.stringview
            match (
                cko
            ) case some then {
            } case none then {
                target = fallbackArg
            }
        }
        deep5: false
        if target == chId when chGen5 then {
            isSynth5: false
            if chName.stringview == "create" then isSynth5 = true
            if chName.stringview == "borrow" then isSynth5 = true
            if chName.stringview == "==" then isSynth5 = true
            if chName.stringview == "!=" then isSynth5 = true
            if isSynth5 == false then {
                skip5: false
                # List's contains/sort exist only for eligible element
                # kinds (use-site parity with the materializer gate).
                if templateId == listTplT5 when listTplT5 > 0 then {
                    csM5: false
                    if chName.stringview == "contains" then csM5 = true
                    if chName.stringview == "sort" then csM5 = true
                    if csM5 then {
                        elemT5: optU64Or o: (subs.get key: ("of".string)) d: 0
                        if elemT5 == 0 then elemT5 = fallbackArg
                        ok5: false
                        if elemT5 > 0 then {
                            csel5: false
                            if chName.stringview == "contains" then {
                                csel5 = isContainsEligibleTid :ty :reg tid: elemT5
                            } else {
                                csel5 = isSortEligibleTid :ty :reg tid: elemT5
                            }
                            if csel5 then ok5 = true
                        }
                        if (ok5) == false then skip5 = true
                    }
                }
                if skip5 then {
                    deep5 = true
                } else {
                    (cloneMethodInto
                        :ty
                        :reg
                        :mainName
                        specName: name
                        specId: mid
                        tplClassId: templateId
                        m: chName.stringview
                        tplFnId: chId
                        :idSubs
                    )
                    deep5 = true
                }
            }
        }
        if deep5 == false then {
            ty.setChild parentTypeId: mid childName: chName.stringview childTypeId: target
        }
        if (reg.typetypeOf typeId: chId) != ztypes.ztypetype.FUNCTION then {
            if (ty.isChildLockField
                parentTypeId: templateId
                name: chName.stringview
            ) == false then {
                if (reg.hasDestructorName typeId: target) then monoNeedsDtor9 = true
            }
        }
        ci = ci + 1
    }
    # A user generic CLASS whose SUBSTITUTED fields are destructible carries
    # an auto-destructor, exactly like its non-generic counterpart (the
    # builtin-template list above cannot see through substitution; without
    # this, `class { val: t }` with t=String leaks its payload).
    if tt == ztypes.ztypetype.CLASS when monoNeedsDtor9 when (reg.hasDestructorName typeId: mid) == false then {
        mdnU9: "\{name}_destroy"
        reg.setDestructorName typeId: mid name: mdnU9.stringview
    }
    # RECORD instances: numeric-param fields synthesize from their declared
    # constraint (size: u64.generic -> a u64 child) when no field references
    # them; then the meta-create requalifies to the instance and ==/!=
    # synthesize -- except str/array, whose branches own those members
    # (their u64 `to` child comes from THIS synth; the branches add none).
    if tt == ztypes.ztypetype.RECORD then {
        tplNm9: regTypeNameOf :reg tid: templateId
        isSized9: false
        if templateId == (builtinTidT :ty :reg base: "str") then isSized9 = true
        if templateId == (builtinTidT :ty :reg base: "array") then isSized9 = true
        tk9: genericTypeKey :ty :reg tid: templateId
        pNames9: reg.genericParamNamesOf typeKey: tk9.stringview
        pi9: 0.u64
        pn0: pNames9.length
        for pi9 < pn0 loop {
            pname9: pNames9.get i: pi9
            cdx9: reg.genericParamConstraintOf typeKey: tk9.stringview paramName: pname9.stringview
            isNum9: true
            if cdx9.kind == ztypes.constraintkind.ANY then isNum9 = false
            if cdx9.kind == ztypes.constraintkind.NONE then isNum9 = false
            if isNum9 then {
                exo9: ty.childOf parentTypeId: mid name: pname9.stringview
                match (
                    exo9
                ) case some then {
                } case none then {
                    pcon9: constraintTextOf desc: cdx9
                    cno9: walkLookupTyperef :ty :reg currentUnit: mainName base: pcon9.stringview
                    match (
                        cno9
                    ) case some then {
                        ty.setChild parentTypeId: mid childName: pname9.stringview childTypeId: cno9
                    } case none then {
                    }
                }
            }
            pi9 = pi9 + 1
        }
        if (isSized9) == false then {
            crq9: "\{name}.create"
            crId9: reg.newType name: crq9.stringview typetype: ztypes.ztypetype.FUNCTION
            ty.setChild parentTypeId: mid childName: "create" childTypeId: crId9
            eqo9: ty.childOf parentTypeId: mid name: "=="
            match (
                eqo9
            ) case some then {
            } case none then {
                req9: "\{name}.=="
                reqId9: reg.newType name: req9.stringview typetype: ztypes.ztypetype.FUNCTION
                ty.setChild parentTypeId: mid childName: "==" childTypeId: reqId9
                rne9: "\{name}.!="
                rneId9: reg.newType name: rne9.stringview typetype: ztypes.ztypetype.FUNCTION
                ty.setChild parentTypeId: mid childName: "!=" childTypeId: rneId9
            }
        }
    }
    wantTag: false
    if tt == ztypes.ztypetype.VARIANT then wantTag = true
    if tt == ztypes.ztypetype.UNION then wantTag = true
    if wantTag then {
        tagName: "\{name}:tag:data"
        tagId: reg.newType name: tagName.stringview typetype: ztypes.ztypetype.DATA
        ty.setChild parentTypeId: mid childName: "tag" childTypeId: tagId
    }
    if tt == ztypes.ztypetype.VARIANT then {
        eqName: "\{name}.=="
        eqId: reg.newType name: eqName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: mid childName: "==" childTypeId: eqId
        neName: "\{name}.!="
        neId: reg.newType name: neName.stringview typetype: ztypes.ztypetype.FUNCTION
        ty.setChild parentTypeId: mid childName: "!=" childTypeId: neId
    }
    return mid
}

# isContainsEligibleTid / isSortEligibleTid -- element types List.contains /
# List.sort support (the hardcoded equality / ordering dispatch): numerics +
# bool + the String/StringView/str family; sort excludes bool (no ordering).
isContainsEligibleTid: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    tid: u64
} out bool is {
    if tid == (builtinTidT :ty :reg base: "bool") then return true
    return (isSortEligibleTid :ty :reg :tid)
}

isSortEligibleTid: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry tid: u64} out bool is {
    if tid == 0 then return false
    if (isNumericTid :ty :reg :tid) then return true
    if tid == (builtinTidT :ty :reg base: "String") then return true
    if tid == (builtinTidT :ty :reg base: "StringView") then return true
    if tid == (builtinTidT :ty :reg base: "str") then return true
    return false
}

# isStdlibUnitName / isUserShadowElem -- a collection element that is a USER type
# shadowing a builtin name (e.g. a user `String`) is NOT the native builtin, so it
# earns no builtin contains/sort (like any other user type). isUserShadowElem is true
# when the element is defined in a user file unit (not a stdlib unit, not a scalar).
isStdlibUnitName: function {name: StringView} out bool is {
    if name == "system" then return true
    if name == "core" then return true
    if name == "collections" then return true
    if name == "io" then return true
    if name == "os" then return true
    if name == "cli" then return true
    return false
}

isUserShadowElem: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    elemTid: u64
} out bool is {
    duo: ty.definedInUnit.get key: elemTid
    match (
        duo
    ) case some then {
        return (isStdlibUnitName name: duo.stringview) == false
    } case none then {
        return false
    }
}

# mintCollectionMethod -- one synthesized `{mono}.{m}` FUNCTION child; returns
# the method's type id so callers can link its return type.
mintCollectionMethod: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    monoName: StringView
    monoId: u64
    m: StringView
} out u64 is {
    fname: "\{monoName}.\{m}"
    fid: reg.newType name: fname.stringview typetype: ztypes.ztypetype.FUNCTION
    reg.setNative typeId: fid value: true
    ty.setChild parentTypeId: monoId childName: m childTypeId: fid
    return fid
}

# mapGetWrapperName -- the Map.get return-wrapper template by value kind:
# optionval for valtypes (copy-out), OptionView for reftypes incl. String (a
# borrowed, locked view into the map's storage; the caller `.copy`s to keep it).
mapGetWrapperName: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    valArg: u64
} out String is {
    isVal: false
    {
        vt: reg.typeById.get key: valArg
        match (
            vt
        ) case some then {
            vvo: vt.isValtype
            match (
                vvo
            ) case some then {
                if vvo then isVal = true
            } case none then {
            }
        } case none then {
        }
    }
    if isVal then return ("optionval".string)
    return ("OptionView".string)
}

# getOrMintSpec -- the id-keyed specialization tree front door: derive the
# definition-order argument keys from the name-keyed subs (fallbackArg fills a
# single missing parameter), walk the generic-child edges, and return the existing
# spec on a full-path hit. A parameter absent from subs with no fallback (a
# numeric value parameter -- str/array's `to`) skips the tree -- mintMono's
# name dedup still holds for those. On a miss the leaf materializes via mintMono; multi-level
# paths mint intermediate nodes (genericOriginId = template, genericArgs =
# the key prefix) that cache partial paths without being emitted.
# checkConstraintSat -- a specialization argument against its parameter's
# declared constraint. Any (and numeric bounds, which never reach the tree)
# pass; value-kind constraints check typeIsValtype/typeIsReftype; StringLike
# checks membership. GENERIC_PARAM args skip -- partial specs re-check on
# completion. Location-free (the spec front door holds no source node).
# constraintKindFor -- classify a constraint's declared text into a tag once,
# at registration; the checks then compare the tag, not the string.
constraintKindFor: function {text: StringView} out ztypes.constraintkind is {
    if text == "Any.valtype" then return ztypes.constraintkind.VALTYPE
    if text == "Any.reftype" then return ztypes.constraintkind.REFTYPE
    if text == "StringLike" then return ztypes.constraintkind.STRINGLIKE
    if text == "Any" then return ztypes.constraintkind.ANY
    if text.length == 0 then return ztypes.constraintkind.NONE
    nm9: constraintNumericMax cv: text
    match (
        nm9
    ) case some then {
        return ztypes.constraintkind.NUMERIC
    } case none then {
    }
    return ztypes.constraintkind.OTHER
}

# constraintNumericName -- the integer-scalar name for a numeric bound, for
# diagnostics; the exact inverse of constraintNumericMax.
constraintNumericName: function {max: u64} out String is {
    if max == 255 then return "u8".string
    if max == 65535 then return "u16".string
    if max == 4294967295 then return "u32".string
    if max == 18446744073709551615.u64 then return "u64".string
    if max == 127 then return "i8".string
    if max == 32767 then return "i16".string
    if max == 2147483647 then return "i32".string
    if max == 9223372036854775807 then return "i64".string
    return "".string
}

# constraintTextOf -- reconstruct a constraint's declared text from its tag
# for diagnostics; reads fields only, constructs nothing.
constraintTextOf: function {desc: ztypes.ConstraintDesc} out String is {
    if desc.kind == ztypes.constraintkind.VALTYPE then return "Any.valtype".string
    if desc.kind == ztypes.constraintkind.REFTYPE then return "Any.reftype".string
    if desc.kind == ztypes.constraintkind.STRINGLIKE then return "StringLike".string
    if desc.kind == ztypes.constraintkind.ANY then return "Any".string
    if desc.kind == ztypes.constraintkind.NUMERIC then {
        nmx7: desc.numericMax
        match (
            nmx7
        ) case some then {
            return (constraintNumericName max: nmx7)
        } case none then {
        }
    }
    return "".string
}

# constraintNumericMax -- the largest value an integer-scalar generic-param
# constraint admits; none when the constraint is not an integer scalar (a
# numeric argument on such a parameter stays on the name-keyed path).
constraintNumericMax: function {cv: StringView} out optionval u64 is {
    if cv == "u8" then return (optionval.some 255.u64)
    if cv == "u16" then return (optionval.some 65535.u64)
    if cv == "u32" then return (optionval.some 4294967295.u64)
    if cv == "u64" then return (optionval.some 18446744073709551615.u64)
    if cv == "i8" then return (optionval.some 127.u64)
    if cv == "i16" then return (optionval.some 32767.u64)
    if cv == "i32" then return (optionval.some 2147483647.u64)
    if cv == "i64" then return (optionval.some 9223372036854775807.u64)
    return (optionval.none u64)
}

checkConstraintSat: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    typeKey: StringView
    paramName: StringView
    argTid: u64
} is {
    if (reg.typetypeOf typeId: argTid) == ztypes.ztypetype.GENERIC_PARAM then return
    cd9: reg.genericParamConstraintOf :typeKey :paramName
    ck9: cd9.kind
    if ck9 == ztypes.constraintkind.NONE then return
    ok9: true
    if ck9 == ztypes.constraintkind.VALTYPE then ok9 = typeIsValtype :ty :reg tid: argTid
    if ck9 == ztypes.constraintkind.REFTYPE then {
        rz9: reg.typeById.get key: argTid
        rOk9: false
        match (
            rz9
        ) case some then {
            rv9: rz9.isValtype
            match (
                rv9
            ) case some then {
                rOk9 = rv9 == false
            } case none then {
            }
        } case none then {
        }
        ok9 = rOk9
    }
    if ck9 == ztypes.constraintkind.STRINGLIKE then {
        okSL9: false
        svT9: builtinTidT :ty :reg base: "StringView"
        if svT9 > 0 when argTid == svT9 then okSL9 = true
        if okSL9 == false then {
            # conformance rows live on the declaring type; a mono (str_32)
            # conforms through its generic origin (the str template)
            probeT9: argTid
            {
                ago9: reg.typeById.get key: argTid
                match (
                    ago9
                ) case some then {
                    agoo9: ago9.genericOriginId
                    match (
                        agoo9
                    ) case some then {
                        probeT9 = agoo9
                    } case none then {}
                } case none then {}
            }
            txT9: builtinTidT :ty :reg base: "Text"
            if txT9 > 0 then {
                with cit9: ty.conformance.iterate do for crow9: cit9 loop {
                    if crow9.specTypeId == txT9 then {
                        if crow9.implTypeId == argTid then okSL9 = true
                        if crow9.implTypeId == probeT9 then okSL9 = true
                    }
                }
            }
        }
        ok9 = okSL9
    }
    if (ok9) == false then {
        an9: regTypeNameOf :reg tid: argTid
        con9: constraintTextOf desc: cd9
        m9: "generic argument '\{an9}' does not satisfy constraint '\{con9}' on parameter '\{paramName}' of '\{typeKey}'"
        addResolveError :ty e: zast.err.GENERICERROR msg: m9
    }
}

# heapOwningValtypeTid -- a RECORD/VARIANT that transitively owns heap
# members (a class/union box, a destructor-carrying mono, or another owning
# valtype): its byte-range hash and equality cannot cover them.
heapOwningValtypeTid: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    tid: u64
} out bool is {
    tt9: reg.typetypeOf typeId: tid
    isVR9: false
    if tt9 == ztypes.ztypetype.RECORD then isVR9 = true
    if tt9 == ztypes.ztypetype.VARIANT then isVR9 = true
    if isVR9 == false then return false
    hrows9: (List u64)
    {
        hob9: ty.childIndex.get key: tid
        match (
            hob9
        ) case some then {
            with hoit9: hob9.rows.iterate do for hor9: hoit9 loop {
                hrv9: hor9
                hrows9.append hrv9
            }
        } case none then {}
    }
    hcn9: hrows9.length
    hci9: 0.u64
    for hci9 < hcn9 loop {
        hri9: hrows9.get i: hci9
        htc9: ty.typeChild.get i: hri9
        hci9 = hci9 + 1
        {
            hcto9: ty.childTypeById.get key: htc9.childNameId
            match (
                hcto9
            ) case some then {
                hctt9: reg.typetypeOf typeId: hcto9
                if hctt9 != ztypes.ztypetype.FUNCTION when htc9.childName.stringview != "tag" then {
                    if hctt9 == ztypes.ztypetype.CLASS then return true
                    if hctt9 == ztypes.ztypetype.UNION then return true
                    if (reg.hasDestructorName typeId: hcto9) then return true
                    if hctt9 == ztypes.ztypetype.RECORD then {
                        if (heapOwningValtypeTid :ty :reg tid: hcto9) then return true
                    }
                    if hctt9 == ztypes.ztypetype.VARIANT then {
                        if (heapOwningValtypeTid :ty :reg tid: hcto9) then return true
                    }
                }
            } case none then {}
        }
    }
    return false
}

getOrMintSpec: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    name: StringView
    templateId: u64
    subs: (Map String value: u64)
    valSubs: (Map String value: u64)
    fallbackArg: u64
} out u64 is {
    tk8: genericTypeKey :ty :reg tid: templateId
    pnames8: reg.genericParamNamesOf typeKey: tk8.stringview
    # An elided leading type argument stages under the empty name; rebind it
    # to the primary generic parameter before the trie keys and idSubs build
    # (mintMono's own rebind happens after both).
    {
        emptyKey8: "".string
        ev8: subs.get key: emptyKey8
        match (
            ev8
        ) case some then {
            prnm8: firstGenericParamName :ty :reg :templateId
            if prnm8.length > 0 then subs.set key: prnm8 value: ev8
        } case none then {
        }
        evv8: valSubs.get key: emptyKey8
        match (
            evv8
        ) case some then {
            prnmv8: firstGenericParamName :ty :reg :templateId
            if prnmv8.length > 0 then valSubs.set key: prnmv8 value: evv8
        } case none then {
        }
    }
    keys8: (List u64)
    keyIsVal8: (List bool)
    trieOk8: true
    if pnames8.length == 0 then trieOk8 = false
    with pit8: pnames8.iterate do for pn8: pit8 loop {
        pgot8: subs.get key: pn8.copy
        match (
            pgot8
        ) case some then {
            (checkConstraintSat
                :ty
                :reg
                typeKey: tk8.stringview
                paramName: pn8.stringview
                argTid: pgot8
            )
            keys8.append pgot8
            keyIsVal8.append false
        } case none then {
            vgot8: valSubs.get key: pn8.copy
            match (
                vgot8
            ) case some then {
                # a numeric literal keys its trie level by VALUE; per-level
                # kind is fixed by the parameter, so values and type ids
                # cannot collide
                cd8: reg.genericParamConstraintOf typeKey: tk8.stringview paramName: pn8.stringview
                nmx8: cd8.numericMax
                match (
                    nmx8
                ) case some then {
                    if vgot8 > nmx8 then {
                        cvn8: constraintTextOf desc: cd8
                        m8v: "numeric argument \{vgot8} exceeds constraint '\{cvn8}' on parameter '\{pn8}' of '\{tk8}'"
                        addResolveError :ty e: zast.err.GENERICERROR msg: m8v
                    }
                    keys8.append vgot8
                    keyIsVal8.append true
                } case none then {
                    trieOk8 = false
                }
            } case none then {
                if fallbackArg > 0 when pnames8.length == 1 then {
                    fb8: fallbackArg
                    keys8.append fb8
                    keyIsVal8.append false
                } else {
                    trieOk8 = false
                }
            }
        }
    }
    if trieOk8 when keys8.length > 0 then {
        # byte-range hash/equality cannot cover owned members: a heap-owning
        # valtype cannot key a Set/Map (classes hash by identity, String by
        # content -- both fine)
        hkSet9: builtinTidT :ty :reg base: "Set"
        hkMap9: builtinTidT :ty :reg base: "Map"
        hkKind9: "".string
        if hkSet9 > 0 when templateId == hkSet9 then hkKind9 = "Set element".string
        if hkMap9 > 0 when templateId == hkMap9 then hkKind9 = "Map key".string
        if hkKind9.length > 0 when (keyIsVal8.get i: 0) == false then {
            hkT9: keys8.get i: 0
            if (heapOwningValtypeTid :ty :reg tid: hkT9) then {
                hkN9: regTypeNameOf :reg tid: hkT9
                mHK9: "heap-owning value type '\{hkN9}' cannot be a \{hkKind9}"
                addResolveError :ty e: zast.err.GENERICERROR msg: mHK9
            }
        }
    }
    if trieOk8 then {
        cur8: templateId
        ki8: 0.u64
        kn8: keys8.length
        hit8: true
        for ki8 < kn8 loop {
            k8: keys8.get i: ki8
            n8: reg.getGenericChild parentId: cur8 key: k8
            match (
                n8
            ) case some then {
                cur8 = n8
            } case none then {
                hit8 = false
                ki8 = kn8
            }
            ki8 = ki8 + 1
        }
        if hit8 then return cur8
    }
    idSubs8: (Map u64 value: u64)
    if trieOk8 then {
        pi8: 0.u64
        pt8: pnames8.length
        for pi8 < pt8 loop {
            pnm8: pnames8.get i: pi8
            pto8: reg.genericParamTidOf typeKey: tk8.stringview paramName: pnm8.stringview
            match (
                pto8
            ) case some then {
                if (keyIsVal8.get i: pi8) == false then {
                    kv8: keys8.get i: pi8
                    pk8: pto8
                    idSubs8.set key: pk8 value: kv8
                }
            } case none then {}
            pi8 = pi8 + 1
        }
    }
    hasParamKey8: false
    if trieOk8 then {
        hk8: 0.u64
        hn8: keys8.length
        for hk8 < hn8 loop {
            if (keyIsVal8.get i: hk8) == false then {
                hv8: keys8.get i: hk8
                if (reg.typetypeOf typeId: hv8) == ztypes.ztypetype.GENERIC_PARAM then {
                    hasParamKey8 = true
                }
            }
            hk8 = hk8 + 1
        }
    }
    mid8: 0.u64
    if hasParamKey8 then {
        # a generic-param arg makes the spec PARTIAL: a trie-only entry that
        # is never emitted or name-registered; the clone-side respecialize
        # completes it with concrete args per instance.
        pnmP8: "\{name}__partial"
        mid8 = reg.newType name: pnmP8.stringview typetype: ztypes.ztypetype.GENERIC_PARAM
        reg.setGenericOrigin typeId: mid8 value: templateId
    } else {
        mid8 = mintMono :ty :reg :mainName :name :templateId :subs idSubs: idSubs8 :fallbackArg
    }
    if trieOk8 when mid8 > 0 then {
        cur9: templateId
        ki9: 0.u64
        kn9: keys8.length
        for ki9 < kn9 loop {
            k9: keys8.get i: ki9
            last9: false
            if ki9 + 1 == kn9 then last9 = true
            n9: reg.getGenericChild parentId: cur9 key: k9
            step9: 0.u64
            match (
                n9
            ) case some then {
                step9 = n9
            } case none then {
                if last9 then {
                    step9 = mid8
                } else {
                    inm9: "\{name}__node"
                    step9 = (reg.newType
                        name: inm9.stringview
                        typetype: ztypes.ztypetype.GENERIC_PARAM
                    )
                    kj9: 0.u64
                    for kj9 <= ki9 loop {
                        pk9: keys8.get i: kj9
                        if (keyIsVal8.get i: kj9) then {
                            reg.appendGenericArgValue specId: step9 value: pk9
                        } else {
                            reg.appendGenericArg specId: step9 arg: pk9
                        }
                        kj9 = kj9 + 1
                    }
                }
                reg.setGenericChild parentId: cur9 key: k9 child: step9
            }
            cur9 = step9
            ki9 = ki9 + 1
        }
        ka9: 0.u64
        for ka9 < kn9 loop {
            av9: keys8.get i: ka9
            if (keyIsVal8.get i: ka9) then {
                reg.appendGenericArgValue specId: mid8 value: av9
            } else {
                reg.appendGenericArg specId: mid8 arg: av9
            }
            ka9 = ka9 + 1
        }
    }
    okC3: trieOk8
    if hasParamKey8 then okC3 = false
    if mid8 == 0 then okC3 = false
    if okC3 then {
        # a trie-keyed concrete specialization mints its chain family and
        # collection children here with def-order args; name-keyed mints
        # (sized records, empty-subs chains) keep their caller-side
        # invocations, which carry the elem/val ids this path cannot derive
        tnC3: regTypeNameOf :reg tid: templateId
        tnl3: tnC3.length
        nmC3: name.string
        nml3: nmC3.length
        sfxC3: "".string
        if nml3 > tnl3 then {
            sfv3: (nmC3.substring from: tnl3 to: nml3)
            sfxC3 = sfv3.string
        }
        # elem = the first TYPE key (a sized record's leading value key is
        # not an element); val = the second key only when it is a type
        elemC3: 0.u64
        ei3: 0.u64
        en3: keys8.length
        for ei3 < en3 loop {
            if elemC3 == 0 then {
                if (keyIsVal8.get i: ei3) == false then elemC3 = keys8.get i: ei3
            }
            ei3 = ei3 + 1
        }
        valC3: 0.u64
        if keys8.length > 1 then {
            if (keyIsVal8.get i: 1) == false then valC3 = keys8.get i: 1
        }
        # MapItemIter's iterator element is the derived MapEntry spec (its
        # call's OptionView some-arm), not a trie key
        skipC3: false
        if templateId == (builtinTidT :ty :reg base: "MapItemIter") then {
            skipC3 = true
            micoC4: ty.childOf parentTypeId: mid8 name: "call"
            match (
                micoC4
            ) case some then {
                mizoC4: reg.typeById.get key: micoC4
                match (
                    mizoC4
                ) case some then {
                    mrtoC4: mizoC4.returnTypeId
                    match (
                        mrtoC4
                    ) case some then {
                        mieoC4: ty.childOf parentTypeId: mrtoC4 name: "some"
                        match (
                            mieoC4
                        ) case some then {
                            elemC3 = mieoC4
                            skipC3 = false
                        } case none then {}
                    } case none then {}
                } case none then {}
            } case none then {}
        }
        if skipC3 == false then {
            (mintCollectionChildren
                :ty
                :reg
                :mainName
                monoName: name
                monoId: mid8
                :templateId
                suffix: sfxC3.stringview
                elemArg: elemC3
                valArg: valC3
            )
        }
    }
    return mid8
}

# mintReturnWrapper -- mint a no-argument wrapper spec (empty subs/valSubs) and,
# on a hit, record it as targetId's return type. The element is fixed by
# fallbackArg (the get/remove collection wrappers).
mintReturnWrapper: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    targetId: u64
    name: StringView
    templateId: u64
    fallbackArg: u64
} out u64 is {
    weM: (Map String value: u64)
    vsM: (Map String value: u64)
    mid: getOrMintSpec :ty :reg :mainName :name :templateId subs: weM valSubs: vsM :fallbackArg
    if mid > 0 then reg.setReturnType typeId: targetId value: mid
    return mid
}

# mintCollectionChildren -- the per-instance collection children the
# produced templates cannot express: length/capacity u64 value children,
# the create child (except List and Map, which have their own create
# paths), the Map get/remove value-kind wrapper returns, MapEntry's
# key/value accessors, and the sized str/array member tables. Method
# signatures and composite returns come from the cloned template methods
# (healed by respecialize). No-op for other templates or when the
# instance already has children (re-mint dedup).
# monoValName -- the value-type name component of a get-wrapper mono name. A user
# type SHADOWING a builtin (its name also names a system type) appends its canonical
# id, so its wrapper mono is distinct from the system type's same-named wrapper (a
# user i64 -> "i64_7" vs system "i64"); otherwise the bare name (no churn for a
# non-shadow type). Without this the get-wrapper mono name (optionval_i64) collides
# under the shared system key and the shadow reuses the system instance (wrong `some`-arm type).
monoValName: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry tid: u64} out String is {
    tn: regTypeNameOf :reg :tid
    if (isUserShadowElem :ty :reg elemTid: tid) then {
        if (builtinTidT :ty :reg base: tn.stringview) > 0 then return ("\{tn}_\{tid}")
    }
    return tn
}

mintCollectionChildren: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    monoName: StringView
    monoId: u64
    templateId: u64
    suffix: StringView
    elemArg: u64
    valArg: u64
} is {
    listTid: builtinTidT :ty :reg base: "List"
    listViewTid: builtinTidT :ty :reg base: "ListView"
    setTid: builtinTidT :ty :reg base: "Set"
    mapTid: builtinTidT :ty :reg base: "Map"
    mapEntryTid: builtinTidT :ty :reg base: "MapEntry"
    strTid: builtinTidT :ty :reg base: "str"
    arrayTid: builtinTidT :ty :reg base: "array"
    listIterTid: builtinTidT :ty :reg base: "ListIter"
    setIterTid: builtinTidT :ty :reg base: "SetIter"
    mapKeyIterTid: builtinTidT :ty :reg base: "MapKeyIter"
    mapItemIterTid: builtinTidT :ty :reg base: "MapItemIter"
    isIter: false
    if templateId == listIterTid then isIter = true
    if templateId == setIterTid then isIter = true
    if templateId == mapKeyIterTid then isIter = true
    if templateId == mapItemIterTid then isIter = true
    isColl: isIter
    if templateId == listTid then isColl = true
    if templateId == listViewTid then isColl = true
    if templateId == setTid then isColl = true
    if templateId == mapTid then isColl = true
    if templateId == mapEntryTid then isColl = true
    if templateId == strTid then isColl = true
    if templateId == arrayTid then isColl = true
    if (isColl) == false then return
    # List children come from the produced template methods cloned per
    # instance (composite returns healed by respecialize); only the
    # length/capacity u64 children materialize here. Runs on every naming.
    if templateId == listTid then {
        u64L: 0.u64
        uoL: walkLookupTyperef :ty :reg currentUnit: mainName base: "u64"
        match (
            uoL
        ) case some then {
            u64L = uoL
        } case none then {
        }
        if u64L > 0 then {
            ty.setChild parentTypeId: monoId childName: "length" childTypeId: u64L
            ty.setChild parentTypeId: monoId childName: "capacity" childTypeId: u64L
        }
        return
    }
    # One build per instance: a spec can reach this arm from several mint
    # paths, and the str/array rebuild below would mint fresh member types
    # per invocation (their instances copy template children at mint time,
    # so childCount cannot signal "already built").
    bgot: ty.collectionChildrenBuilt.get key: monoId
    if (optBoolOr o: bgot d: false) then return
    bk0: monoId
    ty.collectionChildrenBuilt.set key: bk0 value: true
    u64id: (declareCanonicalType
        :ty
        :reg
        defUnit: "system"
        name: "u64"
        typetype: ztypes.ztypetype.RECORD
    )
    # ListView children come from the produced template method (get); the
    # length field (the canonical u64) and the create child materialize here,
    # once per mono (post-memo: this arm mints).
    if templateId == listViewTid then {
        ty.setChild parentTypeId: monoId childName: "length" childTypeId: u64id
        mintCollectionMethod :ty :reg :monoName :monoId m: "create"
        return
    }
    # Set children come from the produced template methods (returns healed
    # by respecialize); the length/capacity fields (the canonical u64) and
    # the create child materialize here, once per mono.
    if templateId == setTid then {
        ty.setChild parentTypeId: monoId childName: "length" childTypeId: u64id
        ty.setChild parentTypeId: monoId childName: "capacity" childTypeId: u64id
        mintCollectionMethod :ty :reg :monoName :monoId m: "create"
        return
    }
    # Iterator families: call is produced+cloned (its OptionView return
    # healed by respecialize); only the create child mints here, once per
    # mono.
    if isIter then {
        mintCollectionMethod :ty :reg :monoName :monoId m: "create"
        return
    }
    # Map children come from the produced template methods (iterator
    # returns healed by respecialize); the length/capacity fields and the
    # value-kind wrapper returns for get/remove (inexpressible in source:
    # optionval for a valtype, Option/OptionView otherwise) materialize
    # here, once per mono. Map has no create child (its construction path
    # is separate).
    if templateId == mapTid when valArg > 0 then {
        ty.setChild parentTypeId: monoId childName: "length" childTypeId: u64id
        ty.setChild parentTypeId: monoId childName: "capacity" childTypeId: u64id
        vnM: monoValName :ty :reg tid: valArg
        mgoM: ty.childOf parentTypeId: monoId name: "get"
        match (
            mgoM
        ) case some then {
            wtplM: mapGetWrapperName :ty :reg :valArg
            wtoM: walkLookupTyperef :ty :reg currentUnit: mainName base: wtplM.stringview
            match (
                wtoM
            ) case some then {
                wnM: "\{wtplM}_\{vnM}"
                (mintReturnWrapper
                    :ty
                    :reg
                    :mainName
                    targetId: mgoM
                    name: wnM.stringview
                    templateId: wtoM
                    fallbackArg: valArg
                )
            } case none then {
            }
        } case none then {
        }
        mrmoM: ty.childOf parentTypeId: monoId name: "remove"
        match (
            mrmoM
        ) case some then {
            rwtM: "Option".string
            if (typeIsValtype :ty :reg tid: valArg) then rwtM = "optionval".string
            rwtoM: walkLookupTyperef :ty :reg currentUnit: mainName base: rwtM.stringview
            match (
                rwtoM
            ) case some then {
                rwnM: "\{rwtM}_\{vnM}"
                (mintReturnWrapper
                    :ty
                    :reg
                    :mainName
                    targetId: mrmoM
                    name: rwnM.stringview
                    templateId: rwtoM
                    fallbackArg: valArg
                )
            } case none then {
            }
        } case none then {
        }
        return
    }
    isSized: false
    if templateId == strTid then isSized = true
    if templateId == arrayTid then isSized = true
    # str/array are PERMANENT materializer arms: sized RECORDs are keyed by
    # a numeric value parameter that rides the trie as a literal VALUE key
    # (genericArgIsValue marks the ordinal); it never enters idSubs, so
    # produce+clone has nothing to substitute. Their templates resolve from source (record
    # attachMethods runs regardless of genericity) and copy their children
    # at mint time; the branches below REPLACE the value-dependent members
    # in place (setChild keeps positions) -- fresh const-clone size fields,
    # element-typed get/set returns, String-returning string, and the ==/!=
    # that resolveRecord and mintMono both skip for sized records. The
    # emitter builds the structs from the z_str/z_array tmpls by name-parsed
    # size and reads only the == child's presence. The dedup guard below
    # applies only to the from-scratch families.
    if (isSized) == false then {
        if (ty.childCount parentTypeId: monoId) > 0 then return
    }
    boolid: 0.u64
    bo9: walkLookupTyperef :ty :reg currentUnit: mainName base: "bool"
    match (
        bo9
    ) case some then {
        boolid = bo9
    } case none then {
    }
    if templateId == mapEntryTid then {
        kyId: mintCollectionMethod :ty :reg :monoName :monoId m: "key"
        reg.setReturnType typeId: kyId value: elemArg
        vlId: mintCollectionMethod :ty :reg :monoName :monoId m: "value"
        if valArg > 0 then reg.setReturnType typeId: vlId value: valArg
        mintCollectionMethod :ty :reg :monoName :monoId m: "create"
    }
    if templateId == arrayTid then {
        agId: mintCollectionMethod :ty :reg :monoName :monoId m: "get"
        reg.setReturnType typeId: agId value: elemArg
        asId: mintCollectionMethod :ty :reg :monoName :monoId m: "set"
        reg.setReturnType typeId: asId value: elemArg
        ty.setChild parentTypeId: monoId childName: "length" childTypeId: u64id
        mintCollectionMethod :ty :reg :monoName :monoId m: "create"
        aeqId: mintCollectionMethod :ty :reg :monoName :monoId m: "=="
        reg.setReturnType typeId: aeqId value: boolid
        aneId: mintCollectionMethod :ty :reg :monoName :monoId m: "!="
        reg.setReturnType typeId: aneId value: boolid
    }
    if templateId == strTid then {
        ty.setChild parentTypeId: monoId childName: "length" childTypeId: u64id
        ty.setChild parentTypeId: monoId childName: "size" childTypeId: u64id
        tstId: mintCollectionMethod :ty :reg :monoName :monoId m: "string"
        sgo: walkLookupTyperef :ty :reg currentUnit: mainName base: "String"
        sgid: optU64Or o: sgo d: 0
        if sgid > 0 then reg.setReturnType typeId: tstId value: sgid
        mintCollectionMethod :ty :reg :monoName :monoId m: "create"
        teqId: mintCollectionMethod :ty :reg :monoName :monoId m: "=="
        reg.setReturnType typeId: teqId value: boolid
        tneId: mintCollectionMethod :ty :reg :monoName :monoId m: "!="
        reg.setReturnType typeId: tneId value: boolid
    }
}

# genericTypeKey -- "{defining-unit}.{name}" for the registry's generic-param
# set lookups.
genericTypeKey: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry tid: u64} out String is {
    tn: regTypeNameOf :reg :tid
    duo: ty.definedInUnit.get key: tid
    match (
        duo
    ) case some then {
        return ("\{duo}.\{tn}")
    } case none then {
    }
    return tn
}

# firstGenericParamName -- the primary (first-declared) generic parameter
# name of a template, or empty when it has none. Binds an elided leading type
# argument (`(List String)` == `(List of: String)`) to its parameter.
firstGenericParamName: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    templateId: u64
} out String is {
    tk: genericTypeKey :ty :reg tid: templateId
    names: reg.genericParamNamesOf typeKey: tk.stringview
    if names.length > 0 then {
        firstNm: names.get i: 0
        return firstNm.copy
    }
    return "".string
}

# inferGenericConstruction -- a generic class/record template called with
# field-bound value arguments: labels naming generic params resolve as
# explicit type args; other args walk as values and bind their field's
# param (literals materialise + restamp the bare node). The deduped
# instance mints with substituted fields plus a synthesized create.
# 0 when nothing infers.
inferGenericConstruction: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    call: zast.CallData
    tplId: u64
    reportMissing: bool
} out u64 is {
    tname: typeNameOf :st tid: tplId
    if tname.length == 0 then return 0
    tk: genericTypeKey ty: st.typing reg: st.reg tid: tplId
    # Stage the template's children, then keep the ones whose TYPE NAME is a
    # registered generic param (field shells carry the param name, not a
    # GENERIC_PARAM typetype).
    cNames3: (List String)
    cIds3: (List u64)
    {
        igb9: st.typing.childIndex.get key: tplId
        match (
            igb9
        ) case some then {
            with igit9: igb9.rows.iterate do for igr9: igit9 loop {
                tc: st.typing.typeChild.get i: igr9
                cto: st.typing.childTypeById.get key: tc.childNameId
                match (
                    cto
                ) case some then {
                    fnv: tc.childName.stringview
                    fn1: fnv.string
                    cNames3.append fn1
                    cid1: cto
                    cIds3.append cid1
                } case none then {
                }
            }
        } case none then {}
    }
    fNames: (List String)
    fParams: (List String)
    ci3: 0.u64
    cn3: cIds3.length
    for ci3 < cn3 loop {
        cid3: cIds3.get i: ci3
        pnm3: typeNameOf :st tid: cid3
        if (st.reg.isGenericParamOf typeKey: tk.stringview name: pnm3.stringview) then {
            nm3: cNames3.get i: ci3
            nv3: nm3.stringview
            n3: nv3.string
            fNames.append n3
            fParams.append pnm3
        }
        ci3 = ci3 + 1
    }
    sfx: "".string
    subs: (Map String value: u64)
    boundParams: (Set String)
    firstA: 0.u64
    primaryName: firstGenericParamName ty: st.typing reg: st.reg templateId: tplId
    # the value-arg walk below is a DRY RUN for type inference: bracket its
    # ownership effects (take overlays, borrow locks) so the real ctor walk
    # re-checks from a clean slate — an explicit `.take` arg otherwise
    # collides with its own inference pass.
    infMark9: st.entriesMark
    argIdx: 0.u64
    with aiter: call.arguments.iterate do for arg: aiter loop {
        match (
            arg
        ) case namedoperation then {
            pk: unitLabel o: arg.name
            # elided leading type arg: an unnamed first arg naming a type
            # binds the primary generic param (`(List String)`); a value
            # first arg (`(box 5)`) is left for value inference.
            if pk.length == 0 when argIdx == 0 then {
                anE: paramTypeBaseName op: arg.operation
                if (isNumericLiteralName name: anE.stringview) == false then {
                    teo: (walkLookupTyperef
                        ty: st.typing
                        reg: st.reg
                        currentUnit: unitName
                        base: anE.stringview
                    )
                    match (
                        teo
                    ) case some then {
                        if primaryName.length > 0 then pk = primaryName.copy
                    } case none then {
                    }
                }
            }
            isP: false
            if pk.length > 0 then {
                isP = st.reg.isGenericParamOf typeKey: tk.stringview name: pk.stringview
            }
            if isP then {
                an: paramTypeBaseName op: arg.operation
                if (isNumericLiteralName name: an.stringview) then {
                    sfx.append s: "_"
                    sfx.append s: an.stringview
                    boundParams.add item: pk.copy
                } else {
                    ao: (walkLookupTyperef
                        ty: st.typing
                        reg: st.reg
                        currentUnit: unitName
                        base: an.stringview
                    )
                    match (
                        ao
                    ) case some then {
                        atn: typeNameOf :st tid: ao
                        sfx.append s: "_"
                        sfx.append s: atn.stringview
                        pk2: pk.copy
                        pv2: ao
                        subs.set key: pk2 value: pv2
                        boundParams.add item: pk.copy
                        if firstA == 0 then firstA = ao
                    } case none then {
                    }
                }
            } else {
                vt0: checkValue :st :unitName :unitBody node: arg.operation
                gidx: 0.u64
                gfound: false
                fi: 0.u64
                fn2: fNames.length
                for fi < fn2 loop {
                    f0: fNames.get i: fi
                    if f0.stringview == pk.stringview then {
                        if (gfound) == false then {
                            gidx = fi
                            gfound = true
                        }
                    }
                    fi = fi + 1
                }
                if gfound when vt0 > 0 then {
                    mv0: materialiseLiteral :st :unitName t: vt0
                    if mv0 != vt0 then {
                        iid0: innermostNodeId n: arg.operation
                        if iid0 > 0 then {
                            setm0: mv0
                            st.typing.nodeType.set key: iid0.u64 value: setm0
                        }
                    }
                    gp0: fParams.get i: gidx
                    already: optU64Or o: (subs.get key: gp0) d: 0
                    if already <= 0 then {
                        vtn: typeNameOf :st tid: mv0
                        sfx.append s: "_"
                        sfx.append s: vtn.stringview
                        gpv0: gp0.stringview
                        gpc: gpv0.string
                        gpv: mv0
                        subs.set key: gpc value: gpv
                        boundParams.add item: gp0.copy
                        if firstA == 0 then firstA = mv0
                    }
                }
            }
        } else {
        }
        argIdx = argIdx + 1
    }
    st.truncateEntries marker: infMark9
    paramsM: st.reg.genericParamNamesOf typeKey: tk.stringview
    firstMissing: "".string
    pmi: 0.u64
    pmn: paramsM.length
    for pmi < pmn loop {
        pmName: paramsM.get i: pmi
        if (boundParams.has item: pmName.copy) == false then {
            if firstMissing.length == 0 then firstMissing = pmName.copy
        }
        pmi = pmi + 1
    }
    if firstMissing.length > 0 then {
        if reportMissing then {
            emn: "".string
            ehn: "".string
            if sfx.length == 0 then {
                mmsg: "cannot infer type arguments for generic type '\{tname}'"
                (addErrorH
                    :st
                    nodeid: call.nodeid
                    lineno: call.lineno
                    colno: call.colno
                    e: zast.err.GENERICERROR
                    msg: mmsg
                    note: emn
                    hint: ehn
                    width: 0
                )
            } else {
                fmc: firstMissing.copy
                mmsg2: "cannot infer generic parameter '\{fmc}' for '\{tname}'"
                (addErrorH
                    :st
                    nodeid: call.nodeid
                    lineno: call.lineno
                    colno: call.colno
                    e: zast.err.GENERICERROR
                    msg: mmsg2
                    note: emn
                    hint: ehn
                    width: 0
                )
            }
        }
        return 0
    }
    if sfx.length == 0 then return 0
    mname: "\{tname}\{sfx}"
    vsD9: (Map String value: u64)
    mid: (getOrMintSpec
        ty: st.typing
        reg: st.reg
        mainName: unitName
        name: mname.stringview
        templateId: tplId
        :subs
        valSubs: vsD9
        fallbackArg: 0
    )
    if mid == 0 then return 0
    cro: st.typing.childOf parentTypeId: mid name: "create"
    match (
        cro
    ) case some then {
    } case none then {
        crn: "\{mname}.create"
        crId: st.reg.newType name: crn.stringview typetype: ztypes.ztypetype.FUNCTION
        st.typing.setChild parentTypeId: mid childName: "create" childTypeId: crId
    }
    return mid
}

# genericTypeConstruction -- a generic TYPE template in callable position
# with type-name arguments constructs its mono in place (`(List of: String)`
# in value position): resolve each argument as a type, mint the deduped mono
# with its chains and children, and the call's
# value is the mono.
genericTypeConstruction: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    call: zast.CallData
    tplId: u64
} out u64 is {
    tname: typeNameOf :st tid: tplId
    if tname.length == 0 then return 0
    tk0: genericTypeKey ty: st.typing reg: st.reg tid: tplId
    sfx: "".string
    subs: (Map String value: u64)
    valSubs2: (Map String value: u64)
    numParamNames9: (List String)
    numParamVals9: (List String)
    firstA: 0.u64
    anyMiss: false
    primaryName: firstGenericParamName ty: st.typing reg: st.reg templateId: tplId
    argIdx: 0.u64
    aiter: call.arguments.iterate
    for arg: aiter loop {
        match (
            arg
        ) case namedoperation then {
            # only generic-param labels construct here; a value arg means
            # the field-bound inference leg owns the call.
            pk0: unitLabel o: arg.name
            # An elided leading type argument (`(List zvfs.ProviderBox)`) binds
            # the primary generic param: probe the unnamed first arg as a type
            # (atom via walkLookupTyperef, cross-unit dotted via dottedTyperefId).
            # Only a real type rebinds; a value first arg (`(box 5)`) keeps its
            # empty label so the field-bound inference leg owns the call.
            if pk0.length == 0 when argIdx == 0 then {
                if primaryName.length > 0 then {
                    anP: paramTypeBaseName op: arg.operation
                    pid0: 0.u64
                    if (isNumericLiteralName name: anP.stringview) == false then {
                        pao0: (walkLookupTyperef
                            ty: st.typing
                            reg: st.reg
                            currentUnit: unitName
                            base: anP.stringview
                        )
                        pid0 = optU64Or o: pao0 d: 0
                        if pid0 == 0 then pid0 = dottedTyperefId :st op: arg.operation
                    }
                    if pid0 > 0 then pk0 = primaryName.copy
                }
            }
            isP0: false
            if pk0.length > 0 then {
                isP0 = st.reg.isGenericParamOf typeKey: tk0.stringview name: pk0.stringview
            }
            if (isP0) == false then anyMiss = true
            an: paramTypeBaseName op: arg.operation
            if (anyMiss) == false then { if (isNumericLiteralName name: an.stringview) then {
                nsfx2: "\{sfx}_\{an}"
                sfx = nsfx2
                if pk0.length > 0 then {
                    npn0: pk0.copy
                    numParamNames9.append npn0
                    npv0: an.copy
                    numParamVals9.append npv0
                    pdv0: parseDecimalU64 text: an.stringview
                    match (
                        pdv0
                    ) case some then {
                        vgk0: pk0.copy
                        vgv0: pdv0
                        valSubs2.set key: vgk0 value: vgv0
                    } case none then {}
                }
            } else {
                ao: (walkLookupTyperef
                    ty: st.typing
                    reg: st.reg
                    currentUnit: unitName
                    base: an.stringview
                )
                aid: optU64Or o: ao d: 0
                if aid == 0 then aid = dottedTyperefId :st op: arg.operation
                if aid > 0 then {
                    atn: typeNameOf :st tid: aid
                    nsfx: "\{sfx}_\{atn}"
                    sfx = nsfx
                    if pk0.length > 0 then {
                        pv: aid
                        subs.set key: pk0.copy value: pv
                    }
                    if firstA == 0 then firstA = aid
                } else {
                    anyMiss = true
                }
            } }
        } else {}
        argIdx = argIdx + 1
    }
    if anyMiss then return 0
    if sfx.length == 0 then return 0
    mname: "\{tname}\{sfx}"
    mid: (getOrMintSpec
        ty: st.typing
        reg: st.reg
        mainName: unitName
        name: mname.stringview
        templateId: tplId
        :subs
        valSubs: valSubs2
        fallbackArg: firstA
    )
    if mid == 0 then return 0
    npi9: 0.u64
    npn9: numParamNames9.length
    for npi9 < npn9 loop {
        npName9: numParamNames9.get i: npi9
        npVal9: numParamVals9.get i: npi9
        (st.typing.setChildDefault
            parentTypeId: mid
            name: npName9.stringview
            default: npVal9.stringview
        )
        npi9 = npi9 + 1
    }
    isSized2: false
    if tname.stringview == "str" then isSized2 = true
    if tname.stringview == "array" then isSized2 = true
    if isSized2 then {
        (mintCollectionChildren
            ty: st.typing
            reg: st.reg
            mainName: unitName
            monoName: mname.stringview
            monoId: mid
            templateId: tplId
            suffix: sfx.stringview
            elemArg: firstA
            valArg: 0
        )
    }
    # Only a bare-atom callable restamps to the instance; a dotted callable
    # (the .str conversion form) leaves the path unstamped like the reference.
    gcb: bareAtomName n: call.callable
    gcal: nodeId n: call.callable
    if gcal > 0 when gcb.length > 0 then {
        setga: mid
        st.typing.nodeType.set key: gcal.u64 value: setga
    }
    setgt: mid
    st.typing.nodeType.set key: call.nodeid.u64 value: setgt
    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.CLASS_CREATE
    return mid
}

# validateGenericTypeArgs -- reject unknown / duplicate generic TYPE arguments
# at a settled construction site. A named arg matching neither a declared
# generic param nor a declared field (child) is an unknown type argument; a
# generic param supplied twice (e.g. an elided leading arg plus an explicit
# label) is a duplicate. Returns false when an error was emitted.
validateGenericTypeArgs: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    call: zast.CallData
    tplId: u64
    allowFrom: bool
} out bool is {
    tname: typeNameOf :st tid: tplId
    if tname.length == 0 then return true
    tk: genericTypeKey ty: st.typing reg: st.reg tid: tplId
    childNames: (List String)
    {
        vgb9: st.typing.childIndex.get key: tplId
        match (
            vgb9
        ) case some then {
            with vgit9: vgb9.rows.iterate do for vgr9: vgit9 loop {
                tc: st.typing.typeChild.get i: vgr9
                cn0: tc.childName.stringview
                cn1: cn0.string
                childNames.append cn1
            }
        } case none then {}
    }
    primaryName: firstGenericParamName ty: st.typing reg: st.reg templateId: tplId
    seen: (Set String)
    ok: true
    argIdx: 0.u64
    aiter: call.arguments.iterate
    for arg: aiter loop {
        match (
            arg
        ) case namedoperation then {
            pk: unitLabel o: arg.name
            if pk.length == 0 when argIdx == 0 then {
                if primaryName.length > 0 then {
                    anP: paramTypeBaseName op: arg.operation
                    pid0: 0.u64
                    if (isNumericLiteralName name: anP.stringview) == false then {
                        pao0: (walkLookupTyperef
                            ty: st.typing
                            reg: st.reg
                            currentUnit: unitName
                            base: anP.stringview
                        )
                        pid0 = optU64Or o: pao0 d: 0
                        if pid0 == 0 then pid0 = dottedTyperefId :st op: arg.operation
                    }
                    if pid0 > 0 then pk = primaryName.copy
                }
            }
            skipFrom: false
            if allowFrom when pk.stringview == "from" then skipFrom = true
            if pk.length > 0 when (skipFrom) == false then {
                isP: st.reg.isGenericParamOf typeKey: tk.stringview name: pk.stringview
                if isP then {
                    if (seen.has item: pk.copy) when (allowFrom) == false then {
                        pkc: pk.copy
                        m1: "duplicate type argument '\{pkc}'"
                        en1: "".string
                        eh1: "".string
                        (addErrorH
                            :st
                            nodeid: arg.nodeid
                            lineno: arg.lineno
                            colno: arg.colno
                            e: zast.err.GENERICERROR
                            msg: m1
                            note: en1
                            hint: eh1
                            width: pk.length.u32
                        )
                        ok = false
                    } else {
                        seen.add item: pk.copy
                    }
                } else {
                    isField: false
                    ci: 0.u64
                    cn: childNames.length
                    for ci < cn loop {
                        cnm: childNames.get i: ci
                        if cnm.stringview == pk.stringview then isField = true
                        ci = ci + 1
                    }
                    if (isField) == false then {
                        pkc2: pk.copy
                        m2: "unknown type argument '\{pkc2}' for generic type '\{tname}'"
                        plist: st.reg.genericParamNamesOf typeKey: tk.stringview
                        note2: "valid type parameters: ".string
                        pi: 0.u64
                        pn2: plist.length
                        for pi < pn2 loop {
                            if pi > 0 then note2.append s: ", "
                            pnm: plist.get i: pi
                            note2.append s: pnm.stringview
                            pi = pi + 1
                        }
                        eh2: "".string
                        (addErrorH
                            :st
                            nodeid: arg.nodeid
                            lineno: arg.lineno
                            colno: arg.colno
                            e: zast.err.GENERICERROR
                            msg: m2
                            note: note2
                            hint: eh2
                            width: pk.length.u32
                        )
                        ok = false
                    }
                }
            }
        } else {
        }
        argIdx = argIdx + 1
    }
    return ok
}

# methodReturnOf -- a method FUNCTION type's return type id: the synthesized
# returnTypeId link when set, else the AST method's recorded `out T` ref node
# (funcReturnNode) read through the post-demand stamp.
methodReturnOf: function {st: zenv.ZSymbolTable mid: u64} out optionval u64 is {
    rto: (optionval.none u64)
    {
        t: st.reg.typeById.get key: mid
        match (
            t
        ) case some then {
            rto = t.returnTypeId
        } case none then {
        }
    }
    match (
        rto
    ) case some then {
        return (optionval.some rto)
    } case none then {
    }
    rn: st.typing.funcReturnNode.get key: mid
    match (
        rn
    ) case some then {
        nt: st.typing.nodeType.get key: rn
        match (
            nt
        ) case some then {
            return (optionval.some nt)
        } case none then {
        }
    } case none then {
    }
    return (optionval.none u64)
}

# iterWrapperElem -- when a type is an Option / optionval / OptionView instance,
# its element (`some` child) type id.
iterWrapperElem: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    wid: u64
} out optionval u64 is {
    origin: 0.u64
    goo: (optionval.none u64)
    {
        t: st.reg.typeById.get key: wid
        match (
            t
        ) case some then {
            goo = t.genericOriginId
        } case none then {
        }
    }
    match (
        goo
    ) case some then {
        origin = goo
    } case none then {
    }
    if origin == 0 then return (optionval.none u64)
    isWrapper: false
    oo: walkLookupTyperef ty: st.typing reg: st.reg currentUnit: unitName base: "Option"
    match (
        oo
    ) case some then {
        if origin == oo then isWrapper = true
    } case none then {
    }
    vo: walkLookupTyperef ty: st.typing reg: st.reg currentUnit: unitName base: "optionval"
    match (
        vo
    ) case some then {
        if origin == vo then isWrapper = true
    } case none then {
    }
    wo: walkLookupTyperef ty: st.typing reg: st.reg currentUnit: unitName base: "OptionView"
    match (
        wo
    ) case some then {
        if origin == wo then isWrapper = true
    } case none then {
    }
    if isWrapper then return (st.typing.childOf parentTypeId: wid name: "some")
    return (optionval.none u64)
}

# isOptionViewMono -- true when a type is an OptionView instance (its per-
# iteration values are borrowed views, so the loop var binds BORROWED).
isOptionViewMono: function {st: zenv.ZSymbolTable unitName: StringView wid: u64} out bool is {
    origin: 0.u64
    goo: (optionval.none u64)
    {
        t: st.reg.typeById.get key: wid
        match (
            t
        ) case some then {
            goo = t.genericOriginId
        } case none then {
        }
    }
    match (
        goo
    ) case some then {
        origin = goo
    } case none then {
    }
    if origin == 0 then return false
    wo: walkLookupTyperef ty: st.typing reg: st.reg currentUnit: unitName base: "OptionView"
    match (
        wo
    ) case some then {
        return origin == wo
    } case none then {
        return false
    }
}

# methodHasNoUserArgs -- true when a method type has no user-visible parameters
# beyond the implicit receiver: no children at all (synthesized collection
# methods), or a single child that IS the receiver -- `this`, or the long-form
# receiver recorded in thisParamName (`stringview: function {t: this.lock}`).
# optStrIsSome -- whether an optional string is present.
optStrIsSome: function {o: Option String} out bool is {
    match (
        o
    ) case some then {
        return true
    } case none then {
        return false
    }
}

optStrEquals: function {o: Option String s: StringView} out bool is {
    match (
        o
    ) case some then {
        return o.stringview == s
    } case none then {
        return false
    }
}

# optStrOrEmpty -- copy of the option's payload, or "" when none.
optStrOrEmpty: function {o: Option String} out String is {
    match (
        o
    ) case some then {
        return (o.copy)
    } case none then {
        return ("".string)
    }
}

# optU64Or / optBoolOr -- the option's payload, or the given default. Collapse
# the some/none match at get-or-default sites (match narrowing needs a
# bare-name subject, so inline gets can't match directly).
optU64Or: function {o: optionval u64 d: u64} out u64 is {
    match (
        o
    ) case some then {
        return o
    } case none then {
        return d
    }
}

optBoolOr: function {o: optionval bool d: bool} out bool is {
    match (
        o
    ) case some then {
        return o
    } case none then {
        return d
    }
}

# createDottedBaseId -- the base atom's node id when a dotted path's child is
# `create` (explicit construction: `T.create` is bare-name construction).
createDottedBaseId: function {n: Node} out optionval u32 is {
    match (
        n
    ) case dottedpath then {
        ccn: atomName n: n.child
        if ccn.stringview == "create" then return (optionval.some (nodeId n: n.parent))
    } else {
    }
    return (optionval.none u32)
}

# rootNameOf -- a value path's root atom name (unwrapping expressions and
# dotted segments), or "".
rootNameOf: function {n: Node} out String is {
    match (
        n
    ) case atomid then {
        return n.name.copy
    } case expression then {
        return (rootNameOf n: n.expression)
    } case dottedpath then {
        return (rootNameOf n: n.parent)
    } else {
        return "".string
    }
}

# dottedChildName -- a dotted path's child atom name, or "".
dottedChildName: function {n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        return (atomName n: n.child)
    } else {
        return "".string
    }
}

# unionCreateArmName -- the constructed arm's name when a value is a tagged
# subtype construction (a UNION_CREATE-stamped call's dotted child), or "".
unionCreateArmName: function {st: zenv.ZSymbolTable n: Node} out String is {
    match (
        n
    ) case expression then {
        return (unionCreateArmName :st n: n.expression)
    } case dottedpath then {
        dgot: st.typing.dpTaggedParent.get key: n.nodeid.u64
        match (
            dgot
        ) case some then {
            return (atomName n: n.child)
        } case none then {
            return "".string
        }
    } case call then {
        kOpt: st.typing.callKind.get key: n.nodeid.u64
        isUC: false
        match (
            kOpt
        ) case some then {
            if kOpt == zast.callkind.UNION_CREATE then isUC = true
        } case none then {}
        if isUC then return (dottedChildName n: n.callable)
        return "".string
    } else {
        return "".string
    }
}

# borrowDottedBaseId -- the base atom's node id when a dotted path's child is
# `borrow` (a protocol/facet borrow projection), or none.
borrowDottedBaseId: function {n: Node} out optionval u32 is {
    match (
        n
    ) case dottedpath then {
        bcn: atomName n: n.child
        if bcn.stringview == "borrow" then return (optionval.some (nodeId n: n.parent))
    } else {
    }
    return (optionval.none u32)
}

# valueNoCoerce -- checkValue minus the value-position auto-call coercion
# (construction arguments take method REFERENCES for function-typed fields).
valueNoCoerce: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    n: Node
} out u64 is {
    match (
        n
    ) case expression then {
        ev: valueNoCoerce :st :unitName :unitBody n: n.expression
        if ev > 0 then {
            sete: ev
            st.typing.nodeType.set key: n.nodeid.u64 value: sete
        }
        return ev
    } case dottedpath then {
        return (checkDotted :st :unitName :unitBody dp: n coerce: false)
    } else {
        return (checkValue :st :unitName :unitBody node: n)
    }
}

# checkProjectionCreate -- `F.create from: expr` / `P.borrow from: expr` on a
# facet or protocol: a projection, not a call. No CALL scope; the from-argument
# walks in the current scope (a facet copies its source -- nothing is consumed);
# the value is the facet/protocol type.
checkProjectionCreate: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    call: zast.CallData
    pjId: u64
    consumes: bool
    borrows: bool
} out u64 is {
    found: false
    aiter: call.arguments.iterate
    for arg: aiter loop {
        match (
            arg
        ) case namedoperation then {
            if (found) == false then {
                an: unitLabel o: arg.name
                isFrom: false
                if an.length == 0 then {
                    isFrom = true
                } else {
                    if an.stringview == "from" then isFrom = true
                }
                if isFrom then {
                    found = true
                    pvt: checkValue :st :unitName :unitBody node: arg.operation
                    if pvt > 0 then {
                        if borrows then {
                            # The from-path's root is the borrow origin (a
                            # bare name or a `.lock`/`.borrow` projection) --
                            # the projection borrows, it never hoists.
                            pbr: rootNameOf n: arg.operation
                            if pbr.length > 0 then {
                                pbv2: st.lookupVarId name: pbr.stringview
                                match (
                                    pbv2
                                ) case some then {
                                    drainPendingBorrow :st
                                    pbc2: pbr.copy
                                    st.typing.pendingBorrowPath.append pbc2
                                } case none then {}
                            }
                        } else {
                            if (argIsTrivial op: arg.operation) then {
                                pbn: bareAtomName n: arg.operation
                                if pbn.length > 0 then {
                                    pbv: st.lookupVarId name: pbn.stringview
                                    match (
                                        pbv
                                    ) case some then {
                                        if consumes then {
                                            (st.invalidate
                                                name: pbn.stringview
                                                loc: (optionval.none ztypes.zsrcpos)
                                            )
                                        }
                                    } case none then {}
                                }
                            } else {
                                tnm3: (hoistArg
                                    :st
                                    argNode: arg.operation
                                    argType: pvt
                                    paramType: 0
                                    :consumes
                                )
                            }
                        }
                    }
                }
            }
        } else {}
    }
    setpj: pjId
    st.typing.nodeType.set key: call.nodeid.u64 value: setpj
    pjk9: zast.callkind.PROTOCOL_CREATE
    if (st.reg.typetypeOf typeId: pjId) == ztypes.ztypetype.FACET then {
        if borrows then {
            pjk9 = zast.callkind.FACET_BORROW
        } else {
            pjk9 = zast.callkind.FACET_CREATE
        }
    } else {
        if borrows then pjk9 = zast.callkind.PROTOCOL_BORROW
    }
    st.typing.callKind.set key: call.nodeid.u64 value: pjk9
    return pjId
}

# metaCreateBaseId -- the base atom's node id when a callable is the dotted
# `meta.create` (the enclosing type's raw allocator), or none.
metaCreateBaseId: function {n: Node} out optionval u32 is {
    match (
        n
    ) case dottedpath then {
        pn: atomName n: n.parent
        cn2: atomName n: n.child
        if pn.stringview == "meta" when cn2.stringview == "create" then {
            return (optionval.some (nodeId n: n.parent))
        }
    } else {
    }
    return (optionval.none u32)
}

# typedefBaseOf -- a typedef type's base type id (the recorded base name,
# resolved at read time -- the resolver runs before the base's unit), or 0.
typedefBaseOf: function {st: zenv.ZSymbolTable unitName: StringView tid: u64} out u64 is {
    bo: st.typing.typedefBaseName.get key: tid
    match (
        bo
    ) case some then {
        return (optU64Or
            o: (walkLookupTyperef
                ty: st.typing
                reg: st.reg
                currentUnit: unitName
                base: bo.stringview
            )
            d: 0
        )
    } case none then {
        return 0
    }
}

# typedefBaseMangledOf -- a typedef type's base INSTANCE id (the recorded
# mangled name resolved at read time -- monos register in resolved once
# minted), or 0.
typedefBaseMangledOf: function {st: zenv.ZSymbolTable unitName: StringView tid: u64} out u64 is {
    bo: st.typing.typedefBaseMangled.get key: tid
    match (
        bo
    ) case some then {
        return (optU64Or
            o: (walkLookupTyperef
                ty: st.typing
                reg: st.reg
                currentUnit: unitName
                base: bo.stringview
            )
            d: 0
        )
    } case none then {
        return 0
    }
}

# checkTypedefCreate -- `T.create from: expr` / bare `T expr` on a typedef:
# an owned cast, not a call. No CALL scope; the from-argument walks in the
# current scope (a non-trivial one hoists there) and is consumed; the value
# is the typedef type.
checkTypedefCreate: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    call: zast.CallData
    tdId: u64
} out u64 is {
    found: false
    aiter: call.arguments.iterate
    for arg: aiter loop {
        match (
            arg
        ) case namedoperation then {
            if (found) == false then {
                an: unitLabel o: arg.name
                isFrom: false
                if an.length == 0 then {
                    isFrom = true
                } else {
                    if an.stringview == "from" then isFrom = true
                }
                if isFrom then {
                    found = true
                    vt: checkValue :st :unitName :unitBody node: arg.operation
                    if vt > 0 then {
                        if (argIsTrivial op: arg.operation) then {
                            bn: bareAtomName n: arg.operation
                            if bn.length > 0 then {
                                bvo: st.lookupVarId name: bn.stringview
                                match (
                                    bvo
                                ) case some then {
                                    (st.invalidate
                                        name: bn.stringview
                                        loc: (optionval.none ztypes.zsrcpos)
                                    )
                                } case none then {}
                            }
                        } else {
                            tnm: (hoistArg
                                :st
                                argNode: arg.operation
                                argType: vt
                                paramType: 0
                                consumes: true
                            )
                        }
                    }
                }
            }
        } else {}
    }
    settd: tdId
    st.typing.nodeType.set key: call.nodeid.u64 value: settd
    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.TYPEDEF_CREATE
    return tdId
}

# checkTypedefBorrow -- `T.borrow from: expr` on a typedef: a borrowed
# cast. No CALL scope, no take; the from-argument walks in the current
# scope and the binding borrows the argument's source (the lifted view
# origin when the argument is itself a borrowed view, else the
# argument's own path).
checkTypedefBorrow: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    call: zast.CallData
    tdId: u64
} out u64 is {
    found: false
    aiter: call.arguments.iterate
    for arg: aiter loop {
        match (
            arg
        ) case namedoperation then {
            if (found) == false then {
                an: unitLabel o: arg.name
                isFrom: false
                if an.length == 0 then {
                    isFrom = true
                } else {
                    if an.stringview == "from" then isFrom = true
                }
                if isFrom then {
                    found = true
                    vt: checkValue :st :unitName :unitBody node: arg.operation
                    if vt > 0 then {
                        if st.typing.pendingBorrowPath.length <= 0 then {
                            tup: (List String)
                            appendValueTuple n: arg.operation dst: tup
                            ti: 0.u64
                            tn: tup.length
                            for ti < tn loop {
                                te: tup.get i: ti
                                tec: te.copy
                                st.typing.pendingBorrowPath.append tec
                                ti = ti + 1
                            }
                        }
                    }
                }
            }
        } else {}
    }
    settd: tdId
    st.typing.nodeType.set key: call.nodeid.u64 value: settd
    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.TYPEDEF_BORROW
    return tdId
}

# methodHasThisReceiver -- a FUNCTION child bound to a receiver: a declared
# `this` param (shorthand) or a recorded long-form receiver name. A this-less
# function member is a callable field, not a method.
methodHasThisReceiver: function {st: zenv.ZSymbolTable mid: u64} out bool is {
    if (st.typing.hasChild parentTypeId: mid name: "this") then return true
    zo: st.reg.typeById.get key: mid
    match (
        zo
    ) case some then {
        return (optStrIsSome o: zo.thisParamName)
    } case none then {
        return false
    }
}

methodHasNoUserArgs: function {st: zenv.ZSymbolTable mid: u64} out bool is {
    cnt: st.typing.childCount parentTypeId: mid
    if cnt == 0 then return true
    if cnt != 1 then return false
    soleName: "".string
    bm9: st.typing.childIndex.get key: mid
    match (
        bm9
    ) case some then {
        with rmit9: bm9.rows.iterate do for rmi9: rmit9 loop {
            tc: st.typing.typeChild.get i: rmi9
            soleName = tc.childName.copy
        }
    } case none then {}
    if soleName.stringview == "this" then return true
    zo: st.reg.typeById.get key: mid
    match (
        zo
    ) case some then {
        return (optStrEquals o: zo.thisParamName s: soleName.stringview)
    } case none then {
        return false
    }
}

# canonicalChildBase -- a cross-unit narrowed match-arm base can be a shell id
# (distinct from the canonical defining-unit id) whose member children are not
# registered. Find a same-named type in any unit's resolved scope that has the
# named member; 0 when none. Mirrors the emitter's resolveTypeIdByName scan.
canonicalChildBase: function {st: zenv.ZSymbolTable bt: u64 child: StringView} out u64 is {
    nm: typeNameOf :st tid: bt
    if nm.length == 0 then return 0
    cands9: (List u64)
    with uit: st.reg.unitNameTid.iterateItems do for ue: uit loop {
        k: "\{ue.key}.\{nm}"
        ro9: resolvedByKey ty: st.typing reg: st.reg key: k
        match (
            ro9
        ) case some then {
            if ro9 != bt then cands9.append ro9
        } case none then {}
    }
    found: 0.u64
    ci9: 0.u64
    cnn9: cands9.length
    for ci9 < cnn9 loop {
        if found == 0 then {
            cand9: cands9.get i: ci9
            rc9: st.typing.childOf parentTypeId: cand9 name: child
            match (
                rc9
            ) case some then {
                found = cand9
            } case none then {}
        }
        ci9 = ci9 + 1
    }
    return found
}

# markDataRuntimeIndexed -- a data block accessed via `.index` / `.array` needs
# its static array emitted; label accesses fold to constants and don't.
markDataRuntimeIndexed: function {st: zenv.ZSymbolTable tid: u64} is {
    to9: st.reg.typeById.get key: tid
    match (
        to9
    ) case some then {
        to9.runtimeIndexed = true
    } case none then {}
}

# checkDotted -- a dotted method reference in a body: type the base, look the
# member up on the base's type, and stamp the dotted node -- with the method's
# return when the method takes no user parameters beyond the receiver (the
# auto-call coercion), else with the method FUNCTION type itself.
checkDotted: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    dp: zast.DottedPathData
    coerce: bool
} out u64 is {
    # Numeric dotted suffix (`1.u8`): when the child names a non-function
    # type, the path is a typed-literal cast -- the parent atom coerces to
    # the suffix type and the path carries it.
    castBase: atomName n: dp.parent
    if (isNumericLiteralName name: castBase.stringview) then {
        castChild: atomName n: dp.child
        castOpt: (walkLookupTyperef
            ty: st.typing
            reg: st.reg
            currentUnit: unitName
            base: castChild.stringview
        )
        match (
            castOpt
        ) case some then {
            if (st.reg.typetypeOf typeId: castOpt) != ztypes.ztypetype.FUNCTION then {
                castPid: nodeId n: dp.parent
                setcp: castOpt
                st.typing.nodeType.set key: castPid.u64 value: setcp
                setcd: castOpt
                st.typing.nodeType.set key: dp.nodeid.u64 value: setcd
                return castOpt
            }
        } case none then {
        }
    }
    bt: checkValue :st :unitName :unitBody node: dp.parent
    if bt == 0 then {
        # an unresolved bare-name base may be a unit-qualified member
        # path (io.stdout): the side map types the base as the UNIT type.
        ubn: atomName n: dp.parent
        if ubn.length > 0 then {
            ubo: st.reg.unitNameTid.get key: ubn
            match (
                ubo
            ) case some then {
                bt = ubo
                ubp: nodeId n: dp.parent
                if ubp > 0 then {
                    setub: ubo
                    st.typing.nodeType.set key: ubp.u64 value: setub
                }
            } case none then {
            }
        }
        if bt == 0 then return 0
    }
    # A literal base materialises before member lookup (`5.iterate` is
    # i64.iterate); the parent node restamps at the concrete default.
    if (isLiteralTypeId :st tid: bt) then {
        mbt9: materialiseLiteral :st :unitName t: bt
        if mbt9 != bt then {
            bt = mbt9
            pid9: nodeId n: dp.parent
            if pid9 > 0 then {
                setp9: mbt9
                st.typing.nodeType.set key: pid9.u64 value: setp9
            }
        }
    }
    cn: atomName n: dp.child
    if cn.length == 0 then return 0
    # `.private` / `.public` access markers: the path carries the base's
    # type (the access view is a dump-filtered shell, not a member).
    if cn.stringview == "private" then {
        setpv: bt
        st.typing.nodeType.set key: dp.nodeid.u64 value: setpv
        return bt
    }
    if cn.stringview == "public" then {
        setpb: bt
        st.typing.nodeType.set key: dp.nodeid.u64 value: setpb
        return bt
    }
    if cn.stringview == "lock" then {
        setlk: bt
        st.typing.nodeType.set key: dp.nodeid.u64 value: setlk
        return bt
    }
    # A `.string`/`.stringview` conversion is legal only when it changes the
    # type: String.stringview projects a view, StringView.string owns a copy.
    # The same-type forms are rejected -- `.string` on a String hides a fresh
    # copy (spell it `.copy`), `.stringview` on a StringView is an identity
    # no-op. A StringView base keeps the member path below for `.string`
    # (a real native converting view -> owned String).
    if cn.stringview == "string" then {
        if bt == (builtinTidTc :st base: "String") then {
            mss9: "redundant conversion: '.string' on a String".string
            nss9: "the value is already an owned String; '.string' would hide a fresh copy".string
            hss9: "use '.copy' for an owned duplicate, or drop '.string'".string
            (addErrorH
                :st
                nodeid: dp.nodeid
                lineno: dp.lineno
                colno: dp.colno
                e: zast.err.TYPEERROR
                msg: mss9
                note: nss9
                hint: hss9
                width: cn.length.u32
            )
            return 0
        }
    }
    if cn.stringview == "stringview" then {
        if bt == (builtinTidTc :st base: "StringView") then {
            msv9: "redundant conversion: '.stringview' on a StringView".string
            nsv9: "the value is already a StringView".string
            hsv9: "drop '.stringview'".string
            (addErrorH
                :st
                nodeid: dp.nodeid
                lineno: dp.lineno
                colno: dp.colno
                e: zast.err.TYPEERROR
                msg: msv9
                note: nsv9
                hint: hsv9
                width: cn.length.u32
            )
            return 0
        }
    }
    # `.str` on String/StringView/str bases is the sized-conversion form:
    # the path resolves to the str TEMPLATE (unstamped -- the call check
    # mints the sized instance and stamps only the Call node).
    if cn.stringview == "str" then {
        isStrBase: false
        if bt == (builtinTidTc :st base: "String") then isStrBase = true
        if bt == (builtinTidTc :st base: "StringView") then isStrBase = true
        if (isStrBase) == false then {
            bga9: 0.u64
            {
                bz9: st.reg.typeById.get key: bt
                match (
                    bz9
                ) case some then {
                    bgo9: bz9.genericOriginId
                    match (
                        bgo9
                    ) case some then {
                        bga9 = bgo9
                    } case none then {
                    }
                } case none then {
                }
            }
            if bga9 > 0 then {
                if bga9 == (builtinTidTc :st base: "str") then isStrBase = true
            }
        }
        if isStrBase then {
            sto9: walkLookupTyperef ty: st.typing reg: st.reg currentUnit: unitName base: "str"
            match (
                sto9
            ) case some then {
                return sto9
            } case none then {
            }
        }
    }
    if cn.stringview == "borrow" then {
        # Protocol/facet `.borrow` and a typedef wrapper's FUNCTION borrow
        # child are projection callables, not ownership markers.
        btt1: st.reg.typetypeOf typeId: bt
        isMk: true
        if btt1 == ztypes.ztypetype.PROTOCOL then isMk = false
        if btt1 == ztypes.ztypetype.FACET then isMk = false
        if isMk then {
            bco: st.typing.childOf parentTypeId: bt name: "borrow"
            bcid: optU64Or o: bco d: 0
            if bcid > 0 then {
                if (st.reg.typetypeOf typeId: bcid) == ztypes.ztypetype.FUNCTION then isMk = false
            }
        }
        if isMk then {
            setbw: bt
            st.typing.nodeType.set key: dp.nodeid.u64 value: setbw
            return bt
        }
    }
    # `.take` / `.release`: ownership transfer markers, not members. The path
    # carries the base's type; a bare-name source releases its held locks and
    # invalidates (the taken overlay propagates out of popped scopes).
    isXferMarker: false
    if cn.stringview == "take" then isXferMarker = true
    if cn.stringview == "release" then isXferMarker = true
    if isXferMarker then {
        mkRoot: bareAtomName n: dp.parent
        if cn.stringview == "release" when mkRoot.length == 0 then {
            mrv9: "'.release' can only be applied to a variable name".string
            (addError
                :st
                nodeid: dp.nodeid
                lineno: dp.lineno
                colno: dp.colno
                e: zast.err.OWNERERROR
                msg: mrv9
            )
        }
        if mkRoot.length > 0 then {
            mvo: st.lookupVarId name: mkRoot.stringview
            match (
                mvo
            ) case some then {
                relBlocked9: false
                if cn.stringview == "take" then {
                    if (isViewVar :st vid: mvo) then {
                        relBlocked9 = true
                        tbr9: mkRoot.copy
                        mtb9: "Cannot move borrowed variable '\{tbr9}' with '.take' — borrowed names stay bound to their source for the full scope; copy with '.copy' to keep the source"
                        (addError
                            :st
                            nodeid: dp.nodeid
                            lineno: dp.lineno
                            colno: dp.colno
                            e: zast.err.OWNERERROR
                            msg: mtb9
                        )
                    }
                }
                if cn.stringview == "release" then {
                    rpath9: (List String)
                    mrkc9: mkRoot.copy
                    rpath9.append mrkc9
                    elh9: st.findExclusiveLock path: rpath9
                    match (
                        elh9
                    ) case some then {
                        relBlocked9 = true
                        ahn9: st.formatLockHolder elh9
                        mra9: mkRoot.copy
                        macc9: "Cannot access: '\{mra9}' has exclusive lock held by '\{ahn9}'"
                        ahint9: "".string
                        if elh9.kind == ztypes.zlockholderkind.VAR then {
                            ahnc9: ahn9.copy
                            ahint9 = "read through '\{ahnc9}' instead, or end '\{ahnc9}'s scope first to release the lock"
                        }
                        aen9: "".string
                        aid9: nodeId n: dp.parent
                        aln9: nodeLine n: dp.parent
                        acl9: nodeCol n: dp.parent
                        (addErrorH
                            :st
                            nodeid: aid9
                            lineno: aln9
                            colno: acl9
                            e: zast.err.OWNERERROR
                            msg: macc9
                            note: aen9
                            hint: ahint9
                            width: mkRoot.length.u32
                        )
                    } case none then {
                    }
                    rlk9: st.findLock name: mkRoot.stringview
                    match (
                        rlk9
                    ) case some then {
                        relBlocked9 = true
                        rhn9: "".string
                        rlhh9: st.findLockHolder name: mkRoot.stringview
                        match (
                            rlhh9
                        ) case some then {
                            rhn9 = st.formatLockHolder rlhh9
                        } case none then {
                        }
                        lsn9: zenv.zlockstateNameLower t: rlk9
                        mrr9: mkRoot.copy
                        mrel9: "Cannot release '\{mrr9}': \{lsn9} lock held by '\{rhn9}'"
                        (addError
                            :st
                            nodeid: dp.nodeid
                            lineno: dp.lineno
                            colno: dp.colno
                            e: zast.err.OWNERERROR
                            msg: mrel9
                        )
                    } case none then {
                    }
                }
                if (relBlocked9) == false then {
                    mh: (ztypes.zlockholder kind: ztypes.zlockholderkind.VAR id: mvo)
                    st.releaseHeldLocks holder: mh
                    st.invalidate name: mkRoot.stringview loc: takenHere
                }
            } case none then {
                if cn.stringview == "release" then {
                    dfo9: (walkLookupTyperef
                        ty: st.typing
                        reg: st.reg
                        currentUnit: unitName
                        base: mkRoot.stringview
                    )
                    match (
                        dfo9
                    ) case some then {
                        mrc9: mkRoot.copy
                        mtl9: "Cannot release top-level definition '\{mrc9}'"
                        (addError
                            :st
                            nodeid: dp.nodeid
                            lineno: dp.lineno
                            colno: dp.colno
                            e: zast.err.OWNERERROR
                            msg: mtl9
                        )
                    } case none then {
                    }
                }
            }
        }
        setmk: bt
        st.typing.nodeType.set key: dp.nodeid.u64 value: setmk
        return bt
    }
    # A compile-time numeric index on an array instance projects the element
    # type (`a.0` reads / reassigns element zero).
    if (isNumericLiteralName name: cn.stringview) then {
        isArr9: false
        bga8: 0.u64
        {
            bz8: st.reg.typeById.get key: bt
            match (
                bz8
            ) case some then {
                bgo8: bz8.genericOriginId
                match (
                    bgo8
                ) case some then {
                    bga8 = bgo8
                } case none then {
                }
            } case none then {
            }
        }
        if bga8 > 0 then {
            gn8: typeNameOf :st tid: bga8
            if gn8.stringview == "array" then isArr9 = true
        }
        if isArr9 then {
            go8: st.typing.childOf parentTypeId: bt name: "get"
            match (
                go8
            ) case some then {
                ro8: methodReturnOf :st mid: go8
                match (
                    ro8
                ) case some then {
                    seta8: ro8
                    st.typing.nodeType.set key: dp.nodeid.u64 value: seta8
                    return ro8
                } case none then {
                }
            } case none then {
            }
        }
    }
    # `.index` / `.array` on a data block need its static array emitted (label
    # accesses fold to constants); mark the type so the emitter keeps the array.
    if (st.reg.typetypeOf typeId: bt) == ztypes.ztypetype.DATA then {
        if cn.stringview == "index" then markDataRuntimeIndexed :st tid: bt
        if cn.stringview == "array" then markDataRuntimeIndexed :st tid: bt
    }
    # `.array` on a data block copies the elements into the sized array
    # instance (array_{elem}_{count}), minting it on first access. The
    # element type rides the data's `tag__{elem}` tag-child name.
    if cn.stringview == "array" then {
        if (st.reg.typetypeOf typeId: bt) == ztypes.ztypetype.DATA then {
            tgo: st.typing.childOf parentTypeId: bt name: "tag"
            match (
                tgo
            ) case some then {
                tagn: typeNameOf :st tid: tgo
                eno: tagn.stringview.stripPrefix p: "tag__"
                match (
                    eno
                ) case some then {
                    den: eno.string
                    elo: (walkLookupTyperef
                        ty: st.typing
                        reg: st.reg
                        currentUnit: unitName
                        base: den.stringview
                    )
                    match (
                        elo
                    ) case some then {
                        ecnt: (st.typing.childCount parentTypeId: bt) - 1
                        ato: (walkLookupTyperef
                            ty: st.typing
                            reg: st.reg
                            currentUnit: unitName
                            base: "array"
                        )
                        match (
                            ato
                        ) case some then {
                            amn: "array_\{den}_\{ecnt}"
                            asubs: (Map String value: u64)
                            sk0: "of".string
                            sv0: elo
                            asubs.set key: sk0 value: sv0
                            vsE9: (Map String value: u64)
                            amid: (getOrMintSpec
                                ty: st.typing
                                reg: st.reg
                                mainName: unitName
                                name: amn.stringview
                                templateId: ato
                                subs: asubs
                                valSubs: vsE9
                                fallbackArg: 0
                            )
                            asfx: "_\{den}_\{ecnt}"
                            (mintCollectionChildren
                                ty: st.typing
                                reg: st.reg
                                mainName: unitName
                                monoName: amn.stringview
                                monoId: amid
                                templateId: ato
                                suffix: asfx.stringview
                                elemArg: elo
                                valArg: 0
                            )
                            setar: amid
                            st.typing.nodeType.set key: dp.nodeid.u64 value: setar
                            return amid
                        } case none then {
                        }
                    } case none then {
                    }
                } case none then {
                }
            } case none then {
            }
        }
    }
    # a unit-qualified member (`io.stdout`): the member resolves in that
    # unit's namespace; a no-arg FUNCTION member auto-calls in value
    # position (its return is the path's value).
    if (st.reg.typetypeOf typeId: bt) == ztypes.ztypetype.UNIT then {
        un9: typeNameOf :st tid: bt
        mo9: (walkLookupTyperef
            ty: st.typing
            reg: st.reg
            currentUnit: un9.stringview
            base: cn.stringview
        )
        match (
            mo9
        ) case some then {
            result9: mo9
            isFn9: false
            if (st.reg.typetypeOf typeId: mo9) == ztypes.ztypetype.FUNCTION then isFn9 = true
            if coerce when isFn9 then {
                if (methodHasNoUserArgs :st mid: mo9) then {
                    ro9: methodReturnOf :st mid: mo9
                    match (
                        ro9
                    ) case some then {
                        result9 = ro9
                    } case none then {
                        result9 = st.reg.allocType
                    }
                }
            }
            setu9: result9
            st.typing.nodeType.set key: dp.nodeid.u64 value: setu9
            return result9
        } case none then {
            unc9: un9.copy
            cnc9: cn.copy
            m3: "unit '\{unc9}' has no member '\{cnc9}'"
            sug3: suggestSimilar :st parentTypeId: bt name: cn.stringview
            h3: "".string
            if sug3.length > 0 then {
                sgc3: sug3.copy
                hh3: "did you mean '\{sgc3}'?"
                h3 = hh3
            }
            en3: "".string
            cnid3: nodeId n: dp.child
            cnln3: nodeLine n: dp.child
            cncl3: nodeCol n: dp.child
            (addErrorH
                :st
                nodeid: cnid3
                lineno: cnln3
                colno: cncl3
                e: zast.err.TYPEERROR
                msg: m3
                note: en3
                hint: h3
                width: cn.length.u32
            )
            return 0
        }
    }
    # a typedef member that isn't on the wrapper delegates to the base
    # (Bytes.append is List_u8.append).
    tdw9: st.typing.childOf parentTypeId: bt name: cn.stringview
    match (
        tdw9
    ) case some then {
    } case none then {
        tdd9: typedefBaseMangledOf :st :unitName tid: bt
        if tdd9 == 0 then tdd9 = typedefBaseOf :st :unitName tid: bt
        if tdd9 > 0 then bt = tdd9
    }
    # A cross-unit narrowed match-arm base can be a SHELL whose member
    # children are not registered (cross-unit demand mints a shell id distinct
    # from the canonical defining-unit id); on a member miss retarget the base
    # to a same-named type in another unit's resolved scope that has the member.
    preMo9: st.typing.childOf parentTypeId: bt name: cn.stringview
    preHas9: false
    match (
        preMo9
    ) case some then {
        preHas9 = true
    } case none then {}
    if (preHas9) == false then {
        if (st.typing.definedInUnit.has key: bt) == false then {
            cb9: canonicalChildBase :st :bt child: cn.stringview
            if cb9 > 0 then bt = cb9
        }
    }
    mo: st.typing.childOf parentTypeId: bt name: cn.stringview
    match (
        mo
    ) case some then {
        # member-owner stamp: the use-site dotted path resolved a member of
        # `bt` (field, method, or tagged arm). Tooling reads this for
        # go-to-definition; the compiler itself never consumes it.
        if dp.nodeid > 0 when bt > 0 then {
            setmo9: bt
            st.typing.memberOwnerTid.set key: dp.nodeid.u64 value: setmo9
        }
        # A subtype member named on a tagged TYPE (not a value of it, not the
        # tag, not a method) is a construction reference: record the dotted
        # node's tagged parent (construction dispatch and generic-union
        # inference key off it), stamp the path with the parent, and the
        # path's value IS the parent. A value base keeps member semantics.
        btt0: st.reg.typetypeOf typeId: bt
        isTagged0: false
        if btt0 == ztypes.ztypetype.VARIANT then isTagged0 = true
        if btt0 == ztypes.ztypetype.UNION then isTagged0 = true
        if isTagged0 then {
            ctt0: st.reg.typetypeOf typeId: mo
            isMember0: true
            if ctt0 == ztypes.ztypetype.FUNCTION then isMember0 = false
            if ctt0 == ztypes.ztypetype.DATA then isMember0 = false
            if isMember0 then {
                tvn0: bareAtomName n: dp.parent
                isVal0: false
                if tvn0.length > 0 then {
                    tvo0: st.lookupVarId name: tvn0.stringview
                    match (
                        tvo0
                    ) case some then {
                        isVal0 = true
                    } case none then {}
                }
                if (isVal0) == false then {
                    dpk0: dp.nodeid.u64
                    dpv0: bt
                    st.typing.dpTaggedParent.set key: dpk0 value: dpv0
                    setdp0: bt
                    st.typing.nodeType.set key: dp.nodeid.u64 value: setdp0
                    return bt
                }
            }
        }
        if (st.typing.isAsConstClone typeId: mo) then {
            setcc: mo
            st.typing.nodeType.set key: dp.nodeid.u64 value: setcc
            return mo
        }
        rm: mo
        result: 0.u64
        result = rm
        # Reading a protocol-typed conformance member projects a borrow of
        # the receiver: the consuming binding becomes BORROWED with the base
        # as its origin (and installs the borrow locks).
        rmtt: st.reg.typetypeOf typeId: rm
        if rmtt == ztypes.ztypetype.PROTOCOL then {
            pjroot: bareAtomName n: dp.parent
            if pjroot.length > 0 then {
                pjvo: st.lookupVarId name: pjroot.stringview
                match (
                    pjvo
                ) case some then {
                    drainPendingBorrow :st
                    pjc: pjroot.copy
                    st.typing.pendingBorrowPath.append pjc
                } case none then {}
            }
        }
        if coerce when (st.typing.isChildFnptrField parentTypeId: bt name: cn.stringview) then {
            # bare name = call: a value-position read of an args-bearing
            # fn-pointer field is a call missing its arguments; `.take` is
            # the reference form (peeled before this leg)
            natE3: st.typing.inAssignTarget
            {
                nzo3: st.reg.typeById.get key: mo
                match (
                    nzo3
                ) case some then {
                    if nzo3.isNative then natE3 = true
                } case none then {}
            }
            if natE3 == false when (methodHasNoUserArgs :st mid: mo) == false then {
                cnE3: cn.copy
                mE3: "function-pointer field '\{cnE3}' takes arguments; call it, or reference it with '.take'"
                (addError
                    :st
                    nodeid: dp.nodeid
                    lineno: dp.lineno
                    colno: dp.colno
                    e: zast.err.CALLERROR
                    msg: mE3
                )
            }
        }
        if coerce when (methodHasNoUserArgs :st mid: mo) then {
            ro: methodReturnOf :st mid: mo
            match (
                ro
            ) case some then {
                result = ro
                fb: st.typing.funcReturnsBorrow.get key: mo
                match (
                    fb
                ) case some then {
                    if fb then {
                        # Build locally, then append through the full field
                        # path (a field list passed as an argument is a
                        # non-owning shallow copy -- appends would be lost).
                        tup: (List String)
                        appendValueTuple n: dp.parent dst: tup
                        drainPendingBorrow :st
                        ti: 0.u64
                        tn: tup.length
                        for ti < tn loop {
                            te: tup.get i: ti
                            tec: te.copy
                            st.typing.pendingBorrowPath.append tec
                            ti = ti + 1
                        }
                        if (returnIsIteratorTid :st tid: result) == false then {
                            st.typing.pendingBorrowShared = true
                        }
                    } else {
                        drainPendingBorrow :st
                    }
                } case none then {
                    # an owning auto-call (`.copy` / `.string` / user methods)
                    # consumes any receiver-evaluation borrow residue (the get
                    # in `(xs.get i).copy` must not flow to the binding).
                    drainPendingBorrow :st
                }
            } case none then {
                # A no-`out` METHOD auto-call resolves to null (the
                # reference's auto-call rule for out-less methods). Non-
                # function members (field shells) keep their re-resolved
                # type.
                if (st.reg.typetypeOf typeId: mo) == ztypes.ztypetype.FUNCTION then {
                    # an unregistered shell id: the stamp never joins the
                    # dump (the reference's t_null carries no unit either)
                    result = st.reg.allocType
                }
            }
        }
        stampGate :st nid: dp.nodeid tid: result
        return result
    } case none then {
        if (st.reg.typetypeOf typeId: bt) == ztypes.ztypetype.GENERIC_PARAM then {
            # `.copy` is an ownership primitive, not a constrained member:
            # every instantiation copies, so a generic-param receiver types
            # it t -> t (the per-instance clone emits the concrete copy).
            if cn.stringview == "copy" then {
                stampGate :st nid: dp.nodeid tid: bt
                return bt
            }
            btn9x: typeNameOf :st tid: bt
            mgp9: "type parameter '\{btn9x}' has no member '\{cn}' (its constraint provides none)"
            (addError
                :st
                nodeid: dp.nodeid
                lineno: dp.lineno
                colno: dp.colno
                e: zast.err.GENERICERROR
                msg: mgp9
            )
        }
        # `.copy` on a receiver with no copy member is a hard error: deep
        # copy exists for strings, containers, and generic type parameters
        # only. Without this the emitter has no clone to emit and the
        # miss would surface as invalid C.
        if cn.stringview == "copy" when (st.reg.typetypeOf typeId: bt) != ztypes.ztypetype.GENERIC_PARAM then {
            btnCp9: typeNameOf :st tid: bt
            bttCp9: st.reg.typetypeOf typeId: bt
            isValCp9: false
            if bttCp9 == ztypes.ztypetype.RECORD then isValCp9 = true
            if bttCp9 == ztypes.ztypetype.VARIANT then isValCp9 = true
            if bttCp9 == ztypes.ztypetype.FACET then isValCp9 = true
            mCp9: "type '\{btnCp9}' has no '.copy': deep copy of user-defined reftypes is not implemented (move with '.take', or copy field-by-field)"
            if isValCp9 then {
                mCp9 = "type '\{btnCp9}' has no '.copy': valtypes copy by assignment (drop '.copy')"
            }
            (addError
                :st
                nodeid: dp.nodeid
                lineno: dp.lineno
                colno: dp.colno
                e: zast.err.TYPEERROR
                msg: mCp9
            )
        }
        return 0
    }
}

checkAtomid: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    node: zast.AtomIdData
} out u64 is {
    result: 0.u64
    vtOpt: st.lookup name: node.name.stringview
    match (
        vtOpt
    ) case some then {
        result = vtOpt
        # break/continue diverge: the atom's value is never (the scope
        # entry stays the unregistered placeholder).
        isBrk9: false
        if node.name.stringview == "break" then isBrk9 = true
        if node.name.stringview == "continue" then isBrk9 = true
        if isBrk9 then {
            result = (optU64Or
                o: (walkLookupTyperef ty: st.typing reg: st.reg currentUnit: unitName base: "never")
                d: result
            )
        }
        stampGate :st nid: node.nodeid tid: result
        # atom-use variable id: stamped even during template walks (variable
        # ids are valid there; stampGate only gates GENERIC_PARAM types)
        avo9: st.lookupVarId name: node.name.stringview
        match (
            avo9
        ) case some then {
            setav9: avo9
            st.typing.atomVariableId.set key: node.nodeid.u64 value: setav9
        } case none then {}
    } case none then {
        if node.name.stringview == "return" then {
            mrt9: st.typing.currentReturnTypeId
            if mrt9 > 0 then {
                mtt9: st.reg.typetypeOf typeId: mrt9
                isVoidRet9: false
                if mtt9 == ztypes.ztypetype.NULL then isVoidRet9 = true
                if mtt9 == ztypes.ztypetype.NEVER then isVoidRet9 = true
                if (isVoidRet9) == false then {
                    rtn9: typeNameOf :st tid: mrt9
                    rtnc9: rtn9.copy
                    mm9: "missing return value: function expects '\{rtnc9}'"
                    en6: "".string
                    eh6: "".string
                    (addErrorH
                        :st
                        nodeid: node.nodeid
                        lineno: node.lineno
                        colno: node.colno
                        e: zast.err.TYPEERROR
                        msg: mm9
                        note: en6
                        hint: eh6
                        width: 6
                    )
                }
            }
        }
        if (st.isTakenName name: node.name.stringview) then {
            nmc9: node.name.copy
            eh5: "".string
            m5: "cannot use '\{nmc9}' after ownership transfer"
            nt5: "this name no longer owns a value; it was moved earlier".string
            (addErrorH
                :st
                nodeid: node.nodeid
                lineno: node.lineno
                colno: node.colno
                e: zast.err.OWNERERROR
                msg: m5
                note: nt5
                hint: eh5
                width: node.name.length.u32
            )
            return 0
        }
        if (isNumericLiteralName name: node.name.stringview) then {
            if (isFloatLiteralName name: node.name.stringview) then {
                result = literalFloatId
            } else {
                result = literalIntId
            }
            setl: result
            st.typing.nodeType.set key: node.nodeid.u64 value: setl
        } else {
            fo: (walkLookupTyperef
                ty: st.typing
                reg: st.reg
                currentUnit: unitName
                base: node.name.stringview
            )
            match (
                fo
            ) case some then {
                result = fo
                # A bare no-arg non-generic FUNCTION name is a call: the
                # value is its return (an unregistered shell when out-less).
                isAutoFn: false
                {
                    fz9: st.reg.typeById.get key: fo
                    match (
                        fz9
                    ) case some then {
                        if fz9.typetype == ztypes.ztypetype.FUNCTION then {
                            if (fz9.isgeneric) == false then isAutoFn = true
                        }
                    } case none then {
                    }
                }
                if isAutoFn when (methodHasNoUserArgs :st mid: fo) then {
                    ro9: methodReturnOf :st mid: fo
                    match (
                        ro9
                    ) case some then {
                        result = ro9
                    } case none then {
                        result = st.reg.allocType
                    }
                }
                setu: result
                st.typing.nodeType.set key: node.nodeid.u64 value: setu
                # atom-use unit-def id: the DEF's tid (nodeType carries the
                # auto-call RETURN type above, which is not the referent)
                setud9: fo
                st.typing.atomUnitDefId.set key: node.nodeid.u64 value: setud9
                maybeWalkMethods :st :unitName :unitBody name: node.name.stringview
            } case none then {
            }
        }
    }
    return result
}

# isFloatLiteralName -- a numeric-literal atom carrying a decimal point (the
# float default; hex/binary stay integer literals).
isFloatLiteralName: function {name: StringView} out bool is {
    i: 0.u64
    n: name.length
    for i < n loop {
        b: name.byteAt i
        match (
            b
        ) case some then {
            if b == 46 then return true
        } case none then {
        }
        i = i + 1
    }
    return false
}

# isComparisonOp -- a binop operator whose result is bool (not the operand type).
isComparisonOp: function {name: StringView} out bool is {
    if name == "<" then return true
    if name == ">" then return true
    if name == "<=" then return true
    if name == ">=" then return true
    if name == "==" then return true
    if name == "!=" then return true
    return false
}

# checkClause -- walk one if-clause: its condition(s) (namedoperation-wrapped)
# then its then-statement block.
checkClause: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    clause: Node
} out u64 is {
    match (
        clause
    ) case ifclause then {
        coiter: clause.conditions.iterate
        for cond: coiter loop {
            match (
                cond
            ) case namedoperation then {
                checkValue :st :unitName :unitBody node: cond.operation
            } else {
            }
        }
        checkStatement :st :unitName :unitBody block: clause.statement
        return (lastStmtType :st block: clause.statement)
    } else {
        return 0
    }
}

# lastStmtType -- the resolved type id of a statement block's last statement
# (the value of a do-block), or 0 when empty/untyped.
lastStmtType: function {st: zenv.ZSymbolTable block: Node} out u64 is {
    result: 0.u64
    match (
        block
    ) case statement then {
        ne: block.statements.length
        if ne > 0 then {
            last: block.statements.get i: (ne - 1)
            match (
                last
            ) case statementline then {
                result = optU64Or o: (st.typing.nodeType.get key: last.nodeid.u64) d: result
            } else {
            }
        }
    } else {
        # An expression-shaped body (a bare `then 10` branch) carries its
        # value on its own node.
        bid9: nodeId n: block
        if bid9 > 0 then result = optU64Or o: (st.typing.nodeType.get key: bid9.u64) d: result
    }
    return result
}

# materialiseLiteral -- fold a literal pseudo-type id to its concrete default
# (i64 / f64); concrete ids pass through.
materialiseLiteral: function {st: zenv.ZSymbolTable unitName: StringView t: u64} out u64 is {
    base: ""
    if t == literalIntId then base = "i64"
    if t == literalFloatId then base = "f64"
    if base.length == 0 then return t
    return (optU64Or
        o: (walkLookupTyperef ty: st.typing reg: st.reg currentUnit: unitName :base)
        d: t
    )
}

# checkAssignment -- a local binding `name: value`: walk the value, materialise a
# literal-typed value to its concrete default (the binding takes i64, unlike a
# for-loop binding which keeps the pseudo id), define the local (owned for a plain
# value), and stamp the assignment node + def-variable.
checkAssignment: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    asgn: zast.AssignmentData
} is {
    drainPendingBorrow :st
    vt: checkValue :st :unitName :unitBody node: asgn.value
    if vt == 0 then {
        ubn9: unresolvedBareCallable :st :unitName n: asgn.value
        if ubn9.length > 0 then {
            ubm9: "Unknown reference '\{ubn9}'"
            ubid9: nodeId n: asgn.value
            ubln9: nodeLine n: asgn.value
            ubcl9: nodeCol n: asgn.value
            (addError
                :st
                nodeid: ubid9
                lineno: ubln9
                colno: ubcl9
                e: zast.err.BADREFERENCE
                msg: ubm9
            )
        }
    }
    mvt: materialiseLiteral :st :unitName t: vt
    vt = mvt
    if vt > 0 when (st.reg.typetypeOf typeId: vt) == ztypes.ztypetype.NULL then {
        m1: "'null' cannot be used as a value — null must be wrapped in a union or variant (eg. option.none)".string
        vln1: nodeLine n: asgn.value
        vcl1: nodeCol n: asgn.value
        vid1: nodeId n: asgn.value
        en1: "".string
        eh1: "".string
        (addErrorH
            :st
            nodeid: vid1
            lineno: vln1
            colno: vcl1
            e: zast.err.TYPEERROR
            msg: m1
            note: en1
            hint: eh1
            width: 4
        )
        return
    }
    if vt > 0 then {
        bsrc: (List String)
        takePendingBorrow :st dst: bsrc
        own: ztypes.zownership.OWNED
        if bsrc.length > 0 when (typeIsReftype :st tid: vt) then own = ztypes.zownership.BORROWED
        v: st.reg.newVariable ztypeId: vt ownership: own
        vid: v.variableId
        if own == ztypes.zownership.BORROWED then {
            r0: bsrc.get i: 0
            bo: r0.copy
            v.borrowOrigin = (Option.some bo)
        }
        st.defineVar name: asgn.name.stringview var: v
        vid2: vid
        st.typing.defVariableId.set key: asgn.nodeid.u64 value: vid2
        setk: vt
        st.typing.nodeType.set key: asgn.nodeid.u64 value: setk
        rn5: bareAtomName n: asgn.value
        if rn5.length > 0 when (typeIsReftype
            :st
            tid: vt
        ) when (st.reg.hasDestructorName typeId: vt) then {
            vo5: st.lookupVarId name: rn5.stringview
            match (
                vo5
            ) case some then {
                if (isBorrowedVar :st vid: vo5) then {
                    rnc5: rn5.copy
                    mb5: "Cannot move borrowed variable '\{rnc5}' into an owned binding — borrowed names stay bound to their source for the full scope"
                    (addError
                        :st
                        nodeid: asgn.nodeid
                        lineno: asgn.lineno
                        colno: asgn.colno
                        e: zast.err.OWNERERROR
                        msg: mb5
                    )
                } else {
                    st.invalidate name: rn5.stringview loc: (optionval.none ztypes.zsrcpos)
                }
            } case none then {
            }
        }
        if own == ztypes.zownership.BORROWED then {
            lfsA9: isViewFamilyTid :st tid: vt
            if st.typing.pendingBorrowShared then lfsA9 = true
            st.typing.pendingBorrowShared = false
            (installBorrowLocks
                :st
                src: bsrc
                :vid
                leafShared: lfsA9
                nodeid: asgn.nodeid
                lineno: asgn.lineno
                colno: asgn.colno
            )
        }
        # Binding a tagged-subtype construction narrows the name to the
        # constructed arm (assignment-based narrowing: the overlay keeps the
        # subject's type with the narrowed-subtype sidecar).
        ucArm: unionCreateArmName :st n: asgn.value
        if ucArm.length > 0 then {
            (st.narrow
                name: asgn.name.stringview
                toTypeId: vt
                subtypeName: ucArm.stringview
                shadow: false
            )
        }
    }
}

# checkReassignment -- `lhs = value`: resolve the target path and the value, then
# reset any narrowing on a bare-name target (appends a non-definition overlay
# entry, mirroring _check_reassignment_inner's reset_narrowing).
checkReassignment: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    rasgn: zast.ReassignmentData
} is {
    st.typing.inAssignTarget = true
    lvt: checkValue :st :unitName :unitBody node: rasgn.topath
    st.typing.inAssignTarget = false
    rvt: checkValue :st :unitName :unitBody node: rasgn.value
    # A typeof-placeholder field resolves at its first write: swap the
    # field child to the RHS's type and restamp the target path.
    if lvt > 0 when rvt > 0 then {
        tso: st.typing.typeofShell.get key: lvt
        match (
            tso
        ) case some then {
            troot: methodReceiverRoot n: rasgn.topath
            if troot.length > 0 then {
                tto: st.lookup name: troot.stringview
                match (
                    tto
                ) case some then {
                    tfn: dottedChildName n: rasgn.topath
                    if tfn.length > 0 then {
                        mrvt: materialiseLiteral :st :unitName t: rvt
                        (st.typing.setChild
                            parentTypeId: tto
                            childName: tfn.stringview
                            childTypeId: mrvt
                        )
                        settof: mrvt
                        st.typing.nodeType.set key: tso.u64 value: settof
                        tpid: nodeId n: rasgn.topath
                        if tpid > 0 then {
                            settp: mrvt
                            st.typing.nodeType.set key: tpid.u64 value: settp
                        }
                    }
                } case none then {
                }
            }
        } case none then {
        }
    }
    # A literal RHS at a concretely-typed target coerces: restamp the RHS's
    # innermost node (wrappers derive through the dump's descent). A
    # literal-typed target (a literal-init loop binding) keeps the pseudo.
    if lvt > 0 when rvt > 0 when (isLiteralTypeId :st tid: rvt) then {
        if (isLiteralTypeId :st tid: lvt) == false then {
            iid: innermostNodeId n: rasgn.value
            if iid > 0 then {
                setc: lvt
                st.typing.nodeType.set key: iid.u64 value: setc
            }
        }
    }
    nm: atomName n: rasgn.topath
    if nm.length > 0 then {
        st.resetNarrowing name: nm.stringview
        nvo9: st.lookupVarId name: nm.stringview
        match (
            nvo9
        ) case some then {
            if (isBorrowedVar :st vid: nvo9) then {
                nmc9: nm.copy
                ma9: "Cannot reassign borrowed variable '\{nmc9}'"
                ha9: "borrowed names are bound for their full scope; shadow in an inner scope instead".string
                ena9: "".string
                (addErrorH
                    :st
                    nodeid: rasgn.nodeid
                    lineno: rasgn.lineno
                    colno: rasgn.colno
                    e: zast.err.OWNERERROR
                    msg: ma9
                    note: ena9
                    hint: ha9
                    width: nm.length.u32
                )
            }
        } case none then {
        }
    }
    troot9: methodReceiverRoot n: rasgn.topath
    tfn9: dottedChildName n: rasgn.topath
    if troot9.length > 0 when tfn9.length > 0 then {
        tto9: st.lookup name: troot9.stringview
        match (
            tto9
        ) case some then {
            if (st.typing.isChildLockField parentTypeId: tto9 name: tfn9.stringview) then {
                tfnc9: tfn9.copy
                md9: "Cannot reassign '.lock' field '\{tfnc9}' — lock fields are set at construction time and immutable"
                (addError
                    :st
                    nodeid: rasgn.nodeid
                    lineno: rasgn.lineno
                    colno: rasgn.colno
                    e: zast.err.OWNERERROR
                    msg: md9
                )
            }
        } case none then {
        }
    }
    # A bare-name reftype RHS is a move: the source invalidates (the symtab
    # appends its taken overlay entry).
    rn: bareAtomName n: rasgn.value
    if rn.length > 0 when rvt > 0 when (typeIsReftype :st tid: rvt) then {
        vo: st.lookupVarId name: rn.stringview
        match (
            vo
        ) case some then {
            if (isBorrowedVar :st vid: vo) then {
                rnc9: rn.copy
                mc9: "Cannot move borrowed variable '\{rnc9}' by reassignment — borrowed names stay bound to their source for the full scope; copy with '.copy' to keep the source"
                (addError
                    :st
                    nodeid: rasgn.nodeid
                    lineno: rasgn.lineno
                    colno: rasgn.colno
                    e: zast.err.OWNERERROR
                    msg: mc9
                )
            } else {
                st.invalidate name: rn.stringview loc: (optionval.none ztypes.zsrcpos)
            }
        } case none then {
        }
    }
}

# checkSwap -- `lhs swap rhs`: resolve both operand paths (stamping them). The swap
# carries no type (the expression wrapper is null, like reassignment) and does no
# narrowing. Operand ownership/lock/type-match validation produces no dump rows -- deferred.
checkSwap: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    swapnode: zast.SwapStmtData
} is {
    checkValue :st :unitName :unitBody node: swapnode.lhs
    checkValue :st :unitName :unitBody node: swapnode.rhs
}

# withValueOwnership -- the with-binding's ownership from the bound value's
# syntactic shape, mirroring the reference's function-argument rules: a bare
# name bound to a runtime variable or a plain dotted path borrows; `.take`
# transfers; calls, literals and constructions are fresh owned values.
withValueOwnership: function {st: zenv.ZSymbolTable v: Node} out ztypes.zownership is {
    match (
        v
    ) case expression then {
        return (withValueOwnership :st v: v.expression)
    } case atomid then {
        vo: st.lookupVarId name: v.name.stringview
        match (
            vo
        ) case some then {
            return ztypes.zownership.BORROWED
        } case none then {
            return ztypes.zownership.OWNED
        }
    } case dottedpath then {
        cn: atomName n: v.child
        if cn.stringview == "take" then {
            return ztypes.zownership.OWNED
        } else {
            return ztypes.zownership.BORROWED
        }
    } else {
        return ztypes.zownership.OWNED
    }
}

# checkWith -- walk `with name: value do body`: push the `with` scope, bind the
# alias variable (BORROWED for a plain-path value), walk the body, then pop. The
# with node carries the bound value's type; the with-expression's value is the
# body's value.
checkWith: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    withnode: zast.WithData
} out u64 is {
    withMarker: st.pushBlock name: "with"
    vt: checkValue :st :unitName :unitBody node: withnode.value
    if vt > 0 then {
        own: withValueOwnership :st v: withnode.value
        # The borrow target: a BORROW-returning auto-call reported the receiver
        # source; a plain-path value locks its full dotted tuple. Valtype
        # borrows are copies -- no lock.
        btgt: (List String)
        takePendingBorrow :st dst: btgt
        if btgt.length == 0 then {
            if own == ztypes.zownership.BORROWED then appendValueTuple n: withnode.value dst: btgt
        } else {
            # A pending borrow from the value's call (a lock-param transfer
            # or a borrow-marked return) makes the with-binding borrowed.
            own = ztypes.zownership.BORROWED
        }
        v: st.reg.newVariable ztypeId: vt ownership: own
        vid: v.variableId
        st.defineVar name: withnode.name.stringview var: v
        vid2: vid
        st.typing.defVariableId.set key: withnode.nodeid.u64 value: vid2
        if (typeIsReftype :st tid: vt) then {
            lfsW9: isViewFamilyTid :st tid: vt
            if st.typing.pendingBorrowShared then lfsW9 = true
            st.typing.pendingBorrowShared = false
            (installBorrowLocks
                :st
                src: btgt
                :vid
                leafShared: lfsW9
                nodeid: withnode.nodeid
                lineno: withnode.lineno
                colno: withnode.colno
            )
        }
        setk: vt
        st.typing.nodeType.set key: withnode.nodeid.u64 value: setk
    }
    dt: checkValue :st :unitName :unitBody node: withnode.body
    st.popTo marker: withMarker
    return dt
}

# blockHasBreak -- a bare `break` statement somewhere in this block's own
# control flow (descending if/match/with bodies but NOT nested do/for, whose
# breaks bind to them). Drives the do-block's optionval wrapping.
blockHasBreak: function {n: Node} out bool is {
    match (
        n
    ) case statement then {
        siter: n.statements.iterate
        for s0: siter loop {
            if (blockHasBreak n: s0) then return true
        }
        return false
    } case statementline then {
        return (blockHasBreak n: n.statementline)
    } case expression then {
        return (blockHasBreak n: n.expression)
    } case atomid then {
        return (n.name.stringview == "break")
    } case ifexpr then {
        cliter: n.clauses.iterate
        for cl0: cliter loop {
            match (
                cl0
            ) case ifclause then {
                if (blockHasBreak n: cl0.statement) then return true
            } else {
            }
        }
        return (blockHasBreakOpt bodyOpt: n.elseclause)
    } case caseexpr then {
        mliter: n.clauses.iterate
        for ml0: mliter loop {
            match (
                ml0
            ) case caseclause then {
                if (blockHasBreak n: ml0.statement) then return true
            } else {
            }
        }
        return (blockHasBreakOpt bodyOpt: n.elseclause)
    } case withexpr then {
        return (blockHasBreak n: n.body)
    } else {
        return false
    }
}

# blockHasBreakOpt -- blockHasBreak over an optional body.
blockHasBreakOpt: function {bodyOpt: Option Node} out bool is {
    match (
        bodyOpt
    ) case some then {
        return (blockHasBreak n: bodyOpt)
    } case none then {
        return false
    }
}

# checkDo -- walk a do-block: push the `block` scope, define break (an entry
# position placeholder with an unregistered type id, so it never joins the dump),
# walk the statements, then pop. The do resolves to its last statement's value type.
checkDo: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    donode: zast.DoData
} out u64 is {
    doMarker: st.pushBlock name: "block"
    dbk: st.reg.allocType
    st.define name: "break" ztypeId: dbk
    checkStatement :st :unitName :unitBody block: donode.statement
    result: lastStmtType :st block: donode.statement
    st.popTo marker: doMarker
    # A break-carrying do-block's value wraps in optionval (early exit =
    # none); the literal pseudo keys the instance as literal_int/float.
    # A REFTYPE block value wraps in Option instead (boxed payload).
    if result > 0 when (blockHasBreak n: donode.statement) then {
        vtn0: typeNameOf :st tid: result
        payId0: result
        if result == literalIntId then {
            vtn0 = "literal_int".string
            if st.typing.literalIntShellId == 0 then {
                nli0: st.reg.newType name: "literal_int" typetype: ztypes.ztypetype.RECORD
                st.reg.setValtype typeId: nli0 value: true
                st.typing.literalIntShellId = nli0
            }
            payId0 = st.typing.literalIntShellId
        }
        if result == literalFloatId then {
            vtn0 = "literal_float".string
            if st.typing.literalFloatShellId == 0 then {
                nlf0: st.reg.newType name: "literal_float" typetype: ztypes.ztypetype.RECORD
                st.reg.setValtype typeId: nlf0 value: true
                st.typing.literalFloatShellId = nlf0
            }
            payId0 = st.typing.literalFloatShellId
        }
        if vtn0.length > 0 then {
            wrapB0: "optionval"
            if (typeIsReftype :st tid: payId0) then wrapB0 = "Option"
            ovo0: (walkLookupTyperef
                ty: st.typing
                reg: st.reg
                currentUnit: unitName
                base: wrapB0
            )
            match (
                ovo0
            ) case some then {
                osubs0: (Map String value: u64)
                ok0: "t".string
                ov0: payId0
                osubs0.set key: ok0 value: ov0
                omn0: "\{wrapB0}_\{vtn0}"
                vsF9: (Map String value: u64)
                omid0: (getOrMintSpec
                    ty: st.typing
                    reg: st.reg
                    mainName: unitName
                    name: omn0.stringview
                    templateId: ovo0
                    subs: osubs0
                    valSubs: vsF9
                    fallbackArg: 0
                )
                if omid0 > 0 then result = omid0
            } case none then {
            }
        }
    }
    if result > 0 then {
        setk: result
        st.typing.nodeType.set key: donode.nodeid.u64 value: setk
    }
    return result
}

# isCallNode -- the node is a (possibly expression-wrapped) call.
isCallNode: function {n: Node} out bool is {
    match (
        n
    ) case call then {
        return true
    } case expression then {
        return (isCallNode n: n.expression)
    } else {
        return false
    }
}

# checkFor -- walk a for-loop: push the `for` scope, define break/continue (entry
# position placeholders with unregistered type ids, so they never join the dump),
# then walk the conditions, postconditions, and body, and pop. A named condition
# is a binding: define the loop var with the condition value's type (the value of
# a bare literal init stays the literal pseudo-type, keeping the entry out of the
# dump joins). Iterator-wrapper element extraction needs monomorphization and is
# not implemented. The for itself resolves to null (filtered) in statement position.
checkFor: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    fornode: zast.ForData
} out u64 is {
    forMarker: st.pushBlock name: "for"
    bk: st.reg.allocType
    st.define name: "break" ztypeId: bk
    ct: st.reg.allocType
    st.define name: "continue" ztypeId: ct
    citer: fornode.conditions.iterate
    for cond: citer loop {
        match (
            cond
        ) case namedoperation then {
            # A bare 0-arg function returning an iterator class auto-invokes
            # (the reference rewrites the condition to a synthetic call):
            # its walk runs in a call scope and the atom keeps the FUNCTION
            # stamp rather than the auto-call's coerced return.
            facId: 0.u64
            fbn: bareAtomName n: cond.operation
            if fbn.length > 0 then {
                ffo: (walkLookupTyperef
                    ty: st.typing
                    reg: st.reg
                    currentUnit: unitName
                    base: fbn.stringview
                )
                match (
                    ffo
                ) case some then {
                    if (st.reg.typetypeOf typeId: ffo) == ztypes.ztypetype.FUNCTION then {
                        if (methodHasNoUserArgs :st mid: ffo) then {
                            fro: methodReturnOf :st mid: ffo
                            match (
                                fro
                            ) case some then {
                                if (st.reg.typetypeOf typeId: fro) == ztypes.ztypetype.CLASS then {
                                    fco: st.typing.childOf parentTypeId: fro name: "call"
                                    match (
                                        fco
                                    ) case some then {
                                        facId = ffo
                                    } case none then {
                                    }
                                }
                            } case none then {
                            }
                        }
                    }
                } case none then {
                }
            }
            vt: 0.u64
            if facId > 0 then {
                # the factory's lazy walks (its body + the iterator class's
                # methods via return-first transitivity) fire before the
                # synthetic invocation's call scope opens.
                maybeWalkMethods :st :unitName :unitBody name: fbn.stringview
                fcm: st.pushCall
                vt = checkValue :st :unitName :unitBody node: cond.operation
                st.popTo marker: fcm
                fiid: innermostNodeId n: cond.operation
                if fiid > 0 then {
                    setff: facId
                    st.typing.nodeType.set key: fiid.u64 value: setff
                }
            } else {
                vt = checkValue :st :unitName :unitBody node: cond.operation
            }
            nm: unitLabel o: cond.name
            if nm.length > 0 when vt > 0 then {
                # A call-shaped iterator init probes its per-iteration call
                # in an empty call scope (the reference's rewrite walks it
                # once); gated on the value being an iterator wrapper.
                if (isCallNode n: cond.operation) then {
                    doProbe9: false
                    pw9: iterWrapperElem :st :unitName wid: vt
                    match (
                        pw9
                    ) case some then {
                        doProbe9 = true
                    } case none then {
                        ico9: st.typing.childOf parentTypeId: vt name: "call"
                        match (
                            ico9
                        ) case some then {
                            doProbe9 = true
                        } case none then {
                        }
                    }
                    if doProbe9 then {
                        ecm9: st.pushCall
                        st.popTo marker: ecm9
                    }
                }
                elem: 0.u64
                isView: false
                w1: iterWrapperElem :st :unitName wid: vt
                match (
                    w1
                ) case some then {
                    elem = w1
                    isView = isOptionViewMono :st :unitName wid: vt
                } case none then {
                }
                if elem == 0 then {
                    if (st.reg.typetypeOf typeId: vt) == ztypes.ztypetype.FUNCTION then {
                        r1: methodReturnOf :st mid: vt
                        match (
                            r1
                        ) case some then {
                            w2: iterWrapperElem :st :unitName wid: r1
                            match (
                                w2
                            ) case some then {
                                elem = w2
                                isView = isOptionViewMono :st :unitName wid: r1
                            } case none then {
                            }
                        } case none then {
                        }
                    } else {
                        c1: st.typing.childOf parentTypeId: vt name: "call"
                        match (
                            c1
                        ) case some then {
                            r2: methodReturnOf :st mid: c1
                            match (
                                r2
                            ) case some then {
                                w3: iterWrapperElem :st :unitName wid: r2
                                match (
                                    w3
                                ) case some then {
                                    elem = w3
                                    isView = isOptionViewMono :st :unitName wid: r2
                                } case none then {
                                }
                            } case none then {
                            }
                        } case none then {
                        }
                    }
                }
                if elem > 0 then {
                    if isView then {
                        srcName: atomName n: cond.operation
                        bo: "<iterator>".string
                        if srcName.length > 0 then bo = srcName.copy
                        v: st.reg.newVariable ztypeId: elem ownership: ztypes.zownership.BORROWED
                        v.borrowOrigin = (Option.some bo)
                        vid: v.variableId
                        st.defineVar name: nm.stringview var: v
                        condNid: nodeId n: cond.operation
                        st.typing.defVariableId.set key: condNid.u64 value: vid
                    } else {
                        st.define name: nm.stringview ztypeId: elem
                    }
                } else {
                    st.define name: nm.stringview ztypeId: vt
                }
            }
        } else {
        }
    }
    piter: fornode.postconditions.iterate
    for pc: piter loop {
        match (
            pc
        ) case namedoperation then {
            checkValue :st :unitName :unitBody node: pc.operation
        } else {
            checkValue :st :unitName :unitBody node: pc
        }
    }
    walkBody :st :unitName :unitBody bodyOpt: fornode.body
    elemT9: lastStmtTypeOpt :st bodyOpt: fornode.body
    if st.isUnreachable then st.discardTakenInCurrentScope
    st.popTo marker: forMarker
    # for-as-expression: a value-producing body makes the loop a List of
    # that element type (the comprehension form).
    if elemT9 > 0 then {
        en9: typeNameOf :st tid: elemT9
        isNull9: false
        if en9.stringview == "null" then isNull9 = true
        if en9.length == 0 then isNull9 = true
        if (isNull9) == false then {
            lto9: walkLookupTyperef ty: st.typing reg: st.reg currentUnit: unitName base: "List"
            match (
                lto9
            ) case some then {
                lsubs9: (Map String value: u64)
                lk9: "of".string
                lv9: elemT9
                lsubs9.set key: lk9 value: lv9
                lsfx9: "_\{en9}"
                lmn9: "List\{lsfx9}"
                vsG9: (Map String value: u64)
                lmid9: (getOrMintSpec
                    ty: st.typing
                    reg: st.reg
                    mainName: unitName
                    name: lmn9.stringview
                    templateId: lto9
                    subs: lsubs9
                    valSubs: vsG9
                    fallbackArg: 0
                )
                if lmid9 > 0 then {
                    setf9: lmid9
                    st.typing.nodeType.set key: fornode.nodeid.u64 value: setf9
                    return lmid9
                }
            } case none then {
            }
        }
    }
    return 0
}

# checkIf -- walk an if: push the `if` scope, then a `if_branch` scope per clause
# and an `if_else` scope for the else; when every branch diverges (returns) the
# if resolves to never and marks the enclosing scope unreachable.
# restoreTakenArm -- after a NON-diverging if arm, undo any takes of outer-scope
# owned vars (clearTaken) so the next arm + the restore see them live, recording
# them in `taken` for a single post-if invalidate. Without this a take in one arm
# propagates (via popTo) into the sibling arm, which then sees the var as gone and
# never stamps its type (e.g. an else-arm's `childpath.take` emitting `.take` on a
# String). Mirrors the reference _check_if_inner per-arm restore; the port's take
# is an overlay over a persisting entry, so clearTaken alone restores (no redefine).
restoreTakenArm: function {st: zenv.ZSymbolTable liveBefore: Set String taken: Set String} is {
    liveAfter: st.getLiveOwnedVars
    for vn: liveBefore.iterate loop {
        if (liveAfter.has item: vn) == false then {
            taken.add item: vn.copy
            st.clearTaken name: vn.stringview
        }
    }
}

# invalidateTakenAcross -- after the whole if, mark every var taken in some arm as
# taken in the enclosing scope (it is consumed on at least one path, so a later use
# is use-after-take).
invalidateTakenAcross: function {st: zenv.ZSymbolTable names: Set String} is {
    for vn: names.iterate loop {
        st.invalidate name: vn.stringview loc: (optionval.none ztypes.zsrcpos)
    }
}

checkIf: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    ifnode: zast.IfData
} out u64 is {
    ifMarker: st.pushBlock name: "if"
    liveBefore: st.getLiveOwnedVars
    takenAcross: (Set String)
    nvId: (optU64Or
        o: (walkLookupTyperef ty: st.typing reg: st.reg currentUnit: unitName base: "never")
        d: 0
    )
    branchTypes: (List u64)
    allDiverge: true
    cliter: ifnode.clauses.iterate
    for clause: cliter loop {
        bm: st.pushBlock name: "if_branch"
        bt9: checkClause :st :unitName :unitBody :clause
        btc: bt9
        branchTypes.append btc
        if st.isUnreachable then {
            # a diverging arm transfers ownership on a path that never reaches
            # fall-through: drop its take overlays before pop so they don't
            # bubble into the parent scope (where post-if uses would see the
            # variable as taken).
            st.discardTakenInCurrentScope
        } else {
            allDiverge = false
            restoreTakenArm :st :liveBefore taken: takenAcross
        }
        st.popTo marker: bm
    }
    hasElse: false
    match (
        ifnode.elseclause
    ) case some then {
        hasElse = true
        ebm: st.pushBlock name: "if_else"
        walkBody :st :unitName :unitBody bodyOpt: ifnode.elseclause
        et9: lastStmtTypeOpt :st bodyOpt: ifnode.elseclause
        etc9: et9
        branchTypes.append etc9
        if st.isUnreachable then {
            st.discardTakenInCurrentScope
        } else {
            allDiverge = false
            restoreTakenArm :st :liveBefore taken: takenAcross
        }
        st.popTo marker: ebm
    } case none then {
        allDiverge = false
    }
    result: 0.u64
    if allDiverge then {
        if nvId > 0 then {
            result = nvId
            setk: result
            st.typing.nodeType.set key: ifnode.nodeid.u64 value: setk
        }
    } else {
        # An exhaustive (else-carrying) if is a value: the first completing
        # branch's type, diverging branches skipped (mirrors the match rule).
        if hasElse then {
            ti9: 0.u64
            tn9: branchTypes.length
            for ti9 < tn9 loop {
                bt2: branchTypes.get i: ti9
                if bt2 != nvId then {
                    if bt2 > 0 then {
                        result = bt2
                        setv9: result
                        st.typing.nodeType.set key: ifnode.nodeid.u64 value: setv9
                        ti9 = tn9
                    } else {
                        ti9 = tn9
                    }
                }
                ti9 = ti9 + 1
            }
        }
    }
    st.popTo marker: ifMarker
    invalidateTakenAcross :st names: takenAcross
    if allDiverge then st.markUnreachable
    return result
}

# comparisonCoerceTarget -- the type a literal comparison operand coerces at:
# the concrete side's operator-child first-param type when resolvable (a
# boxed value's == is the element's, so the literal wears the element type),
# else the concrete side itself.
comparisonCoerceTarget: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    concrete: u64
    op: StringView
} out u64 is {
    opo9: st.typing.childOf parentTypeId: concrete name: op
    match (
        opo9
    ) case some then {
        p0n9: positionalParamName :st funcId: opo9 idx: 0 skipRecv: true
        if p0n9.length > 0 then {
            ppo9: st.typing.childOf parentTypeId: opo9 name: p0n9.stringview
            match (
                ppo9
            ) case some then {
                return ppo9
            } case none then {
            }
        }
    } case none then {
    }
    return concrete
}

# checkBinop -- type an arithmetic binop. Both operands are walked (so their
# nodes are stamped); the result is the lhs operand type (correct for same-type
# arithmetic -- full operator-method dispatch lands with a comparison example).
checkBinop: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    binop: zast.BinOpData
} out u64 is {
    result: 0.u64
    lt: checkValue :st :unitName :unitBody node: binop.lhs
    rt: checkValue :st :unitName :unitBody node: binop.rhs
    opn: atomName n: binop.operator
    if (isComparisonOp name: opn.stringview) then {
        boOpt: walkLookupTyperef ty: st.typing reg: st.reg currentUnit: unitName base: "bool"
        match (
            boOpt
        ) case some then {
            result = boOpt
        } case none then {
            result = lt
        }
        # A literal operand coerces (restamps) at the concrete side's type.
        lLit9: false
        if lt == literalIntId then lLit9 = true
        if lt == literalFloatId then lLit9 = true
        rLit9: false
        if rt == literalIntId then rLit9 = true
        if rt == literalFloatId then rLit9 = true
        if lLit9 when rLit9 then {} else {
            if lLit9 when rt > 0 then {
                lct9: comparisonCoerceTarget :st :unitName concrete: rt op: opn.stringview
                lid9: innermostNodeId n: binop.lhs
                if lid9 > 0 then {
                    setlc9: lct9
                    st.typing.nodeType.set key: lid9.u64 value: setlc9
                }
            }
            if rLit9 when lt > 0 then {
                rct9: comparisonCoerceTarget :st :unitName concrete: lt op: opn.stringview
                rid9: innermostNodeId n: binop.rhs
                if rid9 > 0 then {
                    setrc9: rct9
                    st.typing.nodeType.set key: rid9.u64 value: setrc9
                }
            }
        }
    } else {
        result = lt
        # Operator children delegate (a boxed value's `+` is the element's,
        # so the result is the element type, not the box).
        opo: st.typing.childOf parentTypeId: lt name: opn.stringview
        match (
            opo
        ) case some then {
            oro: methodReturnOf :st mid: opo
            match (
                oro
            ) case some then {
                result = oro
            } case none then {
            }
        } case none then {
        }
    }
    tdb2: typedefBaseOf :st :unitName tid: result
    if tdb2 > 0 then result = tdb2
    if result > 0 when (st.reg.typetypeOf typeId: result) == ztypes.ztypetype.GENERIC_PARAM then {
        # Structural pass-through: the SAME parameter on both sides flows
        # through arithmetic as itself (the per-instance clone checks remain
        # the arithmetic backstop); mixed operands stay untyped.
        if (result == rt) == false then return 0
    }
    if result > 0 then stampGate :st nid: binop.nodeid tid: result
    return result
}

# argIsTrivial -- true when a call argument's operation is a hoisting no-op: a
# bare atom, a labelvalue, a string literal without interpolation, or an
# expression wrapping a bare atom / labelvalue. Anything else (binop, call,
# dotted path, interpolated string) hoists into a synth temp.
argIsTrivial: function {op: Node} out bool is {
    match (
        op
    ) case atomid then {
        return true
    } case labelvalue then {
        return true
    } case atomstring then {
        spiter: op.stringparts.iterate
        for sp: spiter loop {
            match (
                sp
            ) case stringchunk then {
            } else {
                return false
            }
        }
        return true
    } case expression then {
        match (
            op.expression
        ) case atomid then {
            return true
        } case labelvalue then {
            return true
        } else {
            return false
        }
    } else {
        return false
    }
}

# hoistArg -- hoist a non-trivial call argument into a fresh `_tN` synth temp:
# define the temp (OWNED, synth origin anf) in the open CALL scope and record
# the synth Assignment / value-Expression / AtomId rows + their type stamps so
# the dump matches the reference's hoisted tree. The parsed argument keeps its
# own stamps; only the dump rows are synthesised (no AST mutation).
# typeIsReftype -- a registered type whose isValtype flag is explicitly false
# (classes, unions, protocols, heap natives like String). Unset or unregistered
# ids are not reftypes.
typeIsReftype: function {st: zenv.ZSymbolTable tid: u64} out bool is {
    zo: st.reg.typeById.get key: tid
    match (
        zo
    ) case some then {
        vt: zo.isValtype
        match (
            vt
        ) case some then {
            return vt == false
        } case none then {
            return false
        }
    } case none then {
        return false
    }
}

# typeIsValtype -- a registered type whose isValtype flag is explicitly true
# (records, variants, facets, primitives). Unset or unregistered ids are not
# valtypes.
typeIsValtype: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry tid: u64} out bool is {
    zo: reg.typeById.get key: tid
    match (
        zo
    ) case some then {
        vt: zo.isValtype
        match (
            vt
        ) case some then {
            return vt == true
        } case none then {
            return false
        }
    } case none then {
        return false
    }
}

# innermostNodeId -- the node id of a value with its expression wrappers
# stripped (the node the dump's descent reads first); 0 for uncovered kinds.
innermostNodeId: function {n: Node} out u32 is {
    match (
        n
    ) case expression then {
        return (innermostNodeId n: n.expression)
    } else {
        return (nodeId :n)
    }
}

# bareAtomName -- the (expression-unwrapped) bare atom name of a value node,
# or "" when the value is any other shape.
bareAtomName: function {n: Node} out String is {
    match (
        n
    ) case expression then {
        return (bareAtomName n: n.expression)
    } case atomid then {
        return n.name.copy
    } else {
        return "".string
    }
}

# methodReceiverRoot -- the bare root name of a dotted callable's receiver
# (`a.compare` -> a), "" for non-dotted or non-bare receivers.
methodReceiverRoot: function {n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        return (bareAtomName n: n.parent)
    } else {
        return "".string
    }
}

# methodReceiverTuple -- the full dotted path of a method call's receiver
# (everything before the method name): `st.reg.unitNameTid.get` -> [st, reg,
# unitNameTid]. Empty when the callable is not a dotted path or the receiver
# is not a plain path. Path-scoped locks need the full tuple so sibling
# fields stay independent.
methodReceiverTuple: function {n: Node dst: List String} is {
    match (
        n
    ) case dottedpath then {
        appendValueTuple n: n.parent :dst
    } else {
    }
}

# dottedParentNodeId -- the nodeid of a dotted callable's receiver expression
# (its stamped type is the immediate receiver type); 0 otherwise.
dottedParentNodeId: function {n: Node} out u32 is {
    match (
        n
    ) case dottedpath then {
        return (nodeId n: n.parent)
    } else {
        return 0
    }
}

# positionalParamName -- the funcId's parameter name at `idx` (typeChild
# position order), "" when absent. Positional call args map to it. With
# skipRecv, receiver rows (`this` or the fn's thisParamName) are excluded
# from the count: a dotted method call supplies the receiver implicitly, so
# its positional args map onto the remaining params.
positionalParamName: function {
    st: zenv.ZSymbolTable
    funcId: u64
    idx: u64
    skipRecv: bool
} out String is {
    result: "".string
    found: false
    seen: 0.u64
    bp9: st.typing.childIndex.get key: funcId
    match (
        bp9
    ) case some then {
        with rpit9: bp9.rows.iterate do for rpi9: rpit9 loop {
            tc: st.typing.typeChild.get i: rpi9
            if (found) == false then {
                isRecv9: false
                if skipRecv then {
                    if tc.childName.stringview == "this" then isRecv9 = true
                    zoR9: st.reg.typeById.get key: funcId
                    match (
                        zoR9
                    ) case some then {
                        if (optStrEquals o: zoR9.thisParamName s: tc.childName.stringview) then {
                            isRecv9 = true
                        }
                    } case none then {}
                }
                if (isRecv9) == false then {
                    if seen == idx then {
                        result = tc.childName.copy
                        found = true
                    }
                    seen = seen + 1
                }
            }
        }
    } case none then {}
    return result
}

# lockCallArg -- the call-scoped EXCLUSIVE lock a lock/borrow parameter takes
# on its argument's root for the call's duration (the symtab appends the lock
# overlay entry in the open call scope; it vanishes when the scope pops).
lockCallArg: function {
    st: zenv.ZSymbolTable
    name: StringView
    callId: u64
    shared: bool
    nodeid: u32
    lineno: u32
    colno: u32
} is {
    pth: (List String)
    nm: name.string
    pth.append nm
    h: (ztypes.zlockholder kind: ztypes.zlockholderkind.CALL id: callId)
    h2: (ztypes.zlockholder kind: ztypes.zlockholderkind.CALL id: callId)
    clk9: ztypes.zlockstate.EXCLUSIVE
    if shared then clk9 = ztypes.zlockstate.SHARED
    r: st.tryLock path: pth lockType: clk9 holder: h hasSelfHolder: true selfHolder: h2
    if r.length > 0 then addError :st :nodeid :lineno :colno e: zast.err.OWNERERROR msg: r
}

# lockCallPath -- call-scoped path lock over a full receiver tuple: SHARED
# on the strict prefixes, reader/writer kind on the leaf. Same-call locks
# share the CALL holder identity (self-idempotent).
lockCallPath: function {
    st: zenv.ZSymbolTable
    path: List String
    callId: u64
    shared: bool
    nodeid: u32
    lineno: u32
    colno: u32
} is {
    n: path.length
    if n == 0 then return
    end: 1.u64
    for end < n loop {
        sub: (List String)
        i: 0.u64
        for i < end loop {
            e: path.get :i
            ec: e.copy
            sub.append ec
            i = i + 1
        }
        hs: (ztypes.zlockholder kind: ztypes.zlockholderkind.CALL id: callId)
        hs2: (ztypes.zlockholder kind: ztypes.zlockholderkind.CALL id: callId)
        rs: (st.tryLock
            path: sub
            lockType: ztypes.zlockstate.SHARED
            holder: hs
            hasSelfHolder: true
            selfHolder: hs2
        )
        if rs.length > 0 then addError :st :nodeid :lineno :colno e: zast.err.OWNERERROR msg: rs
        end = end + 1
    }
    full: (List String)
    j: 0.u64
    for j < n loop {
        e2: path.get i: j
        ec2: e2.copy
        full.append ec2
        j = j + 1
    }
    he: (ztypes.zlockholder kind: ztypes.zlockholderkind.CALL id: callId)
    he2: (ztypes.zlockholder kind: ztypes.zlockholderkind.CALL id: callId)
    clk9: ztypes.zlockstate.EXCLUSIVE
    if shared then clk9 = ztypes.zlockstate.SHARED
    re: st.tryLock path: full lockType: clk9 holder: he hasSelfHolder: true selfHolder: he2
    if re.length > 0 then addError :st :nodeid :lineno :colno e: zast.err.OWNERERROR msg: re
}

# lockSuffixBase -- the bare base name of a `<atom>.lock` argument, ""
# otherwise.
lockSuffixBase: function {n: Node} out String is {
    match (
        n
    ) case expression then {
        return (lockSuffixBase n: n.expression)
    } case dottedpath then {
        ln: atomName n: n.child
        if ln.stringview == "lock" then {
            return (bareAtomName n: n.parent)
        } else {
            return "".string
        }
    } else {
        return "".string
    }
}

# takenHere -- the location stamp an ownership-transfer overlay carries (pop
# propagates only located takes into the enclosing scope).
takenHere: function {} out optionval ztypes.zsrcpos is {
    return (optionval.some (ztypes.zsrcpos fsno: 0 lineno: 0 colno: 0))
}

# appendValueTuple -- the dotted-path tuple of a value node (root first),
# appended onto dst; non-path shapes contribute nothing.
appendValueTuple: function {n: Node dst: List String} is {
    match (
        n
    ) case expression then {
        appendValueTuple n: n.expression :dst
    } case atomid then {
        nm: n.name.copy
        dst.append nm
    } case dottedpath then {
        appendValueTuple n: n.parent :dst
        cn: atomName n: n.child
        if cn.length > 0 then dst.append cn
    } else {
    }
}

# drainPendingBorrow / takePendingBorrow -- clear the borrow side-channel /
# move it into a local list (root-first order preserved).
drainPendingBorrow: function {st: zenv.ZSymbolTable} is {
    for st.typing.pendingBorrowPath.length > 0 loop {
        pd: st.typing.pendingBorrowPath.pop
    }
    st.typing.pendingBorrowShared = false
}

takePendingBorrow: function {st: zenv.ZSymbolTable dst: List String} is {
    n: st.typing.pendingBorrowPath.length
    i: 0.u64
    for i < n loop {
        e: st.typing.pendingBorrowPath.get :i
        ec: e.copy
        dst.append ec
        i = i + 1
    }
    sh9: st.typing.pendingBorrowShared
    drainPendingBorrow :st
    st.typing.pendingBorrowShared = sh9
}

# installBorrowLocks -- SHARED on every path prefix, EXCLUSIVE on the leaf
# (the symtab appends one lock overlay entry per acquisition, keyed by the
# path root -- the oracle's non-definition rows). Holder = the binding var.
installBorrowLocks: function {
    st: zenv.ZSymbolTable
    src: List String
    vid: u64
    leafShared: bool
    nodeid: u32
    lineno: u32
    colno: u32
} is {
    n: src.length
    if n == 0 then return
    end: 1.u64
    for end < n loop {
        sub: (List String)
        i: 0.u64
        for i < end loop {
            e: src.get :i
            ec: e.copy
            sub.append ec
            i = i + 1
        }
        hs: (ztypes.zlockholder kind: ztypes.zlockholderkind.VAR id: vid)
        hs2: (ztypes.zlockholder kind: ztypes.zlockholderkind.VAR id: vid)
        rs: (st.tryLock
            path: sub
            lockType: ztypes.zlockstate.SHARED
            holder: hs
            hasSelfHolder: false
            selfHolder: hs2
        )
        if rs.length > 0 then addError :st :nodeid :lineno :colno e: zast.err.OWNERERROR msg: rs
        end = end + 1
    }
    full: (List String)
    j: 0.u64
    for j < n loop {
        e2: src.get i: j
        ec2: e2.copy
        full.append ec2
        j = j + 1
    }
    he: (ztypes.zlockholder kind: ztypes.zlockholderkind.VAR id: vid)
    he2: (ztypes.zlockholder kind: ztypes.zlockholderkind.VAR id: vid)
    lk9: ztypes.zlockstate.EXCLUSIVE
    if leafShared then lk9 = ztypes.zlockstate.SHARED
    re: st.tryLock path: full lockType: lk9 holder: he hasSelfHolder: false selfHolder: he2
    if re.length > 0 then addError :st :nodeid :lineno :colno e: zast.err.OWNERERROR msg: re
}

# isLiteralTypeId -- a literal-typed value: the unregistered int/float pseudo
# ids, or a data block's registered literal_int/literal_float element shell.
isLiteralTypeId: function {st: zenv.ZSymbolTable tid: u64} out bool is {
    if tid == literalIntId then return true
    if tid == literalFloatId then return true
    nm: typeNameOf :st :tid
    if nm.stringview == "literal_int" then return true
    return nm.stringview == "literal_float"
}

hoistArg: function {
    st: zenv.ZSymbolTable
    argNode: Node
    argType: u64
    paramType: u64
    consumes: bool
} out String is {
    tn: st.typing.nextTempId
    st.typing.nextTempId = tn + 1
    tname: "_t\{tn}"
    ln: nodeLine n: argNode
    co: nodeCol n: argNode
    assignId: st.typing.nextSynthNodeId
    exprId: assignId + 1
    atomId: assignId + 2
    st.typing.nextSynthNodeId = assignId + 3
    st.typing.synthNodes.append (ztyping.SynthNode
        nodeid: assignId
        kind: "Assignment".string
        label: st.typing.synthLabel.copy
        lineno: ln
        colno: co)
    st.typing.synthNodes.append (ztyping.SynthNode
        nodeid: exprId
        kind: "Expression".string
        label: st.typing.synthLabel.copy
        lineno: ln
        colno: co)
    st.typing.synthNodes.append (ztyping.SynthNode
        nodeid: atomId
        kind: "AtomId".string
        label: st.typing.synthLabel.copy
        lineno: ln
        colno: co)
    seta: argType
    st.typing.nodeType.set key: assignId.u64 value: seta
    sete: argType
    st.typing.nodeType.set key: exprId.u64 value: sete
    atomT: argType
    if paramType > 0 then atomT = paramType
    setm: atomT
    st.typing.nodeType.set key: atomId.u64 value: setm
    hbsrc: (List String)
    takePendingBorrow :st dst: hbsrc
    hown: ztypes.zownership.OWNED
    if hbsrc.length > 0 when (typeIsReftype :st tid: argType) then hown = ztypes.zownership.BORROWED
    v: st.reg.newVariable ztypeId: argType ownership: hown
    v.synthOrigin = (Option.some "anf".string)
    if hown == ztypes.zownership.BORROWED then {
        hr0: hbsrc.get i: 0
        hbo: hr0.copy
        v.borrowOrigin = (Option.some hbo)
    }
    vid: v.variableId
    st.defineVar name: tname.stringview var: v
    # No borrow locks for the hoisted temp: it lives only for the call, whose
    # own arg/receiver locks already cover the path -- a VAR-holder lock here
    # would conflict with the call's CALL-holder locks on the same path.
    st.typing.defVariableId.set key: assignId.u64 value: vid
    if consumes then st.invalidate name: tname.stringview loc: (optionval.none ztypes.zsrcpos)
    return tname
}

# walkCallArgsHoist -- the user-call argument walk: type each argument, then
# hoist non-trivial ones into synth temps (mirrors _check_call_arguments).
# isConfMarkerId -- the (tid, name) child is an as-block conformance/satisfaction
# marker (not a data field) when a conformance row records it.
isConfMarkerId: function {conf: List ztypes.ZConformance tid: u64 name: StringView} out bool is {
    found: false
    with citer: conf.iterate do for row: citer loop {
        if row.implTypeId == tid when row.label.stringview == name then found = true
    }
    return found
}

# dataFieldNames -- a type's user-supplied data fields/params in order (the
# ztypecheck-side mirror of the emitter's recFieldLists): for a FUNCTION, all
# params; for a record/class, fnptr fields plus non-FUNCTION fields, excluding
# as-block constants (asConstClone) and conformance markers.
dataFieldNames: function {st: zenv.ZSymbolTable tid: u64 names: List String ids: List u64} is {
    isFn: false
    if (st.reg.typetypeOf typeId: tid) == ztypes.ztypetype.FUNCTION then isFn = true
    # this type's conformance-marker labels, collected once (the per-field
    # probe below is a scan over these few names, not the whole table)
    mkNames8: (List String)
    if isFn == false then {
        with cfit8: st.typing.conformance.iterate do for crow8: cfit8 loop {
            if crow8.implTypeId == tid then mkNames8.append crow8.label.copy
        }
    }
    bd9: st.typing.childIndex.get key: tid
    match (
        bd9
    ) case some then {
        with rdit9: bd9.rows.iterate do for rdi9: rdit9 loop {
            tc: st.typing.typeChild.get i: rdi9
            cto: optU64Or o: (st.typing.childTypeById.get key: tc.childNameId) d: 0
            inc: false
            if isFn then {
                inc = true
            } else {
                fptr: false
                fpo: st.typing.childIsFnptrField.get key: tc.childNameId
                match (
                    fpo
                ) case some then {
                    fptr = fpo
                } case none then {}
                if fptr then {
                    inc = true
                } else {
                    if cto > 0 when (st.reg.typetypeOf typeId: cto) != ztypes.ztypetype.FUNCTION then {
                        isC: false
                        aco: st.typing.asConstClone.get key: cto
                        match (
                            aco
                        ) case some then {
                            isC = aco
                        } case none then {}
                        isMk8: false
                        mi8: 0.u64
                        mn8: mkNames8.length
                        for mi8 < mn8 loop {
                            mv8: mkNames8.get i: mi8
                            if mv8.stringview == tc.childName.stringview then isMk8 = true
                            mi8 = mi8 + 1
                        }
                        if isC == false when isMk8 == false then inc = true
                    }
                }
            }
            if inc then {
                cnx: tc.childName.copy
                names.append cnx
                idx0: cto
                ids.append idx0
            }
        }
    } case none then {}
}

# checkMissingCallArgs -- report each required field/param (no default) a call or
# construction did not provide. The method receiver is implicitly bound; a
# construction's FUNCTION-typed (fnptr) fields are auto-bound.
checkMissingCallArgs: function {
    st: zenv.ZSymbolTable
    call: zast.CallData
    funcId: u64
    isCtor: bool
} is {
    mcb0: metaCreateBaseId n: call.callable
    match (
        mcb0
    ) case some then {
        return
    } case none then {}
    fzNat9: false
    {
        fzo9: st.reg.typeById.get key: funcId
        match (
            fzo9
        ) case some then {
            if fzo9.isNative then fzNat9 = true
        } case none then {}
    }
    if fzNat9 then return
    effId: funcId
    if isCtor then {
        crId: optU64Or o: (st.typing.childOf parentTypeId: funcId name: "create") d: 0
        if crId > 0 when (st.reg.typetypeOf typeId: crId) == ztypes.ztypetype.FUNCTION then {
            crBody9: false
            crn9: st.typing.funcReturnNode.get key: crId
            match (
                crn9
            ) case some then {
                crBody9 = true
            } case none then {}
            if crBody9 then effId = crId
        }
    }
    names: (List String)
    ids: (List u64)
    dataFieldNames :st tid: effId :names :ids
    pcnt: names.length
    if pcnt == 0 then return
    posCount: 0.u64
    with aiter: call.arguments.iterate do for arg: aiter loop {
        match (
            arg
        ) case namedoperation then {
            an: unitLabel o: arg.name
            if an.length == 0 then posCount = posCount + 1
        } else {}
    }
    thisPn9: "".string
    {
        zoR: st.reg.typeById.get key: effId
        match (
            zoR
        ) case some then {
            thisPn9 = optStrOrEmpty o: zoR.thisParamName
        } case none then {}
    }
    vpos: 0.u64
    i: 0.u64
    for i < pcnt loop {
        pname: names.get :i
        pcid: ids.get :i
        i = i + 1
        isRecv9: false
        if pname.stringview == "this" then isRecv9 = true
        if thisPn9.length > 0 when thisPn9.stringview == pname.stringview then isRecv9 = true
        if (isRecv9) == false then {
            posI: vpos
            vpos = vpos + 1
            need: true
            if isCtor when (st.reg.typetypeOf typeId: pcid) == ztypes.ztypetype.FUNCTION then {
                # only a body-carrying fn type defaults the field (a bodyless
                # SPEC field requires the reference); record and class
                # constructions fill the omitted slot with the field type's
                # symbol (the fnptr-field fill in the emitter's create path)
                fhbOk9: optBoolOr o: (st.typing.fnHasBody.get key: pcid) d: false
                effTT9: st.reg.typetypeOf typeId: effId
                ctorFill9: false
                if effTT9 == ztypes.ztypetype.RECORD then ctorFill9 = true
                if effTT9 == ztypes.ztypetype.CLASS then ctorFill9 = true
                if fhbOk9 when ctorFill9 then need = false
            }
            if (st.typing.hasChildDefault parentTypeId: effId name: pname.stringview) then {
                need = false
            }
            if need then {
            prov: false
            if posI < posCount then prov = true
            with niter: call.arguments.iterate do for narg: niter loop {
                match (
                    narg
                ) case namedoperation then {
                    nn: unitLabel o: narg.name
                    if nn.length > 0 when nn.stringview == pname.stringview then prov = true
                } else {}
            }
            if (prov) == false then {
                tnm: typeNameOf :st tid: pcid
                tnc: tnm.copy
                pnc: pname.copy
                mm: "missing required argument '\{pnc}' (type: \{tnc})"
                (addError
                    :st
                    nodeid: call.nodeid
                    lineno: call.lineno
                    colno: call.colno
                    e: zast.err.CALLERROR
                    msg: mm
                )
                }
            }
        }
    }
}

walkCallArgsHoist: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    unitBody: List Node
    call: zast.CallData
    funcId: u64
    isCtor: bool
    reportUnknown: bool
    recvImplicit: bool
} out String is {
    lockRoot: "".string
    st.typing.lastLockParamRoot = "".string
    argIdx: 0.u64
    boundArgIds: (List u64)
    aiter: call.arguments.iterate
    for arg: aiter loop {
        match (
            arg
        ) case namedoperation then {
            # a FUNCTION-typed field takes a method REFERENCE: its ctor
            # argument walks without the value-position auto-call coercion.
            useNC: false
            if isCtor then {
                pn0: unitLabel o: arg.name
                if pn0.length > 0 then {
                    fco: st.typing.childOf parentTypeId: funcId name: pn0.stringview
                    fcid: optU64Or o: fco d: 0
                    if fcid > 0 then {
                        if (st.reg.typetypeOf typeId: fcid) == ztypes.ztypetype.FUNCTION then {
                            useNC = true
                        }
                    }
                }
            }
            vt: 0.u64
            if useNC then {
                vt = valueNoCoerce :st :unitName :unitBody n: arg.operation
            } else {
                vt = checkValue :st :unitName :unitBody node: arg.operation
            }
            if vt > 0 then {
                pn: unitLabel o: arg.name
                if (isCtor) == false when pn.length > 0 when funcId > 0 then {
                    if (st.typing.childCount parentTypeId: funcId) > 0 then {
                        pco9: st.typing.childOf parentTypeId: funcId name: pn.stringview
                        pcidX9: optU64Or o: pco9 d: 0
                        if pcidX9 == 0 then {
                            pnc9: pn.copy
                            m2: "unknown argument '\{pnc9}'"
                            anid9: arg.nodeid
                            anln9: arg.lineno
                            ancl9: arg.colno
                            sug2: suggestSimilar :st parentTypeId: funcId name: pn.stringview
                            h2: "".string
                            if sug2.length > 0 then {
                                sgc2: sug2.copy
                                hh2: "did you mean '\{sgc2}'?"
                                h2 = hh2
                            }
                            en2: "".string
                            (addErrorH
                                :st
                                nodeid: anid9
                                lineno: anln9
                                colno: ancl9
                                e: zast.err.CALLERROR
                                msg: m2
                                note: en2
                                hint: h2
                                width: pn.length.u32
                            )
                        } else {
                            ptid9: pcidX9
                            if ptid9 > 0 when vt > 0 then {
                                if (typesCompatible :st :unitName a: vt b: ptid9) == false then {
                                    skipMM9: false
                                    if (isNumericTid
                                        ty: st.typing
                                        reg: st.reg
                                        tid: vt
                                    ) when (isNumericTid
                                        ty: st.typing
                                        reg: st.reg
                                        tid: ptid9
                                    ) then skipMM9 = true
                                    ptt9: st.reg.typetypeOf typeId: ptid9
                                    if ptt9 == ztypes.ztypetype.PROTOCOL then skipMM9 = true
                                    if ptt9 == ztypes.ztypetype.FACET then skipMM9 = true
                                    if ptt9 == ztypes.ztypetype.GENERIC_PARAM then skipMM9 = true
                                    if ptt9 == ztypes.ztypetype.FUNCTION then skipMM9 = true
                                    if (skipMM9) == false then {
                                        en7: typeNameOf :st tid: ptid9
                                        an7: typeNameOf :st tid: vt
                                        enc7: en7.copy
                                        anc7: an7.copy
                                        pnc7: pn.copy
                                        mm7: "argument '\{pnc7}' type mismatch: expected \{enc7}, got \{anc7}"
                                        en7b: "".string
                                        eh7: "".string
                                        (addErrorH
                                            :st
                                            nodeid: arg.nodeid
                                            lineno: arg.lineno
                                            colno: arg.colno
                                            e: zast.err.CALLERROR
                                            msg: mm7
                                            note: en7b
                                            hint: eh7
                                            width: pn.length.u32
                                        )
                                    }
                                }
                            }
                        }
                    }
                }
                if reportUnknown when (isCtor) == false when pn.length == 0 when funcId > 0 then {
                    if (st.typing.childCount parentTypeId: funcId) == 0 then {
                        if (st.reg.typetypeOf typeId: funcId) == ztypes.ztypetype.FUNCTION then {
                            tmm9: "too many arguments: function takes no parameters".string
                            (addError
                                :st
                                nodeid: arg.nodeid
                                lineno: arg.lineno
                                colno: arg.colno
                                e: zast.err.CALLERROR
                                msg: tmm9
                            )
                        }
                    }
                }
                wasPos9: false
                if pn.length == 0 then {
                    wasPos9 = true

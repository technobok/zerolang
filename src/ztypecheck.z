# valueNoCoerce -- checkValue minus the value-position auto-call coercion
# (construction arguments take method REFERENCES for function-typed fields).
valueNoCoerce: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) n: Node} out u64 is {

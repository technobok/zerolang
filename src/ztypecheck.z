                isLockish: false
                isDeclLock: false
                pt: 0.u64
                if funcId > 0 when pn.length > 0 then {
                    if (isLiteralTypeId :st tid: vt) then {
                        po: st.typing.childOf parentTypeId: funcId name: pn.stringview
                        match (
                            po
                        ) case some then {
                            pt = po
                        } case none then {
                        }
                    }
                    cnid: st.typing.childIdFor parentTypeId: funcId name: pn.stringview
                    oo: st.typing.childOwnership.get key: cnid
                    match (
                        oo
                    ) case some then {
                        if oo == ztypes.zparamownership.TAKE then isTake = true
                        if oo == ztypes.zparamownership.LOCK then {
                            isLockish = true
                            isDeclLock = true

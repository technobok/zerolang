                                            }
                                        }
                                    }
                                } else null
                            }
                            setuc: dtp
                            st.typing.nodeType.set key: call.nodeid.u64 value: setuc
                            (st.typing.callKind.set
                                key: call.nodeid.u64
                                value: zast.callkind.unionCreate
                            )
                            return dtp
                        }
                    } else {
                        # a GENERIC FUNCTION member (io.eprintln) dispatches
                        # through the generic-call machinery like its bare-
                        # name form.
                        isGenF: false
                        {
                            gf9: st.reg.typeById.get key: dro
                            match (
                                gf9
                            ) case some then {
                                if gf9.typetype == ztypes.ztypetype.functionType then {
                                    if gf9.isgeneric then isGenF = true
                                }
                            } case none then null
                        }
                        if isGenF then {
                            gfr: checkGenericCall :st :unitName :ast :unitBody :call funcId: dro
                            if gfr > 0 then {
                                setgf: gfr
                                st.typing.nodeType.set key: call.nodeid.u64 value: setgf
                            }

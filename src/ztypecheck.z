                    pn = pp
                }
                if funcId > 0 when pn.length > 0 then {
                    dcnid9: st.typing.childIdFor parentTypeId: funcId name: pn.stringview
                    dupSeen9: false
                    with bIt9: boundArgIds.iterate do for bId9: bIt9 loop {
                        if bId9 == dcnid9 then dupSeen9 = true
                    }
                    if dupSeen9 when reportUnknown then {
                        pncD9: pn.copy
                        dmm9: "argument '\{pncD9}' specified more than once"
                        (addError
                            :st
                            nodeid: arg.nodeid
                            lineno: arg.lineno
                            colno: arg.colno
                            e: zast.err.CALLERROR
                            msg: dmm9
                        )
                    } else {
                        boundArgIds.append dcnid9
                    }
                    if wasPos9 when (isCtor) == false then {
                        cpidP9: (optU64Or
                            o: (st.typing.childOf parentTypeId: funcId name: pn.stringview)
                            d: 0
                        )
                        if cpidP9 > 0 then {
                            ptidP9: cpidP9
                            if ptidP9 > 0 when vt > 0 then {
                                if (typesCompatible :st :unitName a: vt b: ptidP9) == false then {
                                    skipP9: false
                                    if (isNumericTid
                                        ty: st.typing
                                        reg: st.reg
                                        tid: vt
                                    ) when (isNumericTid
                                        ty: st.typing
                                        reg: st.reg
                                        tid: ptidP9
                                    ) then skipP9 = true
                                    pttP9: st.reg.typetypeOf typeId: ptidP9
                                    if pttP9 == ztypes.ztypetype.PROTOCOL then skipP9 = true
                                    if pttP9 == ztypes.ztypetype.FACET then skipP9 = true
                                    if pttP9 == ztypes.ztypetype.GENERIC_PARAM then skipP9 = true
                                    if pttP9 == ztypes.ztypetype.FUNCTION then skipP9 = true
                                    if (skipP9) == false then {
                                        enP9: typeNameOf :st tid: ptidP9
                                        anP9: typeNameOf :st tid: vt
                                        encP9: enP9.copy
                                        ancP9: anP9.copy
                                        tmmP9: "argument type mismatch: expected \{encP9}, got \{ancP9}"
                                        enP9b: "".string
                                        ehP9: "".string
                                        (addErrorH
                                            :st
                                            nodeid: arg.nodeid
                                            lineno: arg.lineno
                                            colno: arg.colno
                                            e: zast.err.CALLERROR
                                            msg: tmmP9
                                            note: enP9b
                                            hint: ehP9
                                            width: pn.length.u32
                                        )
                                    }
                                }
                            }
                        }
                    }
                }

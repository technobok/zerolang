                    # `.create` constructs, so the result is the base type.
                    if mres == 0 then {
                        cdb: createDottedBaseId :ast n: (ast.nodes.get i: (call.callable - 1).u64)
                        cdbid: u32
                        match (
                            cdb
                        ) case some then {
                            cdbid = cdb

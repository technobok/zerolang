                return (resolveChildPayload st: st unitName: unitName cid: ppo9)
            } case none then {
            }
        } else {
        }
    } case none then {
    }
    return concrete
}

# checkBinop -- type an arithmetic binop. Both operands are walked (so their
# nodes are stamped); the result is the lhs operand type (correct for same-type
# arithmetic -- full operator-method dispatch lands with a comparison example).
checkBinop: function {st: zenv.ZSymbolTable unitName: StringView unitBody: (List of: Node) binop: zast.BinOpData} out u64 is {
    result: 0.u64
    lt: checkValue st: st unitName: unitName unitBody: unitBody node: binop.lhs
    rt: checkValue st: st unitName: unitName unitBody: unitBody node: binop.rhs
    opn: atomName n: binop.operator
    if (isComparisonOp name: opn.stringview) then {
        boOpt: lookupTyperef resolved: st.typing.resolved mainName: unitName base: "bool"
        match (
            boOpt
        ) case some then {
            result = boOpt
        } case none then {
            result = lt
        }
        # A literal operand coerces (restamps) at the concrete side's type.
        lLit9: false
        if lt == literalIntId then { lLit9 = true } else {
        }
        if lt == literalFloatId then { lLit9 = true } else {
        }
        rLit9: false
        if rt == literalIntId then { rLit9 = true } else {
        }
        if rt == literalFloatId then { rLit9 = true } else {
        }
        if lLit9 when rLit9 then {} else {
            if lLit9 when rt > 0.u64 then {
                lct9: comparisonCoerceTarget st: st unitName: unitName concrete: rt op: opn.stringview

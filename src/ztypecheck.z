                    }
                }
            }
            if isBox then {
                bres: checkBoxConstruction :st :unitName :unitBody :call tplId: funcId
                if bres > 0 then return bres
            }
            if isGen then {
                gtt: st.reg.typetypeOf typeId: funcId
                if gtt != ztypes.ztypetype.FUNCTION then {
                    errB9: st.typing.errors.length
                    vok9: validateGenericTypeArgs :st :unitName :call tplId: funcId allowFrom: false
                    gres: genericTypeConstruction :st :unitName :call tplId: funcId
                    if gres > 0 then return gres

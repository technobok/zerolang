                            drainPendingBorrow :st
                            mlrc: mlr.copy
                            st.typing.pendingBorrowPath.append mlrc
                            if (returnIsIteratorTid :st tid: mres) == false then {
                                st.typing.pendingBorrowShared = true
                            }
                        }
                    }

# Type checker, ported from src/ztypecheck.py.
#
# Slice 4.5a: registers one UNIT type per unit (the `unit` table) and resolves
# the MAIN unit's top-level FUNCTION definition signatures into the type
# registry -- each function plus its parameter children, with referenced
# parameter types registered as shallow named shells. Mirrors the reference
# `resolve_only_main` capability (no body walk, no generics, no system-wide
# resolution); the SQL `types` / `type_children` tables read the result,
# filtered to the example's own unit. Data blocks, records, variants, classes,
# generics and body checking arrive in later slices.
#
# The registry is created by the caller and threaded in (not stored on the
# ZTyping container), mirroring the reference's module-level type table: the
# SQL dumper reads it as a separate argument.

Node: zast.Node
Ast: zast.Ast

# Well-known Ast.names pool ids (fixed by Ast.create's intern order in
# zast.z -- the authority).
wkThis: 1.u32
wkReturn: 2.u32
wkBreak: 3.u32
wkContinue: 4.u32

# Well-known member-name pool ids (zast.z is the authority; append-only),
# widened to u64 for ZTypeChild.nameId keys.
wkThisMember: 1.u64
wkCreate: 5.u64
wkBorrow: 6.u64
wkCall: 7.u64
wkGet: 8.u64
wkRemove: 11.u64
wkLength: 15.u64
wkCapacity: 16.u64
wkSize: 17.u64
wkValue: 19.u64
wkSome: 21.u64
wkTag: 22.u64
wkState: 23.u64
wkOpEq: 29.u64
wkOpNe: 30.u64
wkResumeInput: 31.u64

# unitdefNodeId -- the nodeid of the unit row an id names (0 when the id does
# not name a unit). The row view is scoped to the fetch.
unitdefNodeId: function {ast: Ast nId: u32} out u32 is {
    out9: u32
    {
        n9: ast.nodes.get i: (nId - 1).u64
        if n9.unitdef then out9 = n9.nodeid
    }
    return out9
}

# nodeId -- the nodeid of an arbitrary type-ref / definition Node. Covers the
# kinds a type expression or method def can take (atom / labelvalue / dotted /
# expression / call / functiondef); 0 otherwise (the stamp is then a no-op row
# the typed_nodes JOIN drops).
nodeId: function {n: Node} out u32 is {
    match (
        n
    ) case atomid then {
        return n.nodeid
    } case labelvalue then {
        return n.nodeid
    } case binop then {
        return n.nodeid
    } case dottedpath then {
        return n.nodeid
    } case expression then {
        return n.nodeid
    } case call then {
        return n.nodeid
    } case functiondef then {
        return n.nodeid
    } case assignment then {
        return n.nodeid
    } case reassignment then {
        return n.nodeid
    } else {
        return 0
    }
}

# nodeLine / nodeCol -- the source position of a value-expression Node. Covers
# the operation kinds a call argument can take; 0 otherwise.
nodeLine: function {n: Node} out u32 is {
    match (
        n
    ) case atomid then {
        return n.lineno
    } case labelvalue then {
        return n.lineno
    } case dottedpath then {
        return n.lineno
    } case expression then {
        return n.lineno
    } case call then {
        return n.lineno
    } case binop then {
        return n.lineno
    } case atomstring then {
        return n.lineno
    } else {
        return 0
    }
}

nodeCol: function {n: Node} out u32 is {
    match (
        n
    ) case atomid then {
        return n.colno
    } case labelvalue then {
        return n.colno
    } case dottedpath then {
        return n.colno
    } case expression then {
        return n.colno
    } case call then {
        return n.colno
    } case binop then {
        return n.colno
    } case atomstring then {
        return n.colno
    } else {
        return 0
    }
}

# atomName -- the name of an atom Node (atomid / labelvalue) as an owned String,
# "" for anything else. Matching the Node param narrows it cleanly (the proven
# simple-param pattern), so callers pass a field/arg projection without worrying
# about path-subject narrowing.
atomName: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case atomid then {
        return (zast.nameTextCopy :ast ref: n.name)
    } case labelvalue then {
        return (zast.nameTextCopy :ast ref: n.name)
    } else {
        return "".string
    }
}

# atomNameId -- the Ast.names pool id of an atomid/labelvalue node's name
# (0 when the node is neither; no pool id is 0, so lookups by it miss).
atomNameId: function {ast: Ast n: Node} out u64 is {
    match (
        n
    ) case atomid then {
        return n.name.u64
    } case labelvalue then {
        return n.name.u64
    } else {
        return 0
    }
}

# addError -- append a typecheck diagnostic to the typing's error list,
# deduped by node position so a spec resolved more than once reports once.
# addResolveError -- a diagnostic raised from the resolution core, which
# holds no source node: location-free, deduped by message.
addResolveError: function {ty: ztyping.ZTyping e: zast.err msg: String} is {
    dup9: false
    with eit9: ty.errors.iterate do for pe9: eit9 loop {
        if pe9.msg.stringview == msg.stringview then dup9 = true
    }
    if (dup9) == false then {
        en9: String
        eh9: String
        ty.errors.append (zast.ErrorData
            nodeid: 0
            lineno: 0
            colno: 0
            width: 1
            err: e
            msg: msg.copy
            fsno: 0
            note: en9
            hint: eh9
        )
        ty.isError = true
    }
}

# stampGate -- a body-walk node stamp that suppresses GENERIC_PARAM values
# during a generic template walk: the emitter re-walks the shared template
# AST per instance and must not see template-time param stamps.
stampGate: function {st: zenv.ZSymbolTable nid: u32 tid: u64} is {
    if st.typing.suppressParamStamps then {
        if (st.reg.typetypeOf typeId: tid) == ztypes.ztypetype.genericParam then return
    }
    sv9: tid
    st.typing.nodeType.set key: nid.u64 value: sv9
}

addErrorH: function {
    st: zenv.ZSymbolTable
    nodeid: u32
    lineno: u32
    colno: u32
    e: zast.err
    msg: String
    note: String
    hint: String
    width: u32
} is {
    dup: false
    with it: st.typing.errors.iterate do for prev: it loop {
        if prev.nodeid == nodeid when prev.lineno == lineno when prev.colno == colno when prev.msg.stringview == msg.stringview then {
            dup = true
        }
    }
    if (dup) == false then {
        st.typing.errors.append (zast.ErrorData
            :nodeid
            :lineno
            :colno
            :width
            err: e
            msg: msg.copy
            fsno: 0
            note: note.copy
            hint: hint.copy
        )
        st.typing.isError = true
    }
}

# addResolveErrorH -- addErrorH for resolution-time callers that hold the
# ZTyping directly (no symbol table yet); same dedup, so re-entrant
# resolution passes report once.
addResolveErrorH: function {
    ty: ztyping.ZTyping
    nodeid: u32
    lineno: u32
    colno: u32
    e: zast.err
    msg: String
    width: u32
} is {
    dup: false
    with it: ty.errors.iterate do for prev: it loop {
        if prev.nodeid == nodeid when prev.lineno == lineno when prev.colno == colno when prev.msg.stringview == msg.stringview then {
            dup = true
        }
    }
    if (dup) == false then {
        ty.errors.append (zast.ErrorData
            :nodeid
            :lineno
            :colno
            :width
            err: e
            msg: msg.copy
            fsno: 0
            note: "".string
            hint: "".string
        )
        ty.isError = true
    }
}

addError: function {
    st: zenv.ZSymbolTable
    nodeid: u32
    lineno: u32
    colno: u32
    e: zast.err
    msg: String
} is {
    en9: String
    eh9: String
    addErrorH :st :nodeid :lineno :colno :e :msg note: en9 hint: eh9 width: 1
}

# isBorrowedVar -- true when the variable id is bound BORROWED (a borrowed
# parameter or a genuine borrowed local). Reliable now that pendingBorrowPath
# no longer leaks a sub-expression's borrow into an owned binding.
isBorrowedVar: function {st: zenv.ZSymbolTable vid: u64} out bool is {
    ow: st.typing.variableOwnership.get key: vid
    isB9: false
    match (
        ow
    ) case some then {
        if ow == ztypes.zownership.borrowed then isB9 = true
    } case none then null
    return isB9
}

# isNumericTid -- a concrete integer/float type id (literal-coercion target).
isNumericTid: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    tid: u64
} out bool is {
    if tid == 0 then return false
    if tid == (builtinTidT :ast :ty :reg base: "i8") then return true
    if tid == (builtinTidT :ast :ty :reg base: "i16") then return true
    if tid == (builtinTidT :ast :ty :reg base: "i32") then return true
    if tid == (builtinTidT :ast :ty :reg base: "i64") then return true
    if tid == (builtinTidT :ast :ty :reg base: "i128") then return true
    if tid == (builtinTidT :ast :ty :reg base: "u8") then return true
    if tid == (builtinTidT :ast :ty :reg base: "u16") then return true
    if tid == (builtinTidT :ast :ty :reg base: "u32") then return true
    if tid == (builtinTidT :ast :ty :reg base: "u64") then return true
    if tid == (builtinTidT :ast :ty :reg base: "u128") then return true
    if tid == (builtinTidT :ast :ty :reg base: "f32") then return true
    if tid == (builtinTidT :ast :ty :reg base: "f64") then return true
    if tid == (builtinTidT :ast :ty :reg base: "c8") then return true
    if tid == (builtinTidT :ast :ty :reg base: "c32") then return true
    return false
}

# isImplicitZeroCreateTid -- a bare type name in a runtime value position
# that constructs its zero/empty value with no arguments: the numeric
# scalars (zero) and String (empty). The stamp drives the emitter; the
# atom's nodeType stays the type id itself.
isImplicitZeroCreateTid: function {ast: Ast st: zenv.ZSymbolTable tid: u64} out bool is {
    if (isNumericTid :ast ty: st.typing reg: st.reg :tid) then return true
    if tid == (builtinTidT :ast ty: st.typing reg: st.reg base: "String") then return true
    return false
}

# bareCtorError -- one diagnostic for a bare type name in value position
# that cannot construct, with the shared teaching note.
bareCtorError: function {
    st: zenv.ZSymbolTable
    nodeid: u32
    lineno: u32
    colno: u32
    width: u32
    msg: String
    hint: String
} is {
    nt9: "a bare type name in value position is a zero-argument 'create' construction".string
    mc9: msg.copy
    hc9: hint.copy
    (addErrorH
        :st
        :nodeid
        :lineno
        :colno
        e: zast.err.callError
        msg: mc9
        note: nt9
        hint: hc9
        :width
    )
}

# checkBareTypeConstruction -- a bare type name in a runtime value position
# is a zero-argument create construction. Records/classes stamp for the
# emitter when no required field remains (defaults and a body-carrying user
# create both satisfy) and report the missing fields otherwise; a typedef
# class over String is the empty string value. Families that cannot
# construct -- views, generic templates, unions/variants (an arm must be
# selected), protocols/facets, source-produced iterators, create-disabled
# types -- each get a targeted diagnostic.
checkBareTypeConstruction: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast
    node: zast.AtomIdData
    tid: u64
} is {
    cbW9: ast.names.texts.get i: (node.name - 1).u64
    (checkBareTypeValueAt
        :ast
        :st
        :unitName
        nodeid: node.nodeid
        lineno: node.lineno
        colno: node.colno
        width: cbW9.length.u32.orPanic
        :tid
    )
}

# checkBareTypeValueAt -- checkBareTypeConstruction's core against explicit
# source coordinates, shared by the bare-atom and unit-qualified dotted legs.
checkBareTypeValueAt: function {
    ast: Ast
    st: zenv.ZSymbolTable
    unitName: StringView
    nodeid: u32
    lineno: u32
    colno: u32
    width: u32
    tid: u64
} is {
    tt9: st.reg.typetypeOf typeId: tid
    isFam9: false
    if tt9 == ztypes.ztypetype.recordType then isFam9 = true
    if tt9 == ztypes.ztypetype.classType then isFam9 = true
    if tt9 == ztypes.ztypetype.unionType then isFam9 = true
    if tt9 == ztypes.ztypetype.variantType then isFam9 = true
    if tt9 == ztypes.ztypetype.protocolType then isFam9 = true
    if tt9 == ztypes.ztypetype.facetType then isFam9 = true
    if (isFam9) == false then return
    tn9: typeNameOf :st :tid
    # borrowed views -- including a typedef class over a view (PathView) --
    # bind from an owner and cannot be constructed
    isVw9: isViewFamilyTid :ast :st :tid
    tdb9: u64
    if (isVw9) == false then {
        tdb9 = typedefBaseOf :ast :st :unitName :tid
        if tdb9 > 0 when (isViewFamilyTid :ast :st tid: tdb9) then isVw9 = true
    }
    if isVw9 then {
        tnv9: tn9.copy
        mv9: "cannot construct '\{tnv9}' from its bare name: a borrowed view binds from an owner"
        hv9: "project the view from its owner ('.stringview', '.listview', '.substring')".string
        bareCtorError :st :nodeid :lineno :colno :width msg: mv9 hint: hv9
        return
    }
    # a generic template has no concrete layout until its arguments apply
    isGen9: false
    {
        gz9: st.reg.typeById.get key: tid
        match (
            gz9
        ) case some then {
            if gz9.isgeneric then isGen9 = true
        } case none then null
    }
    if isGen9 then {
        tng9: tn9.copy
        mg9: "cannot construct '\{tng9}' from its bare name: a generic type needs type arguments"
        hg9: "apply type arguments first, e.g. '(List of: u8)'".string
        bareCtorError :st :nodeid :lineno :colno :width msg: mg9 hint: hg9
        return
    }
    # unions and variants select an arm; bool's arms are its literals
    isUV9: false
    if tt9 == ztypes.ztypetype.unionType then isUV9 = true
    if tt9 == ztypes.ztypetype.variantType then isUV9 = true
    if isUV9 then {
        tnu9: tn9.copy
        mu9: "cannot construct '\{tnu9}' from its bare name: a union/variant selects an arm"
        hu9: "construct an arm: '\{tn9}.<arm> ...'"
        if tid == (builtinTidT :ast ty: st.typing reg: st.reg base: "bool") then {
            hu9 = "write 'false' (the zero arm) or 'true'".string
        }
        bareCtorError :st :nodeid :lineno :colno :width msg: mu9 hint: hu9
        return
    }
    isPF9: false
    if tt9 == ztypes.ztypetype.protocolType then isPF9 = true
    if tt9 == ztypes.ztypetype.facetType then isPF9 = true
    if isPF9 then {
        tnp9: tn9.copy
        mp9: "cannot construct '\{tnp9}' from its bare name: a protocol/facet projects a conforming value"
        hp9: "bind a value of a conforming type instead".string
        bareCtorError :st :nodeid :lineno :colno :width msg: mp9 hint: hp9
        return
    }
    # a typedef class over String (Path) is the empty string value
    if tdb9 > 0 when tdb9 == (builtinTidT :ast ty: st.typing reg: st.reg base: "String") then {
        ics9: tid
        st.typing.implicitCreate.set key: nodeid.u64 value: ics9
        return
    }
    # source-produced iterators have no standalone construction
    isIt9: false
    if tid == (builtinTidT :ast ty: st.typing reg: st.reg base: "CpIter") then isIt9 = true
    if tid == (builtinTidT :ast ty: st.typing reg: st.reg base: "Splitter") then isIt9 = true
    if tid == (builtinTidT :ast ty: st.typing reg: st.reg base: "LinesIter") then isIt9 = true
    if isIt9 then {
        tni9: tn9.copy
        mi9: "cannot construct '\{tni9}' from its bare name: iterators are produced by their source"
        hi9: "call '.iterate' / '.split' / '.codepoints' / '.lines' on the source value".string
        bareCtorError :st :nodeid :lineno :colno :width msg: mi9 hint: hi9
        return
    }
    crO9: st.typing.childOfId parentTypeId: tid nameId: wkCreate
    hasCr9: false
    match (
        crO9
    ) case some then {
        if (st.reg.typetypeOf typeId: crO9) == ztypes.ztypetype.functionType then hasCr9 = true
    } case none then null
    if (hasCr9) == false then {
        tnn9: tn9.copy
        mn0: "cannot construct '\{tnn9}' from its bare name: the type does not define construction (create: null)"
        hn0: "use the type's own factory functions".string
        bareCtorError :st :nodeid :lineno :colno :width msg: mn0 hint: hn0
        return
    }
    prov9: (List String)
    misN9: (List String)
    misI9: (List u64)
    (missingCtorFields
        :ast
        :st
        funcId: tid
        isCtor: true
        provided: prov9
        posCount: 0
        missingNames: misN9
        missingIds: misI9
    )
    if misN9.length == 0 then {
        icr9: tid
        st.typing.implicitCreate.set key: nodeid.u64 value: icr9
        return
    }
    lst9: String
    li9: u64
    ln9: misN9.length
    for li9 < ln9 loop {
        mn9: misN9.get i: li9
        mid9: misI9.get i: li9
        li9 = li9 + 1
        mtn9: typeNameOf :st tid: mid9
        mnc9: mn9.copy
        mtc9: mtn9.copy
        if lst9.length > 0 then lst9.append ", "
        ln1: "'\{mnc9}' (type: \{mtc9})"
        lst9.append ln1.stringview
    }
    tnc9: tn9.copy
    tnh9: tn9.copy
    m9: "cannot construct '\{tnc9}' from its bare name: missing required arguments \{lst9}"
    eh9: "provide each listed argument ('\{tnh9} name: value ...') or add field defaults"
    bareCtorError :st :nodeid :lineno :colno :width msg: m9 hint: eh9
}

# isViewFamilyTid -- a borrowed-view type: OptionView/ListView/MapEntry monos
# (generic-origin keyed) or the non-generic StringView/ByteView views. A view
# result is a borrow into its parent container/string: the binding holds a
# SHARED lock on the parent and the payload cannot be moved out.
isViewFamilyTid: function {ast: Ast st: zenv.ZSymbolTable tid: u64} out bool is {
    if tid == 0 then return false
    if tid == (builtinTidT :ast ty: st.typing reg: st.reg base: "StringView") then return true
    if tid == (builtinTidT :ast ty: st.typing reg: st.reg base: "ByteView") then return true
    vog9: u64
    {
        vt9: st.reg.typeById.get key: tid
        match (
            vt9
        ) case some then {
            vgo9: vt9.genericOriginId
            match (
                vgo9
            ) case some then {
                vog9 = vgo9
            } case none then null
        } case none then null
    }
    if vog9 == 0 then return false
    if vog9 == (builtinTidT :ast ty: st.typing reg: st.reg base: "OptionView") then return true
    if vog9 == (builtinTidT :ast ty: st.typing reg: st.reg base: "ListView") then return true
    if vog9 == (builtinTidT :ast ty: st.typing reg: st.reg base: "MapEntry") then return true
    return false
}

# isViewVar -- a borrowed binding whose DECLARED type is a view (OptionView
# from Map.get, StringView, ...): its payload aliases the parent's storage,
# so moving the (narrowed) payload out would drain the parent. Borrowed
# non-view bindings (a protocol call's fresh result bound conservatively)
# keep the pre-existing move semantics.
isViewVar: function {ast: Ast st: zenv.ZSymbolTable vid: u64} out bool is {
    if (isBorrowedVar :st :vid) == false then return false
    vzo9: st.typing.variableZtype.get key: vid
    match (
        vzo9
    ) case some then {
        return (isViewFamilyTid :ast :st tid: vzo9)
    } case none then {
        return false
    }
}

# isContainerReaderCall -- a synthesized container method known not to
# mutate its receiver: the call's receiver lock is SHARED so readers
# coexist with live views (many readers XOR one writer XOR one exclusive
# iterator). Writers and user methods (opaque bodies) stay EXCLUSIVE.
isContainerReaderCall: function {
    ast: Ast
    st: zenv.ZSymbolTable
    recvTid: u64
    mname: StringView
} out bool is {
    if recvTid == 0 then return false
    base9: recvTid
    {
        rt9: st.reg.typeById.get key: recvTid
        match (
            rt9
        ) case some then {
            rg9: rt9.genericOriginId
            match (
                rg9
            ) case some then {
                base9 = rg9
            } case none then null
        } case none then null
    }
    if base9 == (builtinTidT :ast ty: st.typing reg: st.reg base: "Map") then {
        if mname == "get" then return true
        if mname == "getv" then return true
        if mname == "has" then return true
        if mname == "length" then return true
        if mname == "capacity" then return true
        if mname == "copy" then return true
        return false
    }
    if base9 == (builtinTidT :ast ty: st.typing reg: st.reg base: "Set") then {
        if mname == "has" then return true
        if mname == "length" then return true
        if mname == "capacity" then return true
        if mname == "copy" then return true
        return false
    }
    if base9 == (builtinTidT :ast ty: st.typing reg: st.reg base: "List") then {
        if mname == "get" then return true
        if mname == "contains" then return true
        if mname == "length" then return true
        if mname == "capacity" then return true
        if mname == "copy" then return true
        return false
    }
    if base9 == (builtinTidT :ast ty: st.typing reg: st.reg base: "String") then {
        if mname == "length" then return true
        if mname == "compare" then return true
        if mname == "copy" then return true
        return false
    }
    return false
}

# typesCompatible -- compare two type ids: identity, never (divergent) actual,
# generic-param pairs, literal/numeric coercion (literal_int/float -> concrete
# numerics), and an asymmetric typedef-base walk on `a`.
typesCompatible: function {
    ast: Ast
    st: zenv.ZSymbolTable
    unitName: StringView
    a: u64
    b: u64
} out bool is {
    if a == b then return true
    if (st.reg.typetypeOf typeId: a) == ztypes.ztypetype.neverType then return true
    if (st.reg.typetypeOf typeId: a) == ztypes.ztypetype.genericParam when (st.reg.typetypeOf typeId: b) == ztypes.ztypetype.genericParam then {
        # Any two type parameters are template-compatible: params resolve to
        # canonical per-(template,param) tids and the per-instance clone
        # checks are the concrete backstop.
        return true
    }
    aLit9: isLiteralTypeId :st tid: a
    bLit9: isLiteralTypeId :st tid: b
    if aLit9 when bLit9 then return true
    if aLit9 then {
        if (isNumericTid :ast ty: st.typing reg: st.reg tid: b) then return true
    }
    if bLit9 then {
        if (isNumericTid :ast ty: st.typing reg: st.reg tid: a) then return true
    }
    cur9: a
    for cur9 > 0 loop {
        nb9: typedefBaseOf :ast :st :unitName tid: cur9
        if nb9 == 0 then {
            cur9 = 0
        } else {
            if nb9 == b then return true
            cur9 = nb9
        }
    }
    # Last resort (only when the id-based checks all fail): cross-unit instances
    # of one type get distinct tids -- a generic template is monomorphized per
    # unit, and a unit-qualified alias (`tokenize.Token`) resolves apart from
    # its target (`zlexer.Token`), so `List tokenize.Token` and `List Token`
    # diverge by tid yet denote the same type and emitted struct. The structural
    # name is the canonical signature (it encodes the full instantiation and
    # collapses aliases), so equal non-empty names are the same type.
    anA9: typeNameOf :st tid: a
    if anA9.length > 0 then {
        anB9: typeNameOf :st tid: b
        if anA9.stringview == anB9.stringview then return true
    }
    return false
}

# byteOf -- the byte at index i (0 when out of range).
byteOf: function {s: StringView i: u64} out u8 is {
    bo: s.byteAt i
    match (
        bo
    ) case some then {
        return bo
    } case none then null
    return 0
}

# levenshtein -- byte-level edit distance (two-row DP), for did-you-mean.
levenshtein: function {a: StringView b: StringView} out u64 is {
    na: a.length
    nb: b.length
    if na == 0 then return nb
    if nb == 0 then return na
    prev: (List u64)
    j0: u64
    for j0 <= nb loop {
        jv: j0
        prev.append jv
        j0 = j0 + 1
    }
    i: u64
    for i < na loop {
        cur: (List u64)
        cur.append (i + 1)
        ab: byteOf s: a :i
        j: u64
        for j < nb loop {
            bb: byteOf s: b i: j
            cost: 1.u64
            if ab == bb then cost = 0
            delc: (prev.get i: (j + 1)) + 1
            insc: (cur.get i: j) + 1
            subc: (prev.get i: j) + cost
            best: delc
            if insc < best then best = insc
            if subc < best then best = subc
            cur.append best
            j = j + 1
        }
        prev = cur
        i = i + 1
    }
    return (prev.get i: nb)
}

# suggestSimilar -- the closest child name of parentTypeId to `name` (edit
# distance <= 2 and unique); "" if none. Powers the did-you-mean hint.
suggestSimilar: function {
    ast: Ast
    st: zenv.ZSymbolTable
    parentTypeId: u64
    name: StringView
} out String is {
    best: String
    bestDist: 3.u64
    tied: false
    with citer: st.typing.typeChild.iterate do for tc: citer loop {
        if tc.parentTypeId == parentTypeId then {
            cnB9: ast.names.texts.get i: (tc.nameId - 1).u64
            cn: cnB9.stringview
            if (cn == name) == false then {
                d: levenshtein a: name b: cn
                if d < bestDist then {
                    best = cnB9.copy
                    bestDist = d
                    tied = false
                } else {
                    if d == bestDist then tied = true
                }
            }
        }
    }
    if bestDist <= 2 when (tied) == false when best.length > 0 then return best
    return "".string
}

# populatePreludeBody -- record one unit body's unit-rooted dotted aliases as
# prelude entries (bare name -> defining unit). Type-rooted targets
# (true: bool.true) are value re-exports, never asked of the index side.
populatePreludeBody: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitopId: u32
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: unitopId
    with bit: bodyIds9.iterate do for bmId9: bit loop {
        bm: ast.nodes.get i: (bmId9 - 1).u64
        if bm.namedoperation then {
            dn: zast.nameTextCopy :ast ref: bm.name
            atgt0: dottedDefTarget :ast n: (ast.nodes.get i: (bm.operation - 1).u64)
            if atgt0.length > 0 then {
                ps0: String
                with pit: (atgt0.stringview.split sep: ".") do for pseg: pit loop {
                    if ps0.length == 0 then ps0 = pseg.string
                }
                pchk0: ps0.copy
                if (reg.unitNameTid.has key: pchk0) then {
                    pk0: dn.copy
                    ty.preludeUnit.set key: pk0 value: ps0
                }
            }
        }
    }
}

# populatePrelude -- fill ty.preludeUnit from core's re-exports BEFORE any
# demand resolution (lowerGenerators pre-resolves system types, whose defs
# already ask definingUnitFor for prelude names).
populatePrelude: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry program: Node} is {
    match (
        program
    ) case program then {
        uCnt9a: program.ast.units.length
        uIdx9a: u64
        for uIdx9a < uCnt9a loop {
            ruId9: program.ast.units.get i: uIdx9a
            uIdx9a = uIdx9a + 1
            opId9: u32
            {
                ru: program.ast.nodes.get i: (ruId9 - 1).u64
                if ru.namedoperation then {
                    isCore9: (zast.poolTextEq
                        pool: program.ast.names
                        ref: ru.name
                        s: "core"
                    )
                    if isCore9 then opId9 = ru.operation
                }
            }
            if opId9 > 0 then {
                (populatePreludeBody
                    :ty
                    :reg
                    ast: program.ast
                    unitopId: opId9
                )
            }
        }
    } else null
}

# indexUnitDefs -- pre-scan every unit's top-level definitions into a
# (unit.name) -> typetype index BEFORE resolution, so a reference can declare the
# ONE canonical record id (declare-before-bind) instead of an anonymous shell. No
# ids minted here. Dotted-path aliases and the null/never empty types keep their
# existing post-demand handling (defTypetypeOf returns none for them).
indexUnitDefs: function {ty: ztyping.ZTyping program: Node} is {
    match (
        program
    ) case program then {
        uidx0: u64
        uCnt9b: program.ast.units.length
        uIdx9b: u64
        for uIdx9b < uCnt9b loop {
            ruId9: program.ast.units.get i: uIdx9b
            uIdx9b = uIdx9b + 1
            opId9: u32
            unm9: String
            {
                ru: program.ast.nodes.get i: (ruId9 - 1).u64
                if ru.namedoperation then {
                    unm: zast.poolTextCopy pool: program.ast.names ref: ru.name
                    opId9 = ru.operation
                    unm9 = unm.copy
                }
            }
            if opId9 > 0 then {
                (indexUnitBody
                    :ty
                    ast: program.ast
                    unitName: unm9.stringview
                    unitIdx: uidx0
                    unitopId: opId9
                )
            }
            uidx0 = uidx0 + 1
        }
        ty.defNodeIndexBuilt = true
    } else null
}

# indexUnitBody -- index one unit's top-level defs (mirrors resolveDemandedUnitBody's
# unitdef.body walk).
indexUnitBody: function {
    ty: ztyping.ZTyping
    ast: Ast
    unitName: StringView
    unitIdx: u64
    unitopId: u32
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: unitopId
    {
        bidx0: u64
        with bit: bodyIds9.iterate do for bmId9: bit loop {
            bm: ast.nodes.get i: (bmId9 - 1).u64
            if bm.namedoperation then {
                dn: zast.nameTextCopy :ast ref: bm.name
                tto: (defTypetypeOf
                    :ast
                    defn: (ast.nodes.get i: (bm.operation - 1).u64)
                    name: dn.stringview
                )
                match (
                    tto
                ) case some then {
                    k: "\{unitName}.\{dn}"
                    ty.defTypetype.set key: k value: tto
                } case none then null
                sk0: "\{unitName}.\{dn}"
                uv0: unitIdx
                ty.defNodeUnitIdx.set key: sk0 value: uv0
                atgt0: dottedDefTarget :ast n: (ast.nodes.get i: (bm.operation - 1).u64)
                if atgt0.length > 0 then {
                    ak0: "\{unitName}.\{dn}"
                    ty.funcAliases.set key: ak0 value: atgt0
                    adn0: "\{unitName}.\{dn}"
                    adnid0: nodeId n: (ast.nodes.get i: (bm.operation - 1).u64)
                    adv0: adnid0.u64
                    ty.aliasDefNode.set key: adn0 value: adv0
                }
                sk1: "\{unitName}.\{dn}"
                bv1: bidx0
                ty.defNodeBodyIdx.set key: sk1 value: bv1
            }
            bidx0 = bidx0 + 1
        }
    }
}

# defTypetypeOf -- the typetype a top-level definition node declares, mirroring
# resolveDef's dispatch. None for nodes that mint no canonical type here (dotted-
# path aliases, the null/never empty types, enums/generics in later slices).
defTypetypeOf: function {
    ast: Ast
    defn: Node
    name: StringView
} out optionval ztypes.ztypetype is {
    match (
        defn
    ) case functiondef then {
        return (optionval.some ztypes.ztypetype.functionType)
    } case expression then {
        return (defTypetypeOf :ast defn: (ast.nodes.get i: (defn.expression - 1).u64) :name)
    } case datablock then {
        return (optionval.some ztypes.ztypetype.dataType)
    } case objectdef then {
        match (
            defn.kind
        ) case recordDef then {
            if name == "null" then return (optionval.none ztypes.ztypetype)
            if name == "never" then return (optionval.none ztypes.ztypetype)
            return (optionval.some ztypes.ztypetype.recordType)
        } case variantDef then {
            return (optionval.some ztypes.ztypetype.variantType)
        } case unionDef then {
            return (optionval.some ztypes.ztypetype.unionType)
        } case classDef then {
            return (optionval.some ztypes.ztypetype.classType)
        } case facetDef then {
            return (optionval.some ztypes.ztypetype.facetType)
        } case protocolDef then {
            return (optionval.some ztypes.ztypetype.protocolType)
        } else {
            return (optionval.none ztypes.ztypetype)
        }
    } else {
        return (optionval.none ztypes.ztypetype)
    }
}

# definingUnitFor -- the unit that defines `name` for a reference in
# `currentUnit`: the current unit's own defs (declare-before-bind index),
# else the prelude surface (core's unit-rooted re-exports, ty.preludeUnit).
# "" when neither indexes it (generic params, this/numerics, forward refs
# to a nonexistent type) -- the caller then mints a shell exactly as
# before. Scope-shaped: the current unit shadows the prelude. The id-side
# bare walk (walkLookupTyperef) keeps its own full root order for
# internal/mangled queries.
definingUnitFor: function {
    ty: ztyping.ZTyping
    currentUnit: StringView
    name: StringView
} out String is {
    k0: "\{currentUnit}.\{name}"
    k0b: "\{currentUnit}.\{name}"
    hitk0: ty.defTypetype.has key: k0
    if (hitk0) == false then hitk0 = ty.defNodeUnitIdx.has key: k0b
    if hitk0 then return currentUnit.string
    pgo0: ty.preludeUnit.get key: name.string
    match (
        pgo0
    ) case some then {
        return pgo0.copy
    } case none then null
    return "".string
}

# declareCanonicalType -- get-or-declare the ONE canonical id for `unit.name` as a
# childOf edge under its unit (with definedInUnit set). The single convergence point for both a
# reference (resolveAtomType) and the definition (the resolveX resolvers): whoever
# runs first mints; the rest reuse the same id. Does NOT touch definedKeys (the
# body-resolved marker), so demanded bodies still resolve lazily.
declareCanonicalType: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    defUnit: StringView
    name: StringView
    typetype: ztypes.ztypetype
} out u64 is {
    cudm: reg.unitNameTid.get key: defUnit.string
    match (
        cudm
    ) case some then {
        exm: ty.childOf pool: ast.names parentTypeId: cudm :name
        match (
            exm
        ) case some then {
            return exm
        } case none then null
    } case none then null
    id: reg.newType :name :typetype
    cud0: reg.unitNameTid.get key: defUnit.string
    match (
        cud0
    ) case some then {
        ty.setChildId parentTypeId: cud0 nameId: (ast.internString text: name).u64 childTypeId: id
    } case none then null
    idu: id
    duv: defUnit.string
    ty.definedInUnit.set key: idu value: duv
    return id
}

# dottedDefTarget -- the "unit.Type" target of a cross-unit type alias
# (`Node: zast.Node`), or "" when the definition is not a dotted alias.
dottedDefTarget: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case expression then {
        return (dottedDefTarget :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case dottedpath then {
        pn: atomName :ast n: (ast.nodes.get i: (n.parent - 1).u64)
        cn: atomName :ast n: (ast.nodes.get i: (n.child - 1).u64)
        return "\{pn}.\{cn}"
    } else {
        return "".string
    }
}

# resolveNamedType -- resolve a bare type NAME to its canonical id via the
# declare-before-bind index (definingUnitFor -> declareCanonicalType), minting a
# RECORD shell only for a numeric-literal default or an unresolved/forward name.
# `thisName` scopes the enclosing type's generic params. resolveAtomType aliases
# the self-type keywords `this`/`type` to the enclosing type name and calls here,
# so a native method's `:this` / `rhs: type` lands on the one canonical id, not a
# fresh shell.
resolveNamedType: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    name: StringView
    thisName: StringView
} out u64 is {
    if name == "null" then {
        return (declareCanonicalType
            :ast
            :ty
            :reg
            defUnit: "system"
            name: "null"
            typetype: ztypes.ztypetype.nullType
        )
    }
    if name == "never" then {
        return (declareCanonicalType
            :ast
            :ty
            :reg
            defUnit: "system"
            name: "never"
            typetype: ztypes.ztypetype.neverType
        )
    }
    b0: name.byteAt 0.u64
    isnum: false
    match (
        b0
    ) case some then {
        if b0 >= 48 when b0 <= 57 then isnum = true
    } case none then null
    if isnum then {
        # A numeric-literal name types as the literal's DEFAULT scalar (system
        # i64/f64) -- it is not a name reference, so a unit-local scalar shadow
        # must not capture it. Pre-index (defNodeIndexBuilt false) keeps the
        # named-shell fallback.
        dn7: "i64"
        if name.contains "." then dn7 = "f64"
        sid7: descendNamed :ty :reg :ast defUnit: "system" name: dn7
        if sid7 > 0 then return sid7
        return (reg.newType name: dn7 typetype: ztypes.ztypetype.recordType)
    }
    if thisName.length > 0 then {
        etk7: "\{unitName}.\{thisName}"
        if (reg.isGenericParamOf typeKey: etk7.stringview :name) then {
            pgo7: reg.genericParamTidOf typeKey: etk7.stringview paramName: name
            match (
                pgo7
            ) case some then {
                return pgo7
            } case none then null
            ptid7: reg.newType :name typetype: ztypes.ztypetype.genericParam
            reg.setGenericParamTid typeKey: etk7.stringview paramName: name tid: ptid7
            return ptid7
        }
    }
    duo7: definingUnitFor :ty currentUnit: unitName :name
    if duo7.length > 0 then {
        ttk7: "\{duo7}.\{name}"
        tto7: ty.defTypetype.get key: ttk7
        match (
            tto7
        ) case some then {
            did7: descendNamed :ty :reg :ast defUnit: duo7.stringview :name
            if did7 > 0 then return did7
            return (declareCanonicalType
                :ast
                :ty
                :reg
                defUnit: duo7.stringview
                :name
                typetype: tto7
            )
        } case none then {
            k7b: "\{duo7}.\{name}"
            ex7: resolvedByKey :ast :ty :reg key: k7b
            match (
                ex7
            ) case some then {
                return ex7
            } case none then null
            k7c: "\{duo7}.\{name}"
            fa7: ty.funcAliases.get key: k7c
            match (
                fa7
            ) case some then {
                ap7: String
                ac7: String
                with sit7: (fa7.stringview.split sep: ".") do for seg7: sit7 loop {
                    if ap7.length == 0 then {
                        ap7 = seg7.string
                    } else {
                        ac7 = seg7.string
                    }
                }
                dtk7: "\{ap7}.\{ac7}"
                tt7: ty.defTypetype.get key: dtk7
                match (
                    tt7
                ) case some then {
                    return (declareCanonicalType
                        :ast
                        :ty
                        :reg
                        defUnit: ap7.stringview
                        name: ac7.stringview
                        typetype: tt7
                    )
                } case none then null
            } case none then null
            return (reg.newType :name typetype: ztypes.ztypetype.recordType)
        }
    } else {
        return (reg.newType :name typetype: ztypes.ztypetype.recordType)
    }
}

# resolveAtomType -- resolve a type-atom name in a method/param position. `this`
# and `type` alias the enclosing type (thisName); everything else is a plain name.
resolveAtomType: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    nm: StringView
    thisName: StringView
} out u64 is {
    if nm == "this" then return (resolveNamedType :ty :reg :ast :unitName name: thisName :thisName)
    if nm == "type" then {
        if thisName.length != 0 then {
            return (resolveNamedType :ty :reg :ast :unitName name: thisName :thisName)
        }
    }
    return (resolveNamedType :ty :reg :ast :unitName name: nm :thisName)
}

# literalIntId -- pseudo-type id worn by bare numeric literals during the body
# walk. Never registered, so symbol-table and node rows carrying it drop out of
# the dump projections' types join; foldLiteralStamps rewrites surviving node
# stamps to i64 before the dump.
literalIntId: 0x7FFFFFFFFFFFFFFF.u64
literalFloatId: 0x7FFFFFFFFFFFFFFE.u64

# parseDecimalU64 -- a decimal digit string as a u64 value; none when empty
# or any byte is not a digit (signs, radix prefixes, suffixed forms stay on
# the name-keyed path).
parseDecimalU64: function {text: StringView} out optionval u64 is {
    acc9: u64
    i9: u64
    any9: false
    run9: true
    for run9 loop {
        bo9: text.byteAt i9
        match (
            bo9
        ) case some then {
            if bo9 >= 48 when bo9 <= 57 then {
                d9: bo9 - 48
                acc9 = acc9 * 10 + d9.u64
                any9 = true
            } else {
                any9 = false
                run9 = false
            }
        } case none then {
            run9 = false
        }
        i9 = i9 + 1
    }
    if any9 then return (optionval.some acc9)
    return (optionval.none u64)
}

# isNumericLiteralName -- true when a name begins with a digit: a numeric-literal
# atom (an `as`-block static constant like `version: 1`), as opposed to a type-name
# atom (a conformance marker). 48..57 are the ASCII digits.
# isNumericTypeName -- the name of a builtin numeric scalar type.
isNumericTypeName: function {name: StringView} out bool is {
    if name == "i8" then return true
    if name == "i16" then return true
    if name == "i32" then return true
    if name == "i64" then return true
    if name == "i128" then return true
    if name == "u8" then return true
    if name == "u16" then return true
    if name == "u32" then return true
    if name == "u64" then return true
    if name == "u128" then return true
    if name == "f32" then return true
    if name == "f64" then return true
    if name == "c8" then return true
    if name == "c32" then return true
    return false
}

isNumericLiteralName: function {name: StringView} out bool is {
    b0: name.byteAt 0.u64
    match (
        b0
    ) case some then {
        if b0 >= 48 when b0 <= 57 then return true
        if b0 == 45 then {
            b1: name.byteAt 1.u64
            match (
                b1
            ) case some then {
                if b1 >= 48 when b1 <= 57 then return true
            } case none then null
        }
    } case none then null
    return false
}

# isStripMarker -- true for a dotted-path leaf that is an ownership or access marker
# (`.lock`/`.borrow`/`.take`/`.private`/`.public`); a type reference peels these to
# reach the underlying base type.
isStripMarker: function {name: StringView} out bool is {
    if name == "lock" then return true
    if name == "borrow" then return true
    if name == "take" then return true
    if name == "private" then return true
    if name == "public" then return true
    return false
}

# isLabelValue -- true when a node is a bare `:X` label-value (an anonymous
# conformance marker in an as-block parses as a namedoperation wrapping one).
isLabelValue: function {op: Node} out bool is {
    match (
        op
    ) case labelvalue then {
        return true
    } else {
        return false
    }
}

# nodeMentionsName -- whether a subtree references a bare name (atom reads,
# call callables, dotted bases). Drives the conformer-context gate: the
# reference's lazy resolution only reaches a conformer the main body names.
nodeMentionsName: function {ast: Ast n: Node name: StringView} out bool is {
    match (
        n
    ) case atomid then {
        return (zast.nameTextEq :ast ref: n.name s: name)
    } case expression then {
        return (nodeMentionsName :ast n: (ast.nodes.get i: (n.expression - 1).u64) :name)
    } case dottedpath then {
        return (nodeMentionsName :ast n: (ast.nodes.get i: (n.parent - 1).u64) :name)
    } case call then {
        if (nodeMentionsName :ast n: (ast.nodes.get i: (n.callable - 1).u64) :name) then return true
        aiter: n.arguments.iterate
        for argId9: aiter loop {
            arg: ast.nodes.get i: (argId9 - 1).u64
            match (
                arg
            ) case namedoperation then {
                if (nodeMentionsName
                    :ast
                    n: (ast.nodes.get i: (arg.operation - 1).u64)
                    :name
                ) then return true
            } else null
        }
        return false
    } case binop then {
        if (nodeMentionsName :ast n: (ast.nodes.get i: (n.lhs - 1).u64) :name) then return true
        return (nodeMentionsName :ast n: (ast.nodes.get i: (n.rhs - 1).u64) :name)
    } case statement then {
        siter: n.statements.iterate
        for smId9: siter loop {
            if (nodeMentionsName :ast n: (ast.nodes.get i: (smId9 - 1).u64) :name) then return true
        }
        return false
    } case statementline then {
        sln9: ast.nodes.get i: (n.statementline - 1).u64
        return (nodeMentionsName :ast n: sln9 :name)
    } case assignment then {
        return (nodeMentionsName :ast n: (ast.nodes.get i: (n.value - 1).u64) :name)
    } case reassignment then {
        return (nodeMentionsName :ast n: (ast.nodes.get i: (n.value - 1).u64) :name)
    } case caseexpr then {
        if (nodeMentionsName :ast n: (ast.nodes.get i: (n.subject - 1).u64) :name) then return true
        citer: n.clauses.iterate
        for cm: citer loop {
            if (nodeMentionsName :ast n: (ast.nodes.get i: (cm - 1).u64) :name) then return true
        }
        return false
    } case caseclause then {
        return (nodeMentionsName :ast n: (ast.nodes.get i: (n.statement - 1).u64) :name)
    } case ifexpr then {
        citer2: n.clauses.iterate
        for cm2Id9: citer2 loop {
            if (nodeMentionsName :ast n: (ast.nodes.get i: (cm2Id9 - 1).u64) :name) then return true
        }
        return false
    } case forexpr then {
        return (nodeMentionsNameOptAt :ast oId: n.body :name)
    } case withexpr then {
        if (nodeMentionsName :ast n: (ast.nodes.get i: (n.value - 1).u64) :name) then return true
        return (nodeMentionsName :ast n: (ast.nodes.get i: (n.body - 1).u64) :name)
    } case doexpr then {
        return (nodeMentionsName :ast n: (ast.nodes.get i: (n.statement - 1).u64) :name)
    } else {
        return false
    }
}

# nodeMentionsNameOptAt -- nodeMentionsName over a table id (0 = absent).
nodeMentionsNameOptAt: function {ast: Ast oId: u32 name: StringView} out bool is {
    if oId == 0 then return false
    return (nodeMentionsName :ast n: (ast.nodes.get i: (oId - 1).u64) :name)
}

# fnBodyMentions -- nodeMentionsName over a function definition's body.
fnBodyMentions: function {ast: Ast op: Node name: StringView} out bool is {
    match (
        op
    ) case functiondef then {
        return (nodeMentionsNameOptAt :ast oId: op.body :name)
    } else {
        return false
    }
}

# mainBodyMentions -- whether the unit's `main` function body references a name.
mainBodyMentions: function {ast: Ast unitBody: List u32 name: StringView} out bool is {
    {
        with miter: unitBody.iterate do for mmId9: miter loop {
            mm: ast.nodes.get i: (mmId9 - 1).u64
            match (
                mm
            ) case namedoperation then {
                if (zast.nameTextEq :ast ref: mm.name s: "main") then return (fnBodyMentions
                    :ast
                    op: (ast.nodes.get i: (mm.operation - 1).u64)
                    :name
                )
            } else null
        }
    }
    return false
}

# recordConformerContexts -- pre-record each as-block marker target's first
# conforming type (body order) so a demand-resolved protocol binds its spec
# receiver to the conformer (the reference resolves the protocol inside the
# conformer's resolution, inheriting its `this` context). Full mode only:
# signature-only resolves protocols standalone, receiver dropped.
recordConformerContexts: function {
    ast: Ast
    ty: ztyping.ZTyping
    defName: StringView
    op: Node
} is {
    match (
        op
    ) case objectdef then {
        isRef: false
        if op.kind == zast.nodetype.classDef then isRef = true
        if op.kind == zast.nodetype.unionDef then isRef = true
        dk0: defName.string
        dv0: isRef
        ty.mainDefIsReftype.set key: dk0 value: dv0
        aiter: op.asItems.iterate
        for amId9: aiter loop {
            am: ast.nodes.get i: (amId9 - 1).u64
            match (
                am
            ) case namedoperation then {
                cn: atomName :ast n: (ast.nodes.get i: (am.operation - 1).u64)
                skipIt: false
                if cn.length == 0 then skipIt = true
                if (isNumericLiteralName name: cn.stringview) then skipIt = true
                if (skipIt) == false then {
                    ck: cn.copy
                    got: ty.protocolThisContext.get key: ck
                    match (
                        got
                    ) case some then null case none then {
                        ck2: cn.copy
                        cv: defName.string
                        ty.protocolThisContext.set key: ck2 value: cv
                    }
                }
            } else null
        }
    } else null
}

# isBareGenericParam -- a generic-param definition in direct dotted form
# (`t: Any.generic`); wrapped shapes (a def whose payload merely contains a
# constraint) are not unit-level generic params.
isBareGenericParam: function {ast: Ast op: Node} out bool is {
    match (
        op
    ) case dottedpath then {
        leaf: atomName :ast n: (ast.nodes.get i: (op.child - 1).u64)
        if leaf.stringview == "generic" then return true
        if leaf.stringview == "valtype" then return true
        if leaf.stringview == "reftype" then return true
        return false
    } else {
        return false
    }
}

# isGenericParam -- true when a type-expr is a generic-parameter constraint
# (`Any.generic` / `u64.generic` / `Any.valtype`): a dottedpath whose leaf is
# `generic` or `valtype`, peeling an `expression` / parameterized `call` wrapper.
isGenericParam: function {ast: Ast op: Node} out bool is {
    match (
        op
    ) case expression then {
        return (isGenericParam :ast op: (ast.nodes.get i: (op.expression - 1).u64))
    } case call then {
        return (isGenericParam :ast op: (ast.nodes.get i: (op.callable - 1).u64))
    } case dottedpath then {
        leaf: atomName :ast n: (ast.nodes.get i: (op.child - 1).u64)
        if leaf.stringview == "generic" then return true
        if leaf.stringview == "valtype" then return true
        if leaf.stringview == "reftype" then return true
        return false
    } else {
        return false
    }
}

# registerGenericParams -- record a type's generic-param names (keyed
# `{unit}.{type}.{param}`) so method-param resolution can drop params typed by them.
# registerGenericParamOne -- record one member's generic-param declaration.
registerGenericParamOne: function {
    ast: Ast
    reg: ztypes.ZTypeRegistry
    typeKey: StringView
    m: Node
} is {
    match (
        m
    ) case namedoperation then {
        if (isGenericParam :ast op: (ast.nodes.get i: (m.operation - 1).u64)) then {
            pn: zast.nameTextCopy :ast ref: m.name
            cb: genericConstraintBase :ast n: (ast.nodes.get i: (m.operation - 1).u64)
            ckx9: genericConstraintKind :ast n: (ast.nodes.get i: (m.operation - 1).u64)
            cf9x: cb.copy
            if ckx9.length > 0 then cf9x = "\{cb}.\{ckx9}"
            k9: constraintKindFor text: cf9x.stringview
            mx9: (optionval.none u64)
            if k9 == ztypes.constraintkind.numeric then {
                mx9 = constraintNumericMax cv: cf9x.stringview
            }
            reg.addGenericParam :typeKey paramName: pn.stringview kind: k9 numericMax: mx9
        }
    } else null
}

# genericConstraintKind -- the value-kind leaf of a constraint declaration
# (`Any.valtype` -> "valtype", `Any.reftype` -> "reftype"), "" for plain
# `.generic` bounds.
genericConstraintKind: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case expression then {
        return (genericConstraintKind :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case dottedpath then {
        cn9: atomName :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if cn9.stringview == "valtype" then return cn9
        if cn9.stringview == "reftype" then return cn9
        return "".string
    } else {
        return "".string
    }
}

# genericConstraintBase -- the constraint name of a `u64.generic`-style param
# declaration (the dotted parent), "" otherwise.
genericConstraintBase: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case expression then {
        return (genericConstraintBase :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case dottedpath then {
        return (atomName :ast n: (ast.nodes.get i: (n.parent - 1).u64))
    } else {
        return "".string
    }
}

# hasGenericParam -- true when any item in the block is a generic-param declaration.
# Takes the list by value so its iterator's lock is released on return (the scan is
# sequenced before any persistent iterator over the same list).
# hasGenericParam / registerGenericParams -- id-list flavors for
# converted unit bodies (declaration lists stay embedded until S4).
hasGenericParam: function {ast: Ast items: List u32} out bool is {
    hi9: u64
    hn9: items.length
    for hi9 < hn9 loop {
        hid9: items.get i: hi9
        hm9: ast.nodes.get i: (hid9 - 1).u64
        match (
            hm9
        ) case namedoperation then {
            if (isGenericParam :ast op: (ast.nodes.get i: (hm9.operation - 1).u64)) then return true
        } else null
        hi9 = hi9 + 1
    }
    return false
}

registerGenericParams: function {
    reg: ztypes.ZTypeRegistry
    ast: Ast
    typeKey: StringView
    items: List u32
} is {
    ri9: u64
    rn9: items.length
    for ri9 < rn9 loop {
        rid9: items.get i: ri9
        rm9: ast.nodes.get i: (rid9 - 1).u64
        registerGenericParamOne :ast :reg :typeKey m: rm9
        ri9 = ri9 + 1
    }
}

# unitDefIsGeneric -- a unit definition is generic when its body declares a generic
# param. Mirrors objectdefIsGeneric; gates dep-signature-stamp suppression off generic
# units, whose template signatures resolve differently.
unitDefIsGeneric: function {ast: Ast oId: u32} out bool is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: oId
    return (hasGenericParam :ast items: bodyIds9)
}

# pathOwnership -- the ownership a param/field type expr declares via a `.lock`/
# `.borrow`/`.take` dotted-path leaf, or none. (Only `.lock` is valid on a field; all
# three on a param.)
pathOwnership: function {ast: Ast n: Node} out optionval ztypes.zparamownership is {
    match (
        n
    ) case dottedpath then {
        cn: atomName :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if cn.stringview == "lock" then return (optionval.some ztypes.zparamownership.lockMode)
        if cn.stringview == "borrow" then return (optionval.some ztypes.zparamownership.borrowMode)
        if cn.stringview == "take" then return (optionval.some ztypes.zparamownership.takeMode)
        return (optionval.none ztypes.zparamownership)
    } else {
        return (optionval.none ztypes.zparamownership)
    }
}

# baseTypeName -- the underlying base type name of a type expr, peeling `.lock`/
# `.private`/etc. dotted-path markers (`Container.private.lock` -> `Container`,
# `this.lock` -> `this`); the atom name for a bare atom; "" otherwise.
baseTypeName: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case atomid then {
        return (zast.nameTextCopy :ast ref: n.name)
    } case labelvalue then {
        return (zast.nameTextCopy :ast ref: n.name)
    } case dottedpath then {
        cn: atomName :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if (isStripMarker name: cn.stringview) then {
            return (baseTypeName :ast n: (ast.nodes.get i: (n.parent - 1).u64))
        } else {
            return "".string
        }
    } else {
        return "".string
    }
}

# genericApplHead -- the head type name of a generic application `(List of: T)` /
# `(Option t: T)` (the callable's atom name); "" for a non-application expr.
genericApplHead: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case expression then {
        return (genericApplHead :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case call then {
        return (atomName :ast n: (ast.nodes.get i: (n.callable - 1).u64))
    } else {
        return "".string
    }
}

# fieldHeadName -- a field type's head name: baseTypeName, falling back to the
# generic-application head so a `(List of: Node)` / `(Option t: Node)` field is
# recognized (List/Option) for the destructor-cleanup decision.
fieldHeadName: function {ast: Ast n: Node} out String is {
    b: baseTypeName :ast :n
    if b.length > 0 then return b
    return (genericApplHead :ast :n)
}

# resolveTyperefShell -- register a SHALLOW named shell for a referenced type
# (e.g. the `i64` in `n: i64`), routing atom names through resolveAtomType so
# `this`/numeric-default atoms resolve correctly. A parenthesized parameterized
# type `(T arg: N)` (an expression wrapping a call) mangles to a `T_N` shell.
# Source-type rows never include these shells (they fall outside `defined_in_unit`),
# but a `type_children` row joins to the shell's name. Returns the shell's type id.
recordNodeName: function {ty: ztyping.ZTyping unitName: StringView name: StringView nid: u64} is {
    if name.length != 0 then {
        kc: nid
        ty.pendingTyperef.set key: kc value: name.string
        kc2: nid
        ty.pendingTyperefUnit.set key: kc2 value: unitName.string
        if ty.suppressSigStamp then {
            kc3: nid
            sv0: true
            ty.noStampNode.set key: kc3 value: sv0
        }
    }
}

# recordResolvedName -- record (nid -> name) for post-demand resolution; the `this` and
# `type` self-keywords record as the enclosing type (thisName).
recordResolvedName: function {
    ty: ztyping.ZTyping
    unitName: StringView
    thisName: StringView
    name: StringView
    nid: u64
} is {
    if name == "this" then {
        recordNodeName :ty :unitName name: thisName :nid
    } else {
        if name == "type" then {
            recordNodeName :ty :unitName name: thisName :nid
        } else {
            if (isNumericLiteralName :name) then {
                if name.contains "." then {
                    recordNodeName :ty :unitName name: "f64" :nid
                } else {
                    recordNodeName :ty :unitName name: "i64" :nid
                }
            } else {
                recordNodeName :ty :unitName :name :nid
            }
        }
    }
}

# monoArgName -- a pending-instantiation argument's recorded name: `this` and
# `type` map to the enclosing type (the recordResolvedName mapping); "" when
# there is no enclosing type.
monoArgName: function {an: StringView thisName: StringView} out String is {
    if an == "this" then return thisName.string
    if an == "type" then return thisName.string
    return an.string
}

# resolveDottedArgTid -- a unit-qualified dotted generic argument
# (ztypes.zlockstate): descend the member in its defining unit. Marker /
# non-unit dotted shapes resolve 0 (the caller skips the record).
resolveDottedArgTid: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    dp: Node
} out u64 is {
    match (
        dp
    ) case dottedpath then {
        pq9: atomName :ast n: (ast.nodes.get i: (dp.parent - 1).u64)
        cq9: atomName :ast n: (ast.nodes.get i: (dp.child - 1).u64)
        if pq9.length > 0 when cq9.length > 0 then {
            if (reg.isUnitName name: pq9.stringview) then {
                return (descendNamed
                    :ty
                    :reg
                    :ast
                    defUnit: pq9.stringview
                    name: cq9.stringview
                )
            }
        }
    } else null
    return 0
}

# ensureNativeLinkTargets -- descend the native templates the collection
# materializer links returns against by NAME (String / StringView, the
# option wrappers, the iterator/view families): inline specialization runs
# at resolve time, before the demand worklist would have pulled them.
# definedKeys makes every descent after the first a no-op.
ensureNativeLinkTargets: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
} is {
    if ty.nativeLinkTargetsDone then return
    ty.nativeLinkTargetsDone = true
    descendNamed :ty :reg :ast defUnit: "system" name: "String"
    descendNamed :ty :reg :ast defUnit: "system" name: "StringView"
    descendNamed :ty :reg :ast defUnit: "system" name: "Option"
    descendNamed :ty :reg :ast defUnit: "system" name: "OptionView"
    descendNamed :ty :reg :ast defUnit: "system" name: "optionval"
    descendNamed :ty :reg :ast defUnit: "system" name: "Result"
    descendNamed :ty :reg :ast defUnit: "system" name: "resultval"
    descendNamed :ty :reg :ast defUnit: "collections" name: "List"
    descendNamed :ty :reg :ast defUnit: "collections" name: "ListIter"
    descendNamed :ty :reg :ast defUnit: "collections" name: "ListView"
    descendNamed :ty :reg :ast defUnit: "collections" name: "Set"
    descendNamed :ty :reg :ast defUnit: "collections" name: "SetIter"
    descendNamed :ty :reg :ast defUnit: "collections" name: "Map"
    descendNamed :ty :reg :ast defUnit: "collections" name: "MapKeyIter"
    descendNamed :ty :reg :ast defUnit: "collections" name: "MapItemIter"
    descendNamed :ty :reg :ast defUnit: "collections" name: "MapEntry"
}

# resolveMonoRefInline -- resolve a call-shaped parameterized type ref at the
# point it is recorded: resolve the template and every argument now (nested
# parameterized args recurse; the descent pulls unresolved defs), then dedup /
# materialize through getOrMintSpec and stamp the wrapper node. Numeric size
# literals join the instance name only (const values, not type refs). Returns
# 0 -- recording nothing -- when the callable is empty or any argument is
# unresolvable (a template-internal generic-param name stays a shell).
resolveMonoRefInline: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    thisName: StringView
    enclKey: StringView
    op: Node
    nid: u32
} out u64 is {
    match (
        op
    ) case expression then {
        return (resolveMonoRefInline
            :ty
            :reg
            :ast
            :unitName
            :thisName
            :enclKey
            op: (ast.nodes.get i: (op.expression - 1).u64)
            :nid
        )
    } case call then {
        return (resolveMonoRefParts
            :ty
            :reg
            :ast
            :unitName
            :thisName
            :enclKey
            callable: (ast.nodes.get i: (op.callable - 1).u64)
            arguments: op.arguments
            :nid
        )
    } else null
    return 0
}

# resolveMonoRefParts -- resolveMonoRefInline's call-shaped core, taking the
# callable and argument list directly so narrowed call subjects can feed it.
resolveMonoRefParts: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    thisName: StringView
    enclKey: StringView
    callable: Node
    arguments: List u32
    nid: u32
} out u64 is {
    {
        tname9: atomName :ast n: callable
        if tname9.length == 0 then return 0
        sfx9: String
        subs9: (Map String value: u64)
        valSubsR9: (Map String value: u64)
        firstA9: u64
        allOk9: true
        aiter9: arguments.iterate
        for arg9Id9: aiter9 loop {
            arg9: ast.nodes.get i: (arg9Id9 - 1).u64
            match (
                arg9
            ) case namedoperation then {
                an9: atomName :ast n: (ast.nodes.get i: (arg9.operation - 1).u64)
                if (isNumericLiteralName name: an9.stringview) then {
                    sfx9.append s: "_"
                    sfx9.append s: an9.stringview
                    pdv9: parseDecimalU64 text: an9.stringview
                    match (
                        pdv9
                    ) case some then {
                        vpn9: zast.nameTextCopy :ast ref: arg9.name
                        vsk9: vpn9.copy
                        vsv9: pdv9
                        valSubsR9.set key: vsk9 value: vsv9
                    } case none then null
                } else {
                    aid9: u64
                    if an9.length == 0 then {
                        opf19: ast.nodes.get i: (arg9.operation - 1).u64
                        aid9 = resolveDottedArgTid :ty :reg :ast dp: opf19
                        if aid9 == 0 then {
                            inner9: (resolveMonoRefInline
                                :ty
                                :reg
                                :ast
                                :unitName
                                :thisName
                                :enclKey
                                op: (ast.nodes.get i: (arg9.operation - 1).u64)
                                nid: 0
                            )
                            if inner9 > 0 then {
                                aid9 = inner9
                            } else {
                                allOk9 = false
                            }
                        }
                    } else {
                        anc9: monoArgName an: an9.stringview :thisName
                        if anc9.length == 0 then {
                            allOk9 = false
                        } else {
                            if enclKey.length > 0 when (reg.isGenericParamOf
                                typeKey: enclKey
                                name: anc9.stringview
                            ) then {
                                epo9: (reg.genericParamTidOf
                                    typeKey: enclKey
                                    paramName: anc9.stringview
                                )
                                match (
                                    epo9
                                ) case some then {
                                    aid9 = epo9
                                } case none then {
                                    aid9 = (reg.newType
                                        name: anc9.stringview
                                        typetype: ztypes.ztypetype.genericParam
                                    )
                                    (reg.setGenericParamTid
                                        typeKey: enclKey
                                        paramName: anc9.stringview
                                        tid: aid9
                                    )
                                }
                            }
                            # a name the CURRENT unit defines wins even when
                            # not yet declared -- the ladder walk sees only
                            # declared defs and would fall through to a
                            # same-named stdlib type (resolveAtomType's rule)
                            duo9: definingUnitFor :ty currentUnit: unitName name: anc9.stringview
                            if aid9 == 0 when duo9.stringview == unitName then {
                                aid9 = (descendNamed
                                    :ty
                                    :reg
                                    :ast
                                    defUnit: duo9.stringview
                                    name: anc9.stringview
                                )
                            }
                            if aid9 == 0 then {
                                ao9: (walkLookupTyperef
                                    :ast
                                    :ty
                                    :reg
                                    currentUnit: unitName
                                    base: anc9.stringview
                                )
                                aid9 = optU64Or o: ao9 d: 0
                            }
                            if aid9 == 0 then {
                                if duo9.length > 0 then {
                                    aid9 = (descendNamed
                                        :ty
                                        :reg
                                        :ast
                                        defUnit: duo9.stringview
                                        name: anc9.stringview
                                    )
                                }
                            }
                            if aid9 == 0 then allOk9 = false
                        }
                    }
                    if aid9 > 0 then {
                        sfx9.append s: "_"
                        vn9: monoValName :ast :ty :reg tid: aid9
                        sfx9.append s: vn9.stringview
                        if firstA9 == 0 then firstA9 = aid9
                        pn9: zast.nameTextCopy :ast ref: arg9.name
                        sk9: pn9.copy
                        sv9: aid9
                        subs9.set key: sk9 value: sv9
                    }
                }
            } else null
        }
        if allOk9 == false then return 0
        if sfx9.length == 0 then return 0
        tplId9: u64
        tduo9: definingUnitFor :ty currentUnit: unitName name: tname9.stringview
        if tduo9.stringview == unitName then {
            tplId9 = (descendNamed
                :ty
                :reg
                :ast
                defUnit: tduo9.stringview
                name: tname9.stringview
            )
        }
        if tplId9 == 0 then {
            tplO9: walkLookupTyperef :ast :ty :reg currentUnit: unitName base: tname9.stringview
            tplId9 = optU64Or o: tplO9 d: 0
        }
        if tplId9 == 0 then {
            if tduo9.length > 0 then {
                tplId9 = (descendNamed
                    :ty
                    :reg
                    :ast
                    defUnit: tduo9.stringview
                    name: tname9.stringview
                )
            }
        }
        if tplId9 == 0 then return 0
        ensureNativeLinkTargets :ty :reg :ast
        # generator wrapper collapse: the synth `.call` return's Option over a
        # VALTYPE element is optionval (ownership is a physical no-op there);
        # a REFTYPE element is Option (the yielded value is owned — it must
        # outlive the `.call`, so the payload lives in a malloc'd box).
        tn9: tname9.copy
        gwv9: optBoolOr o: (ty.generatorWrapper.get key: nid.u64) d: false
        if gwv9 when firstA9 > 0 then {
            if (typeIsValtype :ty :reg tid: firstA9) then {
                ovd9: descendNamed :ty :reg :ast defUnit: "system" name: "optionval"
                if ovd9 > 0 then {
                    tplId9 = ovd9
                    tn9 = "optionval".string
                }
            } else {
                obd9: descendNamed :ty :reg :ast defUnit: "system" name: "Option"
                if obd9 > 0 then {
                    tplId9 = obd9
                    tn9 = "Option".string
                }
            }
        }
        mnOwn9: reg.regMainUnit.copy
    mainName9: mnOwn9.stringview
        mname9: "\{tn9}\{sfx9}"
        # firstA9 rides as the fallback: when a template's param name differs
        # from the call label (Option's `t` vs the conventional `of:`), the
        # clone fallback leg types native-union arms from it -- a spec first
        # minted from a TYPE-position ref must carry real arm payloads.
        mid9: (getOrMintSpec
            :ast
            :ty
            :reg
            mainName: mainName9
            name: mname9.stringview
            templateId: tplId9
            subs: subs9
            valSubs: valSubsR9
            fallbackArg: firstA9
        )
        if mid9 == 0 then return 0
        # backstop for a sized record whose size literal did not parse as a
        # decimal (the value-keyed trie path arms sized specs centrally)
        isSized9: false
        if tn9.stringview == "str" then isSized9 = true
        if tn9.stringview == "array" then isSized9 = true
        if isSized9 then {
            (mintCollectionChildren
                :ast
                :ty
                :reg
                mainName: mainName9
                monoName: mname9.stringview
                monoId: mid9
                templateId: tplId9
                suffix: sfx9.stringview
                elemArg: firstA9
                valArg: 0
            )
        }
        if nid > 0 then {
            smv9: mid9
            ty.nodeType.set key: nid.u64 value: smv9
        }
        return mid9
    }
}

# recordTyperef -- record a signature type-ref node (param / field / arm / return) for
# post-demand stamping. resolveTyperefShell yields only a NULL-unit shell and the real
# type may be unresolved here (system / forward refs), so the base name is resolved to its
# real type later by stampTyperefs. Recurses parameterized args and strip-marker dotted
# paths; `this`/`type` record as the enclosing type (thisName).
recordTyperef: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    thisName: StringView
    node: Node
} is {
    match (
        node
    ) case expression then {
        (resolveMonoRefInline
            :ty
            :reg
            :ast
            :unitName
            :thisName
            enclKey: ""
            op: (ast.nodes.get i: (node.expression - 1).u64)
            nid: node.nodeid
        )
        iex9: ast.nodes.get i: (node.expression - 1).u64
        recordTyperef :ty :reg :ast :unitName :thisName node: iex9
    } case call then {
        # Parameterized type `(T arg: U ...)`: the outer node resolves to a NULL-defined
        # mono (filtered out); record each argument's inner TYPE-ref (e.g. the `u32` in
        # `(optionval t: u32)`), but skip numeric-literal size args (the `16` in
        # `(str to: 16)`) -- they are const values, not type references. The pending
        # instantiation is recorded by the enclosing expression arm (the wrapper node
        # carries the reference's instance stamp).
        aiter: node.arguments.iterate
        for argId9: aiter loop {
            arg: ast.nodes.get i: (argId9 - 1).u64
            match (
                arg
            ) case namedoperation then {
                an: atomName :ast n: (ast.nodes.get i: (arg.operation - 1).u64)
                if (isNumericLiteralName name: an.stringview) == false then {
                    (recordTyperef
                        :ty
                        :reg
                        :ast
                        :unitName
                        :thisName
                        node: (ast.nodes.get i: (arg.operation - 1).u64)
                    )
                }
            } else null
        }
    } case dottedpath then {
        # Ownership/access strip marker (this.lock / StringView.borrow / Container.private):
        # record the dotted node with its peeled base AND recurse on the parent so the
        # stripped inner atom is stamped too (the reference stamps both ppath + stripped).
        # A `.typedef` marker only recurses -- the dotted node itself resolves to a
        # NULL-defined typedef wrapper the dump filters out.
        cn: atomName :ast n: (ast.nodes.get i: (node.child - 1).u64)
        pn: atomName :ast n: (ast.nodes.get i: (node.parent - 1).u64)
        if (reg.unitNameTid.has key: pn) then {
            # cross-unit qualified type ref (zlexer.Token): record the MEMBER under
            # its DEFINING unit (the parent) so stampTyperefs bridges this node.
            (recordResolvedName
                :ty
                unitName: pn.stringview
                :thisName
                name: cn.stringview
                nid: node.nodeid.u64
            )
        } else {
            if (isStripMarker name: cn.stringview) then {
                bn: baseTypeName :ast n: (ast.nodes.get i: (node.parent - 1).u64)
                recordResolvedName :ty :unitName :thisName name: bn.stringview nid: node.nodeid.u64
                # a parameterized parent ((List of: String).take) has no base
                # name; the marker dp wears the parent's mono stamp.
                if bn.length == 0 then {
                    (resolveMonoRefInline
                        :ty
                        :reg
                        :ast
                        :unitName
                        :thisName
                        enclKey: ""
                        op: (ast.nodes.get i: (node.parent - 1).u64)
                        nid: node.nodeid
                    )
                }
                # Ownership markers peel and stamp the inner ref; `.private` /
                # `.public` resolve the pair atomically (no base-atom stamp).
                if cn.stringview != "private" then {
                    if cn.stringview != "public" then {
                        dpp9: ast.nodes.get i: (node.parent - 1).u64
                        recordTyperef :ty :reg :ast :unitName :thisName node: dpp9
                    }
                }
            } else {
                if cn.stringview == "typedef" then {
                    dpp9: ast.nodes.get i: (node.parent - 1).u64
                    recordTyperef :ty :reg :ast :unitName :thisName node: dpp9
                }
            }
        }
    } case atomid then {
        rrA9: ast.names.texts.get i: (node.name - 1).u64
        (recordResolvedName
            :ty
            :unitName
            :thisName
            name: rrA9.stringview
            nid: node.nodeid.u64
        )
    } case labelvalue then {
        rrA9: ast.names.texts.get i: (node.name - 1).u64
        (recordResolvedName
            :ty
            :unitName
            :thisName
            name: rrA9.stringview
            nid: node.nodeid.u64
        )
    } else null
}

# returnParamTid -- when a return typeref names one of the enclosing
# template's generic parameters, its canonical parameter type id; else 0.
returnParamTid: function {
    reg: ztypes.ZTypeRegistry
    enclKey: StringView
    ast: Ast
    oId: u32
} out u64 is {
    if oId == 0 then return 0
    o: ast.nodes.get i: (oId - 1).u64
    bn: atomName :ast n: o
    # a marker-suffixed generic return (`of.take` / `of.borrow`) reads its
    # base name through the peeled parent.
    if bn.length == 0 then bn = markerPeeledBase :ast n: o
    if (reg.isGenericParamOf typeKey: enclKey name: bn.stringview) then {
        po: reg.genericParamTidOf typeKey: enclKey paramName: bn.stringview
        match (
            po
        ) case some then {
            return po
        } case none then null
        rpt7: reg.newType name: bn.stringview typetype: ztypes.ztypetype.genericParam
        reg.setGenericParamTid typeKey: enclKey paramName: bn.stringview tid: rpt7
        return rpt7
    }

    return 0
}

# partialTyperefTid -- resolve a composite parameterized typeref inside a
# template method signature to a spec through the shared disassembly
# (resolveMonoRefParts with the template's enclKey). Returns the spec only
# when it is PARTIAL (an argument named a generic param); a fully-concrete
# composite stays 0, preserving the caller's eager-path behavior.
partialTyperefTid: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    enclKey: StringView
    n: Node
} out u64 is {
    match (
        n
    ) case expression then {
        iexM9: ast.nodes.get i: (n.expression - 1).u64
        return (partialTyperefTid :ty :reg :ast :unitName :enclKey n: iexM9)
    } case dottedpath then {
        dcn6: atomName :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if (isStripMarker name: dcn6.stringview) then {
            dpq9: ast.nodes.get i: (n.parent - 1).u64
            return (partialTyperefTid :ty :reg :ast :unitName :enclKey n: dpq9)
        }
        return 0
    } case call then {
        rmp6: (resolveMonoRefParts
            :ty
            :reg
            :ast
            :unitName
            thisName: ""
            :enclKey
            callable: (ast.nodes.get i: (n.callable - 1).u64)
            arguments: n.arguments
            nid: 0
        )
        if rmp6 > 0 then {
            if (reg.typetypeOf typeId: rmp6) == ztypes.ztypetype.genericParam then return rmp6
        }
        return 0
    } else null
    return 0
}

# partialReturnTid -- partialTyperefTid over a function's return typeref.
partialReturnTid: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    enclKey: StringView
    oId: u32
} out u64 is {
    if oId == 0 then return 0
    o: ast.nodes.get i: (oId - 1).u64
    return (partialTyperefTid :ty :reg :ast :unitName :enclKey n: o)

    return 0
}

# returnIsIteratorTid -- the resolved return type belongs to an iterator
# family (ListIter/SetIter/MapKeyIter/MapItemIter or a generator's synth
# iterator `.call`... the collection families by generic origin). Iterator
# borrows stay EXCLUSIVE (many SHARED views XOR one writer XOR one
# exclusive iterator); other returned borrows are read-views and lock
# SHARED.
returnIsIteratorTid: function {st: zenv.ZSymbolTable tid: u64} out bool is {
    if tid == 0 then return false
    org9: u64
    {
        tz9: st.reg.typeById.get key: tid
        match (
            tz9
        ) case some then {
            go9: tz9.genericOriginId
            match (
                go9
            ) case some then {
                org9 = go9
            } case none then null
        } case none then null
    }
    probe9: tid
    if org9 > 0 then probe9 = org9
    pn9: typeNameOf :st tid: probe9
    if pn9.stringview == "ListIter" then return true
    if pn9.stringview == "SetIter" then return true
    if pn9.stringview == "MapKeyIter" then return true
    if pn9.stringview == "MapItemIter" then return true
    return false
}

# markerPeeledBase -- the base atom name under a strip-marker dotted path
# (`of.take` -> "of"); "" for any other shape.
markerPeeledBase: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        mcn3: atomName :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if (isStripMarker name: mcn3.stringview) then {
            return (atomName :ast n: (ast.nodes.get i: (n.parent - 1).u64))
        }
        return "".string
    } else {
        return "".string
    }
}

# stampGenericParamRef -- a return typeref naming one of the enclosing
# template's generic params stamps the unit's generic-param type directly
# (generic params live outside the name-resolution table).
stampGenericParamRef: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    enclKey: StringView
    ast: Ast oId: u32
} is {
    if oId == 0 then return
    o: ast.nodes.get i: (oId - 1).u64
    bn: atomName :ast n: o
    # a marker-suffixed generic return (`of.take` / `of.borrow`) reads its
    # base name through the peeled parent; the marker dp wears the stamp,
    # matching recordTyperef's convention for concrete marked returns.
    if bn.length == 0 then bn = markerPeeledBase :ast n: o
    if (reg.isGenericParamOf typeKey: enclKey name: bn.stringview) then {
        gpt3: u64
        gpo3: reg.genericParamTidOf typeKey: enclKey paramName: bn.stringview
        match (
            gpo3
        ) case some then {
            gpt3 = gpo3
        } case none then {
            gpt3 = reg.newType name: bn.stringview typetype: ztypes.ztypetype.genericParam
            reg.setGenericParamTid typeKey: enclKey paramName: bn.stringview tid: gpt3
        }
        gnid3: nodeId n: o
        gpv3b: gpt3
        ty.nodeType.set key: gnid3.u64 value: gpv3b
    }

}

# recordGenericMarkerReturn -- a marker-suffixed generic-param return
# (`out of.take` / `out of.borrow`) records its peeled base name at the
# dotted node (pendingTyperef) so the mono-return substitution finds it:
# the plain-atom leg records inside recordTyperef, while the marker leg
# only resolution-stamps.
recordGenericMarkerReturn: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    enclKey: StringView
    ast: Ast oId: u32
} is {
    if oId == 0 then return
    o: ast.nodes.get i: (oId - 1).u64
    mpb3: markerPeeledBase :ast n: o
    if mpb3.length > 0 when (reg.isGenericParamOf typeKey: enclKey name: mpb3.stringview) then {
        mnid3: nodeId n: o
        recordNodeName :ty :unitName name: mpb3.stringview nid: mnid3.u64
    }

}

# recordFuncReturnNode -- map a function type id to its return type-ref's node id
# so a call site can read the resolved return type (node_type, post stampTyperefs).
recordFuncReturnNode: function {ty: ztyping.ZTyping fid: u64 ast: Ast oId: u32} is {
    if oId == 0 then return
    o: ast.nodes.get i: (oId - 1).u64
    rn: nodeId n: o
    fidc: fid
    ty.funcReturnNode.set key: fidc value: rn.u64

}

# recordReturnType -- record a function's `out T` return type-ref (mirrors
# demandReturnType's extraction). A parameterized return (out (Result ...)) yields no
# bare base name and is skipped (its mono is NULL-defined, filtered out anyway).
recordReturnType: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    thisName: StringView
    oId: u32
} is {
    if oId == 0 then return
    o: ast.nodes.get i: (oId - 1).u64
    recordTyperef :ty :reg :ast :unitName :thisName node: o

}

# demandTyperefNames -- record demands for every name a type-expr
# references (the head and, transitively, parameter-arg names), so the
# demand walks resolve a signature's full closure. Creates no types.
demandTyperefNames: function {
    ast: Ast
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    typeExpr: Node
} is {
    match (
        typeExpr
    ) case atomid then {
        teN9: ast.names.texts.get i: (typeExpr.name - 1).u64
        if (isNumericLiteralName name: teN9.stringview) == false then {
            reg.recordDemand name: teN9.stringview
            reg.recordSeededDemand un: unitName name: teN9.stringview
        }
    } case expression then {
        (demandTyperefNames
            :ast
            :reg
            :unitName
            typeExpr: (ast.nodes.get i: (typeExpr.expression - 1).u64)
        )
    } case call then {
        hn: atomName :ast n: (ast.nodes.get i: (typeExpr.callable - 1).u64)
        if hn.length > 0 then {
            reg.recordDemand name: hn.stringview
            reg.recordSeededDemand un: unitName name: hn.stringview
        }
        aiter: typeExpr.arguments.iterate
        for argId9: aiter loop {
            arg: ast.nodes.get i: (argId9 - 1).u64
            match (
                arg
            ) case namedoperation then {
                (demandTyperefNames
                    :ast
                    :reg
                    :unitName
                    typeExpr: (ast.nodes.get i: (arg.operation - 1).u64)
                )
            } else null
        }
    } case dottedpath then {
        (demandTyperefNames
            :ast
            :reg
            :unitName
            typeExpr: (ast.nodes.get i: (typeExpr.parent - 1).u64)
        )
    } else null
}

# typeArgSuffixName -- the suffix component a collection type-arg contributes to a
# shell mono name. A bare atom gives its name; a cross-unit dotted ref gives its
# MEMBER name (ztypes.zparamownership -> zparamownership) so the shell's mono name
# matches the construction path's typeNameOf-based name. Without this the dotted
# arg's atomName is "" and the shell mints `Map_u64_` (empty value), a distinct id
# from the constructed `Map_u64_zparamownership` -- the emitter's fieldMonoId
# canonicalizes by name, so divergent names leave a field/create type mismatch.
typeArgSuffixName: function {ast: Ast reg: ztypes.ZTypeRegistry op: Node} out String is {
    match (
        op
    ) case expression then {
        return (typeArgSuffixName :ast :reg op: (ast.nodes.get i: (op.expression - 1).u64))
    } case dottedpath then {
        pNm: atomName :ast n: (ast.nodes.get i: (op.parent - 1).u64)
        if (reg.isUnitName name: pNm.stringview) then {
            return (atomName :ast n: (ast.nodes.get i: (op.child - 1).u64))
        } else {
            return "".string
        }
    } else {
        return (atomName :ast n: op)
    }
}

resolveTyperefShell: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    typeExpr: Node
    thisName: StringView
} out u64 is {
    match (
        typeExpr
    ) case atomid then {
        teR9: ast.names.texts.get i: (typeExpr.name - 1).u64
        reg.recordDemand name: teR9.stringview
        reg.recordSeededDemand un: unitName name: teR9.stringview
        return (resolveAtomType
            :ty
            :reg
            :ast
            :unitName
            nm: teR9.stringview
            :thisName
        )
    } case labelvalue then {
        teL9: ast.names.texts.get i: (typeExpr.name - 1).u64
        return (resolveAtomType
            :ty
            :reg
            :ast
            :unitName
            nm: teL9.stringview
            :thisName
        )
    } case expression then {
        return (resolveTyperefShell
            :ty
            :reg
            :ast
            :unitName
            typeExpr: (ast.nodes.get i: (typeExpr.expression - 1).u64)
            :thisName
        )
    } case call then {
        imid8: (resolveMonoRefParts
            :ty
            :reg
            :ast
            :unitName
            :thisName
            enclKey: ""
            callable: (ast.nodes.get i: (typeExpr.callable - 1).u64)
            arguments: typeExpr.arguments
            nid: 0
        )
        if imid8 > 0 then return imid8
        suffix: atomName :ast n: (ast.nodes.get i: (typeExpr.callable - 1).u64)
        reg.recordDemand name: suffix.stringview
        reg.recordSeededDemand un: unitName name: suffix.stringview
        aiter: typeExpr.arguments.iterate
        for argId9: aiter loop {
            arg: ast.nodes.get i: (argId9 - 1).u64
            match (
                arg
            ) case namedoperation then {
                an: typeArgSuffixName :ast :reg op: (ast.nodes.get i: (arg.operation - 1).u64)
                suffix.append "_"
                suffix.append an.stringview
                (demandTyperefNames
                    :ast
                    :reg
                    :unitName
                    typeExpr: (ast.nodes.get i: (arg.operation - 1).u64)
                )
            } else null
        }
        return (reg.newType name: suffix.stringview typetype: ztypes.ztypetype.recordType)
    } case dottedpath then {
        # A cross-unit qualified type ref (zlexer.Token) names the MEMBER in the
        # referenced unit -- resolve the child like a bare atom. Otherwise a dotted
        # type-expr peels to its parent: an ownership/access strip marker
        # (Container.private.lock) or a variant/union subtype default where the arm
        # is the default value and the type is the parent (direction.north).
        pNm: atomName :ast n: (ast.nodes.get i: (typeExpr.parent - 1).u64)
        if (reg.isUnitName name: pNm.stringview) then {
            cNm: atomName :ast n: (ast.nodes.get i: (typeExpr.child - 1).u64)
            reg.recordDemand name: cNm.stringview
            reg.recordSeededDemand un: unitName name: cNm.stringview
            did8: descendNamed :ty :reg :ast defUnit: pNm.stringview name: cNm.stringview
            if did8 > 0 then return did8
            return (resolveAtomType :ty :reg :ast :unitName nm: cNm.stringview :thisName)
        } else {
            # a dotted numeric literal (4.u64, 2.5.f32) declares the SUFFIX
            # type: peeling to the numeric parent would collapse it to the
            # literal default (i64/f64), silently mistyping the slot
            nSfx9: atomName :ast n: (ast.nodes.get i: (typeExpr.child - 1).u64)
            isSfx9: isNumericTypeName name: nSfx9.stringview
            if (isNumericLiteralName name: pNm.stringview) when isSfx9 then {
                return (resolveAtomType
                    :ty
                    :reg
                    :ast
                    :unitName
                    nm: nSfx9.stringview
                    :thisName
                )
            }
            return (resolveTyperefShell
                :ty
                :reg
                :ast
                :unitName
                typeExpr: (ast.nodes.get i: (typeExpr.parent - 1).u64)
                :thisName
            )
        }
    } else {
        return (reg.newType name: "?" typetype: ztypes.ztypetype.recordType)
    }
}

# regTypeNameOf -- a type's name (owned copy) straight off the registry.
regTypeNameOf: function {reg: ztypes.ZTypeRegistry tid: u64} out String is {
    t: reg.typeById.get key: tid
    match (
        t
    ) case some then {
        return t.name.copy
    } case none then {
        return "".string
    }
}

# typeofSourceType -- resolve a typeof field's SOURCE without a body walk
# (the reference's resolution-time method walks run its placeholder swap
# even in resolve-only mode; our sources are signature-resolvable): a bare
# atom reads the owner's already-resolved field of that name (a generator
# parameter capture), and a call to a lowered factory yields the factory's
# `{name}_iter` class. 0 when the shape needs the body walk.
typeofSourceType: function {ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    ownerId: u64
    n: Node
} out u64 is {
    match (
        n
    ) case expression then {
        return (typeofSourceType
            :ast
            :ty
            :reg
            :unitName
            :ownerId
            n: (ast.nodes.get i: (n.expression - 1).u64)
        )
    } case atomid then {
        if ownerId == 0 then return 0
        co: ty.childOfId parentTypeId: ownerId nameId: n.name.u64
        match (
            co
        ) case some then {
            cn9: regTypeNameOf :reg tid: co
            if cn9.length > 0 then {
                ro9: walkLookupTyperef :ast :ty :reg currentUnit: unitName base: cn9.stringview
                match (
                    ro9
                ) case some then {
                    return ro9
                } case none then {
                    return co
                }
            } else {
                return co
            }
        } case none then {
            return 0
        }
    } case call then {
        fn9: atomName :ast n: (ast.nodes.get i: (n.callable - 1).u64)
        if fn9.length > 0 then {
            sk9: "\{unitName}.\{fn9}_iter"
            so9: resolvedByKey :ast :ty :reg key: sk9
            match (
                so9
            ) case some then {
                return so9
            } case none then {
                return 0
            }
        } else {
            return 0
        }
    } else {
        return 0
    }
}

# resolveTyperefShellMarked -- resolveTyperefShell plus the typeof handling:
# a generator-promoted local's field type is a `typeof <first-rhs>` node.
# When the source resolves from signatures alone the field types directly
# (and the typeof node stamps); otherwise the shell is marked and the
# body's first `this.<field> =` write swaps it (the reference's
# placeholder mechanism).
resolveTyperefShellMarked: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    ownerId: u64
    typeExpr: Node
    thisName: StringView
} out u64 is {
    isTof: false
    match (
        typeExpr
    ) case typeofexpr then {
        isTof = true
        tsx9: ast.nodes.get i: (typeExpr.source - 1).u64
        rid9: typeofSourceType :ast :ty :reg :unitName :ownerId n: tsx9
        if rid9 > 0 then {
            # the node's stamp defers to the post-demand pass so it lands
            # on the globally-resolved type, not an early shell
            tnm9: regTypeNameOf :reg tid: rid9
            if tnm9.length > 0 then {
                ty.pendingTyperef.set key: typeExpr.nodeid.u64 value: tnm9
                tun9: unitName.string
                ty.pendingTyperefUnit.set key: typeExpr.nodeid.u64 value: tun9
            }
            return rid9
        }
    } else null
    prevCE9: ty.inContainmentEdge
    ty.inContainmentEdge = true
    cid: resolveTyperefShell :ty :reg :ast :unitName :typeExpr :thisName
    ty.inContainmentEdge = prevCE9
    if isTof then {
        match (
            typeExpr
        ) case typeofexpr then {
            tk: cid
            tv: typeExpr.nodeid
            ty.typeofShell.set key: tk value: tv
        } else null
    }
    return cid
}

# nameIsInUnitReftype -- true when a type name resolves to an in-unit reference type
# (class or union). Drives the reftype-param BORROW default and class field cleanup.
# Native heap params (String/List/Map) are pointer-typed already and get no BORROW
# default (mirrors the reference's `not is_heap_allocated` guard), so they are NOT
# matched here -- only user class/union types defined in this unit.
nameIsInUnitReftype: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    name: StringView
} out bool is {
    rr: resolveUnitChild :ast :ty :reg :unitName :name
    match (
        rr
    ) case some then {
        tt: reg.typetypeOf typeId: rr
        match (
            tt
        ) case classType then {
            return true
        } case unionType then {
            return true
        } else {
            return false
        }
    } case none then {
        return false
    }
}

# paramTypeBaseName -- the base type name of a (possibly parameterized) param type
# expression: an atom name directly, or the callable of a parenthesized
# `(List of: i64)` form (an expression wrapping a call). "" for anything else.
# returnHasBorrowMarkerNode / returnHasBorrowMarker -- the function's return
# type carries the `.borrow` marker (`out StringView.borrow`).
returnHasBorrowMarkerNode: function {ast: Ast n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (returnHasBorrowMarkerNode :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case dottedpath then {
        cn: atomName :ast n: (ast.nodes.get i: (n.child - 1).u64)
        return cn.stringview == "borrow"
    } else {
        return false
    }
}

returnHasBorrowMarker: function {ast: Ast oId: u32} out bool is {
    if oId == 0 then return false
    o: ast.nodes.get i: (oId - 1).u64
    return (returnHasBorrowMarkerNode :ast n: o)

}

# paramIsThisReceiver -- the parameter's type names the receiver: bare `this`
# or a marker-suffixed `this.lock` / `this.borrow`.
paramIsThisReceiver: function {ast: Ast op: Node} out bool is {
    match (
        op
    ) case expression then {
        return (paramIsThisReceiver :ast op: (ast.nodes.get i: (op.expression - 1).u64))
    } case atomid then {
        return op.name == wkThis
    } case dottedpath then {
        pn: atomName :ast n: (ast.nodes.get i: (op.parent - 1).u64)
        return pn.stringview == "this"
    } else {
        return false
    }
}

paramTypeBaseName: function {ast: Ast op: Node} out String is {
    match (
        op
    ) case atomid then {
        return (zast.nameTextCopy :ast ref: op.name)
    } case labelvalue then {
        return (zast.nameTextCopy :ast ref: op.name)
    } case expression then {
        return (paramTypeBaseName :ast op: (ast.nodes.get i: (op.expression - 1).u64))
    } case call then {
        return (atomName :ast n: (ast.nodes.get i: (op.callable - 1).u64))
    } else {
        return "".string
    }
}

# isBorrowReftypeCollection -- true for a parameterized collection whose mono is a
# non-heap-allocated reftype, which takes the reftype-param BORROW default: List and
# ListView (stack struct + heap buffer). Set/Map monos are heap-allocated (no BORROW);
# the native iterator views have no destructor (no BORROW); str/array are valtypes.
# Mirrors the is_heap_allocated the reference stamps on collection monos.
isBorrowReftypeCollection: function {name: StringView} out bool is {
    if name == "List" then return true
    if name == "ListView" then return true
    return false
}

# isBorrowNativeReftype -- true for native heap-owning reftypes (currently String)
# that take the BORROW default as an unannotated param. Keyed by name, like the
# classifiers above: the oracle decides by metadata (a native CLASS that owns heap,
# not is_heap_allocated), but native types resolve AFTER the main unit, so that
# metadata is not yet populated when a param resolves.
isBorrowNativeReftype: function {name: StringView} out bool is {
    if name == "String" then return true
    return false
}

# isNativeValueView -- true for StringView, the native immutable string view (subtype
# STRINGVIEW): a param of this type stays unowned (a value-passed copy of a borrowed
# view), so it takes no BORROW default. Other reftypes -- String (native, owns heap),
# the mutable iterators (CpIter/Splitter/LinesIter), and non-native views (ListView/
# OptionView) -- take the normal reftype-param BORROW default.
isNativeValueView: function {name: StringView} out bool is {
    if name == "StringView" then return true
    return false
}

# demandReturnType -- record cross-unit demand for a function's return-type base
# name (`out (Result t: u64 e: IoError)` -> demand "Result"), so a type named only
# in a return position is resolved. The Option is borrowed, never bound.
demandReturnType: function {
    ast: Ast
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    oId: u32
} is {
    if oId == 0 then return
    o: ast.nodes.get i: (oId - 1).u64
    demandTyperefNames :ast :reg :unitName typeExpr: o

}

# resolveFunction -- resolve a function definition signature into a FUNCTION
# type: a child per parameter (param name -> type-ref shell, `this` params bound
# to thisName), its defining unit (source-types filter), and a `{unit}.{name}`
# entry in the resolved name-view. Returns the FUNCTION type id (a record method
# binds it as a child; a free function discards it). The map `set`s TAKE the u64,
# so copies are threaded for `definedInUnit.set` and the returned id.
# fnHasLockParam -- does any parameter (including a `this.lock` receiver) carry
# a `.lock` marker? A `.borrow` return must borrow from a locked parameter so
# the returned view has a locked parent to live in (docs/ownership.pdoc).
fnHasLockParam: function {ast: Ast fnode: zast.FunctionData} out bool is {
    found9: false
    with pit9: fnode.parameters.iterate do for pmId9: pit9 loop {
        if (found9) == false then {
            pm9: ast.nodes.get i: (pmId9 - 1).u64
            match (
                pm9
            ) case namedoperation then {
                po9: pathOwnership :ast n: (ast.nodes.get i: (pm9.operation - 1).u64)
                match (
                    po9
                ) case some then {
                    if po9 == ztypes.zparamownership.lockMode then found9 = true
                } case none then null
            } else null
        }
    }
    return found9
}

# checkBorrowReturnLock -- a `.borrow`-returning function must borrow from a
# `.lock` parameter (a `this.lock` receiver counts), so the returned view has a
# locked parent (docs/ownership.pdoc). Runs at every function/method decl.
checkBorrowReturnLock: function {
    ast: Ast
    ty: ztyping.ZTyping
    fnode: zast.FunctionData
    defName: StringView
} is {
    if (returnHasBorrowMarker :ast oId: fnode.returntype) then {
        if (fnHasLockParam :ast :fnode) == false then {
            (addResolveErrorH
                :ty
                nodeid: fnode.nodeid
                lineno: fnode.lineno
                colno: fnode.colno
                e: zast.err.ownerError
                msg: "a `.borrow` return must borrow from a `.lock` parameter -- mark the source parameter (e.g. `t: this.lock`) so the returned view has a locked parent".string
                width: defName.length.u32.orPanic
            )
        }
    }
}

resolveFunction: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    defName: StringView
    fnode: zast.FunctionData
    thisName: StringView
    skipThisType: bool
} out u64 is {
    fid: (declareCanonicalType
        :ast
        :ty
        :reg
        defUnit: unitName
        name: defName
        typetype: ztypes.ztypetype.functionType
    )
    reg.setNative typeId: fid value: fnode.isNative
    {
        fhbV: fnode.body > 0
        fhbK: fid
        ty.fnHasBody.set key: fhbK value: fhbV
    }
    dfid: fid
    rfid: fid
    isgen: hasGenericParam :ast items: fnode.asItems
    if isgen then {
        reg.setGeneric typeId: fid value: true
        # Function templates register their param constraints like type
        # templates do (checkGenericCall checks satisfaction per call).
        fgtk9: "\{unitName}.\{defName}"
        registerGenericParams :ast :reg typeKey: fgtk9.stringview items: fnode.asItems
        aiter2: fnode.asItems.iterate
        for amId9: aiter2 loop {
            am: ast.nodes.get i: (amId9 - 1).u64
            match (
                am
            ) case namedoperation then {
                if (isGenericParam :ast op: (ast.nodes.get i: (am.operation - 1).u64)) then {
                    apn: zast.nameTextCopy :ast ref: am.name
                    ty.setGenericArg parentTypeId: fid paramName: apn.stringview argTypeId: 0
                }
            } else null
        }
        hasB: fnode.body > 0
        if hasB then {
            dvg: bodyEndsInReturn :ast bodyId: fnode.body
            fidd: fid
            ty.fnBodyDiverges.set key: fidd value: dvg
        }
    }
    enclKey: unitName.string
    if thisName.length != 0 then enclKey = "\{unitName}.\{thisName}"
    fnKey9: String
    if isgen then fnKey9 = "\{unitName}.\{defName}"
    piter: fnode.parameters.iterate
    for pmId9: piter loop {
        pm: ast.nodes.get i: (pmId9 - 1).u64
        match (
            pm
        ) case namedoperation then {
            skipParam: false
            genParam: false
            fnParam9: false
            ptn: atomName :ast n: (ast.nodes.get i: (pm.operation - 1).u64)
            if skipThisType then {
                if ptn.stringview == "this" then skipParam = true
            }
            if skipParam == false when isgen then {
                if (reg.isGenericParamOf typeKey: fnKey9.stringview name: ptn.stringview) then {
                    skipParam = true
                    fnParam9 = true
                }
            }
            if skipParam == false when (reg.isGenericParamOf
                typeKey: enclKey.stringview
                name: ptn.stringview
            ) then {
                skipParam = true
                genParam = true
            }
            if skipParam then {
                if fnParam9 then {
                    # the template's own param: bind the canonical
                    # per-(template,param) tid as the child so holder
                    # inference and the idSubs clone substitution ride it.
                    # No node stamp (fn monos re-walk the SHARED template
                    # AST) and no typeref/demand recording (a user type
                    # coincidentally named like the param must not bind).
                    pnameF9: zast.nameTextCopy :ast ref: pm.name
                    fpt9: u64
                    fpo9: reg.genericParamTidOf typeKey: fnKey9.stringview paramName: ptn.stringview
                    match (
                        fpo9
                    ) case some then {
                        fpt9 = fpo9
                    } case none then {
                        fpt9 = (reg.newType
                            name: ptn.stringview
                            typetype: ztypes.ztypetype.genericParam
                        )
                        (reg.setGenericParamTid
                            typeKey: fnKey9.stringview
                            paramName: ptn.stringview
                            tid: fpt9
                        )
                    }
                    (ty.setChildId
                        parentTypeId: fid
                        nameId: pm.name.u64
                        childTypeId: fpt9
                    )
                }
                if genParam then {
                    # the unit's own param: stamp the param node with the
                    # canonical per-(enclosing,param) tid (get-or-mint). No
                    # setChild -- unit template methods stay childless (emit
                    # `(void)`); unit bodies clone, so the stamp is per-clone.
                    gpt2: u64
                    gpo2: (reg.genericParamTidOf
                        typeKey: enclKey.stringview
                        paramName: ptn.stringview
                    )
                    match (
                        gpo2
                    ) case some then {
                        gpt2 = gpo2
                    } case none then {
                        gpt2 = (reg.newType
                            name: ptn.stringview
                            typetype: ztypes.ztypetype.genericParam
                        )
                        (reg.setGenericParamTid
                            typeKey: enclKey.stringview
                            paramName: ptn.stringview
                            tid: gpt2
                        )
                    }
                    pnid2: nodeId n: (ast.nodes.get i: (pm.operation - 1).u64)
                    gpv2b: gpt2
                    ty.nodeType.set key: pnid2.u64 value: gpv2b
                    if thisName.length != 0 then {
                        (ty.setChildId
                            parentTypeId: fid
                            nameId: pm.name.u64
                            childTypeId: gpt2
                        )
                    }
                }
            } else {
                pname: zast.nameTextCopy :ast ref: pm.name
                cid: (resolveTyperefShell
                    :ty
                    :reg
                    :ast
                    :unitName
                    typeExpr: (ast.nodes.get i: (pm.operation - 1).u64)
                    :thisName
                )
                (ty.setChildId
                    parentTypeId: fid
                    nameId: pm.name.u64
                    childTypeId: cid
                )
                if (isNumericLiteralName name: ptn.stringview) then {
                    (ty.setChildDefault
                        pool: ast.names
                        parentTypeId: fid
                        name: pname.stringview
                        default: ptn.stringview
                    )
                } else {
                    fnRefIsFn9: false
                    fnRefOpt9: (walkLookupTyperef
                        :ast
                        :ty
                        :reg
                        currentUnit: unitName
                        base: ptn.stringview
                    )
                    match (
                        fnRefOpt9
                    ) case some then {
                        if (reg.typetypeOf typeId: fnRefOpt9) == ztypes.ztypetype.functionType then {
                            fnRefIsFn9 = true
                        }
                    } case none then null
                    if fnRefIsFn9 then {
                        (ty.setDefaultFunction
                            pool: ast.names
                            parentTypeId: fid
                            name: pname.stringview
                            funcname: ptn.stringview
                        )
                    } else {
                        pdcn9: dottedChildName :ast n: (ast.nodes.get i: (pm.operation - 1).u64)
                        if pdcn9.length > 0 when (isStripMarker name: pdcn9.stringview) == false then {
                            prn9: rootNameOf :ast n: (ast.nodes.get i: (pm.operation - 1).u64)
                            # a dotted numeric literal (0.u64) is a typed numeric
                            # default, not a variant arm (mirrors the field
                            # classifiers' rootNameOf guard)
                            if (isNumericLiteralName name: prn9.stringview) then {
                                (ty.setChildDefault
                                    pool: ast.names
                                    parentTypeId: fid
                                    name: pname.stringview
                                    default: prn9.stringview
                                )
                            } else if (reg.isUnitName name: prn9.stringview) == false then {
                                (ty.setDefaultVariantArm
                                    pool: ast.names
                                    parentTypeId: fid
                                    name: pname.stringview
                                    armName: pdcn9.stringview
                                )
                            }
                        }
                    }
                }
                if (paramIsThisReceiver :ast op: (ast.nodes.get i: (pm.operation - 1).u64)) then {
                    reg.setThisParamName typeId: fid name: pname.stringview
                }
                (recordTyperef
                    :ty
                    :reg
                    :ast
                    :unitName
                    :thisName
                    node: (ast.nodes.get i: (pm.operation - 1).u64)
                )
                pown: pathOwnership :ast n: (ast.nodes.get i: (pm.operation - 1).u64)
                match (
                    pown
                ) case some then {
                    (ty.setChildOwnership
                        pool: ast.names
                        parentTypeId: fid
                        name: pname.stringview
                        ownership: pown
                    )
                } case none then {
                    isref: (paramIsBorrowReftype
                        :ast
                        :ty
                        :reg
                        :unitName
                        :thisName
                        op: (ast.nodes.get i: (pm.operation - 1).u64)
                    )
                    if isref then {
                        (ty.setChildOwnership
                            pool: ast.names
                            parentTypeId: fid
                            name: pname.stringview
                            ownership: ztypes.zparamownership.borrowMode
                        )
                    }
                }
            }
        } else null
    }
    demandReturnType :ast :reg :unitName oId: fnode.returntype
    (recordReturnType
        :ty
        :reg
        :ast
        :unitName
        :thisName
        oId: fnode.returntype
    )
    recordFuncReturnNode :ast :ty :fid oId: fnode.returntype
    (stampGenericParamRef
        :ty
        :reg
        :ast
        enclKey: enclKey.stringview
        oId: fnode.returntype
    )
    (recordGenericMarkerReturn
        :ty
        :reg
        :ast
        :unitName
        enclKey: enclKey.stringview
        oId: fnode.returntype
    )
    rpt4: u64
    frOpt9: fnode.returntype
    if isgen then {
        rpt4 = returnParamTid :ast :reg enclKey: fnKey9.stringview oId: frOpt9
    }
    if rpt4 == 0 then {
        frOpt9b: fnode.returntype
        rpt4 = returnParamTid :ast :reg enclKey: enclKey.stringview oId: frOpt9b
    }
    if rpt4 > 0 then {
        reg.setReturnType typeId: fid value: rpt4
        # a method whose return is a generic param (its own OR the enclosing
        # type's) is a per-instance clone candidate: mintMono's clone loop
        # (gated on isgeneric) must substitute the return for each mono
        reg.setGeneric typeId: fid value: true
    }
    if rpt4 == 0 when unitName == "collections" then {
        # collection template methods declare composite parameterized returns
        # ((ListIter of: of).borrow); they resolve to partial specs so clones
        # heal through respecialize. Map.get/remove keep their value-kind
        # wrapper projection (optionval/Option/OptionView by the value's
        # nature) and are skipped here.
        skipPr4: false
        if defName == "Map.get" then skipPr4 = true
        if defName == "Map.remove" then skipPr4 = true
        if skipPr4 == false then {
            prt4: (partialReturnTid
                :ty
                :reg
                :ast
                :unitName
                enclKey: enclKey.stringview
                oId: fnode.returntype
            )
            if prt4 > 0 then reg.setReturnType typeId: fid value: prt4
        }
    }
    if (returnHasBorrowMarker :ast oId: fnode.returntype) then {
        fbk: fid
        fbv: true
        ty.funcReturnsBorrow.set key: fbk value: fbv
    }
    checkBorrowReturnLock :ast :ty :fnode :defName
    ty.definedInUnit.set key: dfid value: unitName.string
    return rfid
}

# paramIsBorrowReftype -- the default-ownership rule for a parameter with no
# explicit suffix: user reftypes (and the borrow-default native reftypes /
# collections) borrow; native value views do not.
paramIsBorrowReftype: function {ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    thisName: StringView
    op: Node
} out bool is {
    tn: atomName :ast n: op
    isref: false
    if tn.stringview == "this" then {
        isref = nameIsInUnitReftype :ast :ty :reg :unitName name: thisName
        if (isref) == false then {
            tk0: thisName.string
            rgo: ty.mainDefIsReftype.get key: tk0
            match (
                rgo
            ) case some then {
                isref = rgo
            } case none then null
        }
        if (isNativeValueView name: thisName) then isref = false
    } else {
        if tn.length == 0 then {
            base: paramTypeBaseName :ast :op
            isref = isBorrowReftypeCollection name: base.stringview
        } else {
            isref = nameIsInUnitReftype :ast :ty :reg :unitName name: tn.stringview
            tdu: definingUnitFor :ty currentUnit: unitName name: tn.stringview
            if (isBorrowNativeReftype name: tn.stringview) when tdu.stringview == "system" then {
                isref = true
            }
            if (isNativeValueView name: tn.stringview) when tdu.stringview == "system" then {
                isref = false
            }
        }
    }
    return isref
}

# resolveMethodFn -- resolve one record-method as-item (a namedoperation whose
# operation is a functiondef) into a qualified `{record}.{method}` FUNCTION type,
# `this` params bound to thisName (the record). Returns its type id, or none for a
# non-function as-item (tag spec / generic param), which the caller skips.
resolveMethodFn: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    qname: StringView
    thisName: StringView
    op: Node
} out optionval u64 is {
    match (
        op
    ) case functiondef then {
        mid: (resolveFunction
            :ty
            :reg
            :ast
            :unitName
            defName: qname
            fnode: op
            :thisName
            skipThisType: false
        )
        midS: mid
        ty.nodeType.set key: op.nodeid.u64 value: midS
        return (optionval.some mid)
    } else {
        return (optionval.none u64)
    }
}

# functiondefIsNative -- an is-block method marked `is native` (no body to
# check or emit; its members come from the native materializer).
functiondefIsNative: function {op: Node} out bool is {
    match (
        op
    ) case functiondef then {
        return op.isNative
    } else {
        return false
    }
}

# isFunctionDefOp -- true when an is-block item's operation is a functiondef (a
# method), false for a field type-ref. Gates generic-class method production without
# resolving the function -- mirrors the oracle's isgeneric gate, which never builds a
# method FUNCTION type for a generic class (so no spurious collections FUNCTION row).
isFunctionDefOp: function {op: Node} out bool is {
    match (
        op
    ) case functiondef then {
        return true
    } else {
        return false
    }
}

# resolveSpecFn -- resolve one facet/protocol is-block spec method (a namedoperation
# whose operation is a functiondef) into a qualified `{type}.{spec}` FUNCTION. Like
# resolveMethodFn but drops the `:this` receiver: a facet/protocol `this` resolves to
# nothing (the reference returns no type), so the spec keeps only its real params.
resolveSpecFn: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    qname: StringView
    thisName: StringView
    op: Node
    skipThis: bool
} out optionval u64 is {
    match (
        op
    ) case functiondef then {
        sid: (resolveFunction
            :ty
            :reg
            :ast
            :unitName
            defName: qname
            fnode: op
            :thisName
            skipThisType: skipThis
        )
        sidS: sid
        ty.nodeType.set key: op.nodeid.u64 value: sidS
        return (optionval.some sid)
    } else {
        return (optionval.none u64)
    }
}

# markerTargetId -- the FACET/PROTOCOL type a conformance as-item points at
# (`m: measurable` / `myreader: Reader`), or none for a method / `create: null` /
# any other as-item. The target must already be resolved (defined earlier in the unit).
markerTargetId: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    ast: Ast
    op: Node
} out optionval u64 is {
    tn: atomName :ast n: op
    if tn.length == 0 then return (optionval.none u64)
    rkey: "\{unitName}.\{tn}"
    rr: resolvedByKey :ast :ty :reg key: rkey
    match (
        rr
    ) case some then {
        tt: reg.typetypeOf typeId: rr
        match (
            tt
        ) case facetType then {
            return (optionval.some rr)
        } case protocolType then {
            return (optionval.some rr)
        } case recordType then {
            return (optionval.some rr)
        } else {
            return (optionval.none u64)
        }
    } case none then {
        return (optionval.none u64)
    }
}

# eqNullOptOut -- true when a type's `as {}` block opts out of equality by
# declaring `==: null` or `!=: null` (mirrors the `create: null` opt-out): the
# record / variant synthetic `==` / `!=` is then suppressed, so a comparison on
# the type resolves no method and is a hard error.
eqNullOptOut: function {ast: Ast asItems: List u32} out bool is {
    result: false
    with aiter: asItems.iterate do for amId9: aiter loop {
        am: ast.nodes.get i: (amId9 - 1).u64
        match (
            am
        ) case namedoperation then {
            mn9: zast.nameTextCopy :ast ref: am.name
            isEqNe9: false
            if mn9.stringview == "==" then isEqNe9 = true
            if mn9.stringview == "!=" then isEqNe9 = true
            if isEqNe9 then {
                vn9: atomName :ast n: (ast.nodes.get i: (am.operation - 1).u64)
                if vn9.stringview == "null" then result = true
            }
        } else null
    }
    return result
}

# attachMethods -- resolve an as-block's method items (namedoperation -> functiondef)
# as children of `parentId`, returning whether one is named `create` (so the caller
# skips the synth create). Takes the item list by value so its iterator's lock is
# released on return -- letting attachMarkers re-scan the same list (cf. resolveUnion).
attachMethods: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    defName: StringView
    parentId: u64
    asItems: List u32
} out bool is {
    hasCreate: false
    aiter: asItems.iterate
    for amId9: aiter loop {
        am: ast.nodes.get i: (amId9 - 1).u64
        match (
            am
        ) case namedoperation then {
            mname: zast.nameTextCopy :ast ref: am.name
            if mname.stringview == "create" then hasCreate = true
            {
                mop9: ast.nodes.get i: (am.operation - 1).u64
                match (
                    mop9
                ) case functiondef then {
                    checkBorrowReturnLock :ast :ty fnode: mop9 defName: mname.stringview
                } else null
            }
            qname: "\{defName}.\{mname}"
            mido: (resolveMethodFn
                :ty
                :reg
                :ast
                :unitName
                qname: qname.stringview
                thisName: defName
                op: (ast.nodes.get i: (am.operation - 1).u64)
            )
            match (
                mido
            ) case some then {
                (ty.setChildId
                    parentTypeId: parentId
                    nameId: am.name.u64
                    childTypeId: mido
                )
            } case none then {
                cn: atomName :ast n: (ast.nodes.get i: (am.operation - 1).u64)
                if (isNumericLiteralName name: cn.stringview) then {
                    # A static constant's child is a per-constant NULL-unit
                    # clone of the literal's default type: named through the
                    # type_children join, filtered from typed_nodes.
                    clname: "i64"
                    if (isFloatLiteralName name: cn.stringview) then clname = "f64"
                    cid: reg.newType name: clname typetype: ztypes.ztypetype.recordType
                    (ty.setChildId
                        parentTypeId: parentId
                        nameId: am.name.u64
                        childTypeId: cid
                    )
                    ty.markAsConstClone typeId: cid
                    cnid3: nodeId n: (ast.nodes.get i: (am.operation - 1).u64)
                    cidc: cid
                    ty.nodeType.set key: cnid3.u64 value: cidc
                }
            }
            gfn: "\{defName}_\{mname}"
            (synthGeneratorForMethod
                :ty
                :reg
                :ast
                :unitName
                fnName: gfn.stringview
                thisName: defName
                op: (ast.nodes.get i: (am.operation - 1).u64)
            )
        } else null
    }
    return hasCreate
}

# attachMarkers -- resolve an as-block's facet/protocol conformance markers
# (`m: measurable` / `myreader: Reader`) as children of `parentId`, run AFTER the
# methods so markers take later positions. Returns whether any marker target owns a
# destructor (a protocol), so a class holder keeps its own.
# recordConformance -- record an impl-satisfies-spec conformance, but only when the
# spec resolves to a FACET or PROTOCOL (a RECORD marker like a numeric's `tag: tag` is a
# discriminator child, NOT a conformance). Mirrors _record_conformance (ztypecheck.py:3516);
# the helper C names (vtable/create/destroy/wrapper) are emitter-set and stay empty here.
recordConformance: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    implTypeId: u64
    specTypeId: u64
    label: StringView
} is {
    tt: reg.typetypeOf typeId: specTypeId
    recordIt: false
    isFacetC: false
    match (
        tt
    ) case facetType then {
        recordIt = true
        isFacetC = true
    } case protocolType then {
        recordIt = true
    } else null
    if recordIt then {
        cf: reg.newConformance :implTypeId :specTypeId :label isFacet: isFacetC
        ty.conformance.append cf
    }
}

attachMarkers: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    parentId: u64
    asItems: List u32
} out bool is {
    needsDtor: false
    miter: asItems.iterate
    for mmId9: miter loop {
        mm: ast.nodes.get i: (mmId9 - 1).u64
        match (
            mm
        ) case namedoperation then {
            cnm: atomName :ast n: (ast.nodes.get i: (mm.operation - 1).u64)
            if (isNumericLiteralName name: cnm.stringview) == false then {
                (recordTyperef
                    :ty
                    :reg
                    :ast
                    :unitName
                    thisName: ""
                    node: (ast.nodes.get i: (mm.operation - 1).u64)
                )
            }
            mtid: (markerTargetId
                :ty
                :reg
                :unitName
                :ast
                op: (ast.nodes.get i: (mm.operation - 1).u64)
            )
            match (
                mtid
            ) case some then {
                mlbl: zast.nameTextCopy :ast ref: mm.name
                (ty.setChildId
                    parentTypeId: parentId
                    nameId: mm.name.u64
                    childTypeId: mtid
                )
                if (reg.hasDestructorName typeId: mtid) then needsDtor = true
                (recordConformance
                    :ty
                    :reg
                    implTypeId: parentId
                    specTypeId: mtid
                    label: mlbl.stringview
                )
            } case none then {
                if (isLabelValue op: (ast.nodes.get i: (mm.operation - 1).u64)) then {
                    amlbl: zast.nameTextCopy :ast ref: mm.name
                    amlid: (resolveAtomType
                        :ty
                        :reg
                        :ast
                        :unitName
                        nm: amlbl.stringview
                        thisName: ""
                    )
                    (ty.setChildId
                        parentTypeId: parentId
                        nameId: mm.name.u64
                        childTypeId: amlid
                    )
                    acf: (reg.newConformance
                        implTypeId: parentId
                        specTypeId: amlid
                        label: amlbl.stringview
                        isFacet: false
                    )
                    ty.conformance.append acf
                }
            }
        } else null
    }
    return needsDtor
}

# dataOutTypeName -- the element-type name from a data block's optional `out T`
# (an atom type-expr), or "" when absent. The Option is BORROWED (param), never
# bound to a local: a bare bind would move the Option out of the shared AST node
# and free its payload, corrupting the later dump walk.
dataOutTypeName: function {ast: Ast oId: u32} out String is {
    if oId == 0 then return "".string
    return (atomName :ast n: (ast.nodes.get i: (oId - 1).u64))
}

# resolveData -- resolve a data-block definition into a DATA type: one `literal_int`
# child per element (the element's own label when present, else its ordinal) plus a
# `tag` child typed `tag__{element-type}` -- the `out T` width when declared, else
# i64 -- mark it a non-valtype, then record its defining unit + `{unit}.{name}` view.
# Elements stay literal_int (coerced per use); typed / float elements arrive with the
# examples that exercise them.
resolveData: function {ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    defName: StringView
    dnode: zast.DataBlockData
} is {
    did: (declareCanonicalType
        :ast
        :ty
        :reg
        defUnit: unitName
        name: defName
        typetype: ztypes.ztypetype.dataType
    )
    ddid: did
    reg.setValtype typeId: did value: false
    if ty.literalIntShellId == 0 then {
        ty.literalIntShellId = reg.newType name: "literal_int" typetype: ztypes.ztypetype.recordType
        reg.setValtype typeId: ty.literalIntShellId value: true
    }
    litId: ty.literalIntShellId
    ordinal: u64
    eiter: dnode.elements.iterate
    for elId9: eiter loop {
        nmRef9: u32
        isNo9: false
        {
            el: ast.nodes.get i: (elId9 - 1).u64
            match (
                el
            ) case namedoperation then {
                nmRef9 = el.name
                isNo9 = true
            } else null
        }
        if isNo9 then {
            if nmRef9 == 0 then {
                ord: "\{ordinal}"
                oid9: (ast.internString text: ord.stringview).u64
                ty.setChildId parentTypeId: did nameId: oid9 childTypeId: litId
            } else {
                ty.setChildId parentTypeId: did nameId: nmRef9.u64 childTypeId: litId
            }
        }
        ordinal = ordinal + 1
    }
    etn: dataOutTypeName :ast oId: dnode.outType
    tagName: "tag__i64".string
    if etn.length != 0 then tagName = "tag__\{etn.stringview}"
    tagId: (declareCanonicalType
        :ast
        :ty
        :reg
        defUnit: "system"
        name: tagName.stringview
        typetype: ztypes.ztypetype.recordType
    )
    ty.setChildId parentTypeId: did nameId: wkTag childTypeId: tagId
    ty.definedInUnit.set key: ddid value: unitName.string
}

# isTypedefField -- true when a type-expr Node is an `X.typedef` dottedpath (the
# marker that makes a record a zero-overhead typedef wrapper). Matching the Node
# param narrows it cleanly.
isTypedefField: function {ast: Ast n: Node} out bool is {
    match (
        n
    ) case dottedpath then {
        cn: atomName :ast n: (ast.nodes.get i: (n.child - 1).u64)
        return (cn.stringview == "typedef")
    } else {
        return false
    }
}

# recordIsTypedef -- true when a record's `is` body carries a single `X.typedef`
# field. Such a record gets no field child and synthesizes `create`+`borrow`
# instead of `create`/`==`/`!=`.
recordIsTypedef: function {ast: Ast rnode: zast.ObjectDefData} out bool is {
    fiter: rnode.isItems.iterate
    for fmId9: fiter loop {
        fm: ast.nodes.get i: (fmId9 - 1).u64
        match (
            fm
        ) case namedoperation then {
            if (isTypedefField :ast n: (ast.nodes.get i: (fm.operation - 1).u64)) then return true
        } else null
    }
    return false
}

# typedefFieldBaseName -- the base type name of an `X.typedef` field's `X`
# (e.g. `(List of: u8).typedef` -> "List"). Borrows the Node, never binds it (a
# bare bind would move the type-expr out of the shared AST).
typedefFieldBaseName: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        return (paramTypeBaseName :ast op: (ast.nodes.get i: (n.parent - 1).u64))
    } else {
        return "".string
    }
}

# mangledTypeName -- a type ref's resolvable name: bare atoms as-is, a
# parameterized ref as its instance mangling (`(List of: u8)` ->
# "List_u8"), matching the shell/mono naming so member delegation finds
# the minted instance.
mangledTypeName: function {ast: Ast op: Node} out String is {
    match (
        op
    ) case atomid then {
        return (zast.nameTextCopy :ast ref: op.name)
    } case labelvalue then {
        return (zast.nameTextCopy :ast ref: op.name)
    } case expression then {
        return (mangledTypeName :ast op: (ast.nodes.get i: (op.expression - 1).u64))
    } case call then {
        base: atomName :ast n: (ast.nodes.get i: (op.callable - 1).u64)
        aiter: op.arguments.iterate
        for argId9: aiter loop {
            arg: ast.nodes.get i: (argId9 - 1).u64
            match (
                arg
            ) case namedoperation then {
                an: atomName :ast n: (ast.nodes.get i: (arg.operation - 1).u64)
                if an.length > 0 then {
                    base.append s: "_"
                    base.append s: an.stringview
                }
            } else null
        }
        return base
    } case dottedpath then {
        return (atomName :ast n: (ast.nodes.get i: (op.child - 1).u64))
    } else {
        return "".string
    }
}

# objectTypedefBase -- the base type name of an objectdef's single `X.typedef`
# field (the typedef wrapper base), or "" when the object is not a typedef.
objectTypedefBase: function {ast: Ast onode: zast.ObjectDefData} out String is {
    fiter: onode.isItems.iterate
    for fmId9: fiter loop {
        fm: ast.nodes.get i: (fmId9 - 1).u64
        match (
            fm
        ) case namedoperation then {
            if (isTypedefField
                :ast
                n: (ast.nodes.get i: (fm.operation - 1).u64)
            ) then return (typedefFieldBaseName
                :ast
                n: (ast.nodes.get i: (fm.operation - 1).u64)
            )
        } else null
    }
    return "".string
}

# typedefFieldMangledName -- the mangled instance name of an `X.typedef`
# field's `X` (`(List of: u8).typedef` -> "List_u8"), the minted-mono key
# member delegation resolves through.
typedefFieldMangledName: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        return (mangledTypeName :ast op: (ast.nodes.get i: (n.parent - 1).u64))
    } else {
        return "".string
    }
}

# objectTypedefMangled -- the mangled base-instance name of an objectdef's
# single `X.typedef` field, or "" when the object is not a typedef.
objectTypedefMangled: function {ast: Ast onode: zast.ObjectDefData} out String is {
    fiter: onode.isItems.iterate
    for fmId9: fiter loop {
        fm: ast.nodes.get i: (fmId9 - 1).u64
        match (
            fm
        ) case namedoperation then {
            if (isTypedefField :ast n: (ast.nodes.get i: (fm.operation - 1).u64)) then {
                return (typedefFieldMangledName :ast n: (ast.nodes.get i: (fm.operation - 1).u64))
            }
        } else null
    }
    return "".string
}

# resolveRecord -- resolve a record ObjectDef into a RECORD valtype. A normal
# record: a child per field (field name -> type-ref shell), a child per as-block
# method, then synthesized `create`/`==`/`!=`. A typedef record (single
# `X.typedef` field): no field child, the methods, then `create`+`borrow`. Synth
# children are shallow FUNCTION shells (JOIN-only). Generics arrive later.
# fnFieldFlaggableName -- an is-block FUNCTION member that should become a struct
# fnptr slot (a spec field / method / method-ref), excluding the constructor and
# comparison synthetics so they stay free functions / ctors.
fnFieldFlaggableName: function {name: StringView} out bool is {
    if name == "create" then return false
    if name == "==" then return false
    if name == "!=" then return false
    if name == "borrow" then return false
    return true
}

# typeExprHasPrivate -- does a field's type expression carry a `.private` marker
# (`Container.private.lock`), i.e. is it a friend handle? Walks the dotted path
# (markers nest outermost-last: `((Container.private).lock)`).
typeExprHasPrivate: function {ast: Ast n: Node} out bool is {
    match (
        n
    ) case dottedpath then {
        cn9: atomName :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if cn9.stringview == "private" then return true
        return (typeExprHasPrivate :ast n: (ast.nodes.get i: (n.parent - 1).u64))
    } else {
        return false
    }
}

# scanVisibility -- one AST-only pass filling two out-lists (with-scoped
# iterators, no lock outlives the scan): `excl` = pool ids of USER-declared
# members NOT in the `public:` block (empty when there is no block -- the
# all-public default; synthesized edges are never listed); `grants` = pool ids
# of fields whose declared type is a `.private` handle (independent of any
# `public:` block). The resolver applies both once child edges are registered.
scanVisibility: function {
    ty: ztyping.ZTyping
    ast: Ast
    onode: zast.ObjectDefData
    excl: (List u64)
    grants: (List u64)
} is {
    pubIds: (Set u64)
    pubFound: false
    with aiter: onode.asItems.iterate do for aId9: aiter loop {
        an9: ast.nodes.get i: (aId9 - 1).u64
        match (
            an9
        ) case namedoperation then {
            if (zast.nameTextEq :ast ref: an9.name s: "private") then {
                (addResolveErrorH
                    :ty
                    nodeid: an9.nodeid
                    lineno: an9.lineno
                    colno: an9.colno
                    e: zast.err.typeError
                    msg: "`private:` cannot be redefined -- `private` always includes every field and method of the type".string
                    width: 7
                )
            }
            if (zast.nameTextEq :ast ref: an9.name s: "public") then {
                pubFound = true
                op9: ast.nodes.get i: (an9.operation - 1).u64
                match (
                    op9
                ) case unitdef then {
                    with biter: op9.body.iterate do for bId9: biter loop {
                        bn9: ast.nodes.get i: (bId9 - 1).u64
                        match (
                            bn9
                        ) case namedoperation then {
                            pubIds.add item: bn9.name.u64
                        } else null
                    }
                } else null
            }
        } else null
    }
    with fiter: onode.isItems.iterate do for fId9: fiter loop {
        fm9: ast.nodes.get i: (fId9 - 1).u64
        match (
            fm9
        ) case namedoperation then {
            if (typeExprHasPrivate
                :ast
                n: (ast.nodes.get i: (fm9.operation - 1).u64)
            ) then grants.append from: fm9.name.u64
            if pubFound then {
                hasF9: pubIds.has item: fm9.name.u64
                if (hasF9) == false then excl.append from: fm9.name.u64
            }
        } else null
    }
    if (pubFound) == false then return
    with a2iter: onode.asItems.iterate do for a2Id9: a2iter loop {
        am9: ast.nodes.get i: (a2Id9 - 1).u64
        match (
            am9
        ) case namedoperation then {
            skip9: false
            if (zast.nameTextEq :ast ref: am9.name s: "public") then skip9 = true
            if (zast.nameTextEq :ast ref: am9.name s: "private") then skip9 = true
            if (skip9) == false then {
                hasM9: pubIds.has item: am9.name.u64
                if (hasM9) == false then excl.append from: am9.name.u64
            }
        } else null
    }
}

# applyPrivateExclusions -- mark each excluded member private, by pool id.
applyPrivateExclusions: function {ty: ztyping.ZTyping parentId: u64 excl: (List u64)} is {
    ei9: u64
    en9: excl.length
    for ei9 < en9 loop {
        ty.setChildPrivateId parentTypeId: parentId nameId: (excl.get i: ei9)
        ei9 = ei9 + 1
    }
}

# applyGrantsPrivate -- mark each `.private`-typed field as a friend handle.
applyGrantsPrivate: function {ty: ztyping.ZTyping parentId: u64 grants: (List u64)} is {
    gi9: u64
    gn9: grants.length
    for gi9 < gn9 loop {
        ty.setChildGrantsPrivateId parentTypeId: parentId nameId: (grants.get i: gi9)
        gi9 = gi9 + 1
    }
}

resolveRecord: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    defName: StringView
    rnode: zast.ObjectDefData
} is {
    rid: (declareCanonicalType
        :ast
        :ty
        :reg
        defUnit: unitName
        name: defName
        typetype: ztypes.ztypetype.recordType
    )
    rrid: rid
    pvExcl_rrid: (List u64)
    pvGrants_rrid: (List u64)
    scanVisibility :ty :ast onode: rnode excl: pvExcl_rrid grants: pvGrants_rrid
    reg.setValtype typeId: rid value: true
    isgen: hasGenericParam :ast items: rnode.asItems
    eqOptR9: eqNullOptOut :ast asItems: rnode.asItems
    if isgen then {
        reg.setGeneric typeId: rid value: true
        rtk: "\{unitName}.\{defName}"
        registerGenericParams :ast :reg typeKey: rtk.stringview items: rnode.asItems
    }
    istd: recordIsTypedef :ast :rnode
    if istd then {
        tdb: objectTypedefBase :ast onode: rnode
        if tdb.length > 0 then {
            tdk: rid
            ty.typedefBaseName.set key: tdk value: tdb
        }
        tdm: objectTypedefMangled :ast onode: rnode
        if tdm.length > 0 then {
            tdk2: rid
            ty.typedefBaseMangled.set key: tdk2 value: tdm
        }
    }
    hasCreateIs: false
    hasEqIs: false
    if (istd) == false then {
        fiter: rnode.isItems.iterate
        for fmId9: fiter loop {
            fm: ast.nodes.get i: (fmId9 - 1).u64
            match (
                fm
            ) case namedoperation then {
                fname: zast.nameTextCopy :ast ref: fm.name
                qname: "\{defName}.\{fname}"
                mido: (resolveMethodFn
                    :ty
                    :reg
                    :ast
                    :unitName
                    qname: qname.stringview
                    thisName: defName
                    op: (ast.nodes.get i: (fm.operation - 1).u64)
                )
                match (
                    mido
                ) case some then {
                    if fname.stringview == "create" then hasCreateIs = true
                    if fname.stringview == "==" then hasEqIs = true
                    (ty.setChildId
                        parentTypeId: rid
                        nameId: fm.name.u64
                        childTypeId: mido
                    )
                    if (fnFieldFlaggableName name: fname.stringview) then {
                        (ty.setChildFnptrField
                            pool: ast.names
                            parentTypeId: rid
                            name: fname.stringview
                        )
                    }
                } case none then {
                    ftnR9: fieldHeadName :ast n: (ast.nodes.get i: (fm.operation - 1).u64)
                    mkeyR9: "\{unitName}.\{defName}.\{ftnR9}"
                    mrefR9: resolvedByKey :ast :ty :reg key: mkeyR9
                    handledR9: false
                    match (
                        mrefR9
                    ) case some then {
                        (ty.setChildId
                            parentTypeId: rid
                            nameId: fm.name.u64
                            childTypeId: mrefR9
                        )
                        if (reg.typetypeOf typeId: mrefR9) == ztypes.ztypetype.functionType then {
                            (ty.setChildFnptrField
                                pool: ast.names
                                parentTypeId: rid
                                name: fname.stringview
                            )
                        }
                        pdkR9: nodeId n: (ast.nodes.get i: (fm.operation - 1).u64)
                        pdoR9: rid
                        ty.pendingDefaultOwner.set key: pdkR9.u64 value: pdoR9
                        pdk2R9: nodeId n: (ast.nodes.get i: (fm.operation - 1).u64)
                        pdiR9: mrefR9
                        ty.pendingDefaultId.set key: pdk2R9.u64 value: pdiR9
                        handledR9 = true
                    } case none then null
                    if (handledR9) == false then {
                        cid: (resolveTyperefShellMarked
                            :ty
                            :reg
                            :ast
                            :unitName
                            ownerId: 0
                            typeExpr: (ast.nodes.get i: (fm.operation - 1).u64)
                            thisName: defName
                        )
                        (ty.setChildId
                            parentTypeId: rid
                            nameId: fm.name.u64
                            childTypeId: cid
                        )
                        if (reg.typetypeOf typeId: cid) == ztypes.ztypetype.functionType then {
                            (ty.setChildFnptrField
                                pool: ast.names
                                parentTypeId: rid
                                name: fname.stringview
                            )
                        }
                        (recordTyperef
                            :ty
                            :reg
                            :ast
                            :unitName
                            thisName: ""
                            node: (ast.nodes.get i: (fm.operation - 1).u64)
                        )
                        dcn1: dottedChildName :ast n: (ast.nodes.get i: (fm.operation - 1).u64)
                        rdnr: rootNameOf :ast n: (ast.nodes.get i: (fm.operation - 1).u64)
                        if (isNumericLiteralName name: rdnr.stringview) then {
                            (ty.setChildDefault
                                pool: ast.names
                                parentTypeId: rid
                                name: fname.stringview
                                default: rdnr.stringview
                            )
                        } else {
                            if dcn1.length > 0 when (isStripMarker name: dcn1.stringview) == false when (reg.isUnitName name: rdnr.stringview) == false then {
                                (ty.setDefaultVariantArm
                                    pool: ast.names
                                    parentTypeId: rid
                                    name: fname.stringview
                                    armName: dcn1.stringview
                                )
                            }
                        }
                        if dcn1.length > 0 when (isStripMarker name: dcn1.stringview) then {} else {
                            if dcn1.length > 0 then {
                                rdk3: nodeId n: (ast.nodes.get i: (fm.operation - 1).u64)
                                rdo3: rid
                                ty.pendingDefaultOwner.set key: rdk3.u64 value: rdo3
                                rdk4: nodeId n: (ast.nodes.get i: (fm.operation - 1).u64)
                                rdn4: rootNameOf :ast n: (ast.nodes.get i: (fm.operation - 1).u64)
                                ty.pendingDefaultName.set key: rdk4.u64 value: rdn4
                            }
                        }
                    }
                }
            } else null
        }
    }
    hasCreateAs: (attachMethods
        :ty
        :reg
        :ast
        :unitName
        :defName
        parentId: rid
        asItems: rnode.asItems
    )
    hasCreate: hasCreateIs
    if hasCreateAs then hasCreate = true
    attachMarkers :ty :reg :ast :unitName parentId: rid asItems: rnode.asItems
    if (hasCreate) == false then {
        createName: "\{defName}.create"
        createId: reg.newType name: createName.stringview typetype: ztypes.ztypetype.functionType
        ty.setChildId parentTypeId: rid nameId: wkCreate childTypeId: createId
    }
    if istd then {
        borrowName: "\{defName}.borrow"
        borrowId: reg.newType name: borrowName.stringview typetype: ztypes.ztypetype.functionType
        ty.setChildId parentTypeId: rid nameId: wkBorrow childTypeId: borrowId
    } else {
        if (isgen) == false then {
            if (hasEqIs) == false when (eqOptR9) == false then {
                eqName: "\{defName}.=="
                eqId: reg.newType name: eqName.stringview typetype: ztypes.ztypetype.functionType
                ty.setChildId parentTypeId: rid nameId: wkOpEq childTypeId: eqId
                neqName: "\{defName}.!="
                neqId: reg.newType name: neqName.stringview typetype: ztypes.ztypetype.functionType
                ty.setChildId parentTypeId: rid nameId: wkOpNe childTypeId: neqId
            }
        }
    }
    applyPrivateExclusions :ty parentId: rrid excl: pvExcl_rrid
    applyGrantsPrivate :ty parentId: rrid grants: pvGrants_rrid
    ty.definedInUnit.set key: rrid value: unitName.string
}

# resolveVariant -- resolve a variant ObjectDef into a VARIANT valtype: a child per
# arm (arm name -> payload type-ref shell; a `null` arm -> the `null` shell), a
# synthesized `tag` child (the `{name}:tag:data` discriminator wrapper), any as-block
# methods, then synthesized `==`/`!=`. Variants have no `create` (bare construction is
# disabled). Custom-DATA tags + generics arrive later.
# detectTagAccessor -- a non-function variant/union as-item of the form
# `name: <numeric>.tag` declares the read-only tag accessor: instances
# expose the discriminator ordinal as the numeric type under that name.
detectTagAccessor: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    defName: StringView
    ownerId: u64
    armNames: Set String
    am: zast.NamedOperationData
} is {
    tp9: dottedParentName :ast n: (ast.nodes.get i: (am.operation - 1).u64)
    tc9: dottedChildName :ast n: (ast.nodes.get i: (am.operation - 1).u64)
    if tc9.stringview != "tag" then return
    if (isNumericTypeName name: tp9.stringview) == false then return
    mname9: zast.nameTextCopy :ast ref: am.name
    nid9: (resolveTyperefShellMarked
        :ty
        :reg
        :ast
        :unitName
        ownerId: 0
        typeExpr: (ast.nodes.get i: (am.operation - 1).u64)
        thisName: defName
    )
    if nid9 == 0 then return
    if (armNames.has item: mname9) then {
        mac9: "'\{mname9}' collides with the '\{defName}' arm of the same name"
        (addResolveErrorH
            :ty
            nodeid: am.nodeid
            lineno: am.lineno
            colno: am.colno
            e: zast.err.duplicateDef
            msg: mac9
            width: mname9.length.u32.orPanic
        )
        return
    }
    man9: mname9.copy
    ty.tagAccessorName.set key: ownerId value: man9
    ty.tagAccessorTid.set key: ownerId value: nid9
}

resolveVariant: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    defName: StringView
    vnode: zast.ObjectDefData
} is {
    vid: (declareCanonicalType
        :ast
        :ty
        :reg
        defUnit: unitName
        name: defName
        typetype: ztypes.ztypetype.variantType
    )
    vvid: vid
    pvExcl_vvid: (List u64)
    pvGrants_vvid: (List u64)
    scanVisibility :ty :ast onode: vnode excl: pvExcl_vvid grants: pvGrants_vvid
    reg.setValtype typeId: vid value: true
    isgen: hasGenericParam :ast items: vnode.asItems
    eqOptV9: eqNullOptOut :ast asItems: vnode.asItems
    if isgen then {
        reg.setGeneric typeId: vid value: true
        gtk9: "\{unitName}.\{defName}"
        registerGenericParams :ast :reg typeKey: gtk9.stringview items: vnode.asItems
    }
    armNames9: (Set String)
    fiter: vnode.isItems.iterate
    for fmId9: fiter loop {
        fm: ast.nodes.get i: (fmId9 - 1).u64
        match (
            fm
        ) case namedoperation then {
            aname: zast.nameTextCopy :ast ref: fm.name
            if aname.stringview == "tag" then {
                mt9: "'tag' is a reserved member name".string
                (addResolveErrorH
                    :ty
                    nodeid: fm.nodeid
                    lineno: fm.lineno
                    colno: fm.colno
                    e: zast.err.reservedMember
                    msg: mt9
                    width: 3
                )
            }
            armNames9.add item: aname.copy
            cid: (resolveTyperefShellMarked
                :ty
                :reg
                :ast
                :unitName
                ownerId: 0
                typeExpr: (ast.nodes.get i: (fm.operation - 1).u64)
                thisName: defName
            )
            (ty.setChildId
                parentTypeId: vid
                nameId: fm.name.u64
                childTypeId: cid
            )
            (recordTyperef
                :ty
                :reg
                :ast
                :unitName
                thisName: ""
                node: (ast.nodes.get i: (fm.operation - 1).u64)
            )
        } else null
    }
    if (isgen) == false then {
        customTagV: unionCustomTagId :ast :ty :reg :unitName uid: vid asItems: vnode.asItems
        tagId: u64
        match (
            customTagV
        ) case some then {
            tagId = customTagV
        } case none then {
            tagName: "\{defName}:tag:data"
            tagId = reg.newType name: tagName.stringview typetype: ztypes.ztypetype.dataType
        }
        ty.setChildId parentTypeId: vid nameId: wkTag childTypeId: tagId
    }
    aiter: vnode.asItems.iterate
    for amId9: aiter loop {
        am: ast.nodes.get i: (amId9 - 1).u64
        match (
            am
        ) case namedoperation then {
            mname: zast.nameTextCopy :ast ref: am.name
            qname: "\{defName}.\{mname}"
            mido: (resolveMethodFn
                :ty
                :reg
                :ast
                :unitName
                qname: qname.stringview
                thisName: defName
                op: (ast.nodes.get i: (am.operation - 1).u64)
            )
            match (
                mido
            ) case some then {
                if (armNames9.has item: mname) then {
                    mc9: "'\{mname}' collides with the '\{defName}' arm of the same name"
                    (addResolveErrorH
                        :ty
                        nodeid: am.nodeid
                        lineno: am.lineno
                        colno: am.colno
                        e: zast.err.duplicateDef
                        msg: mc9
                        width: mname.length.u32.orPanic
                    )
                } else if mname.stringview == "tag" then {
                    mr9: "'tag' is a reserved member name".string
                    (addResolveErrorH
                        :ty
                        nodeid: am.nodeid
                        lineno: am.lineno
                        colno: am.colno
                        e: zast.err.reservedMember
                        msg: mr9
                        width: 3
                    )
                } else {
                    (ty.setChildId
                        parentTypeId: vid
                        nameId: am.name.u64
                        childTypeId: mido
                    )
                }
            } else {
                if (isgen) == false then {
                    (detectTagAccessor
                        :ty
                        :reg
                        :ast
                        :unitName
                        :defName
                        ownerId: vid
                        armNames: armNames9
                        :am
                    )
                }
            }
        } else null
    }
    if (isgen) == false when (eqOptV9) == false then {
        eqName: "\{defName}.=="
        eqId: reg.newType name: eqName.stringview typetype: ztypes.ztypetype.functionType
        ty.setChildId parentTypeId: vid nameId: wkOpEq childTypeId: eqId
        neqName: "\{defName}.!="
        neqId: reg.newType name: neqName.stringview typetype: ztypes.ztypetype.functionType
        ty.setChildId parentTypeId: vid nameId: wkOpNe childTypeId: neqId
    }
    applyPrivateExclusions :ty parentId: vvid excl: pvExcl_vvid
    applyGrantsPrivate :ty parentId: vvid grants: pvGrants_vvid
    ty.definedInUnit.set key: vvid value: unitName.string
}

# dottedParentName -- the parent atom name of a `parent.child` dottedpath Node, ""
# for anything else. Matching the Node param narrows it cleanly.
dottedParentName: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case expression then {
        return (dottedParentName :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case dottedpath then {
        return (atomName :ast n: (ast.nodes.get i: (n.parent - 1).u64))
    } else {
        return "".string
    }
}

# dottedTyperefId -- the type id of a cross-unit qualified type ref `unit.Type`
# (e.g. the `zvfs.ProviderBox` element of a `(List of: zvfs.ProviderBox)`),
# resolved through the defining unit's scope. Bare-name visibility covers only
# main+system, so a dep element misses there; this bridges via unitNameTid +
# resolved. 0 when not a dotted ref or unresolved.
dottedTyperefId: function {ast: Ast st: zenv.ZSymbolTable op: Node} out u64 is {
    match (
        op
    ) case expression then {
        return (dottedTyperefId :ast :st op: (ast.nodes.get i: (op.expression - 1).u64))
    } case dottedpath then {
        pn: atomName :ast n: (ast.nodes.get i: (op.parent - 1).u64)
        cn: atomName :ast n: (ast.nodes.get i: (op.child - 1).u64)
        if (st.reg.unitNameTid.has key: pn) then {
            k: "\{pn}.\{cn}"
            ro: resolvedByKey :ast ty: st.typing reg: st.reg key: k
            return (optU64Or o: ro d: 0)
        } else {
            return 0
        }
    } else {
        return 0
    }
}

# unionCustomTagId -- a union's custom DATA tag, if any: an `as { tag: <data>.tag }`
# item whose `<data>` resolves to an in-unit DATA type. Returns that DATA's type id;
# none when absent or not a DATA (the union then synthesizes its own tag wrapper).
unionCustomTagId: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    uid: u64
    asItems: List u32
} out optionval u64 is {
    iter: asItems.iterate
    for amId9: iter loop {
        am: ast.nodes.get i: (amId9 - 1).u64
        match (
            am
        ) case namedoperation then {
            nm: zast.nameTextCopy :ast ref: am.name
            if nm.stringview == "tag" then {
                pn: dottedParentName :ast n: (ast.nodes.get i: (am.operation - 1).u64)
                if pn.length != 0 then {
                    rr: walkLookupTyperef :ast :ty :reg currentUnit: unitName base: pn.stringview
                    match (
                        rr
                    ) case some then {
                        tt: reg.typetypeOf typeId: rr
                        isdata: false
                        match (
                            tt
                        ) case dataType then {
                            isdata = true
                        } else null
                        if isdata then {
                            return (optionval.some rr)
                        } else {
                            # the reference stamps only the main unit's
                            # custom-tag items (system variants resolve
                            # standalone, unstamped).
                            if unitName == reg.regMainUnit.stringview then {
                                tgk: "system.tag".string
                                tgo: resolvedByKey :ast :ty :reg key: tgk
                                match (
                                    tgo
                                ) case some then {
                                    tnid0: (innermostNodeId
                                        :ast
                                        n: (ast.nodes.get i: (am.operation - 1).u64)
                                    )
                                    ty.nodeType.set key: tnid0.u64 value: tgo
                                } case none then null
                            }
                        }
                    } case none then {
                        # the tag base resolves later (demand order): record
                        # the demand and a pending fixup for the tag child.
                        reg.recordDemand name: pn.stringview
                        uk: uid
                        pv: pn.copy
                        ty.pendingCustomTag.set key: uk value: pv
                        uk2: uid
                        pnid9: innermostNodeId :ast n: (ast.nodes.get i: (am.operation - 1).u64)
                        pnv9: pnid9.u64
                        ty.pendingCustomTagNode.set key: uk2 value: pnv9
                    }
                }
            }
        } else null
    }
    return (optionval.none u64)
}

# resolveUnion -- resolve a union ObjectDef into a UNION reference type: a child
# per arm (arm name -> payload type-ref shell; a `null` arm -> the `null` shell),
# a synthesized `tag` child (the `{name}:tag:data` discriminator wrapper), then any
# as-block methods. Unions are reference types (is_valtype false); they have no
# `create` (bare construction is disabled) and no `==`/`!=`. A union keeps a
# destructor unless every arm is `null` (Priority elides it; IntResult/Result/Typed
# keep it). A custom DATA tag (`as { tag: <data>.tag }`) becomes the `tag` child in
# place of the synth wrapper; generics arrive later.
resolveUnion: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    defName: StringView
    vnode: zast.ObjectDefData
} is {
    uid: (declareCanonicalType
        :ast
        :ty
        :reg
        defUnit: unitName
        name: defName
        typetype: ztypes.ztypetype.unionType
    )
    uuid: uid
    pvExcl_uuid: (List u64)
    pvGrants_uuid: (List u64)
    scanVisibility :ty :ast onode: vnode excl: pvExcl_uuid grants: pvGrants_uuid
    reg.setValtype typeId: uid value: false
    isgen: hasGenericParam :ast items: vnode.asItems
    if isgen then {
        reg.setGeneric typeId: uid value: true
        gtk9: "\{unitName}.\{defName}"
        registerGenericParams :ast :reg typeKey: gtk9.stringview items: vnode.asItems
    }
    allNull: true
    armNames9: (Set String)
    fiter: vnode.isItems.iterate
    for fmId9: fiter loop {
        fm: ast.nodes.get i: (fmId9 - 1).u64
        match (
            fm
        ) case namedoperation then {
            aname: zast.nameTextCopy :ast ref: fm.name
            if aname.stringview == "tag" then {
                mt9: "'tag' is a reserved member name".string
                (addResolveErrorH
                    :ty
                    nodeid: fm.nodeid
                    lineno: fm.lineno
                    colno: fm.colno
                    e: zast.err.reservedMember
                    msg: mt9
                    width: 3
                )
            }
            armNames9.add item: aname.copy
            an: atomName :ast n: (ast.nodes.get i: (fm.operation - 1).u64)
            if an.stringview != "null" then allNull = false
            cid: (resolveTyperefShellMarked
                :ty
                :reg
                :ast
                :unitName
                ownerId: 0
                typeExpr: (ast.nodes.get i: (fm.operation - 1).u64)
                thisName: defName
            )
            (ty.setChildId
                parentTypeId: uid
                nameId: fm.name.u64
                childTypeId: cid
            )
            (recordTyperef
                :ty
                :reg
                :ast
                :unitName
                thisName: ""
                node: (ast.nodes.get i: (fm.operation - 1).u64)
            )
        } else null
    }
    if (isgen) == false then {
        customTag: unionCustomTagId :ast :ty :reg :unitName :uid asItems: vnode.asItems
        tagId: u64
        match (
            customTag
        ) case some then {
            tagId = customTag
        } case none then {
            tagName: "\{defName}:tag:data"
            tagId = reg.newType name: tagName.stringview typetype: ztypes.ztypetype.dataType
        }
        ty.setChildId parentTypeId: uid nameId: wkTag childTypeId: tagId
    }
    aiter: vnode.asItems.iterate
    for amId9: aiter loop {
        am: ast.nodes.get i: (amId9 - 1).u64
        match (
            am
        ) case namedoperation then {
            mname: zast.nameTextCopy :ast ref: am.name
            qname: "\{defName}.\{mname}"
            mido: (resolveMethodFn
                :ty
                :reg
                :ast
                :unitName
                qname: qname.stringview
                thisName: defName
                op: (ast.nodes.get i: (am.operation - 1).u64)
            )
            match (
                mido
            ) case some then {
                if (armNames9.has item: mname) then {
                    mc9: "'\{mname}' collides with the '\{defName}' arm of the same name"
                    (addResolveErrorH
                        :ty
                        nodeid: am.nodeid
                        lineno: am.lineno
                        colno: am.colno
                        e: zast.err.duplicateDef
                        msg: mc9
                        width: mname.length.u32.orPanic
                    )
                } else if mname.stringview == "tag" then {
                    mr9: "'tag' is a reserved member name".string
                    (addResolveErrorH
                        :ty
                        nodeid: am.nodeid
                        lineno: am.lineno
                        colno: am.colno
                        e: zast.err.reservedMember
                        msg: mr9
                        width: 3
                    )
                } else {
                    (ty.setChildId
                        parentTypeId: uid
                        nameId: am.name.u64
                        childTypeId: mido
                    )
                }
            } else {
                if (isgen) == false then {
                    (detectTagAccessor
                        :ty
                        :reg
                        :ast
                        :unitName
                        :defName
                        ownerId: uid
                        armNames: armNames9
                        :am
                    )
                }
            }
        } else null
    }
    if (allNull) == false then {
        dn: "\{defName}_destroy"
        reg.setDestructorName typeId: uid name: dn.stringview
    }
    applyPrivateExclusions :ty parentId: uuid excl: pvExcl_uuid
    applyGrantsPrivate :ty parentId: uuid grants: pvGrants_uuid
    ty.definedInUnit.set key: uuid value: unitName.string
}

# fieldTypeNeedsCleanup -- true when a class field needs cleanup (so the holder keeps
# a destructor): a `.lock` field (its borrow is released at scope exit), a native heap
# type (String/List/Map/Set), or an in-unit type that itself HAS a destructor
# (`reg.hasDestructorName`). A scalar field, or an owned class/union field whose type
# has no destructor, needs none. Name check for the natives is a scaffold-stage
# approximation (system types carry no real id under resolve-only-main).
fieldTypeNeedsCleanup: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    name: StringView
    isLock: bool
} out bool is {
    if isLock then return true
    if name == "String" then return true
    if name == "List" then return true
    if name == "Map" then return true
    if name == "Set" then return true
    if name == "Option" then return true
    if name == "Result" then return true
    duo8: definingUnitFor :ty currentUnit: unitName :name
    if duo8.length > 0 then {
        tto8: ty.defTypetype.get key: ("\{duo8}.\{name}")
        match (
            tto8
        ) case some then {
            boxed8: false
            if tto8 == ztypes.ztypetype.classType then boxed8 = true
            if tto8 == ztypes.ztypetype.unionType then boxed8 = true
            if boxed8 then {
                gk8: "\{duo8}.\{name}"
                if (ty.resolving.has item: gk8) then return true
            }
        } case none then null
        descendNamed :ty :reg :ast defUnit: duo8.stringview :name
    }
    # key by the DEFINING unit: a bare cross-unit field type (Bytes from
    # collections) resolves under its own unit, not the class's
    ku8: unitName.string
    if duo8.length > 0 then ku8 = duo8.copy
    rkey: "\{ku8.stringview}.\{name}"
    rr: resolvedByKey :ast :ty :reg key: rkey
    match (
        rr
    ) case some then {
        return (reg.hasDestructorName typeId: rr)
    } case none then {
        return false
    }
}

# resolveClass -- resolve a class ObjectDef into a CLASS reference type: a child per
# field (field name -> type-ref shell), a child per as-block method, then a synthesized
# `create` child (LAST). Classes are reference types (is_valtype false); they get
# `create` but NO `==`/`!=` (unlike records). A class keeps a destructor when any field
# owns heap data (fieldTypeNeedsCleanup), else none. A typedef class (single
# `X.typedef` field) gets no field child, synth `create`+`borrow`, and inherits
# needs_destructor from the wrapped base (List -> yes, ListView -> no). Custom /
# `null` create, generics + protocols come later.
resolveClass: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    defName: StringView
    cnode: zast.ObjectDefData
} is {
    cid: (declareCanonicalType
        :ast
        :ty
        :reg
        defUnit: unitName
        name: defName
        typetype: ztypes.ztypetype.classType
    )
    ccid: cid
    pvExcl_ccid: (List u64)
    pvGrants_ccid: (List u64)
    scanVisibility :ty :ast onode: cnode excl: pvExcl_ccid grants: pvGrants_ccid
    reg.setValtype typeId: cid value: false
    needsDtor: false
    isgen: hasGenericParam :ast items: cnode.asItems
    if isgen then {
        reg.setGeneric typeId: cid value: true
        gtk9: "\{unitName}.\{defName}"
        registerGenericParams :ast :reg typeKey: gtk9.stringview items: cnode.asItems
    }
    istd: recordIsTypedef :ast rnode: cnode
    if istd then {
        tdbase: objectTypedefBase :ast onode: cnode
        if (fieldTypeNeedsCleanup
            :ty
            :reg
            :ast
            :unitName
            name: tdbase.stringview
            isLock: false
        ) then needsDtor = true
        if tdbase.length > 0 then {
            tdk3: cid
            ty.typedefBaseName.set key: tdk3 value: tdbase
        }
        tdm3: objectTypedefMangled :ast onode: cnode
        if tdm3.length > 0 then {
            tdk4: cid
            ty.typedefBaseMangled.set key: tdk4 value: tdm3
        }
    }
    fiter: cnode.isItems.iterate
    for fmId9: fiter loop {
        fm: ast.nodes.get i: (fmId9 - 1).u64
        match (
            fm
        ) case namedoperation then {
            if (isFunctionDefOp op: (ast.nodes.get i: (fm.operation - 1).u64)) then {
                fname: zast.nameTextCopy :ast ref: fm.name
                prodM4: false
                if (isgen) == false then {
                    prodM4 = true
                } else {
                    if (functiondefIsNative op: (ast.nodes.get i: (fm.operation - 1).u64)) == false then {
                        prodM4 = true
                    } else {
                        # Flipped collection families resolve their native
                        # method decls like user template methods. create is
                        # special-cased; length/capacity stay field children
                        # (their C surface is a struct read, not a method).
                        famF3: false
                        if defName == "List" then famF3 = true
                        if defName == "ListView" then famF3 = true
                        if defName == "Set" then famF3 = true
                        if defName == "Map" then famF3 = true
                        if unitName == "collections" when famF3 then {
                            prodSkipL: false
                            if fname.stringview == "create" then prodSkipL = true
                            if fname.stringview == "length" then prodSkipL = true
                            if fname.stringview == "capacity" then prodSkipL = true
                            if (prodSkipL) == false then prodM4 = true
                        }
                    }
                }
                if prodM4 then {
                    qname: "\{defName}.\{fname}"
                    mido: (resolveMethodFn
                        :ty
                        :reg
                        :ast
                        :unitName
                        qname: qname.stringview
                        thisName: defName
                        op: (ast.nodes.get i: (fm.operation - 1).u64)
                    )
                    match (
                        mido
                    ) case some then {
                        (ty.setChildId
                            parentTypeId: cid
                            nameId: fm.name.u64
                            childTypeId: mido
                        )
                        if isgen then reg.setGeneric typeId: mido value: true
                        if (fnFieldFlaggableName name: fname.stringview) then {
                            (ty.setChildFnptrField
                                pool: ast.names
                                parentTypeId: cid
                                name: fname.stringview
                            )
                        }
                    } case none then null
                }
            } else {
                fname: zast.nameTextCopy :ast ref: fm.name
                ftn: fieldHeadName :ast n: (ast.nodes.get i: (fm.operation - 1).u64)
                lockField: false
                flock0: pathOwnership :ast n: (ast.nodes.get i: (fm.operation - 1).u64)
                match (
                    flock0
                ) case some then {
                    lockField = true
                } case none then null
                mkey: "\{unitName}.\{defName}.\{ftn}"
                mref: resolvedByKey :ast :ty :reg key: mkey
                match (
                    mref
                ) case some then {
                    (ty.setChildId
                        parentTypeId: cid
                        nameId: fm.name.u64
                        childTypeId: mref
                    )
                    if (reg.typetypeOf typeId: mref) == ztypes.ztypetype.functionType then {
                        (ty.setChildFnptrField
                            pool: ast.names
                            parentTypeId: cid
                            name: fname.stringview
                        )
                    }
                    if lockField then (ty.setChildLockField
                        pool: ast.names
                        parentTypeId: cid
                        name: fname.stringview
                    )
                    # a sibling-member ref default: the construction fill
                    # stamps the default's node with the member's type.
                    pdk: nodeId n: (ast.nodes.get i: (fm.operation - 1).u64)
                    pdo: cid
                    ty.pendingDefaultOwner.set key: pdk.u64 value: pdo
                    pdk2: nodeId n: (ast.nodes.get i: (fm.operation - 1).u64)
                    pdi: mref
                    ty.pendingDefaultId.set key: pdk2.u64 value: pdi
                } case none then {
                    if (isTypedefField :ast n: (ast.nodes.get i: (fm.operation - 1).u64)) then {
                        # No field child for the wrapper, but the inner refs
                        # (the u8 in `(List of: u8).typedef`) still stamp.
                        (recordTyperef
                            :ty
                            :reg
                            :ast
                            :unitName
                            thisName: ""
                            node: (ast.nodes.get i: (fm.operation - 1).u64)
                        )
                    } else {
                        if fname.stringview != "_resume_input" then {
                            if (fieldTypeNeedsCleanup
                                :ty
                                :reg
                                :ast
                                :unitName
                                name: ftn.stringview
                                isLock: lockField
                            ) then needsDtor = true
                        }
                        cidf: (resolveTyperefShellMarked
                            :ty
                            :reg
                            :ast
                            :unitName
                            ownerId: cid
                            typeExpr: (ast.nodes.get i: (fm.operation - 1).u64)
                            thisName: defName
                        )
                        (ty.setChildId
                            parentTypeId: cid
                            nameId: fm.name.u64
                            childTypeId: cidf
                        )
                        if (reg.typetypeOf typeId: cidf) == ztypes.ztypetype.functionType then {
                            (ty.setChildFnptrField
                                pool: ast.names
                                parentTypeId: cid
                                name: fname.stringview
                            )
                        }
                        if lockField then {
                            (ty.setChildLockField
                                pool: ast.names
                                parentTypeId: cid
                                name: fname.stringview
                            )
                        }
                        (recordTyperef
                            :ty
                            :reg
                            :ast
                            :unitName
                            thisName: ""
                            node: (ast.nodes.get i: (fm.operation - 1).u64)
                        )
                        dcn0: dottedChildName :ast n: (ast.nodes.get i: (fm.operation - 1).u64)
                        rdnc: rootNameOf :ast n: (ast.nodes.get i: (fm.operation - 1).u64)
                        if (isNumericLiteralName name: rdnc.stringview) then {
                            (ty.setChildDefault
                                pool: ast.names
                                parentTypeId: cid
                                name: fname.stringview
                                default: rdnc.stringview
                            )
                        } else {
                            if dcn0.length > 0 when (isStripMarker name: dcn0.stringview) == false when (reg.isUnitName name: rdnc.stringview) == false then {
                                (ty.setDefaultVariantArm
                                    pool: ast.names
                                    parentTypeId: cid
                                    name: fname.stringview
                                    armName: dcn0.stringview
                                )
                            }
                        }
                        if dcn0.length > 0 when (isStripMarker name: dcn0.stringview) then {} else {
                            if dcn0.length > 0 then {
                                rdk: nodeId n: (ast.nodes.get i: (fm.operation - 1).u64)
                                rdo: cid
                                ty.pendingDefaultOwner.set key: rdk.u64 value: rdo
                                rdk2: nodeId n: (ast.nodes.get i: (fm.operation - 1).u64)
                                rdn: rootNameOf :ast n: (ast.nodes.get i: (fm.operation - 1).u64)
                                ty.pendingDefaultName.set key: rdk2.u64 value: rdn
                            }
                        }
                    }
                }
            }
        } else null
    }
    # Flipped iterator families: their only method decl (`call`) lives in
    # the as-block; produce it like the isItems loop does. attachMethods
    # stays non-generic-only (it also handles const-clone members and
    # generator synthesis, which native decls never need).
    with aiterP4: cnode.asItems.iterate do for amP4Id9: aiterP4 loop {
        amP4: ast.nodes.get i: (amP4Id9 - 1).u64
        match (
            amP4
        ) case namedoperation then {
            if (isFunctionDefOp op: (ast.nodes.get i: (amP4.operation - 1).u64)) then {
                afnP4: zast.nameTextCopy :ast ref: amP4.name
                prodA4: false
                if isgen when (functiondefIsNative op: (ast.nodes.get i: (amP4.operation - 1).u64)) then {
                    famA4: false
                    if defName == "ListIter" then famA4 = true
                    if defName == "SetIter" then famA4 = true
                    if defName == "MapKeyIter" then famA4 = true
                    if defName == "MapItemIter" then famA4 = true
                    if unitName == "collections" when famA4 then {
                        skipA4: false
                        if afnP4.stringview == "create" then skipA4 = true
                        if afnP4.stringview == "length" then skipA4 = true
                        if afnP4.stringview == "capacity" then skipA4 = true
                        if (skipA4) == false then prodA4 = true
                    }
                }
                if prodA4 then {
                    aqnP4: "\{defName}.\{afnP4}"
                    amidP4: (resolveMethodFn
                        :ty
                        :reg
                        :ast
                        :unitName
                        qname: aqnP4.stringview
                        thisName: defName
                        op: (ast.nodes.get i: (amP4.operation - 1).u64)
                    )
                    match (
                        amidP4
                    ) case some then {
                        (ty.setChildId
                            parentTypeId: cid
                            nameId: amP4.name.u64
                            childTypeId: amidP4
                        )
                        reg.setGeneric typeId: amidP4 value: true
                        if (fnFieldFlaggableName name: afnP4.stringview) then {
                            (ty.setChildFnptrField
                                pool: ast.names
                                parentTypeId: cid
                                name: afnP4.stringview
                            )
                        }
                    } case none then null
                }
            }
        } else null
    }
    hasCreate: false
    if (isgen) == false then {
        hcAs: (attachMethods
            :ty
            :reg
            :ast
            :unitName
            :defName
            parentId: cid
            asItems: cnode.asItems
        )
        if hcAs then hasCreate = true
        mNeedsDtor: (attachMarkers
            :ty
            :reg
            :ast
            :unitName
            parentId: cid
            asItems: cnode.asItems
        )
        if mNeedsDtor then needsDtor = true
    }
    if (hasCreate) == false then {
        if (isgen) == false then {
            createName: "\{defName}.create"
            createId: (reg.newType
                name: createName.stringview
                typetype: ztypes.ztypetype.functionType
            )
            ty.setChildId parentTypeId: cid nameId: wkCreate childTypeId: createId
        }
    }
    if istd then {
        borrowName: "\{defName}.borrow"
        borrowId: reg.newType name: borrowName.stringview typetype: ztypes.ztypetype.functionType
        ty.setChildId parentTypeId: cid nameId: wkBorrow childTypeId: borrowId
    }
    if defName == "String" then needsDtor = true
    if needsDtor then {
        dn: "\{defName}_destroy"
        reg.setDestructorName typeId: cid name: dn.stringview
    }
    applyPrivateExclusions :ty parentId: ccid excl: pvExcl_ccid
    applyGrantsPrivate :ty parentId: ccid grants: pvGrants_ccid
    ty.definedInUnit.set key: ccid value: unitName.string
}

# resolveFacet -- resolve a facet ObjectDef into a FACET valtype: a child per
# is-block spec method (the `:this` receiver dropped), then synthesized `create` +
# `borrow` FUNCTION shells (JOIN-only, no own row). Facets are value types
# (is_valtype true), no destructor, no `==`/`!=`. Generic facets arrive later.
resolveFacet: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    defName: StringView
    fnode: zast.ObjectDefData
} is {
    fid: (declareCanonicalType
        :ast
        :ty
        :reg
        defUnit: unitName
        name: defName
        typetype: ztypes.ztypetype.facetType
    )
    ffid: fid
    pvExcl_ffid: (List u64)
    pvGrants_ffid: (List u64)
    scanVisibility :ty :ast onode: fnode excl: pvExcl_ffid grants: pvGrants_ffid
    reg.setValtype typeId: fid value: true
    isgen: hasGenericParam :ast items: fnode.isItems
    if isgen then reg.setGeneric typeId: fid value: true
    specThisStr: defName.string
    dropThis: true
    if unitName == ty.fullMainUnit.stringview then {
        fdk: defName.string
        fcto: ty.protocolThisContext.get key: fdk
        match (
            fcto
        ) case some then {
            specThisStr = fcto.copy
            dropThis = false
        } case none then null
    }
    siter: fnode.isItems.iterate
    for smId9: siter loop {
        sm: ast.nodes.get i: (smId9 - 1).u64
        match (
            sm
        ) case namedoperation then {
            mname: zast.nameTextCopy :ast ref: sm.name
            qname: "\{defName}.\{mname}"
            sido: (resolveSpecFn
                :ty
                :reg
                :ast
                :unitName
                qname: qname.stringview
                thisName: specThisStr.stringview
                op: (ast.nodes.get i: (sm.operation - 1).u64)
                skipThis: dropThis
            )
            match (
                sido
            ) case some then {
                (ty.setChildId
                    parentTypeId: fid
                    nameId: sm.name.u64
                    childTypeId: sido
                )
            } else null
        } else null
    }
    if (isgen) == false then {
        createName: "\{defName}.create"
        createId: reg.newType name: createName.stringview typetype: ztypes.ztypetype.functionType
        ty.setChildId parentTypeId: fid nameId: wkCreate childTypeId: createId
        borrowName: "\{defName}.borrow"
        borrowId: reg.newType name: borrowName.stringview typetype: ztypes.ztypetype.functionType
        ty.setChildId parentTypeId: fid nameId: wkBorrow childTypeId: borrowId
    }
    applyPrivateExclusions :ty parentId: ffid excl: pvExcl_ffid
    applyGrantsPrivate :ty parentId: ffid grants: pvGrants_ffid
    ty.definedInUnit.set key: ffid value: unitName.string
}

# resolveProtocol -- resolve a protocol ObjectDef into a PROTOCOL reftype: a child
# per is-block spec method (the `:this` receiver dropped), then synth `create` +
# `borrow` FUNCTION shells, then an unconditional destructor (a protocol wraps heap
# data). Reference type (is_valtype false), no `==`/`!=`. Generic protocols arrive later.
resolveProtocol: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    defName: StringView
    fnode: zast.ObjectDefData
} is {
    pid: (declareCanonicalType
        :ast
        :ty
        :reg
        defUnit: unitName
        name: defName
        typetype: ztypes.ztypetype.protocolType
    )
    ppid: pid
    pvExcl_ppid: (List u64)
    pvGrants_ppid: (List u64)
    scanVisibility :ty :ast onode: fnode excl: pvExcl_ppid grants: pvGrants_ppid
    reg.setValtype typeId: pid value: false
    isgen: hasGenericParam :ast items: fnode.isItems
    if isgen then reg.setGeneric typeId: pid value: true
    # A protocol spec receiver is normally dropped (resolves to nothing). The reference
    # resolves Text NESTED inside String's `:Text` marker, so Text's spec `:this` binds
    # to the enclosing String -- mirror that for the system Text protocol.
    specThisStr: defName.string
    dropThis: true
    if unitName == "system" then {
        if defName == "Text" then {
            specThisStr = "String".string
            dropThis = false
        }
    }
    if dropThis when unitName == ty.fullMainUnit.stringview then {
        dk: defName.string
        cto: ty.protocolThisContext.get key: dk
        match (
            cto
        ) case some then {
            specThisStr = cto.copy
            dropThis = false
        } case none then null
    }
    siter: fnode.isItems.iterate
    for smId9: siter loop {
        sm: ast.nodes.get i: (smId9 - 1).u64
        match (
            sm
        ) case namedoperation then {
            mname: zast.nameTextCopy :ast ref: sm.name
            qname: "\{defName}.\{mname}"
            sido: (resolveSpecFn
                :ty
                :reg
                :ast
                :unitName
                qname: qname.stringview
                thisName: specThisStr.stringview
                op: (ast.nodes.get i: (sm.operation - 1).u64)
                skipThis: dropThis
            )
            match (
                sido
            ) case some then {
                (ty.setChildId
                    parentTypeId: pid
                    nameId: sm.name.u64
                    childTypeId: sido
                )
            } else null
        } else null
    }
    if (isgen) == false then {
        createName: "\{defName}.create"
        createId: reg.newType name: createName.stringview typetype: ztypes.ztypetype.functionType
        ty.setChildId parentTypeId: pid nameId: wkCreate childTypeId: createId
        borrowName: "\{defName}.borrow"
        borrowId: reg.newType name: borrowName.stringview typetype: ztypes.ztypetype.functionType
        ty.setChildId parentTypeId: pid nameId: wkBorrow childTypeId: borrowId
    }
    dn: "\{defName}_destroy"
    reg.setDestructorName typeId: pid name: dn.stringview
    applyPrivateExclusions :ty parentId: ppid excl: pvExcl_ppid
    applyGrantsPrivate :ty parentId: ppid grants: pvGrants_ppid
    ty.definedInUnit.set key: ppid value: unitName.string
}

# registerEmptyType -- register a native bottom type (null -> NULL, never -> NEVER) as a
# valtype with a single synth `create` child. The reference special-cases these: they are
# `record is native` in source but carry a distinct typetype and only a create child.
registerEmptyType: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    name: StringView
    tt: ztypes.ztypetype
} out u64 is {
    rk0: "\{unitName}.\{name}"
    ex0: resolvedByKey :ast :ty :reg key: rk0
    match (
        ex0
    ) case some then {
        reg.setValtype typeId: ex0 value: true
        ccn0: "\{name}.create"
        cci0: reg.newType name: ccn0.stringview typetype: ztypes.ztypetype.functionType
        ty.setChildId parentTypeId: ex0 nameId: wkCreate childTypeId: cci0
        ty.definedInUnit.set key: ex0 value: unitName.string
        return ex0
    } case none then null
    nid: reg.newType :name typetype: tt
    nnid: nid
    reg.setValtype typeId: nid value: true
    ccname: "\{name}.create"
    ccid: reg.newType name: ccname.stringview typetype: ztypes.ztypetype.functionType
    ty.setChildId parentTypeId: nid nameId: wkCreate childTypeId: ccid
    ty.definedInUnit.set key: nnid value: unitName.string
    return nid
}

# descendIntoUnit -- fetch the def node at bodyIdx inside a unit's body and
# resolve it. Split from descendNamed so the unit node arrives as a plain
# parameter (matching resolveUnitBody's narrowing shape).
descendIntoUnit: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    defName: StringView
    bodyIdx: u64
    unitdefId: u32
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: unitdefId
    if bodyIdx >= bodyIds9.length then return
    bm9Id9: bodyIds9.get i: bodyIdx
    bm9: ast.nodes.get i: (bm9Id9 - 1).u64
    if bm9.namedoperation then {
        dn9: zast.nameTextCopy :ast ref: bm9.name
        if dn9.stringview == defName then {
            (resolveDef
                :ty
                :reg
                :ast
                :unitName
                :defName
                defn: (ast.nodes.get i: (bm9.operation - 1).u64)
            )
        }
    }
}

# descendNamed -- reference-level DFS entry: resolve a named top-level def's
# body by descending into its AST node (located via the defNodeUnitIdx /
# defNodeBodyIdx node finder) so a reference's dependency resolves before the
# referrer continues. Returns the canonical forward-decl id; a grey
# (in-progress) or already-resolved target returns it without re-descending.
# Returns 0 when the name is not an indexed top-level def, so the caller keeps
# its shell behavior.
descendNamed: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    defUnit: StringView
    name: StringView
} out u64 is {
    if ty.defNodeIndexBuilt == false then return 0
    if defUnit == "core" then return 0
    tto9: ty.defTypetype.get key: ("\{defUnit}.\{name}")
    ttv9: ztypes.ztypetype.nullType
    classified9: false
    match (
        tto9
    ) case some then {
        ttv9 = tto9
        classified9 = true
    } case none then null
    tid9: u64
    if classified9 then tid9 = declareCanonicalType :ast :ty :reg :defUnit :name typetype: ttv9
    dk9a: "\{defUnit}.\{name}"
    if (ty.definedKeys.has item: dk9a) then return tid9
    dk9b: "\{defUnit}.\{name}"
    if (ty.resolving.has item: dk9b) then {
        # A grey hit is a back-edge. Reference-kind targets (UNION/CLASS --
        # boxed) are legal forward declarations; a VALUE-kind target reached
        # through a containment edge cannot lay out.
        if ty.inContainmentEdge then {
            cycV9: false
            if ttv9 == ztypes.ztypetype.recordType then cycV9 = true
            if ttv9 == ztypes.ztypetype.variantType then cycV9 = true
            if cycV9 then {
                cem9: "containment cycle: value type '\{defUnit}.\{name}' contains itself by value; box the field behind a class, union, or Option"
                addResolveError :ty e: zast.err.typeError msg: cem9
            }
        }
        return tid9
    }
    uo9: ty.defNodeUnitIdx.get key: ("\{defUnit}.\{name}")
    uidx9: u64
    match (
        uo9
    ) case some then {
        uidx9 = uo9
    } case none then {
        return tid9
    }
    bo9: ty.defNodeBodyIdx.get key: ("\{defUnit}.\{name}")
    bidx9: u64
    match (
        bo9
    ) case some then {
        bidx9 = bo9
    } case none then {
        return tid9
    }
    sup9: ty.suppressSigStamp
    ty.suppressSigStamp = false
    ue9Id9: ast.units.get i: uidx9
    ue9: ast.nodes.get i: (ue9Id9 - 1).u64
    match (
        ue9
    ) case namedoperation then {
        (descendIntoUnit
            :ty
            :reg
            :ast
            unitName: defUnit
            defName: name
            bodyIdx: bidx9
            unitdefId: ue9.operation
        )
    } else null
    ty.suppressSigStamp = sup9
    if classified9 == false then {
        ro9: resolveUnitChild :ast :ty :reg unitName: defUnit :name
        return (optU64Or o: ro9 d: 0)
    }
    return tid9
}

# resolveDef -- dispatch a main-unit definition by kind. Resolves functions, data
# blocks, records, variants, unions, classes, facets and protocols; a top-level data
# block parses as an `expression` wrapping a `datablock`, so unwrap one level and
# re-dispatch. Enums and generics arrive in later slices.
resolveDef: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    defName: StringView
    defn: Node
} is {
    gk0: "\{unitName}.\{defName}"
    ty.resolving.add item: gk0
    # A containment edge is ONE hop: this def's own resolution starts a
    # fresh context (its field/arm legs re-arm the flag), so an outer field
    # bracket never taints nested param/return resolution.
    prevCE0: ty.inContainmentEdge
    ty.inContainmentEdge = false
    match (
        defn
    ) case functiondef then {
        fid: (resolveFunction
            :ty
            :reg
            :ast
            :unitName
            :defName
            fnode: defn
            thisName: ""
            skipThisType: false
        )
        ty.nodeType.set key: defn.nodeid.u64 value: fid
        if (isGeneratorReturn :ast oId: defn.returntype) then {
            (synthGeneratorIterClass
                :ty
                :reg
                :ast
                :unitName
                fnName: defName
                thisName: ""
                fnode: defn
            )
        }
    } case expression then {
        dfx9: ast.nodes.get i: (defn.expression - 1).u64
        resolveDef :ty :reg :ast :unitName :defName defn: dfx9
        exprKey: "\{unitName}.\{defName}"
        exprid: resolvedByKey :ast :ty :reg key: exprKey
        match (
            exprid
        ) case some then {
            ty.nodeType.set key: defn.nodeid.u64 value: exprid
        } case none then null
    } case datablock then {
        resolveData :ast :ty :reg :unitName :defName dnode: defn
        dbKey: "\{unitName}.\{defName}"
        dbrid: resolvedByKey :ast :ty :reg key: dbKey
        match (
            dbrid
        ) case some then {
            ty.nodeType.set key: defn.nodeid.u64 value: dbrid
        } case none then null
    } case objectdef then {
        match (
            defn.kind
        ) case recordDef then {
            if defName == "null" then {
                registerEmptyType :ast :ty :reg :unitName name: "null" tt: ztypes.ztypetype.nullType
            } else {
                if defName == "never" then {
                    nvid9: (registerEmptyType
                        :ast
                        :ty
                        :reg
                        :unitName
                        name: "never"
                        tt: ztypes.ztypetype.neverType
                    )
                    setnv9: nvid9
                    ty.nodeType.set key: defn.nodeid.u64 value: setnv9
                } else {
                    resolveRecord :ty :reg :ast :unitName :defName rnode: defn
                }
            }
        } case variantDef then {
            resolveVariant :ty :reg :ast :unitName :defName vnode: defn
        } case unionDef then {
            resolveUnion :ty :reg :ast :unitName :defName vnode: defn
        } case classDef then {
            resolveClass :ty :reg :ast :unitName :defName cnode: defn
        } case facetDef then {
            resolveFacet :ty :reg :ast :unitName :defName fnode: defn
        } case protocolDef then {
            resolveProtocol :ty :reg :ast :unitName :defName fnode: defn
        } else null
        objKey: "\{unitName}.\{defName}"
        objrid: resolvedByKey :ast :ty :reg key: objKey
        match (
            objrid
        ) case some then {
            ty.nodeType.set key: defn.nodeid.u64 value: objrid
        } case none then null
    } case dottedpath then {
        # A unit-level type alias (`Node: zast.Node`): resolve the cross-unit dotted
        # ref to a (shell) type id and register it under the unit's name, so bare-alias
        # return types and value uses resolve. Replicates resolveTyperefShell's
        # cross-unit leg; mirrors the reference's _type_of_definition dotted-path
        # fallback (ztypecheck.py:1184).
        apNm9: atomName :ast n: (ast.nodes.get i: (defn.parent - 1).u64)
        if (reg.isUnitName name: apNm9.stringview) then {
            acNm9: atomName :ast n: (ast.nodes.get i: (defn.child - 1).u64)
            reg.recordDemand name: acNm9.stringview
            reg.recordSeededDemand un: unitName name: acNm9.stringview
            tgtKey9: "\{apNm9}.\{acNm9}"
            ark9: "\{unitName}.\{defName}"
            # Record alias -> target; resolveTypeAliases repoints the alias to the
            # target's canonical id once the demand fixpoint has resolved it. The
            # target is usually still unresolved here, so the placeholder below would
            # otherwise leave the alias a phantom RECORD shell (a second empty `Node`
            # beside the real zast.Node union).
            fk9: ark9.copy
            fv9: tgtKey9.copy
            ty.funcAliases.set key: fk9 value: fv9
            # Use the canonical id if already resolved; else a shell placeholder
            # (overwritten by resolveTypeAliases) so the demand fixpoint terminates.
            if (ty.resolving.has item: tgtKey9) then {
                aem9: "alias cycle: '\{unitName}.\{defName}' aliases '\{tgtKey9}' which is still resolving"
                addResolveError :ty e: zast.err.typeError msg: aem9
            }
            descendNamed :ty :reg :ast defUnit: apNm9.stringview name: acNm9.stringview
            tgo9: resolvedByKey :ast :ty :reg key: tgtKey9
            aid9: u64
            match (
                tgo9
            ) case some then {
                aid9 = tgo9
            } case none then {
                aid9 = (resolveAtomType
                    :ty
                    :reg
                    :ast
                    :unitName
                    nm: acNm9.stringview
                    thisName: ""
                )
            }
            sda9: aid9
            ty.nodeType.set key: defn.nodeid.u64 value: sda9
            # a cross-unit `unit.Type` alias carries its target tid for
            # go-to-definition (dotted node; see the type-position stamp)
            ty.atomUnitDefId.set key: defn.nodeid.u64 value: sda9
        }
    } else null
    # Unit -> def childOf edges are built at mint (declareCanonicalType) for real
    # defs and on demand (resolvedByKey's alias-follow) for aliases; no tail pass.
    ty.inContainmentEdge = prevCE0
    gk1: "\{unitName}.\{defName}"
    ty.resolving.delete item: gk1
    dkk0: "\{unitName}.\{defName}"
    ty.definedKeys.add item: dkk0
}

# resolveTypeAliases -- repoint each unit-level type alias (recorded in funcAliases
# during resolveDef as "{unit}.{alias}" -> "{targetUnit}.{target}") to its target's
# canonical type id, now that the cross-unit demand fixpoint has resolved targets.
# Without this an alias whose target was unresolved when first walked stays bound to a
# phantom RECORD shell (a second empty `Node` beside the real zast.Node union), which
# breaks cross-unit return types and union-arm construction.
resolveTypeAliases: function {ast: Ast ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry} is {
    akeys9: (List String)
    avals9: (List String)
    with it: ty.funcAliases.iterateItems do for e: it loop {
        ek9: e.key.copy
        akeys9.append ek9
        ev9: e.value.copy
        avals9.append ev9
    }
    ai9: u64
    an9: akeys9.length
    for ai9 < an9 loop {
        aek9: akeys9.get i: ai9
        aev9: avals9.get i: ai9
        ai9 = ai9 + 1
        tgo: resolvedByKey :ast :ty :reg key: aev9.copy
        match (
            tgo
        ) case some then {
            tv: tgo
            au: String
            an: String
            with skit: (aek9.stringview.split sep: ".") do for kseg: skit loop {
                if au.length == 0 then {
                    au = kseg.string
                } else {
                    an = kseg.string
                }
            }
            uro: reg.unitNameTid.get key: au
            match (
                uro
            ) case some then {
                (ty.setChildId
                    parentTypeId: uro
                    nameId: (zast.poolFind pool: ast.names text: an.stringview).u64
                    childTypeId: tv
                )
            } case none then null
        } case none then {
            vau: String
            van: String
            with vkit: (aek9.stringview.split sep: ".") do for vseg: vkit loop {
                if vau.length == 0 then {
                    vau = vseg.string
                } else {
                    van = vseg.string
                }
            }
            vroot: String
            vmem: String
            with vvit: (aev9.stringview.split sep: ".") do for vvseg: vvit loop {
                if vroot.length == 0 then {
                    vroot = vvseg.string
                } else {
                    vmem = vvseg.string
                }
            }
            tto: walkLookupTyperef :ast :ty :reg currentUnit: vau.stringview base: vroot.stringview
            match (
                tto
            ) case some then {
                memo: ty.childOf pool: ast.names parentTypeId: tto name: vmem.stringview
                match (
                    memo
                ) case some then {
                    rtt: reg.typetypeOf typeId: tto
                    isTag: false
                    if rtt == ztypes.ztypetype.variantType then isTag = true
                    if rtt == ztypes.ztypetype.unionType then isTag = true
                    if isTag then {
                        mtt: reg.typetypeOf typeId: memo
                        isMem: true
                        if mtt == ztypes.ztypetype.functionType then isMem = false
                        if mtt == ztypes.ztypetype.dataType then isMem = false
                        if isMem then {
                            vuro: reg.unitNameTid.get key: vau.copy
                            match (
                                vuro
                            ) case some then {
                                (ty.setChildId
                                    parentTypeId: vuro
                                    nameId: (zast.poolFind pool: ast.names text: van.stringview).u64
                                    childTypeId: tto
                                )
                            } case none then null
                            vno: ty.aliasDefNode.get key: aek9.copy
                            match (
                                vno
                            ) case some then {
                                vrn: vroot.copy
                                ty.pendingTyperef.set key: vno value: vrn
                                vun: vau.copy
                                ty.pendingTyperefUnit.set key: vno value: vun
                            } case none then null
                        }
                    }
                } case none then null
            } case none then null
        }
    }
}

# resolveUnitBody -- resolve every top-level definition signature in a unit.
# resolveUnitBody -- resolve a unit's definition signatures. Signature-only
# resolves every member; the full body-walk mode mirrors check()'s eager set
# (functions and units only -- other definitions resolve on demand, so unused
# main-unit records/classes/unions drop out of the full dump).
resolveUnitBody: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    unitdefId: u32
    full: bool
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: unitdefId
    {
        if (hasGenericParam :ast items: bodyIds9) then {
            registerGenericParams :reg :ast typeKey: unitName items: bodyIds9
            # Each generic-param name gets a canonical per-(unit,param)
            # GENERIC_PARAM tid (get-or-mint), attributed to the unit; the
            # param definition's value node carries it so template signatures
            # and bodies stamp it.
            with gpiter: bodyIds9.iterate do for gmId9: gpiter loop {
                gm: ast.nodes.get i: (gmId9 - 1).u64
                match (
                    gm
                ) case namedoperation then {
                    if (isBareGenericParam
                        :ast
                        op: (ast.nodes.get i: (gm.operation - 1).u64)
                    ) then {
                        gpn0: zast.nameTextCopy :ast ref: gm.name
                        gtid0: u64
                        gpo0: reg.genericParamTidOf typeKey: unitName paramName: gpn0.stringview
                        match (
                            gpo0
                        ) case some then {
                            gtid0 = gpo0
                        } case none then {
                            gtid0 = (reg.newType
                                name: gpn0.stringview
                                typetype: ztypes.ztypetype.genericParam
                            )
                            (reg.setGenericParamTid
                                typeKey: unitName
                                paramName: gpn0.stringview
                                tid: gtid0
                            )
                        }
                        gtidK0: gtid0
                        ty.definedInUnit.set key: gtidK0 value: unitName.string
                        gpnid: nodeId n: (ast.nodes.get i: (gm.operation - 1).u64)
                        gtidV0: gtid0
                        ty.nodeType.set key: gpnid.u64 value: gtidV0
                    }
                } else null
            }
        }
        if full then {
            # The reference binds a spec receiver only when the conformer's
            # resolution triggers the protocol's; a main body that never
            # names the conformer resolves the protocol context-free (e.g.
            # through a function signature). Collect member names first --
            # the body list cannot be passed while its iterator is live.
            fmu: unitName.string
            ty.fullMainUnit = fmu
            ccNames: (List String)
            with cmiter: bodyIds9.iterate do for cmmId9: cmiter loop {
                cmm: ast.nodes.get i: (cmmId9 - 1).u64
                ccn0: String
                match (
                    cmm
                ) case namedoperation then {
                    ccn1: zast.nameTextCopy :ast ref: cmm.name
                    ccn0 = ccn1
                } else null
                ccNames.append ccn0
            }
            mainOp9: u32
            with cmit0: bodyIds9.iterate do for cmm0: cmit0 loop {
                if mainOp9 == 0 then {
                    cmn0: ast.nodes.get i: (cmm0 - 1).u64
                    match (
                        cmn0
                    ) case namedoperation then {
                        if (zast.nameTextEq
                            :ast
                            ref: cmn0.name
                            s: "main"
                        ) then mainOp9 = cmn0.operation
                    } else null
                }
            }
            cci: u64
            ccTotal: ccNames.length
            for cci < ccTotal loop {
                cnm2: ccNames.get i: cci
                if cnm2.length > 0 when mainOp9 > 0 then {
                    if (fnBodyMentions
                        :ast
                        op: (ast.nodes.get i: (mainOp9 - 1).u64)
                        name: cnm2.stringview
                    ) then {
                        mem2Id9: bodyIds9.get i: cci
                        mem2: ast.nodes.get i: (mem2Id9 - 1).u64
                        match (
                            mem2
                        ) case namedoperation then {
                            (recordConformerContexts
                                :ast
                                :ty
                                defName: cnm2.stringview
                                op: (ast.nodes.get i: (mem2.operation - 1).u64)
                            )
                        } else null
                    }
                }
                cci = cci + 1
            }
        }
        biter: bodyIds9.iterate
        for bm: biter loop {
            bmNode9: ast.nodes.get i: (bm - 1).u64
            match (
                bmNode9
            ) case namedoperation then {
                defName: zast.nameTextCopy :ast ref: bmNode9.name
                eager: true
                if full then {
                    if (isFunctionDefOp op: (ast.nodes.get i: (bmNode9.operation - 1).u64)) == false then {
                        if (isUnitOp op: (ast.nodes.get i: (bmNode9.operation - 1).u64)) == false then eager = false
                    }
                }
                if eager then {
                    if (isUnitOp op: (ast.nodes.get i: (bmNode9.operation - 1).u64)) then {
                        (resolveInlineGenericUnit
                            :ty
                            :reg
                            :ast
                            :unitName
                            defName: defName.stringview
                            unitOpId: bmNode9.operation
                        )
                    } else {
                        rkeyE: "\{unitName}.\{defName}"
                        if (ty.definedKeys.has item: rkeyE) == false then {
                            (resolveDef
                                :ty
                                :reg
                                :ast
                                :unitName
                                defName: defName.stringview
                                defn: (ast.nodes.get i: (bmNode9.operation - 1).u64)
                            )
                        }
                    }
                }
            } else null
        }
    }
}

# typecheck -- entry point. Registers a UNIT type per unit (the `unit` table)
# and resolves the main unit's definition signatures into the registry. The
# registry is supplied by the caller and read by the SQL dumper.
# registerAndResolveMain -- register a UNIT type per unit, then resolve the main
# unit's definition signatures. Iterates program.ast.units transiently so the demand
# pass can re-iterate it without an overlapping exclusive lock.
# isFileUnit -- a user FILE unit (main or a loaded dependency like zlexer/zast/
# zvfs) whose body must be fully resolved + checked so its types/functions emit;
# system library units ride the demand pass + native fragments instead.
isFileUnit: function {name: StringView} out bool is {
    if name == "system" then return false
    if name == "core" then return false
    if name == "collections" then return false
    if name == "io" then return false
    if name == "os" then return false
    if name == "cli" then return false
    return true
}

# registerUnitRoots -- Stage D: register a UNIT type + name for EVERY unit up
# front, before lowerGenerators / indexUnitDefs / demand resolution, so
# reg.unitNameTid is complete and childOf-at-mint (declareCanonicalType) always sees
# a populated unit root. The main unit precedes its deps in unit order, so a
# cross-unit qualified type ref (zlexer.Token) sees the dep as a unit; member
# paths type their base as the UNIT type via this name-keyed side map -- never the
# resolution chain, where a main unit sharing a type's name (str.z, panic.z) would
# shadow it. Formerly registerAndResolveMain Pass 1.
registerUnitRoots: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry program: Node} is {
    match (
        program
    ) case program then {
        uCnt9c: program.ast.units.length
        uIdx9c: u64
        for uIdx9c < uCnt9c loop {
            ruId9: program.ast.units.get i: uIdx9c
            uIdx9c = uIdx9c + 1
            opId9: u32
            nm9: String
            {
                ru: program.ast.nodes.get i: (ruId9 - 1).u64
                if ru.namedoperation then {
                    nm: zast.poolTextCopy pool: program.ast.names ref: ru.name
                    opId9 = ru.operation
                    nm9 = nm.copy
                }
            }
            if opId9 > 0 then {
                uid: reg.newType name: nm9.stringview typetype: ztypes.ztypetype.unitType
                opid: unitdefNodeId ast: program.ast nId: opId9
                ty.unitTypesById.set key: opid.u64 value: uid
                uid3: uid
                reg.setUnitName name: nm9.stringview uid: uid3
            }
        }
    } else null
}

# demandAllUnitDefs -- demand every top-level definition of a unit. Used
# when a stdlib unit is the MAIN unit (an editor opened it): its type
# defs have no in-graph consumers, so nothing would demand them and
# their signature typerefs would never stamp.
demandAllUnitDefs: function {reg: ztypes.ZTypeRegistry ast: Ast unitdefId: u32} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: unitdefId
    with dit9: bodyIds9.iterate do for bm9Id9: dit9 loop {
        bm9: ast.nodes.get i: (bm9Id9 - 1).u64
        if bm9.namedoperation then {
            dn9: zast.nameTextCopy :ast ref: bm9.name
            if dn9.length > 0 then reg.recordDemand name: dn9.stringview
        }
    }
}

# nativeOnlyBodyError -- one diagnostic for a bodied function declared in a
# native-only stdlib unit (its C would never be emitted; calls fail at link).
nativeOnlyBodyError: function {
    ty: ztyping.ZTyping
    unitName: StringView
    fnName: StringView
    nodeid: u32
    lineno: u32
    colno: u32
} is {
    unc9: unitName.string
    fnc9: fnName.string
    em9: "type method '\{fnc9}' in unit '\{unc9}' cannot carry a .z body: the type is runtime-backed"
    en9: (
        "the runtime-backed stdlib units' types are implemented by the C runtime; their methods are 'is native'"
    ).string
    eh9: "implement it as a native under src/runtime, or as a free function taking the value".string
    ty.errors.append (zast.ErrorData
        :nodeid
        :lineno
        :colno
        width: fnName.length.u32.orPanic
        err: zast.err.typeError
        msg: em9
        fsno: 0
        note: en9
        hint: eh9
    )
    ty.isError = true
}

# nativeOnlyCheckOp -- one unit member: a bodied top-level function errors
# directly; a type's is/as members are scanned for bodied methods.
nativeOnlyCheckOp: function {
    ast: Ast
    ty: ztyping.ZTyping
    unitName: StringView
    defName: StringView
    op: Node
} is {
    # a bodied FREE function here is ordinary emitted code (only the
    # unit's TYPES are runtime-backed); nothing to reject at this level
    match (
        op
    ) case objectdef then {
        with iit9: op.isItems.iterate do for im9Id9: iit9 loop {
            im9: ast.nodes.get i: (im9Id9 - 1).u64
            match (
                im9
            ) case namedoperation then {
                if (isFunctionDefWithBody o: (ast.nodes.get i: (im9.operation - 1).u64)) then {
                    in9: zast.nameTextCopy :ast ref: im9.name
                    mn9: "\{defName}.\{in9}"
                    (nativeOnlyBodyError
                        :ty
                        :unitName
                        fnName: mn9.stringview
                        nodeid: (nodeId n: (ast.nodes.get i: (im9.operation - 1).u64))
                        lineno: (nodeLine n: (ast.nodes.get i: (im9.operation - 1).u64))
                        colno: (nodeCol n: (ast.nodes.get i: (im9.operation - 1).u64))
                    )
                }
            } else null
        }
        with ait9: op.asItems.iterate do for am9Id9: ait9 loop {
            am9: ast.nodes.get i: (am9Id9 - 1).u64
            match (
                am9
            ) case namedoperation then {
                if (isFunctionDefWithBody o: (ast.nodes.get i: (am9.operation - 1).u64)) then {
                    an9: zast.nameTextCopy :ast ref: am9.name
                    amn9: "\{defName}.\{an9}"
                    (nativeOnlyBodyError
                        :ty
                        :unitName
                        fnName: amn9.stringview
                        nodeid: (nodeId n: (ast.nodes.get i: (am9.operation - 1).u64))
                        lineno: (nodeLine n: (ast.nodes.get i: (am9.operation - 1).u64))
                        colno: (nodeCol n: (ast.nodes.get i: (am9.operation - 1).u64))
                    )
                }
            } else null
        }
    } else null
}

# checkNativeOnlyUnitBodies -- the runtime-backed stdlib units
# (system/core/collections/io/os/cli) implement their TYPES in the C
# runtime: a type method with a .z body there would never be emitted
# (emitRecordDefs excludes those units), so reject it eagerly. Bodied
# FREE functions are fine -- they emit like any cross-unit function.
checkNativeOnlyUnitBodies: function {
    ast: Ast
    ty: ztyping.ZTyping
    unitName: StringView
    unitdefId: u32
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: unitdefId
    with dit9: bodyIds9.iterate do for dm9Id9: dit9 loop {
        dm9: ast.nodes.get i: (dm9Id9 - 1).u64
        if dm9.namedoperation then {
            dn9: zast.nameTextCopy :ast ref: dm9.name
            (nativeOnlyCheckOp
                :ast
                :ty
                :unitName
                defName: dn9.stringview
                op: (ast.nodes.get i: (dm9.operation - 1).u64)
            )
        }
    }
}

# unitHasDemandedBodiedFn -- a unit carries a top-level bodied function the
# program actually referenced (its composed key resolved during the demand
# loop). Gates the runtime-backed units' post-main resolve+walk so programs
# that never call a bodied stdlib fn stay untouched.
unitHasDemandedBodiedFn: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    unitdefId: u32
} out bool is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: unitdefId
    with bit9: bodyIds9.iterate do for bm9Id9: bit9 loop {
        bm9: ast.nodes.get i: (bm9Id9 - 1).u64
        if bm9.namedoperation then {
            if (isFunctionDefWithBody o: (ast.nodes.get i: (bm9.operation - 1).u64)) then {
                bn9: zast.nameTextCopy :ast ref: bm9.name
                bk9: "\{unitName}.\{bn9}"
                ro9: resolvedByKey :ast :ty :reg key: bk9
                if ro9.some then return true
            }
        }
    }
    return false
}

registerAndResolveMain: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    program: Node
    full: bool
} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        # Pass 1 (unit-root minting) hoisted to registerUnitRoots, run before lowerGenerators.
        # Pass 2: resolve EVERY file unit's definition signatures (main + deps
        # like zlexer/zast/zvfs), so cross-unit type refs resolve to the dep's
        # own type and the dep's type/fn def nodes get stamped for emission.
        muN0: program.ast.units.length
        muI0: u64
        for muI0 < muN0 loop {
            muId9: program.ast.units.get i: muI0
            muI0 = muI0 + 1
            opId9: u32
            nm9: String
            {
                mu: program.ast.nodes.get i: (muId9 - 1).u64
                if mu.namedoperation then {
                    nm: zast.poolTextCopy pool: program.ast.names ref: mu.name
                    opId9 = mu.operation
                    nm9 = nm.copy
                }
            }
            if opId9 > 0 then {
                if (isStdlibUnitName name: nm9.stringview) then {
                    (checkNativeOnlyUnitBodies
                        :ty
                        ast: program.ast
                        unitName: nm9.stringview
                        unitdefId: opId9
                    )
                }
                eager9: isFileUnit name: nm9.stringview
                if nm9.stringview == mainName then {
                    # a stdlib unit opened as main: demand all of its
                    # defs so every signature typeref resolves + stamps.
                    if (eager9) == false then (demandAllUnitDefs
                        :reg
                        ast: program.ast
                        unitdefId: opId9
                    )
                    eager9 = true
                }
                if eager9 then {
                    # Skeleton mode (full=false): the reference resolves dep
                    # signatures lazily and never stamps their type-ref atoms, so
                    # suppress the dep sig stamps to match. Full mode stamps them
                    # (the reference does too), so leave it on there.
                    supp: false
                    if (full) == false then {
                        if (nm9.stringview == mainName) == false then {
                            if (unitDefIsGeneric
                                ast: program.ast
                                oId: opId9
                            ) == false then supp = true
                        }
                    }
                    ty.suppressSigStamp = supp
                    (resolveUnitBody
                        :ty
                        :reg
                        ast: program.ast
                        unitName: nm9.stringview
                        unitdefId: opId9
                        :full
                    )
                    ty.suppressSigStamp = false
                }
            }
        }
    } else null
}

# resolveDemandedUnitBody -- resolve the definitions of a non-main unit that a
# main-unit signature referenced (reg.isDemanded) and that aren't resolved yet,
# stamping them with that unit's name (mirrors the oracle's on-demand resolution).
resolveDemandedUnitBody: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    shadowUnit: StringView
    unitdefId: u32
} out bool is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: unitdefId
    anyDemanded: false
    {
        biter: bodyIds9.iterate
        for bm: biter loop {
            bmNode9: ast.nodes.get i: (bm - 1).u64
            match (
                bmNode9
            ) case namedoperation then {
                dn: zast.nameTextCopy :ast ref: bmNode9.name
                if (reg.isDemanded name: dn.stringview) then {
                    # A name the main unit defines shadows this unit's def --
                    # unless the unit's own internals demand it (seeded io
                    # names): the reference resolves those io-locally.
                    shadowed: false
                    if shadowUnit.length != 0 then {
                        skey: "\{shadowUnit}.\{dn}"
                        sgot: resolvedByKey :ast :ty :reg key: skey
                        match (
                            sgot
                        ) case some then {
                            shadowed = true
                        } case none then null
                    }
                    if shadowed when (reg.isSeededDemand un: unitName name: dn.stringview) then {
                        shadowed = false
                    }
                    if shadowed when (reg.isSeededDemand un: "*" name: dn.stringview) then {
                        shadowed = false
                    }
                    if (shadowed) == false then {
                        anyDemanded = true
                        rkey: "\{unitName}.\{dn}"
                        if (ty.definedKeys.has item: rkey) == false then {
                            (resolveDef
                                :ty
                                :reg
                                :ast
                                :unitName
                                defName: dn.stringview
                                defn: (ast.nodes.get i: (bmNode9.operation - 1).u64)
                            )
                        }
                    }
                }
            } else null
        }
    }
    return anyDemanded
}

# isConformanceMarker -- true when an as-item operation is a bare type reference
# (atomid / labelvalue), i.e. a conformance marker like `:Text` or `m: Reader`.
isConformanceMarker: function {op: Node} out bool is {
    match (
        op
    ) case atomid then {
        return true
    } case labelvalue then {
        return true
    } else {
        return false
    }
}

# declaresConformance -- true when an objectdef declares conformance via an as-item
# (the oracle eager-resolves such collections types on first touch of the unit).
declaresConformance: function {ast: Ast op: Node} out bool is {
    match (
        op
    ) case objectdef then {
        citer: op.asItems.iterate
        for cmId9: citer loop {
            cm: ast.nodes.get i: (cmId9 - 1).u64
            match (
                cm
            ) case namedoperation then {
                if (isConformanceMarker op: (ast.nodes.get i: (cm.operation - 1).u64)) then return true
            } else null
        }
        return false
    } else {
        return false
    }
}

# resolveConformanceDefs -- resolve every not-yet-resolved unit def that declares a
# conformance marker, mirroring the oracle's eager conformance pass. Only `str`
# (`:Text`) qualifies in collections today; called when the unit was demanded at all.
resolveConformanceDefs: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    unitdefId: u32
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: unitdefId
    biter: bodyIds9.iterate
    for bm: biter loop {
        bmNode9: ast.nodes.get i: (bm - 1).u64
        if bmNode9.namedoperation then {
            if (declaresConformance
                :ast
                op: (ast.nodes.get i: (bmNode9.operation - 1).u64)
            ) then {
                dn: zast.nameTextCopy :ast ref: bmNode9.name
                rkey: "\{unitName}.\{dn}"
                if (ty.definedKeys.has item: rkey) == false then {
                    (resolveDef
                        :ty
                        :reg
                        :ast
                        :unitName
                        defName: dn.stringview
                        defn: (ast.nodes.get i: (bmNode9.operation - 1).u64)
                    )
                }
            }
        }
    }
}

# seedIteratorDemands -- a collection template's produced methods carry
# shell returns (chain returns link per-instance via the family fixup arms),
# so the sibling iterator/view templates are still unreachable by reference
# descent. When a collection is demanded, demand its iterators too.
seedIteratorDemands: function {reg: ztypes.ZTypeRegistry} is {
    if (reg.isDemanded name: "Set") then reg.recordDemand name: "SetIter"
    if (reg.isDemanded name: "List") then {
        reg.recordDemand name: "ListIter"
        reg.recordDemand name: "ListView"
    }
    if (reg.isDemanded name: "Map") then {
        reg.recordDemand name: "MapKeyIter"
        reg.recordDemand name: "MapItemIter"
        reg.recordDemand name: "MapEntry"
    }
}

# seedSystemDemands -- the literal-materialization set: the system types a
# program can require without ever writing a resolvable reference to them.
# Numeric scalars + tag back per-use literal shells (resolveAtomType mints
# them by name; the canonical defs must exist as typedef/emission bases),
# and bool backs core's true/false re-exports (resolveTypeAliases resolves
# them against the already-resolved system.bool). Every other system type is
# reached by reference descent at its first use.
seedSystemDemands: function {reg: ztypes.ZTypeRegistry} is {
    reg.recordDemand name: "i8"
    reg.recordDemand name: "i16"
    reg.recordDemand name: "i32"
    reg.recordDemand name: "i64"
    reg.recordDemand name: "i128"
    reg.recordDemand name: "u8"
    reg.recordDemand name: "u16"
    reg.recordDemand name: "u32"
    reg.recordDemand name: "u64"
    reg.recordDemand name: "u128"
    reg.recordDemand name: "f32"
    reg.recordDemand name: "f64"
    reg.recordDemand name: "tag"
    reg.recordDemand name: "bool"
}

# seedIoDemands -- demand the io-unit closure the reference's full typecheck pulls
# reference-driven: the stream protocols (conformance-marker targets), IoError
# (the Result err arms), and seekorigin (Seeker.seek). The .z demand pass is
# name-driven, so the closure is seeded explicitly (like seedSystemDemands);
# IoError/seekorigin precede the protocols in io.z body order, so demands recorded
# while resolving the protocols would arrive after the pass already walked them.
seedIoDemands: function {reg: ztypes.ZTypeRegistry} is {
    reg.recordDemand name: "Reader"
    reg.recordSeededDemand un: "io" name: "Reader"
    reg.recordDemand name: "Writer"
    reg.recordSeededDemand un: "io" name: "Writer"
    reg.recordDemand name: "Seeker"
    reg.recordSeededDemand un: "io" name: "Seeker"
    reg.recordDemand name: "Closer"
    reg.recordSeededDemand un: "io" name: "Closer"
    reg.recordDemand name: "IoError"
    reg.recordSeededDemand un: "io" name: "IoError"
    reg.recordDemand name: "seekorigin"
    reg.recordSeededDemand un: "io" name: "seekorigin"
}

# stampCtorDefaults -- a construction fills unprovided defaulted fields: the
# default's node stamps its resolved member/parent type, once the owner has
# actually been constructed (full-mode body walk).
stampCtorDefaults: function {ast: Ast st: zenv.ZSymbolTable unitName: StringView} is {
    dnids9: (List u64)
    owners: (List u64)
    with diter: st.typing.pendingDefaultOwner.iterateItems do for de: diter loop {
        dk: de.key
        dnids9.append dk
        dv: de.value
        owners.append dv
    }
    di: u64
    dn: dnids9.length
    for di < dn loop {
        ow: owners.get i: di
        cgot: st.typing.constructedTypes.get key: ow
        isCon: optBoolOr o: cgot d: false
        if isCon then {
            nd: dnids9.get i: di
            ido: st.typing.pendingDefaultId.get key: nd
            idv: optU64Or o: ido d: 0
            if idv > 0 then {
                nd2: dnids9.get i: di
                setd2: idv
                st.typing.nodeType.set key: nd2 value: setd2
            } else {
                nd3: dnids9.get i: di
                ng9: copiedMapStr m: st.typing.pendingDefaultName key: nd3
                if ng9.length > 0 then {
                    nrt: (optU64Or
                        o: (walkLookupTyperef
                            :ast
                            ty: st.typing
                            reg: st.reg
                            currentUnit: unitName
                            base: ng9.stringview
                        )
                        d: 0
                    )
                    if nrt > 0 then {
                        nd4: dnids9.get i: di
                        setd4: nrt
                        st.typing.nodeType.set key: nd4 value: setd4
                    }
                }
            }
        }
        di = di + 1
    }
}

# fixupCustomTags -- bind deferred custom union tags: a `tag: X.tag` as-item
# whose data block resolved after the union (demand order) overrides the
# synthesized tag child once both exist.
fixupCustomTags: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
} is {
    pend: (List u64)
    pnames: (List String)
    with citer: ty.pendingCustomTag.iterateItems do for ce: citer loop {
        ck: ce.key
        pend.append ck
        cvv: ce.value.stringview
        cv: cvv.string
        pnames.append cv
    }
    ci: u64
    cn: pend.length
    for ci < cn loop {
        cuid: pend.get i: ci
        cnm: pnames.get i: ci
        co: walkLookupTyperef :ast :ty :reg currentUnit: mainName base: cnm.stringview
        ctid: optU64Or o: co d: 0
        if ctid > 0 then {
            if (reg.typetypeOf typeId: ctid) == ztypes.ztypetype.dataType then {
                cuidc: cuid
                ty.setChildId parentTypeId: cuidc nameId: wkTag childTypeId: ctid
            } else {
                cuidn: cuid
                cngo: ty.pendingCustomTagNode.get key: cuidn
                cnid9: optU64Or o: cngo d: 0
                if cnid9 > 0 then {
                    tgk2: "system.tag".string
                    tgo2: resolvedByKey :ast :ty :reg key: tgk2
                    match (
                        tgo2
                    ) case some then {
                        ty.nodeType.set key: cnid9 value: tgo2
                    } case none then null
                }
            }
        }
        ci = ci + 1
    }
}

# bodyEndsInReturn -- true when a function body's last statement is a
# bare `return ...` call (the syntactic divergence the clone-scope synthesis
# needs; no stamps are made).
bodyEndsInReturn: function {ast: Ast bodyId: u32} out bool is {
    if bodyId == 0 then return false
    return (blockEndsInReturn :ast block: (ast.nodes.get i: (bodyId - 1).u64))
}

blockEndsInReturn: function {ast: Ast block: Node} out bool is {
    match (
        block
    ) case statement then {
        ne: block.statements.length
        if ne > 0 then {
            lastId9: block.statements.get i: (ne - 1)
            last: ast.nodes.get i: (lastId9 - 1).u64
            match (
                last
            ) case statementline then {
                return (stmtExprIsReturn :ast op: (ast.nodes.get i: (last.statementline - 1).u64))
            } else {
                return false
            }
        } else {
            return false
        }
    } else {
        return false
    }
}

# stmtExprIsReturn -- an expression statement whose inner call's callable is
# the `return` builtin.
stmtExprIsReturn: function {ast: Ast op: Node} out bool is {
    match (
        op
    ) case expression then {
        return (exprCallIsReturn :ast op: (ast.nodes.get i: (op.expression - 1).u64))
    } else {
        return false
    }
}

exprCallIsReturn: function {ast: Ast op: Node} out bool is {
    match (
        op
    ) case call then {
        cn: atomName :ast n: (ast.nodes.get i: (op.callable - 1).u64)
        return cn.stringview == "return"
    } else {
        return false
    }
}

# isFunctionDefWithBody -- true when a node is a functiondef carrying a non-empty body
# (a real method, not a facet/protocol spec signature whose body is none).
isFunctionDefWithBody: function {o: Node} out bool is {
    match (
        o
    ) case functiondef then {
        return o.body > 0
    } else {
        return false
    }
}

# objectHasMethodBody -- true when an objectdef holds at least one is/as-item method
# with a body. Scans both blocks (transient iterators over different lists).
objectHasMethodBody: function {ast: Ast op: Node} out bool is {
    match (
        op
    ) case objectdef then {
        iiter: op.isItems.iterate
        for imId9: iiter loop {
            im: ast.nodes.get i: (imId9 - 1).u64
            match (
                im
            ) case namedoperation then {
                if (isFunctionDefWithBody o: (ast.nodes.get i: (im.operation - 1).u64)) then return true
            } else null
        }
        aiter: op.asItems.iterate
        for amId9: aiter loop {
            am: ast.nodes.get i: (amId9 - 1).u64
            match (
                am
            ) case namedoperation then {
                if (isFunctionDefWithBody o: (ast.nodes.get i: (am.operation - 1).u64)) then return true
            } else null
        }
        return false
    } else {
        return false
    }
}

# unitHasObjectMethodBody -- true when a unit body holds an objectdef with a method-body.
unitHasObjectMethodBody: function {ast: Ast defId: u32} out bool is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: defId
    biter: bodyIds9.iterate
    for bm: biter loop {
        bmNode9: ast.nodes.get i: (bm - 1).u64
        if bmNode9.namedoperation then {
            if (objectHasMethodBody
                :ast
                op: (ast.nodes.get i: (bmNode9.operation - 1).u64)
            ) then return true
        }
    }
    return false
}

# seedBodyWalkDemands -- the reference WALKS objectdef method bodies during
# resolve-only-main (records/classes/facets/protocols), and those bodies use the `return`
# builtin, so the closure pulls `return` + its `out never` type. The .z resolver does
# signatures only, so when the MAIN unit has any objectdef with a method-with-body,
# demand `return` + `never` to match.
# scanCallsInNode -- recursively record demands for the call targets in an
# expression/statement subtree (full-mode body-walk pre-pass): `return` pulls
# return+never, any other bare-atom callable (e.g. `print`) is demanded by name
# so the cross-unit pass resolves it before the walk runs.
scanCallsInNode: function {ast: Ast reg: ztypes.ZTypeRegistry node: Node} is {
    match (
        node
    ) case statement then {
        for stmId9: node.statements.iterate loop {
            scanCallsInNode :ast :reg node: (ast.nodes.get i: (stmId9 - 1).u64)
        }
    } case statementline then {
        scanCallsInNode :ast :reg node: (ast.nodes.get i: (node.statementline - 1).u64)
    } case expression then {
        scanCallsInNode :ast :reg node: (ast.nodes.get i: (node.expression - 1).u64)
    } case call then {
        cn: atomName :ast n: (ast.nodes.get i: (node.callable - 1).u64)
        if cn.stringview == "return" then {
            reg.recordDemand name: "return"
            reg.recordDemand name: "never"
        } else {
            # error/panic return never; the demand must land before the
            # system sweep passes never's definition.
            if cn.stringview == "error" then reg.recordDemand name: "never"
            if cn.stringview == "panic" then reg.recordDemand name: "never"
            if cn.length > 0 then reg.recordDemand name: cn.stringview
        }
        scanCallsInNode :ast :reg node: (ast.nodes.get i: (node.callable - 1).u64)
        for argId9: node.arguments.iterate loop {
            arg: ast.nodes.get i: (argId9 - 1).u64
            match (
                arg
            ) case namedoperation then {
                scanCallsInNode :ast :reg node: (ast.nodes.get i: (arg.operation - 1).u64)
            } else null
        }
    } case atomstring then {
        for spId9: node.stringparts.iterate loop {
            scanCallsInNode :ast :reg node: (ast.nodes.get i: (spId9 - 1).u64)
        }
    } case atomid then {
        # bare body identifiers demand main-unit definitions (unit constants,
        # data blocks); non-definition names never match a demanded def.
        scN9: ast.names.texts.get i: (node.name - 1).u64
        if (isNumericLiteralName name: scN9.stringview) == false then {
            reg.recordDemand name: scN9.stringview
        }
    } case binop then {
        scanCallsInNode :ast :reg node: (ast.nodes.get i: (node.lhs - 1).u64)
        scanCallsInNode :ast :reg node: (ast.nodes.get i: (node.rhs - 1).u64)
    } case assignment then {
        scanCallsInNode :ast :reg node: (ast.nodes.get i: (node.value - 1).u64)
    } case reassignment then {
        scanCallsInNode :ast :reg node: (ast.nodes.get i: (node.topath - 1).u64)
        scanCallsInNode :ast :reg node: (ast.nodes.get i: (node.value - 1).u64)
    } case ifexpr then {
        for clId9: node.clauses.iterate loop {
            scanCallsInNode :ast :reg node: (ast.nodes.get i: (clId9 - 1).u64)
        }
        scanBodyAt :ast :reg bodyId: node.elseclause
    } case forexpr then {
        reg.recordDemand name: "never"
        for fcId9: node.conditions.iterate loop {
            fc: ast.nodes.get i: (fcId9 - 1).u64
            match (
                fc
            ) case namedoperation then {
                scanCallsInNode :ast :reg node: (ast.nodes.get i: (fc.operation - 1).u64)
            } else null
        }
        scanBodyAt :ast :reg bodyId: node.body
        for fpId9: node.postconditions.iterate loop {
            fp: ast.nodes.get i: (fpId9 - 1).u64
            match (
                fp
            ) case namedoperation then {
                scanCallsInNode :ast :reg node: (ast.nodes.get i: (fp.operation - 1).u64)
            } else null
        }
    } case doexpr then {
        reg.recordDemand name: "never"
        if (blockHasBreak :ast n: (ast.nodes.get i: (node.statement - 1).u64)) then {
            reg.recordDemand name: "optionval"
        }
        scanCallsInNode :ast :reg node: (ast.nodes.get i: (node.statement - 1).u64)
    } case withexpr then {
        scanCallsInNode :ast :reg node: (ast.nodes.get i: (node.value - 1).u64)
        scanCallsInNode :ast :reg node: (ast.nodes.get i: (node.body - 1).u64)
    } case dottedpath then {
        bn: atomName :ast n: (ast.nodes.get i: (node.parent - 1).u64)
        if bn.length > 0 then {
            reg.recordDemand name: bn.stringview
            # a unit-qualified member (io.stdout) demands the member name
            # so the unit's demand walk resolves it
            isUnitQ: false
            if bn.stringview == "io" then isUnitQ = true
            if bn.stringview == "os" then isUnitQ = true
            if bn.stringview == "cli" then isUnitQ = true
            if (reg.isUnitName name: bn.stringview) then isUnitQ = true
            if isUnitQ then {
                mn0: atomName :ast n: (ast.nodes.get i: (node.child - 1).u64)
                if mn0.length > 0 then reg.recordDemand name: mn0.stringview
            }
        }
        scanCallsInNode :ast :reg node: (ast.nodes.get i: (node.parent - 1).u64)
    } case caseexpr then {
        scanCallsInNode :ast :reg node: (ast.nodes.get i: (node.subject - 1).u64)
        for clId9: node.clauses.iterate loop {
            scanCallsInNode :ast :reg node: (ast.nodes.get i: (clId9 - 1).u64)
        }
        scanBodyAt :ast :reg bodyId: node.elseclause
    } case caseclause then {
        scanCallsInNode :ast :reg node: (ast.nodes.get i: (node.statement - 1).u64)
    } case ifclause then {
        for cndId9: node.conditions.iterate loop {
            cnd: ast.nodes.get i: (cndId9 - 1).u64
            match (
                cnd
            ) case namedoperation then {
                scanCallsInNode :ast :reg node: (ast.nodes.get i: (cnd.operation - 1).u64)
            } else null
        }
        scanCallsInNode :ast :reg node: (ast.nodes.get i: (node.statement - 1).u64)
    } else null
}

# scanBodyAt -- scan a function body table id for call demands (0 = absent).
scanBodyAt: function {ast: Ast reg: ztypes.ZTypeRegistry bodyId: u32} is {
    if bodyId > 0 then scanCallsInNode :ast :reg node: (ast.nodes.get i: (bodyId - 1).u64)
}

# scanDefCalls -- scan a functiondef's body, or an objectdef's is/as method
# bodies, for call demands. A type constructed only inside a method body must be
# demanded here or it never resolves and the construction stamps type 0.
scanDefCalls: function {ast: Ast reg: ztypes.ZTypeRegistry op: Node} is {
    match (
        op
    ) case functiondef then {
        scanBodyAt :ast :reg bodyId: op.body
    } case objectdef then {
        iiter: op.isItems.iterate
        for imId9: iiter loop {
            im: ast.nodes.get i: (imId9 - 1).u64
            match (
                im
            ) case namedoperation then {
                if (isFunctionDefWithBody o: (ast.nodes.get i: (im.operation - 1).u64)) then (scanDefCalls
                    :ast
                    :reg
                    op: (ast.nodes.get i: (im.operation - 1).u64)
                )
            } else null
        }
        aiter: op.asItems.iterate
        for amId9: aiter loop {
            am: ast.nodes.get i: (amId9 - 1).u64
            match (
                am
            ) case namedoperation then {
                if (isFunctionDefWithBody o: (ast.nodes.get i: (am.operation - 1).u64)) then (scanDefCalls
                    :ast
                    :reg
                    op: (ast.nodes.get i: (am.operation - 1).u64)
                )
            } else null
        }
    } else null
}

# scanDemandedDepClassBodies -- a dependency unit's DEMANDED class methods are
# body-walked (depWalkUnit), so a type constructed only inside those methods
# (e.g. zvfs ProviderTable.registerNull -> NullProvider) must be demanded here
# or it never resolves and the construction stamps type 0. Mirrors scanDefCalls
# over the reached (isDemanded) non-generic objectdef members; the cross-unit
# demand fixpoint then resolves the newly-demanded types and depWalkUnit walks
# them. The isDemanded gate matches the reference's reached-only closure.
scanDemandedDepClassBodies: function {
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitdefId: u32
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: unitdefId
    for bmId9: bodyIds9.iterate loop {
        bm: ast.nodes.get i: (bmId9 - 1).u64
        if bm.namedoperation then {
            cn: zast.nameTextCopy :ast ref: bm.name
            if (reg.isDemanded name: cn.stringview) then {
                hasm: objectdefHasMethodBodies :ast op: (ast.nodes.get i: (bm.operation - 1).u64)
                if hasm when (objectdefIsGeneric
                    :ast
                    o: (ast.nodes.get i: (bm.operation - 1).u64)
                ) then hasm = false
                if hasm then scanDefCalls :ast :reg op: (ast.nodes.get i: (bm.operation - 1).u64)
            }
        }
    }
}


# scanMainBodyCalls -- record call-target demands for every function body in the
# main unit (the full-mode body walk reaches them; demand must precede the pass).
scanMainBodyCalls: function {reg: ztypes.ZTypeRegistry program: Node} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        uCnt9f: program.ast.units.length
        uIdx9f: u64
        for uIdx9f < uCnt9f loop {
            uId9: program.ast.units.get i: uIdx9f
            uIdx9f = uIdx9f + 1
            opId9: u32
            eager9: false
            {
                u: program.ast.nodes.get i: (uId9 - 1).u64
                if u.namedoperation then {
                    nm: zast.poolTextCopy pool: program.ast.names ref: u.name
                    eager9 = isFileUnit name: nm.stringview
                    if nm.stringview == mainName then eager9 = true
                    opId9 = u.operation
                }
            }
            if eager9 when opId9 > 0 then {
                (scanUnitCalls
                    :reg
                    ast: program.ast
                    unitdefId: opId9
                )
            }
        }
    } else null
}

# scanUnitCalls -- scan each function definition's body in a unit for call demands.
scanUnitCalls: function {reg: ztypes.ZTypeRegistry ast: Ast unitdefId: u32} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: unitdefId
    for bmId9: bodyIds9.iterate loop {
        bm: ast.nodes.get i: (bmId9 - 1).u64
        if bm.namedoperation then {
            scanDefCalls :ast :reg op: (ast.nodes.get i: (bm.operation - 1).u64)
        }
    }
}

seedBodyWalkDemands: function {reg: ztypes.ZTypeRegistry program: Node} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        found: false
        uiter: program.ast.units.iterate
        for uId9: uiter loop {
            u: program.ast.nodes.get i: (uId9 - 1).u64
            match (
                u
            ) case namedoperation then {
                nm: zast.poolTextCopy pool: program.ast.names ref: u.name
                if nm.stringview == mainName then {
                    if (unitHasObjectMethodBody
                        ast: program.ast
                        defId: u.operation
                    ) then found = true
                }
            } else null
        }
        if found then {
            reg.recordDemand name: "return"
            reg.recordDemand name: "never"
        }
    } else null
}

# onFirstEntry -- run a stdlib / dependency unit's one-time demand machinery the
# first time the descent worklist resolves a def in it: seed io's internal
# closure (under the full body-walk driver), resolve the conformance declarers
# reference-following cannot reach (io / collections / system), and prime a user
# dependency unit's return / never demands plus its class-body call scan.
onFirstEntry: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    mainName: StringView
    unitdefId: u32
    full: bool
    entered: Set String
} is {
    if (entered.has item: unitName.string) then return
    entered.add item: unitName.string
    if unitName == "io" then {
        if full then seedIoDemands :reg
        resolveConformanceDefs :ty :reg :ast unitName: "io" :unitdefId
        return
    }
    if unitName == "collections" then {
        resolveConformanceDefs :ty :reg :ast unitName: "collections" :unitdefId
        return
    }
    if unitName == "system" then {
        resolveConformanceDefs :ty :reg :ast unitName: "system" :unitdefId
        return
    }
    if unitName == "os" then return
    if unitName == "cli" then return
    if unitName == mainName then return
    reg.recordDemand name: "return"
    reg.recordDemand name: "never"
    scanDemandedDepClassBodies :reg :ast :unitdefId
}

# resolveDemandsByDescent -- the descent-era demand worklist. Seeds the body-walk
# demands, then body-drains the main unit (full mode) and every dependency unit
# except core to a joint fixpoint; each resolved def's own references descend
# inline (resolveAtomType -> descendNamed), so per-unit body order only decides
# trigger order, not dependency order. The tail resolves core's bool
# re-exports explicitly (descent skips core).
resolveDemandsByDescent: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    program: Node
    full: bool
} is {
    seedBodyWalkDemands :reg :program
    if (reg.isDemanded name: "print") then {
        reg.recordDemand name: "StringLike"
        reg.recordDemand name: "str"
        reg.recordDemand name: "List"
    }
    entered9: (Set String)
    mnOwn9: reg.regMainUnit.copy
    mainName9: mnOwn9.stringview
    match (
        program
    ) case program then {
        if full then {
            mdN9: program.ast.units.length
            mdI9: u64
            for mdI9 < mdN9 loop {
                mu9Id9: program.ast.units.get i: mdI9
                mdI9 = mdI9 + 1
                mOpId9: u32
                {
                    mu9: program.ast.nodes.get i: (mu9Id9 - 1).u64
                    if mu9.namedoperation then {
                        mnm9: zast.poolTextCopy pool: program.ast.names ref: mu9.name
                        if mnm9.stringview == mainName9 then mOpId9 = mu9.operation
                    }
                }
                if mOpId9 > 0 then {
                    againM9: true
                    for againM9 loop {
                        beforeM9: reg.nextTypeId
                        (resolveDemandedUnitBody
                            :ty
                            :reg
                            ast: program.ast
                            unitName: mainName9
                            shadowUnit: ""
                            unitdefId: mOpId9
                        )
                        if reg.nextTypeId == beforeM9 then againM9 = false
                    }
                }
            }
        }
        againU9: true
        for againU9 loop {
            beforeU9: reg.nextTypeId
            seedSystemDemands :reg
            seedIteratorDemands :reg
            udN9: program.ast.units.length
            udI9: u64
            for udI9 < udN9 loop {
                u9Id9: program.ast.units.get i: udI9
                udI9 = udI9 + 1
                uOpId9: u32
                un9: String
                {
                    u9: program.ast.nodes.get i: (u9Id9 - 1).u64
                    if u9.namedoperation then {
                        un0: zast.poolTextCopy pool: program.ast.names ref: u9.name
                        isDep0: true
                        if un0.stringview == mainName9 then isDep0 = false
                        if un0.stringview == "core" then isDep0 = false
                        if isDep0 then {
                            uOpId9 = u9.operation
                            un9 = un0.copy
                        }
                    }
                }
                if uOpId9 > 0 then {
                    anyDem9: (resolveDemandedUnitBody
                        :ty
                        :reg
                        ast: program.ast
                        unitName: un9.stringview
                        shadowUnit: mainName9
                        unitdefId: uOpId9
                    )
                    if anyDem9 then {
                        (onFirstEntry
                            :ty
                            :reg
                            ast: program.ast
                            unitName: un9.stringview
                            mainName: mainName9
                            unitdefId: uOpId9
                            :full
                            entered: entered9
                        )
                    }
                }
            }
            if reg.nextTypeId == beforeU9 then againU9 = false
        }
    } else null
}

# callableUnitName -- the callable's name when a binding value is a (possibly
# expression-wrapped) call, else "". Spots a generic-unit instantiation binding
# (intmath: (genmath t: i64)).
callableUnitName: function {ast: Ast op: Node} out String is {
    match (
        op
    ) case expression then {
        return (callableUnitName :ast op: (ast.nodes.get i: (op.expression - 1).u64))
    } case call then {
        return (atomName :ast n: (ast.nodes.get i: (op.callable - 1).u64))
    } else {
        return "".string
    }
}

# firstArgTypeName -- the type-name of a call's first argument (the instantiation type
# argument, e.g. i64 in (genmath t: i64)), else "".
firstArgTypeName: function {ast: Ast op: Node} out String is {
    match (
        op
    ) case expression then {
        return (firstArgTypeName :ast op: (ast.nodes.get i: (op.expression - 1).u64))
    } case call then {
        aiter: op.arguments.iterate
        for argId9: aiter loop {
            arg: ast.nodes.get i: (argId9 - 1).u64
            match (
                arg
            ) case namedoperation then {
                return (atomName :ast n: (ast.nodes.get i: (arg.operation - 1).u64))
            } else null
        }
        return "".string
    } else {
        return "".string
    }
}

# collectMainInstantiations -- scan a unit body for generic-unit instantiation bindings
# and append the mono name ({template}_{arg}) + template name to the parallel lists.
# InstReq -- one generic-unit instantiation binding (intmath: (mathops t: i64)):
# the names the mint needs plus the binding's node ids for full-mode stamps.
InstReq: class {
    bind: String
    mono: String
    tmpl: String
    argn: String
    exprId: u64
    callId: u64
    calId: u64
    argAtomId: u64
}

# instFillIds -- record the instantiation's expression/call/callable/arg node
# ids on the request (the reference stamps all four at binding resolution).
instFillIds: function {ast: Ast r: InstReq op: Node} is {
    match (
        op
    ) case expression then {
        r.exprId = op.nodeid.u64
        instFillIds :ast :r op: (ast.nodes.get i: (op.expression - 1).u64)
    } case call then {
        r.callId = op.nodeid.u64
        instFillCallable :r op: (ast.nodes.get i: (op.callable - 1).u64)
        aiter: op.arguments.iterate
        for a9Id9: aiter loop {
            a9: ast.nodes.get i: (a9Id9 - 1).u64
            match (
                a9
            ) case namedoperation then {
                if r.argAtomId == 0 then (instFillArg
                    :ast
                    :r
                    op: (ast.nodes.get i: (a9.operation - 1).u64)
                )
            } else null
        }
    } else null
}

instFillCallable: function {r: InstReq op: Node} is {
    match (
        op
    ) case atomid then {
        r.calId = op.nodeid.u64
    } else null
}

instFillArg: function {ast: Ast r: InstReq op: Node} is {
    match (
        op
    ) case expression then {
        instFillArg :ast :r op: (ast.nodes.get i: (op.expression - 1).u64)
    } case atomid then {
        r.argAtomId = op.nodeid.u64
    } else null
}

collectMainInstantiations: function {ast: Ast o: Node reqs: List InstReq} is {
    match (
        o
    ) case unitdef then {
        biter: o.body.iterate
        for bm: biter loop {
            bmNode9: ast.nodes.get i: (bm - 1).u64
            match (
                bmNode9
            ) case namedoperation then {
                tn: callableUnitName :ast op: (ast.nodes.get i: (bmNode9.operation - 1).u64)
                if tn.length != 0 then {
                    at: firstArgTypeName :ast op: (ast.nodes.get i: (bmNode9.operation - 1).u64)
                    bindn: zast.nameTextCopy :ast ref: bmNode9.name
                    mono: "\{tn}_\{at}"
                    r9: (InstReq
                        bind: bindn
                        :mono
                        tmpl: tn
                        argn: at
                        exprId: 0
                        callId: 0
                        calId: 0
                        argAtomId: 0
                    )
                    instFillIds :ast r: r9 op: (ast.nodes.get i: (bmNode9.operation - 1).u64)
                    reqs.append r9
                }
            } else null
        }
    } else null
}

# scanMainForInstantiations -- find the main unit and collect its instantiation requests.
# Its own function scope bounds the program.ast.units iterator so it releases before the
# mono-creation pass (which iterates program.ast.units again).
scanMainForInstantiations: function {program: Node reqs: List InstReq} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        uiter: program.ast.units.iterate
        for uId9: uiter loop {
            u: program.ast.nodes.get i: (uId9 - 1).u64
            match (
                u
            ) case namedoperation then {
                un: zast.poolTextCopy pool: program.ast.names ref: u.name
                if un.stringview == mainName then (collectMainInstantiations
                    ast: program.ast
                    o: (program.ast.nodes.get i: (u.operation - 1).u64)
                    :reqs
                )
            } else null
        }
    } else null
}

# attachMonoUnitFuncs -- add a JOIN-only `{mono}.{fn}` FUNCTION shell child per function
# in the template unit's body. The mono function rows are defined_in_unit=NULL (excluded
# from the filtered dump), so no params are resolved -- only the names matter for the JOIN.
attachMonoUnitFuncs: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    monoId: u64
    monoName: StringView
    templateOpId: u32
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: templateOpId
    {
        fiter: bodyIds9.iterate
        for fm: fiter loop {
            fmNode9: ast.nodes.get i: (fm - 1).u64
            match (
                fmNode9
            ) case namedoperation then {
                if (isFunctionDefOp op: (ast.nodes.get i: (fmNode9.operation - 1).u64)) then {
                    fn: zast.nameTextCopy :ast ref: fmNode9.name
                    shellName: "\{monoName}.\{fn}"
                    shellId: (reg.newType
                        name: shellName.stringview
                        typetype: ztypes.ztypetype.functionType
                    )
                    (ty.setChildId
                        parentTypeId: monoId
                        nameId: fmNode9.name.u64
                        childTypeId: shellId
                    )
                }
            } else null
        }
    }
}

# resolveUnitMono -- create a mono UNIT (mangled name, defined_in_unit=the instantiating
# unit) with JOIN-only function-shell children from the template's body, then seed
# return/never demand (the template functions have bodies). Skips when already resolved
# or the template unit is not found.
# isIteratorCall -- true when a type-expr is a call to `Iterator` (a generator's
# `out (Iterator gives: T)` return), peeling an expression wrapper.
isIteratorCall: function {ast: Ast op: Node} out bool is {
    match (
        op
    ) case expression then {
        return (isIteratorCall :ast op: (ast.nodes.get i: (op.expression - 1).u64))
    } case call then {
        cn: atomName :ast n: (ast.nodes.get i: (op.callable - 1).u64)
        return (cn.stringview == "Iterator")
    } else {
        return false
    }
}

# isGeneratorReturn -- true when a function's return type is the Iterator protocol
# (i.e. the function is a generator that lowers to a synth iterator class).
isGeneratorReturn: function {ast: Ast oId: u32} out bool is {
    if oId == 0 then return false
    o: ast.nodes.get i: (oId - 1).u64
    return (isIteratorCall :ast op: o)

}

# subtreeHasYield -- true if a node subtree contains a yield expression.
subtreeHasYield: function {ast: Ast node: Node} out bool is {
    match (
        node
    ) case yieldexpr then {
        return true
    } case statement then {
        siter: node.statements.iterate
        for stId9: siter loop {
            if (subtreeHasYield :ast node: (ast.nodes.get i: (stId9 - 1).u64)) then return true
        }
        return false
    } case statementline then {
        sln9: ast.nodes.get i: (node.statementline - 1).u64
        return (subtreeHasYield :ast node: sln9)
    } case expression then {
        return (subtreeHasYield :ast node: (ast.nodes.get i: (node.expression - 1).u64))
    } case forexpr then {
        if node.body == 0 then return false
        return (subtreeHasYield :ast node: (ast.nodes.get i: (node.body - 1).u64))
    } case ifexpr then {
        cliter: node.clauses.iterate
        for clId9: cliter loop {
            if (subtreeHasYield :ast node: (ast.nodes.get i: (clId9 - 1).u64)) then return true
        }
        if node.elseclause == 0 then return false
        return (subtreeHasYield :ast node: (ast.nodes.get i: (node.elseclause - 1).u64))
    } case ifclause then {
        return (subtreeHasYield :ast node: (ast.nodes.get i: (node.statement - 1).u64))
    } else {
        return false
    }
}

# nodeIsYieldingLoop -- true when a statement (peeling statementline/expression) is a
# for-loop whose body contains a yield.
nodeIsYieldingLoop: function {ast: Ast node: Node} out bool is {
    match (
        node
    ) case statementline then {
        sln29: ast.nodes.get i: (node.statementline - 1).u64
        return (nodeIsYieldingLoop :ast node: sln29)
    } case expression then {
        return (nodeIsYieldingLoop :ast node: (ast.nodes.get i: (node.expression - 1).u64))
    } case forexpr then {
        if node.body == 0 then return false
        return (subtreeHasYield :ast node: (ast.nodes.get i: (node.body - 1).u64))
    } else {
        return false
    }
}

# bodyHasYieldingLoop -- true when a function body (a table id, 0 = absent) contains a
# yielding loop. Generators with one promote their straight-line locals to fields.
bodyHasYieldingLoop: function {ast: Ast bodyId: u32} out bool is {
    if bodyId == 0 then return false
    return (blockHasYieldingLoop :ast blk: (ast.nodes.get i: (bodyId - 1).u64))
}
blockHasYieldingLoop: function {ast: Ast blk: Node} out bool is {
    match (
        blk
    ) case statement then {
        siter: blk.statements.iterate
        for stId9: siter loop {
            if (nodeIsYieldingLoop :ast node: (ast.nodes.get i: (stId9 - 1).u64)) then return true
        }
        return false
    } else {
        return false
    }
}

# assignmentLocalName -- the local name a statement-line binds via `name: value`, or "".
assignmentLocalName: function {ast: Ast line: Node} out String is {
    match (
        line
    ) case statementline then {
        return (assignmentInnerName s: (ast.nodes.get i: (line.statementline - 1).u64))
    } else {
        return "".string
    }
}
assignmentInnerName: function {s: Node} out String is {
    match (
        s
    ) case assignment then {
        return s.name.copy
    } else {
        return "".string
    }
}

# addPromotedLocals -- add a field (i64) per top-level local binding in a generator body
# (the loop-carried counters promoted to iter-class fields).
addPromotedLocals: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    iterId: u64
    bodyId: u32
} is {
    if bodyId > 0 then {
        addPromotedLocalsBlk :ty :reg :ast :iterId blk: (ast.nodes.get i: (bodyId - 1).u64)
    }
}
addPromotedLocalsBlk: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    iterId: u64
    blk: Node
} is {
    match (
        blk
    ) case statement then {
        siter: blk.statements.iterate
        for stId9: siter loop {
            nm: assignmentLocalName :ast line: (ast.nodes.get i: (stId9 - 1).u64)
            if nm.length != 0 then {
                lf: resolveAtomType :ty :reg :ast unitName: "" nm: "i64" thisName: ""
                (ty.setChildId
                    parentTypeId: iterId
                    nameId: (zast.poolFind pool: ast.names text: nm.stringview).u64
                    childTypeId: lf
                )
            }
        }
    } else null
}

# synthGeneratorIterClass -- synthesize the `<fn>_iter` CLASS the oracle lowers a
# generator to: a `state: i64` field, a `create` method (param `state: i64`), and a
# `call` method (receiver `this`, BORROW). All defined_in_unit=the example; seed
# return/never demand (the lowered methods have bodies). No-param / no-promoted-local
# generators only (counter); captured params + promoted locals arrive later.
# addResumeInput -- for a bidirectional generator (`accepts: U` in the Iterator
# return), add the `_resume_input: U` field to the iter class and a `value: U` param
# (with the annotated ownership) to its `call` method.
addResumeInput: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    iterId: u64
    callId: u64
    returntypeId: u32
} is {
    if returntypeId == 0 then return
    returntype: ast.nodes.get i: (returntypeId - 1).u64
    addResumeInputExpr :ty :reg :ast :iterId :callId rt: returntype

}
addResumeInputExpr: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    iterId: u64
    callId: u64
    rt: Node
} is {
    match (
        rt
    ) case expression then {
        rtx9: ast.nodes.get i: (rt.expression - 1).u64
        addResumeInputExpr :ty :reg :ast :iterId :callId rt: rtx9
    } case call then {
        aiter: rt.arguments.iterate
        for argId9: aiter loop {
            arg: ast.nodes.get i: (argId9 - 1).u64
            match (
                arg
            ) case namedoperation then {
                an: zast.nameTextCopy :ast ref: arg.name
                if an.stringview == "accepts" then {
                    tn: baseTypeName :ast n: (ast.nodes.get i: (arg.operation - 1).u64)
                    rf: (resolveAtomType
                        :ty
                        :reg
                        :ast
                        unitName: ""
                        nm: tn.stringview
                        thisName: ""
                    )
                    (ty.setChildId
                        parentTypeId: iterId
                        nameId: wkResumeInput
                        childTypeId: rf
                    )
                    vf: (resolveAtomType
                        :ty
                        :reg
                        :ast
                        unitName: ""
                        nm: tn.stringview
                        thisName: ""
                    )
                    (ty.setChildId
                        parentTypeId: callId
                        nameId: wkValue
                        childTypeId: vf
                    )
                    own: pathOwnership :ast n: (ast.nodes.get i: (arg.operation - 1).u64)
                    match (
                        own
                    ) case some then {
                        ty.setChildOwnershipId parentTypeId: callId nameId: wkValue ownership: own
                    } case none then null
                }
            } else null
        }
    } else null
}

# condIterableCallable -- the callable name of a for-loop's inline iterable (a
# `binding: (gen ...)` condition), or "". A `while` condition (no binding) yields "".
condIterableCallable: function {ast: Ast conds: List u32} out String is {
    citer: conds.iterate
    for cId9: citer loop {
        c: ast.nodes.get i: (cId9 - 1).u64
        match (
            c
        ) case namedoperation then {
            cb: callableUnitName :ast op: (ast.nodes.get i: (c.operation - 1).u64)
            if cb.length != 0 then return cb
        } else null
    }
    return "".string
}

# forIterableCallable -- for a yielding for-loop whose iterable is a generator call,
# the callable name; "" otherwise (peels statementline/expression).
forIterableCallable: function {ast: Ast e: Node} out String is {
    match (
        e
    ) case statementline then {
        sln9: ast.nodes.get i: (e.statementline - 1).u64
        return (forIterableCallable :ast e: sln9)
    } case expression then {
        return (forIterableCallable :ast e: (ast.nodes.get i: (e.expression - 1).u64))
    } case forexpr then {
        hy9: false
        if e.body > 0 then {
            eb9: ast.nodes.get i: (e.body - 1).u64
            hy9 = subtreeHasYield :ast node: eb9
        }
        if hy9 then {
            return (condIterableCallable :ast conds: e.conditions)
        } else {
            return "".string
        }
    } else {
        return "".string
    }
}

# addInlineIterFields -- add an `_iterN: <callable>_iter` field per yielding for-loop
# whose iterable is an inline generator call (chain/map_filter's nested pipeline). The
# field is typed by the nested generator's iter class; no create param (that lives on
# the excluded NULL-unit create).
addInlineIterFields: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    iterId: u64
    bodyId: u32
} is {
    if bodyId > 0 then {
        addInlineIterFieldsBlk :ty :reg :ast :iterId blk: (ast.nodes.get i: (bodyId - 1).u64)
    }
}
addInlineIterFieldsBlk: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    iterId: u64
    blk: Node
} is {
    match (
        blk
    ) case statement then {
        n: u64
        siter: blk.statements.iterate
        for stId9: siter loop {
            cb: forIterableCallable :ast e: (ast.nodes.get i: (stId9 - 1).u64)
            if cb.length != 0 then {
                fieldName: "_iter\{n}"
                fieldType: "\{cb.stringview}_iter"
                ft: (resolveAtomType
                    :ty
                    :reg
                    :ast
                    unitName: ""
                    nm: fieldType.stringview
                    thisName: ""
                )
                (ty.setChildId
                    parentTypeId: iterId
                    nameId: (ast.internString text: fieldName.stringview).u64
                    childTypeId: ft
                )
                n = n + 1
            }
        }
    } else null
}

# synthGeneratorForMethod -- synthesize the iter class for a generator METHOD (an
# as-block method whose return is the Iterator protocol). thisName is the enclosing
# type, so a `this`-typed captured param (b: this.private.lock) resolves to it.
synthGeneratorForMethod: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    fnName: StringView
    thisName: StringView
    op: Node
} is {
    match (
        op
    ) case functiondef then {
        if (isGeneratorReturn :ast oId: op.returntype) then {
            synthGeneratorIterClass :ty :reg :ast :unitName :fnName :thisName fnode: op
        }
    } else null
}

synthGeneratorIterClass: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    fnName: StringView
    thisName: StringView
    fnode: zast.FunctionData
} is {
    iterName: "\{fnName}_iter"
    iterId: reg.newType name: iterName.stringview typetype: ztypes.ztypetype.classType
    iid: iterId
    reg.setValtype typeId: iterId value: false
    ty.definedInUnit.set key: iid value: unitName.string
    needsDtor: false
    st1: resolveAtomType :ty :reg :ast :unitName nm: "i64" thisName: ""
    ty.setChildId parentTypeId: iterId nameId: wkState childTypeId: st1
    createName: "\{iterName}.create"
    createId: reg.newType name: createName.stringview typetype: ztypes.ztypetype.functionType
    cdid: createId
    ty.definedInUnit.set key: cdid value: unitName.string
    callName: "\{iterName}.call"
    callId: reg.newType name: callName.stringview typetype: ztypes.ztypetype.functionType
    clid: callId
    ty.definedInUnit.set key: clid value: unitName.string
    ty.setChildId parentTypeId: callId nameId: wkThisMember childTypeId: iterId
    (ty.setChildOwnershipId
        parentTypeId: callId
        nameId: wkThis.u64
        ownership: ztypes.zparamownership.borrowMode
    )
    piter: fnode.parameters.iterate
    for pmId9: piter loop {
        pm: ast.nodes.get i: (pmId9 - 1).u64
        match (
            pm
        ) case namedoperation then {
            pn: zast.nameTextCopy :ast ref: pm.name
            ptn: baseTypeName :ast n: (ast.nodes.get i: (pm.operation - 1).u64)
            f1: resolveAtomType :ty :reg :ast :unitName nm: ptn.stringview :thisName
            (ty.setChildId
                parentTypeId: iterId
                nameId: pm.name.u64
                childTypeId: f1
            )
            f2: resolveAtomType :ty :reg :ast :unitName nm: ptn.stringview :thisName
            (ty.setChildId
                parentTypeId: createId
                nameId: pm.name.u64
                childTypeId: f2
            )
            pown: pathOwnership :ast n: (ast.nodes.get i: (pm.operation - 1).u64)
            match (
                pown
            ) case some then {
                (ty.setChildOwnership
                    pool: ast.names
                    parentTypeId: createId
                    name: pn.stringview
                    ownership: pown
                )
                needsDtor = true
            } case none then null
        } else null
    }
    (addResumeInput
        :ty
        :reg
        :ast
        :iterId
        :callId
        returntypeId: fnode.returntype
    )
    if (bodyHasYieldingLoop :ast bodyId: fnode.body) then {
        addPromotedLocals :ty :reg :ast :iterId bodyId: fnode.body
    }
    addInlineIterFields :ty :reg :ast :iterId bodyId: fnode.body
    ty.setChildId parentTypeId: iterId nameId: wkCreate childTypeId: createId
    ty.setChildId parentTypeId: iterId nameId: wkCall childTypeId: callId
    if needsDtor then {
        dn: "\{iterName}_destroy"
        reg.setDestructorName typeId: iterId name: dn.stringview
    }
    reg.recordDemand name: "return"
    reg.recordDemand name: "never"
}

# isUnitOp -- true when a binding's operation is an inline `unit as {...}` definition.
isUnitOp: function {op: Node} out bool is {
    match (
        op
    ) case unitdef then {
        return true
    } else {
        return false
    }
}

# resolveInlineGenericUnit -- resolve an inline generic unit (mathops: unit as { t:
# Any.generic; add; double }) into a UNIT type (is_generic) whose functions are mangled
# {unit}_{fn} FUNCTION children (with their generic-param types KEPT -- unlike a generic
# FILE unit, an inline template's params are not suppressed).
resolveInlineGenericUnit: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    defName: StringView
    unitOpId: u32
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: unitOpId
    {
        uid: reg.newType name: defName typetype: ztypes.ztypetype.unitType
        did: uid
        rid: uid
        if (hasGenericParam :ast items: bodyIds9) then {
            reg.setGeneric typeId: uid value: true
            if ty.fullMainUnit.length > 0 then {
                # full mode mirrors the reference's inline-template touch:
                # the unit node and each bare generic-param def stamp, and
                # the param name resolves so signature t-refs stamp.
                udnid: unitdefNodeId :ast nId: unitOpId
                uidv: uid
                ty.nodeType.set key: udnid.u64 value: uidv
                with gpiter: bodyIds9.iterate do for gmId9: gpiter loop {
                    gm: ast.nodes.get i: (gmId9 - 1).u64
                    match (
                        gm
                    ) case namedoperation then {
                        if (isBareGenericParam
                            :ast
                            op: (ast.nodes.get i: (gm.operation - 1).u64)
                        ) then {
                            gpn5: zast.nameTextCopy :ast ref: gm.name
                            ik5: "\{unitName}.\{defName}"
                            gtid5: u64
                            gpo5: (reg.genericParamTidOf
                                typeKey: ik5.stringview
                                paramName: gpn5.stringview
                            )
                            match (
                                gpo5
                            ) case some then {
                                gtid5 = gpo5
                            } case none then {
                                gtid5 = (reg.newType
                                    name: gpn5.stringview
                                    typetype: ztypes.ztypetype.genericParam
                                )
                                (reg.setGenericParamTid
                                    typeKey: ik5.stringview
                                    paramName: gpn5.stringview
                                    tid: gtid5
                                )
                            }
                            gpnid: nodeId n: (ast.nodes.get i: (gm.operation - 1).u64)
                            gtidV5: gtid5
                            ty.nodeType.set key: gpnid.u64 value: gtidV5
                        }
                    } else null
                }
            }
        }
        ty.definedInUnit.set key: did value: unitName.string
        # A non-generic inline unit is a real type; lay its unit->def childOf edge
        # (a generic template must NOT get one -- its id is the pre-instantiation
        # template, which would shadow instance lookups).
        if (hasGenericParam :ast items: bodyIds9) == false then {
            icu0: reg.unitNameTid.get key: unitName.string
            match (
                icu0
            ) case some then {
                (ty.setChildId
                    parentTypeId: icu0
                    nameId: (zast.poolFind pool: ast.names text: defName).u64
                    childTypeId: rid
                )
            } case none then null
        }
        biter: bodyIds9.iterate
        for bm: biter loop {
            bmNode9: ast.nodes.get i: (bm - 1).u64
            match (
                bmNode9
            ) case namedoperation then {
                fn: zast.nameTextCopy :ast ref: bmNode9.name
                qn: "\{defName}_\{fn}"
                mido: (resolveMethodFn
                    :ty
                    :reg
                    :ast
                    :unitName
                    qname: qn.stringview
                    thisName: ""
                    op: (ast.nodes.get i: (bmNode9.operation - 1).u64)
                )
                match (
                    mido
                ) case some then {
                    (ty.setChildId
                        parentTypeId: uid
                        nameId: bmNode9.name.u64
                        childTypeId: mido
                    )
                } case none then null
            } else null
        }
    }
}

# createUnitMono -- create a mono UNIT (defined_in_unit=the instantiating unit) with
# JOIN-only function-shell children from a template unit body, then seed return/never
# demand. Dedups on the mono's resolved key.
createUnitMono: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    monoName: StringView
    templateName: StringView
    templateOpId: u32
} is {
    rkey: "\{unitName}.\{monoName}"
    got: resolvedByKey :ast :ty :reg key: rkey
    exists: false
    match (
        got
    ) case some then {
        exists = true
    } case none then null
    if (exists) == false then {
        monoId: reg.newType name: monoName typetype: ztypes.ztypetype.unitType
        did: monoId
        rid: monoId
        ty.definedInUnit.set key: did value: unitName.string
        iur: monoId
        reg.setUnitName name: monoName uid: iur
        ccu2: reg.unitNameTid.get key: unitName.string
        match (
            ccu2
        ) case some then {
            (ty.setChildId
                parentTypeId: ccu2
                nameId: (ast.internString text: monoName).u64
                childTypeId: rid
            )
        } case none then null
        # link the mono to its template (inline templates register under
        # the main unit; file templates carry the per-unit UNIT type).
        tplKey: "\{unitName}.\{templateName}"
        tplGot: resolvedByKey :ast :ty :reg key: tplKey
        match (
            tplGot
        ) case some then {
            reg.setGenericOrigin typeId: monoId value: tplGot
        } case none then {
            tplK2: templateName.string
            utGot: reg.unitNameTid.get key: tplK2
            match (
                utGot
            ) case some then {
                reg.setGenericOrigin typeId: monoId value: utGot
            } case none then {
                # inline generic template: no childOf edge and not a unit
                # root -- its id lives only in the full-mode def-node stamp
                # laid by resolveInlineGenericUnit.
                itnid: unitdefNodeId :ast nId: templateOpId
                itso: ty.nodeType.get key: itnid.u64
                match (
                    itso
                ) case some then {
                    reg.setGenericOrigin typeId: monoId value: itso
                } case none then null
            }
        }
        attachMonoUnitFuncs :ty :reg :ast :monoId :monoName :templateOpId
        reg.recordDemand name: "return"
        reg.recordDemand name: "never"
    }
}

# resolveInlineMono -- create the mono for an INLINE template: scan the main unit body
# for the inline `unit as {...}` binding named templateName and build the mono from it.
resolveInlineMono: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    monoName: StringView
    templateName: StringView
    mainOpId: u32
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: mainOpId
    {
        biter: bodyIds9.iterate
        for bm: biter loop {
            bmNode9: ast.nodes.get i: (bm - 1).u64
            match (
                bmNode9
            ) case namedoperation then {
                bn: zast.nameTextCopy :ast ref: bmNode9.name
                if bn.stringview == templateName then {
                    if (isUnitOp op: (ast.nodes.get i: (bmNode9.operation - 1).u64)) then {
                        (createUnitMono
                            :ty
                            :ast
                            :reg
                            :unitName
                            :monoName
                            :templateName
                            templateOpId: bmNode9.operation
                        )
                    }
                }
            } else null
        }
    }
}

# resolveUnitMono -- create the mono UNIT for a generic-unit instantiation. The template
# is either a FILE unit (in program.ast.units) or an INLINE unit in the main body
# (unitName == the main unit name for these instantiations).
resolveUnitMono: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    program: Node
    unitName: StringView
    monoName: StringView
    templateName: StringView
} is {
    match (
        program
    ) case program then {
        uiter: program.ast.units.iterate
        for uId9: uiter loop {
            u: program.ast.nodes.get i: (uId9 - 1).u64
            match (
                u
            ) case namedoperation then {
                un: zast.poolTextCopy pool: program.ast.names ref: u.name
                if un.stringview == templateName then {
                    (createUnitMono
                        :ty
                        ast: program.ast
                        :reg
                        :unitName
                        :monoName
                        :templateName
                        templateOpId: u.operation
                    )
                }
                if un.stringview == unitName then {
                    (resolveInlineMono
                        :ty
                        :reg
                        ast: program.ast
                        :unitName
                        :monoName
                        :templateName
                        mainOpId: u.operation
                    )
                }
            } else null
        }
    } else null
}

# typeNameOfReg -- typeNameOf without a symbol table (registry-only callers).
typeNameOfReg: function {reg: ztypes.ZTypeRegistry tid: u64} out String is {
    t: reg.typeById.get key: tid
    match (
        t
    ) case some then {
        return t.name.copy
    } case none then {
        return "".string
    }
}

# fnReturnBaseName -- the base type name of a function's return typeref
# ("" when absent), for completing substituted signatures whose template
# return was still unresolved at signature time.
fnReturnBaseName: function {ast: Ast oId: u32} out String is {
    if oId == 0 then return "".string
    o: ast.nodes.get i: (oId - 1).u64
    return (baseTypeName :ast n: o)

}

fnReturnBaseNameOf: function {ast: Ast op: Node} out String is {
    match (
        op
    ) case functiondef then {
        return (fnReturnBaseName :ast oId: op.returntype)
    } else {
        return "".string
    }
}

# cloneUnitMethod -- deep-clone a template method functiondef with fresh synth
# nodeids. The clone's rows never become reachable from the program roots, so
# its body's stamps stay out of the dump; only its walk's scope/entry/variable
# rows are visible.
cloneUnitMethod: function {ast: Ast ids: zgenerator.GenIds op: Node} out Option Node is {
    match (
        op
    ) case functiondef then {
        pm9: (Map String value: bool)
        params9: (List u32)
        with piter: op.parameters.iterate do for ppId9: piter loop {
            pp: ast.nodes.get i: (ppId9 - 1).u64
            pc: zgenerator.clonePath :ast :ids n: pp
            params9.append (zast.tableAppendRebase :ast n: pc)
        }
        rt9: (zgenerator.rewriteOptToThisAt
            :ast
            :ids
            oId: op.returntype
            promoted: pm9
        )
        body9: zgenerator.rewriteOptToThisAt :ast :ids oId: op.body promoted: pm9
        ln9: op.lineno
        cn9: op.colno
        fnew: (Node.functiondef (zast.FunctionData
            nodeid: ids.mint
            lineno: ln9
            colno: cn9
            returntype: rt9
            parameters: params9
            body: body9
            isNative: false
            asItems: (List u32))
        )
        return (Option.some fnew)
    } else {
        return (Option.none Node)
    }
}

# buildUnitMonoFull -- full-mode unit-mono completion: substituted method
# children ({mono}.{fn} FUNCTION types whose generic-param-named child types
# and return are replaced by the instantiation arg) plus a cloned body per
# method, stashed for the lazy first-use walk. One build per mono.
# registerMonoFnParams -- register a mono unit fn's generic-param-typed params
# (a: t -> a: argId) on the mono FUNCTION type, sourced from the template fn's
# AST. The template fn stays childless -- only the instance carries substituted
# param children, matching the reference (which carries them via the clone).
registerMonoFnParams: function {
    ast: Ast
    ty: ztyping.ZTyping
    op: Node
    fnId: u64
    gpNames: (Map String value: bool)
    argId: u64
} is {
    match (
        op
    ) case functiondef then {
        ppiter: op.parameters.iterate
        for ppmId9: ppiter loop {
            ppm: ast.nodes.get i: (ppmId9 - 1).u64
            match (
                ppm
            ) case namedoperation then {
                pptn: atomName :ast n: (ast.nodes.get i: (ppm.operation - 1).u64)
                ppgo: gpNames.get key: pptn
                match (
                    ppgo
                ) case some then {
                    if argId > 0 then {
                        ppnm: zast.nameTextCopy :ast ref: ppm.name
                        (ty.setChildId
                            parentTypeId: fnId
                            nameId: ppm.name.u64
                            childTypeId: argId
                        )
                    }
                } case none then null
            } else null
        }
    } else null
}

buildUnitMonoFull: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    tmplUnitName: StringView
    tmplName: StringView
    monoId: u64
    monoName: StringView
    tplId: u64
    argId: u64
    templateOpId: u32
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: templateOpId
    bgot9: ty.collectionChildrenBuilt.get key: monoId
    if (optBoolOr o: bgot9 d: false) then return
    bk0: monoId
    ty.collectionChildrenBuilt.set key: bk0 value: true
    gpNames: (Map String value: bool)
    gpFirst: String
    {
        with giter: bodyIds9.iterate do for gmId9: giter loop {
            gm: ast.nodes.get i: (gmId9 - 1).u64
            match (
                gm
            ) case namedoperation then {
                if (isGenericParam :ast op: (ast.nodes.get i: (gm.operation - 1).u64)) then {
                    gn: zast.nameTextCopy :ast ref: gm.name
                    if gpFirst.length == 0 then {
                        gnv9: gn.stringview
                        gpc9: gnv9.string
                        gpFirst = gpc9
                    }
                    gv: true
                    gpNames.set key: gn value: gv
                }
            } else null
        }
        ids9: (zgenerator.GenIds nextId: ty.nextSynthNodeId)
        fiter: bodyIds9.iterate
        for fm: fiter loop {
            fmNode9: ast.nodes.get i: (fm - 1).u64
            match (
                fmNode9
            ) case namedoperation then {
                if (isFunctionDefOp op: (ast.nodes.get i: (fmNode9.operation - 1).u64)) then {
                    fn: zast.nameTextCopy :ast ref: fmNode9.name
                    qn: "\{monoName}.\{fn}"
                    srcId: u64
                    tfo: ty.childOf pool: ast.names parentTypeId: tplId name: fn.stringview
                    match (
                        tfo
                    ) case some then {
                        srcId = tfo
                    } case none then {
                        tq: "\{tmplName}_\{fn}"
                        mo0: (resolveMethodFn
                            :ty
                            :reg
                            :ast
                            unitName: tmplUnitName
                            qname: tq.stringview
                            thisName: ""
                            op: (ast.nodes.get i: (fmNode9.operation - 1).u64)
                        )
                        match (
                            mo0
                        ) case some then {
                            srcId = mo0
                            (ty.setChildId
                                parentTypeId: tplId
                                nameId: fmNode9.name.u64
                                childTypeId: mo0
                            )
                        } case none then null
                    }
                    newFnId: reg.newType name: qn.stringview typetype: ztypes.ztypetype.functionType
                    if srcId > 0 then {
                        cNames: (List String)
                        cIds: (List u64)
                        {
                            bmb9: ty.childIndex.get key: srcId
                            match (
                                bmb9
                            ) case some then {
                                with bmit9: bmb9.rows.iterate do for bmr9: bmit9 loop {
                                    tc: ty.typeChild.get i: bmr9
                                    cto: ty.childTypeById.get key: tc.childNameId
                                    match (
                                        cto
                                    ) case some then {
                                        cnB0: ast.names.texts.get i: (tc.nameId - 1).u64
                                        cn0: cnB0.copy
                                        cNames.append cn0
                                        cid2: cto
                                        cIds.append cid2
                                    } case none then null
                                }
                            } case none then null
                        }
                        ci: u64
                        cn3: cNames.length
                        for ci < cn3 loop {
                            chName: cNames.get i: ci
                            chId: cIds.get i: ci
                            target: chId
                            ctn: typeNameOfReg :reg tid: chId
                            cgo: gpNames.get key: ctn
                            match (
                                cgo
                            ) case some then {
                                if argId > 0 then target = argId
                            } case none then null
                            (ty.setChildId
                                parentTypeId: newFnId
                                nameId: (zast.poolFind pool: ast.names text: chName.stringview).u64
                                childTypeId: target
                            )
                            ci = ci + 1
                        }
                        rto9: (optionval.none u64)
                        {
                            tf2: reg.typeById.get key: srcId
                            match (
                                tf2
                            ) case some then {
                                rto9 = tf2.returnTypeId
                            } case none then null
                        }
                        match (
                            rto9
                        ) case some then {
                            rtv: rto9
                            rtn: typeNameOfReg :reg tid: rtv
                            rgo: gpNames.get key: rtn
                            match (
                                rgo
                            ) case some then {
                                if argId > 0 then rtv = argId
                            } case none then null
                            reg.setReturnType typeId: newFnId value: rtv
                        } case none then {
                            # template return unresolved at signature time
                            # (out t): derive from the method's AST typeref.
                            rnm: (fnReturnBaseNameOf
                                :ast
                                op: (ast.nodes.get i: (fmNode9.operation - 1).u64)
                            )
                            if rnm.length > 0 then {
                                rgo2: gpNames.get key: rnm
                                rid2: u64
                                match (
                                    rgo2
                                ) case some then {
                                    rid2 = argId
                                } case none then {
                                    rlo2: (walkLookupTyperef
                                        :ast
                                        :ty
                                        :reg
                                        currentUnit: tmplUnitName
                                        base: rnm.stringview
                                    )
                                    match (
                                        rlo2
                                    ) case some then {
                                        rid2 = rlo2
                                    } case none then null
                                }
                                if rid2 > 0 then reg.setReturnType typeId: newFnId value: rid2
                            }
                        }
                    }
                    (registerMonoFnParams
                        :ast
                        :ty
                        op: (ast.nodes.get i: (fmNode9.operation - 1).u64)
                        fnId: newFnId
                        :gpNames
                        :argId
                    )
                    (ty.setChildId
                        parentTypeId: monoId
                        nameId: fmNode9.name.u64
                        childTypeId: newFnId
                    )
                    co9: (cloneUnitMethod
                        :ast
                        ids: ids9
                        op: (ast.nodes.get i: (fmNode9.operation - 1).u64)
                    )
                    match (
                        co9
                    ) case some then {
                        gpv9: gpFirst.stringview
                        gpn9: gpv9.string
                        mn9: monoName.string
                        rec9: (ztyping.PendingUnitWalk
                            :monoId
                            monoName: mn9
                            qualified: qn
                            gpName: gpn9
                            :argId
                            fn: co9.take
                        )
                        ty.pendingUnitWalk.append rec9
                        mk9: monoId
                        pw9: true
                        ty.unitMonoWalksPending.set key: mk9 value: pw9
                    } case none then null
                }
            } else null
        }
        ty.nextSynthNodeId = ids9.nextId
    }
}

# completeInlineReq -- locate an inline template member by name in the main
# unit body and build its mono's full-mode completion.
completeInlineReq: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    mainName: StringView
    monoId: u64
    monoName: StringView
    tmplName: StringView
    tplId: u64
    argId: u64
    mainOpId: u32
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: mainOpId
    {
        biter: bodyIds9.iterate
        for bm: biter loop {
            bmNode9: ast.nodes.get i: (bm - 1).u64
            match (
                bmNode9
            ) case namedoperation then {
                bn: zast.nameTextCopy :ast ref: bmNode9.name
                if bn.stringview == tmplName then {
                    if (isUnitOp op: (ast.nodes.get i: (bmNode9.operation - 1).u64)) then {
                        (buildUnitMonoFull
                            :ty
                            :reg
                            :ast
                            tmplUnitName: mainName
                            :tmplName
                            :monoId
                            :monoName
                            :tplId
                            :argId
                            templateOpId: bmNode9.operation
                        )
                    }
                }
            } else null
        }
    }
}

# inlineTemplateTid -- the canonical id of an inline generic-unit template
# (mathops: unit as {...} in the main body). A generic inline template has no
# unit->def childOf edge (it would shadow instance lookups) and is not a unit
# root, so the only durable record of its id is the full-mode def-node stamp
# laid by resolveInlineGenericUnit; 0 when no such binding is stamped.
inlineTemplateTid: function {
    ty: ztyping.ZTyping
    ast: Ast
    mainOpId: u32
    tmplName: StringView
} out u64 is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: mainOpId
    found: u64
    {
        biter: bodyIds9.iterate
        for bm: biter loop {
            bmNode9: ast.nodes.get i: (bm - 1).u64
            match (
                bmNode9
            ) case namedoperation then {
                bn: zast.nameTextCopy :ast ref: bmNode9.name
                if bn.stringview == tmplName then {
                    if (isUnitOp op: (ast.nodes.get i: (bmNode9.operation - 1).u64)) then {
                        tnid: unitdefNodeId :ast nId: bmNode9.operation
                        tso: ty.nodeType.get key: tnid.u64
                        match (
                            tso
                        ) case some then {
                            found = tso
                        } case none then null
                    }
                }
            } else null
        }
    }
    return found
}

# completeUnitInstantiations -- post-demand full-mode pass: with system types
# resolved, finish each generic-unit instantiation (substituted children +
# clone stash), register the binding name, and stamp the instantiation's
# expression/call/callable/arg nodes (the reference stamps all four).
completeUnitInstantiations: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    program: Node
} is {
    mainName: programMainName :program
    reqs: (List InstReq)
    scanMainForInstantiations :program :reqs
    i: u64
    for i < reqs.length loop {
        r: reqs.get :i
        rbv1: r.bind.stringview
        rb: rbv1.string
        rmv1: r.mono.stringview
        rm: rmv1.string
        rtv1: r.tmpl.stringview
        rt: rtv1.string
        rav1: r.argn.stringview
        ra: rav1.string
        re: r.exprId
        rc: r.callId
        rl: r.calId
        rg: r.argAtomId
        mk: "\{mainName}.\{rm}"
        mgo: (optionval.none u64)
        match (
            program
        ) case program then {
            mgo = resolvedByKey ast: program.ast :ty :reg key: mk
        } else null
        match (
            mgo
        ) case some then {
            mid9: mgo
            br9: mid9
            reg.setUnitName name: rb.stringview uid: br9
            tplId: u64
            tk: "\{mainName}.\{rt}"
            tgo: (optionval.none u64)
            match (
                program
            ) case program then {
                tgo = resolvedByKey ast: program.ast :ty :reg key: tk
            } else null
            match (
                tgo
            ) case some then {
                tplId = tgo
            } case none then {
                tnv9: rt.stringview
                tn9: tnv9.string
                ugo: reg.unitNameTid.get key: tn9
                match (
                    ugo
                ) case some then {
                    tplId = ugo
                } case none then null
            }
            argId: u64
            ago: (optionval.none u64)
            match (
                program
            ) case program then {
                ago = (walkLookupTyperef
                    ast: program.ast
                    :ty
                    :reg
                    currentUnit: mainName.stringview
                    base: ra.stringview
                )
            } else null
            match (
                ago
            ) case some then {
                argId = ago
            } case none then null
            if tplId == 0 then {
                match (
                    program
                ) case program then {
                    tuiter: program.ast.units.iterate
                    for tuId9: tuiter loop {
                        tu: program.ast.nodes.get i: (tuId9 - 1).u64
                        match (
                            tu
                        ) case namedoperation then {
                            tun: zast.poolTextCopy pool: program.ast.names ref: tu.name
                            if tun.stringview == mainName.stringview then {
                                tplId = (inlineTemplateTid
                                    :ty
                                    ast: program.ast
                                    mainOpId: tu.operation
                                    tmplName: rt.stringview
                                )
                            }
                        } else null
                    }
                } else null
            }
            if tplId > 0 then {
                match (
                    program
                ) case program then {
                    uN9: program.ast.units.length
                    uI9: u64
                    for uI9 < uN9 loop {
                        u9Id9: program.ast.units.get i: uI9
                        u9: program.ast.nodes.get i: (u9Id9 - 1).u64
                        uI9 = uI9 + 1
                        match (
                            u9
                        ) case namedoperation then {
                            un9: zast.poolTextCopy pool: program.ast.names ref: u9.name
                            if un9.stringview == rt.stringview then {
                                (buildUnitMonoFull
                                    :ty
                                    :reg
                                    ast: program.ast
                                    tmplUnitName: un9.stringview
                                    tmplName: rt.stringview
                                    monoId: mid9
                                    monoName: rm.stringview
                                    :tplId
                                    :argId
                                    templateOpId: u9.operation
                                )
                            }
                            if un9.stringview == mainName.stringview then {
                                (completeInlineReq
                                    :ty
                                    :reg
                                    ast: program.ast
                                    mainName: mainName.stringview
                                    monoId: mid9
                                    monoName: rm.stringview
                                    tmplName: rt.stringview
                                    :tplId
                                    :argId
                                    mainOpId: u9.operation
                                )
                            }
                        } else null
                    }
                } else null
            }
            if re > 0 then {
                ev: mid9
                ty.nodeType.set key: re value: ev
            }
            if rc > 0 then {
                cv: mid9
                ty.nodeType.set key: rc value: cv
            }
            if rl > 0 when tplId > 0 then {
                lv: tplId
                ty.nodeType.set key: rl value: lv
            }
            if rg > 0 when argId > 0 then {
                av: argId
                ty.nodeType.set key: rg value: av
            }
        } case none then null
        i = i + 1
    }
}

# runUnitMonoWalks -- first body-walk use of a generic-unit mono: walk each
# stashed method clone under a unitgeneric scope. The generic param name
# temporarily resolves to the arg type for the walk (param typerefs resolve
# by name); clone scopes parent under the current (using) scope, matching
# the reference's lazy clone-and-check.
runUnitMonoWalks: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    monoId: u64
} is {
    pgo: st.typing.unitMonoWalksPending.get key: monoId
    match (
        pgo
    ) case some then null case none then {
        return
    }
    dk: monoId
    st.typing.unitMonoWalksPending.remove key: dk
    n9: st.typing.pendingUnitWalk.length
    i9: u64
    for i9 < n9 loop {
        rmid: (st.typing.pendingUnitWalk.get i: i9).monoId
        if rmid == monoId then {
            rqual: String
            rgp: String
            rmn: String
            raid: u64
            {
                rec: st.typing.pendingUnitWalk.get i: i9
                rqual = rec.qualified.copy
                rgp = rec.gpName.copy
                rmn = rec.monoName.copy
                raid = rec.argId
            }
            sn: "unitgeneric:\{rmn}"
            st.push name: sn.stringview
            st.define name: rgp.stringview ztypeId: raid
            prevL: st.typing.synthLabel.copy
            prevT: st.typing.currentThisName.copy
            ed8: (List u32)
            (checkFunctionBody
                :st
                :unitName
                defName: rqual.stringview
                defn: (st.typing.pendingUnitWalk.get i: i9).fn
                thisName: ""
                :ast :unitBody
                depUnits: ed8
            )
            st.typing.synthLabel = prevL
            st.typing.currentThisName = prevT
            st.pop
        }
        i9 = i9 + 1
    }
}

# resolveMainUnitInstantiations -- resolve generic-unit instantiation bindings in the main
# unit (intmath: (genmath t: i64)) into mono UNIT types. Two passes avoid nested
# program.ast.units iteration: collect requests (separate fn), then create each mono.
# programMainName -- the main unit's name as an owned copy (no lingering lock on
# program, so program stays freely passable as a Node).
programMainName: function {program: Node} out String is {
    match (
        program
    ) case program then {
        return (program.mainUnitName.copy)
    } else {
        return "".string
    }
}

resolveMainUnitInstantiations: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    program: Node
} is {
    mainName: programMainName :program
    reqs: (List InstReq)
    scanMainForInstantiations :program :reqs
    i: u64
    for i < reqs.length loop {
        r: reqs.get :i
        rmv0: r.mono.stringview
        rm: rmv0.string
        rtv0: r.tmpl.stringview
        rt: rtv0.string
        (resolveUnitMono
            :ty
            :reg
            :program
            unitName: mainName.stringview
            monoName: rm.stringview
            templateName: rt.stringview
        )
        i = i + 1
    }
}

# typecheck -- entry point. Registers a UNIT type per unit and resolves the main
# unit's definition signatures, then demand-resolves the cross-unit types those
# signatures referenced. The registry is supplied by the caller, read by the dumper.
# builtinTidTc -- the canonical registry id of a stdlib builtin by base name
# (mainName "" so a user type of the same name never shadows it). 0 when absent.
builtinTidT: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    base: StringView
} out u64 is {
    bk: base.string
    m: ty.builtinTidMemo.get key: bk
    match (
        m
    ) case some then {
        return m
    } case none then null
    r: (optU64Or o: (walkLookupTyperef :ast :ty :reg currentUnit: "" :base) d: 0)
    if r == 0 then return r
    ty.builtinTidMemo.set key: bk.take value: r
    return r
}

builtinTidTc: function {ast: Ast st: zenv.ZSymbolTable base: StringView} out u64 is {
    return (builtinTidT :ast ty: st.typing reg: st.reg :base)
}

# stampTyperefs -- post-demand pass: stamp every recorded type-ref node with its real
# resolved type. Runs after the demand descent, so system + forward refs are present
# in childOf. pendingTyperef is a sibling field of nodeType (no lock
# conflict). The widened typed_nodes differential reads the resulting nodeType rows.
stampTyperefs: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry program: Node} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        pkeys9: (List u64)
        pvals9: (List String)
        with it: ty.pendingTyperef.iterateItems do for e: it loop {
            pk9: e.key
            pkeys9.append pk9
            pv9: e.value.copy
            pvals9.append pv9
        }
        pi9: u64
        pcnt9: pkeys9.length
        for pi9 < pcnt9 loop {
            uk: pkeys9.get i: pi9
            pval9: pvals9.get i: pi9
            pi9 = pi9 + 1
            originOwn9: String
            {
                uo: ty.pendingTyperefUnit.get key: uk
                match (
                    uo
                ) case some then {
                    if uo.length > 0 then originOwn9 = uo.copy
                } case none then null
            }
            origin: mainName
            if originOwn9.length > 0 then origin = originOwn9.stringview
            skip0: false
            {
                sk0: ty.noStampNode.get key: uk
                match (
                    sk0
                ) case some then {
                    if sk0 then skip0 = true
                } case none then null
            }
            if (skip0) == false then {
                r: (walkLookupTyperef
                    ast: program.ast
                    :ty
                    :reg
                    currentUnit: origin
                    base: pval9.stringview
                )
                match (
                    r
                ) case some then {
                    nid: uk
                    ty.nodeType.set key: nid value: r
                    # every resolved type reference records the definition it
                    # names, for go-to-definition (bare + dotted); codegen-inert
                    # because a type-annotation atom is never emitted as an
                    # expression (the emitter's only atomUnitDefId reader).
                    ty.atomUnitDefId.set key: nid value: r
                } case none then null
            }
        }
    } else null
}

# ownershipOfParam -- a parameter's binding ownership from its path annotation:
# an explicit .take binds OWNED, everything else (.borrow / .lock / default)
# binds BORROWED (mirrors _check_function_body_inner's param-ownership mapping).
ownershipOfParam: function {o: optionval ztypes.zparamownership} out ztypes.zownership is {
    match (
        o
    ) case some then {
        po: o
        match (
            po
        ) case takeMode then {
            return ztypes.zownership.owned
        } case borrowMode then {
            return ztypes.zownership.borrowed
        } case lockMode then {
            return ztypes.zownership.borrowed
        }
    } case none then {
        return ztypes.zownership.borrowed
    }
}

# paramTypeId -- the resolved type id of a parameter's type-expr. Reads the
# post-demand node stamp (stampTyperefs), falling back to a cross-unit name
# lookup for a bare-atom base.
paramTypeId: function {ast: Ast
    typing: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    op: Node
} out u64 is {
    # A parameter type carrying an ownership marker (ztypes.ZTypeRegistry.take)
    # resolves through its peeled base: the marker node is recorded under the
    # current unit and left unstamped, so read the inner cross-unit ref that
    # stampTyperefs resolved. Mirrors the reference's _strip_path_ownership.
    match (
        op
    ) case dottedpath then {
        ocn: atomName :ast n: (ast.nodes.get i: (op.child - 1).u64)
        if (isStripMarker name: ocn.stringview) then {
            dpr9: ast.nodes.get i: (op.parent - 1).u64
            return (paramTypeId :ast :typing :reg :unitName op: dpr9)
        }
    } else null
    onid: nodeId n: op
    r: typing.nodeType.get key: onid.u64
    match (
        r
    ) case some then {
        return r
    } case none then {
        an: atomName :ast n: op
        ano: walkLookupTyperef :ast ty: typing :reg currentUnit: unitName base: an.stringview
        anid: optU64Or o: ano d: 0
        if anid > 0 then return anid
        # a dotted typeref naming a variant/union ARM is an arm DEFAULT:
        # the parameter's type is the tagged parent.
        bn: rootNameOf :ast n: op
        if bn.length > 0 then {
            # a dotted numeric literal (0.u64) declares the SUFFIX type: the
            # body read must carry it, not fall to 0 (untyped/permissive)
            dcn9: dottedChildName :ast n: op
            isSfx9: isNumericTypeName name: dcn9.stringview
            if (isNumericLiteralName name: bn.stringview) when isSfx9 then {
                return (optU64Or
                    o: (walkLookupTyperef
                        :ast
                        ty: typing
                        :reg
                        currentUnit: unitName
                        base: dcn9.stringview
                    )
                    d: 0
                )
            }
            return (optU64Or
                o: (walkLookupTyperef
                    :ast
                    ty: typing
                    :reg
                    currentUnit: unitName
                    base: bn.stringview
                )
                d: 0
            )
        }
        return 0
    }
}

# isReturnCallKind -- true iff the stamped call-kind is a diverging control
# statement (return / panic / error); the statement walk marks the scope
# unreachable after one.
isReturnCallKind: function {o: optionval zast.callkind} out bool is {
    match (
        o
    ) case some then {
        ck: o
        match (
            ck
        ) case returnCall then {
            return true
        } case panicCall then {
            return true
        } case errorCall then {
            return true
        } else {
            return false
        }
    } case none then {
        return false
    }
}

# checkString -- a non-interpolated string literal types as StringView; an
# interpolated one (any non-chunk part) types as String, since it must allocate
# to splice the values, and each interpolated sub-expression is walked + stamped.
checkString: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    node: zast.AtomStringData
} out u64 is {
    result: u64
    hasInterp: false
    for partId9: node.stringparts.iterate loop {
        part: ast.nodes.get i: (partId9 - 1).u64
        match (
            part
        ) case stringchunk then null else {
            hasInterp = true
            checkValue :st :unitName :ast :unitBody node: part
        }
    }
    # the runtime value is always the SYSTEM String/StringView (the interp
    # machinery and the literal pool build system strings), so the stamp is
    # canonical even in a unit that shadows the name
    tyOpt: (optionval.none u64)
    if hasInterp then {
        tyOpt = walkLookupTyperef :ast ty: st.typing reg: st.reg currentUnit: "" base: "String"
    } else {
        tyOpt = walkLookupTyperef :ast ty: st.typing reg: st.reg currentUnit: "" base: "StringView"
    }
    match (
        tyOpt
    ) case some then {
        result = tyOpt
        setk: result
        st.typing.nodeType.set key: node.nodeid.u64 value: setk
    } case none then null
    drainPendingBorrow :st
    return result
}

# checkAtomid -- type a name-atom in value position: a local variable resolves
# via the symbol table. (Numeric literals + unit-def atoms land in later slices.)
# typeNameOf -- a registered type's name as an owned String ("" when absent).
typeNameOf: function {st: zenv.ZSymbolTable tid: u64} out String is {
    t: st.reg.typeById.get key: tid
    match (
        t
    ) case some then {
        return t.name.copy
    } case none then {
        return "".string
    }
}

# cloneMethodInto -- specialize one template method for an instance: a fresh
# FUNCTION type named {spec}.{m} whose param children and return substitute
# the template parameters (id-first, then re-specialization). genericOriginId
# points at the TEMPLATE METHOD so the emitter's mono-instance sweep emits the
# template body against this signature.
cloneMethodInto: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    specName: StringView
    specId: u64
    tplClassId: u64
    m: StringView
    tplFnId: u64
    idSubs: (Map u64 value: u64)
} is {
    fn5: "\{specName}.\{m}"
    fid5: reg.newType name: fn5.stringview typetype: ztypes.ztypetype.functionType
    reg.setGenericOrigin typeId: fid5 value: tplFnId
    # The clone answers call-site questions the same way the template does:
    # isNative gates arg validation, thisParamName drives receiver auto-fill
    # and the no-paren auto-call, funcReturnsBorrow carries the `.borrow`
    # return marker, and funcReturnNode backs methodReturnOf for concrete
    # (non-generic) returns.
    tpn0: String
    isNat0: false
    {
        tz0: reg.typeById.get key: tplFnId
        match (
            tz0
        ) case some then {
            if tz0.isNative then isNat0 = true
            tpn0 = optStrOrEmpty o: tz0.thisParamName
        } case none then null
    }
    if isNat0 then reg.setNative typeId: fid5 value: true
    if tpn0.length > 0 then reg.setThisParamName typeId: fid5 name: tpn0.stringview
    if (optBoolOr o: (ty.funcReturnsBorrow.get key: tplFnId) d: false) then {
        ty.funcReturnsBorrow.set key: fid5 value: true
    }
    frn0: optU64Or o: (ty.funcReturnNode.get key: tplFnId) d: 0
    if frn0 > 0 then ty.funcReturnNode.set key: fid5 value: frn0
    cN5: (List String)
    cI5: (List u64)
    cOh5: (List bool)
    cOv5: (List ztypes.zparamownership)
    {
        cmb9: ty.childIndex.get key: tplFnId
        match (
            cmb9
        ) case some then {
            with cit5: cmb9.rows.iterate do for cmr9: cit5 loop {
                tc5: ty.typeChild.get i: cmr9
                co5: ty.childTypeById.get key: tc5.childNameId
                match (
                    co5
                ) case some then {
                    nmB5: ast.names.texts.get i: (tc5.nameId - 1).u64
                    nm5: nmB5.copy
                    cN5.append nm5
                    cv5: co5
                    cI5.append cv5
                    oo5: ty.childOwnership.get key: tc5.childNameId
                    match (
                        oo5
                    ) case some then {
                        cOh5.append true
                        ov5c: oo5
                        cOv5.append ov5c
                    } case none then {
                        cOh5.append false
                        cOv5.append ztypes.zparamownership.borrowMode
                    }
                } case none then null
            }
        } case none then null
    }
    tplNm5: regTypeNameOf :reg tid: tplClassId
    pi5: u64
    pn5: cN5.length
    for pi5 < pn5 loop {
        pnm5: cN5.get i: pi5
        ptid5: cI5.get i: pi5
        tgt5: ptid5
        if ptid5 == tplClassId then tgt5 = specId
        if pnm5.stringview == "this" then tgt5 = specId
        if tpn0.length > 0 when pnm5.stringview == tpn0.stringview then tgt5 = specId
        if tgt5 == ptid5 then {
            # `this`/`type`-typed params carry fresh shells named after the
            # class; shell-name identity marks the self type.
            ptn5: regTypeNameOf :reg tid: ptid5
            if ptn5.stringview == tplNm5.stringview then tgt5 = specId
        }
        if tgt5 == ptid5 then {
            ido5: idSubs.get key: ptid5
            match (
                ido5
            ) case some then {
                tgt5 = ido5
            } case none then {
                rs5: respecialize :ast :ty :reg :mainName specTid: ptid5 :idSubs
                if rs5 > 0 then tgt5 = rs5
            }
        }
        (ty.setChildId
            parentTypeId: fid5
            nameId: (zast.poolFind pool: ast.names text: pnm5.stringview).u64
            childTypeId: tgt5
        )
        if (cOh5.get i: pi5) then {
            pov5: cOv5.get i: pi5
            (ty.setChildOwnership
                pool: ast.names
                parentTypeId: fid5
                name: pnm5.stringview
                ownership: pov5
            )
        }
        pi5 = pi5 + 1
    }
    rto5: u64
    {
        tz5: reg.typeById.get key: tplFnId
        match (
            tz5
        ) case some then {
            ro5: tz5.returnTypeId
            match (
                ro5
            ) case some then {
                rto5 = ro5
            } case none then null
        } case none then null
    }
    if rto5 > 0 then {
        rt5: rto5
        if rto5 == tplClassId then rt5 = specId
        if rt5 == rto5 then {
            rtn5: regTypeNameOf :reg tid: rto5
            if rtn5.stringview == tplNm5.stringview then rt5 = specId
        }
        rdo5: idSubs.get key: rto5
        match (
            rdo5
        ) case some then {
            rt5 = rdo5
        } case none then {
            rr5: respecialize :ast :ty :reg :mainName specTid: rto5 :idSubs
            if rr5 > 0 then rt5 = rr5
        }
        # a return still GENERIC_PARAM-typed (a partial the subs could not
        # complete -- multi-param chains mint with empty subs) stays unset;
        # the name-keyed fixup arms heal it after minting
        if (reg.typetypeOf typeId: rt5) != ztypes.ztypetype.genericParam then {
            reg.setReturnType typeId: fid5 value: rt5
        }
    }
    (ty.setChildId
        parentTypeId: specId
        nameId: (zast.poolFind pool: ast.names text: m).u64
        childTypeId: fid5
    )
}

# respecialize -- a type that is itself a specialization (nonempty genericArgs)
# re-specializes when any of its arguments is substituted: the origin template
# specializes again with the mapped argument list. 0 when nothing changes.
respecialize: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    specTid: u64
    idSubs: (Map u64 value: u64)
} out u64 is {
    an9: reg.genericArgCount specId: specTid
    if an9 == 0 then return 0
    origin9: u64
    {
        zo9: reg.typeById.get key: specTid
        match (
            zo9
        ) case some then {
            og9: zo9.genericOriginId
            match (
                og9
            ) case some then {
                origin9 = og9
            } case none then null
        } case none then null
    }
    if origin9 == 0 then return 0
    changed9: false
    mapped9: (List u64)
    ai9: u64
    for ai9 < an9 loop {
        av9: reg.genericArgAt specId: specTid ordinal: ai9
        if (reg.genericArgIsValueAt specId: specTid ordinal: ai9) then {
            # a numeric VALUE ordinal has nothing to substitute
            av9v: av9
            mapped9.append av9v
        } else {
            mo9: idSubs.get key: av9
            match (
                mo9
            ) case some then {
                mapped9.append mo9
                changed9 = true
            } case none then {
                # an arg that is itself a spec may carry substitutable args one
                # level down (OptionView over a MapEntry partial) -- recurse
                rec9: respecialize :ast :ty :reg :mainName specTid: av9 :idSubs
                if rec9 > 0 then {
                    mapped9.append rec9
                    changed9 = true
                } else {
                    av9b: av9
                    mapped9.append av9b
                }
            }
        }
        ai9 = ai9 + 1
    }
    if changed9 == false then return 0
    tk9: genericTypeKey :ty :reg tid: origin9
    pn9: reg.genericParamNamesOf typeKey: tk9.stringview
    if pn9.length != an9 then return 0
    subs9: (Map String value: u64)
    rvSubs9: (Map String value: u64)
    sfx9: String
    on9: regTypeNameOf :reg tid: origin9
    mi9: u64
    for mi9 < an9 loop {
        mp9: pn9.get i: mi9
        mv9: mapped9.get i: mi9
        sfx9.append s: "_"
        if (reg.genericArgIsValueAt specId: specTid ordinal: mi9) then {
            vk9: mp9.copy
            vv9r: mv9
            rvSubs9.set key: vk9 value: vv9r
            nvs9: "\{mv9}"
            sfx9.append s: nvs9.stringview
        } else {
            sk9: mp9.copy
            sv9: mv9
            subs9.set key: sk9 value: sv9
            vn9: monoValName :ast :ty :reg tid: mv9
            sfx9.append s: vn9.stringview
        }
        mi9 = mi9 + 1
    }
    mn9: "\{on9}\{sfx9}"
    return (getOrMintSpec
        :ast
        :ty
        :reg
        :mainName
        name: mn9.stringview
        templateId: origin9
        subs: subs9
        valSubs: rvSubs9
        fallbackArg: 0
    )
}

# mintMono -- register one generic-instance type (deduped by mono name): the
# template's typetype and valtype flag, genericOriginId linking back, and the
# instance's children -- the template's children with generic-param targets
# substituted (matched by arg name; fallbackArg substitutes every child, the
# single-type-param call-site inference) -- plus the synthesized members: a
# per-instance tag data type (variants and unions) and the autogen ==/!=
# functions (variants). Childless templates (the collection classes) produce
# no children; their cloned method children land with the class-mono slice.
mintMono: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    name: StringView
    templateId: u64
    subs: (Map String value: u64)
    idSubs: (Map u64 value: u64)
    fallbackArg: u64
} out u64 is {
    kn: name.string
    got: resolveSystemChild :ast :ty :reg :name
    match (
        got
    ) case some then {
        return got
    } case none then null
    tt: ztypes.ztypetype.recordType
    vto: (optionval.none bool)
    tplNative: false
    {
        tpl: reg.typeById.get key: templateId
        match (
            tpl
        ) case some then {
            tt = tpl.typetype
            vto = tpl.isValtype
            tplNative = tpl.isNative
        } case none then null
    }
    mid: reg.newType :name typetype: tt
    match (
        vto
    ) case some then {
        reg.setValtype typeId: mid value: vto
    } case none then null
    reg.setGenericOrigin typeId: mid value: templateId
    reg.setNative typeId: mid value: tplNative
    if tt == ztypes.ztypetype.classType then reg.setIsHeapAllocated typeId: mid
    # Register under <unit>.<mangled> so name lookups (field/arm shells named
    # by the mangled form) resolve to the instance once minted.
    mcu9: reg.unitNameTid.get key: mainName.string
    match (
        mcu9
    ) case some then {
        ty.setChildId parentTypeId: mcu9 nameId: (ast.internString text: name).u64 childTypeId: mid
    } case none then null
    # monos are global (defined_in_unit NULL): the system-keyed alias makes
    # them resolvable from every unit's lookup chain (a pending instantiation
    # staged while resolving io.z resolves nested args with mainName "io").
    mcu8: reg.unitNameTid.get key: "system".string
    match (
        mcu8
    ) case some then {
        ty.setChildId parentTypeId: mcu8 nameId: (ast.internString text: name).u64 childTypeId: mid
    } case none then null
    # A heap-owning generic instance carries a destructor (so a holder/local
    # frees it; the emitter builds the cname). Collections own native heap;
    # Option/Result own a heap box. A user generic whose template already has a
    # destructor inherits one. Map/Set own native heap too (freed via a `&`-less
    # heap-pointer destroy). Views (ListView/OptionView) own no heap -- excluded.
    tplNmD: regTypeNameOf :reg tid: templateId
    needsDtorM: false
    if templateId == (builtinTidT :ast :ty :reg base: "List") then needsDtorM = true
    if templateId == (builtinTidT :ast :ty :reg base: "Option") then needsDtorM = true
    if templateId == (builtinTidT :ast :ty :reg base: "Result") then needsDtorM = true
    if templateId == (builtinTidT :ast :ty :reg base: "Map") then needsDtorM = true
    if templateId == (builtinTidT :ast :ty :reg base: "Set") then needsDtorM = true
    if needsDtorM then {
        mdnM: "\{name}_destroy"
        reg.setDestructorName typeId: mid name: mdnM.stringview
    }
    # An elided leading type argument stages under the empty name; rebind it
    # to the template's primary generic parameter so the substituted children
    # resolve (`(List String)` == `(List of: String)`).
    {
        emptyKey: String
        ev: subs.get key: emptyKey
        match (
            ev
        ) case some then {
            prnm: firstGenericParamName :ty :reg :templateId
            if prnm.length > 0 then subs.set key: prnm value: ev
        } case none then null
    }
    cNames: (List String)
    cIds: (List u64)
    {
        mmb9: ty.childIndex.get key: templateId
        match (
            mmb9
        ) case some then {
            with mmit9: mmb9.rows.iterate do for mmr9: mmit9 loop {
                tc: ty.typeChild.get i: mmr9
                cto: ty.childTypeById.get key: tc.childNameId
                match (
                    cto
                ) case some then {
                    cnB1: ast.names.texts.get i: (tc.nameId - 1).u64
                    cn: cnB1.copy
                    cNames.append cn
                    cid2: cto
                    cIds.append cid2
                } case none then null
            }
        } case none then null
    }
    listTplT5: builtinTidT :ast :ty :reg base: "List"
    monoNeedsDtor9: false
    ci: u64
    cn3: cNames.length
    for ci < cn3 loop {
        chName: cNames.get i: ci
        # getv: concrete-param native with an inexpressible return -- the
        # Map fixup re-mints it per mono; the generic-target machinery
        # (respecialize on the raw template child) must not touch it
        if chName.stringview == "getv" then {
            ci = ci + 1
            continue
        }
        chId: cIds.get i: ci
        target: chId
        ido9: idSubs.get key: chId
        match (
            ido9
        ) case some then {
            target = ido9
        } case none then {
            rsp9: respecialize :ast :ty :reg :mainName specTid: chId :idSubs
            if rsp9 > 0 then target = rsp9
        }
        ctn: regTypeNameOf :reg tid: chId
        if target == chId then target = optU64Or o: (subs.get key: ctn) d: target
        # Generic FUNCTION children are clone candidates: the elided-arg
        # fallback must not swallow them (a method child's dotted name never
        # resolves, so the lookup-miss leg would replace the method with the
        # element type).
        chGen5: false
        if (reg.typetypeOf typeId: chId) == ztypes.ztypetype.functionType then {
            cz5: reg.typeById.get key: chId
            match (
                cz5
            ) case some then {
                chGen5 = cz5.isgeneric
            } case none then null
        }
        if fallbackArg > 0 when (ctn.stringview == "null") == false when target == chId when (chGen5) == false then {
            cko: walkLookupTyperef :ast :ty :reg currentUnit: mainName base: ctn.stringview
            match (
                cko
            ) case some then null case none then {
                target = fallbackArg
            }
        }
        deep5: false
        if target == chId when chGen5 then {
            isSynth5: false
            if chName.stringview == "create" then isSynth5 = true
            if chName.stringview == "borrow" then isSynth5 = true
            if chName.stringview == "==" then isSynth5 = true
            if chName.stringview == "!=" then isSynth5 = true
            if isSynth5 == false then {
                skip5: false
                # List's contains/sort exist only for eligible element
                # kinds (use-site parity with the materializer gate).
                if templateId == listTplT5 when listTplT5 > 0 then {
                    csM5: false
                    if chName.stringview == "contains" then csM5 = true
                    if chName.stringview == "sort" then csM5 = true
                    if csM5 then {
                        elemT5: optU64Or o: (subs.get key: ("of".string)) d: 0
                        if elemT5 == 0 then elemT5 = fallbackArg
                        ok5: false
                        if elemT5 > 0 then {
                            csel5: false
                            if chName.stringview == "contains" then {
                                csel5 = isContainsEligibleTid :ast :ty :reg tid: elemT5
                            } else {
                                csel5 = isSortEligibleTid :ast :ty :reg tid: elemT5
                            }
                            if csel5 then ok5 = true
                        }
                        if (ok5) == false then skip5 = true
                    }
                }
                if skip5 then {
                    deep5 = true
                } else {
                    (cloneMethodInto
                        :ast
                        :ty
                        :reg
                        :mainName
                        specName: name
                        specId: mid
                        tplClassId: templateId
                        m: chName.stringview
                        tplFnId: chId
                        :idSubs
                    )
                    deep5 = true
                }
            }
        }
        if deep5 == false then {
            (ty.setChildId
                parentTypeId: mid
                nameId: (zast.poolFind pool: ast.names text: chName.stringview).u64
                childTypeId: target
            )
        }
        if (reg.typetypeOf typeId: chId) != ztypes.ztypetype.functionType then {
            if (ty.isChildLockField
                pool: ast.names
                parentTypeId: templateId
                name: chName.stringview
            ) == false then {
                if (reg.hasDestructorName typeId: target) then monoNeedsDtor9 = true
            }
        }
        ci = ci + 1
    }
    # A user generic CLASS whose SUBSTITUTED fields are destructible carries
    # an auto-destructor, exactly like its non-generic counterpart (the
    # builtin-template list above cannot see through substitution; without
    # this, `class { val: t }` with t=String leaks its payload).
    if tt == ztypes.ztypetype.classType when monoNeedsDtor9 when (reg.hasDestructorName typeId: mid) == false then {
        mdnU9: "\{name}_destroy"
        reg.setDestructorName typeId: mid name: mdnU9.stringview
    }
    # RECORD instances: numeric-param fields synthesize from their declared
    # constraint (size: u64.generic -> a u64 child) when no field references
    # them; then the meta-create requalifies to the instance and ==/!=
    # synthesize -- except str/array, whose branches own those members
    # (their u64 `to` child comes from THIS synth; the branches add none).
    if tt == ztypes.ztypetype.recordType then {
        tplNm9: regTypeNameOf :reg tid: templateId
        isSized9: false
        if templateId == (builtinTidT :ast :ty :reg base: "str") then isSized9 = true
        if templateId == (builtinTidT :ast :ty :reg base: "array") then isSized9 = true
        tk9: genericTypeKey :ty :reg tid: templateId
        pNames9: reg.genericParamNamesOf typeKey: tk9.stringview
        pi9: u64
        pn0: pNames9.length
        for pi9 < pn0 loop {
            pname9: pNames9.get i: pi9
            cdx9: reg.genericParamConstraintOf typeKey: tk9.stringview paramName: pname9.stringview
            isNum9: true
            if cdx9.kind == ztypes.constraintkind.any then isNum9 = false
            if cdx9.kind == ztypes.constraintkind.none then isNum9 = false
            if isNum9 then {
                exo9: ty.childOf pool: ast.names parentTypeId: mid name: pname9.stringview
                match (
                    exo9
                ) case some then null case none then {
                    pcon9: constraintTextOf desc: cdx9
                    cno9: (walkLookupTyperef
                        :ast
                        :ty
                        :reg
                        currentUnit: mainName
                        base: pcon9.stringview
                    )
                    match (
                        cno9
                    ) case some then {
                        (ty.setChildId
                            parentTypeId: mid
                            nameId: (zast.poolFind pool: ast.names text: pname9.stringview).u64
                            childTypeId: cno9
                        )
                    } case none then null
                }
            }
            pi9 = pi9 + 1
        }
        if (isSized9) == false then {
            crq9: "\{name}.create"
            crId9: reg.newType name: crq9.stringview typetype: ztypes.ztypetype.functionType
            ty.setChildId parentTypeId: mid nameId: wkCreate childTypeId: crId9
            eqo9: ty.childOfId parentTypeId: mid nameId: wkOpEq
            match (
                eqo9
            ) case some then null case none then {
                req9: "\{name}.=="
                reqId9: reg.newType name: req9.stringview typetype: ztypes.ztypetype.functionType
                ty.setChildId parentTypeId: mid nameId: wkOpEq childTypeId: reqId9
                rne9: "\{name}.!="
                rneId9: reg.newType name: rne9.stringview typetype: ztypes.ztypetype.functionType
                ty.setChildId parentTypeId: mid nameId: wkOpNe childTypeId: rneId9
            }
        }
    }
    wantTag: false
    if tt == ztypes.ztypetype.variantType then wantTag = true
    if tt == ztypes.ztypetype.unionType then wantTag = true
    if wantTag then {
        tagName: "\{name}:tag:data"
        tagId: reg.newType name: tagName.stringview typetype: ztypes.ztypetype.dataType
        ty.setChildId parentTypeId: mid nameId: wkTag childTypeId: tagId
    }
    if tt == ztypes.ztypetype.variantType then {
        eqName: "\{name}.=="
        eqId: reg.newType name: eqName.stringview typetype: ztypes.ztypetype.functionType
        ty.setChildId parentTypeId: mid nameId: wkOpEq childTypeId: eqId
        neName: "\{name}.!="
        neId: reg.newType name: neName.stringview typetype: ztypes.ztypetype.functionType
        ty.setChildId parentTypeId: mid nameId: wkOpNe childTypeId: neId
    }
    return mid
}

# isContainsEligibleTid / isSortEligibleTid -- element types List.contains /
# List.sort support (the hardcoded equality / ordering dispatch): numerics +
# bool + the String/StringView/str family; sort excludes bool (no ordering).
isContainsEligibleTid: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    tid: u64
} out bool is {
    if tid == (builtinTidT :ast :ty :reg base: "bool") then return true
    return (isSortEligibleTid :ast :ty :reg :tid)
}

isSortEligibleTid: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    tid: u64
} out bool is {
    if tid == 0 then return false
    if (isNumericTid :ast :ty :reg :tid) then return true
    if tid == (builtinTidT :ast :ty :reg base: "String") then return true
    if tid == (builtinTidT :ast :ty :reg base: "StringView") then return true
    if tid == (builtinTidT :ast :ty :reg base: "str") then return true
    return false
}

# isStdlibUnitName / isUserShadowElem -- a collection element that is a USER type
# shadowing a builtin name (e.g. a user `String`) is NOT the native builtin, so it
# earns no builtin contains/sort (like any other user type). isUserShadowElem is true
# when the element is defined in a user file unit (not a stdlib unit, not a scalar).
isStdlibUnitName: function {name: StringView} out bool is {
    if name == "system" then return true
    if name == "core" then return true
    if name == "collections" then return true
    if name == "io" then return true
    if name == "os" then return true
    if name == "cli" then return true
    return false
}

isUserShadowElem: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    elemTid: u64
} out bool is {
    duo: ty.definedInUnit.get key: elemTid
    match (
        duo
    ) case some then {
        return (isStdlibUnitName name: duo.stringview) == false
    } case none then {
        return false
    }
}

# mintCollectionMethod -- one synthesized `{mono}.{m}` FUNCTION child; returns
# the method's type id so callers can link its return type.
mintCollectionMethod: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    monoName: StringView
    monoId: u64
    m: StringView
} out u64 is {
    fname: "\{monoName}.\{m}"
    fid: reg.newType name: fname.stringview typetype: ztypes.ztypetype.functionType
    reg.setNative typeId: fid value: true
    (ty.setChildId
        parentTypeId: monoId
        nameId: (zast.poolFind pool: ast.names text: m).u64
        childTypeId: fid
    )
    return fid
}

# mapGetWrapperName -- the Map.get return-wrapper template by value kind:
# optionval for valtypes (copy-out), OptionView for reftypes incl. String (a
# borrowed, locked view into the map's storage; the caller `.copy`s to keep it).
mapGetWrapperName: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    valArg: u64
} out String is {
    isVal: false
    {
        vt: reg.typeById.get key: valArg
        match (
            vt
        ) case some then {
            vvo: vt.isValtype
            match (
                vvo
            ) case some then {
                if vvo then isVal = true
            } case none then null
        } case none then null
    }
    if isVal then return ("optionval".string)
    return ("OptionView".string)
}

# getOrMintSpec -- the id-keyed specialization tree front door: derive the
# definition-order argument keys from the name-keyed subs (fallbackArg fills a
# single missing parameter), walk the generic-child edges, and return the existing
# spec on a full-path hit. A parameter absent from subs with no fallback (a
# numeric value parameter -- str/array's `to`) skips the tree -- mintMono's
# name dedup still holds for those. On a miss the leaf materializes via mintMono; multi-level
# paths mint intermediate nodes (genericOriginId = template, genericArgs =
# the key prefix) that cache partial paths without being emitted.
# checkConstraintSat -- a specialization argument against its parameter's
# declared constraint. Any (and numeric bounds, which never reach the tree)
# pass; value-kind constraints check typeIsValtype/typeIsReftype; StringLike
# checks membership. GENERIC_PARAM args skip -- partial specs re-check on
# completion. Location-free (the spec front door holds no source node).
# constraintKindFor -- classify a constraint's declared text into a tag once,
# at registration; the checks then compare the tag, not the string.
constraintKindFor: function {text: StringView} out ztypes.constraintkind is {
    if text == "Any.valtype" then return ztypes.constraintkind.valType
    if text == "Any.reftype" then return ztypes.constraintkind.refType
    if text == "StringLike" then return ztypes.constraintkind.stringLike
    if text == "Any" then return ztypes.constraintkind.any
    if text.length == 0 then return ztypes.constraintkind.none
    nm9: constraintNumericMax cv: text
    match (
        nm9
    ) case some then {
        return ztypes.constraintkind.numeric
    } case none then null
    return ztypes.constraintkind.other
}

# constraintNumericName -- the integer-scalar name for a numeric bound, for
# diagnostics; the exact inverse of constraintNumericMax.
constraintNumericName: function {max: u64} out String is {
    if max == 255 then return "u8".string
    if max == 65535 then return "u16".string
    if max == 4294967295 then return "u32".string
    if max == 18446744073709551615.u64 then return "u64".string
    if max == 127 then return "i8".string
    if max == 32767 then return "i16".string
    if max == 2147483647 then return "i32".string
    if max == 9223372036854775807 then return "i64".string
    return "".string
}

# constraintTextOf -- reconstruct a constraint's declared text from its tag
# for diagnostics; reads fields only, constructs nothing.
constraintTextOf: function {desc: ztypes.ConstraintDesc} out String is {
    if desc.kind == ztypes.constraintkind.valType then return "Any.valtype".string
    if desc.kind == ztypes.constraintkind.refType then return "Any.reftype".string
    if desc.kind == ztypes.constraintkind.stringLike then return "StringLike".string
    if desc.kind == ztypes.constraintkind.any then return "Any".string
    if desc.kind == ztypes.constraintkind.numeric then {
        nmx7: desc.numericMax
        match (
            nmx7
        ) case some then {
            return (constraintNumericName max: nmx7)
        } case none then null
    }
    return "".string
}

# constraintNumericMax -- the largest value an integer-scalar generic-param
# constraint admits; none when the constraint is not an integer scalar (a
# numeric argument on such a parameter stays on the name-keyed path).
constraintNumericMax: function {cv: StringView} out optionval u64 is {
    if cv == "u8" then return (optionval.some 255.u64)
    if cv == "u16" then return (optionval.some 65535.u64)
    if cv == "u32" then return (optionval.some 4294967295.u64)
    if cv == "u64" then return (optionval.some 18446744073709551615.u64)
    if cv == "i8" then return (optionval.some 127.u64)
    if cv == "i16" then return (optionval.some 32767.u64)
    if cv == "i32" then return (optionval.some 2147483647.u64)
    if cv == "i64" then return (optionval.some 9223372036854775807.u64)
    return (optionval.none u64)
}

checkConstraintSat: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    typeKey: StringView
    paramName: StringView
    argTid: u64
} is {
    if (reg.typetypeOf typeId: argTid) == ztypes.ztypetype.genericParam then return
    cd9: reg.genericParamConstraintOf :typeKey :paramName
    ck9: cd9.kind
    if ck9 == ztypes.constraintkind.none then return
    ok9: true
    if ck9 == ztypes.constraintkind.valType then ok9 = typeIsValtype :ty :reg tid: argTid
    if ck9 == ztypes.constraintkind.refType then {
        rz9: reg.typeById.get key: argTid
        rOk9: false
        match (
            rz9
        ) case some then {
            rv9: rz9.isValtype
            match (
                rv9
            ) case some then {
                rOk9 = rv9 == false
            } case none then null
        } case none then null
        ok9 = rOk9
    }
    if ck9 == ztypes.constraintkind.stringLike then {
        okSL9: false
        svT9: builtinTidT :ast :ty :reg base: "StringView"
        if svT9 > 0 when argTid == svT9 then okSL9 = true
        if okSL9 == false then {
            # conformance rows live on the declaring type; a mono (str_32)
            # conforms through its generic origin (the str template)
            probeT9: argTid
            {
                ago9: reg.typeById.get key: argTid
                match (
                    ago9
                ) case some then {
                    agoo9: ago9.genericOriginId
                    match (
                        agoo9
                    ) case some then {
                        probeT9 = agoo9
                    } case none then null
                } case none then null
            }
            txT9: builtinTidT :ast :ty :reg base: "Text"
            if txT9 > 0 then {
                with cit9: ty.conformance.iterate do for crow9: cit9 loop {
                    if crow9.specTypeId == txT9 then {
                        if crow9.implTypeId == argTid then okSL9 = true
                        if crow9.implTypeId == probeT9 then okSL9 = true
                    }
                }
            }
        }
        ok9 = okSL9
    }
    if (ok9) == false then {
        an9: regTypeNameOf :reg tid: argTid
        con9: constraintTextOf desc: cd9
        m9: "generic argument '\{an9}' does not satisfy constraint '\{con9}' on parameter '\{paramName}' of '\{typeKey}'"
        addResolveError :ty e: zast.err.genericError msg: m9
    }
}

# heapOwningValtypeTid -- a RECORD/VARIANT that transitively owns heap
# members (a class/union box, a destructor-carrying mono, or another owning
# valtype): its byte-range hash and equality cannot cover them.
heapOwningValtypeTid: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    tid: u64
} out bool is {
    tt9: reg.typetypeOf typeId: tid
    isVR9: false
    if tt9 == ztypes.ztypetype.recordType then isVR9 = true
    if tt9 == ztypes.ztypetype.variantType then isVR9 = true
    if isVR9 == false then return false
    hrows9: (List u64)
    {
        hob9: ty.childIndex.get key: tid
        match (
            hob9
        ) case some then {
            with hoit9: hob9.rows.iterate do for hor9: hoit9 loop {
                hrv9: hor9
                hrows9.append hrv9
            }
        } case none then null
    }
    hcn9: hrows9.length
    hci9: u64
    for hci9 < hcn9 loop {
        hri9: hrows9.get i: hci9
        htc9: ty.typeChild.get i: hri9
        hci9 = hci9 + 1
        {
            hcto9: ty.childTypeById.get key: htc9.childNameId
            match (
                hcto9
            ) case some then {
                hctt9: reg.typetypeOf typeId: hcto9
                hnB9: ast.names.texts.get i: (htc9.nameId - 1).u64
                if hctt9 != ztypes.ztypetype.functionType when hnB9.stringview != "tag" then {
                    if hctt9 == ztypes.ztypetype.classType then return true
                    if hctt9 == ztypes.ztypetype.unionType then return true
                    if (reg.hasDestructorName typeId: hcto9) then return true
                    if hctt9 == ztypes.ztypetype.recordType then {
                        if (heapOwningValtypeTid :ast :ty :reg tid: hcto9) then return true
                    }
                    if hctt9 == ztypes.ztypetype.variantType then {
                        if (heapOwningValtypeTid :ast :ty :reg tid: hcto9) then return true
                    }
                }
            } case none then null
        }
    }
    return false
}

getOrMintSpec: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    name: StringView
    templateId: u64
    subs: (Map String value: u64)
    valSubs: (Map String value: u64)
    fallbackArg: u64
} out u64 is {
    tk8: genericTypeKey :ty :reg tid: templateId
    pnames8: reg.genericParamNamesOf typeKey: tk8.stringview
    # An elided leading type argument stages under the empty name; rebind it
    # to the primary generic parameter before the trie keys and idSubs build
    # (mintMono's own rebind happens after both).
    {
        emptyKey8: String
        ev8: subs.get key: emptyKey8
        match (
            ev8
        ) case some then {
            prnm8: firstGenericParamName :ty :reg :templateId
            if prnm8.length > 0 then subs.set key: prnm8 value: ev8
        } case none then null
        evv8: valSubs.get key: emptyKey8
        match (
            evv8
        ) case some then {
            prnmv8: firstGenericParamName :ty :reg :templateId
            if prnmv8.length > 0 then valSubs.set key: prnmv8 value: evv8
        } case none then null
    }
    keys8: (List u64)
    keyIsVal8: (List bool)
    trieOk8: true
    if pnames8.length == 0 then trieOk8 = false
    with pit8: pnames8.iterate do for pn8: pit8 loop {
        pgot8: subs.get key: pn8.copy
        match (
            pgot8
        ) case some then {
            (checkConstraintSat
                :ast
                :ty
                :reg
                typeKey: tk8.stringview
                paramName: pn8.stringview
                argTid: pgot8
            )
            keys8.append pgot8
            keyIsVal8.append false
        } case none then {
            vgot8: valSubs.get key: pn8.copy
            match (
                vgot8
            ) case some then {
                # a numeric literal keys its trie level by VALUE; per-level
                # kind is fixed by the parameter, so values and type ids
                # cannot collide
                cd8: reg.genericParamConstraintOf typeKey: tk8.stringview paramName: pn8.stringview
                nmx8: cd8.numericMax
                match (
                    nmx8
                ) case some then {
                    if vgot8 > nmx8 then {
                        cvn8: constraintTextOf desc: cd8
                        m8v: "numeric argument \{vgot8} exceeds constraint '\{cvn8}' on parameter '\{pn8}' of '\{tk8}'"
                        addResolveError :ty e: zast.err.genericError msg: m8v
                    }
                    keys8.append vgot8
                    keyIsVal8.append true
                } case none then {
                    trieOk8 = false
                }
            } case none then {
                if fallbackArg > 0 when pnames8.length == 1 then {
                    fb8: fallbackArg
                    keys8.append fb8
                    keyIsVal8.append false
                } else {
                    trieOk8 = false
                }
            }
        }
    }
    if trieOk8 when keys8.length > 0 then {
        # byte-range hash/equality cannot cover owned members: a heap-owning
        # valtype cannot key a Set/Map (classes hash by identity, String by
        # content -- both fine)
        hkSet9: builtinTidT :ast :ty :reg base: "Set"
        hkMap9: builtinTidT :ast :ty :reg base: "Map"
        hkKind9: String
        if hkSet9 > 0 when templateId == hkSet9 then hkKind9 = "Set element".string
        if hkMap9 > 0 when templateId == hkMap9 then hkKind9 = "Map key".string
        if hkKind9.length > 0 when (keyIsVal8.get i: 0) == false then {
            hkT9: keys8.get i: 0
            if (heapOwningValtypeTid :ast :ty :reg tid: hkT9) then {
                hkN9: regTypeNameOf :reg tid: hkT9
                mHK9: "heap-owning value type '\{hkN9}' cannot be a \{hkKind9}"
                addResolveError :ty e: zast.err.genericError msg: mHK9
            }
        }
    }
    if trieOk8 then {
        cur8: templateId
        ki8: u64
        kn8: keys8.length
        hit8: true
        for ki8 < kn8 loop {
            k8: keys8.get i: ki8
            n8: reg.getGenericChild parentId: cur8 key: k8
            match (
                n8
            ) case some then {
                cur8 = n8
            } case none then {
                hit8 = false
                ki8 = kn8
            }
            ki8 = ki8 + 1
        }
        if hit8 then return cur8
    }
    idSubs8: (Map u64 value: u64)
    if trieOk8 then {
        pi8: u64
        pt8: pnames8.length
        for pi8 < pt8 loop {
            pnm8: pnames8.get i: pi8
            pto8: reg.genericParamTidOf typeKey: tk8.stringview paramName: pnm8.stringview
            match (
                pto8
            ) case some then {
                if (keyIsVal8.get i: pi8) == false then {
                    kv8: keys8.get i: pi8
                    pk8: pto8
                    idSubs8.set key: pk8 value: kv8
                }
            } case none then null
            pi8 = pi8 + 1
        }
    }
    hasParamKey8: false
    if trieOk8 then {
        hk8: u64
        hn8: keys8.length
        for hk8 < hn8 loop {
            if (keyIsVal8.get i: hk8) == false then {
                hv8: keys8.get i: hk8
                if (reg.typetypeOf typeId: hv8) == ztypes.ztypetype.genericParam then {
                    hasParamKey8 = true
                }
            }
            hk8 = hk8 + 1
        }
    }
    mid8: u64
    if hasParamKey8 then {
        # a generic-param arg makes the spec PARTIAL: a trie-only entry that
        # is never emitted or name-registered; the clone-side respecialize
        # completes it with concrete args per instance.
        pnmP8: "\{name}__partial"
        mid8 = reg.newType name: pnmP8.stringview typetype: ztypes.ztypetype.genericParam
        reg.setGenericOrigin typeId: mid8 value: templateId
    } else {
        mid8 = mintMono :ast :ty :reg :mainName :name :templateId :subs idSubs: idSubs8 :fallbackArg
    }
    if trieOk8 when mid8 > 0 then {
        cur9: templateId
        ki9: u64
        kn9: keys8.length
        for ki9 < kn9 loop {
            k9: keys8.get i: ki9
            last9: false
            if ki9 + 1 == kn9 then last9 = true
            n9: reg.getGenericChild parentId: cur9 key: k9
            step9: u64
            match (
                n9
            ) case some then {
                step9 = n9
            } case none then {
                if last9 then {
                    step9 = mid8
                } else {
                    inm9: "\{name}__node"
                    step9 = (reg.newType
                        name: inm9.stringview
                        typetype: ztypes.ztypetype.genericParam
                    )
                    kj9: u64
                    for kj9 <= ki9 loop {
                        pk9: keys8.get i: kj9
                        if (keyIsVal8.get i: kj9) then {
                            reg.appendGenericArgValue specId: step9 value: pk9
                        } else {
                            reg.appendGenericArg specId: step9 arg: pk9
                        }
                        kj9 = kj9 + 1
                    }
                }
                reg.setGenericChild parentId: cur9 key: k9 child: step9
            }
            cur9 = step9
            ki9 = ki9 + 1
        }
        ka9: u64
        for ka9 < kn9 loop {
            av9: keys8.get i: ka9
            if (keyIsVal8.get i: ka9) then {
                reg.appendGenericArgValue specId: mid8 value: av9
            } else {
                reg.appendGenericArg specId: mid8 arg: av9
            }
            ka9 = ka9 + 1
        }
    }
    okC3: trieOk8
    if hasParamKey8 then okC3 = false
    if mid8 == 0 then okC3 = false
    if okC3 then {
        # a trie-keyed concrete specialization mints its chain family and
        # collection children here with def-order args; name-keyed mints
        # (sized records, empty-subs chains) keep their caller-side
        # invocations, which carry the elem/val ids this path cannot derive
        tnC3: regTypeNameOf :reg tid: templateId
        tnl3: tnC3.length
        nmC3: name.string
        nml3: nmC3.length
        sfxC3: String
        if nml3 > tnl3 then {
            sfv3: (nmC3.substring from: tnl3 to: nml3)
            sfxC3 = sfv3.string
        }
        # elem = the first TYPE key (a sized record's leading value key is
        # not an element); val = the second key only when it is a type
        elemC3: u64
        ei3: u64
        en3: keys8.length
        for ei3 < en3 loop {
            if elemC3 == 0 then {
                if (keyIsVal8.get i: ei3) == false then elemC3 = keys8.get i: ei3
            }
            ei3 = ei3 + 1
        }
        valC3: u64
        if keys8.length > 1 then {
            if (keyIsVal8.get i: 1) == false then valC3 = keys8.get i: 1
        }
        # MapItemIter's iterator element is the derived MapEntry spec (its
        # call's OptionView some-arm), not a trie key
        skipC3: false
        if templateId == (builtinTidT :ast :ty :reg base: "MapItemIter") then {
            skipC3 = true
            micoC4: ty.childOfId parentTypeId: mid8 nameId: wkCall
            match (
                micoC4
            ) case some then {
                mizoC4: reg.typeById.get key: micoC4
                match (
                    mizoC4
                ) case some then {
                    mrtoC4: mizoC4.returnTypeId
                    match (
                        mrtoC4
                    ) case some then {
                        mieoC4: ty.childOfId parentTypeId: mrtoC4 nameId: wkSome
                        match (
                            mieoC4
                        ) case some then {
                            elemC3 = mieoC4
                            skipC3 = false
                        } case none then null
                    } case none then null
                } case none then null
            } case none then null
        }
        if skipC3 == false then {
            (mintCollectionChildren
                :ast
                :ty
                :reg
                :mainName
                monoName: name
                monoId: mid8
                :templateId
                suffix: sfxC3.stringview
                elemArg: elemC3
                valArg: valC3
            )
        }
    }
    return mid8
}

# mintReturnWrapper -- mint a no-argument wrapper spec (empty subs/valSubs) and,
# on a hit, record it as targetId's return type. The element is fixed by
# fallbackArg (the get/remove collection wrappers).
mintReturnWrapper: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    targetId: u64
    name: StringView
    templateId: u64
    fallbackArg: u64
} out u64 is {
    weM: (Map String value: u64)
    vsM: (Map String value: u64)
    mid: getOrMintSpec :ast :ty :reg :mainName :name :templateId subs: weM valSubs: vsM :fallbackArg
    if mid > 0 then reg.setReturnType typeId: targetId value: mid
    return mid
}

# mintCollectionChildren -- the per-instance collection children the
# produced templates cannot express: length/capacity u64 value children,
# the create child (except List and Map, which have their own create
# paths), the Map get/remove value-kind wrapper returns, MapEntry's
# key/value accessors, and the sized str/array member tables. Method
# signatures and composite returns come from the cloned template methods
# (healed by respecialize). No-op for other templates or when the
# instance already has children (re-mint dedup).
# monoValName -- the value-type name component of a get-wrapper mono name. A user
# type SHADOWING a builtin (its name also names a system type) appends its canonical
# id, so its wrapper mono is distinct from the system type's same-named wrapper (a
# user i64 -> "i64_7" vs system "i64"); otherwise the bare name (no churn for a
# non-shadow type). Without this the get-wrapper mono name (optionval_i64) collides
# under the shared system key and the shadow reuses the system instance (wrong `some`-arm type).
monoValName: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    tid: u64
} out String is {
    tn: regTypeNameOf :reg :tid
    if (isUserShadowElem :ty :reg elemTid: tid) then {
        if (builtinTidT :ast :ty :reg base: tn.stringview) > 0 then return ("\{tn}_\{tid}")
    }
    return tn
}

mintCollectionChildren: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    monoName: StringView
    monoId: u64
    templateId: u64
    suffix: StringView
    elemArg: u64
    valArg: u64
} is {
    listTid: builtinTidT :ast :ty :reg base: "List"
    listViewTid: builtinTidT :ast :ty :reg base: "ListView"
    setTid: builtinTidT :ast :ty :reg base: "Set"
    mapTid: builtinTidT :ast :ty :reg base: "Map"
    mapEntryTid: builtinTidT :ast :ty :reg base: "MapEntry"
    strTid: builtinTidT :ast :ty :reg base: "str"
    arrayTid: builtinTidT :ast :ty :reg base: "array"
    listIterTid: builtinTidT :ast :ty :reg base: "ListIter"
    setIterTid: builtinTidT :ast :ty :reg base: "SetIter"
    mapKeyIterTid: builtinTidT :ast :ty :reg base: "MapKeyIter"
    mapItemIterTid: builtinTidT :ast :ty :reg base: "MapItemIter"
    isIter: false
    if templateId == listIterTid then isIter = true
    if templateId == setIterTid then isIter = true
    if templateId == mapKeyIterTid then isIter = true
    if templateId == mapItemIterTid then isIter = true
    isColl: isIter
    if templateId == listTid then isColl = true
    if templateId == listViewTid then isColl = true
    if templateId == setTid then isColl = true
    if templateId == mapTid then isColl = true
    if templateId == mapEntryTid then isColl = true
    if templateId == strTid then isColl = true
    if templateId == arrayTid then isColl = true
    if (isColl) == false then return
    # List children come from the produced template methods cloned per
    # instance (composite returns healed by respecialize); only the
    # length/capacity u64 children materialize here. Runs on every naming.
    if templateId == listTid then {
        u64L: u64
        uoL: walkLookupTyperef :ast :ty :reg currentUnit: mainName base: "u64"
        match (
            uoL
        ) case some then {
            u64L = uoL
        } case none then null
        if u64L > 0 then {
            ty.setChildId parentTypeId: monoId nameId: wkLength childTypeId: u64L
            ty.setChildId parentTypeId: monoId nameId: wkCapacity childTypeId: u64L
        }
        return
    }
    # One build per instance: a spec can reach this arm from several mint
    # paths, and the str/array rebuild below would mint fresh member types
    # per invocation (their instances copy template children at mint time,
    # so childCount cannot signal "already built").
    bgot: ty.collectionChildrenBuilt.get key: monoId
    if (optBoolOr o: bgot d: false) then return
    bk0: monoId
    ty.collectionChildrenBuilt.set key: bk0 value: true
    u64id: (declareCanonicalType
        :ast
        :ty
        :reg
        defUnit: "system"
        name: "u64"
        typetype: ztypes.ztypetype.recordType
    )
    # ListView children come from the produced template method (get); the
    # length field (the canonical u64) and the create child materialize here,
    # once per mono (post-memo: this arm mints).
    if templateId == listViewTid then {
        ty.setChildId parentTypeId: monoId nameId: wkLength childTypeId: u64id
        mintCollectionMethod :ast :ty :reg :monoName :monoId m: "create"
        return
    }
    # Set children come from the produced template methods (returns healed
    # by respecialize); the length/capacity fields (the canonical u64) and
    # the create child materialize here, once per mono.
    if templateId == setTid then {
        ty.setChildId parentTypeId: monoId nameId: wkLength childTypeId: u64id
        ty.setChildId parentTypeId: monoId nameId: wkCapacity childTypeId: u64id
        mintCollectionMethod :ast :ty :reg :monoName :monoId m: "create"
        return
    }
    # Iterator families: call is produced+cloned (its OptionView return
    # healed by respecialize); only the create child mints here, once per
    # mono.
    if isIter then {
        mintCollectionMethod :ast :ty :reg :monoName :monoId m: "create"
        return
    }
    # Map children come from the produced template methods (iterator
    # returns healed by respecialize); the length/capacity fields and the
    # value-kind wrapper returns for get/remove (inexpressible in source:
    # optionval for a valtype, Option/OptionView otherwise) materialize
    # here, once per mono. Map has no create child (its construction path
    # is separate).
    if templateId == mapTid when valArg > 0 then {
        ty.setChildId parentTypeId: monoId nameId: wkLength childTypeId: u64id
        ty.setChildId parentTypeId: monoId nameId: wkCapacity childTypeId: u64id
        vnM: monoValName :ast :ty :reg tid: valArg
        mgoM: ty.childOfId parentTypeId: monoId nameId: wkGet
        match (
            mgoM
        ) case some then {
            wtplM: mapGetWrapperName :ty :reg :valArg
            wtoM: walkLookupTyperef :ast :ty :reg currentUnit: mainName base: wtplM.stringview
            match (
                wtoM
            ) case some then {
                wnM: "\{wtplM}_\{vnM}"
                (mintReturnWrapper
                    :ast
                    :ty
                    :reg
                    :mainName
                    targetId: mgoM
                    name: wnM.stringview
                    templateId: wtoM
                    fallbackArg: valArg
                )
            } case none then null
        } case none then null
        # getv has concrete params, so the clone pass leaves the raw template
        # child in place; re-mint it as a per-mono native (args unchecked,
        # like length/key/value) and heal the return by value kind.
        gvIdM: mintCollectionMethod :ast :ty :reg :monoName :monoId m: "getv"
        wtvM: mapGetWrapperName :ty :reg :valArg
        wtvoM: walkLookupTyperef :ast :ty :reg currentUnit: mainName base: wtvM.stringview
        match (
            wtvoM
        ) case some then {
            wvnM: "\{wtvM}_\{vnM}"
            (mintReturnWrapper
                :ast
                :ty
                :reg
                :mainName
                targetId: gvIdM
                name: wvnM.stringview
                templateId: wtvoM
                fallbackArg: valArg
            )
        } case none then null
        mrmoM: ty.childOfId parentTypeId: monoId nameId: wkRemove
        match (
            mrmoM
        ) case some then {
            rwtM: "Option".string
            if (typeIsValtype :ty :reg tid: valArg) then rwtM = "optionval".string
            rwtoM: walkLookupTyperef :ast :ty :reg currentUnit: mainName base: rwtM.stringview
            match (
                rwtoM
            ) case some then {
                rwnM: "\{rwtM}_\{vnM}"
                (mintReturnWrapper
                    :ast
                    :ty
                    :reg
                    :mainName
                    targetId: mrmoM
                    name: rwnM.stringview
                    templateId: rwtoM
                    fallbackArg: valArg
                )
            } case none then null
        } case none then null
        return
    }
    isSized: false
    if templateId == strTid then isSized = true
    if templateId == arrayTid then isSized = true
    # str/array are PERMANENT materializer arms: sized RECORDs are keyed by
    # a numeric value parameter that rides the trie as a literal VALUE key
    # (genericArgIsValue marks the ordinal); it never enters idSubs, so
    # produce+clone has nothing to substitute. Their templates resolve from source (record
    # attachMethods runs regardless of genericity) and copy their children
    # at mint time; the branches below REPLACE the value-dependent members
    # in place (setChild keeps positions) -- fresh const-clone size fields,
    # element-typed get/set returns, String-returning string, and the ==/!=
    # that resolveRecord and mintMono both skip for sized records. The
    # emitter builds the structs from the z_str/z_array tmpls by name-parsed
    # size and reads only the == child's presence. The dedup guard below
    # applies only to the from-scratch families.
    if (isSized) == false then {
        if (ty.childCount parentTypeId: monoId) > 0 then return
    }
    boolid: u64
    bo9: walkLookupTyperef :ast :ty :reg currentUnit: mainName base: "bool"
    match (
        bo9
    ) case some then {
        boolid = bo9
    } case none then null
    if templateId == mapEntryTid then {
        kyId: mintCollectionMethod :ast :ty :reg :monoName :monoId m: "key"
        reg.setReturnType typeId: kyId value: elemArg
        vlId: mintCollectionMethod :ast :ty :reg :monoName :monoId m: "value"
        if valArg > 0 then reg.setReturnType typeId: vlId value: valArg
        mintCollectionMethod :ast :ty :reg :monoName :monoId m: "create"
    }
    if templateId == arrayTid then {
        agId: mintCollectionMethod :ast :ty :reg :monoName :monoId m: "get"
        reg.setReturnType typeId: agId value: elemArg
        asId: mintCollectionMethod :ast :ty :reg :monoName :monoId m: "set"
        reg.setReturnType typeId: asId value: elemArg
        ty.setChildId parentTypeId: monoId nameId: wkLength childTypeId: u64id
        mintCollectionMethod :ast :ty :reg :monoName :monoId m: "create"
        aeqId: mintCollectionMethod :ast :ty :reg :monoName :monoId m: "=="
        reg.setReturnType typeId: aeqId value: boolid
        aneId: mintCollectionMethod :ast :ty :reg :monoName :monoId m: "!="
        reg.setReturnType typeId: aneId value: boolid
    }
    if templateId == strTid then {
        ty.setChildId parentTypeId: monoId nameId: wkLength childTypeId: u64id
        ty.setChildId parentTypeId: monoId nameId: wkSize childTypeId: u64id
        tstId: mintCollectionMethod :ast :ty :reg :monoName :monoId m: "string"
        sgo: walkLookupTyperef :ast :ty :reg currentUnit: mainName base: "String"
        sgid: optU64Or o: sgo d: 0
        if sgid > 0 then reg.setReturnType typeId: tstId value: sgid
        mintCollectionMethod :ast :ty :reg :monoName :monoId m: "create"
        teqId: mintCollectionMethod :ast :ty :reg :monoName :monoId m: "=="
        reg.setReturnType typeId: teqId value: boolid
        tneId: mintCollectionMethod :ast :ty :reg :monoName :monoId m: "!="
        reg.setReturnType typeId: tneId value: boolid
    }
}

# genericTypeKey -- "{defining-unit}.{name}" for the registry's generic-param
# set lookups.
genericTypeKey: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry tid: u64} out String is {
    tn: regTypeNameOf :reg :tid
    duo: ty.definedInUnit.get key: tid
    match (
        duo
    ) case some then {
        return ("\{duo}.\{tn}")
    } case none then null
    return tn
}

# firstGenericParamName -- the primary (first-declared) generic parameter
# name of a template, or empty when it has none. Binds an elided leading type
# argument (`(List String)` == `(List of: String)`) to its parameter.
firstGenericParamName: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    templateId: u64
} out String is {
    tk: genericTypeKey :ty :reg tid: templateId
    names: reg.genericParamNamesOf typeKey: tk.stringview
    if names.length > 0 then {
        firstNm: names.get i: 0
        return firstNm.copy
    }
    return "".string
}

# inferGenericConstruction -- a generic class/record template called with
# field-bound value arguments: labels naming generic params resolve as
# explicit type args; other args walk as values and bind their field's
# param (literals materialise + restamp the bare node). The deduped
# instance mints with substituted fields plus a synthesized create.
# 0 when nothing infers.
inferGenericConstruction: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    call: zast.CallData
    tplId: u64
    reportMissing: bool
} out u64 is {
    tname: typeNameOf :st tid: tplId
    if tname.length == 0 then return 0
    tk: genericTypeKey ty: st.typing reg: st.reg tid: tplId
    # Stage the template's children, then keep the ones whose TYPE NAME is a
    # registered generic param (field shells carry the param name, not a
    # GENERIC_PARAM typetype).
    cNames3: (List String)
    cIds3: (List u64)
    {
        igb9: st.typing.childIndex.get key: tplId
        match (
            igb9
        ) case some then {
            with igit9: igb9.rows.iterate do for igr9: igit9 loop {
                tc: st.typing.typeChild.get i: igr9
                cto: st.typing.childTypeById.get key: tc.childNameId
                match (
                    cto
                ) case some then {
                    fnB9: ast.names.texts.get i: (tc.nameId - 1).u64
                    fn1: fnB9.copy
                    cNames3.append fn1
                    cid1: cto
                    cIds3.append cid1
                } case none then null
            }
        } case none then null
    }
    fNames: (List String)
    fParams: (List String)
    ci3: u64
    cn3: cIds3.length
    for ci3 < cn3 loop {
        cid3: cIds3.get i: ci3
        pnm3: typeNameOf :st tid: cid3
        if (st.reg.isGenericParamOf typeKey: tk.stringview name: pnm3.stringview) then {
            nm3: cNames3.get i: ci3
            nv3: nm3.stringview
            n3: nv3.string
            fNames.append n3
            fParams.append pnm3
        }
        ci3 = ci3 + 1
    }
    sfx: String
    subs: (Map String value: u64)
    boundParams: (Set String)
    firstA: u64
    primaryName: firstGenericParamName ty: st.typing reg: st.reg templateId: tplId
    # the value-arg walk below is a DRY RUN for type inference: bracket its
    # ownership effects (take overlays, borrow locks) so the real ctor walk
    # re-checks from a clean slate — an explicit `.take` arg otherwise
    # collides with its own inference pass.
    infMark9: st.entriesMark
    argIdx: u64
    with aiter: call.arguments.iterate do for argId9: aiter loop {
        arg: ast.nodes.get i: (argId9 - 1).u64
        match (
            arg
        ) case namedoperation then {
            pk: zast.nameTextCopy :ast ref: arg.name
            # elided leading type arg: an unnamed first arg naming a type
            # binds the primary generic param (`(List String)`); a value
            # first arg (`(box 5)`) is left for value inference.
            if pk.length == 0 when argIdx == 0 then {
                anE: paramTypeBaseName :ast op: (ast.nodes.get i: (arg.operation - 1).u64)
                if (isNumericLiteralName name: anE.stringview) == false then {
                    teo: (walkLookupTyperef
                        :ast
                        ty: st.typing
                        reg: st.reg
                        currentUnit: unitName
                        base: anE.stringview
                    )
                    match (
                        teo
                    ) case some then {
                        if primaryName.length > 0 then pk = primaryName.copy
                    } case none then null
                }
            }
            isP: false
            if pk.length > 0 then {
                isP = st.reg.isGenericParamOf typeKey: tk.stringview name: pk.stringview
            }
            if isP then {
                an: paramTypeBaseName :ast op: (ast.nodes.get i: (arg.operation - 1).u64)
                if (isNumericLiteralName name: an.stringview) then {
                    sfx.append s: "_"
                    sfx.append s: an.stringview
                    boundParams.add item: pk.copy
                } else {
                    ao: (walkLookupTyperef
                        :ast
                        ty: st.typing
                        reg: st.reg
                        currentUnit: unitName
                        base: an.stringview
                    )
                    match (
                        ao
                    ) case some then {
                        atn: typeNameOf :st tid: ao
                        sfx.append s: "_"
                        sfx.append s: atn.stringview
                        pk2: pk.copy
                        pv2: ao
                        subs.set key: pk2 value: pv2
                        boundParams.add item: pk.copy
                        if firstA == 0 then firstA = ao
                    } case none then null
                }
            } else {
                vt0: (checkValue
                    :st
                    :unitName
                    :ast
                    :unitBody
                    node: (ast.nodes.get i: (arg.operation - 1).u64)
                )
                gidx: u64
                gfound: false
                fi: u64
                fn2: fNames.length
                for fi < fn2 loop {
                    f0: fNames.get i: fi
                    if f0.stringview == pk.stringview then {
                        if (gfound) == false then {
                            gidx = fi
                            gfound = true
                        }
                    }
                    fi = fi + 1
                }
                if gfound when vt0 > 0 then {
                    mv0: materialiseLiteral :ast :st :unitName t: vt0
                    if mv0 != vt0 then {
                        iid0: innermostNodeId :ast n: (ast.nodes.get i: (arg.operation - 1).u64)
                        if iid0 > 0 then {
                            setm0: mv0
                            st.typing.nodeType.set key: iid0.u64 value: setm0
                        }
                    }
                    gp0: fParams.get i: gidx
                    already: optU64Or o: (subs.get key: gp0) d: 0
                    if already <= 0 then {
                        vtn: typeNameOf :st tid: mv0
                        sfx.append s: "_"
                        sfx.append s: vtn.stringview
                        gpv0: gp0.stringview
                        gpc: gpv0.string
                        gpv: mv0
                        subs.set key: gpc value: gpv
                        boundParams.add item: gp0.copy
                        if firstA == 0 then firstA = mv0
                    }
                }
            }
        } else null
        argIdx = argIdx + 1
    }
    st.truncateEntries marker: infMark9
    paramsM: st.reg.genericParamNamesOf typeKey: tk.stringview
    firstMissing: String
    pmi: u64
    pmn: paramsM.length
    for pmi < pmn loop {
        pmName: paramsM.get i: pmi
        if (boundParams.has item: pmName.copy) == false then {
            if firstMissing.length == 0 then firstMissing = pmName.copy
        }
        pmi = pmi + 1
    }
    if firstMissing.length > 0 then {
        if reportMissing then {
            emn: String
            ehn: String
            if sfx.length == 0 then {
                mmsg: "cannot infer type arguments for generic type '\{tname}'"
                (addErrorH
                    :st
                    nodeid: call.nodeid
                    lineno: call.lineno
                    colno: call.colno
                    e: zast.err.genericError
                    msg: mmsg
                    note: emn
                    hint: ehn
                    width: 0
                )
            } else {
                fmc: firstMissing.copy
                mmsg2: "cannot infer generic parameter '\{fmc}' for '\{tname}'"
                (addErrorH
                    :st
                    nodeid: call.nodeid
                    lineno: call.lineno
                    colno: call.colno
                    e: zast.err.genericError
                    msg: mmsg2
                    note: emn
                    hint: ehn
                    width: 0
                )
            }
        }
        return 0
    }
    if sfx.length == 0 then return 0
    mname: "\{tname}\{sfx}"
    vsD9: (Map String value: u64)
    mid: (getOrMintSpec
        :ast
        ty: st.typing
        reg: st.reg
        mainName: unitName
        name: mname.stringview
        templateId: tplId
        :subs
        valSubs: vsD9
        fallbackArg: 0
    )
    if mid == 0 then return 0
    cro: st.typing.childOfId parentTypeId: mid nameId: wkCreate
    match (
        cro
    ) case some then null case none then {
        crn: "\{mname}.create"
        crId: st.reg.newType name: crn.stringview typetype: ztypes.ztypetype.functionType
        st.typing.setChildId parentTypeId: mid nameId: wkCreate childTypeId: crId
    }
    return mid
}

# genericTypeConstruction -- a generic TYPE template in callable position
# with type-name arguments constructs its mono in place (`(List of: String)`
# in value position): resolve each argument as a type, mint the deduped mono
# with its chains and children, and the call's
# value is the mono.
genericTypeConstruction: function {
    ast: Ast
    st: zenv.ZSymbolTable
    unitName: StringView
    call: zast.CallData
    tplId: u64
} out u64 is {
    tname: typeNameOf :st tid: tplId
    if tname.length == 0 then return 0
    tk0: genericTypeKey ty: st.typing reg: st.reg tid: tplId
    sfx: String
    subs: (Map String value: u64)
    valSubs2: (Map String value: u64)
    numParamNames9: (List String)
    numParamVals9: (List String)
    firstA: u64
    anyMiss: false
    primaryName: firstGenericParamName ty: st.typing reg: st.reg templateId: tplId
    argIdx: u64
    aiter: call.arguments.iterate
    for argId9: aiter loop {
        arg: ast.nodes.get i: (argId9 - 1).u64
        match (
            arg
        ) case namedoperation then {
            # only generic-param labels construct here; a value arg means
            # the field-bound inference leg owns the call.
            pk0: zast.nameTextCopy :ast ref: arg.name
            # An elided leading type argument (`(List zvfs.ProviderBox)`) binds
            # the primary generic param: probe the unnamed first arg as a type
            # (atom via walkLookupTyperef, cross-unit dotted via dottedTyperefId).
            # Only a real type rebinds; a value first arg (`(box 5)`) keeps its
            # empty label so the field-bound inference leg owns the call.
            if pk0.length == 0 when argIdx == 0 then {
                if primaryName.length > 0 then {
                    anP: paramTypeBaseName :ast op: (ast.nodes.get i: (arg.operation - 1).u64)
                    pid0: u64
                    if (isNumericLiteralName name: anP.stringview) == false then {
                        pao0: (walkLookupTyperef
                            :ast
                            ty: st.typing
                            reg: st.reg
                            currentUnit: unitName
                            base: anP.stringview
                        )
                        pid0 = optU64Or o: pao0 d: 0
                        if pid0 == 0 then {
                            dop9: ast.nodes.get i: (arg.operation - 1).u64
                            pid0 = dottedTyperefId :ast :st op: dop9
                        }
                    }
                    if pid0 > 0 then pk0 = primaryName.copy
                }
            }
            isP0: false
            if pk0.length > 0 then {
                isP0 = st.reg.isGenericParamOf typeKey: tk0.stringview name: pk0.stringview
            }
            # `capacity:` on a builtin container is a create argument riding
            # the construction sugar: skip it here (it must not reach the
            # spec key or subs) instead of failing over to field inference
            skipCr9: false
            if (isP0) == false when pk0.stringview == "capacity" then {
                if tplId == (builtinTidT
                    :ast
                    ty: st.typing
                    reg: st.reg
                    base: "List"
                ) then skipCr9 = true
                if tplId == (builtinTidT
                    :ast
                    ty: st.typing
                    reg: st.reg
                    base: "Map"
                ) then skipCr9 = true
                if tplId == (builtinTidT
                    :ast
                    ty: st.typing
                    reg: st.reg
                    base: "Set"
                ) then skipCr9 = true
            }
            if (isP0) == false when skipCr9 == false then anyMiss = true
            an: paramTypeBaseName :ast op: (ast.nodes.get i: (arg.operation - 1).u64)
            if (anyMiss) == false when skipCr9 == false then { if (isNumericLiteralName name: an.stringview) then {
                nsfx2: "\{sfx}_\{an}"
                sfx = nsfx2
                if pk0.length > 0 then {
                    npn0: pk0.copy
                    numParamNames9.append npn0
                    npv0: an.copy
                    numParamVals9.append npv0
                    pdv0: parseDecimalU64 text: an.stringview
                    match (
                        pdv0
                    ) case some then {
                        vgk0: pk0.copy
                        vgv0: pdv0
                        valSubs2.set key: vgk0 value: vgv0
                    } case none then null
                }
            } else {
                ao: (walkLookupTyperef
                    :ast
                    ty: st.typing
                    reg: st.reg
                    currentUnit: unitName
                    base: an.stringview
                )
                aid: optU64Or o: ao d: 0
                if aid == 0 then {
                    opf1059: ast.nodes.get i: (arg.operation - 1).u64
                    aid = dottedTyperefId :ast :st op: opf1059
                }
                if aid > 0 then {
                    atn: typeNameOf :st tid: aid
                    nsfx: "\{sfx}_\{atn}"
                    sfx = nsfx
                    if pk0.length > 0 then {
                        pv: aid
                        subs.set key: pk0.copy value: pv
                    }
                    if firstA == 0 then firstA = aid
                } else {
                    anyMiss = true
                }
            } }
        } else null
        argIdx = argIdx + 1
    }
    if anyMiss then return 0
    if sfx.length == 0 then return 0
    mname: "\{tname}\{sfx}"
    mid: (getOrMintSpec
        :ast
        ty: st.typing
        reg: st.reg
        mainName: unitName
        name: mname.stringview
        templateId: tplId
        :subs
        valSubs: valSubs2
        fallbackArg: firstA
    )
    if mid == 0 then return 0
    npi9: u64
    npn9: numParamNames9.length
    for npi9 < npn9 loop {
        npName9: numParamNames9.get i: npi9
        npVal9: numParamVals9.get i: npi9
        (st.typing.setChildDefault
            pool: ast.names
            parentTypeId: mid
            name: npName9.stringview
            default: npVal9.stringview
        )
        npi9 = npi9 + 1
    }
    isSized2: false
    if tname.stringview == "str" then isSized2 = true
    if tname.stringview == "array" then isSized2 = true
    if isSized2 then {
        (mintCollectionChildren
            :ast
            ty: st.typing
            reg: st.reg
            mainName: unitName
            monoName: mname.stringview
            monoId: mid
            templateId: tplId
            suffix: sfx.stringview
            elemArg: firstA
            valArg: 0
        )
    }
    # Only a bare-atom callable restamps to the instance; a dotted callable
    # (the .str conversion form) leaves the path unstamped like the reference.
    gcb: bareAtomName :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    gcal: nodeId n: (ast.nodes.get i: (call.callable - 1).u64)
    if gcal > 0 when gcb.length > 0 then {
        setga: mid
        st.typing.nodeType.set key: gcal.u64 value: setga
    }
    setgt: mid
    st.typing.nodeType.set key: call.nodeid.u64 value: setgt
    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.classCreate
    return mid
}

# validateGenericTypeArgs -- reject unknown / duplicate generic TYPE arguments
# at a settled construction site. A named arg matching neither a declared
# generic param nor a declared field (child) is an unknown type argument; a
# generic param supplied twice (e.g. an elided leading arg plus an explicit
# label) is a duplicate. Returns false when an error was emitted.
validateGenericTypeArgs: function {
    ast: Ast
    st: zenv.ZSymbolTable
    unitName: StringView
    call: zast.CallData
    tplId: u64
    allowFrom: bool
} out bool is {
    tname: typeNameOf :st tid: tplId
    if tname.length == 0 then return true
    tk: genericTypeKey ty: st.typing reg: st.reg tid: tplId
    childNames: (List String)
    {
        vgb9: st.typing.childIndex.get key: tplId
        match (
            vgb9
        ) case some then {
            with vgit9: vgb9.rows.iterate do for vgr9: vgit9 loop {
                tc: st.typing.typeChild.get i: vgr9
                cnB2: ast.names.texts.get i: (tc.nameId - 1).u64
                cn1: cnB2.copy
                childNames.append cn1
            }
        } case none then null
    }
    primaryName: firstGenericParamName ty: st.typing reg: st.reg templateId: tplId
    seen: (Set String)
    ok: true
    argIdx: u64
    aiter: call.arguments.iterate
    for argId9: aiter loop {
        arg: ast.nodes.get i: (argId9 - 1).u64
        match (
            arg
        ) case namedoperation then {
            pk: zast.nameTextCopy :ast ref: arg.name
            if pk.length == 0 when argIdx == 0 then {
                if primaryName.length > 0 then {
                    anP: paramTypeBaseName :ast op: (ast.nodes.get i: (arg.operation - 1).u64)
                    pid0: u64
                    if (isNumericLiteralName name: anP.stringview) == false then {
                        pao0: (walkLookupTyperef
                            :ast
                            ty: st.typing
                            reg: st.reg
                            currentUnit: unitName
                            base: anP.stringview
                        )
                        pid0 = optU64Or o: pao0 d: 0
                        if pid0 == 0 then {
                            dop9: ast.nodes.get i: (arg.operation - 1).u64
                            pid0 = dottedTyperefId :ast :st op: dop9
                        }
                    }
                    if pid0 > 0 then pk = primaryName.copy
                }
            }
            skipFrom: false
            if allowFrom when pk.stringview == "from" then skipFrom = true
            if pk.length > 0 when (skipFrom) == false then {
                isP: st.reg.isGenericParamOf typeKey: tk.stringview name: pk.stringview
                if isP then {
                    if (seen.has item: pk.copy) when (allowFrom) == false then {
                        pkc: pk.copy
                        m1: "duplicate type argument '\{pkc}'"
                        en1: String
                        eh1: String
                        (addErrorH
                            :st
                            nodeid: arg.nodeid
                            lineno: arg.lineno
                            colno: arg.colno
                            e: zast.err.genericError
                            msg: m1
                            note: en1
                            hint: eh1
                            width: pk.length.u32.orPanic
                        )
                        ok = false
                    } else {
                        seen.add item: pk.copy
                    }
                } else {
                    isField: false
                    ci: u64
                    cn: childNames.length
                    for ci < cn loop {
                        cnm: childNames.get i: ci
                        if cnm.stringview == pk.stringview then isField = true
                        ci = ci + 1
                    }
                    if (isField) == false when pk.stringview == "capacity" then {
                        # `capacity:` on a builtin container construction is a
                        # create argument (`Type arg:` is `Type.create arg:`);
                        # native create params carry no modeled children, so
                        # the label is admitted by template identity.
                        if tplId == (builtinTidT :ast ty: st.typing reg: st.reg base: "List") then {
                            isField = true
                        }
                        if tplId == (builtinTidT :ast ty: st.typing reg: st.reg base: "Map") then {
                            isField = true
                        }
                        if tplId == (builtinTidT :ast ty: st.typing reg: st.reg base: "Set") then {
                            isField = true
                        }
                    }
                    if (isField) == false then {
                        pkc2: pk.copy
                        m2: "unknown type argument '\{pkc2}' for generic type '\{tname}'"
                        plist: st.reg.genericParamNamesOf typeKey: tk.stringview
                        note2: "valid type parameters: ".string
                        pi: u64
                        pn2: plist.length
                        for pi < pn2 loop {
                            if pi > 0 then note2.append s: ", "
                            pnm: plist.get i: pi
                            note2.append s: pnm.stringview
                            pi = pi + 1
                        }
                        eh2: String
                        (addErrorH
                            :st
                            nodeid: arg.nodeid
                            lineno: arg.lineno
                            colno: arg.colno
                            e: zast.err.genericError
                            msg: m2
                            note: note2
                            hint: eh2
                            width: pk.length.u32.orPanic
                        )
                        ok = false
                    }
                }
            }
        } else null
        argIdx = argIdx + 1
    }
    return ok
}

# methodReturnOf -- a method FUNCTION type's return type id: the synthesized
# returnTypeId link when set, else the AST method's recorded `out T` ref node
# (funcReturnNode) read through the post-demand stamp.
methodReturnOf: function {st: zenv.ZSymbolTable mid: u64} out optionval u64 is {
    rto: (optionval.none u64)
    {
        t: st.reg.typeById.get key: mid
        match (
            t
        ) case some then {
            rto = t.returnTypeId
        } case none then null
    }
    match (
        rto
    ) case some then {
        return (optionval.some rto)
    } case none then null
    rn: st.typing.funcReturnNode.get key: mid
    match (
        rn
    ) case some then {
        nt: st.typing.nodeType.get key: rn
        match (
            nt
        ) case some then {
            return (optionval.some nt)
        } case none then null
    } case none then null
    return (optionval.none u64)
}

# iterWrapperElem -- when a type is an Option / optionval / OptionView instance,
# its element (`some` child) type id.
iterWrapperElem: function {
    ast: Ast
    st: zenv.ZSymbolTable
    unitName: StringView
    wid: u64
} out optionval u64 is {
    origin: u64
    goo: (optionval.none u64)
    {
        t: st.reg.typeById.get key: wid
        match (
            t
        ) case some then {
            goo = t.genericOriginId
        } case none then null
    }
    match (
        goo
    ) case some then {
        origin = goo
    } case none then null
    if origin == 0 then return (optionval.none u64)
    isWrapper: false
    oo: walkLookupTyperef :ast ty: st.typing reg: st.reg currentUnit: unitName base: "Option"
    match (
        oo
    ) case some then {
        if origin == oo then isWrapper = true
    } case none then null
    vo: walkLookupTyperef :ast ty: st.typing reg: st.reg currentUnit: unitName base: "optionval"
    match (
        vo
    ) case some then {
        if origin == vo then isWrapper = true
    } case none then null
    wo: walkLookupTyperef :ast ty: st.typing reg: st.reg currentUnit: unitName base: "OptionView"
    match (
        wo
    ) case some then {
        if origin == wo then isWrapper = true
    } case none then null
    if isWrapper then return (st.typing.childOfId parentTypeId: wid nameId: wkSome)
    return (optionval.none u64)
}

# isOptionViewMono -- true when a type is an OptionView instance (its per-
# iteration values are borrowed views, so the loop var binds BORROWED).
isOptionViewMono: function {
    ast: Ast
    st: zenv.ZSymbolTable
    unitName: StringView
    wid: u64
} out bool is {
    origin: u64
    goo: (optionval.none u64)
    {
        t: st.reg.typeById.get key: wid
        match (
            t
        ) case some then {
            goo = t.genericOriginId
        } case none then null
    }
    match (
        goo
    ) case some then {
        origin = goo
    } case none then null
    if origin == 0 then return false
    wo: walkLookupTyperef :ast ty: st.typing reg: st.reg currentUnit: unitName base: "OptionView"
    match (
        wo
    ) case some then {
        return origin == wo
    } case none then {
        return false
    }
}

# methodHasNoUserArgs -- true when a method type has no user-visible parameters
# beyond the implicit receiver: no children at all (synthesized collection
# methods), or a single child that IS the receiver -- `this`, or the long-form
# receiver recorded in thisParamName (`stringview: function {t: this.lock}`).
# optStrIsSome -- whether an optional string is present.
optStrIsSome: function {o: Option String} out bool is {
    match (
        o
    ) case some then {
        return true
    } case none then {
        return false
    }
}

optStrEquals: function {o: Option String s: StringView} out bool is {
    match (
        o
    ) case some then {
        return o.stringview == s
    } case none then {
        return false
    }
}

# optStrOrEmpty -- copy of the option's payload, or "" when none.
optStrOrEmpty: function {o: Option String} out String is {
    match (
        o
    ) case some then {
        return (o.copy)
    } case none then {
        return ("".string)
    }
}

# optU64Or / optBoolOr -- the option's payload, or the given default. Collapse
# the some/none match at get-or-default sites (match narrowing needs a
# bare-name subject, so inline gets can't match directly).
optU64Or: function {o: optionval u64 d: u64} out u64 is {
    match (
        o
    ) case some then {
        return o
    } case none then {
        return d
    }
}

optBoolOr: function {o: optionval bool d: bool} out bool is {
    match (
        o
    ) case some then {
        return o
    } case none then {
        return d
    }
}

# createDottedBaseId -- the base atom's node id when a dotted path's child is
# `create` (explicit construction: `T.create` is bare-name construction).
createDottedBaseId: function {ast: Ast n: Node} out optionval u32 is {
    match (
        n
    ) case dottedpath then {
        ccn: atomName :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if ccn.stringview == "create" then return (optionval.some n.parent)
    } else null
    return (optionval.none u32)
}

# rootNameOf -- a value path's root atom name (unwrapping expressions and
# dotted segments), or "".
rootNameOf: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case atomid then {
        return (zast.nameTextCopy :ast ref: n.name)
    } case expression then {
        return (rootNameOf :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case dottedpath then {
        return (rootNameOf :ast n: (ast.nodes.get i: (n.parent - 1).u64))
    } else {
        return "".string
    }
}

# dottedChildName -- a dotted path's child atom name, or "".
dottedChildName: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        return (atomName :ast n: (ast.nodes.get i: (n.child - 1).u64))
    } else {
        return "".string
    }
}

# dottedChildNameId -- the pool id of a dotted path's child atom name
# (0 when the shape differs).
dottedChildNameId: function {ast: Ast n: Node} out u64 is {
    match (
        n
    ) case dottedpath then {
        return (atomNameId :ast n: (ast.nodes.get i: (n.child - 1).u64))
    } else {
        return 0
    }
}

# unionCreateArmName -- the constructed arm's name when a value is a tagged
# subtype construction (a UNION_CREATE-stamped call's dotted child), or "".
unionCreateArmName: function {ast: Ast st: zenv.ZSymbolTable n: Node} out String is {
    match (
        n
    ) case expression then {
        return (unionCreateArmName :ast :st n: (ast.nodes.get i: (n.expression - 1).u64))
    } case dottedpath then {
        dgot: st.typing.dpTaggedParent.get key: n.nodeid.u64
        match (
            dgot
        ) case some then {
            return (atomName :ast n: (ast.nodes.get i: (n.child - 1).u64))
        } case none then {
            return "".string
        }
    } case call then {
        kOpt: st.typing.callKind.get key: n.nodeid.u64
        isUC: false
        match (
            kOpt
        ) case some then {
            if kOpt == zast.callkind.unionCreate then isUC = true
        } case none then null
        if isUC then return (dottedChildName :ast n: (ast.nodes.get i: (n.callable - 1).u64))
        return "".string
    } else {
        return "".string
    }
}

# borrowDottedBaseId -- the base atom's node id when a dotted path's child is
# `borrow` (a protocol/facet borrow projection), or none.
borrowDottedBaseId: function {ast: Ast n: Node} out optionval u32 is {
    match (
        n
    ) case dottedpath then {
        bcn: atomName :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if bcn.stringview == "borrow" then return (optionval.some n.parent)
    } else null
    return (optionval.none u32)
}

# valueNoCoerce -- checkValue minus the value-position auto-call coercion
# (construction arguments take method REFERENCES for function-typed fields).
valueNoCoerce: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    n: Node
} out u64 is {
    match (
        n
    ) case expression then {
        ev: valueNoCoerce :st :unitName :ast :unitBody n: (ast.nodes.get i: (n.expression - 1).u64)
        if ev > 0 then {
            sete: ev
            st.typing.nodeType.set key: n.nodeid.u64 value: sete
        }
        return ev
    } case dottedpath then {
        return (checkDotted :st :unitName :ast :unitBody dp: n coerce: false)
    } else {
        return (checkValue :st :unitName :ast :unitBody node: n)
    }
}

# checkProjectionCreate -- `F.create from: expr` / `P.borrow from: expr` on a
# facet or protocol: a projection, not a call. No CALL scope; the from-argument
# walks in the current scope (a facet copies its source -- nothing is consumed);
# the value is the facet/protocol type.
checkProjectionCreate: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    call: zast.CallData
    pjId: u64
    consumes: bool
    borrows: bool
} out u64 is {
    found: false
    aiter: call.arguments.iterate
    for argId9: aiter loop {
        arg: ast.nodes.get i: (argId9 - 1).u64
        match (
            arg
        ) case namedoperation then {
            if (found) == false then {
                an: zast.nameTextCopy :ast ref: arg.name
                isFrom: false
                if an.length == 0 then {
                    isFrom = true
                } else {
                    if an.stringview == "from" then isFrom = true
                }
                if isFrom then {
                    found = true
                    pvt: (checkValue
                        :st
                        :unitName
                        :ast
                        :unitBody
                        node: (ast.nodes.get i: (arg.operation - 1).u64)
                    )
                    if pvt > 0 then {
                        if borrows then {
                            # The from-path's root is the borrow origin (a
                            # bare name or a `.lock`/`.borrow` projection) --
                            # the projection borrows, it never hoists.
                            pbr: rootNameOf :ast n: (ast.nodes.get i: (arg.operation - 1).u64)
                            if pbr.length > 0 then {
                                pbv2: st.lookupVarId name: pbr.stringview
                                match (
                                    pbv2
                                ) case some then {
                                    drainPendingBorrow :st
                                    pbc2: pbr.copy
                                    st.typing.pendingBorrowPath.append pbc2
                                } case none then null
                            }
                        } else {
                            if (argIsTrivial
                                :ast
                                op: (ast.nodes.get i: (arg.operation - 1).u64)
                            ) then {
                                pbn: bareAtomName :ast n: (ast.nodes.get i: (arg.operation - 1).u64)
                                if pbn.length > 0 then {
                                    pbv: st.lookupVarId name: pbn.stringview
                                    match (
                                        pbv
                                    ) case some then {
                                        if consumes then {
                                            (st.invalidate
                                                name: pbn.stringview
                                                loc: (optionval.none ztypes.zsrcpos)
                                            )
                                        }
                                    } case none then null
                                }
                            } else {
                                tnm3: (hoistArg
                                    :ast
                                    :st
                                    argNode: (ast.nodes.get i: (arg.operation - 1).u64)
                                    argType: pvt
                                    paramType: 0
                                    :consumes
                                )
                            }
                        }
                    }
                }
            }
        } else null
    }
    setpj: pjId
    st.typing.nodeType.set key: call.nodeid.u64 value: setpj
    pjk9: zast.callkind.protocolCreate
    if (st.reg.typetypeOf typeId: pjId) == ztypes.ztypetype.facetType then {
        if borrows then {
            pjk9 = zast.callkind.facetBorrow
        } else {
            pjk9 = zast.callkind.facetCreate
        }
    } else {
        if borrows then pjk9 = zast.callkind.protocolBorrow
    }
    st.typing.callKind.set key: call.nodeid.u64 value: pjk9
    return pjId
}

# metaCreateBaseId -- the base atom's node id when a callable is the dotted
# `meta.create` (the enclosing type's raw allocator), or none.
metaCreateBaseId: function {ast: Ast n: Node} out optionval u32 is {
    match (
        n
    ) case dottedpath then {
        pn: atomName :ast n: (ast.nodes.get i: (n.parent - 1).u64)
        cn2: atomName :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if pn.stringview == "meta" when cn2.stringview == "create" then {
            return (optionval.some (nodeId n: (ast.nodes.get i: (n.parent - 1).u64)))
        }
    } else null
    return (optionval.none u32)
}

# typedefBaseOf -- a typedef type's base type id (the recorded base name,
# copiedMapStr -- owned copy of a u64-keyed map entry ("" when absent):
# confines the value view to this frame so the caller can immediately
# re-lend the map's container (fnReturnTidOf-style view scoping).
copiedMapStr: function {m: (Map u64 value: String) key: u64} out String is {
    vo: m.get :key
    match (
        vo
    ) case some then {
        return vo.copy
    } case none then {
        return "".string
    }
}

# resolved at read time -- the resolver runs before the base's unit), or 0.
typedefBaseOf: function {ast: Ast st: zenv.ZSymbolTable unitName: StringView tid: u64} out u64 is {
    bn9: copiedMapStr m: st.typing.typedefBaseName key: tid
    if bn9.length == 0 then return 0
    return (optU64Or
        o: (walkLookupTyperef
            :ast
            ty: st.typing
            reg: st.reg
            currentUnit: unitName
            base: bn9.stringview
        )
        d: 0
    )
}

# typedefBaseMangledOf -- a typedef type's base INSTANCE id (the recorded
# mangled name resolved at read time -- monos register in resolved once
# minted), or 0.
typedefBaseMangledOf: function {
    ast: Ast
    st: zenv.ZSymbolTable
    unitName: StringView
    tid: u64
} out u64 is {
    bm9: copiedMapStr m: st.typing.typedefBaseMangled key: tid
    if bm9.length == 0 then return 0
    return (optU64Or
        o: (walkLookupTyperef
            :ast
            ty: st.typing
            reg: st.reg
            currentUnit: unitName
            base: bm9.stringview
        )
        d: 0
    )
}

# checkTypedefCreate -- `T.create from: expr` / bare `T expr` on a typedef:
# an owned cast, not a call. No CALL scope; the from-argument walks in the
# current scope (a non-trivial one hoists there) and is consumed; the value
# is the typedef type.
checkTypedefCreate: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    call: zast.CallData
    tdId: u64
} out u64 is {
    found: false
    aiter: call.arguments.iterate
    for argId9: aiter loop {
        arg: ast.nodes.get i: (argId9 - 1).u64
        match (
            arg
        ) case namedoperation then {
            if (found) == false then {
                an: zast.nameTextCopy :ast ref: arg.name
                isFrom: false
                if an.length == 0 then {
                    isFrom = true
                } else {
                    if an.stringview == "from" then isFrom = true
                }
                if isFrom then {
                    found = true
                    vt: (checkValue
                        :st
                        :unitName
                        :ast
                        :unitBody
                        node: (ast.nodes.get i: (arg.operation - 1).u64)
                    )
                    if vt > 0 then {
                        if (argIsTrivial :ast op: (ast.nodes.get i: (arg.operation - 1).u64)) then {
                            bn: bareAtomName :ast n: (ast.nodes.get i: (arg.operation - 1).u64)
                            if bn.length > 0 then {
                                bvo: st.lookupVarId name: bn.stringview
                                match (
                                    bvo
                                ) case some then {
                                    (st.invalidate
                                        name: bn.stringview
                                        loc: (optionval.none ztypes.zsrcpos)
                                    )
                                } case none then null
                            }
                        } else {
                            tnm: (hoistArg
                                :ast
                                :st
                                argNode: (ast.nodes.get i: (arg.operation - 1).u64)
                                argType: vt
                                paramType: 0
                                consumes: true
                            )
                        }
                    }
                }
            }
        } else null
    }
    settd: tdId
    st.typing.nodeType.set key: call.nodeid.u64 value: settd
    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.typedefCreate
    return tdId
}

# checkTypedefBorrow -- `T.borrow from: expr` on a typedef: a borrowed
# cast. No CALL scope, no take; the from-argument walks in the current
# scope and the binding borrows the argument's source (the lifted view
# origin when the argument is itself a borrowed view, else the
# argument's own path).
checkTypedefBorrow: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    call: zast.CallData
    tdId: u64
} out u64 is {
    found: false
    aiter: call.arguments.iterate
    for argId9: aiter loop {
        arg: ast.nodes.get i: (argId9 - 1).u64
        match (
            arg
        ) case namedoperation then {
            if (found) == false then {
                an: zast.nameTextCopy :ast ref: arg.name
                isFrom: false
                if an.length == 0 then {
                    isFrom = true
                } else {
                    if an.stringview == "from" then isFrom = true
                }
                if isFrom then {
                    found = true
                    vt: (checkValue
                        :st
                        :unitName
                        :ast
                        :unitBody
                        node: (ast.nodes.get i: (arg.operation - 1).u64)
                    )
                    if vt > 0 then {
                        if st.typing.pendingBorrowPath.length <= 0 then {
                            tup: (List String)
                            (appendValueTuple
                                :ast
                                n: (ast.nodes.get i: (arg.operation - 1).u64)
                                dst: tup
                            )
                            ti: u64
                            tn: tup.length
                            for ti < tn loop {
                                te: tup.get i: ti
                                tec: te.copy
                                st.typing.pendingBorrowPath.append tec
                                ti = ti + 1
                            }
                        }
                    }
                }
            }
        } else null
    }
    settd: tdId
    st.typing.nodeType.set key: call.nodeid.u64 value: settd
    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.typedefBorrow
    return tdId
}

# methodHasThisReceiver -- a FUNCTION child bound to a receiver: a declared
# `this` param (shorthand) or a recorded long-form receiver name. A this-less
# function member is a callable field, not a method.
methodHasThisReceiver: function {st: zenv.ZSymbolTable mid: u64} out bool is {
    if (st.typing.hasChildId parentTypeId: mid nameId: wkThis.u64) then return true
    zo: st.reg.typeById.get key: mid
    match (
        zo
    ) case some then {
        return (optStrIsSome o: zo.thisParamName)
    } case none then {
        return false
    }
}

methodHasNoUserArgs: function {ast: Ast st: zenv.ZSymbolTable mid: u64} out bool is {
    cnt: st.typing.childCount parentTypeId: mid
    if cnt == 0 then return true
    if cnt != 1 then return false
    soleName: String
    soleId: u64
    bm9: st.typing.childIndex.get key: mid
    match (
        bm9
    ) case some then {
        with rmit9: bm9.rows.iterate do for rmi9: rmit9 loop {
            tc: st.typing.typeChild.get i: rmi9
            snB9: ast.names.texts.get i: (tc.nameId - 1).u64
            soleName = snB9.copy
            soleId = tc.nameId
        }
    } case none then null
    if soleId == wkThis.u64 then return true
    zo: st.reg.typeById.get key: mid
    match (
        zo
    ) case some then {
        return (optStrEquals o: zo.thisParamName s: soleName.stringview)
    } case none then {
        return false
    }
}

# fnAutoCallable -- a bare reference to this function is a zero-argument
# auto-call: it has no user parameters, or every non-receiver parameter
# carries a default the site can fill. The strict no-user-args predicate
# stays separate for its other gates (fnptr-field reads, for-iterators).
fnAutoCallable: function {ast: Ast st: zenv.ZSymbolTable mid: u64} out bool is {
    if (methodHasNoUserArgs :ast :st :mid) then return true
    names: (List String)
    ids: (List u64)
    idsNm: (List u64)
    dataFieldNames :ast :st tid: mid :names :ids nameIds: idsNm
    thisPn9: String
    {
        zo9: st.reg.typeById.get key: mid
        match (
            zo9
        ) case some then {
            thisPn9 = optStrOrEmpty o: zo9.thisParamName
        } case none then null
    }
    n9: names.length
    i9: u64
    userSeen9: false
    for i9 < n9 loop {
        pname: names.get i: i9
        pnameId: idsNm.get i: i9
        i9 = i9 + 1
        isRecv9: false
        if pnameId == wkThis.u64 then isRecv9 = true
        if thisPn9.length > 0 when thisPn9.stringview == pname.stringview then isRecv9 = true
        if (isRecv9) == false then {
            userSeen9 = true
            hd9: st.typing.hasChildDefaultId parentTypeId: mid nameId: pnameId
            if (hd9) == false then return false
        }
    }
    return userSeen9
}

# bareFnRefError -- a bare reference to a function with required parameters
# is a call missing its arguments (a reference needs the explicit '.take').
bareFnRefError: function {
    ast: Ast
    st: zenv.ZSymbolTable
    nodeid: u32
    lineno: u32
    colno: u32
    width: u32
    fid: u64
} is {
    prov9: (List String)
    misN9: (List String)
    misI9: (List u64)
    (missingCtorFields
        :ast
        :st
        funcId: fid
        isCtor: false
        provided: prov9
        posCount: 0
        missingNames: misN9
        missingIds: misI9
    )
    lst9: String
    li9: u64
    ln9: misN9.length
    for li9 < ln9 loop {
        mn9: misN9.get i: li9
        mid9: misI9.get i: li9
        li9 = li9 + 1
        mtn9: typeNameOf :st tid: mid9
        mnc9: mn9.copy
        mtc9: mtn9.copy
        if lst9.length > 0 then lst9.append ", "
        ln1: "'\{mnc9}' (type: \{mtc9})"
        lst9.append ln1.stringview
    }
    fn9: typeNameOf :st tid: fid
    fnc9: fn9.copy
    m9: "a bare reference to '\{fnc9}' calls it: missing required arguments \{lst9}"
    nt9: "a bare function reference in value position is a call".string
    eh9: "call it with its required arguments, or store a reference with '\{fn9}.take'"
    (addErrorH
        :st
        :nodeid
        :lineno
        :colno
        e: zast.err.callError
        msg: m9
        note: nt9
        hint: eh9
        :width
    )
}

# canonicalChildBase -- a cross-unit narrowed match-arm base can be a shell id
# (distinct from the canonical defining-unit id) whose member children are not
# registered. Find a same-named type in any unit's resolved scope that has the
# named member; 0 when none. Mirrors the emitter's resolveTypeIdByName scan.
canonicalChildBase: function {ast: Ast st: zenv.ZSymbolTable bt: u64 child: StringView} out u64 is {
    nm: typeNameOf :st tid: bt
    if nm.length == 0 then return 0
    uks9: (List String)
    with uit: st.reg.unitNameTid.iterateItems do for ue: uit loop {
        ukc9: ue.key.copy
        uks9.append ukc9
    }
    cands9: (List u64)
    uki9: u64
    ukn9: uks9.length
    for uki9 < ukn9 loop {
        uk9: uks9.get i: uki9
        k: "\{uk9}.\{nm}"
        ro9: resolvedByKey :ast ty: st.typing reg: st.reg key: k
        match (
            ro9
        ) case some then {
            if ro9 != bt then cands9.append ro9
        } case none then null
        uki9 = uki9 + 1
    }
    found: u64
    ci9: u64
    cnn9: cands9.length
    for ci9 < cnn9 loop {
        if found == 0 then {
            cand9: cands9.get i: ci9
            rc9: st.typing.childOf pool: ast.names parentTypeId: cand9 name: child
            match (
                rc9
            ) case some then {
                found = cand9
            } case none then null
        }
        ci9 = ci9 + 1
    }
    return found
}

# markDataRuntimeIndexed -- a data block accessed via `.index` / `.array` needs
# its static array emitted; label accesses fold to constants and don't.
markDataRuntimeIndexed: function {st: zenv.ZSymbolTable tid: u64} is {
    to9: st.reg.typeById.get key: tid
    match (
        to9
    ) case some then {
        to9.runtimeIndexed = true
    } case none then null
}

# checkDotted -- a dotted method reference in a body: type the base, look the
# member up on the base's type, and stamp the dotted node -- with the method's
# return when the method takes no user parameters beyond the receiver (the
# auto-call coercion), else with the method FUNCTION type itself.
# baseIsPrivateCapable -- may a private member be read through this base? True
# when the base is the type's own `this`/same-type receiver (self, inside its
# methods), a `.private` projection, or a read of a `.private`-typed friend
# field. Everything else is external and gated.
baseIsPrivateCapable: function {st: zenv.ZSymbolTable ast: Ast bt: u64 baseNode: Node} out bool is {
    btNm9: typeNameOf :st tid: bt
    if btNm9.length > 0 when st.typing.currentThisName.length > 0 then {
        if st.typing.currentThisName.stringview == btNm9.stringview then return true
    }
    match (
        baseNode
    ) case atomid then {
        anm9: zast.nameTextCopy :ast ref: baseNode.name
        if anm9.stringview == "this" then return true
        vo9: st.lookupVarId name: anm9.stringview
        match (
            vo9
        ) case some then {
            po9: st.typing.variableIsPrivate.get key: vo9
            match (
                po9
            ) case some then {
                return po9
            } case none then {
                return false
            }
        } case none then {
            return false
        }
    } case dottedpath then {
        cnm9: atomName :ast n: (ast.nodes.get i: (baseNode.child - 1).u64)
        if cnm9.stringview == "private" then return true
        pbNode9: ast.nodes.get i: (baseNode.parent - 1).u64
        pbNid9: nodeId n: pbNode9
        pbType9: optU64Or o: (st.typing.nodeType.get key: pbNid9.u64) d: 0
        if pbType9 > 0 when (st.typing.isChildGrantsPrivate
            pool: ast.names
            parentTypeId: pbType9
            name: cnm9.stringview
        ) then return true
        return false
    } else {
        return false
    }
}

# memberStrictType -- whether `bt` should get the strict unknown-member check:
# a concrete record/class/union/variant that is either a user type or a
# non-generic stdlib type (numeric scalars, bool, String, StringView -- their
# method sets are fully declared). Generic instances (List/Map/Set monos) and
# bare shells stay lenient because their members are minted per-instantiation.
memberStrictType: function {st: zenv.ZSymbolTable bt: u64} out bool is {
    tt9: st.reg.typetypeOf typeId: bt
    isConc9: false
    if tt9 == ztypes.ztypetype.recordType then isConc9 = true
    if tt9 == ztypes.ztypetype.classType then isConc9 = true
    if tt9 == ztypes.ztypetype.unionType then isConc9 = true
    if tt9 == ztypes.ztypetype.variantType then isConc9 = true
    if (isConc9) == false then return false
    if (isUserShadowElem ty: st.typing reg: st.reg elemTid: bt) then return true
    duo9: st.typing.definedInUnit.get key: bt
    hasUnit9: false
    match (
        duo9
    ) case some then {
        hasUnit9 = true
    } case none then null
    if (hasUnit9) == false then return false
    zo9: st.reg.typeById.get key: bt
    match (
        zo9
    ) case some then {
        if zo9.isgeneric then return false
        goo9: zo9.genericOriginId
        match (
            goo9
        ) case some then {
            return false
        } case none then null
    } case none then {
        return false
    }
    return true
}

checkDotted: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    dp: zast.DottedPathData
    coerce: bool
} out u64 is {
    # Numeric dotted suffix (`1.u8`): when the child names a non-function
    # type, the path is a typed-literal cast -- the parent atom coerces to
    # the suffix type and the path carries it.
    castBase: atomName :ast n: (ast.nodes.get i: (dp.parent - 1).u64)
    if (isNumericLiteralName name: castBase.stringview) then {
        castChild: atomName :ast n: (ast.nodes.get i: (dp.child - 1).u64)
        castOpt: (walkLookupTyperef
            :ast
            ty: st.typing
            reg: st.reg
            currentUnit: unitName
            base: castChild.stringview
        )
        match (
            castOpt
        ) case some then {
            if (st.reg.typetypeOf typeId: castOpt) != ztypes.ztypetype.functionType then {
                # a compile-time-constant conversion is checked statically: a
                # lossy literal cast is an error (300.u8, 3.5.u8, an int beyond
                # a float's mantissa). Reuse the numeric parser's range +
                # float-suffix checks; add the int->float exact-mantissa check.
                if (isNumericTypeName name: castChild.stringview) then {
                    isChar9c: castBase.stringview.startsWith "0c"
                    if (isChar9c) == false then {
                        chk9c: "\{castBase.stringview}\{castChild.stringview}"
                        pn9c: ztypes.parseNumber numstr: chk9c.stringview
                        if pn9c.err.length > 0 then {
                            (addError
                                :st
                                nodeid: dp.nodeid
                                lineno: dp.lineno
                                colno: dp.colno
                                e: zast.err.typeError
                                msg: pn9c.err
                            )
                        } else {
                            if (ztypes.isFloatKind k: pn9c.kind) then {
                                baseDot9c: castBase.contains "."
                                exact9c: true
                                if baseDot9c then {
                                    exact9c = ztypes.floatFitsFloat value: pn9c.fval k: pn9c.kind
                                } else {
                                    ivp9c: ztypes.parseNumber numstr: castBase.stringview
                                    ivr9c: ivp9c.ival.i64
                                    match (
                                        ivr9c
                                    ) case ok then {
                                        exact9c = ztypes.intFitsFloat value: ivr9c k: pn9c.kind
                                    } case err then {
                                        exact9c = false
                                    }
                                }
                                if (exact9c) == false then {
                                    em9c: "Value \{castBase.stringview} not exactly representable as \{castChild.stringview}"
                                    (addError
                                        :st
                                        nodeid: dp.nodeid
                                        lineno: dp.lineno
                                        colno: dp.colno
                                        e: zast.err.typeError
                                        msg: em9c
                                    )
                                }
                            }
                        }
                    }
                }
                castPid: nodeId n: (ast.nodes.get i: (dp.parent - 1).u64)
                setcp: castOpt
                st.typing.nodeType.set key: castPid.u64 value: setcp
                setcd: castOpt
                st.typing.nodeType.set key: dp.nodeid.u64 value: setcd
                return castOpt
            }
        } case none then null
    }
    # the base of a dotted path is a reference, not a bare value: a type
    # name there must not construct (Counter.create, unit.Type.arm). Only
    # name-shaped bases suppress -- an expression base walks normally so
    # atoms inside its args still stamp.
    supPrev9: st.typing.suppressBareCtor
    dpk9: zast.kindOf :ast id: dp.parent
    if dpk9 == zast.astkind.atomid then st.typing.suppressBareCtor = true
    if dpk9 == zast.astkind.dottedpath then st.typing.suppressBareCtor = true
    # a `.take` child makes the base a function REFERENCE: the base walk
    # must not auto-call it
    supFnPrev9: st.typing.suppressFnAutoCall
    tknm9: atomName :ast n: (ast.nodes.get i: (dp.child - 1).u64)
    if tknm9.stringview == "take" then st.typing.suppressFnAutoCall = true
    bt: checkValue :st :unitName :ast :unitBody node: (ast.nodes.get i: (dp.parent - 1).u64)
    st.typing.suppressFnAutoCall = supFnPrev9
    st.typing.suppressBareCtor = supPrev9
    if bt == 0 then {
        # an unresolved bare-name base may be a unit-qualified member
        # path (io.stdout): the side map types the base as the UNIT type.
        ubn: atomName :ast n: (ast.nodes.get i: (dp.parent - 1).u64)
        if ubn.length > 0 then {
            ubo: st.reg.unitNameTid.get key: ubn
            match (
                ubo
            ) case some then {
                bt = ubo
                ubp: nodeId n: (ast.nodes.get i: (dp.parent - 1).u64)
                if ubp > 0 then {
                    setub: ubo
                    st.typing.nodeType.set key: ubp.u64 value: setub
                }
            } case none then null
        }
        if bt == 0 then return 0
    }
    # A literal base materialises before member lookup (`5.iterate` is
    # i64.iterate); the parent node restamps at the concrete default.
    if (isLiteralTypeId :st tid: bt) then {
        mbt9: materialiseLiteral :ast :st :unitName t: bt
        if mbt9 != bt then {
            bt = mbt9
            pid9: nodeId n: (ast.nodes.get i: (dp.parent - 1).u64)
            if pid9 > 0 then {
                setp9: mbt9
                st.typing.nodeType.set key: pid9.u64 value: setp9
            }
        }
    }
    cn: atomName :ast n: (ast.nodes.get i: (dp.child - 1).u64)
    if cn.length == 0 then return 0
    cnId9: atomNameId :ast n: (ast.nodes.get i: (dp.child - 1).u64)
    # `.private` / `.public` access markers: the path carries the base's
    # type (the access view is a dump-filtered shell, not a member).
    if cn.stringview == "private" then {
        # Gate B: a `.private` view may only be produced from a base that
        # already holds private access -- the type's own `this`/same-type
        # receiver (the class minting it), or an existing `.private` handle (a
        # friend forwarding what it was given, per spec). External code holding
        # only a public value cannot mint one -- E0102.
        baseGN9: ast.nodes.get i: (dp.parent - 1).u64
        if (baseIsPrivateCapable :st :ast :bt baseNode: baseGN9) == false then {
            pcNode9: ast.nodes.get i: (dp.child - 1).u64
            pcnid9: nodeId n: pcNode9
            pcln9: nodeLine n: pcNode9
            pccl9: nodeCol n: pcNode9
            btNm9: typeNameOf :st tid: bt
            btNc9: btNm9.copy
            pmsg9: "'.private' of '\{btNc9}' may only be taken by '\{btNm9}' or a holder of its '.private' handle"
            (addErrorH
                :st
                nodeid: pcnid9
                lineno: pcln9
                colno: pccl9
                e: zast.err.privateEscape
                msg: pmsg9
                note: "".string
                hint: "".string
                width: cn.length.u32.orPanic
            )
        }
        setpv: bt
        st.typing.nodeType.set key: dp.nodeid.u64 value: setpv
        return bt
    }
    if cn.stringview == "public" then {
        setpb: bt
        st.typing.nodeType.set key: dp.nodeid.u64 value: setpb
        return bt
    }
    if cn.stringview == "lock" then {
        setlk: bt
        st.typing.nodeType.set key: dp.nodeid.u64 value: setlk
        return bt
    }
    # `.stringview` on a StringView is an identity no-op and is rejected --
    # the value is already a StringView.
    if cn.stringview == "stringview" then {
        if bt == (builtinTidTc :ast :st base: "StringView") then {

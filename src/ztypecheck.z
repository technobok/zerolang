                    # `(xs.get i).copy`): an owning outer call consumes it --
                    # only the push blocks below re-establish one.
                    drainPendingBorrow :st
                    xroot: st.typing.lastLockParamRoot.copy
                    if xroot.length > 0 then {
                        st.typing.lastLockParamRoot = "".string
                        drainPendingBorrow :st
                        st.typing.pendingBorrowPath.append xroot
                    }
                    if (optBoolOr o: (st.typing.funcReturnsBorrow.get key: dro) d: false) then {
                        rtupB: (List String)
                        xq49: ast.nodes.get i: (call.callable - 1).u64
                        methodReceiverTuple :ast n: xq49 dst: rtupB
                        pushedB: false
                        if rtupB.length > 0 then {
                            rvoB: st.lookupVarId name: (rtupB.get i: 0).stringview
                            match (
                                rvoB
                            ) case some then {
                                drainPendingBorrow :st
                                with tib: rtupB.iterate do for segB: tib loop {
                                    sgc: segB.copy
                                    st.typing.pendingBorrowPath.append sgc
                                }
                                if (returnIsIteratorTid :st tid: mres) == false then {

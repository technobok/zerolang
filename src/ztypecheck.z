                    # emitted (unknown/duplicate by validation, or cannot-infer
                    # by inferGenericConstruction): resolve to the template so a
                    # single diagnostic stands without a downstream cascade.
                    if st.typing.errors.length > errB9 then {
                        sttE9: funcId
                        st.typing.nodeType.set key: call.nodeid.u64 value: sttE9
                        return funcId
                    }
                }
                gr: checkGenericCall :st :unitName :ast :unitBody :call :funcId
                result = gr
                if gr > 0 then {
                    setgc: gr
                    st.typing.nodeType.set key: call.nodeid.u64 value: setgc
                }
                if cn.stringview == "panic" then {
                    calid2: nodeId n: (ast.nodes.get i: (call.callable - 1).u64)
                    setpk: funcId
                    st.typing.nodeType.set key: calid2.u64 value: setpk
                    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.panicCall
                }
                if cn.stringview == "error" then {
                    calid3: nodeId n: (ast.nodes.get i: (call.callable - 1).u64)
                    seter: funcId
                    st.typing.nodeType.set key: calid3.u64 value: seter
                    st.typing.callKind.set key: call.nodeid.u64 value: zast.callkind.errorCall
                }
            } else {
                giter: call.arguments.iterate
                for gargId9: giter loop {
                    garg: ast.nodes.get i: (gargId9 - 1).u64
                    match (
                        garg
                    ) case namedoperation then {
                        (checkValue
                            :st
                            :unitName
                            :ast
                            :unitBody
                            node: (ast.nodes.get i: (garg.operation - 1).u64)
                        )
                    } else null
                }
            }
        }
    }
    return result
}

# checkGenericCall -- a call to a generic user function: walk the value args,
# infer the type-param bindings (explicit `param: Type` args, else each value
# arg's materialised type through the parameter it feeds), mint the instance
# (children substituted; return substituted from the recorded `out` placeholder
# name), synthesize the clone scope on first instantiation (empty, named by the
# instance, unreachable per the template body's syntactic divergence -- bodied
# templates only, so native generics like print add no scope), stamp the
# callable with the instance, and resolve to the instance's return. Nested
# control flow inside generic bodies needs a real clone walk and is deferred.
checkGenericCall: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    call: zast.CallData
    funcId: u64
} out u64 is {
    gparams: (List String)
    with gpiter: st.typing.typeGenericArg.iterate do for gp: gpiter loop {
        if gp.parentTypeId == funcId then {
            gpn: gp.paramName.copy
            gparams.append gpn
        }
    }
    pNames: (List String)
    pHolderIds: (List u64)
    {
        gcb9: st.typing.childIndex.get key: funcId
        match (
            gcb9
        ) case some then {
            with gcit9: gcb9.rows.iterate do for gcr9: gcit9 loop {
                tc: st.typing.typeChild.get i: gcr9
                cto: st.typing.childTypeById.get key: tc.childNameId
                match (
                    cto
                ) case some then {
                    # the receiver is implicit at method call sites: keep it
                    # out of the positional holder list so a label-free arg
                    # maps to the first USER param (T holders included)
                    pnB9: ast.names.texts.get i: (tc.nameId - 1).u64
                    if pnB9.stringview != "this" then {
                        pn2: pnB9.copy
                        pNames.append pn2
                        cto2: cto
                        pHolderIds.append cto2
                    }
                } case none then null
            }
        } case none then null
    }
    pHolders: (List String)
    phi: u64
    phn: pHolderIds.length
    for phi < phn loop {
        hid: pHolderIds.get i: phi
        hn: typeNameOf :st tid: hid
        pHolders.append hn
        phi = phi + 1
    }
    subs: (Map String value: u64)
    posIdx: u64
    aiter: call.arguments.iterate
    for argId9: aiter loop {
        arg: ast.nodes.get i: (argId9 - 1).u64
        match (
            arg
        ) case namedoperation then {
            an2: zast.nameTextCopy :ast ref: arg.name
            isTypeArg: false
            tgi: gparams.iterate
            for gp2: tgi loop {
                if an2.stringview == gp2.stringview then isTypeArg = true
            }
            if isTypeArg then {
                tn3: atomName :ast n: (ast.nodes.get i: (arg.operation - 1).u64)
                to3: (walkLookupTyperef
                    :ast
                    ty: st.typing
                    reg: st.reg
                    currentUnit: unitName
                    base: tn3.stringview
                )
                match (
                    to3
                ) case some then {
                    sk: an2.copy
                    sv: to3
                    subs.set key: sk value: sv
                } case none then null
            } else {
                avt: (checkValue
                    :st
                    :unitName
                    :ast
                    :unitBody
                    node: (ast.nodes.get i: (arg.operation - 1).u64)
                )
                mat: materialiseLiteral :ast :st :unitName t: avt
                holder: ""
                if an2.length > 0 then {
                    hi: u64
                    hn2: pNames.length
                    for hi < hn2 loop {
                        pn3: pNames.get i: hi
                        if an2.stringview == pn3.stringview then {
                            hv: pHolders.get i: hi
                            holder = hv.stringview
                        }
                        hi = hi + 1
                    }
                } else {
                    if posIdx < pHolders.length then {
                        hv2: pHolders.get i: posIdx
                        holder = hv2.stringview
                    }
                }
                posIdx = posIdx + 1
                if holder.length > 0 when mat > 0 then {
                    hk: holder.string
                    hgot: subs.get key: hk
                    match (
                        hgot
                    ) case some then null case none then {
                        sk2: holder.string
                        sv2: mat
                        subs.set key: sk2 value: sv2
                    }
                }
            }
        } else null
    }
    mname: typeNameOf :st tid: funcId
    if mname.length == 0 then return 0
    allOk: true
    gtk4: genericTypeKey ty: st.typing reg: st.reg tid: funcId
    giter2: gparams.iterate
    for gp3: giter2 loop {
        gv: gp3.stringview
        gk: gv.string
        ggot: subs.get key: gk
        match (
            ggot
        ) case some then {
            (checkConstraintSat
                :ast
                ty: st.typing
                reg: st.reg
                typeKey: gtk4.stringview
                paramName: gv
                argTid: ggot
            )
            an4: typeNameOf :st tid: ggot
            mname.append s: "_"
            mname.append s: an4.stringview
        } case none then {
            allOk = false
        }
    }
    if allOk == false then return 0
    if gparams.length == 0 then return 0
    wasNew: false
    nk: mname.copy
    ngot: resolveSystemChild :ast ty: st.typing reg: st.reg name: mname.stringview
    match (
        ngot
    ) case some then null case none then {
        wasNew = true
    }
    vsI9: (Map String value: u64)
    mid: (getOrMintSpec
        :ast
        ty: st.typing
        reg: st.reg
        mainName: unitName
        name: mname.stringview
        templateId: funcId
        :subs
        valSubs: vsI9
        fallbackArg: 0
    )
    rno: st.typing.funcReturnNode.get key: funcId
    match (
        rno
    ) case some then {
        rk2: copiedMapStr m: st.typing.pendingTyperef key: rno
        if rk2.length > 0 then {
            rgot2: subs.get key: rk2
            match (
                rgot2
            ) case some then {
                st.reg.setReturnType typeId: mid value: rgot2
            } case none then {
                rconc: (walkLookupTyperef
                    :ast
                    ty: st.typing
                    reg: st.reg
                    currentUnit: unitName
                    base: rk2.stringview
                )
                match (
                    rconc
                ) case some then {
                    st.reg.setReturnType typeId: mid value: rconc
                } case none then null
            }
        }
    } case none then null
    # A generic-instance return (`out (optionval t: u64)`) has no bare
    # pendingTyperef name, so the sub/name path above leaves the mono's
    # return unset -- a native template has no body walk to heal it later.
    # Heal from the template's resolved return type, respecializing a spec
    # that mentions generic params (mirrors the generic-class method path).
    rhas9: false
    {
        mz9: st.reg.typeById.get key: mid
        match (
            mz9
        ) case some then {
            rmo9: mz9.returnTypeId
            match (
                rmo9
            ) case some then {
                rhas9 = true
            } case none then null
        } case none then null
    }
    if (rhas9) == false then {
        rto9: u64
        {
            rns9: st.typing.funcReturnNode.get key: funcId
            match (
                rns9
            ) case some then {
                rst9: st.typing.nodeType.get key: rns9
                match (
                    rst9
                ) case some then {
                    rto9 = rst9
                } case none then null
            } case none then null
        }
        if rto9 == 0 then {
            tz9: st.reg.typeById.get key: funcId
            match (
                tz9
            ) case some then {
                tro9: tz9.returnTypeId
                match (
                    tro9
                ) case some then {
                    rto9 = tro9
                } case none then null
            } case none then null
        }
        if rto9 > 0 then {
            idSubs9: (Map u64 value: u64)
            rr9: (respecialize
                :ast
                ty: st.typing
                reg: st.reg
                mainName: unitName
                specTid: rto9
                idSubs: idSubs9
            )
            rt9: rto9
            if rr9 > 0 then rt9 = rr9
            if (st.reg.typetypeOf typeId: rt9) != ztypes.ztypetype.genericParam then {
                st.reg.setReturnType typeId: mid value: rt9
            }
        }
    }
    if wasNew then {
        dvo: st.typing.fnBodyDiverges.get key: funcId
        match (
            dvo
        ) case some then {
            csname: "function:\{mname}"
            cm2: st.pushBlock name: csname.stringview
            if dvo then st.markUnreachable
            st.popTo marker: cm2
        } case none then null
    }
    # The arg walk above (checkValue per value arg) can leave a pending
    # borrow from a projection argument (s.stringview): drain it -- the
    # call's result is an OWNED value, so a binding of it must not borrow
    # the argument's source. A view-returning generic native would need to
    # propagate its own borrow here instead.
    drainPendingBorrow :st
    with gsub9: subs.iterateItems do for ge9: gsub9 loop {
        gk9: "\{call.nodeid}:\{ge9.key}"
        st.typing.callGenericBinding.set key: gk9.take value: ge9.value
    }
    calid2: nodeId n: (ast.nodes.get i: (call.callable - 1).u64)
    setc2: mid
    st.typing.nodeType.set key: calid2.u64 value: setc2
    return (optU64Or o: (methodReturnOf :st :mid) d: 0)
}

# subjectAtomName -- a match subject's bare-atom name (narrowing requires a
# simple addressable name): unwrap expression wrappers, "" for dotted/complex
# subjects and numeric atoms.
subjectAtomName: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case expression then {
        return (subjectAtomName :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case atomid then {
        saB9: ast.names.texts.get i: (n.name - 1).u64
        if (isNumericLiteralName name: saB9.stringview) then {
            return "".string
        } else {
            return saB9.copy
        }
    } else {
        return "".string
    }
}

# sumSubtypeNames -- a union/variant's arm names: its children minus the
# synthesized members (functions, the tag data record, enums).
sumSubtypeNames: function {ast: Ast st: zenv.ZSymbolTable sid: u64} out List String is {
    names: (List String)
    cids: (List u64)
    bs9: st.typing.childIndex.get key: sid
    match (
        bs9
    ) case some then {
        with rsit9: bs9.rows.iterate do for rsi9: rsit9 loop {
            tc: st.typing.typeChild.get i: rsi9
            cto: st.typing.childTypeById.get key: tc.childNameId
            match (
                cto
            ) case some then {
                nmB2: ast.names.texts.get i: (tc.nameId - 1).u64
                nm2: nmB2.copy
                names.append nm2
                cto2: cto
                cids.append cto2
            } case none then null
        }
    } case none then null
    arms: (List String)
    i: u64
    n: names.length
    for i < n loop {
        cid: cids.get :i
        tt: st.reg.typetypeOf typeId: cid
        keep: true
        if tt == ztypes.ztypetype.functionType then keep = false
        if tt == ztypes.ztypetype.dataType then keep = false
        if tt == ztypes.ztypetype.tagType then keep = false
        if keep then {
            nm3: names.get :i
            nm4: nm3.copy
            arms.append nm4
        }
        i = i + 1
    }
    return arms
}

# isEmptyBody -- a statement block with no statement lines (an empty
# `{}` or `null` clause body).
isEmptyBody: function {n: Node} out bool is {
    match (
        n
    ) case statement then {
        return n.statements.length == 0
    } else {
        return false
    }
}

# checkCase -- walk a match: push the `match` scope, type the subject, push
# `match_body` (resetting the bare-name subject's narrowing), then per arm an
# `arm:{name}` scope with a shadow-narrowing overlay (the subject resolves to
# the arm payload in the body), tracking diverging arms; an else arm excludes
# the covered subtypes. After popping, an exhaustive all-diverging match
# resolves to `never` (a completing-arm result type lands with a value-match
# example) and each diverging arm's subtype is excluded from the subject in
# the enclosing scope (all-excluded marks it unreachable).
checkCase: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    casenode: zast.CaseData
} out u64 is {
    matchMarker: st.pushBlock name: "match"
    subjT: (checkValue
        :st
        :unitName
        :ast
        :unitBody
        node: (ast.nodes.get i: (casenode.subject - 1).u64)
    )
    # A bare generic-parameter subject (`match t`) is not a value -- resolve it
    # against the enclosing generic context (synthLabel is `{unit}.{type}` for a
    # method, `{unit}.{fn}` for a generic free function or unit) so it stamps as a
    # genericParam and the emitter can dissect it per monomorphised instance.
    if subjT == 0 then {
        gsn9: subjectAtomName :ast n: (ast.nodes.get i: (casenode.subject - 1).u64)
        if gsn9.length > 0 then {
            gkey9: String
            if (st.reg.isGenericParamOf
                typeKey: st.typing.synthLabel.stringview
                name: gsn9.stringview
            ) then {
                gkey9 = st.typing.synthLabel.copy
            } else {
                if (st.reg.isGenericParamOf typeKey: unitName name: gsn9.stringview) then {
                    gkey9 = unitName.string
                }
            }
            if gkey9.length > 0 then {
                pgo9: st.reg.genericParamTidOf typeKey: gkey9.stringview paramName: gsn9.stringview
                match (
                    pgo9
                ) case some then {
                    subjT = pgo9
                } case none then {
                    ptid9: (st.reg.newType
                        name: gsn9.stringview
                        typetype: ztypes.ztypetype.genericParam
                    )
                    (st.reg.setGenericParamTid
                        typeKey: gkey9.stringview
                        paramName: gsn9.stringview
                        tid: ptid9
                    )
                    subjT = ptid9
                }
                gsnid9: nodeId n: (ast.nodes.get i: (casenode.subject - 1).u64)
                if gsnid9 > 0 when subjT > 0 then {
                    setgs9: subjT
                    st.typing.nodeType.set key: gsnid9.u64 value: setgs9
                }
            }
        }
    }
    isSum: false
    if subjT > 0 then {
        stt: st.reg.typetypeOf typeId: subjT
        if stt == ztypes.ztypetype.unionType then isSum = true
        if stt == ztypes.ztypetype.variantType then isSum = true
    }
    isGenericSubj9: false
    if subjT > 0 then {
        if (st.reg.typetypeOf typeId: subjT) == ztypes.ztypetype.genericParam then isGenericSubj9 = true
    }
    # A match dissects a union/variant into its arms (a runtime discriminator
    # test) or a generic parameter into its resolutions (at monomorphisation).
    # Any other subject -- a numeric, string, class, record, or a constant --
    # has no child arms to dissect into.
    if subjT > 0 when (isSum) == false when (isGenericSubj9) == false then {
        subjNode9: ast.nodes.get i: (casenode.subject - 1).u64
        subjTn0: typeNameOf :st tid: subjT
        smsg9: "match subject must be a union, variant, or generic parameter, got '\{subjTn0}'"
        (addError
            :st
            nodeid: (nodeId n: subjNode9)
            lineno: (nodeLine n: subjNode9)
            colno: (nodeCol n: subjNode9)
            e: zast.err.typeError
            msg: smsg9
        )
    }
    targetName: String
    if isSum then {
        tn: subjectAtomName :ast n: (ast.nodes.get i: (casenode.subject - 1).u64)
        targetName = tn
    }
    neverId: u64
    nvOpt: walkLookupTyperef :ast ty: st.typing reg: st.reg currentUnit: unitName base: "never"
    match (
        nvOpt
    ) case some then {
        neverId = nvOpt
    } case none then null
    nullId: (optU64Or
        o: (walkLookupTyperef :ast ty: st.typing reg: st.reg currentUnit: unitName base: "null")
        d: 0
    )
    anyEmpty: false
    st.pushBlock name: "match_body"
    if targetName.length > 0 then st.resetNarrowing name: targetName.stringview
    covered: (List String)
    diverging: (List String)
    armTypes: (List u64)
    allDiverge: true
    cliter: casenode.clauses.iterate
    for clauseId9: cliter loop {
        clause: ast.nodes.get i: (clauseId9 - 1).u64
        match (
            clause
        ) case caseclause then {
            armName: atomName :ast n: (ast.nodes.get i: (clause.matcharm - 1).u64)
            armId9: atomNameId :ast n: (ast.nodes.get i: (clause.matcharm - 1).u64)
            if (isEmptyBody n: (ast.nodes.get i: (clause.statement - 1).u64)) then anyEmpty = true
            # A value-match literal arm wears the subject's concrete type.
            if (isSum) == false then {
                if (isNumericLiteralName name: armName.stringview) when subjT > 0 then {
                    if (isLiteralTypeId :st tid: subjT) == false then {
                        amid9: clause.matcharm
                        if amid9 > 0 then {
                            seta9: subjT
                            st.typing.nodeType.set key: amid9.u64 value: seta9
                        }
                    }
                }
            }
            asname: "arm:\{armName}"
            armMarker: st.pushBlock name: asname.stringview
            # Every arm of a sum subject must name one of its declared arms.
            if isSum when subjT > 0 then {
                armo9: st.typing.childOfId parentTypeId: subjT nameId: armId9
                match (
                    armo9
                ) case some then null case none then {
                    subjTn9: typeNameOf :st tid: subjT
                    amsg9: "type '\{subjTn9}' has no arm '\{armName}'"
                    marm9: ast.nodes.get i: (clause.matcharm - 1).u64
                    (addError
                        :st
                        nodeid: (nodeId n: marm9)
                        lineno: (nodeLine n: marm9)
                        colno: (nodeCol n: marm9)
                        e: zast.err.typeError
                        msg: amsg9
                    )
                }
            }
            if targetName.length > 0 when subjT > 0 then {
                po: st.typing.childOfId parentTypeId: subjT nameId: armId9
                match (
                    po
                ) case some then {
                    (st.narrow
                        pool: ast.names
                        name: targetName.stringview
                        toTypeId: po
                        subtypeName: armName.stringview
                        shadow: true
                    )
                } case none then null
            }
            cstC9: ast.nodes.get i: (clause.statement - 1).u64
            checkStatement :st :unitName :ast :unitBody block: cstC9
            at: lastStmtType :st :ast block: cstC9
            atc: at
            armTypes.append atc
            if at > 0 when at == neverId then {
                dn: armName.copy
                diverging.append dn
            } else {
                allDiverge = false
            }
            cn2: armName.copy
            covered.append cn2
            if st.isUnreachable then st.discardTakenInCurrentScope
            st.popTo marker: armMarker
        } else null
    }
    hasElse: casenode.elseclause > 0
    if hasElse then {
        if (isEmptyBody n: (ast.nodes.get i: (casenode.elseclause - 1).u64)) then anyEmpty = true
        elseMarker: st.pushBlock name: "arm:else"
        if targetName.length > 0 when subjT > 0 then {
            with eiter: covered.iterate do for en2: eiter loop {
                (st.exclude
                    pool: ast.names
                    name: targetName.stringview
                    subtypeName: en2.stringview
                    fullTypeId: subjT
                )
            }
            shadowCollapseIfSingle :ast :st name: targetName.stringview fullTid: subjT
        }
        walkBodyAt :st :unitName :ast :unitBody bodyId: casenode.elseclause
        ecr9: ast.nodes.get i: (casenode.elseclause - 1).u64
        et: lastStmtType :st :ast block: ecr9
        armTypes.append et
        if st.isUnreachable then st.discardTakenInCurrentScope
        st.popTo marker: elseMarker
    }
    st.popTo marker: matchMarker
    exhaustive: hasElse
    if (exhaustive) == false then {
        if isSum then {
            arms2: sumSubtypeNames :ast :st sid: subjT
            # ambient narrowing relaxes the requirement: a subject already
            # narrowed to a single arm needs only that arm's case; arms the
            # enclosing flow has excluded are impossible and need none.
            required9: (List String)
            nsn9: String
            if targetName.length > 0 then {
                gsn9: st.narrowedArmOf name: targetName.stringview fullTypeId: subjT
                nsn9 = gsn9
            }
            if nsn9.length > 0 then {
                nreq9: nsn9.copy
                required9.append nreq9
            } else {
                excl9: (Set String)
                if targetName.length > 0 then {
                    st.collectExcluded name: targetName.stringview into: excl9
                }
                with a0it9: arms2.iterate do for an0: a0it9 loop {
                    if (excl9.has item: an0) == false then required9.append an0.copy
                }
            }
            allCovered: true
            missing9: (List String)
            a2iter: required9.iterate
            for an3: a2iter loop {
                found: false
                c2iter: covered.iterate
                for cn3: c2iter loop {
                    if an3.stringview == cn3.stringview then found = true
                }
                if (found) == false then {
                    allCovered = false
                    missing9.append an3.copy
                }
            }
            exhaustive = allCovered
            if (allCovered) == false then {
                mj9: String
                mfirst9: true
                with mit9: missing9.iterate do for mn9: mit9 loop {
                    if (mfirst9) == false then mj9.append ", "
                    mj9.append mn9.stringview
                    mfirst9 = false
                }
                (addErrorH
                    :st
                    nodeid: casenode.nodeid
                    lineno: casenode.lineno
                    colno: casenode.colno
                    e: zast.err.nonExhaustive
                    msg: "non-exhaustive match: missing case(s) \{mj9} -- add them or an `else` clause"
                    note: "".string
                    hint: "".string
                    width: 5
                )
            }
        }
    }
    if targetName.length > 0 when subjT > 0 then {
        with diter: diverging.iterate do for dn2: diter loop {
            (st.exclude
                pool: ast.names
                name: targetName.stringview
                subtypeName: dn2.stringview
                fullTypeId: subjT
            )
        }
        if diverging.length > 0 then {
            shadowCollapseIfSingle :ast :st name: targetName.stringview fullTid: subjT
            (postGuardRecord
                :ast
                :st
                stmtNid: casenode.nodeid
                subject: targetName.stringview
                fullTid: subjT
            )
        }
    }
    if exhaustive when allDiverge when neverId > 0 then {
        if casenode.clauses.length > 0 then {
            setn2: neverId
            st.typing.nodeType.set key: casenode.nodeid.u64 value: setn2
            return neverId
        } else {
            return 0
        }
    }
    if exhaustive when anyEmpty then {
        # an empty (`{}` / null) arm body makes the match valueless: stamp
        # null so consuming the match as a value is rejected.
        if nullId > 0 then {
            setne0: nullId
            st.typing.nodeType.set key: casenode.nodeid.u64 value: setne0
            return nullId
        }
        return 0
    }
    if exhaustive then {
        # the first completing (non-diverging) arm's type is the match value;
        # an untyped completing arm leaves the match unstamped.
        ti: u64
        tn4: armTypes.length
        for ti < tn4 loop {
            at2: armTypes.get i: ti
            if at2 != neverId then {
                if at2 > 0 then {
                    setc3: at2
                    st.typing.nodeType.set key: casenode.nodeid.u64 value: setc3
                    return at2
                } else {
                    return 0
                }
            }
            ti = ti + 1
        }
        return 0
    } else {
        return 0
    }
}

# checkValue -- type an expression-value node, dispatching by kind. Returns the
# resolved type id, or 0 when unhandled.
checkValue: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    node: Node
} out u64 is {
    match (
        node
    ) case call then {
        return (checkCall :st :unitName :ast :unitBody call: node)
    } case binop then {
        return (checkBinop :st :unitName :ast :unitBody binop: node)
    } case atomid then {
        return (checkAtomid :st :unitName :ast :unitBody :node)
    } case atomstring then {
        return (checkString :st :unitName :ast :unitBody :node)
    } case dottedpath then {
        return (checkDotted :st :unitName :ast :unitBody dp: node coerce: true)
    } case caseexpr then {
        return (checkCase :st :unitName :ast :unitBody casenode: node)
    } case ifexpr then {
        return (checkIf :st :unitName :ast :unitBody ifnode: node)
    } case forexpr then {
        return (checkFor :st :unitName :ast :unitBody fornode: node)
    } case labelvalue then {
        # the `:x` shorthand in value position reads the local x
        lvNm9: ast.names.texts.get i: (node.name - 1).u64
        lvo9: st.lookup name: lvNm9.stringview
        match (
            lvo9
        ) case some then {
            setlv9: lvo9
            st.typing.nodeType.set key: node.nodeid.u64 value: setlv9
            lvv9: st.lookupVarId name: lvNm9.stringview
            match (
                lvv9
            ) case some then {
                setlvv9: lvv9
                st.typing.atomVariableId.set key: node.nodeid.u64 value: setlvv9
            } case none then null
            return lvo9
        } case none then {
            return 0
        }
    } case yieldexpr then {
        # a suspension point: the yielded value walks for diagnostics. A
        # bidirectional generator's yield carries the resumed value -- the
        # synth `.call`'s `value` parameter's type (the node itself stays
        # unstamped; the expression wrapper takes the type). A reftype
        # resume value is a borrow into the caller's argument: the
        # surrounding binding becomes BORROWED origin value.
        checkValue :st :unitName :ast :unitBody node: (ast.nodes.get i: (node.expr - 1).u64)
        yvo: st.lookup name: "value"
        match (
            yvo
        ) case some then {
            if (typeIsReftype :st tid: yvo) then {
                drainPendingBorrow :st
                yvc: "value".string
                st.typing.pendingBorrowPath.append yvc
            }
            return yvo
        } case none then {
            return 0
        }
    } case doexpr then {
        return (checkDo :st :unitName :ast :unitBody donode: node)
    } case withexpr then {
        return (checkWith :st :unitName :ast :unitBody withnode: node)
    } case reassignment then {
        checkReassignment :st :unitName :ast :unitBody rasgn: node
        return 0
    } case swapstmt then {
        checkSwap :st :unitName :ast :unitBody swapnode: node
        return 0
    } case expression then {
        t: (checkValue
            :st
            :unitName
            :ast
            :unitBody
            node: (ast.nodes.get i: (node.expression - 1).u64)
        )
        if t > 0 then stampGate :st nid: node.nodeid tid: t
        return t
    } else {
        return 0
    }
}

# checkExpression -- type an expression wrapper from its inner value; returns
# true when the inner is a return terminator (so the caller marks the scope
# unreachable).
checkExpression: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    expr: zast.ExpressionData
} out bool is {
    isRet: false
    t: checkValue :st :unitName :ast :unitBody node: (ast.nodes.get i: (expr.expression - 1).u64)
    if t > 0 then st.typing.nodeType.set key: expr.nodeid.u64 value: t
    innerNid: nodeId n: (ast.nodes.get i: (expr.expression - 1).u64)
    ckOpt: st.typing.callKind.get key: innerNid.u64
    isRet = isReturnCallKind o: ckOpt
    return isRet
}

# checkStmtInner -- dispatch a statement line's inner node (C1: expressions).
checkStmtInner: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    inner: Node
} out bool is {
    match (
        inner
    ) case expression then {
        isR0: checkExpression :st :unitName :ast :unitBody expr: inner
        bn0: bareAtomName :ast n: (ast.nodes.get i: (inner.expression - 1).u64)
        if bn0.stringview == "break" then isR0 = true
        if bn0.stringview == "continue" then isR0 = true
        if bn0.stringview == "return" then isR0 = true
        return isR0
    } case assignment then {
        checkAssignment :st :unitName :ast :unitBody asgn: inner
        return false
    } case reassignment then {
        checkReassignment :st :unitName :ast :unitBody rasgn: inner
        return false
    } else {
        return false
    }
}

# checkStatementLine -- type a statement line; propagate the inner type to the
# line wrapper. Returns true for a return terminator.
checkStatementLine: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    sline: Node
} out bool is {
    isRet: false
    match (
        sline
    ) case statementline then {
        sln9: ast.nodes.get i: (sline.statementline - 1).u64
        isRet = checkStmtInner :st :unitName :ast :unitBody inner: sln9
        inid: nodeId n: sln9
        itOpt: st.typing.nodeType.get key: inid.u64
        match (
            itOpt
        ) case some then {
            st.typing.nodeType.set key: sline.nodeid.u64 value: itOpt
        } case none then null
    } else null
    return isRet
}

# checkStatement -- walk a function-body statement block, marking the scope
# unreachable after a control-flow terminator (return).
checkStatement: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    block: Node
} is {
    match (
        block
    ) case statement then {
        siter: block.statements.iterate
        for slnId9: siter loop {
            sline: ast.nodes.get i: (slnId9 - 1).u64
            isRet: checkStatementLine :st :unitName :ast :unitBody :sline
            drainPendingBorrow :st
            if isRet then st.markUnreachable
        }
    } else null
}

# walkBody -- walk an optional function body (none for spec methods).
walkBody: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    bodyOpt: Option Node
} is {
    match (
        bodyOpt
    ) case some then {
        checkStatement :st :unitName :ast :unitBody block: bodyOpt
    } case none then null
}

# walkBodyAt -- walkBody over a body table id (0 = a spec method, no body).
walkBodyAt: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    bodyId: u32
} is {
    if bodyId > 0 then {
        b9: ast.nodes.get i: (bodyId - 1).u64
        checkStatement :st :unitName :ast :unitBody block: b9
    }
}

# nodeIsFunctiondef -- kind test that keeps the caller's un-narrowed handle.
nodeIsFunctiondef: function {o: Node} out bool is {
    match (
        o
    ) case functiondef then {
        return true
    } else {
        return false
    }
}

# objectdefIsGeneric -- a type definition with a generic as-block parameter;
# generic templates are never body-walked (instances clone at call sites).
objectdefIsGeneric: function {ast: Ast o: Node} out bool is {
    match (
        o
    ) case objectdef then {
        return (hasGenericParam :ast items: o.asItems)
    } else {
        return false
    }
}

# scanTypeNameOpt -- recurse the method-walk trigger into an optional typeref
# (a function's return type).
scanTypeNameOpt: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    oId: u32
} is {
    if oId == 0 then return
    o: ast.nodes.get i: (oId - 1).u64
    bn: baseTypeName :ast n: o
    if bn.length > 0 then maybeWalkMethods :st :unitName :ast :unitBody name: bn.stringview

}

# scanFnSig -- recurse the method-walk trigger through a function signature in
# resolution order: the return type first, then parameters in declaration order.
scanFnSig: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast
    unitBody: List u32
    op: Node
} is {
    match (
        op
    ) case functiondef then {
        scanTypeNameOpt :st :unitName :ast :unitBody oId: op.returntype
        piter: op.parameters.iterate
        for pmId9: piter loop {
            pm: ast.nodes.get i: (pmId9 - 1).u64
            match (
                pm
            ) case namedoperation then {
                bn: baseTypeName :ast n: (ast.nodes.get i: (pm.operation - 1).u64)
                if bn.length > 0 then (maybeWalkMethods
                    :st
                    :unitName
                    :ast
                    :unitBody
                    name: bn.stringview
                )
            } else null
        }
    } else null
}

# scanMemberSignatures -- replay one definition's signature-resolution order:
# an objectdef resolves its field typerefs, then its is- and as-block method
# signatures; a function resolves its own signature. Each name recurses the
# trigger, so transitively referenced types walk their methods first.
scanMemberSignatures: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    op: Node
} is {
    if (nodeIsFunctiondef o: op) then {
        scanFnSig :st :unitName :ast :unitBody :op
    } else {
        match (
            op
        ) case objectdef then {
            with fiter: op.isItems.iterate do for fmId9: fiter loop {
                fm: ast.nodes.get i: (fmId9 - 1).u64
                match (
                    fm
                ) case namedoperation then {
                    if (nodeIsFunctiondef o: (ast.nodes.get i: (fm.operation - 1).u64)) == false then {
                        bn: baseTypeName :ast n: (ast.nodes.get i: (fm.operation - 1).u64)
                        if bn.length > 0 then {
                            maybeWalkMethods :st :unitName :ast :unitBody name: bn.stringview
                        }
                    }
                } else null
            }
            with iiter: op.isItems.iterate do for imId9: iiter loop {
                im: ast.nodes.get i: (imId9 - 1).u64
                match (
                    im
                ) case namedoperation then {
                    (scanFnSig
                        :st
                        :unitName
                        :ast
                        :unitBody
                        op: (ast.nodes.get i: (im.operation - 1).u64)
                    )
                } else null
            }
            with aiter: op.asItems.iterate do for amId9: aiter loop {
                am: ast.nodes.get i: (amId9 - 1).u64
                match (
                    am
                ) case namedoperation then {
                    (scanFnSig
                        :st
                        :unitName
                        :ast
                        :unitBody
                        op: (ast.nodes.get i: (am.operation - 1).u64)
                    )
                } else null
            }
        } else null
    }
}

# maybeWalkMethods -- the resolution-time method-walk trigger: the first time
# a body walk resolves a main-unit definition's name, replay the reference
# resolver's side effects at the current scope position -- scan the signature
# typerefs (recursing per name), then body-check the type's methods. The
# early mark stops re-entry (a method constructing its own type).
maybeWalkMethods: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    name: StringView
} is {
    nk: name.string
    got: st.typing.walkedMethodOwners.get key: nk
    match (
        got
    ) case some then {
        return
    } case none then null
    io: st.typing.mainMemberIndex.get key: nk
    idx: u64
    match (
        io
    ) case some then {
        idx = io
    } case none then {
        return
    }
    mv: true
    st.typing.walkedMethodOwners.set key: nk value: mv
    memId9: unitBody.get i: idx
    mem: ast.nodes.get i: (memId9 - 1).u64
    match (
        mem
    ) case namedoperation then {
        # a demand walk of the owner's method bodies is its own scope: a
        # dotted-base suppression live at the TRIGGERING reference must
        # not leak into the walked bodies
        mwSup9: st.typing.suppressBareCtor
        st.typing.suppressBareCtor = false
        mwSupFn9: st.typing.suppressFnAutoCall
        st.typing.suppressFnAutoCall = false
        (scanMemberSignatures
            :st
            :unitName
            :ast
            :unitBody
            op: (ast.nodes.get i: (mem.operation - 1).u64)
        )
        canWalk: objectdefHasMethodBodies :ast op: (ast.nodes.get i: (mem.operation - 1).u64)
        if canWalk then {
            prev: st.typing.synthLabel.copy
            prevThis: st.typing.currentThisName.copy
            (checkMethodBodies
                :st
                :unitName
                :ast
                :unitBody
                typeName: name
                op: (ast.nodes.get i: (mem.operation - 1).u64)
            )
            st.typing.synthLabel = prev
            st.typing.currentThisName = prevThis
        }
        rko: "\{unitName}.\{name}"
        rgo9: resolvedByKey :ast ty: st.typing reg: st.reg key: rko
        match (
            rgo9
        ) case some then {
            runUnitMonoWalks :st :unitName :ast :unitBody monoId: rgo9
        } case none then null
        st.typing.suppressFnAutoCall = mwSupFn9
        st.typing.suppressBareCtor = mwSup9
    } else null
}

# objectdefHasMethodBodies -- a unit member whose operation is an objectdef
# with at least one functiondef-with-body item.
objectdefHasMethodBodies: function {ast: Ast op: Node} out bool is {
    match (
        op
    ) case objectdef then {
        iiter: op.isItems.iterate
        for imId9: iiter loop {
            im: ast.nodes.get i: (imId9 - 1).u64
            match (
                im
            ) case namedoperation then {
                if (isFunctionDefWithBody o: (ast.nodes.get i: (im.operation - 1).u64)) then return true
            } else null
        }
        aiter: op.asItems.iterate
        for amId9: aiter loop {
            am: ast.nodes.get i: (amId9 - 1).u64
            match (
                am
            ) case namedoperation then {
                if (isFunctionDefWithBody o: (ast.nodes.get i: (am.operation - 1).u64)) then return true
            } else null
        }
        return false
    } else {
        return false
    }
}

# checkMethodBodies -- body-check every method of one type definition (is- and
# as-block functiondefs, declaration order). The scopes land under the walk's
# current scope, mirroring the oracle's resolve-at-first-demand placement.
checkMethodBodies: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    ast: Ast unitBody: List u32
    typeName: StringView
    op: Node
} is {
    match (
        op
    ) case objectdef then {
        iiter: op.isItems.iterate
        for imId9: iiter loop {
            im: ast.nodes.get i: (imId9 - 1).u64
            match (
                im
            ) case namedoperation then {
                if (isFunctionDefWithBody o: (ast.nodes.get i: (im.operation - 1).u64)) then {
                    mname: zast.nameTextCopy :ast ref: im.name
                    qn: "\{typeName}.\{mname}"
                    ed7: (List u32)
                    (checkFunctionBody
                        :st
                        :unitName
                        defName: qn.stringview
                        defn: (ast.nodes.get i: (im.operation - 1).u64)
                        thisName: typeName
                        :ast :unitBody
                        depUnits: ed7
                    )
                }
            } else null
        }
        aiter: op.asItems.iterate
        for amId9: aiter loop {
            am: ast.nodes.get i: (amId9 - 1).u64
            match (
                am
            ) case namedoperation then {
                if (isFunctionDefWithBody o: (ast.nodes.get i: (am.operation - 1).u64)) then {
                    mname2: zast.nameTextCopy :ast ref: am.name
                    qn2: "\{typeName}.\{mname2}"
                    ed6: (List u32)
                    (checkFunctionBody
                        :st
                        :unitName
                        defName: qn2.stringview
                        defn: (ast.nodes.get i: (am.operation - 1).u64)
                        thisName: typeName
                        :ast :unitBody
                        depUnits: ed6
                    )
                }
            } else null
        }
    } else null
}

# lastStmtLineId / lastStmtLineIdAt -- the node id of a function body's last
# statement line (the implicit-return position), or 0 when absent.
lastStmtLineId: function {ast: Ast block: Node} out u32 is {
    match (
        block
    ) case statement then {
        ne: block.statements.length
        if ne > 0 then {
            lastId9: block.statements.get i: (ne - 1)
            last: ast.nodes.get i: (lastId9 - 1).u64
            match (
                last
            ) case statementline then {
                return last.nodeid
            } else null
        }
    } else null
    return 0
}

lastStmtLineIdAt: function {ast: Ast oId: u32} out u32 is {
    if oId == 0 then return 0
    return (lastStmtLineId :ast block: (ast.nodes.get i: (oId - 1).u64))
}

# checkFunctionBody -- type-check one function body. Pushes a scope, binds each
# parameter as a runtime variable, walks the body, then pops (the pop snapshots
# the scope's entries + unreachable flag for the SQL dump).
checkFunctionBody: function {
    st: zenv.ZSymbolTable
    unitName: StringView
    defName: StringView
    defn: Node
    thisName: StringView
    ast: Ast unitBody: List u32
    depUnits: List u32
} is {
    match (
        defn
    ) case functiondef then {
        maybeWalkMethods :st :unitName :ast :unitBody name: defName
        hasBody: defn.body > 0
        isGenDef: false
        rkey: "\{unitName}.\{defName}"
        rgot: resolvedByKey :ast ty: st.typing reg: st.reg key: rkey
        match (
            rgot
        ) case some then {
            {
                gz: st.reg.typeById.get key: rgot
                match (
                    gz
                ) case some then {
                    if gz.isgeneric then isGenDef = true
                } case none then null
            }
        } case none then null
        if hasBody then {
            # A generic template body is checked ONCE, for diagnostics; the
            # emitter re-walks the shared AST per instance, so
            # GENERIC_PARAM-valued stamps are suppressed for the walk (and
            # its scopes/entries stay out of the dump log).
            prevSup9: st.typing.suppressParamStamps
            if isGenDef then st.typing.suppressParamStamps = true
            sname: "function:\{defName}"
            st.push name: sname.stringview
            piter: defn.parameters.iterate
            for pmId9: piter loop {
                pm: ast.nodes.get i: (pmId9 - 1).u64
                match (
                    pm
                ) case namedoperation then {
                    pname: zast.nameTextCopy :ast ref: pm.name
                    pnid: nodeId n: (ast.nodes.get i: (pm.operation - 1).u64)
                    ptid: (paramTypeId
                        :ast
                        typing: st.typing
                        reg: st.reg
                        :unitName
                        op: (ast.nodes.get i: (pm.operation - 1).u64)
                    )
                    if ptid == 0 when isGenDef then {
                        # a template's own bare param carries no stamp; bind
                        # the canonical param tid from the FUNCTION child so
                        # the walk types it (stampGate suppresses the stamp)
                        fgo3: resolvedByKey :ast ty: st.typing reg: st.reg key: rkey
                        match (
                            fgo3
                        ) case some then {
                            fco3: (st.typing.childOf
                                pool: ast.names
                                parentTypeId: fgo3
                                name: pname.stringview
                            )
                            match (
                                fco3
                            ) case some then {
                                if (st.reg.typetypeOf typeId: fco3) == ztypes.ztypetype.genericParam then {
                                    ptid = fco3
                                }
                            } case none then null
                        } case none then null
                    }
                    if ptid > 0 then {
                        noSt: optBoolOr o: (st.typing.noStampNode.get key: pnid.u64) d: false
                        if (noSt) == false then {
                            ppre: st.typing.nodeType.get key: pnid.u64
                            match (
                                ppre
                            ) case some then null case none then {
                                setpp: ptid
                                stampGate :st nid: pnid tid: setpp
                            }
                        }
                    }
                    if thisName.length > 0 when (paramIsThisReceiver
                        :ast
                        op: (ast.nodes.get i: (pm.operation - 1).u64)
                    ) then {
                        thOpt: (walkLookupTyperef
                            :ast
                            ty: st.typing
                            reg: st.reg
                            currentUnit: unitName
                            base: thisName
                        )
                        match (
                            thOpt
                        ) case some then {
                            ptid = thOpt
                        } case none then null
                    }
                    pown9: pathOwnership :ast n: (ast.nodes.get i: (pm.operation - 1).u64)
                    isLockP9: false
                    match (
                        pown9
                    ) case some then {
                        if pown9 == ztypes.zparamownership.lockMode then isLockP9 = true
                    } case none then null
                    isGenP9: false
                    if (st.reg.typetypeOf typeId: ptid) == ztypes.ztypetype.genericParam then isGenP9 = true
                    if isLockP9 when (paramIsThisReceiver
                        :ast
                        op: (ast.nodes.get i: (pm.operation - 1).u64)
                    ) == false when (typeIsValtype
                        ty: st.typing
                        reg: st.reg
                        tid: ptid
                    ) when (isGenP9) == false then {
                        ptn9: typeNameOf :st tid: ptid
                        ptnc9: ptn9.copy
                        pnc9: pname.copy
                        plln9: nodeLine n: (ast.nodes.get i: (pm.operation - 1).u64)
                        plcl9: nodeCol n: (ast.nodes.get i: (pm.operation - 1).u64)
                        ml9: "Cannot use '.lock' on valtype parameter '\{pnc9}' (type '\{ptnc9}') — locking requires identity (use a class)"
                        (addError
                            :st
                            nodeid: pnid
                            lineno: plln9
                            colno: plcl9
                            e: zast.err.ownerError
                            msg: ml9
                        )
                    }
                    own: ownershipOfParam o: (pathOwnership
                        :ast
                        n: (ast.nodes.get i: (pm.operation - 1).u64)
                    )
                    v: st.reg.newVariable ztypeId: ptid ownership: own
                    if (typeExprHasPrivate
                        :ast
                        n: (ast.nodes.get i: (pm.operation - 1).u64)
                    ) then v.isPrivateAccess = true
                    vid2: v.variableId
                    st.defineVar name: pname.stringview var: v
                    st.typing.defVariableId.set key: pnid.u64 value: vid2
                    st.typing.variableOrigin.set key: vid2 value: true
                } else null
            }
            # Synth rows carry the unit member's dump label: a method's nodes
            # live inside its TYPE's subtree, so the label is the type name.
            # Nested method walks save and restore it around their bodies.
            lbl: "\{unitName}.\{defName}"
            if thisName.length > 0 then lbl = "\{unitName}.\{thisName}"
            st.typing.synthLabel = lbl
            tnl: thisName.string
            st.typing.currentThisName = tnl
            if depUnits.length > 0 then runDepUnitWalks :st :ast mainName: unitName :depUnits
            prevRet9: st.typing.currentReturnTypeId
            fitid9: (optU64Or
                o: (resolvedByKey :ast ty: st.typing reg: st.reg key: rkey)
                d: 0
            )
            crt9: u64
            if fitid9 > 0 then crt9 = optU64Or o: (methodReturnOf :st mid: fitid9) d: 0
            st.typing.currentReturnTypeId = crt9
            prevRb9: st.typing.currentReturnsBorrow
            st.typing.currentReturnsBorrow = (optBoolOr
                o: (st.typing.funcReturnsBorrow.get key: fitid9)
                d: false
            )
            walkBodyAt :st :unitName :ast :unitBody bodyId: defn.body
            st.typing.currentReturnTypeId = prevRet9
            st.typing.currentReturnsBorrow = prevRb9
            # Implicit-return coercion: a literal-typed last statement takes
            # the function's concrete return type, stamped on the statement
            # line (the node the reference coerces by id).
            ftid: u64
            ftid = (optU64Or
                o: (resolvedByKey :ast ty: st.typing reg: st.reg key: rkey)
                d: ftid
            )
            if ftid > 0 then {
                ro: methodReturnOf :st mid: ftid
                match (
                    ro
                ) case some then {
                    lsid: lastStmtLineIdAt :ast oId: defn.body
                    if lsid > 0 then {
                        cur: st.typing.nodeType.get key: lsid.u64
                        match (
                            cur
                        ) case some then {
                            if (isLiteralTypeId :st tid: cur) then stampGate :st nid: lsid tid: ro
                        } case none then null
                    }
                } case none then null
            }
            st.pop
            st.typing.suppressParamStamps = prevSup9
        }
    } else null
}

# runDepUnitWalks -- full-mode dependency-unit body walks: the reference
# checks a demanded user unit's function bodies on first touch, inside the
# using function's scope. Walks every resolved function-with-body member of
# each non-system dependency unit, scoped function:{unit}.{fn}.
# resolveDemandedStdDeps -- one resolve sweep over the runtime-backed dep
# units (post-main): resolves whatever their bodied free fns' demands
# recorded, mirroring the registerAndResolveMain demand driver.
resolveDemandedStdDeps: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
} is {
    n9: ast.units.length
    i9: u64
    for i9 < n9 loop {
        u9Id9: ast.units.get i: i9
        u9: ast.nodes.get i: (u9Id9 - 1).u64
        i9 = i9 + 1
        match (
            u9
        ) case namedoperation then {
            un9: zast.nameTextCopy :ast ref: u9.name
            if (isStdlibUnitName name: un9.stringview) then {
                (resolveDemandedUnitBody
                    :ty
                    :reg
                    :ast
                    unitName: un9.stringview
                    shadowUnit: ""
                    unitdefId: u9.operation
                )
            }
        } else null
    }
}

runDepUnitWalks: function {
    st: zenv.ZSymbolTable
    ast: Ast
    mainName: StringView
    depUnits: List u32
} is {
    diter: depUnits.iterate
    for duId9: diter loop {
        du: ast.nodes.get i: (duId9 - 1).u64
        match (
            du
        ) case namedoperation then {
            dn: zast.nameTextCopy :ast ref: du.name
            # the runtime-backed stdlib units are excluded here: their bodied
            # free fns walk in checkBodies' final pass, AFTER the main unit
            # settles (demand order must not disturb main's shadow/mono
            # resolution)
            isKnownD: false
            if dn.stringview == mainName then isKnownD = true
            if dn.stringview == "io" then isKnownD = true
            if dn.stringview == "collections" then isKnownD = true
            if dn.stringview == "system" then isKnownD = true
            if dn.stringview == "core" then isKnownD = true
            if dn.stringview == "os" then isKnownD = true
            if dn.stringview == "cli" then isKnownD = true
            if (isKnownD) == false then (depWalkUnit
                :st
                :ast
                depName: dn.stringview
                unitOpId: du.operation
            )
        } else null
    }
}

# depWalkUnit -- walk one dependency unit's resolved function bodies (two
# passes: indices first, so the body list is free for the walk itself).
depWalkUnit: function {
    st: zenv.ZSymbolTable
    ast: Ast
    depName: StringView
    unitOpId: u32
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: unitOpId
    {
        if (hasGenericParam :ast items: bodyIds9) then return
        emptyD: (List u32)
        idxs: (List u64)
        di0: u64
        with biter: bodyIds9.iterate do for bmId9: biter loop {
            bm: ast.nodes.get i: (bmId9 - 1).u64
            match (
                bm
            ) case namedoperation then {
                if (isFunctionDefWithBody o: (ast.nodes.get i: (bm.operation - 1).u64)) then {
                    dv0: di0
                    idxs.append dv0
                } else {
                    hasm0: (objectdefHasMethodBodies
                        :ast
                        op: (ast.nodes.get i: (bm.operation - 1).u64)
                    )
                    if hasm0 when (objectdefIsGeneric
                        :ast
                        o: (ast.nodes.get i: (bm.operation - 1).u64)
                    ) then hasm0 = false
                    if hasm0 then {
                        dv1: di0
                        idxs.append dv1
                    }
                }
            } else null
            di0 = di0 + 1
        }
        wi: u64
        for wi < idxs.length loop {
            bidx: idxs.get i: wi
            bm2Id9: bodyIds9.get i: bidx
            bm2: ast.nodes.get i: (bm2Id9 - 1).u64
            match (
                bm2
            ) case namedoperation then {
                if (isFunctionDefWithBody o: (ast.nodes.get i: (bm2.operation - 1).u64)) then {
                    fn: zast.nameTextCopy :ast ref: bm2.name
                    rk: "\{depName}.\{fn}"
                    rgo: resolvedByKey :ast ty: st.typing reg: st.reg key: rk
                    match (
                        rgo
                    ) case some then {
                        walked: optBoolOr o: (st.typing.walkedMethodOwners.get key: rk) d: false
                        if (walked) == false then {
                            wv: true
                            wk2: "\{depName}.\{fn}"
                            st.typing.walkedMethodOwners.set key: wk2 value: wv
                            dq: "\{depName}.\{fn}"
                            (checkFunctionBody
                                :st
                                unitName: depName
                                defName: dq.stringview
                                defn: (ast.nodes.get i: (bm2.operation - 1).u64)
                                thisName: ""
                                :ast
                                unitBody: bodyIds9
                                depUnits: emptyD
                            )
                        }
                    } case none then null
                } else {
                    cls: zast.nameTextCopy :ast ref: bm2.name
                    crk: "\{depName}.\{cls}"
                    crgo: resolvedByKey :ast ty: st.typing reg: st.reg key: crk
                    match (
                        crgo
                    ) case some then {
                        cwalked: optBoolOr o: (st.typing.walkedMethodOwners.get key: crk) d: false
                        if (cwalked) == false then {
                            cwv: true
                            cwk: "\{depName}.\{cls}"
                            st.typing.walkedMethodOwners.set key: cwk value: cwv
                            cprev: st.typing.synthLabel.copy
                            cprevThis: st.typing.currentThisName.copy
                            (checkMethodBodies
                                :st
                                unitName: depName
                                :ast
                                unitBody: bodyIds9
                                typeName: cls.stringview
                                op: (ast.nodes.get i: (bm2.operation - 1).u64)
                            )
                            st.typing.synthLabel = cprev
                            st.typing.currentThisName = cprevThis
                        }
                    } case none then null
                }
            } else null
            wi = wi + 1
        }
    }
}

# checkUnitBodies -- walk every function definition with a body in one unit.
checkUnitBodies: function {
    ast: Ast
    st: zenv.ZSymbolTable
    unitName: StringView
    unitdefId: u32
    depUnits: List u32
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: unitdefId
    {
        emptyDeps9: (List u32)
        mi: u64
        with niter: bodyIds9.iterate do for nmId9: niter loop {
            nm: ast.nodes.get i: (nmId9 - 1).u64
            match (
                nm
            ) case namedoperation then {
                mnm: zast.nameTextCopy :ast ref: nm.name
                miv: mi
                st.typing.mainMemberIndex.set key: mnm value: miv
            } else null
            mi = mi + 1
        }
        mn9: bodyIds9.length
        mi9: u64
        for mi9 < mn9 loop {
            mmId9: bodyIds9.get i: mi9
            mi9 = mi9 + 1
            mm: ast.nodes.get i: (mmId9 - 1).u64
            if mm.namedoperation then {
                mainName: zast.nameTextCopy :ast ref: mm.name
                if mainName.stringview == "main" then {
                    (checkFunctionBody
                        :st
                        :unitName
                        defName: mainName.stringview
                        defn: (ast.nodes.get i: (mm.operation - 1).u64)
                        thisName: ""
                        :ast
                        unitBody: bodyIds9
                        :depUnits
                    )
                }
            }
        }
        bn9: bodyIds9.length
        bi9: u64
        for bi9 < bn9 loop {
            bmId9: bodyIds9.get i: bi9
            bi9 = bi9 + 1
            bm: ast.nodes.get i: (bmId9 - 1).u64
            if bm.namedoperation then {
                defName: zast.nameTextCopy :ast ref: bm.name
                if defName.stringview != "main" then {
                    (checkFunctionBody
                        :st
                        :unitName
                        defName: defName.stringview
                        defn: (ast.nodes.get i: (bm.operation - 1).u64)
                        thisName: ""
                        :ast
                        unitBody: bodyIds9
                        depUnits: emptyDeps9
                    )
                }
            }
        }
    }
}

# checkBodies -- the body-walk pass (full mode), mirroring check()'s top-level
# loop: walk the main unit's function bodies, main first, then the others in
# body order. Runs after demand resolution so referenced types are already
# resolved.
checkBodies: function {st: zenv.ZSymbolTable program: Node} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        mainIdx: u64
        found0: false
        i0: u64
        uCnt9d: program.ast.units.length
        uIdx9d: u64
        for uIdx9d < uCnt9d loop {
            uId9: program.ast.units.get i: uIdx9d
            uIdx9d = uIdx9d + 1
            u: program.ast.nodes.get i: (uId9 - 1).u64
            match (
                u
            ) case namedoperation then {
                nm: zast.poolTextCopy pool: program.ast.names ref: u.name
                if nm.stringview == mainName then {
                    if (found0) == false then {
                        mainIdx = i0
                        found0 = true
                    }
                }
            } else null
            i0 = i0 + 1
        }
        if found0 then {
            muId9: program.ast.units.get i: mainIdx
            mOpId9: u32
            {
                mu: program.ast.nodes.get i: (muId9 - 1).u64
                if mu.namedoperation then mOpId9 = mu.operation
            }
            if mOpId9 > 0 then {
                du9: (List u32)
                duN9: program.ast.units.length
                duI9: u64
                for duI9 < duN9 loop {
                    du9.append (program.ast.units.get i: duI9)
                    duI9 = duI9 + 1
                }
                (checkUnitBodies
                    :st
                    unitName: mainName
                    unitdefId: mOpId9
                    ast: program.ast
                    depUnits: du9
                )
            }
        }
        # runtime-backed dep units with bodied free fns: demand, resolve,
        # and walk them AFTER the main unit completes, so main's name,
        # shadow, and mono resolution are settled first
        dn9: program.ast.units.length
        di9: u64
        hasStd9: false
        for di9 < dn9 loop {
            du9Id9: program.ast.units.get i: di9
            di9 = di9 + 1
            dOpId9: u32
            dun9: String
            {
                du9: program.ast.nodes.get i: (du9Id9 - 1).u64
                if du9.namedoperation then {
                    dun0: zast.poolTextCopy pool: program.ast.names ref: du9.name
                    if (isStdlibUnitName name: dun0.stringview) then {
                        dOpId9 = du9.operation
                        dun9 = dun0.copy
                    }
                }
            }
            if dOpId9 > 0 when (unitHasDemandedBodiedFn
                ty: st.typing
                reg: st.reg
                ast: program.ast
                unitName: dun9.stringview
                unitdefId: dOpId9
            ) then {
                (demandAllUnitDefs
                    reg: st.reg
                    ast: program.ast
                    unitdefId: dOpId9
                )
                hasStd9 = true
            }
        }
        if hasStd9 then {
            againS9: true
            for againS9 loop {
                beforeS9: st.reg.nextTypeId
                (resolveDemandedStdDeps
                    ty: st.typing
                    reg: st.reg
                    ast: program.ast
                )
                if st.reg.nextTypeId == beforeS9 then againS9 = false
            }
            wn9: program.ast.units.length
            wi9: u64
            for wi9 < wn9 loop {
                wu9Id9: program.ast.units.get i: wi9
                wi9 = wi9 + 1
                wOpId9: u32
                wun9: String
                {
                    wu9: program.ast.nodes.get i: (wu9Id9 - 1).u64
                    if wu9.namedoperation then {
                        wun0: zast.poolTextCopy pool: program.ast.names ref: wu9.name
                        if (isStdlibUnitName name: wun0.stringview) then {
                            wOpId9 = wu9.operation
                            wun9 = wun0.copy
                        }
                    }
                }
                if wOpId9 > 0 when (unitHasDemandedBodiedFn
                    ty: st.typing
                    reg: st.reg
                    ast: program.ast
                    unitName: wun9.stringview
                    unitdefId: wOpId9
                ) then {
                    (depWalkUnit
                        :st
                        ast: program.ast
                        depName: wun9.stringview
                        unitOpId: wOpId9
                    )
                }
            }
        }
    } else null
}

# foldLiteralStamps -- replace literal-typed node stamps with their concrete
# defaults (i64 / f64) after the body walk: the unregistered pseudo ids and the
# data blocks' registered literal_int/literal_float element shells. Symbol-table
# entries keep their literal ids (the oracle's entry/variable rows read
# literal_int there too).
foldLiteralStamps: function {st: zenv.ZSymbolTable program: Node} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        intId: u64
        li: (walkLookupTyperef
            ast: program.ast
            ty: st.typing
            reg: st.reg
            currentUnit: mainName
            base: "i64"
        )
        match (
            li
        ) case some then {
            intId = li
        } case none then null
        floatId: u64
        lf: (walkLookupTyperef
            ast: program.ast
            ty: st.typing
            reg: st.reg
            currentUnit: mainName
            base: "f64"
        )
        match (
            lf
        ) case some then {
            floatId = lf
        } case none then null
        intShells: (List u64)
        floatShells: (List u64)
        nshell: st.reg.nextTypeId
        ti: u64
        for ti < nshell loop {
            snm: typeNameOf :st tid: ti
            if snm.stringview == "literal_int" then {
                sid: ti
                intShells.append sid
            } else {
                if snm.stringview == "literal_float" then {
                    sid2: ti
                    floatShells.append sid2
                }
            }
            ti = ti + 1
        }
        iks: (List u64)
        fks: (List u64)
        with it: st.typing.nodeType.iterateItems do for e: it loop {
            isInt: e.value == literalIntId
            if (intShells.contains item: e.value) then isInt = true
            isFloat: e.value == literalFloatId
            if (floatShells.contains item: e.value) then isFloat = true
            if isInt then {
                k: e.key
                iks.append k
            }
            if isFloat then {
                k2: e.key
                fks.append k2
            }
        }
        if intId > 0 then {
            kiter: iks.iterate
            for k3: kiter loop {
                kc: k3
                setv: intId
                st.typing.nodeType.set key: kc value: setv
            }
        }
        if floatId > 0 then {
            fiter: fks.iterate
            for k4: fiter loop {
                kc2: k4
                setv2: floatId
                st.typing.nodeType.set key: kc2 value: setv2
            }
        }
    } else null
}

# isBinopNode -- kind test without narrowing (the caller keeps the Node handle).
isBinopNode: function {n: Node} out bool is {
    match (
        n
    ) case binop then {
        return true
    } else {
        return false
    }
}

# constantOperandType -- type one operand of a unit-level constant expression,
# stamping as it walks: a numeric literal wears the pseudo id (folded to its
# visible default later), a name reads an already-materialised constant from
# resolved (body order), and a binop takes the first concretely-typed operand
# (else the literal pseudo). 0 = not a constant shape.
constantOperandType: function {ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    n: Node
} out u64 is {
    match (
        n
    ) case expression then {
        return (constantOperandType
            :ast
            :ty
            :reg
            :mainName
            n: (ast.nodes.get i: (n.expression - 1).u64)
        )
    } case atomid then {
        result: u64
        trN9: ast.names.texts.get i: (n.name - 1).u64
        if (isNumericLiteralName name: trN9.stringview) then {
            if (isFloatLiteralName name: trN9.stringview) then {
                result = literalFloatId
            } else {
                result = literalIntId
            }
        } else {
            ro: walkLookupTyperef :ast :ty :reg currentUnit: mainName base: trN9.stringview
            match (
                ro
            ) case some then {
                result = ro
            } case none then null
        }
        if result > 0 then {
            seto: result
            ty.nodeType.set key: n.nodeid.u64 value: seto
        }
        return result
    } case binop then {
        lt: constantOperandType :ast :ty :reg :mainName n: (ast.nodes.get i: (n.lhs - 1).u64)
        rt: constantOperandType :ast :ty :reg :mainName n: (ast.nodes.get i: (n.rhs - 1).u64)
        opn9: atomName :ast n: (ast.nodes.get i: (n.operator - 1).u64)
        if (isComparisonOp name: opn9.stringview) then {
            # A comparison condition: the result is bool and a literal
            # operand coerces (restamps) at the concrete side's type.
            lLit: false
            if lt == literalIntId then lLit = true
            if lt == literalFloatId then lLit = true
            rLit: false
            if rt == literalIntId then rLit = true
            if rt == literalFloatId then rLit = true
            conc: u64
            if (lLit) == false then {
                if lt > 0 then conc = lt
            }
            if conc == 0 then {
                if (rLit) == false then {
                    if rt > 0 then conc = rt
                }
            }
            if lLit when conc > 0 then {
                lid9: innermostNodeId :ast n: (ast.nodes.get i: (n.lhs - 1).u64)
                if lid9 > 0 then {
                    setl9: conc
                    ty.nodeType.set key: lid9.u64 value: setl9
                }
            }
            if rLit when conc > 0 then {
                rid9: innermostNodeId :ast n: (ast.nodes.get i: (n.rhs - 1).u64)
                if rid9 > 0 then {
                    setr9: conc
                    ty.nodeType.set key: rid9.u64 value: setr9
                }
            }
            bres9: u64
            bo9: walkLookupTyperef :ast :ty :reg currentUnit: mainName base: "bool"
            match (
                bo9
            ) case some then {
                bres9 = bo9
                setb9: bres9
                ty.nodeType.set key: n.nodeid.u64 value: setb9
            } case none then null
            return bres9
        }
        result: lt
        if lt == 0 then result = rt
        if lt == literalIntId then {
            if rt > 0 when rt != literalIntId when rt != literalFloatId then result = rt
        }
        if lt == literalFloatId then {
            if rt > 0 when rt != literalIntId when rt != literalFloatId then result = rt
        }
        if result > 0 then {
            setb: result
            ty.nodeType.set key: n.nodeid.u64 value: setb
        }
        return result
    } else {
        return 0
    }
}

# constantBranchWalk -- walk one unit-level-if branch block: each statement's
# expression types through the constant walk; literal results materialise to
# their defaults (i64/f64) on the statement, its expression wrapper, and the
# atom. Returns the (materialised) last-statement type.
constantBranchWalk: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    mainName: StringView
    block: Node
} out u64 is {
    match (
        block
    ) case statement then {
        result: u64
        siter: block.statements.iterate
        for s9Id9: siter loop {
            s9: ast.nodes.get i: (s9Id9 - 1).u64
            match (
                s9
            ) case statementline then {
                sInner9: ast.nodes.get i: (s9.statementline - 1).u64
                bt0: constantOperandType :ast :ty :reg :mainName n: sInner9
                mt0: u64
                if bt0 == literalIntId then {
                    mt0 = (optU64Or
                        o: (walkLookupTyperef :ast :ty :reg currentUnit: mainName base: "i64")
                        d: 0
                    )
                }
                if bt0 == literalFloatId then {
                    mt0 = (optU64Or
                        o: (walkLookupTyperef :ast :ty :reg currentUnit: mainName base: "f64")
                        d: 0
                    )
                }
                if mt0 > 0 then {
                    sets0: mt0
                    ty.nodeType.set key: s9.nodeid.u64 value: sets0
                    eid0: nodeId n: sInner9
                    if eid0 > 0 then {
                        sete0: mt0
                        ty.nodeType.set key: eid0.u64 value: sete0
                    }
                    iid0: innermostNodeId :ast n: sInner9
                    if iid0 > 0 then {
                        seti0: mt0
                        ty.nodeType.set key: iid0.u64 value: seti0
                    }
                    result = mt0
                } else {
                    if bt0 > 0 then {
                        sets1: bt0
                        ty.nodeType.set key: s9.nodeid.u64 value: sets1
                        result = bt0
                    }
                }
            } else null
        }
        return result
    } else {
        return 0
    }
}

# constantBranchWalkOpt -- constantBranchWalk over an optional block.
constantBranchWalkOpt: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    mainName: StringView
    bodyOpt: Option Node
} out u64 is {
    match (
        bodyOpt
    ) case some then {
        return (constantBranchWalk :ty :reg :ast :mainName block: bodyOpt)
    } case none then {
        return 0
    }
}

# resolveUnitIfDef -- a unit-level `if` definition (compile-time conditional):
# conditions walk through the constant machinery (comparisons stamp bool and
# coerce literal operands), branches walk + materialise, and the definition
# resolves to the first branch's type -- stamped on the If, its Expression
# wrapper, and resolved[unit.name].
resolveUnitIfDef: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    defName: StringView
    wrapperId: u32
    n: Node
} is {
    match (
        n
    ) case ifexpr then {
        t9: u64
        cliter: n.clauses.iterate
        for clauseId9: cliter loop {
            clause: ast.nodes.get i: (clauseId9 - 1).u64
            match (
                clause
            ) case ifclause then {
                coiter: clause.conditions.iterate
                for condId9: coiter loop {
                    cond: ast.nodes.get i: (condId9 - 1).u64
                    match (
                        cond
                    ) case namedoperation then {
                        (constantOperandType
                            :ast
                            :ty
                            :reg
                            :mainName
                            n: (ast.nodes.get i: (cond.operation - 1).u64)
                        )
                    } else null
                }
                bt9: (constantBranchWalk
                    :ty
                    :reg
                    :ast
                    :mainName
                    block: (ast.nodes.get i: (clause.statement - 1).u64)
                )
                if t9 == 0 then t9 = bt9
            } else null
        }
        if n.elseclause > 0 then {
            et9: (constantBranchWalk
                :ty
                :reg
                :ast
                :mainName
                block: (ast.nodes.get i: (n.elseclause - 1).u64)
            )
            if t9 == 0 then t9 = et9
        }
        if t9 > 0 then {
            setw9: t9
            ty.nodeType.set key: wrapperId.u64 value: setw9
            seti9: t9
            ty.nodeType.set key: n.nodeid.u64 value: seti9
            cu9: reg.unitNameTid.get key: mainName.string
            match (
                cu9
            ) case some then {
                (ty.setChildId
                    parentTypeId: cu9
                    nameId: (zast.poolFind pool: ast.names text: defName).u64
                    childTypeId: t9
                )
            } case none then null
        }
    } else null
}

# resolveConstantDef -- one definition: an (expression-wrapped) numeric-literal
# atomid is a unit constant. Record resolved[unit.name] as the literal's concrete
# default (i64 / f64 -- both pre-demanded by seedSystemDemands). The definition's
# own nodes stay unstamped: the oracle's stamps there carry its unregistered
# literal pseudo-type (NULL in the dump), invisible to every projection.
resolveConstantDef: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    defName: StringView
    defn: Node
} is {
    match (
        defn
    ) case expression then {
        (resolveUnitIfDef
            :ast
            :ty
            :reg
            :mainName
            :defName
            wrapperId: defn.nodeid
            n: (ast.nodes.get i: (defn.expression - 1).u64)
        )
        iexL9: ast.nodes.get i: (defn.expression - 1).u64
        resolveConstantDef :ast :ty :reg :mainName :defName defn: iexL9
    } case atomid then {
        dfN9: zast.nameTextCopy :ast ref: defn.name
        if (isNumericLiteralName name: dfN9.stringview) then {
            base: "i64"
            if (isFloatLiteralName name: dfN9.stringview) then base = "f64"
            tOpt: walkLookupTyperef :ast :ty :reg currentUnit: mainName :base
            match (
                tOpt
            ) case some then {
                cu: reg.unitNameTid.get key: mainName.string
                match (
                    cu
                ) case some then {
                    (ty.setChildId
                        parentTypeId: cu
                        nameId: (zast.poolFind pool: ast.names text: defName).u64
                        childTypeId: tOpt
                    )
                } case none then null
            } case none then null
        } else {
            # a bare TYPE name is not a constant value: unit constants take
            # literal values (a zero value is a function-body binding)
            bOpt9: walkLookupTyperef :ast :ty :reg currentUnit: mainName base: dfN9.stringview
            match (
                bOpt9
            ) case some then {
                btt9: reg.typetypeOf typeId: bOpt9
                isFam9: false
                if btt9 == ztypes.ztypetype.recordType then isFam9 = true
                if btt9 == ztypes.ztypetype.classType then isFam9 = true
                if btt9 == ztypes.ztypetype.unionType then isFam9 = true
                if btt9 == ztypes.ztypetype.variantType then isFam9 = true
                if btt9 == ztypes.ztypetype.protocolType then isFam9 = true
                if btt9 == ztypes.ztypetype.facetType then isFam9 = true
                if isFam9 then {
                    btn9: typeNameOfReg :reg tid: bOpt9
                    dnv9: dfN9.copy
                    if btn9.stringview == dnv9.stringview then {
                        dnc9: dnv9.copy
                        um9: "a unit-level constant takes a literal value, not the type '\{dnc9}'"
                        un9: "unit constants inline literal numeric values".string
                        dnh9: dnv9.copy
                        uh9: "a zero value is a function-body binding ('\{defName}: \{dnh9}' inside a function)"
                        ty.errors.append (zast.ErrorData
                            nodeid: defn.nodeid
                            lineno: defn.lineno
                            colno: defn.colno
                            width: dfN9.length.u32.orPanic
                            err: zast.err.typeError
                            msg: um9
                            fsno: 0
                            note: un9
                            hint: uh9
                        )
                        ty.isError = true
                    }
                }
            } case none then null
        }
    } else {
        if (isBinopNode n: defn) then {
            # A constant expression (`COMBINED: OFFSET + SCALE`): the operand
            # walk stamps the refs and the binop; a literal result materialises
            # to its default, a concrete one (an already-materialised constant)
            # keeps it.
            bt: constantOperandType :ast :ty :reg :mainName n: defn
            base2: ""
            if bt == literalIntId then base2 = "i64"
            if bt == literalFloatId then base2 = "f64"
            if base2.length > 0 then {
                mOpt: walkLookupTyperef :ast :ty :reg currentUnit: mainName base: base2
                match (
                    mOpt
                ) case some then {
                    cu2: reg.unitNameTid.get key: mainName.string
                    match (
                        cu2
                    ) case some then {
                        (ty.setChildId
                            parentTypeId: cu2
                            nameId: (zast.poolFind pool: ast.names text: defName).u64
                            childTypeId: mOpt
                        )
                    } case none then null
                } case none then null
            } else {
                if bt > 0 then {
                    cu3: reg.unitNameTid.get key: mainName.string
                    match (
                        cu3
                    ) case some then {
                        (ty.setChildId
                            parentTypeId: cu3
                            nameId: (zast.poolFind pool: ast.names text: defName).u64
                            childTypeId: bt
                        )
                    } case none then null
                }
            }
        }
    }
}

resolveConstantDefsInUnit: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    mainName: StringView
    unitdefId: u32
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: unitdefId
    {
        biter: bodyIds9.iterate
        for bm: biter loop {
            bmNode9: ast.nodes.get i: (bm - 1).u64
            match (
                bmNode9
            ) case namedoperation then {
                defName: zast.nameTextCopy :ast ref: bmNode9.name
                if defName.length > 0 then {
                    (resolveConstantDef
                        :ast
                        :ty
                        :reg
                        :mainName
                        defName: defName.stringview
                        defn: (ast.nodes.get i: (bmNode9.operation - 1).u64)
                    )
                }
            } else null
        }
    }
}

# resolveConstantDefs -- under the full driver, materialise the main unit's numeric
# constant definitions the way the oracle resolves them on first name lookup. Runs
# post-demand so the numeric defaults are already in resolved.
resolveConstantDefs: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry program: Node} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        uiter: program.ast.units.iterate
        for uId9: uiter loop {
            u: program.ast.nodes.get i: (uId9 - 1).u64
            match (
                u
            ) case namedoperation then {
                nm: zast.poolTextCopy pool: program.ast.names ref: u.name
                if nm.stringview == mainName then {
                    (resolveConstantDefsInUnit
                        :ty
                        :reg
                        ast: program.ast
                        :mainName
                        unitdefId: u.operation
                    )
                }
            } else null
        }
    } else null
}

# unitHasYieldFn -- any function member of this unit whose body suspends.
unitHasYieldFn: function {ast: Ast unitdefId: u32} out bool is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: unitdefId
    biter: bodyIds9.iterate
    for bm: biter loop {
        bmNode9: ast.nodes.get i: (bm - 1).u64
        if bmNode9.namedoperation then {
            if (zgenerator.fnBodyHasYield
                :ast
                n: (ast.nodes.get i: (bmNode9.operation - 1).u64)
            ) then return true
            if (objectHasYieldMethod
                :ast
                n: (ast.nodes.get i: (bmNode9.operation - 1).u64)
            ) then return true
        }
    }
    return false
}

# objectHasYieldMethod -- any is/as member of an object definition whose
# body suspends.
objectHasYieldMethod: function {ast: Ast n: Node} out bool is {
    match (
        n
    ) case objectdef then {
        aiter: n.asItems.iterate
        for amId9: aiter loop {
            am: ast.nodes.get i: (amId9 - 1).u64
            match (
                am
            ) case namedoperation then {
                if (zgenerator.fnBodyHasYield
                    :ast
                    n: (ast.nodes.get i: (am.operation - 1).u64)
                ) then return true
            } else null
        }
        iiter: n.isItems.iterate
        for imId9: iiter loop {
            im: ast.nodes.get i: (imId9 - 1).u64
            match (
                im
            ) case namedoperation then {
                if (zgenerator.fnBodyHasYield
                    :ast
                    n: (ast.nodes.get i: (im.operation - 1).u64)
                ) then return true
            } else null
        }
        return false
    } else {
        return false
    }
}

# resolveNamedDefsIn -- resolve exactly the named top-level defs of one
# unit. The generator pass runs pre-index (no node finder, no descent), so
# it walks the unitdef it already holds instead of the demand machinery.
resolveNamedDefsIn: function {
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    ast: Ast
    unitName: StringView
    unitdefId: u32
    wantA: StringView
    wantB: StringView
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: unitdefId
    {
        biter: bodyIds9.iterate
        for bm: biter loop {
            bmNode9: ast.nodes.get i: (bm - 1).u64
            match (
                bmNode9
            ) case namedoperation then {
                dn: zast.nameTextCopy :ast ref: bmNode9.name
                hit: false
                if dn.stringview == wantA then hit = true
                if dn.stringview == wantB then hit = true
                if hit then {
                    rkey: "\{unitName}.\{dn}"
                    if (ty.definedKeys.has item: rkey) == false then {
                        (resolveDef
                            :ty
                            :reg
                            :ast
                            :unitName
                            defName: dn.stringview
                            defn: (ast.nodes.get i: (bmNode9.operation - 1).u64)
                        )
                    }
                }
            } else null
        }
    }
}

# lowerGenerators -- the generator lowering pass (the reference's
# _lower_generators): for each unit, rewrite every yield-function whose
# declared return head resolves to the stdlib Iterator protocol into a
# synth iterator class + a factory. Runs before main-unit resolution so
# the rewritten definitions flow through the normal walk; the Iterator
# protocol resolves through a targeted demand only when a suspending
# function exists, so non-generator programs never touch it.
lowerGenerators: function {ty: ztyping.ZTyping reg: ztypes.ZTypeRegistry program: Node} is {
    match (
        program
    ) case program then {
        anyYield: false
        uCnt9e: program.ast.units.length
        uIdx9e: u64
        for uIdx9e < uCnt9e loop {
            yuId9: program.ast.units.get i: uIdx9e
            uIdx9e = uIdx9e + 1
            yOpId9: u32
            {
                yu: program.ast.nodes.get i: (yuId9 - 1).u64
                if yu.namedoperation then yOpId9 = yu.operation
            }
            if yOpId9 > 0 then {
                if (unitHasYieldFn
                    ast: program.ast
                    unitdefId: yOpId9
                ) then anyYield = true
            }
        }
        if (anyYield) == false then return
        suN0: program.ast.units.length
        suI0: u64
        for suI0 < suN0 loop {
            suId9: program.ast.units.get i: suI0
            suI0 = suI0 + 1
            sOpId9: u32
            {
                su: program.ast.nodes.get i: (suId9 - 1).u64
                if su.namedoperation then {
                    snm: zast.poolTextCopy pool: program.ast.names ref: su.name
                    if snm.stringview == "system" then sOpId9 = su.operation
                }
            }
            if sOpId9 > 0 then {
                (resolveNamedDefsIn
                    :ty
                    :reg
                    ast: program.ast
                    unitName: "system"
                    unitdefId: sOpId9
                    wantA: "Iterator"
                    wantB: "optionval"
                )
            }
        }
        ik: "system.Iterator".string
        iterTid: optU64Or o: (resolvedByKey ast: program.ast :ty :reg key: ik) d: 0
        if iterTid == 0 then return
        ids: zgenerator.newGenIds
        ui: u64
        un: program.ast.units.length
        for ui < un loop {
            uelId9: program.ast.units.get i: ui
            ui = ui + 1
            uOpId9: u32
            {
                uel: program.ast.nodes.get i: (uelId9 - 1).u64
                if uel.namedoperation then uOpId9 = uel.operation
            }
            if uOpId9 > 0 then {
                (lowerGeneratorsInUnit
                    :ty
                    :ids
                    ast: program.ast
                    unitdefId: uOpId9
                )
            }
        }
    } else null
}

# lowerGeneratorsInUnit -- candidates collect first (indexes + names),
# then each lowers by index: the functiondef moves out of its
# namedoperation slot, the factory moves in, and the synth class appends
# to the unit body under `{name}_iter`.
lowerGeneratorsInUnit: function {
    ty: ztyping.ZTyping
    ids: zgenerator.GenIds
    ast: Ast
    unitdefId: u32
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: unitdefId
    {
        cIdx: (List u64)
        bi: u64
        bn: bodyIds9.length
        for bi < bn loop {
            bmId9: bodyIds9.get i: bi
            bm: ast.nodes.get i: (bmId9 - 1).u64
            isCand: false
            match (
                bm
            ) case namedoperation then {
                if (zgenerator.fnBodyHasYield
                    :ast
                    n: (ast.nodes.get i: (bm.operation - 1).u64)
                ) then {
                    hd: zgenerator.returnHeadName :ast n: (ast.nodes.get i: (bm.operation - 1).u64)
                    if hd.stringview == "Iterator" then {
                        if (zgenerator.canLowerNow
                            :ast
                            n: (ast.nodes.get i: (bm.operation - 1).u64)
                            hasReceiver: false
                        ) then isCand = true
                    }
                }
            } else null
            if isCand then {
                bic: bi
                cIdx.append bic
            }
            bi = bi + 1
        }
        stagedCls: (List Node)
        ci: u64
        cn: cIdx.length
        for ci < cn loop {
            idx: cIdx.get i: ci
            uel2Id9: bodyIds9.get i: idx
            # scope the row view: lowering appends to the table below, and a
            # live row view must not span a growing append
            opId9: u32
            dnm: String
            {
                uel2: ast.nodes.get i: (uel2Id9 - 1).u64
                match (
                    uel2
                ) case namedoperation then {
                    dnm = zast.nameTextCopy :ast ref: uel2.name
                    opId9 = uel2.operation
                } else null
            }
            if opId9 > 0 then {
                sname: "\{dnm}_iter"
                fnNode: zast.tableTake :ast id: opId9
                lowOpt: (zgenerator.lowerOne :ast
                    :ids
                    fn: fnNode
                    synthName: sname.stringview
                    receiverType: ""
                )
                match (
                    lowOpt
                ) case some then {
                    wfid: lowOpt.wrapperNodeId
                    wfv: true
                    ty.generatorWrapper.set key: wfid.u64 value: wfv
                    # the create-param and field-path clones must not stamp:
                    # the reference shares those nodes with the factory, so
                    # each ref carries exactly one stamp.
                    nsi: u64
                    nsn: lowOpt.noStamp.length
                    for nsi < nsn loop {
                        ns0: lowOpt.noStamp.get i: nsi
                        nsk: ns0.u64
                        nsv: true
                        ty.noStampNode.set key: nsk value: nsv
                        nsi = nsi + 1
                    }
                    fac: lowOpt.factory.take
                    facId9: zast.tableAppendRebase :ast n: fac
                    {
                        uel2w: ast.nodes.get i: (uel2Id9 - 1).u64
                        match (
                            uel2w
                        ) case namedoperation then {
                            uel2w.operation = facId9
                        } else null
                    }
                    cls: lowOpt.synthClass.take
                    clsN: (zgenerator.mkNamedOp
                        :ast
                        :ids
                        line: 0
                        col: 0
                        name: sname.stringview
                        op: cls
                    )
                    stagedCls.append clsN
                } case none then null
            }
            ci = ci + 1
        }
        # staged synth classes append after the loop: uel2's element view
        # ends with each iteration, and the list must not grow under it.
        for stagedCls.length > 0 loop {
            sc0: stagedCls.pop
            bodyIds9.append (zast.tableAppendRebase :ast n: sc0)
        }
        # method generators: each object definition's members lower the
        # same way, named {Type}_{method}_iter, with the receiver context.
        # Synth classes stage locally; the double-pop drain preserves order.
        pendingCls: (List Node)
        ogi: u64
        ogn: bodyIds9.length
        for ogi < ogn loop {
            oelId9: bodyIds9.get i: ogi
            oel: ast.nodes.get i: (oelId9 - 1).u64
            match (
                oel
            ) case namedoperation then {
                tnm: zast.nameTextCopy :ast ref: oel.name
                if tnm.length > 0 then {
                    (lowerGeneratorMethods
                        :ast
                        :ty
                        :ids
                        typeName: tnm.stringview
                        defn: (ast.nodes.get i: (oel.operation - 1).u64)
                        dst: pendingCls
                    )
                }
            } else null
            ogi = ogi + 1
        }
        revCls: (List Node)
        for pendingCls.length > 0 loop {
            pc0: pendingCls.pop
            revCls.append pc0
        }
        for revCls.length > 0 loop {
            rc0: revCls.pop
            bodyIds9.append (zast.tableAppendRebase :ast n: rc0)
        }
        # the synth members were staged on the working list; write the new
        # tail back into the unit row, whose view is scoped to the write
        {
            u9: ast.nodes.get i: (unitdefId - 1).u64
            if u9.unitdef then {
                wi9: u9.body.length
                wn9: bodyIds9.length
                for wi9 < wn9 loop {
                    nid9: bodyIds9.get i: wi9
                    u9.body.append nid9
                    wi9 = wi9 + 1
                }
            }
        }
    }
}

# lowerGeneratorMethods -- lower the generator methods of one object
# definition (as-block first, then is-block), replacing each method with
# its factory in place and appending the synth class to the unit body.
lowerGeneratorMethods: function {
    ast: Ast
    ty: ztyping.ZTyping
    ids: zgenerator.GenIds
    typeName: StringView
    defn: Node
    dst: List Node
} is {
    match (
        defn
    ) case objectdef then {
        lowerGeneratorItems :ast :ty :ids :typeName items: defn.asItems :dst
        lowerGeneratorItems :ast :ty :ids :typeName items: defn.isItems :dst
    } else null
}

lowerGeneratorItems: function {
    ast: Ast
    ty: ztyping.ZTyping
    ids: zgenerator.GenIds
    typeName: StringView
    items: List u32
    dst: List Node
} is {
    bi: u64
    bn: items.length
    for bi < bn loop {
        bmId9: items.get i: bi
        bm: ast.nodes.get i: (bmId9 - 1).u64
        isCand: false
        match (
            bm
        ) case namedoperation then {
            if (zgenerator.fnBodyHasYield :ast n: (ast.nodes.get i: (bm.operation - 1).u64)) then {
                hd: zgenerator.returnHeadName :ast n: (ast.nodes.get i: (bm.operation - 1).u64)
                if hd.stringview == "Iterator" then {
                    if (zgenerator.canLowerNow
                        :ast
                        n: (ast.nodes.get i: (bm.operation - 1).u64)
                        hasReceiver: true
                    ) then isCand = true
                }
            }
        } else null
        if isCand then {
            bm2Id9: items.get i: bi
            bm2: ast.nodes.get i: (bm2Id9 - 1).u64
            match (
                bm2
            ) case namedoperation then {
                mnm: zast.nameTextCopy :ast ref: bm2.name
                sname: "\{typeName}_\{mnm}_iter"
                fnNode: zast.tableTake :ast id: bm2.operation
                lowOpt: (zgenerator.lowerOne :ast
                    :ids
                    fn: fnNode
                    synthName: sname.stringview
                    receiverType: typeName
                )
                match (
                    lowOpt
                ) case some then {
                    wfid: lowOpt.wrapperNodeId
                    wfv: true
                    ty.generatorWrapper.set key: wfid.u64 value: wfv
                    nsi: u64
                    nsn: lowOpt.noStamp.length
                    for nsi < nsn loop {
                        ns0: lowOpt.noStamp.get i: nsi
                        nsk: ns0.u64
                        nsv: true
                        ty.noStampNode.set key: nsk value: nsv
                        nsi = nsi + 1
                    }
                    fac: lowOpt.factory.take
                    bm2.operation = zast.tableAppendRebase :ast n: fac
                    cls: lowOpt.synthClass.take
                    clsN: (zgenerator.mkNamedOp
                        :ast
                        :ids
                        line: 0
                        col: 0
                        name: sname.stringview
                        op: cls
                    )
                    dst.append clsN
                } case none then null
            } else null
        }
        bi = bi + 1
    }
}

# Resolve a bare type name to its id through the units-as-containers hierarchy,
# over the bare-name visibility order (the current unit shadows the stdlib
# units: system, collections, io, core, os, cli) -- the SOLE encoding of that
# order. It serves internal/mangled queries (mono names, dotted member keys)
# beyond the source-level prelude surface, so it keeps the full root list
# where the index side (definingUnitFor) narrowed to current-unit + prelude.
# walkUnitProbe9 -- one unit-scope probe of the typeref walk: none when the
# unit is unknown or has no such child.
walkUnitProbe9: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    uname: StringView
    base: StringView
} out optionval u64 is {
    uido: reg.unitNameTid.getv key: uname
    match (
        uido
    ) case some then {
        return (ty.childOf pool: ast.names parentTypeId: uido name: base)
    } case none then {
        return (optionval.none u64)
    }
}

walkLookupTyperef: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    currentUnit: StringView
    base: StringView
} out optionval u64 is {
    r9: walkUnitProbe9 :ast :ty :reg uname: currentUnit :base
    match (
        r9
    ) case some then {
        return (optionval.some r9)
    } case none then null
    r8: walkUnitProbe9 :ast :ty :reg uname: "system" :base
    match (
        r8
    ) case some then {
        return (optionval.some r8)
    } case none then null
    r7: walkUnitProbe9 :ast :ty :reg uname: "collections" :base
    match (
        r7
    ) case some then {
        return (optionval.some r7)
    } case none then null
    r6: walkUnitProbe9 :ast :ty :reg uname: "io" :base
    match (
        r6
    ) case some then {
        return (optionval.some r6)
    } case none then null
    r5: walkUnitProbe9 :ast :ty :reg uname: "core" :base
    match (
        r5
    ) case some then {
        return (optionval.some r5)
    } case none then null
    r4: walkUnitProbe9 :ast :ty :reg uname: "os" :base
    match (
        r4
    ) case some then {
        return (optionval.some r4)
    } case none then null
    r3: walkUnitProbe9 :ast :ty :reg uname: "cli" :base
    match (
        r3
    ) case some then {
        return (optionval.some r3)
    } case none then null
    return (optionval.none u64)
}

# resolvedByKey -- resolve a "unit.name[.member]" key by walking childOf from the
# unit root; falls back to the flat resolved map for keys not yet mirrored in
# childOf (during-resolution reads) or non-type binding keys. The read path off
# the flat map (Stage A). Free fn (not a ZTyping method) so smoke-built low-level
# modules never pull in .split.
# resolveUnitChild -- the (unit, name) form of resolvedByKey's two-segment
# walk: no composed key, no split. resolveSystemChild probes the cached
# system unit root with no allocation at all.
resolveUnitChild: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    name: StringView
} out optionval u64 is {
    ro: reg.unitNameTid.get key: unitName.string
    match (
        ro
    ) case some then {
        co: ty.childOf pool: ast.names parentTypeId: ro :name
        match (
            co
        ) case some then {
            return (optionval.some co)
        } case none then null
    } case none then null
    # miss: the composed-key path follows unit-level aliases and lays the
    # unit->alias edge, so the next probe resolves through childOf above
    ck9: "\{unitName}.\{name}"
    return (resolvedByKey :ast :ty :reg key: ck9)
}

resolveSystemChild: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    name: StringView
} out optionval u64 is {
    if ty.systemUnitTid > 0 then {
        co: ty.childOf pool: ast.names parentTypeId: ty.systemUnitTid :name
        match (
            co
        ) case some then {
            return (optionval.some co)
        } case none then null
    }
    ck9: "system.\{name}"
    return (resolvedByKey :ast :ty :reg key: ck9)
}

# --- id-keyed resolution twins: same shape as the text resolvers above, but
# the child name arrives as an already-interned Ast.names pool id, so each
# probe is a childOfId (no per-stage StringPool.find). The composed-key miss
# path materialises the name text once via poolTextCopy (rare). ---

walkUnitProbe9ById: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    uname: StringView
    baseId: u32
} out optionval u64 is {
    uido: reg.unitNameTid.getv key: uname
    match (
        uido
    ) case some then {
        return (ty.childOfId parentTypeId: uido nameId: baseId.u64)
    } case none then {
        return (optionval.none u64)
    }
}

walkLookupTyperefById: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    currentUnit: StringView
    baseId: u32
} out optionval u64 is {
    r9: walkUnitProbe9ById :ast :ty :reg uname: currentUnit :baseId
    match (
        r9
    ) case some then {
        return (optionval.some r9)
    } case none then null
    r8: walkUnitProbe9ById :ast :ty :reg uname: "system" :baseId
    match (
        r8
    ) case some then {
        return (optionval.some r8)
    } case none then null
    r7: walkUnitProbe9ById :ast :ty :reg uname: "collections" :baseId
    match (
        r7
    ) case some then {
        return (optionval.some r7)
    } case none then null
    r6: walkUnitProbe9ById :ast :ty :reg uname: "io" :baseId
    match (
        r6
    ) case some then {
        return (optionval.some r6)
    } case none then null
    r5: walkUnitProbe9ById :ast :ty :reg uname: "core" :baseId
    match (
        r5
    ) case some then {
        return (optionval.some r5)
    } case none then null
    r4: walkUnitProbe9ById :ast :ty :reg uname: "os" :baseId
    match (
        r4
    ) case some then {
        return (optionval.some r4)
    } case none then null
    r3: walkUnitProbe9ById :ast :ty :reg uname: "cli" :baseId
    match (
        r3
    ) case some then {
        return (optionval.some r3)
    } case none then null
    return (optionval.none u64)
}

resolveUnitChildById: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    unitName: StringView
    nameId: u32
} out optionval u64 is {
    ro: reg.unitNameTid.get key: unitName.string
    match (
        ro
    ) case some then {
        co: ty.childOfId parentTypeId: ro nameId: nameId.u64
        match (
            co
        ) case some then {
            return (optionval.some co)
        } case none then null
    } case none then null
    nm9: zast.poolTextCopy pool: ast.names ref: nameId
    ck9: "\{unitName}.\{nm9}"
    return (resolvedByKey :ast :ty :reg key: ck9)
}

resolveSystemChildById: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    nameId: u32
} out optionval u64 is {
    if ty.systemUnitTid > 0 then {
        co: ty.childOfId parentTypeId: ty.systemUnitTid nameId: nameId.u64
        match (
            co
        ) case some then {
            return (optionval.some co)
        } case none then null
    }
    nm9: zast.poolTextCopy pool: ast.names ref: nameId
    ck9: "system.\{nm9}"
    return (resolvedByKey :ast :ty :reg key: ck9)
}

childOfWalk: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    key: String
} out optionval u64 is {
    # two-segment fast path ("unit.name" -- the dominant key shape): view
    # slices instead of a splitter iterator and per-segment strings
    {
        kv9: key.stringview
        d1: kv9.indexOf needle: "."
        match (
            d1
        ) case some then {
            twoSeg9: false
            {
                rest0: kv9.substring from: d1 + 1 to: kv9.length
                d2: rest0.indexOf needle: "."
                match (
                    d2
                ) case some then null case none then twoSeg9 = true
            }
            if twoSeg9 then {
                ro9: u64
                roOk9: false
                {
                    useg9: kv9.substring from: 0 to: d1
                    rg9: reg.unitNameTid.getv key: useg9
                    match (
                        rg9
                    ) case some then {
                        ro9 = rg9
                        roOk9 = true
                    } case none then null
                }
                rox9: (optionval.none u64)
                if roOk9 then rox9 = (optionval.some ro9)
                roN9: rox9
                match (
                    roN9
                ) case some then {
                    rest9: kv9.substring from: d1 + 1 to: kv9.length
                    return (ty.childOf pool: ast.names parentTypeId: roN9 name: rest9)
                } case none then {
                    return (optionval.none u64)
                }
            }
        } case none then null
    }
    cur: u64
    started: false
    ok: true
    with it: (key.stringview.split sep: ".") do for seg: it loop {
        if ok then {
            if started == false then {
                ro: reg.unitNameTid.get key: seg.string
                match (
                    ro
                ) case some then {
                    cur = ro
                    started = true
                } case none then {
                    ok = false
                }
            } else {
                co: ty.childOf pool: ast.names parentTypeId: cur name: seg
                match (
                    co
                ) case some then {
                    cur = co
                } case none then {
                    ok = false
                }
            }
        }
    }
    if ok when started then return (optionval.some cur)
    return (optionval.none u64)
}

resolvedByKey: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    key: String
} out optionval u64 is {
    wo: childOfWalk :ast :ty :reg :key
    match (
        wo
    ) case some then {
        return (optionval.some wo)
    } case none then null
    # On-demand alias resolution (no descend, no units): if `key` is a unit-level type
    # alias, resolve its target with a childOf-only walk and lay the unit->alias edge,
    # so this and future lookups resolve through childOf instead of the flat map. The
    # target walk does NOT recurse through this alias-follow, so it always terminates
    # and a cyclic alias (whose target never has a childOf edge) falls through to the
    # existing cycle diagnostic rather than being silently followed.
    alTgt9: String
    alHit9: false
    {
        ao: ty.funcAliases.getv key: key.stringview
        match (
            ao
        ) case some then {
            alTgt9 = ao.copy
            alHit9 = true
        } case none then null
    }
    if alHit9 then {
        tgo: childOfWalk :ast :ty :reg key: alTgt9
        match (
            tgo
        ) case some then {
            au: String
            an: String
            with sk: (key.stringview.split sep: ".") do for sg: sk loop {
                if au.length == 0 then {
                    au = sg.string
                } else {
                    an = sg.string
                }
            }
            uro: reg.unitNameTid.get key: au
            match (
                uro
            ) case some then {
                # memo write only when the alias name is interned (always,
                # once labels intern at parse); the resolution result never
                # depends on it
                anid9: (ast.names.find s: an.stringview).u64
                if anid9 > 0 then ty.setChildId parentTypeId: uro nameId: anid9 childTypeId: tgo
            } case none then null
            return (optionval.some tgo)
        } case none then null
    }
    return (optionval.none u64)
}

# shellScalarName -- a shell named like a C scalar stays a shell: the
# emitter spells those by NAME (cTypeOf) before any canonicalization, so
# rebinding them would change shadow semantics. Mirrors cTypeOf's set.
shellScalarName: function {name: StringView} out bool is {
    if name == "i8" then return true
    if name == "i16" then return true
    if name == "i32" then return true
    if name == "i64" then return true
    if name == "u8" then return true
    if name == "u16" then return true
    if name == "u32" then return true
    if name == "u64" then return true
    if name == "i128" then return true
    if name == "u128" then return true
    if name == "f32" then return true
    if name == "f64" then return true
    if name == "bool" then return true
    if name == "literal_int" then return true
    return false
}

# shellResolveByName -- the emitter's shell resolution order for `name` seen
# from `unit`: the unit-local key, the system key, the walk list, then the
# registry-wide cross-unit scan. 0 when nothing resolves.
# canonShellTid -- the canonical id for a SHELL stamp value, 0 to leave
# the stamp alone. Mirrors canonicalizeShellChildren's shell detection
# (no defining unit, not a generic param / scalar shell / as-const clone
# / typeof shell); memoized per shell id.
canonShellTid: function {
    ast: Ast
    st: zenv.ZSymbolTable
    cache9: (Map u64 value: u64)
    tid: u64
    mainName: StringView
} out u64 is {
    if tid == 0 then return 0
    co9: cache9.get key: tid
    match (
        co9
    ) case some then {
        return co9
    } case none then null
    res9: u64
    ok9: (st.reg.typetypeOf typeId: tid) != ztypes.ztypetype.genericParam
    if ok9 then {
        duo9: st.typing.definedInUnit.get key: tid
        match (
            duo9
        ) case some then {
            ok9 = false
        } case none then null
    }
    if ok9 then {
        nm9: regTypeNameOf reg: st.reg :tid
        if (shellScalarName name: nm9.stringview) then nm9 = "".string
        aco9: st.typing.asConstClone.get key: tid
        match (
            aco9
        ) case some then {
            if aco9 then nm9 = "".string
        } case none then null
        tso9: st.typing.typeofShell.get key: tid
        match (
            tso9
        ) case some then {
            nm9 = "".string
        } case none then null
        if nm9.length > 0 then {
            rid9: (shellResolveByName
                :ast
                ty: st.typing
                reg: st.reg
                fromUnit: mainName
                name: nm9.stringview
            )
            if rid9 > 0 when rid9 != tid then res9 = rid9
        }
    }
    kc9: tid
    vc9: res9
    cache9.set key: kc9 value: vc9
    return res9
}

# canonicalizeShellNodeStamps -- checkBodies runs BEFORE the shell-child
# canonicalization, so expression nodes typed through a then-shell edge
# carry the shell id in nodeType (and memberOwnerTid / dpTaggedParent):
# the emitter reads receiver types from those stamps, and a shell has no
# origin/children to dispatch on. Rebind them to the canonical type like
# the child edges.
canonicalizeShellNodeStamps: function {ast: Ast st: zenv.ZSymbolTable mainName: StringView} is {
    cache9: (Map u64 value: u64)
    nids9: (List u64)
    vals9: (List u64)
    with it9: st.typing.nodeType.iterateItems do for e9: it9 loop {
        rid9: canonShellTid :ast :st :cache9 tid: e9.value :mainName
        if rid9 > 0 then {
            nids9.append e9.key
            vals9.append rid9
        }
    }
    i9: u64
    for i9 < nids9.length loop {
        k9: nids9.get i: i9
        v9: vals9.get i: i9
        st.typing.nodeType.set key: k9 value: v9
        i9 = i9 + 1
    }
    mnids9: (List u64)
    mvals9: (List u64)
    with mt9: st.typing.memberOwnerTid.iterateItems do for m9: mt9 loop {
        rid2: canonShellTid :ast :st :cache9 tid: m9.value :mainName
        if rid2 > 0 then {
            mnids9.append m9.key
            mvals9.append rid2
        }
    }
    j9: u64
    for j9 < mnids9.length loop {
        k2: mnids9.get i: j9
        v2: mvals9.get i: j9
        st.typing.memberOwnerTid.set key: k2 value: v2
        j9 = j9 + 1
    }
    dnids9: (List u64)
    dvals9: (List u64)
    with dt9: st.typing.dpTaggedParent.iterateItems do for d9: dt9 loop {
        rid3: canonShellTid :ast :st :cache9 tid: d9.value :mainName
        if rid3 > 0 then {
            dnids9.append d9.key
            dvals9.append rid3
        }
    }
    l9: u64
    for l9 < dnids9.length loop {
        k3: dnids9.get i: l9
        v3: dvals9.get i: l9
        st.typing.dpTaggedParent.set key: k3 value: v3
        l9 = l9 + 1
    }
    pnids9: (List u64)
    pvals9: (List u64)
    with pt9: st.typing.dpArmPredicate.iterateItems do for p9: pt9 loop {
        rid4: canonShellTid :ast :st :cache9 tid: p9.value :mainName
        if rid4 > 0 then {
            pnids9.append p9.key
            pvals9.append rid4
        }
    }
    q9: u64
    for q9 < pnids9.length loop {
        k4: pnids9.get i: q9
        v4: pvals9.get i: q9
        st.typing.dpArmPredicate.set key: k4 value: v4
        q9 = q9 + 1
    }
    tnids9: (List u64)
    tvals9: (List u64)
    with tt9: st.typing.dpTagRead.iterateItems do for t9: tt9 loop {
        rid5: canonShellTid :ast :st :cache9 tid: t9.value :mainName
        if rid5 > 0 then {
            tnids9.append t9.key
            tvals9.append rid5
        }
    }
    r9: u64
    for r9 < tnids9.length loop {
        k5: tnids9.get i: r9
        v5: tvals9.get i: r9
        st.typing.dpTagRead.set key: k5 value: v5
        r9 = r9 + 1
    }
    gnids9: (List u64)
    gvals9: (List u64)
    with gt9: st.typing.postGuardTid.iterateItems do for g9: gt9 loop {
        rid7: canonShellTid :ast :st :cache9 tid: g9.value :mainName
        if rid7 > 0 then {
            gnids9.append g9.key
            gvals9.append rid7
        }
    }
    y9: u64
    for y9 < gnids9.length loop {
        k7: gnids9.get i: y9
        v7: gvals9.get i: y9
        st.typing.postGuardTid.set key: k7 value: v7
        y9 = y9 + 1
    }
    anids9: (List u64)
    avals9: (List u64)
    with at9: st.typing.tagAccessorTid.iterateItems do for a9: at9 loop {
        rid6: canonShellTid :ast :st :cache9 tid: a9.value :mainName
        if rid6 > 0 then {
            anids9.append a9.key
            avals9.append rid6
        }
    }
    w9: u64
    for w9 < anids9.length loop {
        k6: anids9.get i: w9
        v6: avals9.get i: w9
        st.typing.tagAccessorTid.set key: k6 value: v6
        w9 = w9 + 1
    }
}

shellResolveByName: function {
    ast: Ast
    ty: ztyping.ZTyping
    reg: ztypes.ZTypeRegistry
    fromUnit: StringView
    name: StringView
} out u64 is {
    r1: resolveUnitChild :ast :ty :reg unitName: fromUnit :name
    match (
        r1
    ) case some then {
        return r1
    } case none then null
    r2: resolveSystemChild :ast :ty :reg :name
    match (
        r2
    ) case some then {
        return r2
    } case none then null
    r3: walkLookupTyperef :ast :ty :reg currentUnit: fromUnit base: name
    match (
        r3
    ) case some then {
        return r3
    } case none then null
    unames9: (List String)
    with uit9: reg.unitNameTid.iterateItems do for ue9: uit9 loop {
        uk9: ue9.key.copy
        unames9.append uk9
    }
    found9: u64
    ui9: u64
    for ui9 < unames9.length loop {
        if found9 == 0 then {
            un9: unames9.get i: ui9
            k9: "\{un9}.\{name}"
            r9: resolvedByKey :ast :ty :reg key: k9
            match (
                r9
            ) case some then {
                found9 = r9
            } case none then null
        }
        ui9 = ui9 + 1
    }
    return found9
}

# canonicalizeShellChildren -- rebind every childTypeById edge whose value is
# a SHELL id (a name-minted reference with no defining unit) to the canonical
# type, resolved in the edge's parent's defining unit with the emitter's
# resolution order. Runs post-resolution so the emitter reads canonical child
# ids and never re-resolves a child by name.
canonicalizeShellChildren: function {ast: Ast st: zenv.ZSymbolTable mainName: StringView} is {
    ri9: u64
    rn9: st.typing.typeChild.length
    for ri9 < rn9 loop {
        rpt9: u64
        rcn9: u64
        {
            row: st.typing.typeChild.get i: ri9
            rpt9 = row.parentTypeId
            rcn9 = row.childNameId
        }
        cto9: u64
        {
            ctoO9: st.typing.childTypeById.get key: rcn9
            match (
                ctoO9
            ) case some then {
                cto9 = ctoO9
            } case none then null
        }
        ok9: cto9 > 0
        if ok9 when (st.reg.typetypeOf typeId: cto9) == ztypes.ztypetype.genericParam then {
            ok9 = false
        }
        if ok9 then {
            duo9: st.typing.definedInUnit.get key: cto9
            match (
                duo9
            ) case some then {
                ok9 = false
            } case none then null
        }
        if ok9 then {
            pu9: mainName.string
            {
                puo9: st.typing.definedInUnit.get key: rpt9
                match (
                    puo9
                ) case some then {
                    pu9 = puo9.copy
                } case none then null
            }
            nm9: regTypeNameOf reg: st.reg tid: cto9
            if (shellScalarName name: nm9.stringview) then nm9 = "".string
            {
                aco9: st.typing.asConstClone.get key: cto9
                match (
                    aco9
                ) case some then {
                    if aco9 then nm9 = "".string
                } case none then null
            }
            {
                tso9: st.typing.typeofShell.get key: cto9
                match (
                    tso9
                ) case some then {
                    nm9 = "".string
                } case none then null
            }
            if nm9.length > 0 then {
                rid9: (shellResolveByName
                    :ast
                    ty: st.typing
                    reg: st.reg
                    fromUnit: pu9.stringview
                    name: nm9.stringview
                )
                if rid9 > 0 when rid9 != cto9 then {
                    setc9: rid9
                    st.typing.childTypeById.set key: rcn9 value: setc9
                }
            }
        }
        ri9 = ri9 + 1
    }
}


typecheck: function {
    program: Node
    reg: ztypes.ZTypeRegistry.take
    full: bool
} out zenv.ZSymbolTable is {
    nodeEstT9: u64
    match (
        program
    ) case program then {
        nodeEstT9 = program.ast.nodes.length
    } else null
    ty: ztyping.newTyping nodeEst: nodeEstT9
    match (
        program
    ) case program then {
        reg.setMainUnit name: program.mainUnitName.stringview
    } else null
    # id 0 is the no-type / unresolved sentinel that checkValue returns on failure.
    # The null VALUE-type is a normal canonical id resolved by name; a `null` arm's
    # child type is always that canonical id, never 0.
    reg.newType name: "notype" typetype: ztypes.ztypetype.nullType
    st: zenv.newSymbolTable :reg typing: ty
    # Stage D: mint every unit's root + fill unitNameTid BEFORE any demand
    # resolution (lowerGenerators pre-resolves system.Iterator/optionval when a
    # generator is present), so childOf-at-mint always sees a populated unit root.
    registerUnitRoots ty: st.typing reg: st.reg :program
    {
        sysUo9: st.reg.unitNameTid.get key: "system".string
        match (
            sysUo9
        ) case some then {
            st.typing.systemUnitTid = sysUo9
        } case none then null
    }
    match (
        program
    ) case program then {
        (declareCanonicalType
            ast: program.ast
            ty: st.typing
            reg: st.reg
            defUnit: "system"
            name: "never"
            typetype: ztypes.ztypetype.neverType
        )
        (declareCanonicalType
            ast: program.ast
            ty: st.typing
            reg: st.reg
            defUnit: "system"
            name: "null"
            typetype: ztypes.ztypetype.nullType
        )
    } else null
    populatePrelude ty: st.typing reg: st.reg :program
    lowerGenerators ty: st.typing reg: st.reg :program
    indexUnitDefs ty: st.typing :program
    registerAndResolveMain ty: st.typing reg: st.reg :program :full
    resolveMainUnitInstantiations ty: st.typing reg: st.reg :program
    if full then scanMainBodyCalls reg: st.reg :program
    resolveDemandsByDescent ty: st.typing reg: st.reg :program :full
    match (
        program
    ) case program then {
        resolveTypeAliases ast: program.ast ty: st.typing reg: st.reg
        (fixupCustomTags
            ast: program.ast
            ty: st.typing
            reg: st.reg
            mainName: program.mainUnitName.stringview
        )
    } else null
    if full then {
        resolveConstantDefs ty: st.typing reg: st.reg :program
        completeUnitInstantiations ty: st.typing reg: st.reg :program
    }
    stampTyperefs ty: st.typing reg: st.reg :program
    if full then {
        checkBodies :st :program
        match (
            program
        ) case program then {
            stampCtorDefaults ast: program.ast :st unitName: program.mainUnitName.stringview
        } else null
        foldLiteralStamps :st :program
        match (
            program
        ) case program then {
            canonicalizeShellChildren ast: program.ast :st mainName: program.mainUnitName.stringview
            (canonicalizeShellNodeStamps
                ast: program.ast
                :st
                mainName: program.mainUnitName.stringview
            )
        } else null
    }
    return st
}

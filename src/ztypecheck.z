                if lid9 > 0.u32 then {
                    setlc9: lct9
                    st.typing.nodeType.set key: lid9.u64 value: setlc9
                } else {
                }
            } else {
            }
            if rLit9 when lt > 0.u64 then {
                rct9: comparisonCoerceTarget st: st unitName: unitName concrete: lt op: opn.stringview
                rid9: innermostNodeId n: binop.rhs
                if rid9 > 0.u32 then {
                    setrc9: rct9
                    st.typing.nodeType.set key: rid9.u64 value: setrc9
                } else {
                }
            } else {
            }
        }
    } else {
        result = lt
        # Operator children delegate (a boxed value's `+` is the element's,
        # so the result is the element type, not the box).
        opo: st.typing.childOf parentTypeId: lt name: opn.stringview
        match (
            opo
        ) case some then {
            oro: methodReturnOf st: st mid: opo
            match (
                oro
            ) case some then {
                result = oro
            } case none then {
            }
        } case none then {
        }
    }
    tdb2: typedefBaseOf st: st unitName: unitName tid: result
    if tdb2 > 0.u64 then {
        result = tdb2
    } else {
    }
    if result > 0.u64 when (st.reg.typetypeOf typeId: result) == ztypes.ztypetype.GENERIC_PARAM then {
        return 0.u64
    } else {
    }
    if result > 0.u64 then {
        setk: result
        st.typing.nodeType.set key: binop.nodeid.u64 value: setk
    } else {
    }
    return result
}

# argIsTrivial -- true when a call argument's operation is a hoisting no-op: a
# bare atom, a labelvalue, a string literal without interpolation, or an
# expression wrapping a bare atom / labelvalue. Anything else (binop, call,

                    # marker. Report the receiver root so the binding goes
                    # borrowed (payload moves rejected, view lock installed).
                    if mres > 0 when mlr.length == 0 then {
                        if (isViewFamilyTid :ast :st tid: mres) then {
                            rtupV: (List String)
                            xq39: ast.nodes.get i: (call.callable - 1).u64
                            methodReceiverTuple :ast n: xq39 dst: rtupV
                            if rtupV.length > 0 then {
                                rvb9: st.lookupVarId name: (rtupV.get i: 0).stringview
                                match (
                                    rvb9
                                ) case some then {
                                    drainPendingBorrow :st
                                    with tiv: rtupV.iterate do for segV: tiv loop {

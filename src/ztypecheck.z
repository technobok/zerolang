                        gmid = (inferGenericConstruction
                            :st
                            :unitName
                            :ast :unitBody
                            :call
                            tplId: funcId
                            reportMissing: vok9
                        )
                    }
                    if gmid > 0 then {
                        calid9: nodeId n: (ast.nodes.get i: (call.callable - 1).u64)
                        if calid9 > 0 then {
                            setc9: gmid
                            st.typing.nodeType.set key: calid9.u64 value: setc9
                        }
                        cm9: st.pushCall
                        _wlr29: (walkCallArgsHoist
                            :st
                            :unitName
                            :ast :unitBody
                            :call
                            funcId: gmid
                            isCtor: true
                            reportUnknown: false
                            recvImplicit: false
                        )
                        checkMissingCallArgs :ast :st :call funcId: gmid isCtor: true
                        st.popTo marker: cm9
                        ctk9: gmid
                        ctv9: true
                        st.typing.constructedTypes.set key: ctk9 value: ctv9
                        setr9: gmid
                        st.typing.nodeType.set key: call.nodeid.u64 value: setr9
                        return gmid
                    }

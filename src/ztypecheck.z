                                                    # paramTypeBaseName/walkLookupTyperef miss a dotted ref, resolve cross-unit.
                                                    opf69: ast.nodes.get i: (farg.operation - 1).u64
                                                    subT = dottedTyperefId :ast :st op: opf69
                                                }
                                            } else {
                                                avt2: (checkValue
                                                    :st
                                                    :unitName
                                                    :ast :unitBody
                                                    node: (ast.nodes.get i: (farg.operation - 1).u64)
                                                )
                                                mvt2: materialiseLiteral :ast :st :unitName t: avt2
                                                subT = mvt2
                                            }
                                        }
                                    } else null
                                }
                                if subT > 0 then {
                                    tn2: typeNameOf :st tid: dtp
                                    an2: typeNameOf :st tid: subT
                                    mname2: "\{tn2}_\{an2}"
                                    subs2: (Map String value: u64)
                                    if (isNullPay) == false then {
                                        pk2: pn0.copy
                                        pv2: subT
                                        subs2.set key: pk2 value: pv2
                                    }
                                    vsH9: (Map String value: u64)
                                    mintedT: (getOrMintSpec
                                        :ast
                                        ty: st.typing
                                        reg: st.reg
                                        mainName: unitName
                                        name: mname2.stringview
                                        templateId: dtp
                                        subs: subs2
                                        valSubs: vsH9
                                        fallbackArg: subT
                                    )
                                    if mintedT > 0 then {
                                        setgu: mintedT
                                        st.typing.nodeType.set key: call.nodeid.u64 value: setgu
                                        (st.typing.callKind.set
                                            key: call.nodeid.u64
                                            value: zast.callkind.unionCreate

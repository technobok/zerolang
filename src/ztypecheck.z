    # none); the literal pseudo keys the instance as literal_int/float.
    if result > 0.u64 when (blockHasBreak n: donode.statement) then {
        vtn0: typeNameOf st: st tid: result
        payId0: result
        if result == literalIntId then {
            vtn0 = "literal_int".string
            payId0 = st.reg.newType name: "literal_int" typetype: ztypes.ztypetype.RECORD
        } else {
        }
        if result == literalFloatId then {
            vtn0 = "literal_float".string
            payId0 = st.reg.newType name: "literal_float" typetype: ztypes.ztypetype.RECORD
        } else {
        }
        if vtn0.length > 0.u64 then {
            ovo0: lookupTyperef resolved: st.typing.resolved mainName: unitName base: "optionval"
            match (
                ovo0

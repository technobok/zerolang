#-- core

# system types

# predeclared vars

print: io.print

# signed integer types

i8: system.i8
i16: system.i16
i32: system.i32
i64: system.i64
i128: system.i128

# unsigned integer types

u8: system.u8
u16: system.u16
u32: system.u32
u64: system.u64
u128: system.u128

# floating point types

f32: system.f32
f64: system.f64


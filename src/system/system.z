# system.zero - System definitions here are provided by the compiler

# tag - predefined generic type for union/variant discriminators
# Implementation injected by the compiler. Proper generic form deferred to generics phase.
tag: record {}

u8: record {
    +: function {:this rhs: type} out type
    -: function {:this rhs: type} out type
    *: function {:this rhs: type} out type
    /: function {:this rhs: type} out type
    <=: function {:this rhs: type} out bool
    <: function {:this rhs: type} out bool
    >: function {:this rhs: type} out bool
    >=: function {:this rhs: type} out bool
    ==: function {:this rhs: type} out bool
    !=: function {:this rhs: type} out bool
    tag: tag
}


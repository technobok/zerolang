# zls -- the zerolang language server (LSP 3.17 subset). Speaks
# JSON-RPC 2.0 with Content-Length framing over stdio (`--stdio`, the
# default) or a framed input file (`--replay`, the test harness's
# transport; os.spawn cannot pipe a child's stdin while capturing its
# output). Documents sync with full text; every didOpen/didChange runs
# zcheck.check with the open buffers overlaid on disk and publishes
# diagnostics. Positions negotiate utf-32 (matching the compiler's
# codepoint columns) and fall back to utf-16 conversion.

Value: json.Value
Obj: json.Obj
Arr: json.Arr
Ast: zast.Ast

# Well-known Ast.names pool id (fixed by Ast.create's intern order in
# zast.z -- the authority), widened to match ZTypeChild.nameId.
wkThis: 1.u64

# Transport -- the byte source/sink the server is framed over. stdio reads
# fd 0 and writes fd 1; replay reads a file and writes fd 1 (the harness
# captures stdout); tcp reads and writes one accepted connection. The Server
# owns this union, so the accepted Conn / open File has exactly one owner and
# both the reader and writer reach it through short-lived borrows.
Transport: union {
    stdio: null
    replay: io.File
    tcp: net.Conn
}

# ---- small builders -------------------------------------------------

newObj: function out Obj is {
    return (Obj entries: (Map String value: Value) keys: (List String))
}

newArr: function out Arr is {
    return (Arr items: (List Value))
}

# ---- uri <-> path ---------------------------------------------------

hexNibble: function {b: u8} out i64 is {
    if b >= 48 when b <= 57 then return (b - 48).i64
    if b >= 97 when b <= 102 then return (b - 87).i64
    if b >= 65 when b <= 70 then return (b - 55).i64
    return -1
}

# uriToPath -- "file:///a/b%20c.z" -> "/a/b c.z". Non-file URIs return "".
uriToPath: function {uri: StringView} out String is {
    if (uri.startsWith "file://") == false then return "".string
    r: String
    i: 7.u64
    n: uri.length
    for i < n loop {
        bo: uri.byteAt :i
        match (
            bo
        ) case some then {
            if bo == 37 when (i + 2) < n then {
                h1: i64
                h2: i64
                b1: uri.byteAt i: i + 1
                match (
                    b1
                ) case some then {
                    h1 = hexNibble b: b1
                } case none then null
                b2: uri.byteAt i: i + 2
                match (
                    b2
                ) case some then {
                    h2 = hexNibble b: b2
                } case none then null
                if h1 >= 0 when h2 >= 0 then {
                    r.appendByte b: ((h1 * 16) + h2).u8.orPanic
                    i = i + 2
                } else {
                    r.appendByte b: bo
                }
            } else {
                r.appendByte b: bo
            }
        } case none then null
        i = i + 1
    }
    return r
}

# pathToUri -- absolute path -> file:// URI (no percent-encoding; the
# workspace paths this serves are plain).
pathToUri: function {path: StringView} out String is {
    r: "file://".string
    r.append path
    return r
}

# relPathOf -- path relative to a provider root ("" when outside it).
relPathOf: function {path: StringView srcDir: StringView} out String is {
    if srcDir.length == 0 then return "".string
    pre: srcDir.string
    pre.append "/"
    pv: pre.stringview
    if path.startsWith pv then return (path.substring from: pre.length to: path.length).string
    return "".string
}

# absRelPath -- absolute path for a provider-relative file: the srcDir
# join when it exists on disk, else the systemDir join when that does,
# else the srcDir join (unsaved new files).
absRelPath: function {rel0: StringView srcDir: StringView systemDir: StringView} out String is {
    sj9: zcheck.joinPath a: srcDir b: rel0
    if (io.exists path: sj9.stringview) then return sj9
    yj9: zcheck.joinPath a: systemDir b: rel0
    if (io.exists path: yj9.stringview) then return yj9
    return sj9
}

# ---- position encoding ----------------------------------------------

# encodedCol -- 1-based codepoint column -> 0-based column in the
# negotiated encoding, measured over `lineText`. utf-32 columns equal
# codepoint counts; utf-16 pays one extra unit per astral codepoint.
encodedCol: function {lineText: StringView cpCol1: u32 utf32: bool} out u32 is {
    if cpCol1 == 0 then return 0
    target: (cpCol1 - 1).u64
    if utf32 then return (cpCol1 - 1).u32
    units: u32
    idx: u64
    with cit: lineText.codepoints do for cp: cit loop {
        if idx >= target then break
        if cp >= 65536 then {
            units = units + 2
        } else {
            units = units + 1
        }
        idx = idx + 1
    }
    # columns past the end of the line degrade to the line's width in
    # units plus the shortfall (whitespace-only overhang)
    if idx < target then units = units + (target - idx).u32.orPanic
    return units
}

# ---- transport i/o -------------------------------------------------

# transportRead -- fill `into9` with up to 64 KiB from the active transport;
# each arm dispatches the concrete Reader (stdio's fd 0, the replay File, or
# the tcp Conn). Matching the bare `tp` param narrows the arm.
transportRead: function {tp: Transport into9: Bytes} out (Result u64 e: IoError) is {
    match (
        tp
    ) case tcp then {
        return (tp.read into: into9 max: 65536)
    } case replay then {
        return (tp.read into: into9 max: 65536)
    } case stdio then {
        r: io.stdin
        return (r.read into: into9 max: 65536)
    }
}

# transportWrite -- write `bv` to the active transport: the tcp Conn, else
# fd 1 (stdio and replay both answer on stdout).
transportWrite: function {tp: Transport bv: ByteView} out (Result u64 e: IoError) is {
    match (
        tp
    ) case tcp then {
        return (tp.write from: bv)
    } else {
        w: io.stdout
        return (w.write from: bv)
    }
}

# transportFd -- the pollable input fd: the tcp socket, else stdin (fd 0).
# replay never polls (a file is always readable), so its fd is unused.
transportFd: function {tp: Transport} out i32 is {
    match (
        tp
    ) case tcp then {
        return tp.fd
    } else {
        return 0
    }
}

# ---- json-rpc send -------------------------------------------------
# The send helpers take the transport by argument (not off `this`): a
# caller passes `tp: this.transport`, a leaf disjoint from `this.docs` /
# `this.snapshots`, so sending stays legal while those fields are locked
# (e.g. publishAll sends inside a docs iteration).

writeAll: function {s: StringView tp: Transport} is {
    b: Bytes
    i: u64
    n: s.length
    for i < n loop {
        bo: s.byteAt :i
        match (
            bo
        ) case some then {
            b.append from: bo
        } case none then null
        i = i + 1
    }
    bv: ByteView.borrow from: b.listview
    wr: transportWrite :tp :bv
    match (
        wr
    ) case ok then null case err then {
        io.eprintln "zls: transport write failed"
    }
}

frameAndSend: function {body: String tp: Transport} is {
    blen: body.length
    m: "Content-Length: \{blen}"
    m.appendByte b: 13
    m.appendByte b: 10
    m.appendByte b: 13
    m.appendByte b: 10
    m.append body.stringview
    writeAll s: m.stringview :tp
}

sendResult: function {id: Value.take result: Value.take tp: Transport} is {
    o: newObj
    o.set key: "jsonrpc".string value: (Value.text "2.0".string)
    o.set key: "id".string value: id
    o.set key: "result".string value: result
    root: (Value.object o)
    body: json.serialize v: root
    frameAndSend :body :tp
}

sendError: function {id: Value.take code: i64 message: StringView tp: Transport} is {
    e: newObj
    e.set key: "code".string value: (Value.intval code)
    e.set key: "message".string value: (Value.text message.string)
    o: newObj
    o.set key: "jsonrpc".string value: (Value.text "2.0".string)
    o.set key: "id".string value: id
    o.set key: "error".string value: (Value.object e)
    root: (Value.object o)
    body: json.serialize v: root
    frameAndSend :body :tp
}

sendNotification: function {method: StringView params: Value.take tp: Transport} is {
    o: newObj
    o.set key: "jsonrpc".string value: (Value.text "2.0".string)
    o.set key: "method".string value: (Value.text method.string)
    o.set key: "params".string value: params
    root: (Value.object o)
    body: json.serialize v: root
    frameAndSend :body :tp
}

# idValueOf -- the request id as a fresh Value (int, string, or null).
idValueOf: function {msg: Value} out Value is {
    f: json.at v: msg path: "id"
    k: f.kind
    match (
        k
    ) case intval then {
        return (Value.intval f.i)
    } case text then {
        return (Value.text f.s.copy)
    } else {
        return Value.nul
    }
}

# ---- header parsing -------------------------------------------------

parseContentLength: function {line: StringView} out u64 is {
    lower: line.toLowerAscii
    lv: lower.stringview
    if lv.startsWith "content-length:" then {
        rest: lv.substring from: 15 to: lv.length
        t: rest.trim
        pr: t.parseU64
        match (
            pr
        ) case ok then {
            return pr
        } case err then {
            return 0
        }
    }
    return 0
}

# ---- document + server ----------------------------------------------

Document: class {
    uri: String
    path: String
    relpath: String
    text: String
    version: i64
}

Server: class {
    docs: (Map String value: Document)
    srcDir: String
    systemDir: String
    srcFlag: String
    sysFlag: String
    encUtf32: bool
    initialized: bool
    shutdownReq: bool
    running: bool
    exitCode: i32
    inbuf: Bytes
    inpos: u64
    transport: Transport
    # true for stdio/tcp (coalesce an edit burst before rechecking); false
    # for replay so every sync message publishes inline (goldens stay stable)
    debounce: bool
    # open-doc uris awaiting a coalesced recheck (interactive mode only)
    dirty: (Map String value: bool)
    # last-good check per document uri: navigation answers from these
    # even while the live buffer is broken
    snapshots: (Map String value: zcheck.CheckResult)
} as {
    # ---- framed reader over the BufReader ----

    needByte: function {:this} out (optionval u8) is {
        for this.inpos >= this.inbuf.length loop {
            fresh: Bytes
            this.inbuf = fresh
            this.inpos = 0
            rr: transportRead tp: this.transport into9: this.inbuf
            match (
                rr
            ) case ok then {
                if rr == 0 then return (optionval.none u8)
            } case err then {
                return (optionval.none u8)
            }
        }
        b: this.inbuf.get i: this.inpos
        this.inpos = this.inpos + 1
        return (optionval.some b)
    }

    readHeaderLine: function {:this} out (Option String) is {
        line: String
        for true loop {
            bo: this.needByte
            match (
                bo
            ) case some then {
                if bo == 10 then {
                    n9: line.length
                    if n9 > 0 then {
                        lv9: line.stringview
                        lb9: lv9.byteAt i: n9 - 1
                        match (
                            lb9
                        ) case some then {
                            if lb9 == 13 then {
                                s2: (lv9.substring from: 0 to: n9 - 1).string
                                return (Option.some s2)
                            }
                        } case none then null
                    }
                    return (Option.some line)
                }
                line.appendByte b: bo
            } case none then {
                return (Option.none String)
            }
        }
    }

    readBody: function {:this n: u64} out (Option String) is {
        body: String
        body.reserve :n
        i: u64
        for i < n loop {
            bo: this.needByte
            match (
                bo
            ) case some then {
                body.appendByte b: bo
            } case none then {
                return (Option.none String)
            }
            i = i + 1
        }
        return (Option.some body)
    }

    # readMessage -- one framed JSON-RPC payload; none at end of input.
    readMessage: function {:this} out (Option String) is {
        clen: u64
        for true loop {
            lo: this.readHeaderLine
            match (
                lo
            ) case some then {
                if lo.length == 0 then break
                lv: lo.stringview
                c9: parseContentLength line: lv
                if c9 > 0 then clen = c9
            } case none then {
                return (Option.none String)
            }
        }
        if clen == 0 then {
            io.eprintln "zls: message without Content-Length"
            return (Option.none String)
        }
        return (this.readBody n: clen)
    }

    # ---- dispatch ----

    handleMessage: function {:this msg: Value} is {
        mo: json.textAt v: msg path: "method"
        hasId: json.hasAt v: msg path: "id"
        match (
            mo
        ) case some then {
            mv: mo.stringview
            if mv == "initialize" then {
                this.handleInitialize :msg
            } else if mv == "initialized" then {
            } else if mv == "shutdown" then {
                this.shutdownReq = true
                idv: idValueOf :msg
                sendResult id: idv result: Value.nul tp: this.transport
            } else if mv == "exit" then {
                this.running = false
                if this.shutdownReq == false then this.exitCode = 1
            } else if mv == "textDocument/didOpen" then {
                this.handleDidOpen :msg
            } else if mv == "textDocument/didChange" then {
                this.handleDidChange :msg
            } else if mv == "textDocument/didClose" then {
                this.handleDidClose :msg
            } else if mv == "textDocument/definition" then {
                this.handleNav :msg mode: 1
            } else if mv == "textDocument/hover" then {
                this.handleNav :msg mode: 2
            } else if mv == "textDocument/references" then {
                this.handleNav :msg mode: 3
            } else if mv == "textDocument/completion" then {
                this.handleNav :msg mode: 4
            } else if mv == "textDocument/signatureHelp" then {
                this.handleNav :msg mode: 5
            } else if mv == "textDocument/formatting" then {
                this.handleFormatting :msg
            } else if mv == "textDocument/documentSymbol" then {
                this.handleDocSymbol :msg
            } else {
                if hasId then {
                    idv2: idValueOf :msg
                    sendError id: idv2 code: -32601 message: "method not found" tp: this.transport
                }
            }
        } case none then {
            io.eprintln "zls: message without method"
        }
    }

    handleInitialize: function {:this msg: Value} is {
        # position encoding: utf-32 when the client offers it
        i: u64
        for true loop {
            pth: "params/capabilities/general/positionEncodings/\{i}"
            f: json.at v: msg path: pth.stringview
            k: f.kind
            done9: false
            match (
                k
            ) case text then {
                if f.s.stringview == "utf-32" then this.encUtf32 = true
            } else {
                done9 = true
            }
            if done9 then break
            i = i + 1
        }
        # workspace discovery: CLI flags > initializationOptions > rootUri
        # auto-detect (zerolang repo layout) > cwd
        rootPath: String
        ro: json.textAt v: msg path: "params/rootUri"
        match (
            ro
        ) case some then {
            rootPath = uriToPath uri: ro.stringview
        } case none then null
        sd: String
        syd: String
        if this.srcFlag.length > 0 then sd = this.srcFlag.copy
        if this.sysFlag.length > 0 then syd = this.sysFlag.copy
        io1: json.textAt v: msg path: "params/initializationOptions/srcDir"
        match (
            io1
        ) case some then {
            if sd.length == 0 then sd = io1.copy
        } case none then null
        io2: json.textAt v: msg path: "params/initializationOptions/systemDir"
        match (
            io2
        ) case some then {
            if syd.length == 0 then syd = io2.copy
        } case none then null
        if sd.length == 0 then {
            if rootPath.length > 0 then {
                candSys: zcheck.joinPath a: rootPath.stringview b: "lib/system"
                candSrc: zcheck.joinPath a: rootPath.stringview b: "src"
                hasSys: io.exists path: candSys.stringview
                hasSrc: io.exists path: candSrc.stringview
                if hasSys when hasSrc then {
                    sd = candSrc.copy
                    if syd.length == 0 then syd = candSys.copy
                } else {
                    sd = rootPath.copy
                }
            } else {
                sd = ".".string
            }
        }
        if syd.length == 0 then syd = zcheck.resolveSystemDir flagVal: ""
        this.srcDir = sd
        this.systemDir = syd
        # response
        caps: newObj
        caps.set key: "textDocumentSync".string value: (Value.intval 1)
        caps.set key: "definitionProvider".string value: (Value.boolean true)
        caps.set key: "hoverProvider".string value: (Value.boolean true)
        comp9: newObj
        ctc9: newArr
        ctc9.items.append (Value.text ".".string)
        ctc9.items.append (Value.text " ".string)
        comp9.set key: "triggerCharacters".string value: (Value.array ctc9)
        caps.set key: "completionProvider".string value: (Value.object comp9)
        sig9: newObj
        stc9: newArr
        stc9.items.append (Value.text ":".string)
        stc9.items.append (Value.text " ".string)
        sig9.set key: "triggerCharacters".string value: (Value.array stc9)
        rtc9: newArr
        rtc9.items.append (Value.text ":".string)
        rtc9.items.append (Value.text " ".string)
        sig9.set key: "retriggerCharacters".string value: (Value.array rtc9)
        caps.set key: "signatureHelpProvider".string value: (Value.object sig9)
        caps.set key: "documentFormattingProvider".string value: (Value.boolean true)
        caps.set key: "referencesProvider".string value: (Value.boolean true)
        caps.set key: "documentSymbolProvider".string value: (Value.boolean true)
        encName: "utf-16"
        if this.encUtf32 then encName = "utf-32"
        caps.set key: "positionEncoding".string value: (Value.text encName.string)
        info: newObj
        info.set key: "name".string value: (Value.text "zls".string)
        info.set key: "version".string value: (Value.text "0.1.0".string)
        res: newObj
        res.set key: "capabilities".string value: (Value.object caps)
        res.set key: "serverInfo".string value: (Value.object info)
        idv: idValueOf :msg
        resv: (Value.object res)
        sendResult id: idv result: resv tp: this.transport
        this.initialized = true
    }

    # ---- document sync (full text) ----

    handleDidOpen: function {:this msg: Value} is {
        uo: json.textAt v: msg path: "params/textDocument/uri"
        to: json.textAt v: msg path: "params/textDocument/text"
        vo: json.intAt v: msg path: "params/textDocument/version"
        ver: i64
        match (
            vo
        ) case some then {
            ver = vo
        } case none then null
        match (
            uo
        ) case some then {
            match (
                to
            ) case some then {
                pth: uriToPath uri: uo.stringview
                rel: relPathOf path: pth.stringview srcDir: this.srcDir.stringview
                if rel.length == 0 then {
                    rel = relPathOf path: pth.stringview srcDir: this.systemDir.stringview
                }
                d: (Document uri: uo.copy path: pth relpath: rel text: to.copy version: ver)
                key9: uo.copy
                this.docs.set key: key9 value: d
                this.syncDoc uri: uo.stringview
            } case none then null
        } case none then null
    }

    handleDidChange: function {:this msg: Value} is {
        uo: json.textAt v: msg path: "params/textDocument/uri"
        to: json.textAt v: msg path: "params/contentChanges/0/text"
        vo: json.intAt v: msg path: "params/textDocument/version"
        match (
            uo
        ) case some then {
            match (
                to
            ) case some then {
                ku: uo.copy
                rem: this.docs.remove key: ku
                changed9: false
                match (
                    rem
                ) case some then {
                    d: rem.take
                    d.text = to.copy
                    match (
                        vo
                    ) case some then {
                        d.version = vo
                    } case none then null
                    key9: uo.copy
                    this.docs.set key: key9 value: d
                    changed9 = true
                } case none then null
                if changed9 then this.syncDoc uri: uo.stringview
            } case none then null
        } case none then null
    }

    handleDidClose: function {:this msg: Value} is {
        uo: json.textAt v: msg path: "params/textDocument/uri"
        match (
            uo
        ) case some then {
            ku: uo.copy
            rem: this.docs.remove key: ku
            match (
                rem
            ) case some then null case none then null
            # clear this uri's diagnostics
            empty9: newArr
            p9: newObj
            p9.set key: "uri".string value: (Value.text uo.copy)
            p9.set key: "diagnostics".string value: (Value.array empty9)
            pv9: (Value.object p9)
            (sendNotification
                method: "textDocument/publishDiagnostics"
                params: pv9
                tp: this.transport
            )
        } case none then null
    }

    # ---- diagnostics ----

    # recomputeFor -- run a full check with all open buffers overlaid,
    # rooted at `uri`'s unit, and publish per-file diagnostics.
    # ---- debounce ----

    syncDoc: function {:this uri: StringView} is {
        if this.debounce then this.markDirty :uri else this.recomputeFor :uri
    }

    markDirty: function {:this uri: StringView} is {
        this.dirty.set key: uri.string value: true
    }

    hasDirty: function {:this} out bool is {
        return (this.dirty.length > 0)
    }

    # flushDirty -- recheck every dirty document, then clear. The dirty uris
    # are copied out first: recomputeFor locks `this`, which would conflict
    # with a live iterator over this.dirty.
    flushDirty: function {:this} is {
        uris9: (List String)
        with it: this.dirty.iterateItems do for e: it loop uris9.append e.key.copy
        fresh: (Map String value: bool)
        this.dirty = fresh
        ui9: u64
        for ui9 < uris9.length loop {
            u9: uris9.get i: ui9
            this.recomputeFor uri: u9.stringview
            ui9 = ui9 + 1
        }
    }

    # inputQuiet -- true when no message is buffered and the input fd stays
    # unreadable for `millis`. A buffered burst reports not-quiet at once.
    inputQuiet: function {:this millis: i32} out bool is {
        if this.inpos < this.inbuf.length then return false
        pr9: net.pollReadable fd: (transportFd tp: this.transport) timeoutMillis: millis
        match (
            pr9
        ) case ok then {
            if pr9 then return false
            return true
        } case err then {
            return true
        }
    }

    recomputeFor: function {:this uri: StringView} is {
        if this.initialized == false then return
        ov: (Map String value: String)
        with dit: this.docs.iterateItems do for e: dit loop {
            if e.value.relpath.length > 0 then {
                k9: e.value.relpath.copy
                v9: e.value.text.copy
                ov.set key: k9 value: v9
            }
        }
        mu: String
        mp: String
        found9: false
        {
            ku: uri.string
            dgo: this.docs.get key: ku
            match (
                dgo
            ) case some then {
                mu = zsource.unitNameOf path: dgo.path.stringview
                mp = dgo.path.copy
                found9 = true
            } case none then null
        }
        if found9 == false then return
        r: (zcheck.check
            srcdir: this.srcDir.stringview
            systemdir: this.systemDir.stringview
            mainUnit: mu.stringview
            overlays: ov
        )
        rows: (List zcheck.diagrow)
        msgs: (List String)
        zcheck.diagsOf :r :rows :msgs
        this.publishAll :r :rows :msgs mainUnit: mu.stringview mainPath: mp.stringview
        if r.parseOk then {
            ku9: uri.string
            this.snapshots.set key: ku9 value: r
        }
    }

    # publishAll -- one publishDiagnostics per open document: its
    # matching rows (by provider path), or an empty list to clear.
    publishAll: function {
        :this
        r: zcheck.CheckResult
        rows: (List zcheck.diagrow)
        msgs: (List String)
        mainUnit: StringView
        mainPath: StringView
    } is {
        # resolve each row's provider path once (parallel to rows)
        paths: (List String)
        with rit: rows.iterate do for row: rit loop {
            pp: String
            if row.fsno > 0 then pp = r.vfs.pathfromprovider dentryid: row.fsno
            paths.append pp
        }
        with dit: this.docs.iterateItems do for e: dit loop {
            drel: e.value.relpath.copy
            dfs: zcheck.joinPath a: this.srcDir.stringview b: drel.stringview
            dov: "/".string
            dov.append drel.stringview
            durl: e.value.uri.copy
            arr: newArr
            nrows: rows.length
            ri: u64
            for ri < nrows loop {
                pv: paths.get i: ri
                hit: false
                if drel.length > 0 then {
                    if pv.stringview == drel.stringview then hit = true
                    if pv.stringview == dfs.stringview then hit = true
                    if pv.stringview == dov.stringview then hit = true
                }
                if hit then {
                    row: rows.get i: ri
                    m: msgs.get i: ri
                    lineText: String
                    lt9: r.vfs.getline dentryid: row.fsno lineno: (row.lineno - 1).u64
                    match (
                        lt9
                    ) case some then {
                        lineText = lt9.copy
                    } case none then null
                    dv: (diagValue
                        :row
                        msg: m.stringview
                        lineText: lineText.stringview
                        utf32: this.encUtf32
                    )
                    arr.items.append dv
                }
                ri = ri + 1
            }
            if e.value.path.stringview == mainPath then {
                (tcLintInto
                    :arr
                    text: e.value.text.copy
                    relpath: drel.stringview
                    utf32: this.encUtf32
                    prog: r.prog
                    uname: mainUnit
                    sto: r.st
                )
            } else {
                lintInto :arr text: e.value.text.copy relpath: drel.stringview utf32: this.encUtf32
            }
            p9: newObj
            p9.set key: "uri".string value: (Value.text durl)
            p9.set key: "diagnostics".string value: (Value.array arr)
            pv9: (Value.object p9)
            (sendNotification
                method: "textDocument/publishDiagnostics"
                params: pv9
                tp: this.transport
            )
        }
    }

    # ---- formatting ----

    handleFormatting: function {:this msg: Value} is {
        idv: idValueOf :msg
        uo: json.textAt v: msg path: "params/textDocument/uri"
        answered9: false
        match (
            uo
        ) case some then {
            dtext: String
            drel: String
            found9: false
            {
                ku: uo.copy
                dgo: this.docs.get key: ku
                match (
                    dgo
                ) case some then {
                    dtext = dgo.text.copy
                    drel = dgo.relpath.copy
                    found9 = true
                } case none then null
            }
            if found9 then {
                res: formatAnswer text: dtext.stringview relpath: drel.stringview
                sendResult id: idv result: res tp: this.transport
                answered9 = true
            }
        } case none then null
        if answered9 == false then sendResult id: idv result: Value.nul tp: this.transport
    }

    # ---- navigation requests ----

    # handleNav -- definition (mode 1), hover (mode 2), references
    # (mode 3): shared request decode + snapshot lookup.
    handleNav: function {:this msg: Value mode: u8} is {
        if this.debounce when this.hasDirty then this.flushDirty
        idv: idValueOf :msg
        uo: json.textAt v: msg path: "params/textDocument/uri"
        lo: json.intAt v: msg path: "params/position/line"
        co: json.intAt v: msg path: "params/position/character"
        line0: -1
        match (
            lo
        ) case some then {
            line0 = lo
        } case none then null
        ch0: -1
        match (
            co
        ) case some then {
            ch0 = co
        } case none then null
        answered9: false
        match (
            uo
        ) case some then {
            if line0 >= 0 when ch0 >= 0 then {
                dtext: String
                drel: String
                found9: false
                {
                    ku: uo.copy
                    dgo: this.docs.get key: ku
                    match (
                        dgo
                    ) case some then {
                        dtext = dgo.text.copy
                        drel = dgo.relpath.copy
                        found9 = true
                    } case none then null
                }
                if found9 then {
                    ks: uo.copy
                    sno: this.snapshots.get key: ks
                    match (
                        sno
                    ) case some then {
                        res: Value.nul
                        trigCh9: String
                        {
                            tco9: json.textAt v: msg path: "params/context/triggerCharacter"
                            match (
                                tco9
                            ) case some then {
                                trigCh9 = tco9.copy
                            } case none then null
                        }
                        if mode == 4 then {
                            res = (completionAnswer
                                snap: sno
                                docRel: drel.stringview
                                srcDir: this.srcDir.stringview
                                docText: dtext.stringview
                                :line0
                                ch: ch0
                                utf32: this.encUtf32
                                trig: trigCh9.stringview
                            )
                        } else if mode == 5 then {
                            res = (signatureHelpAnswer
                                snap: sno
                                docRel: drel.stringview
                                srcDir: this.srcDir.stringview
                                docText: dtext.stringview
                                :line0
                                ch: ch0
                                utf32: this.encUtf32
                            )
                        } else {
                            res = (navAnswer
                                snap: sno
                                docRel: drel.stringview
                                docUri: uo.stringview
                                srcDir: this.srcDir.stringview
                                systemDir: this.systemDir.stringview
                                docText: dtext.stringview
                                :line0
                                ch: ch0
                                utf32: this.encUtf32
                                :mode
                            )
                        }
                        sendResult id: idv result: res tp: this.transport
                        answered9 = true
                    } case none then null
                }
            }
        } case none then null
        if answered9 == false then sendResult id: idv result: Value.nul tp: this.transport
    }

    handleDocSymbol: function {:this msg: Value} is {
        if this.debounce when this.hasDirty then this.flushDirty
        idv: idValueOf :msg
        uo: json.textAt v: msg path: "params/textDocument/uri"
        answered9: false
        match (
            uo
        ) case some then {
            mu: String
            dtext: String
            found9: false
            {
                ku: uo.copy
                dgo: this.docs.get key: ku
                match (
                    dgo
                ) case some then {
                    mu = zsource.unitNameOf path: dgo.path.stringview
                    dtext = dgo.text.copy
                    found9 = true
                } case none then null
            }
            if found9 then {
                ks: uo.copy
                sno: this.snapshots.get key: ks
                match (
                    sno
                ) case some then {
                    res: (symbolsAnswer
                        snap: sno
                        unitName: mu.stringview
                        docText: dtext.stringview
                        utf32: this.encUtf32
                    )
                    sendResult id: idv result: res tp: this.transport
                    answered9 = true
                } case none then null
            }
        } case none then null
        if answered9 == false then sendResult id: idv result: Value.nul tp: this.transport
    }
}

# diagValue -- one LSP Diagnostic object from a flattened row.
diagValue: function {
    row: zcheck.diagrow
    msg: StringView
    lineText: StringView
    utf32: bool
} out Value is {
    line0: u32
    if row.lineno > 0 then line0 = row.lineno - 1
    c0: encodedCol :lineText cpCol1: row.colno :utf32
    w9: row.width
    if w9 == 0 then w9 = 1
    c1: encodedCol :lineText cpCol1: row.colno + w9 :utf32
    if c1 <= c0 then c1 = c0 + 1
    st9: newObj
    st9.set key: "line".string value: (Value.intval line0.i64)
    st9.set key: "character".string value: (Value.intval c0.i64)
    en9: newObj
    en9.set key: "line".string value: (Value.intval line0.i64)
    en9.set key: "character".string value: (Value.intval c1.i64)
    rg9: newObj
    rg9.set key: "start".string value: (Value.object st9)
    rg9.set key: "end".string value: (Value.object en9)
    code9: codeOf n: row.code
    d9: newObj
    d9.set key: "range".string value: (Value.object rg9)
    d9.set key: "severity".string value: (Value.intval 1)
    d9.set key: "code".string value: (Value.text code9)
    d9.set key: "source".string value: (Value.text "zc".string)
    d9.set key: "message".string value: (Value.text msg.string)
    return (Value.object d9)
}

# codeOf -- "E" + zero-padded-4 error code.
codeOf: function {n: u32} out String is {
    r: "E".string
    if n < 1000 then r.append "0"
    if n < 100 then r.append "0"
    if n < 10 then r.append "0"
    cs: "\{n}"
    r.append cs.stringview
    return r
}

# ---- span collection (per-request AST index) ------------------------
# Positions are start-only in the AST; name-bearing leaves get a span
# [colLo, colHi) in 1-based codepoint columns. Row kinds: 1 = bare atom
# use, 2 = member access (nodeid is the DOTTED PATH's id, the
# memberOwnerTid key; the name is the child atom's), 3 = binding name.
# `pos` records every node's start for def-target positioning.

spanrow: record {
    nodeid: u32
    line: u32
    colLo: u32
    colHi: u32
    kind: u8
}

# rangerow -- an enclosing-node span, start..end as line*1048576+col; kind
# 4 = call, 5 = caseexpr. endPos is the last descendant's start (a subtree
# extent good enough to find the node enclosing a cursor).
rangerow: record {
    nodeid: u32
    startPos: u64
    endPos: u64
    kind: u8
}

Spans: class {
    rows: (List spanrow)
    names: (List String)
    pos: (Map u64 value: u64)
    ranges: (List rangerow)
    lastPos: u64
} as {
    note: function {:this id: u32 line: u32 col: u32} is {
        if id > 0 then {
            v9: (line.u64 * 1048576) + col.u64
            this.pos.set key: id.u64 value: v9
            if v9 > this.lastPos then this.lastPos = v9
        }
    }

    addRow: function {:this id: u32 line: u32 col: u32 name: StringView kind: u8} is {
        w9: name.count
        this.rows.append (spanrow nodeid: id :line colLo: col colHi: col + w9.u32.orPanic :kind)
        this.names.append name.string
    }

    memberRow: function {:this ast: Ast dpid: u32 c: zast.Node} is {
        match (
            c
        ) case atomid then {
            cAr9: zast.nameTextCopy :ast ref: c.name
            this.addRow id: dpid line: c.lineno col: c.colno name: cAr9.stringview kind: 2
        } else null
    }

    # innerRangeOfKind -- the innermost recorded range of `kind` whose
    # [startPos, endPos + slack] contains `curPos` (line*1048576+col), or 0.
    innerRangeOfKind: function {:this curPos: u64 kind: u8 slack: u64} out u32 is {
        best9: u32
        bestStart9: u64
        ri9: u64
        for ri9 < this.ranges.length loop {
            rr9: this.ranges.get i: ri9
            hit9: rr9.kind == kind
            if rr9.startPos > curPos then hit9 = false
            if curPos > (rr9.endPos + slack) then hit9 = false
            if hit9 then {
                take9: false
                if best9 == 0 then take9 = true
                if rr9.startPos > bestStart9 then take9 = true
                if take9 then {
                    best9 = rr9.nodeid
                    bestStart9 = rr9.startPos
                }
            }
            ri9 = ri9 + 1
        }
        return best9
    }

    # walkOptAt -- the id-taking entry (0 = absent).
    walkOptAt: function {:this ast: Ast oId: u32} is {
        if oId == 0 then return
        o9: ast.nodes.get i: (oId - 1).u64
        this.walk :ast n: o9
    }

    # walkProgram -- root entry: notes the program node, then walks each
    # unit wrapper (the table rides inside the program node).
    walkProgram: function {:this prog: zast.Node} is {
        match (
            prog
        ) case program then {
            this.note id: prog.nodeid line: prog.lineno col: prog.colno
            wpi9: u64
            wpn9: prog.ast.units.length
            for wpi9 < wpn9 loop {
                wpid9: prog.ast.units.get i: wpi9
                this.walkAt ast: prog.ast nId: wpid9
                wpi9 = wpi9 + 1
            }
        } else null
    }

    # walkAt -- the id-taking entry: the row view is this frame's, so a
    # caller can lend the table in the same call.
    walkAt: function {:this ast: Ast nId: u32} is {
        n9: ast.nodes.get i: (nId - 1).u64
        this.walk :ast n: n9
    }

    walk: function {:this ast: Ast n: zast.Node} is {
        match (
            n
        ) case error then {
            this.note id: n.nodeid line: n.lineno col: n.colno
        } case placeholder then null case atomid then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            nAr9: zast.nameTextCopy :ast ref: n.name
            this.addRow id: n.nodeid line: n.lineno col: n.colno name: nAr9.stringview kind: 1
        } case labelvalue then {
            this.note id: n.nodeid line: n.lineno col: n.colno
        } case stringchunk then {
            this.note id: n.nodeid line: n.lineno col: n.colno
        } case binop then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            this.walk :ast n: (ast.nodes.get i: (n.lhs - 1).u64)
            this.walk :ast n: (ast.nodes.get i: (n.operator - 1).u64)
            this.walk :ast n: (ast.nodes.get i: (n.rhs - 1).u64)
        } case atomstring then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            spit9: n.stringparts.iterate
            for sp9: spit9 loop this.walk :ast n: (ast.nodes.get i: (sp9 - 1).u64)
        } case dottedpath then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            this.walk :ast n: (ast.nodes.get i: (n.parent - 1).u64)
            this.memberRow :ast dpid: n.nodeid c: (ast.nodes.get i: (n.child - 1).u64)
        } case call then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            csp9: (n.lineno.u64 * 1048576) + n.colno.u64
            this.walk :ast n: (ast.nodes.get i: (n.callable - 1).u64)
            ait9: n.arguments.iterate
            for a9: ait9 loop {
                this.walk :ast n: (ast.nodes.get i: (a9 - 1).u64)
            }
            this.ranges.append (rangerow
                nodeid: n.nodeid
                startPos: csp9
                endPos: this.lastPos
                kind: 4
            )
        } case typeofexpr then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            this.walk :ast n: (ast.nodes.get i: (n.source - 1).u64)
        } case namedoperation then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            this.walk :ast n: (ast.nodes.get i: (n.operation - 1).u64)
        } case datablock then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            eit9: n.elements.iterate
            for e9: eit9 loop this.walk :ast n: (ast.nodes.get i: (e9 - 1).u64)
            this.walkOptAt :ast oId: n.outType
        } case yieldexpr then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            this.walk :ast n: (ast.nodes.get i: (n.expr - 1).u64)
        } case statement then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            sit9: n.statements.iterate
            for s9Id9: sit9 loop this.walk :ast n: (ast.nodes.get i: (s9Id9 - 1).u64)
        } case statementline then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            this.walk :ast n: (ast.nodes.get i: (n.statementline - 1).u64)
        } case assignment then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            this.addRow id: n.nodeid line: n.lineno col: n.colno name: n.name.stringview kind: 3
            this.walk :ast n: (ast.nodes.get i: (n.value - 1).u64)
        } case reassignment then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            this.walk :ast n: (ast.nodes.get i: (n.topath - 1).u64)
            this.walk :ast n: (ast.nodes.get i: (n.value - 1).u64)
        } case swapstmt then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            this.walk :ast n: (ast.nodes.get i: (n.lhs - 1).u64)
            this.walk :ast n: (ast.nodes.get i: (n.rhs - 1).u64)
        } case expression then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            this.walk :ast n: (ast.nodes.get i: (n.expression - 1).u64)
        } case ifexpr then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            cit9: n.clauses.iterate
            for c9Id9: cit9 loop this.walk :ast n: (ast.nodes.get i: (c9Id9 - 1).u64)
            this.walkOptAt :ast oId: n.elseclause
        } case ifclause then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            coit9: n.conditions.iterate
            for co9Id9: coit9 loop this.walk :ast n: (ast.nodes.get i: (co9Id9 - 1).u64)
            this.walk :ast n: (ast.nodes.get i: (n.statement - 1).u64)
        } case forexpr then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            fct9: n.conditions.iterate
            for fc9Id9: fct9 loop this.walk :ast n: (ast.nodes.get i: (fc9Id9 - 1).u64)
            this.walkOptAt :ast oId: n.body
            fpt9: n.postconditions.iterate
            for fp9Id9: fpt9 loop this.walk :ast n: (ast.nodes.get i: (fp9Id9 - 1).u64)
        } case doexpr then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            this.walk :ast n: (ast.nodes.get i: (n.statement - 1).u64)
        } case withexpr then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            this.walk :ast n: (ast.nodes.get i: (n.value - 1).u64)
            this.walk :ast n: (ast.nodes.get i: (n.body - 1).u64)
        } case caseexpr then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            xsp9: (n.lineno.u64 * 1048576) + n.colno.u64
            this.walk :ast n: (ast.nodes.get i: (n.subject - 1).u64)
            cct9: n.clauses.iterate
            for cc9Id9: cct9 loop this.walk :ast n: (ast.nodes.get i: (cc9Id9 - 1).u64)
            this.walkOptAt :ast oId: n.elseclause
            this.ranges.append (rangerow
                nodeid: n.nodeid
                startPos: xsp9
                endPos: this.lastPos
                kind: 5
            )
        } case caseclause then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            this.walk :ast n: (ast.nodes.get i: (n.matcharm - 1).u64)
            this.walk :ast n: (ast.nodes.get i: (n.statement - 1).u64)
        } case functiondef then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            this.walkOptAt :ast oId: n.returntype
            pit9: n.parameters.iterate
            for pm9Id9: pit9 loop {
                pm9: ast.nodes.get i: (pm9Id9 - 1).u64
                this.walk :ast n: pm9
            }
            this.walkOptAt :ast oId: n.body
            fat9: n.asItems.iterate
            for fa9Id9: fat9 loop {
                fa9: ast.nodes.get i: (fa9Id9 - 1).u64
                this.walk :ast n: fa9
            }
        } case objectdef then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            oit9: n.isItems.iterate
            for oi9Id9: oit9 loop {
                oi9: ast.nodes.get i: (oi9Id9 - 1).u64
                this.walk :ast n: oi9
            }
            oat9: n.asItems.iterate
            for oa9Id9: oat9 loop {
                oa9: ast.nodes.get i: (oa9Id9 - 1).u64
                this.walk :ast n: oa9
            }
        } case unitdef then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            ubt9: n.body.iterate
            for ub9Id9: ubt9 loop this.walk :ast n: (ast.nodes.get i: (ub9Id9 - 1).u64)
        } case program then {
            this.note id: n.nodeid line: n.lineno col: n.colno
            uit9: n.ast.units.iterate
            for u9Id9x: uit9 loop this.walk :ast n: (ast.nodes.get i: (u9Id9x - 1).u64)
        }
    }
}


# docLine -- 1-based line `lineno` of `text` (without the newline).
docLine: function {text: StringView lineno: u32} out String is {
    if lineno == 0 then return "".string
    cur: 1.u32
    start: u64
    i: u64
    n: text.length
    for i < n loop {
        b: text.byteAt :i
        match (
            b
        ) case some then {
            if b == 10 then {
                if cur == lineno then return (text.substring from: start to: i).string
                cur = cur + 1
                start = i + 1
            }
        } case none then null
        i = i + 1
    }
    if cur == lineno then return (text.substring from: start to: n).string
    return "".string
}

# ---- navigation resolution ------------------------------------------

# cpColOf -- LSP character (0-based, negotiated encoding) -> 1-based
# codepoint column, measured over the line's text.
cpColOf: function {lineText: StringView ch: i64 utf32: bool} out u32 is {
    if ch < 0 then return 1
    if utf32 then return ch.u32.orPanic + 1
    units: i64
    idx: u32
    with cit: lineText.codepoints do for cp: cit loop {
        if units >= ch then break
        if cp >= 65536 then {
            units = units + 2
        } else {
            units = units + 1
        }
        idx = idx + 1
    }
    return idx + 1
}

# pathMatches -- whether a provider path names the request's document
# (overlay "/rel", plain "rel", or "<srcDir>/rel" forms).
pathMatches: function {pv: StringView rel: StringView srcDir: StringView} out bool is {
    if rel.length == 0 then return false
    if pv == rel then return true
    fs9: zcheck.joinPath a: srcDir b: rel
    if pv == fs9.stringview then return true
    ov9: "/".string
    ov9.append rel
    if pv == ov9.stringview then return true
    return false
}

# ---- stamp lookups through the snapshot's Option symtab ----

useVarId: function {o: (Option zenv.ZSymbolTable) nid: u64} out u64 is {
    match (
        o
    ) case some then {
        g9: o.typing.atomVariableId.get key: nid
        match (
            g9
        ) case some then {
            return g9
        } case none then {
            return 0
        }
    } case none then {
        return 0
    }
}

useUnitDef: function {o: (Option zenv.ZSymbolTable) nid: u64} out u64 is {
    match (
        o
    ) case some then {
        g9: o.typing.atomUnitDefId.get key: nid
        match (
            g9
        ) case some then {
            return g9
        } case none then {
            return 0
        }
    } case none then {
        return 0
    }
}

memberOwnerOf: function {o: (Option zenv.ZSymbolTable) nid: u64} out u64 is {
    match (
        o
    ) case some then {
        g9: o.typing.memberOwnerTid.get key: nid
        match (
            g9
        ) case some then {
            return g9
        } case none then {
            return 0
        }
    } case none then {
        return 0
    }
}

defVarIdOf: function {o: (Option zenv.ZSymbolTable) nid: u64} out u64 is {
    match (
        o
    ) case some then {
        g9: o.typing.defVariableId.get key: nid
        match (
            g9
        ) case some then {
            return g9
        } case none then {
            return 0
        }
    } case none then {
        return 0
    }
}

nodeTypeAt: function {o: (Option zenv.ZSymbolTable) nid: u64} out u64 is {
    match (
        o
    ) case some then {
        g9: o.typing.nodeType.get key: nid
        match (
            g9
        ) case some then {
            return g9
        } case none then {
            return 0
        }
    } case none then {
        return 0
    }
}

# varDefNode -- the binding node that declared variable `vid`.
varDefNode: function {o: (Option zenv.ZSymbolTable) vid: u64} out u64 is {
    match (
        o
    ) case some then {
        with it: o.typing.defVariableId.iterateItems do for e: it loop {
            if e.value == vid then return e.key
        }
        return 0
    } case none then {
        return 0
    }
}

typeNameOfOpt: function {o: (Option zenv.ZSymbolTable) tid: u64} out String is {
    match (
        o
    ) case some then {
        return (ztypecheck.typeNameOf st: o :tid)
    } case none then {
        return "".string
    }
}

# displayTypeNameSt -- typeNameOf, but a source type renders "<unit>.<name>"
# UNLESS it is declared in a core-language unit (system/core/collections) or has
# no source unit -- those stay bare. So String/List/Map stay bare while io/os/cli/
# net and other stdlib units render dotted (io.File, cli.OptionDef). A generic mono
# keys the unit test on its ORIGIN's declaring unit while displaying the full
# instance name (e.g. "List u64" stays bare -- List is declared in collections).
displayTypeNameSt: function {st: zenv.ZSymbolTable tid: u64} out String is {
    disp9: ztypecheck.typeNameOf :st :tid
    if disp9.length == 0 then return disp9
    base9: tid
    {
        rt9: st.reg.typeById.get key: tid
        match (
            rt9
        ) case some then {
            go9: rt9.genericOriginId
            match (
                go9
            ) case some then {
                base9 = go9
            } case none then null
        } case none then null
    }
    bname9: String
    {
        rt2: st.reg.typeById.get key: base9
        match (
            rt2
        ) case some then {
            bname9 = rt2.name.copy
        } case none then null
    }
    if bname9.length == 0 then return disp9
    unit9: String
    {
        du9: st.typing.definedInUnit.get key: base9
        match (
            du9
        ) case some then {
            unit9 = du9.copy
        } case none then null
    }
    if unit9.length == 0 then return disp9
    uv9: unit9.stringview
    if uv9 == "system" then return disp9
    if uv9 == "core" then return disp9
    if uv9 == "collections" then return disp9
    return "\{uv9}.\{disp9.stringview}"
}

displayTypeNameOfOpt: function {o: (Option zenv.ZSymbolTable) tid: u64} out String is {
    match (
        o
    ) case some then {
        return (displayTypeNameSt st: o :tid)
    } case none then {
        return "".string
    }
}

# typeKindTextOpt -- a type definition's kind word ("class", "variant", ...)
# for hover, or "" when tid is 0 or names something other than a type def.
typeKindTextOpt: function {o: (Option zenv.ZSymbolTable) tid: u64} out String is {
    result9: String
    if tid == 0 then return result9
    match (
        o
    ) case some then {
        tt9: o.reg.typetypeOf typeId: tid
        match (
            tt9
        ) case classType then {
            result9 = "class".string
        } case recordType then {
            result9 = "record".string
        } case variantType then {
            result9 = "variant".string
        } case unionType then {
            result9 = "union".string
        } case facetType then {
            result9 = "facet".string
        } case protocolType then {
            result9 = "protocol".string
        } else null
    } case none then null
    return result9
}

# defaultDisplay -- a defaulted param's value rendered with its resolved type:
# a numeric default as `v.<type>` (int) or `(v).<type>` (float); a function
# default (`#function:name`) as the bare name; a variant-arm default
# (`#variant:arm`) as `<type>.<arm>`. "" when `dtext` is empty.
defaultDisplay: function {dtext: StringView typeName: StringView} out String is {
    if dtext.length == 0 then return "".string
    b0: dtext.byteAt 0
    isHash9: false
    match (
        b0
    ) case some then {
        if b0 == 35 then isHash9 = true
    } case none then null
    if isHash9 then {
        ci9: u64
        n9: dtext.length
        found9: false
        for ci9 < n9 loop {
            cb9: dtext.byteAt ci9
            match (
                cb9
            ) case some then {
                if cb9 == 58 then found9 = true
            } case none then null
            if found9 then break
            ci9 = ci9 + 1
        }
        isVariant9: false
        {
            kindPart9: dtext.substring from: 1 to: ci9
            if kindPart9 == "variant" then isVariant9 = true
        }
        payload9: dtext.substring from: ci9 + 1 to: n9
        if isVariant9 then {
            r9: typeName.string
            r9.appendByte b: 46
            r9.append payload9
            return r9
        }
        return payload9.string
    }
    isFloat9: false
    if typeName == "f64" then isFloat9 = true
    if typeName == "f32" then isFloat9 = true
    rr9: String
    if isFloat9 then {
        rr9.appendByte b: 40
        rr9.append dtext
        rr9.appendByte b: 41
        rr9.appendByte b: 46
        rr9.append typeName
    } else {
        rr9.append dtext
        rr9.appendByte b: 46
        rr9.append typeName
    }
    return rr9
}

# paramDocs -- map of parameter name -> its trailing `#` doc comment, read from
# the function's declaration source. Resolves the function tid to its
# functiondef node (via the namedoperation wrapper), then reads each parameter
# node's line; only a parameter that is the last on its source line takes that
# line's trailing comment. Empty when the function has no documented parameters.
paramDocs: function {
    o: (Option zenv.ZSymbolTable)
    prog: zast.Node
    vfs: zvfs.ZVfs
    tid: u64
} out (Map String value: String) is {
    result9: (Map String value: String)
    defNid9: defNodeInfo :o :prog :tid member: ""
    if defNid9 == 0 then return result9
    fnNid9: u32
    {
        match (
            prog
        ) case program then {
            wn9: prog.ast.nodes.get i: (defNid9 - 1).u64
            match (
                wn9
            ) case namedoperation then {
                fnNid9 = wn9.operation
            } else null
        } else null
    }
    if fnNid9 == 0 then return result9
    fsno9: u32
    {
        match (
            prog
        ) case program then {
            fsno9 = prog.ast.fsnoForNode nodeid: fnNid9
        } else null
    }
    if fsno9 == 0 then return result9
    paramIds9: (List u32)
    {
        match (
            prog
        ) case program then {
            fd9: prog.ast.nodes.get i: (fnNid9 - 1).u64
            match (
                fd9
            ) case functiondef then {
                with pit9: fd9.parameters.iterate do for pid9: pit9 loop paramIds9.append pid9
            } else null
        } else null
    }
    pnms9: (List String)
    plns9: (List u32)
    pk9: u64
    for pk9 < paramIds9.length loop {
        pid9: paramIds9.get i: pk9
        nameRef9: u32
        ln9: u32
        {
            match (
                prog
            ) case program then {
                pnode9: prog.ast.nodes.get i: (pid9 - 1).u64
                match (
                    pnode9
                ) case namedoperation then {
                    nameRef9 = pnode9.name
                    ln9 = pnode9.lineno
                } else null
            } else null
        }
        if nameRef9 > 0 then {
            match (
                prog
            ) case program then {
                nm9: zast.nameTextCopy ast: prog.ast ref: nameRef9
                pnms9.append nm9
                plns9.append ln9
            } else null
        }
        pk9 = pk9 + 1
    }
    ci9: u64
    cn9: pnms9.length
    for ci9 < cn9 loop {
        lastOnLine9: true
        nxt9: ci9 + 1
        if nxt9 < cn9 then {
            thisLn9: plns9.get i: ci9
            nextLn9: plns9.get i: nxt9
            if nextLn9 == thisLn9 then lastOnLine9 = false
        }
        if lastOnLine9 then {
            curLn9: plns9.get i: ci9
            tcm9: trailingDocOf :vfs fsno: fsno9 line1: curLn9
            if tcm9.length > 0 then {
                kk9: (pnms9.get i: ci9).copy
                result9.set key: kk9 value: tcm9
            }
        }
        ci9 = ci9 + 1
    }
    return result9
}

# fnSigTextOpt -- a function type's readable signature "name: function {p:
# T ...} out Ret", the receiver skipped; "" when the type is not a function.
fnSigTextOpt: function {
    vfs: zvfs.ZVfs
    prog: zast.Node
    o: (Option zenv.ZSymbolTable)
    tid: u64
    name: StringView
} out String is {
    docs9: paramDocs :o :prog :vfs :tid
    match (
        o
    ) case some then {
        isFn9: false
        if (o.reg.typetypeOf typeId: tid) == ztypes.ztypetype.functionType then isFn9 = true
        if (isFn9) == false then return "".string
        # collect (paramName, paramTypeId) while the childIndex view is held,
        # skipping the receiver; resolve type names after the views release
        # (typeNameOf takes an exclusive lock on `o`).
        pnames9: (List String)
        ptids9: (List u64)
        pcnids9: (List u64)
        match (
            prog
        ) case program then {
            bp9: o.typing.childIndex.get key: tid
            match (
                bp9
            ) case some then {
                with rpit9: bp9.rows.iterate do for rpi9: rpit9 loop {
                    tc9: o.typing.typeChild.get i: rpi9
                    cnB9: prog.ast.names.texts.get i: (tc9.nameId - 1).u64
                    cn9: cnB9.stringview
                    isRecv9: false
                    if tc9.nameId == wkThis then isRecv9 = true
                    zt9: o.reg.typeById.get key: tid
                    match (
                        zt9
                    ) case some then {
                        if (ztypecheck.optStrEquals o: zt9.thisParamName s: cn9) then isRecv9 = true
                    } case none then null
                    if (isRecv9) == false then {
                        ctid9: u64
                        cg9: o.typing.childTypeById.get key: tc9.childNameId
                        match (
                            cg9
                        ) case some then {
                            ctid9 = cg9
                        } case none then null
                        pnames9.append cn9.string
                        ptids9.append ctid9
                        pcnids9.append tc9.childNameId
                    }
                }
            } case none then null
        } else null
        # render each param display string (the childIndex view has released;
        # typeNameOf locks `o` exclusively, so a childDefault view is copied
        # out first). A defaulted param shows its value; else type + ownership.
        pdisp9: (List String)
        pi9: u64
        for pi9 < pnames9.length loop {
            pt9: ptids9.get i: pi9
            pcn9: pcnids9.get i: pi9
            dtc9: String
            hasDef9: false
            {
                dt9: o.typing.childDefault.get key: pcn9
                match (
                    dt9
                ) case some then {
                    dtc9 = dt9.copy
                    hasDef9 = true
                } case none then null
            }
            ptn9: displayTypeNameSt st: o tid: pt9
            ps9: (pnames9.get i: pi9).copy
            ps9.append ": "
            if hasDef9 then {
                dd9: defaultDisplay dtext: dtc9.stringview typeName: ptn9.stringview
                if dd9.length > 0 then {
                    ps9.append dd9.stringview
                } else {
                    ps9.append ptn9.stringview
                }
            } else {
                ps9.append ptn9.stringview
                oo9: o.typing.childOwnership.get key: pcn9
                match (
                    oo9
                ) case some then {
                    if oo9 == ztypes.zparamownership.takeMode then ps9.append ".take"
                    if oo9 == ztypes.zparamownership.lockMode then ps9.append ".lock"
                } case none then null
            }
            pdisp9.append ps9
            pi9 = pi9 + 1
        }
        rets9: String
        rr9: ztypecheck.methodReturnOf st: o mid: tid
        rtid9: ztypecheck.optU64Or o: rr9 d: 0
        if rtid9 > 0 then {
            rtn9: displayTypeNameSt st: o tid: rtid9
            rets9.append " out "
            rets9.append rtn9.stringview
            rb9: o.typing.funcReturnsBorrow.get key: tid
            match (
                rb9
            ) case some then {
                if rb9 then rets9.append ".borrow"
            } case none then null
        }
        # one line, or param-per-line (zl fmt >100-col style) when too long.
        pdocs9: (List String)
        hasDocs9: false
        pdi9: u64
        for pdi9 < pnames9.length loop {
            pdc9: String
            {
                pn0: pnames9.get i: pdi9
                dgot9: docs9.get key: pn0
                match (
                    dgot9
                ) case some then {
                    pdc9 = dgot9.copy
                } case none then null
            }
            if pdc9.length > 0 then hasDocs9 = true
            pdocs9.append pdc9
            pdi9 = pdi9 + 1
        }
        one9: name.string
        one9.append ": function"
        if pdisp9.length > 0 then {
            one9.append " {"
            oi9: u64
            for oi9 < pdisp9.length loop {
                if oi9 > 0 then one9.append " "
                one9.append (pdisp9.get i: oi9).stringview
                oi9 = oi9 + 1
            }
            one9.append "}"
        }
        one9.append rets9.stringview
        if one9.length <= 100 when hasDocs9 == false then return one9
        if pdisp9.length == 0 then return one9
        wrap9: name.string
        wrap9.append ": function {"
        wi9: u64
        for wi9 < pdisp9.length loop {
            wrap9.appendByte b: 10
            wrap9.append "    "
            wrap9.append (pdisp9.get i: wi9).stringview
            wpdc9: pdocs9.get i: wi9
            if wpdc9.length > 0 then {
                wrap9.append "  # "
                wrap9.append wpdc9.stringview
            }
            wi9 = wi9 + 1
        }
        wrap9.appendByte b: 10
        wrap9.append "}"
        wrap9.append rets9.stringview
        return wrap9
    } case none then {
        return "".string
    }
}

# fnParamDisplays -- the per-parameter display strings for a function tid
# (receiver skipped): each "name: <type>[.take/.lock]" or "name: <default>",
# mirroring fnSigTextOpt's param rendering. Raw material for signatureHelp
# parameters.
fnParamDisplays: function {
    prog: zast.Node
    o: (Option zenv.ZSymbolTable)
    tid: u64
} out (List String) is {
    out9: (List String)
    match (
        o
    ) case some then {
        pnames9: (List String)
        ptids9: (List u64)
        pcnids9: (List u64)
        match (
            prog
        ) case program then {
            bp9: o.typing.childIndex.get key: tid
            match (
                bp9
            ) case some then {
                with rpit9: bp9.rows.iterate do for rpi9: rpit9 loop {
                    tc9: o.typing.typeChild.get i: rpi9
                    cnB9: prog.ast.names.texts.get i: (tc9.nameId - 1).u64
                    cn9: cnB9.stringview
                    isRecv9: false
                    if tc9.nameId == wkThis then isRecv9 = true
                    zt9: o.reg.typeById.get key: tid
                    match (
                        zt9
                    ) case some then {
                        if (ztypecheck.optStrEquals o: zt9.thisParamName s: cn9) then isRecv9 = true
                    } case none then null
                    if (isRecv9) == false then {
                        ctid9: u64
                        cg9: o.typing.childTypeById.get key: tc9.childNameId
                        match (
                            cg9
                        ) case some then {
                            ctid9 = cg9
                        } case none then null
                        pnames9.append cn9.string
                        ptids9.append ctid9
                        pcnids9.append tc9.childNameId
                    }
                }
            } case none then null
        } else null
        pi9: u64
        for pi9 < pnames9.length loop {
            pt9: ptids9.get i: pi9
            pcn9: pcnids9.get i: pi9
            dtc9: String
            hasDef9: false
            {
                dt9: o.typing.childDefault.get key: pcn9
                match (
                    dt9
                ) case some then {
                    dtc9 = dt9.copy
                    hasDef9 = true
                } case none then null
            }
            ptn9: displayTypeNameSt st: o tid: pt9
            ps9: (pnames9.get i: pi9).copy
            ps9.append ": "
            if hasDef9 then {
                dd9: defaultDisplay dtext: dtc9.stringview typeName: ptn9.stringview
                if dd9.length > 0 then {
                    ps9.append dd9.stringview
                } else {
                    ps9.append ptn9.stringview
                }
            } else {
                ps9.append ptn9.stringview
                oo9: o.typing.childOwnership.get key: pcn9
                match (
                    oo9
                ) case some then {
                    if oo9 == ztypes.zparamownership.takeMode then ps9.append ".take"
                    if oo9 == ztypes.zparamownership.lockMode then ps9.append ".lock"
                } case none then null
            }
            out9.append ps9
            pi9 = pi9 + 1
        }
    } case none then null
    return out9
}

# hoverMarkdown -- a hover result: `code` rendered as a fenced ```zerolang
# block (highlighted like source), then an optional doc block as markdown
# prose. `code` may be multi-line (a hand-wrapped signature).
hoverMarkdown: function {code: StringView doc: StringView} out Value is {
    v9: String
    v9.appendByte b: 96
    v9.appendByte b: 96
    v9.appendByte b: 96
    v9.append "zerolang"
    v9.appendByte b: 10
    v9.append code
    v9.appendByte b: 10
    v9.appendByte b: 96
    v9.appendByte b: 96
    v9.appendByte b: 96
    if doc.length > 0 then {
        v9.appendByte b: 10
        v9.appendByte b: 10
        v9.append doc
    }
    mk9: newObj
    mk9.set key: "kind".string value: (Value.text "markdown".string)
    mk9.set key: "value".string value: (Value.text v9)
    ho9: newObj
    ho9.set key: "contents".string value: (Value.object mk9)
    return (Value.object ho9)
}

# ---- def-node navigation (unit/body indexes into the program AST) ----

memberIn: function {
    ast: Ast
    op: zast.Node
    name: StringView
    wrapperId: u32
} out u64 is {
    match (
        op
    ) case objectdef then {
        iit9: op.isItems.iterate
        for ii9Id9: iit9 loop {
            ii9: ast.nodes.get i: (ii9Id9 - 1).u64
            m9: (memberLabelId :ast m: ii9 :name)
            if m9 > 0 then return m9
        }
        ait9: op.asItems.iterate
        for ai9Id9: ait9 loop {
            ai9: ast.nodes.get i: (ai9Id9 - 1).u64
            m2: (memberLabelId :ast m: ai9 :name)
            if m2 > 0 then return m2
        }
        return wrapperId.u64
    } else {
        return wrapperId.u64
    }
}

memberLabelId: function {ast: Ast m: zast.Node name: StringView} out u64 is {
    match (
        m
    ) case namedoperation then {
        if (zast.nameTextEq :ast ref: m.name s: name) then return m.nodeid.u64
        return 0
    } else {
        return 0
    }
}

defOrMember: function {ast: Ast d: zast.Node member: StringView} out u64 is {
    match (
        d
    ) case namedoperation then {
        if member.length == 0 then return d.nodeid.u64
        return (memberIn
            :ast
            op: (ast.nodes.get i: (d.operation - 1).u64)
            name: member
            wrapperId: d.nodeid
        )
    } else {
        return 0
    }
}

navUnitDef: function {ast: Ast ud: zast.Node bidx: u64 member: StringView} out u64 is {
    match (
        ud
    ) case unitdef then {
        if bidx >= ud.body.length then return 0
        m9Id: ud.body.get i: bidx
        return (defOrMember :ast d: (ast.nodes.get i: (m9Id - 1).u64) :member)
    } else {
        return 0
    }
}

navWrapper: function {ast: Ast wId: u32 bidx: u64 member: StringView} out u64 is {
    w: ast.nodes.get i: (wId - 1).u64
    match (
        w
    ) case namedoperation then {
        return (navUnitDef :ast ud: (ast.nodes.get i: (w.operation - 1).u64) :bidx :member)
    } else {
        return 0
    }
}

navBody: function {prog: zast.Node uidx: u64 bidx: u64 member: StringView} out u64 is {
    match (
        prog
    ) case program then {
        if uidx >= prog.ast.units.length then return 0
        u9Id9: prog.ast.units.get i: uidx
        return (navWrapper ast: prog.ast wId: u9Id9 :bidx :member)
    } else {
        return 0
    }
}

# defNodeInfo -- the target nodeid for a top-level def (member == "")
# or a named member inside it. Mono tids chase their generic origin.
defNodeInfo: function {
    o: (Option zenv.ZSymbolTable)
    prog: zast.Node
    tid: u64
    member: StringView
} out u64 is {
    key0: defKeyOfTid :o :tid
    if key0.length == 0 then return 0
    return (defNodeByKeyIn :o :prog key: key0.stringview :member)
}

# defKeyOfTid -- a type's "unit.name" def-finder key (mono tids chase
# their generic origin); "" when the type has no source definition.
# definedInUnit holds only the unit; the name comes from the registry.
defKeyOfTid: function {o: (Option zenv.ZSymbolTable) tid: u64} out String is {
    match (
        o
    ) case some then {
        t9: tid
        tn9: String
        rt9: o.reg.typeById.get key: t9
        match (
            rt9
        ) case some then {
            go9: rt9.genericOriginId
            match (
                go9
            ) case some then {
                t9 = go9
            } case none then null
        } case none then null
        rt2: o.reg.typeById.get key: t9
        match (
            rt2
        ) case some then {
            tn9 = rt2.name.copy
        } case none then null
        if tn9.length == 0 then return "".string
        ko9: o.typing.definedInUnit.get key: t9
        match (
            ko9
        ) case some then {
            k9: "\{ko9.stringview}.\{tn9.stringview}"
            return k9
        } case none then {
            return "".string
        }
    } case none then {
        return "".string
    }
}

# defNodeByKeyIn -- target nodeid for a "unit.name" def-finder key.
defNodeByKeyIn: function {
    o: (Option zenv.ZSymbolTable)
    prog: zast.Node
    key: StringView
    member: StringView
} out u64 is {
    match (
        o
    ) case some then {
        ui9: u64
        bi9: u64
        hasU9: false
        hasB9: false
        k1: key.string
        ug9: o.typing.defNodeUnitIdx.get key: k1
        match (
            ug9
        ) case some then {
            ui9 = ug9
            hasU9 = true
        } case none then null
        k2: key.string
        bg9: o.typing.defNodeBodyIdx.get key: k2
        match (
            bg9
        ) case some then {
            bi9 = bg9
            hasB9 = true
        } case none then null
        if hasU9 when hasB9 then return (navBody :prog uidx: ui9 bidx: bi9 :member)
        return 0
    } case none then {
        return 0
    }
}

# locationValue -- an LSP Location for a target node ({} miss -> nul).
locationValue: function {
    snap: zcheck.CheckResult
    sp: Spans
    nid: u64
    width: u32
    docRel: StringView
    docUri: StringView
    srcDir: StringView
    systemDir: StringView
    docText: StringView
    utf32: bool
} out Value is {
    pg9: sp.pos.get key: nid
    match (
        pg9
    ) case some then {
        line9: (pg9 / 1048576).u32.orPanic
        col9: (pg9 % 1048576).u32.orPanic
        if line9 == 0 then return Value.nul
        fs9: zcheck.fsnoFor r: snap nodeid: nid.u32.orPanic
        if fs9 == 0 then return Value.nul
        pp9: snap.vfs.pathfromprovider dentryid: fs9
        own9: pathMatches pv: pp9.stringview rel: docRel :srcDir
        uri9: String
        lineText9: String
        if own9 then {
            uri9 = docUri.string
            lineText9 = docLine text: docText lineno: line9
        } else {
            absp9: snap.vfs.pathfromproviderNative dentryid: fs9
            if absp9.length == 0 then {
                st0: u64
                if pp9.startsWith "/" then st0 = 1
                rel0: pp9.substring from: st0 to: pp9.length
                absp9 = absRelPath :rel0 :srcDir :systemDir
            }
            uri9 = pathToUri path: absp9.stringview
            lg9: snap.vfs.getline dentryid: fs9 lineno: (line9 - 1).u64
            match (
                lg9
            ) case some then {
                lineText9 = lg9.copy
            } case none then null
        }
        w9: width
        if w9 == 0 then w9 = 1
        c0: encodedCol lineText: lineText9.stringview cpCol1: col9 :utf32
        c1: encodedCol lineText: lineText9.stringview cpCol1: col9 + w9 :utf32
        if c1 <= c0 then c1 = c0 + 1
        st9: newObj
        st9.set key: "line".string value: (Value.intval (line9 - 1).i64)
        st9.set key: "character".string value: (Value.intval c0.i64)
        en9: newObj
        en9.set key: "line".string value: (Value.intval (line9 - 1).i64)
        en9.set key: "character".string value: (Value.intval c1.i64)
        rg9: newObj
        rg9.set key: "start".string value: (Value.object st9)
        rg9.set key: "end".string value: (Value.object en9)
        lo9: newObj
        lo9.set key: "uri".string value: (Value.text uri9)
        lo9.set key: "range".string value: (Value.object rg9)
        return (Value.object lo9)
    } case none then {
        return Value.nul
    }
}

# defNodeOf -- the def-node id a resolved hit points at: a variable binding
# (refVid), a type/function def (refTid), or an owner's member (refOwner +
# member name); 0 when unresolved.
defNodeOf: function {
    o: (Option zenv.ZSymbolTable)
    prog: zast.Node
    refVid: u64
    refTid: u64
    refOwner: u64
    member: StringView
} out u64 is {
    if refVid > 0 then return (varDefNode :o vid: refVid)
    if refTid > 0 then return (defNodeInfo :o :prog tid: refTid member: "")
    if refOwner > 0 then return (defNodeInfo :o :prog tid: refOwner :member)
    return 0
}

# trailingDocOf -- the text of a trailing `#` comment on `line1` (1-based) of
# file `fsno`, the `#` and surrounding space stripped; "" when there is none.
# Surfaces a field's or parameter's inline doc in hover.
trailingDocOf: function {vfs: zvfs.ZVfs fsno: u32 line1: u32} out String is {
    result9: String
    if line1 == 0 then return result9
    lg9: vfs.getline dentryid: fsno lineno: (line1 - 1).u64
    match (
        lg9
    ) case some then {
        lv9: lg9.stringview
        n9: lv9.length
        inStr9: false
        hashAt9: u64
        found9: false
        i9: u64
        for i9 < n9 loop {
            b9: lv9.byteAt i: i9
            match (
                b9
            ) case some then {
                if b9 == 34 then inStr9 = (inStr9 == false)
                if b9 == 35 when inStr9 == false when found9 == false then {
                    hashAt9 = i9
                    found9 = true
                }
            } case none then null
            if found9 then break
            i9 = i9 + 1
        }
        if found9 then {
            after9: lv9.substring from: (hashAt9 + 1) to: n9
            trimmed9: after9.trim
            result9 = trimmed9.string
        }
    } case none then null
    return result9
}

# docCommentForNode -- the contiguous `#` comment block immediately above the
# definition at `defLine` (1-based) in file `fsno`, each line stripped of its
# leading "# " and joined top-to-bottom by newlines; "" when there is none.
# Reads through the vfs, so a definition in another unit works too.
docCommentForNode: function {snap: zcheck.CheckResult fsno: u32 defLine: u32} out String is {
    if defLine <= 1 then return "".string
    acc9: (List String)
    k9: defLine
    for k9 > 1 loop {
        k9 = k9 - 1
        lg9: snap.vfs.getline dentryid: fsno lineno: (k9 - 1).u64
        stop9: false
        match (
            lg9
        ) case some then {
            lv9: lg9.stringview
            tl9: lv9.trimStart
            if tl9.startsWith "#" then {
                st9: 1.u64
                sb9: tl9.byteAt i: 1
                match (
                    sb9
                ) case some then {
                    if sb9 == 32 then st9 = 2
                } case none then null
                ds9: tl9.substring from: st9 to: tl9.length
                acc9.append ds9.string
            } else {
                stop9 = true
            }
        } case none then {
            stop9 = true
        }
        if stop9 then break
    }
    out9: String
    ai9: acc9.length
    for ai9 > 0 loop {
        ai9 = ai9 - 1
        if out9.length > 0 then out9.appendByte b: 10
        dl9: acc9.get i: ai9
        out9.append dl9.stringview
    }
    return out9
}

# unitFsnoByName -- the vfs dentry id of the file for the unit named
# `name`, or 0 when no such unit file exists.
unitFsnoByName: function {snap: zcheck.CheckResult name: StringView} out u32 is {
    ids9: (List u32)
    paths9: (List String)
    snap.vfs.fileTable outIds: ids9 outPaths: paths9
    result9: u32
    i9: u64
    n9: ids9.length
    for i9 < n9 loop {
        pth9: paths9.get i: i9
        un9: zsource.unitNameOf path: pth9.stringview
        if un9.stringview == name then result9 = ids9.get i: i9
        i9 = i9 + 1
    }
    return result9
}

# unitGenericParamsOf -- a unitdef's generic parameters rendered " {T U}"
# (its `T: base.generic` body declarations); "" when it has none.
unitGenericParamsOf: function {ast: Ast udId: u32} out String is {
    ud: ast.nodes.get i: (udId - 1).u64
    out9: String
    match (
        ud
    ) case unitdef then {
        bit9: ud.body.iterate
        for gm9Id: bit9 loop {
            gm9: ast.nodes.get i: (gm9Id - 1).u64
            match (
                gm9
            ) case namedoperation then {
                if (ztypecheck.isBareGenericParam
                    :ast
                    op: (ast.nodes.get i: (gm9.operation - 1).u64)
                ) then {
                    gpn9: zast.nameTextCopy :ast ref: gm9.name
                    if out9.length == 0 then out9.append " {"
                    if out9.length > 2 then out9.append " "
                    out9.append gpn9.stringview
                }
            } else null
        }
    } else null
    if out9.length > 0 then out9.append "}"
    return out9
}

# unitGenericSuffix -- the " {T U}" suffix for a generic unit named `name`.
unitGenericSuffix: function {prog: zast.Node name: StringView} out String is {
    out9: String
    match (
        prog
    ) case program then {
        uCnt9a: prog.ast.units.length
        uIdx9a: u64
        for uIdx9a < uCnt9a loop {
            u9Id9: prog.ast.units.get i: uIdx9a
            uIdx9a = uIdx9a + 1
            opId9: u32
            {
                u9: prog.ast.nodes.get i: (u9Id9 - 1).u64
                if u9.namedoperation then {
                    lb9: zast.poolTextCopy pool: prog.ast.names ref: u9.name
                    if lb9.stringview == name then opId9 = u9.operation
                }
            }
            if opId9 > 0 then {
                gs9: (unitGenericParamsOf
                    ast: prog.ast
                    udId: opId9
                )
                if gs9.length > 0 then out9 = gs9
            }
        }
    } else null
    return out9
}

# unitDocComment -- a unit file's godoc-style header: the contiguous `#`
# comment lines from the top of the file, up to the first blank line or
# first definition. "" when the file has no header comment.
unitDocComment: function {snap: zcheck.CheckResult fsno: u32} out String is {
    out9: String
    k9: u64
    for true loop {
        lg9: snap.vfs.getline dentryid: fsno lineno: k9
        stop9: false
        match (
            lg9
        ) case some then {
            lv9: lg9.stringview
            tl9: lv9.trimStart
            if tl9.startsWith "#" then {
                st9: 1.u64
                sb9: tl9.byteAt i: 1
                match (
                    sb9
                ) case some then {
                    if sb9 == 32 then st9 = 2
                } case none then null
                ds9: tl9.substring from: st9 to: tl9.length
                if out9.length > 0 then out9.appendByte b: 10
                out9.append ds9
            } else {
                stop9 = true
            }
        } case none then {
            stop9 = true
        }
        if stop9 then break
        k9 = k9 + 1
    }
    return out9
}

# locationAtFileTop -- an LSP Location at line 0 of file `fsno` (a unit
# reference has no member node to point at).
locationAtFileTop: function {
    snap: zcheck.CheckResult
    fsno: u32
    docRel: StringView
    docUri: StringView
    srcDir: StringView
    systemDir: StringView
} out Value is {
    if fsno == 0 then return Value.nul
    pp9: snap.vfs.pathfromprovider dentryid: fsno
    own9: pathMatches pv: pp9.stringview rel: docRel :srcDir
    uri9: String
    if own9 then {
        uri9 = docUri.string
    } else {
        absp9: snap.vfs.pathfromproviderNative dentryid: fsno
        if absp9.length == 0 then {
            st0: u64
            if pp9.startsWith "/" then st0 = 1
            rel0: pp9.substring from: st0 to: pp9.length
            absp9 = absRelPath :rel0 :srcDir :systemDir
        }
        uri9 = pathToUri path: absp9.stringview
    }
    st9: newObj
    st9.set key: "line".string value: (Value.intval 0.i64)
    st9.set key: "character".string value: (Value.intval 0.i64)
    en9: newObj
    en9.set key: "line".string value: (Value.intval 0.i64)
    en9.set key: "character".string value: (Value.intval 0.i64)
    rg9: newObj
    rg9.set key: "start".string value: (Value.object st9)
    rg9.set key: "end".string value: (Value.object en9)
    lo9: newObj
    lo9.set key: "uri".string value: (Value.text uri9)
    lo9.set key: "range".string value: (Value.object rg9)
    return (Value.object lo9)
}

# dispositionNote -- a call argument's disposition (from the argDisposition
# stamp) as a one-line prose note, or "".
dispositionNote: function {o: (Option zenv.ZSymbolTable) nid: u64} out String is {
    match (
        o
    ) case some then {
        d9: o.typing.argDisposition.get key: nid
        match (
            d9
        ) case some then {
            if d9 == ztypes.zparamownership.takeMode then {
                return "Moved into the call (a taking parameter).".string
            }
            if d9 == ztypes.zparamownership.lockMode then {
                return "Locked for the duration of the call (a lock parameter).".string
            }
            if d9 == ztypes.zparamownership.borrowMode then {
                return "Borrowed for the duration of the call.".string
            }
        } case none then null
    } case none then null
    return "".string
}

# inferredGenericLines -- concrete generic bindings inferred for the call
# `callId` whose callee is `calleeNid`, one "# T = Type" comment per bound
# generic param (from the callGenericBinding stamp), or "".
inferredGenericLines: function {o: (Option zenv.ZSymbolTable) callId: u64} out String is {
    match (
        o
    ) case some then {
        prefix9: "\{callId}:"
        holders9: (List String)
        tids9: (List u64)
        with git9: o.typing.callGenericBinding.iterateItems do for e9: git9 loop {
            k9: e9.key.copy
            if k9.startsWith prefix9.stringview then {
                hv9: k9.substring from: prefix9.length to: k9.length
                holders9.append hv9.string
                tids9.append e9.value
            }
        }
        r9: String
        hi9: u64
        for hi9 < holders9.length loop {
            tn9: displayTypeNameSt st: o tid: (tids9.get i: hi9)
            if r9.length > 0 then r9.appendByte b: 10
            r9.append "# "
            r9.append (holders9.get i: hi9).stringview
            r9.append " = "
            r9.append tn9.stringview
            hi9 = hi9 + 1
        }
        return r9
    } case none then {
        return "".string
    }
}

# refAnnotation -- a value reference's ownership + scope origin (+ borrow
# source) as an in-fence `#` comment body: "owned local" / "borrowed
# parameter" / "borrowed local, from s" / "static unit-level"; "" when the
# reference carries no stamped ownership/origin.
refAnnotation: function {o: (Option zenv.ZSymbolTable) vid: u64 nid: u64} out String is {
    if vid == 0 then {
        udo9: useUnitDef :o :nid
        if udo9 > 0 then return "static unit-level".string
        return "".string
    }
    match (
        o
    ) case some then {
        own9: String
        vo9: o.typing.variableOwnership.get key: vid
        match (
            vo9
        ) case some then {
            if vo9 == ztypes.zownership.owned then own9 = "owned".string
            if vo9 == ztypes.zownership.borrowed then own9 = "borrowed".string
        } case none then null
        orig9: String
        ro9: o.typing.variableOrigin.get key: vid
        match (
            ro9
        ) case some then {
            if ro9 then orig9 = "parameter".string
            if (ro9) == false then orig9 = "local".string
        } case none then null
        if own9.length == 0 when orig9.length == 0 then return "".string
        r9: String
        if own9.length > 0 then r9.append own9.stringview
        if orig9.length > 0 then {
            if r9.length > 0 then r9.append " "
            r9.append orig9.stringview
        }
        bo9: o.typing.variableBorrowOrigin.get key: vid
        match (
            bo9
        ) case some then {
            bsrc9: bo9.copy
            if bsrc9.length > 0 then {
                r9.append ", from "
                r9.append bsrc9.stringview
            }
        } case none then null
        return r9
    } case none then {
        return "".string
    }
}

# navAnswer -- definition (1), hover (2), references (3) from the
# last-good snapshot.
navAnswer: function {
    snap: zcheck.CheckResult
    docRel: StringView
    docUri: StringView
    srcDir: StringView
    systemDir: StringView
    docText: StringView
    line0: i64
    ch: i64
    utf32: bool
    mode: u8
} out Value is {
    l1: line0 + 1
    l1u: l1.u32.orPanic
    lt: docLine text: docText lineno: l1u
    cp1: cpColOf lineText: lt.stringview :ch :utf32
    sp: (Spans
        rows: (List spanrow)
        names: (List String)
        pos: (Map u64 value: u64)
        ranges: (List rangerow)
        lastPos: 0
    )
    sp.walkProgram prog: snap.prog
    bestIdx: -1
    bestKind: u8
    nr: sp.rows.length
    ri: u64
    for ri < nr loop {
        row: sp.rows.get i: ri
        if row.line == l1u when row.colLo <= cp1 then {
            if cp1 < row.colHi then {
                fs9: zcheck.fsnoFor r: snap nodeid: row.nodeid
                pp9: snap.vfs.pathfromprovider dentryid: fs9
                if (pathMatches pv: pp9.stringview rel: docRel :srcDir) then {
                    take9: false
                    if bestIdx < 0 then take9 = true
                    if row.kind == 2 when bestKind != 2 then take9 = true
                    if take9 then {
                        bestIdx = ri.i64.orPanic
                        bestKind = row.kind
                    }
                }
            }
        }
        ri = ri + 1
    }
    if bestIdx < 0 then return Value.nul
    bi: bestIdx.u64.orPanic
    hit: sp.rows.get i: bi
    hname: (sp.names.get i: bi).copy
    w9: hit.colHi - hit.colLo
    hnid: hit.nodeid.u64

    # resolve the hit to a target
    refVid: u64
    refTid: u64
    refOwner: u64
    if bestKind == 1 then {
        refVid = useVarId o: snap.st nid: hnid
        if refVid == 0 then refTid = useUnitDef o: snap.st nid: hnid
    }
    if bestKind == 2 then {
        refOwner = memberOwnerOf o: snap.st nid: hnid
        # a unit-qualified member has no owner stamp; fall back to its def tid
        if refOwner == 0 then refTid = useUnitDef o: snap.st nid: hnid
    }
    if bestKind == 3 then refVid = defVarIdOf o: snap.st nid: hnid

    unitFsno9: u32
    if refVid == 0 when refTid == 0 then unitFsno9 = unitFsnoByName :snap name: hname.stringview

    if mode == 2 then {
        if unitFsno9 > 0 then {
            ub9: hname.copy
            ub9.append ": unit"
            ugs9: unitGenericSuffix prog: snap.prog name: hname.stringview
            ub9.append ugs9.stringview
            udoc9: unitDocComment :snap fsno: unitFsno9
            return (hoverMarkdown code: ub9.stringview doc: udoc9.stringview)
        }
        tnid: hnid
        t9: nodeTypeAt o: snap.st nid: tnid
        # a callable / unit-member auto-calls to its return type in value
        # position; prefer its stamped def tid so a function hovers as its
        # signature rather than the return value's type.
        ud9: useUnitDef o: snap.st nid: tnid
        sigTid9: t9
        if ud9 > 0 then sigTid9 = ud9
        body9: (fnSigTextOpt
            vfs: snap.vfs
            prog: snap.prog
            o: snap.st
            tid: sigTid9
            name: hname.stringview
        )
        if body9.length == 0 then {
            tk9: typeKindTextOpt o: snap.st tid: refTid
            if tk9.length > 0 then {
                body9 = displayTypeNameOfOpt o: snap.st tid: refTid
                body9.append ": "
                body9.append tk9.stringview
            } else {
                if t9 == 0 then return Value.nul
                tn: displayTypeNameOfOpt o: snap.st tid: t9
                if tn.length == 0 then return Value.nul
                if refOwner > 0 then {
                    own9: displayTypeNameOfOpt o: snap.st tid: refOwner
                    if own9.length > 0 then {
                        body9.append own9.stringview
                        body9.appendByte b: 46
                    }
                }
                body9.append hname.stringview
                body9.append ": "
                body9.append tn.stringview
                annot9: refAnnotation o: snap.st vid: refVid nid: tnid
                if annot9.length > 0 then {
                    body9.append "  # "
                    body9.append annot9.stringview
                }
            }
        }
        docBody9: String
        # append the `#` doc block above the definition, if any (cross-file ok)
        dnd9: (defNodeOf
            o: snap.st
            prog: snap.prog
            :refVid
            :refTid
            :refOwner
            member: hname.stringview
        )
        if dnd9 > 0 then {
            dfs9: zcheck.fsnoFor r: snap nodeid: dnd9.u32.orPanic
            dpg9: sp.pos.get key: dnd9
            match (
                dpg9
            ) case some then {
                dln9: (dpg9 / 1048576).u32.orPanic
                if dfs9 > 0 when dln9 > 1 then {
                    doc9: docCommentForNode :snap fsno: dfs9 defLine: dln9
                    if doc9.length > 0 then docBody9 = doc9
                    if refOwner > 0 then {
                        tc9: trailingDocOf vfs: snap.vfs fsno: dfs9 line1: dln9
                        if tc9.length > 0 then {
                            body9.append "  # "
                            body9.append tc9.stringview
                        }
                    }
                }
            } case none then null
        }
        # call-site enrichment: hovering a callee appends inferred generic
        # bindings (in-fence); hovering an argument appends its disposition.
        hpos9: u64
        {
            hp9: sp.pos.get key: hnid
            match (
                hp9
            ) case some then {
                hpos9 = hp9
            } case none then null
        }
        callId9: sp.innerRangeOfKind curPos: hpos9 kind: 4 slack: 0
        if callId9 > 0 then {
            callPos9: u64
            {
                cp9x: sp.pos.get key: callId9.u64
                match (
                    cp9x
                ) case some then {
                    callPos9 = cp9x
                } case none then null
            }
            if callPos9 == hpos9 then {
                gl9: inferredGenericLines o: snap.st callId: callId9.u64
                if gl9.length > 0 then {
                    body9.appendByte b: 10
                    body9.append gl9.stringview
                }
            } else {
                dn9x: dispositionNote o: snap.st nid: hnid
                if dn9x.length > 0 then {
                    if docBody9.length > 0 then {
                        docBody9.appendByte b: 10
                        docBody9.appendByte b: 10
                    }
                    docBody9.append dn9x.stringview
                }
            }
        }
        return (hoverMarkdown code: body9.stringview doc: docBody9.stringview)
    }

    if mode == 1 then {
        if unitFsno9 > 0 then {
            return (locationAtFileTop :snap fsno: unitFsno9 :docRel :docUri :srcDir :systemDir)
        }
        dn9: defNodeOf o: snap.st prog: snap.prog :refVid :refTid :refOwner member: hname.stringview
        if dn9 == 0 then return Value.nul
        return (locationValue
            :snap
            :sp
            nid: dn9
            width: w9
            :docRel
            :docUri
            :srcDir
            :systemDir
            :docText
            :utf32
        )
    }

    # references: one pass over the span rows
    arr: newArr
    rj: u64
    for rj < nr loop {
        row2: sp.rows.get i: rj
        n2: row2.nodeid.u64
        add9: false
        if refVid > 0 then {
            if row2.kind == 1 then {
                if (useVarId o: snap.st nid: n2) == refVid then add9 = true
            }
            if row2.kind == 3 then {
                if (defVarIdOf o: snap.st nid: n2) == refVid then add9 = true
            }
        }
        if refTid > 0 when row2.kind == 1 then {
            if (useUnitDef o: snap.st nid: n2) == refTid then add9 = true
        }
        if refOwner > 0 when row2.kind == 2 then {
            if (memberOwnerOf o: snap.st nid: n2) == refOwner then {
                nm2: sp.names.get i: rj
                if nm2.stringview == hname.stringview then add9 = true
            }
        }
        if add9 then {
            lv2: (locationValue
                :snap
                :sp
                nid: n2
                width: row2.colHi - row2.colLo
                :docRel
                :docUri
                :srcDir
                :systemDir
                :docText
                :utf32
            )
            appendIfObject :arr v: lv2
        }
        rj = rj + 1
    }
    return (Value.array arr)
}

# appendIfObject -- append `v` when it is a real Location (drop nul).
appendIfObject: function {arr: Arr v: Value.take} is {
    keep9: false
    match (
        v
    ) case object then {
        keep9 = true
    } else null
    if keep9 then arr.items.append v
}

# symbolsAnswer -- flat DocumentSymbol list for the document's unit.
symbolsAnswer: function {
    snap: zcheck.CheckResult
    unitName: StringView
    docText: StringView
    utf32: bool
} out Value is {
    arr: newArr
    collectUnitSymbols prog: snap.prog :unitName :docText :utf32 :arr
    return (Value.array arr)
}

collectUnitSymbols: function {
    prog: zast.Node
    unitName: StringView
    docText: StringView
    utf32: bool
    arr: Arr
} is {
    match (
        prog
    ) case program then {
        uCnt9b: prog.ast.units.length
        uIdx9b: u64
        for uIdx9b < uCnt9b loop {
            u9Id9: prog.ast.units.get i: uIdx9b
            uIdx9b = uIdx9b + 1
            (collectUnitSymbolsIn
                ast: prog.ast
                wId: u9Id9
                :unitName
                :docText
                :utf32
                :arr
            )
        }
    } else null
}

collectUnitSymbolsIn: function {
    ast: Ast
    wId: u32
    unitName: StringView
    docText: StringView
    utf32: bool
    arr: Arr
} is {
    w: ast.nodes.get i: (wId - 1).u64
    match (
        w
    ) case namedoperation then {
        lb9: zast.nameTextCopy :ast ref: w.name
        if lb9.stringview == unitName then (collectBodySymbols
            :ast
            ud: (ast.nodes.get i: (w.operation - 1).u64)
            :docText
            :utf32
            :arr
        )
    } else null
}

collectBodySymbols: function {
    ast: Ast
    ud: zast.Node
    docText: StringView
    utf32: bool
    arr: Arr
} is {
    match (
        ud
    ) case unitdef then {
        bit9: ud.body.iterate
        for b9Id: bit9 loop symbolOf :ast m: (ast.nodes.get i: (b9Id - 1).u64) :docText :utf32 :arr
    } else null
}

symbolOf: function {
    ast: Ast
    m: zast.Node
    docText: StringView
    utf32: bool
    arr: Arr
} is {
    match (
        m
    ) case namedoperation then {
        lb9: zast.nameTextCopy :ast ref: m.name
        if lb9.length == 0 then return
        k9: symbolKindOf op: (ast.nodes.get i: (m.operation - 1).u64)
        lt9: docLine text: docText lineno: m.lineno
        c0: encodedCol lineText: lt9.stringview cpCol1: m.colno :utf32
        wname9: lb9.stringview.count
        c1: encodedCol lineText: lt9.stringview cpCol1: m.colno + wname9.u32.orPanic :utf32
        if c1 <= c0 then c1 = c0 + 1
        line0: i64
        if m.lineno > 0 then line0 = (m.lineno - 1).i64
        st9: newObj
        st9.set key: "line".string value: (Value.intval line0)
        st9.set key: "character".string value: (Value.intval c0.i64)
        en9: newObj
        en9.set key: "line".string value: (Value.intval line0)
        en9.set key: "character".string value: (Value.intval c1.i64)
        rg9: newObj
        rg9.set key: "start".string value: (Value.object st9)
        rg9.set key: "end".string value: (Value.object en9)
        rv9: (Value.object rg9)
        sy9: newObj
        sy9.set key: "name".string value: (Value.text lb9.copy)
        sy9.set key: "kind".string value: (Value.intval k9)
        sy9.set key: "range".string value: rv9
        rgv2: (rangeCopy :docText :utf32 :line0 c0: c0.i64 c1: c1.i64)
        sy9.set key: "selectionRange".string value: rgv2
        arr.items.append (Value.object sy9)
    } else null
}

# rangeCopy -- a fresh range object (ranges cannot be shared: Values
# move into their parent on set).
rangeCopy: function {docText: StringView utf32: bool line0: i64 c0: i64 c1: i64} out Value is {
    docText
    utf32
    st9: newObj
    st9.set key: "line".string value: (Value.intval line0)
    st9.set key: "character".string value: (Value.intval c0)
    en9: newObj
    en9.set key: "line".string value: (Value.intval line0)
    en9.set key: "character".string value: (Value.intval c1)
    rg9: newObj
    rg9.set key: "start".string value: (Value.object st9)
    rg9.set key: "end".string value: (Value.object en9)
    return (Value.object rg9)
}

symbolKindOf: function {op: zast.Node} out i64 is {
    match (
        op
    ) case functiondef then {
        return 12
    } case objectdef then {
        return 5
    } else {
        return 13
    }
}

# ---- lint + formatting ------------------------------------------------

# lintInto -- fast-tier zl findings for one live buffer as Warning /
# Information diagnostics (hard errors stay with the compile pass,
# which owns them).
lintInto: function {arr: Arr text: String.take relpath: StringView utf32: bool} is {
    la9: zsource.analyzeSource source: text path: relpath.string lineLength: 100 casing: false
    appendLintDiags :arr :la9 :utf32
}

# tcLintInto -- lintInto plus the typecheck-tier rules (L005 suffix, L012
# unused private def / member, L013 / L014 unused local / param) for the
# document that owns the check's main unit. Reuses the compile pass's
# program and symbol table -- no second typecheck.
tcLintInto: function {
    arr: Arr
    text: String.take
    relpath: StringView
    utf32: bool
    prog: Node
    uname: StringView
    sto: (Option zenv.ZSymbolTable)
} is {
    la9: zsource.analyzeSource source: text path: relpath.string lineLength: 100 casing: false
    match (
        sto
    ) case some then {
        la9.lintSuffixUnit :prog :uname st: sto
        la9.reportUnusedDefs :prog :uname st: sto
        la9.reportUnusedVars :prog :uname st: sto
    } case none then null
    appendLintDiags :arr :la9 :utf32
}

# appendLintDiags -- an Analysis's collected warnings / infos as LSP
# diagnostic rows (hard errors stay with the compile pass, which owns them).
appendLintDiags: function {arr: Arr la9: zsource.Analysis utf32: bool} is {
    with dit9: la9.diags.iterate do for d9: dit9 loop {
        sevN9: i64
        k9: d9.sev
        match (
            k9
        ) case warning then {
            sevN9 = 2
        } case info then {
            sevN9 = 3
        } else null
        if sevN9 > 0 then {
            lt9: docLine text: la9.source.stringview lineno: d9.lineno
            line0: i64
            if d9.lineno > 0 then line0 = (d9.lineno - 1).i64
            c0: encodedCol lineText: lt9.stringview cpCol1: d9.colno :utf32
            w9: d9.width
            if w9 == 0 then w9 = 1
            c1: encodedCol lineText: lt9.stringview cpCol1: d9.colno + w9 :utf32
            if c1 <= c0 then c1 = c0 + 1
            m9: d9.msg.copy
            if d9.hint.length > 0 then {
                m9.appendByte b: 10
                m9.append "hint: "
                m9.append d9.hint.stringview
            }
            st9: newObj
            st9.set key: "line".string value: (Value.intval line0)
            st9.set key: "character".string value: (Value.intval c0.i64)
            en9: newObj
            en9.set key: "line".string value: (Value.intval line0)
            en9.set key: "character".string value: (Value.intval c1.i64)
            rg9: newObj
            rg9.set key: "start".string value: (Value.object st9)
            rg9.set key: "end".string value: (Value.object en9)
            dg9: newObj
            dg9.set key: "range".string value: (Value.object rg9)
            dg9.set key: "severity".string value: (Value.intval sevN9)
            dg9.set key: "code".string value: (Value.text d9.code.copy)
            dg9.set key: "source".string value: (Value.text "zl".string)
            dg9.set key: "message".string value: (Value.text m9)
            arr.items.append (Value.object dg9)
        }
    }
}

# formatAnswer -- the zl fmt pipeline over a live buffer: fast-tier
# edits, re-parse validation, wrap at 100. One whole-document TextEdit
# when anything changed; null when the buffer has parse errors or a
# fix would break it (the editor keeps the buffer untouched).
formatAnswer: function {text: StringView relpath: StringView} out Value is {
    a9: zsource.analyzeSource source: text.string path: relpath.string lineLength: 100 casing: false
    if a9.parseErrorCount > 0 then return Value.nul
    newsrc: a9.source.copy
    valid9: true
    if a9.edits.length > 0 then {
        newsrc = zfix.applyEdits source: a9.source.stringview edits: a9.edits
        valid9 = zsource.sourceParses source: newsrc.copy
    }
    if valid9 == false then return Value.nul
    wrapped9: zsource.wrapSource source: newsrc.stringview lineLength: 100
    newsrc = wrapped9
    arr: newArr
    changed9: (newsrc.stringview == text) == false
    if changed9 then {
        nl9: i64
        i9: u64
        n9: text.length
        for i9 < n9 loop {
            b9: text.byteAt i: i9
            match (
                b9
            ) case some then {
                if b9 == 10 then nl9 = nl9 + 1
            } case none then null
            i9 = i9 + 1
        }
        st9: newObj
        st9.set key: "line".string value: (Value.intval 0)
        st9.set key: "character".string value: (Value.intval 0)
        en9: newObj
        en9.set key: "line".string value: (Value.intval nl9 + 1)
        en9.set key: "character".string value: (Value.intval 0)
        rg9: newObj
        rg9.set key: "start".string value: (Value.object st9)
        rg9.set key: "end".string value: (Value.object en9)
        te9: newObj
        te9.set key: "range".string value: (Value.object rg9)
        te9.set key: "newText".string value: (Value.text newsrc)
        arr.items.append (Value.object te9)
    }
    return (Value.array arr)
}

# ---- completion -------------------------------------------------------

# byteIdxOfCp -- byte offset where the 1-based codepoint column starts;
# s.length when the column is past the end of the line.
byteIdxOfCp: function {s: StringView cp1: u32} out u64 is {
    if cp1 <= 1 then return 0
    cnt: u32
    i: u64
    n: s.length
    for i < n loop {
        b: s.byteAt :i
        match (
            b
        ) case some then {
            isStart9: b < 128
            if b >= 192 then isStart9 = true
            if isStart9 then {
                cnt = cnt + 1
                if cnt == cp1 then return i
            }
        } case none then null
        i = i + 1
    }
    return n
}

isIdentByte: function {b: u8} out bool is {
    if b >= 97 when b <= 122 then return true
    if b >= 65 when b <= 90 then return true
    if b >= 48 when b <= 57 then return true
    if b == 95 then return true
    return false
}

# addCand -- record a completion candidate (first kind wins on dups).
addCand: function {sink: (Map String value: u8) name: StringView kind: u8} is {
    if name.length == 0 then return
    k9: name.string
    if (sink.has key: k9) then return
    k2: name.string
    sink.set key: k2 value: kind
}

addKeywords: function {sink: (Map String value: u8)} is {
    addCand :sink name: "function" kind: 14
    addCand :sink name: "class" kind: 14
    addCand :sink name: "record" kind: 14
    addCand :sink name: "union" kind: 14
    addCand :sink name: "variant" kind: 14
    addCand :sink name: "protocol" kind: 14
    addCand :sink name: "facet" kind: 14
    addCand :sink name: "data" kind: 14
    addCand :sink name: "if" kind: 14
    addCand :sink name: "then" kind: 14
    addCand :sink name: "else" kind: 14
    addCand :sink name: "when" kind: 14
    addCand :sink name: "match" kind: 14
    addCand :sink name: "case" kind: 14
    addCand :sink name: "for" kind: 14
    addCand :sink name: "while" kind: 14
    addCand :sink name: "loop" kind: 14
    addCand :sink name: "with" kind: 14
    addCand :sink name: "do" kind: 14
    addCand :sink name: "return" kind: 14
    addCand :sink name: "break" kind: 14
    addCand :sink name: "continue" kind: 14
    addCand :sink name: "is" kind: 14
    addCand :sink name: "as" kind: 14
    addCand :sink name: "in" kind: 14
    addCand :sink name: "out" kind: 14
    addCand :sink name: "native" kind: 14
    addCand :sink name: "true" kind: 14
    addCand :sink name: "false" kind: 14
    addCand :sink name: "null" kind: 14
}

# defKindOf -- the CompletionItemKind of a top-level definition.
defKindOf: function {op: zast.Node} out u8 is {
    match (
        op
    ) case functiondef then {
        return 3
    } case objectdef then {
        return 7
    } else {
        return 21
    }
}

# collectTopDefs -- every loaded unit's name (Module) and top-level
# definition labels (Function / Class / Constant).
collectTopDefs: function {prog: zast.Node sink: (Map String value: u8)} is {
    match (
        prog
    ) case program then {
        uCnt9z: prog.ast.units.length
        uIdx9z: u64
        for uIdx9z < uCnt9z loop {
            u9Id9: prog.ast.units.get i: uIdx9z
            uIdx9z = uIdx9z + 1
            (collectUnitDefs
            ast: prog.ast
            wId: u9Id9
            :sink
        )
        }
    } else null
}

collectUnitDefs: function {ast: Ast wId: u32 sink: (Map String value: u8)} is {
    w: ast.nodes.get i: (wId - 1).u64
    match (
        w
    ) case namedoperation then {
        ul9: zast.nameTextCopy :ast ref: w.name
        addCand :sink name: ul9.stringview kind: 9
        collectUnitDefsIn :ast ud: (ast.nodes.get i: (w.operation - 1).u64) :sink
    } else null
}

collectUnitDefsIn: function {ast: Ast ud: zast.Node sink: (Map String value: u8)} is {
    match (
        ud
    ) case unitdef then {
        bit9: ud.body.iterate
        for b9Id: bit9 loop collectMemberDef :ast m: (ast.nodes.get i: (b9Id - 1).u64) :sink
    } else null
}

collectMemberDef: function {ast: Ast m: zast.Node sink: (Map String value: u8)} is {
    match (
        m
    ) case namedoperation then {
        lb9: zast.nameTextCopy :ast ref: m.name
        if lb9.length > 0 then {
            k9: defKindOf op: (ast.nodes.get i: (m.operation - 1).u64)
            addCand :sink name: lb9.stringview kind: k9
        }
    } else null
}

# enclosingDefStart -- the start line of the unit-body definition the
# cursor sits in (the last def at or before the cursor line), also
# adding that definition's parameter names when it is a function.
# 0 when the cursor precedes every definition.
enclosingDefStart: function {
    prog: zast.Node
    unitName: StringView
    l1u: u32
    sink: (Map String value: u8)
} out u32 is {
    match (
        prog
    ) case program then {
        uCnt9c: prog.ast.units.length
        uIdx9c: u64
        for uIdx9c < uCnt9c loop {
            u9Id9: prog.ast.units.get i: uIdx9c
            uIdx9c = uIdx9c + 1
            r9: enclosingInUnit ast: prog.ast wId: u9Id9 :unitName :l1u :sink
            if r9 > 0 then return r9
        }
        return 0
    } else {
        return 0
    }
}

enclosingInUnit: function {
    ast: Ast
    wId: u32
    unitName: StringView
    l1u: u32
    sink: (Map String value: u8)
} out u32 is {
    w: ast.nodes.get i: (wId - 1).u64
    match (
        w
    ) case namedoperation then {
        ul9: zast.nameTextCopy :ast ref: w.name
        if ul9.stringview == unitName then return (enclosingInBody
            :ast
            ud: (ast.nodes.get i: (w.operation - 1).u64)
            :l1u
            :sink
        )
        return 0
    } else {
        return 0
    }
}

enclosingInBody: function {
    ast: Ast
    ud: zast.Node
    l1u: u32
    sink: (Map String value: u8)
} out u32 is {
    match (
        ud
    ) case unitdef then {
        best9: u32
        {
            bit9: ud.body.iterate
            for b9Id: bit9 loop {
                b9IdNode9: ast.nodes.get i: (b9Id - 1).u64
                ln9: memberStartLine m: b9IdNode9
                if ln9 > 0 when ln9 <= l1u then {
                    if ln9 > best9 then best9 = ln9
                }
            }
        }
        if best9 > 0 then {
            bit2: ud.body.iterate
            for b2Id: bit2 loop {
                b2: ast.nodes.get i: (b2Id - 1).u64
                ln2: memberStartLine m: b2
                if ln2 == best9 then addMemberParams :ast m: b2 :sink
            }
        }
        return best9
    } else {
        return 0
    }
}

memberStartLine: function {m: zast.Node} out u32 is {
    match (
        m
    ) case namedoperation then {
        return m.lineno
    } else {
        return 0
    }
}

addMemberParams: function {ast: Ast m: zast.Node sink: (Map String value: u8)} is {
    match (
        m
    ) case namedoperation then {
        addFnParams :ast op: (ast.nodes.get i: (m.operation - 1).u64) :sink
    } else null
}

addFnParams: function {ast: Ast op: zast.Node sink: (Map String value: u8)} is {
    match (
        op
    ) case functiondef then {
        pit9: op.parameters.iterate
        for pm9Id9: pit9 loop {
            pm9: ast.nodes.get i: (pm9Id9 - 1).u64
            addParamLabel :ast pm: pm9 :sink
        }
    } else null
}

addParamLabel: function {ast: Ast pm: zast.Node sink: (Map String value: u8)} is {
    match (
        pm
    ) case namedoperation then {
        pl9: zast.nameTextCopy :ast ref: pm.name
        addCand :sink name: pl9.stringview kind: 6
    } else null
}

# addScopeCompletions -- the enclosing def's params/locals, every loaded
# unit's top-level defs and unit names, and keywords.
addScopeCompletions: function {
    snap: zcheck.CheckResult
    docRel: StringView
    srcDir: StringView
    l1u: u32
    sink: (Map String value: u8)
} is {
    docUnit9: zsource.unitNameOf path: docRel
    defStart9: enclosingDefStart prog: snap.prog unitName: docUnit9.stringview :l1u :sink
    if defStart9 > 0 then {
        sp: (Spans
            rows: (List spanrow)
            names: (List String)
            pos: (Map u64 value: u64)
            ranges: (List rangerow)
            lastPos: 0
        )
        sp.walkProgram prog: snap.prog
        nr9: sp.rows.length
        ri9: u64
        for ri9 < nr9 loop {
            row9: sp.rows.get i: ri9
            if row9.kind == 3 when row9.line >= defStart9 then {
                if row9.line <= l1u then {
                    fs9: zcheck.fsnoFor r: snap nodeid: row9.nodeid
                    pp9: snap.vfs.pathfromprovider dentryid: fs9
                    if (pathMatches pv: pp9.stringview rel: docRel :srcDir) then {
                        nm9: sp.names.get i: ri9
                        addCand :sink name: nm9.stringview kind: 6
                    }
                }
            }
            ri9 = ri9 + 1
        }
    }
    collectTopDefs prog: snap.prog :sink
    addKeywords :sink
}

# addTypeMembers -- a type's fields (kind 5) and methods (kind 2), the
# receiver excluded.
addTypeMembers: function {
    prog: zast.Node
    o: (Option zenv.ZSymbolTable)
    tid: u64
    sink: (Map String value: u8)
} is {
    match (
        o
    ) case some then {
        match (
            prog
        ) case program then {
            addTypeMembersIn :prog :o :tid :sink
        } else null
    } case none then null
}

# addTypeMembersIn -- addTypeMembers with the program narrowed (prog is
# the ProgramData payload).
addTypeMembersIn: function {
    prog: zast.ProgramData
    o: zenv.ZSymbolTable
    tid: u64
    sink: (Map String value: u8)
} is {
    {
        bp9: o.typing.childIndex.get key: tid
        match (
            bp9
        ) case some then {
            with rit9: bp9.rows.iterate do for ri9: rit9 loop {
                tc9: o.typing.typeChild.get i: ri9
                cnB8: prog.ast.names.texts.get i: (tc9.nameId - 1).u64
                cn9: cnB8.stringview
                isRecv9: false
                if tc9.nameId == wkThis then isRecv9 = true
                {
                    zt9: o.reg.typeById.get key: tid
                    match (
                        zt9
                    ) case some then {
                        if (ztypecheck.optStrEquals o: zt9.thisParamName s: cn9) then isRecv9 = true
                    } case none then null
                }
                if (isRecv9) == false then {
                    k9: 5.u8
                    cg9: o.typing.childTypeById.get key: tc9.childNameId
                    match (
                        cg9
                    ) case some then {
                        if (o.reg.typetypeOf typeId: cg9) == ztypes.ztypetype.functionType then k9 = 2
                    } case none then null
                    addCand :sink name: cn9 kind: k9
                }
            }
        } case none then null
    }
}

# addUnitMembers -- the top-level symbols of the file-unit named `name`.
addUnitMembers: function {prog: zast.Node name: StringView sink: (Map String value: u8)} is {
    match (
        prog
    ) case program then {
        uCnt9d: prog.ast.units.length
        uIdx9d: u64
        for uIdx9d < uCnt9d loop {
            u9Id9: prog.ast.units.get i: uIdx9d
            uIdx9d = uIdx9d + 1
            u9: prog.ast.nodes.get i: (u9Id9 - 1).u64
            match (
                u9
            ) case namedoperation then {
                lb9: zast.poolTextCopy pool: prog.ast.names ref: u9.name
                if lb9.stringview == name then (collectUnitDefsIn
                    ast: prog.ast
                    ud: (prog.ast.nodes.get i: (u9.operation - 1).u64)
                    :sink
                )
            } else null
        }
    } else null
}

# baseTypeInScope -- the type id of the local/binding `base` visible in the
# enclosing def (kind-1 use or kind-3 binding rows in scope); 0
# when not found.
baseTypeInScope: function {
    snap: zcheck.CheckResult
    docRel: StringView
    srcDir: StringView
    defStart9: u32
    l1u: u32
    base: StringView
} out u64 is {
    result9: u64
    sp: (Spans
        rows: (List spanrow)
        names: (List String)
        pos: (Map u64 value: u64)
        ranges: (List rangerow)
        lastPos: 0
    )
    sp.walkProgram prog: snap.prog
    nr9: sp.rows.length
    ri9: u64
    for ri9 < nr9 loop {
        row9: sp.rows.get i: ri9
        kindok9: false
        if row9.kind == 3 then kindok9 = true
        if row9.kind == 1 then kindok9 = true
        if kindok9 when row9.line >= defStart9 then {
            if row9.line <= l1u then {
                nm9: sp.names.get i: ri9
                if nm9.stringview == base then {
                    fs9: zcheck.fsnoFor r: snap nodeid: row9.nodeid
                    pp9: snap.vfs.pathfromprovider dentryid: fs9
                    if (pathMatches pv: pp9.stringview rel: docRel :srcDir) then {
                        tt9: nodeTypeAt o: snap.st nid: row9.nodeid.u64
                        if tt9 > 0 then result9 = tt9
                    }
                }
            }
        }
        ri9 = ri9 + 1
    }
    return result9
}

# dotFrom -- index of the first `.` at or after `start` in base, or
# base.length when there is none.
dotFrom: function {base: StringView start: u64} out u64 is {
    n9: base.length
    i9: start
    for i9 < n9 loop {
        b9: base.byteAt i: i9
        match (
            b9
        ) case some then {
            if b9 == 46 then return i9
        } case none then null
        i9 = i9 + 1
    }
    return n9
}

# descendUnitType -- the type id of `unit.name`, resolved (and declared on
# demand) by the compiler's own reference-level resolver, so it works even
# for a type not yet referenced elsewhere in the loaded program.
descendUnitType: function {
    prog: zast.Node
    unitName: StringView
    name: StringView
    o: (Option zenv.ZSymbolTable)
} out u64 is {
    result9: u64
    match (
        o
    ) case some then {
        match (
            prog
        ) case program then {
            result9 = (ztypecheck.descendNamed
                ty: o.typing
                reg: o.reg
                ast: prog.ast
                defUnit: unitName
                :name
            )
        } else null
    } case none then null
    return result9
}

# childOfIn -- the type id of `parent`'s child named `name` (a field, method,
# or a unit's member type), or 0. The compiler's own per-level resolver.
childOfIn: function {
    prog: zast.Node
    o: (Option zenv.ZSymbolTable)
    parent: u64
    name: StringView
} out u64 is {
    result9: u64
    match (
        o
    ) case some then {
        match (
            prog
        ) case program then {
            co9: o.typing.childOf pool: prog.ast.names parentTypeId: parent :name
            match (
                co9
            ) case some then {
                result9 = co9
            } case none then null
        } else null
    } case none then null
    return result9
}

# addMemberCompletions -- members of the base expression before a `.`. A bare
# unit lists its top-level symbols; otherwise the base is resolved one segment
# at a time -- a `unit.Type` head via the compiler's descendNamed (declaring on
# demand), a scope value via baseTypeInScope, each further segment via `childOf`
# -- and the final type's fields/methods are listed.
addMemberCompletions: function {
    snap: zcheck.CheckResult
    docRel: StringView
    srcDir: StringView
    l1u: u32
    base: StringView
    sink: (Map String value: u8)
} is {
    n9: base.length
    d09: dotFrom :base start: 0
    if d09 >= n9 then {
        if (unitFsnoByName :snap name: base) > 0 then {
            addUnitMembers prog: snap.prog name: base :sink
        } else {
            docUnit9: zsource.unitNameOf path: docRel
            throwaway9: (Map String value: u8)
            ds9: (enclosingDefStart
                prog: snap.prog
                unitName: docUnit9.stringview
                :l1u
                sink: throwaway9
            )
            bt9: baseTypeInScope :snap :docRel :srcDir defStart9: ds9 :l1u :base
            if bt9 > 0 then addTypeMembers prog: snap.prog o: snap.st tid: bt9 :sink
        }
        return
    }
    seg09: (base.substring from: 0 to: d09).string
    cur9: u64
    startSeg9: d09 + 1
    if (unitFsnoByName :snap name: seg09.stringview) > 0 then {
        d19: dotFrom :base start: d09 + 1
        seg19: (base.substring from: d09 + 1 to: d19).string
        cur9 = (descendUnitType
            prog: snap.prog
            unitName: seg09.stringview
            name: seg19.stringview
            o: snap.st
        )
        startSeg9 = d19 + 1
    } else {
        docUnit9: zsource.unitNameOf path: docRel
        throwaway9: (Map String value: u8)
        ds9: enclosingDefStart prog: snap.prog unitName: docUnit9.stringview :l1u sink: throwaway9
        cur9 = baseTypeInScope :snap :docRel :srcDir defStart9: ds9 :l1u base: seg09.stringview
    }
    if cur9 == 0 then return
    pos9: startSeg9
    for pos9 <= n9 loop {
        de9: dotFrom :base start: pos9
        seg9: (base.substring from: pos9 to: de9).string
        if seg9.length > 0 then {
            cur9 = childOfIn prog: snap.prog o: snap.st parent: cur9 name: seg9.stringview
            if cur9 == 0 then return
        }
        pos9 = de9 + 1
    }
    addTypeMembers prog: snap.prog o: snap.st tid: cur9 :sink
}

# completionItem -- a completion item object (label + kind, optional detail).
completionItem: function {label: StringView kind: u8 detail: StringView} out Value is {
    it9: newObj
    it9.set key: "label".string value: (Value.text label.string)
    it9.set key: "kind".string value: (Value.intval kind.i64)
    if detail.length > 0 then {
        it9.set key: "detail".string value: (Value.text detail.string)
    }
    return (Value.object it9)
}

# caseArmComplete -- when the cursor sits after `case ` inside a match, append
# the subject variant's remaining arms (sumSubtypeNames minus arms already
# covered by other clauses) to `arr` as EnumMember items. Returns true when it
# handled the completion (a case-arm context), false otherwise.
caseArmComplete: function {
    arr: Arr
    o: (Option zenv.ZSymbolTable)
    prog: zast.Node
    ltv: StringView
    ps9: u64
    prefix: StringView
    cursorPos: u64
} out bool is {
    ws9: ps9
    for ws9 > 0 loop {
        wb9: ltv.byteAt i: ws9 - 1
        stopw9: false
        match (
            wb9
        ) case some then {
            if wb9 != 32 when wb9 != 9 then stopw9 = true
        } case none then {
            stopw9 = true
        }
        if stopw9 then break
        ws9 = ws9 - 1
    }
    if ws9 == ps9 then return false
    wb2: ws9
    for wb2 > 0 loop {
        cb9: ltv.byteAt i: wb2 - 1
        stopc9: false
        match (
            cb9
        ) case some then {
            if (isIdentByte b: cb9) == false then stopc9 = true
        } case none then {
            stopc9 = true
        }
        if stopc9 then break
        wb2 = wb2 - 1
    }
    isCaseKw9: false
    {
        word9: ltv.substring from: wb2 to: ws9
        if word9 == "case" then isCaseKw9 = true
    }
    if (isCaseKw9) == false then return false
    sp9: (Spans
        rows: (List spanrow)
        names: (List String)
        pos: (Map u64 value: u64)
        ranges: (List rangerow)
        lastPos: 0
    )
    sp9.walkProgram :prog
    caseId9: sp9.innerRangeOfKind curPos: cursorPos kind: 5 slack: 1048576
    if caseId9 == 0 then return false
    # caseexpr subject index + clause ids (scoped: one node view at a time)
    subjIdx9: u32
    clauseIds9: (List u64)
    okCase9: false
    match (
        prog
    ) case program then {
        cnode9: prog.ast.nodes.get i: (caseId9 - 1).u64
        match (
            cnode9
        ) case caseexpr then {
            subjIdx9 = cnode9.subject
            with clit9: cnode9.clauses.iterate do for cl9: clit9 loop clauseIds9.append cl9.u64
            okCase9 = true
        } else null
    } else null
    if (okCase9) == false then return false
    if subjIdx9 == 0 then return false
    subjNid9: u32
    match (
        prog
    ) case program then {
        subjNode9: prog.ast.nodes.get i: (subjIdx9 - 1).u64
        subjNid9 = ztypecheck.nodeId n: subjNode9
    } else null
    subjTid9: nodeTypeAt :o nid: subjNid9.u64
    if subjTid9 == 0 then return false
    arms9: (List String)
    gotArms9: false
    match (
        o
    ) case some then {
        match (
            prog
        ) case program then {
            arms9 = ztypecheck.sumSubtypeNames ast: prog.ast st: o sid: subjTid9
            gotArms9 = true
        } else null
    } case none then null
    if (gotArms9) == false then return false
    used9: (List String)
    ui9: u64
    for ui9 < clauseIds9.length loop {
        clId9: clauseIds9.get i: ui9
        maIdx9: u32
        match (
            prog
        ) case program then {
            clNode9: prog.ast.nodes.get i: (clId9 - 1).u64
            match (
                clNode9
            ) case caseclause then {
                maIdx9 = clNode9.matcharm
            } else null
        } else null
        if maIdx9 > 0 then {
            maRef9: u32
            match (
                prog
            ) case program then {
                maNode9: prog.ast.nodes.get i: (maIdx9 - 1).u64
                match (
                    maNode9
                ) case atomid then {
                    maRef9 = maNode9.name
                } case labelvalue then {
                    maRef9 = maNode9.name
                } else null
            } else null
            if maRef9 > 0 then {
                match (
                    prog
                ) case program then {
                    an9: zast.nameTextCopy ast: prog.ast ref: maRef9
                    if an9.length > 0 then used9.append an9
                } else null
            }
        }
        ui9 = ui9 + 1
    }
    with ait9: arms9.iterate do for arm9: ait9 loop {
        skip9: false
        with uit9: used9.iterate do for u9: uit9 loop {
            if u9.stringview == arm9.stringview then skip9 = true
        }
        matchp9: true
        if prefix.length > 0 then {
            if (arm9.startsWith prefix) == false then matchp9 = false
        }
        if skip9 == false when matchp9 then {
            arr.items.append (completionItem label: arm9.stringview kind: 20 detail: "")
        }
    }
    return true
}

# resolveCalleeFuncId -- a callable/leaf node id -> its function tid: nodeType
# carries a method callable's fn tid, useUnitDef a free function's; anything that
# does not name a function type yields 0.
resolveCalleeFuncId: function {o: (Option zenv.ZSymbolTable) nid: u64} out u64 is {
    ftid9: nodeTypeAt :o :nid
    udx9: useUnitDef :o :nid
    if udx9 > 0 then ftid9 = udx9
    if ftid9 == 0 then return 0
    result9: u64
    match (
        o
    ) case some then {
        tt9: o.reg.typetypeOf typeId: ftid9
        match (
            tt9
        ) case functionType then {
            result9 = ftid9
        } else null
    } case none then null
    return result9
}

# leafFuncIdAt -- the innermost leaf span at (line1u, idCol) resolved to a
# function tid, preferring a kind-2 member row so a dotted method's callable
# resolves; 0 when nothing there names a function. Shared by the bare-name
# arg-label lookup and signature help.
leafFuncIdAt: function {
    snap: zcheck.CheckResult
    o: (Option zenv.ZSymbolTable)
    sp: Spans
    docRel: StringView
    srcDir: StringView
    line1u: u32
    idCol: u32
} out u64 is {
    leafNid9: u32
    bk9: u8
    found9: false
    rix9: u64
    for rix9 < sp.rows.length loop {
        row9: sp.rows.get i: rix9
        if row9.line == line1u when row9.colLo <= idCol then {
            if idCol < row9.colHi then {
                fs9: zcheck.fsnoFor r: snap nodeid: row9.nodeid
                pp9: snap.vfs.pathfromprovider dentryid: fs9
                if (pathMatches pv: pp9.stringview rel: docRel :srcDir) then {
                    take9: false
                    if (found9) == false then take9 = true
                    if row9.kind == 2 when bk9 != 2 then take9 = true
                    if take9 then {
                        leafNid9 = row9.nodeid
                        bk9 = row9.kind
                        found9 = true
                    }
                }
            }
        }
        rix9 = rix9 + 1
    }
    if (found9) == false then return 0
    return (resolveCalleeFuncId :o nid: leafNid9.u64)
}

# bareCalleeFuncId9 -- a lone function/method name with no label yet parses as
# an atom/dotted-path, not a call node, so the arg-label path has nothing to sit
# inside. Resolve the identifier just before the trailing whitespace via the
# same leaf-span + def recipe navAnswer uses; a function/method type yields its
# function id, anything else (a value arg, a keyword, an unresolved leaf) 0.
bareCalleeFuncId9: function {
    o: (Option zenv.ZSymbolTable)
    ltv: StringView
    ws9: u64
    cursorPos: u64
    sp: Spans
} out u64 is {
    is9: ws9
    for is9 > 0 loop {
        ib9: ltv.byteAt i: is9 - 1
        stopid9: false
        match (
            ib9
        ) case some then {
            if (isIdentByte b: ib9) == false then stopid9 = true
        } case none then {
            stopid9 = true
        }
        if stopid9 then break
        is9 = is9 - 1
    }
    if is9 == ws9 then return 0
    sub9: ltv.substring from: 0 to: is9
    cc9: sub9.count
    idCol9: cc9.u32.orPanic + 1
    l1u9: (cursorPos / 1048576).u32.orPanic
    leafNid9: u32
    bk9: u8
    found9: false
    rix9: u64
    for rix9 < sp.rows.length loop {
        row9: sp.rows.get i: rix9
        if row9.line == l1u9 when row9.colLo <= idCol9 then {
            if idCol9 < row9.colHi then {
                take9: false
                if (found9) == false then take9 = true
                if row9.kind == 2 when bk9 != 2 then take9 = true
                if take9 then {
                    leafNid9 = row9.nodeid
                    bk9 = row9.kind
                    found9 = true
                }
            }
        }
        rix9 = rix9 + 1
    }
    if (found9) == false then return 0
    return (resolveCalleeFuncId :o nid: leafNid9.u64)
}

# emitLabels -- append `funcId9`'s parameter labels (minus the receiver and any
# already-supplied labels) to `arr` as kind-5 items with a type[+ownership]
# detail. Shared by the bare-name and call-node arg-label paths. Returns true
# when it emitted a label context (the callee has non-receiver params).
emitLabels: function {
    arr: Arr
    o: (Option zenv.ZSymbolTable)
    prog: zast.Node
    funcId9: u64
    supplied9: (List String)
    prefix: StringView
} out bool is {
    # callee params (skip receiver) collected while the childIndex view is held
    pnames9: (List String)
    pcnids9: (List u64)
    pptids9: (List u64)
    match (
        prog
    ) case program then {
        match (
            o
        ) case some then {
            bp9: o.typing.childIndex.get key: funcId9
            match (
                bp9
            ) case some then {
                with rpit9: bp9.rows.iterate do for rpi9: rpit9 loop {
                    tc9: o.typing.typeChild.get i: rpi9
                    cnB9: prog.ast.names.texts.get i: (tc9.nameId - 1).u64
                    cn9: cnB9.stringview
                    isRecv9: false
                    if tc9.nameId == wkThis then isRecv9 = true
                    zt9: o.reg.typeById.get key: funcId9
                    match (
                        zt9
                    ) case some then {
                        if (ztypecheck.optStrEquals o: zt9.thisParamName s: cn9) then isRecv9 = true
                    } case none then null
                    if (isRecv9) == false then {
                        ctid9: u64
                        cg9: o.typing.childTypeById.get key: tc9.childNameId
                        match (
                            cg9
                        ) case some then {
                            ctid9 = cg9
                        } case none then null
                        pnames9.append cn9.string
                        pcnids9.append tc9.childNameId
                        pptids9.append ctid9
                    }
                }
            } case none then null
        } case none then null
    } else null
    if pnames9.length == 0 then return false
    ri9: u64
    for ri9 < pnames9.length loop {
        pn9: pnames9.get i: ri9
        isSupp9: false
        with sit9: supplied9.iterate do for su9: sit9 loop {
            if su9.stringview == pn9.stringview then isSupp9 = true
        }
        matchp9: true
        if prefix.length > 0 then {
            if (pn9.startsWith prefix) == false then matchp9 = false
        }
        if isSupp9 == false when matchp9 then {
            det9: String
            match (
                o
            ) case some then {
                tn9: displayTypeNameSt st: o tid: (pptids9.get i: ri9)
                det9.append tn9.stringview
                oo9: o.typing.childOwnership.get key: (pcnids9.get i: ri9)
                match (
                    oo9
                ) case some then {
                    if oo9 == ztypes.zparamownership.takeMode then det9.append ".take"
                    if oo9 == ztypes.zparamownership.lockMode then det9.append ".lock"
                } case none then null
            } case none then null
            arr.items.append (completionItem label: pn9.stringview kind: 5 detail: det9.stringview)
        }
        ri9 = ri9 + 1
    }
    return true
}

# argLabelComplete -- when the cursor sits at a fresh argument position inside a
# call (not after `:` or `.`), append the callee's remaining parameter labels
# (minus the receiver and the labels already supplied) to `arr`, with a
# type[+ownership] detail. Returns true when it handled a call-arg-label context.
argLabelComplete: function {
    arr: Arr
    o: (Option zenv.ZSymbolTable)
    prog: zast.Node
    ltv: StringView
    ps9: u64
    prefix: StringView
    cursorPos: u64
} out bool is {
    ws9: ps9
    for ws9 > 0 loop {
        wb9: ltv.byteAt i: ws9 - 1
        stopw9: false
        match (
            wb9
        ) case some then {
            if wb9 != 32 when wb9 != 9 then stopw9 = true
        } case none then {
            stopw9 = true
        }
        if stopw9 then break
        ws9 = ws9 - 1
    }
    if ws9 == 0 then return false
    pvb9: ltv.byteAt i: ws9 - 1
    badPos9: false
    match (
        pvb9
    ) case some then {
        if pvb9 == 58 then badPos9 = true
        if pvb9 == 46 then badPos9 = true
    } case none then null
    if badPos9 then return false
    sp9: (Spans
        rows: (List spanrow)
        names: (List String)
        pos: (Map u64 value: u64)
        ranges: (List rangerow)
        lastPos: 0
    )
    sp9.walkProgram :prog
    callId9: sp9.innerRangeOfKind curPos: cursorPos kind: 4 slack: 1048576
    supplied9: (List String)
    # a bare function/method name (no label yet) has no call node; on a fresh
    # arg position (empty prefix) resolve the identifier just before the cursor
    # and, when it names a function/method, offer its labels. Gated to the
    # empty-prefix case so typing a value still falls through to scope
    # completion; given priority since a slack-matched call node may be nearby.
    if prefix.length == 0 then {
        bfid9: bareCalleeFuncId9 :o :ltv :ws9 :cursorPos sp: sp9
        if bfid9 > 0 then {
            empty9: (List String)
            return (emitLabels :arr :o :prog funcId9: bfid9 supplied9: empty9 :prefix)
        }
    }
    if callId9 == 0 then return false
    # callable index + supplied argument node ids (scoped: one node view)
    callableIdx9: u32
    argIds9: (List u64)
    okCall9: false
    match (
        prog
    ) case program then {
        cnode9: prog.ast.nodes.get i: (callId9 - 1).u64
        match (
            cnode9
        ) case call then {
            callableIdx9 = cnode9.callable
            with aiter9: cnode9.arguments.iterate do for aid9: aiter9 loop argIds9.append aid9.u64
            okCall9 = true
        } else null
    } else null
    if (okCall9) == false then return false
    if callableIdx9 == 0 then return false
    # callee function id (callable node -> nodeId -> useUnitDef)
    calNid9: u32
    match (
        prog
    ) case program then {
        caln9: prog.ast.nodes.get i: (callableIdx9 - 1).u64
        calNid9 = ztypecheck.nodeId n: caln9
    } else null
    funcId9: resolveCalleeFuncId :o nid: calNid9.u64
    if funcId9 == 0 then return false
    # supplied labels (each arg -> namedoperation.name ref -> text)
    si9: u64
    for si9 < argIds9.length loop {
        aid9: argIds9.get i: si9
        nameRef9: u32
        match (
            prog
        ) case program then {
            anode9: prog.ast.nodes.get i: (aid9 - 1).u64
            match (
                anode9
            ) case namedoperation then {
                nameRef9 = anode9.name
            } else null
        } else null
        if nameRef9 > 0 then {
            match (
                prog
            ) case program then {
                lbl9: zast.nameTextCopy ast: prog.ast ref: nameRef9
                if lbl9.length > 0 then supplied9.append lbl9
            } else null
        }
        si9 = si9 + 1
    }
    return (emitLabels :arr :o :prog :funcId9 :supplied9 :prefix)
}

# signatureHelpAnswer -- a mid-typing signature popup. A call being typed often
# fails to parse (a trailing label -> "Expected an Operation after label") and is
# absent from the last-good snapshot tree, so locate the enclosing call by a
# paren-depth-aware backward scan of the live buffer (a call spans lines only
# inside parens; a nested call argument is always parenthesised, so the innermost
# unmatched "(" bounds it), resolve the callee against the snapshot, and render
# its signature with the active parameter (the label nearest the cursor). Returns
# a SignatureHelp object, or null when the cursor is not inside a resolvable call.
signatureHelpAnswer: function {
    snap: zcheck.CheckResult
    docRel: StringView
    srcDir: StringView
    docText: StringView
    line0: i64
    ch: i64
    utf32: bool
} out Value is {
    l1: line0 + 1
    l1u: l1.u32.orPanic
    curLt: docLine text: docText lineno: l1u
    cp1: cpColOf lineText: curLt.stringview :ch :utf32
    curByte9: byteIdxOfCp s: curLt.stringview :cp1
    # scan backward for the operation head: the innermost unmatched "(" (an
    # enclosing, possibly multi-line, call) wins; otherwise the nearest statement
    # start (a line begun outside parens) once a block boundary or the buffer top
    # is reached. Newlines are NOT hard stops -- a call spans lines inside parens.
    pd9: i64
    headLine9: l1u
    headByte9: u64
    stmtLine9: l1u
    stmtByte9: u64
    haveStmt9: false
    stop9: false
    scanLine9: l1u
    scanText9: curLt.copy
    scanEnd9: curByte9
    for stop9 == false loop {
        {
            stv9: scanText9.stringview
            i9: scanEnd9
            for i9 > 0 loop {
                bb9: stv9.byteAt i: i9 - 1
                match (
                    bb9
                ) case some then {
                    if bb9 == 41 then pd9 = pd9 + 1
                    if bb9 == 40 then {
                        if pd9 > 0 then {
                            pd9 = pd9 - 1
                        } else {
                            headLine9 = scanLine9
                            headByte9 = i9
                            stop9 = true
                        }
                    }
                    if bb9 == 123 when pd9 == 0 then {
                        if haveStmt9 then {
                            headLine9 = stmtLine9
                            headByte9 = stmtByte9
                        } else {
                            headLine9 = scanLine9
                            headByte9 = i9
                        }
                        stop9 = true
                    }
                    if bb9 == 125 when pd9 == 0 then {
                        if haveStmt9 then {
                            headLine9 = stmtLine9
                            headByte9 = stmtByte9
                        } else {
                            headLine9 = scanLine9
                            headByte9 = i9
                        }
                        stop9 = true
                    }
                } case none then null
                if stop9 then break
                i9 = i9 - 1
            }
        }
        if stop9 then break
        if pd9 == 0 when haveStmt9 == false then {
            stmtLine9 = scanLine9
            stmtByte9 = 0
            haveStmt9 = true
        }
        if scanLine9 <= 1 then {
            if haveStmt9 then {
                headLine9 = stmtLine9
                headByte9 = stmtByte9
            } else {
                headLine9 = 1
                headByte9 = 0
            }
            stop9 = true
        } else {
            scanLine9 = scanLine9 - 1
            scanText9 = docLine text: docText lineno: scanLine9
            scanEnd9 = scanText9.length
        }
    }
    headLt9: docLine text: docText lineno: headLine9
    hstv9: headLt9.stringview
    hlen9: hstv9.length
    j9: headByte9
    for j9 < hlen9 loop {
        wb9: hstv9.byteAt i: j9
        stopw9: false
        match (
            wb9
        ) case some then {
            if wb9 != 32 when wb9 != 9 then stopw9 = true
        } case none then {
            stopw9 = true
        }
        if stopw9 then break
        j9 = j9 + 1
    }
    ids9: j9
    for j9 < hlen9 loop {
        ib9: hstv9.byteAt i: j9
        stopi9: false
        match (
            ib9
        ) case some then {
            if (isIdentByte b: ib9) == false then stopi9 = true
        } case none then {
            stopi9 = true
        }
        if stopi9 then break
        j9 = j9 + 1
    }
    isBind9: false
    {
        cb9: hstv9.byteAt i: j9
        match (
            cb9
        ) case some then {
            if cb9 == 58 then isBind9 = true
        } case none then null
    }
    if isBind9 then {
        j9 = j9 + 1
        for j9 < hlen9 loop {
            wb2: hstv9.byteAt i: j9
            stopw2: false
            match (
                wb2
            ) case some then {
                if wb2 != 32 when wb2 != 9 then stopw2 = true
            } case none then {
                stopw2 = true
            }
            if stopw2 then break
            j9 = j9 + 1
        }
        ids9 = j9
        for j9 < hlen9 loop {
            ib2: hstv9.byteAt i: j9
            stopi2: false
            match (
                ib2
            ) case some then {
                if (isIdentByte b: ib2) == false then stopi2 = true
            } case none then {
                stopi2 = true
            }
            if stopi2 then break
            j9 = j9 + 1
        }
    }
    if j9 == ids9 then return Value.nul
    segStart9: ids9
    for true loop {
        db9: hstv9.byteAt i: j9
        isDot9: false
        match (
            db9
        ) case some then {
            if db9 == 46 then isDot9 = true
        } case none then null
        if (isDot9) == false then break
        j9 = j9 + 1
        segStart9 = j9
        for j9 < hlen9 loop {
            ib3: hstv9.byteAt i: j9
            stopi3: false
            match (
                ib3
            ) case some then {
                if (isIdentByte b: ib3) == false then stopi3 = true
            } case none then {
                stopi3 = true
            }
            if stopi3 then break
            j9 = j9 + 1
        }
    }
    calleeEnd9: j9
    activeLabel9: String
    {
        lowb9: u64
        if headLine9 == l1u then lowb9 = calleeEnd9
        alstv9: curLt.stringview
        k9: curByte9
        apd9: i64
        albreak9: false
        for k9 > lowb9 loop {
            ab9: alstv9.byteAt i: k9 - 1
            match (
                ab9
            ) case some then {
                if ab9 == 41 then apd9 = apd9 + 1
                if ab9 == 40 when apd9 > 0 then apd9 = apd9 - 1
                if ab9 == 58 when apd9 == 0 then {
                    le9: k9 - 1
                    ls9: le9
                    for ls9 > lowb9 loop {
                        lb9: alstv9.byteAt i: ls9 - 1
                        stopl9: false
                        match (
                            lb9
                        ) case some then {
                            if (isIdentByte b: lb9) == false then stopl9 = true
                        } case none then {
                            stopl9 = true
                        }
                        if stopl9 then break
                        ls9 = ls9 - 1
                    }
                    if ls9 < le9 then {
                        activeLabel9 = (alstv9.substring from: ls9 to: le9).string
                        albreak9 = true
                    }
                }
            } case none then null
            if albreak9 then break
            k9 = k9 - 1
        }
    }
    nmS9: (hstv9.substring from: segStart9 to: calleeEnd9).string
    segCp9: u64
    {
        hsub9: hstv9.substring from: 0 to: segStart9
        segCp9 = hsub9.count
    }
    idCol9: segCp9.u32.orPanic + 1
    sp9: (Spans
        rows: (List spanrow)
        names: (List String)
        pos: (Map u64 value: u64)
        ranges: (List rangerow)
        lastPos: 0
    )
    sp9.walkProgram prog: snap.prog
    funcId9: leafFuncIdAt :snap o: snap.st sp: sp9 :docRel :srcDir line1u: headLine9 idCol: idCol9
    if funcId9 == 0 then return Value.nul
    label9: fnSigTextOpt vfs: snap.vfs prog: snap.prog o: snap.st tid: funcId9 name: nmS9.stringview
    if label9.length == 0 then return Value.nul
    pdisps9: fnParamDisplays prog: snap.prog o: snap.st tid: funcId9
    params9: newArr
    activeIdx9: i64
    foundActive9: false
    pi9: u64
    for pi9 < pdisps9.length loop {
        pds9: pdisps9.get i: pi9
        pdv9: pds9.stringview
        colon9: u64
        hasColon9: false
        ci9: u64
        for ci9 < pdv9.length loop {
            cbb9: pdv9.byteAt i: ci9
            match (
                cbb9
            ) case some then {
                if cbb9 == 58 when hasColon9 == false then {
                    colon9 = ci9
                    hasColon9 = true
                }
            } case none then null
            ci9 = ci9 + 1
        }
        pnm9: pdv9
        if hasColon9 then pnm9 = pdv9.substring from: 0 to: colon9
        if foundActive9 == false when activeLabel9.length > 0 then {
            if pnm9 == activeLabel9.stringview then {
                activeIdx9 = pi9.i64.orPanic
                foundActive9 = true
            }
        }
        pobj9: newObj
        pobj9.set key: "label".string value: (Value.text pdv9.string)
        params9.items.append (Value.object pobj9)
        pi9 = pi9 + 1
    }
    siginfo9: newObj
    siginfo9.set key: "label".string value: (Value.text label9)
    siginfo9.set key: "parameters".string value: (Value.array params9)
    siginfo9.set key: "activeParameter".string value: (Value.intval activeIdx9)
    sigs9: newArr
    sigs9.items.append (Value.object siginfo9)
    root9: newObj
    root9.set key: "signatures".string value: (Value.array sigs9)
    root9.set key: "activeSignature".string value: (Value.intval 0)
    root9.set key: "activeParameter".string value: (Value.intval activeIdx9)
    return (Value.object root9)
}

# completionAnswer -- scope-based completion from the last-good
# snapshot: the enclosing definition's params and preceding bindings,
# every loaded unit's top-level defs and unit names, and keywords --
# filtered by the identifier prefix on the LIVE line. A '.' before the
# prefix is member position -> the base's members.
completionAnswer: function {
    snap: zcheck.CheckResult
    docRel: StringView
    srcDir: StringView
    docText: StringView
    line0: i64
    ch: i64
    utf32: bool
    trig: StringView
} out Value is {
    arr: newArr
    l1: line0 + 1
    l1u: l1.u32.orPanic
    lt: docLine text: docText lineno: l1u
    ltv: lt.stringview
    cp1: cpColOf lineText: ltv :ch :utf32
    cur9: byteIdxOfCp s: ltv :cp1
    # identifier prefix ending at the cursor
    ps9: cur9
    for ps9 > 0 loop {
        b9: ltv.byteAt i: ps9 - 1
        match (
            b9
        ) case some then {
            if (isIdentByte b: b9) == false then break
        } case none then {
            break
        }
        ps9 = ps9 - 1
    }
    cands: (Map String value: u8)
    memberMode9: false
    # member position: a '.' before the prefix -> complete the base's members
    if ps9 > 0 then {
        pb9: ltv.byteAt i: ps9 - 1
        match (
            pb9
        ) case some then {
            if pb9 == 46 then {
                memberMode9 = true
                be9: ps9 - 1
                bs9: be9
                for bs9 > 0 loop {
                    bb9: ltv.byteAt i: bs9 - 1
                    match (
                        bb9
                    ) case some then {
                        if (isIdentByte b: bb9) == false when bb9 != 46 then break
                    } case none then {
                        break
                    }
                    bs9 = bs9 - 1
                }
                base9: (ltv.substring from: bs9 to: be9).string
                (addMemberCompletions
                    :snap
                    :docRel
                    :srcDir
                    :l1u
                    base: base9.stringview
                    sink: cands
                )
            }
        } case none then null
    }
    prefix9: (ltv.substring from: ps9 to: cur9).string

    if (memberMode9) == false then {
        curPos9: (l1u.u64 * 1048576) + cp1.u64
        handledCA9: (caseArmComplete
            :arr
            o: snap.st
            prog: snap.prog
            :ltv
            :ps9
            prefix: prefix9.stringview
            cursorPos: curPos9
        )
        if handledCA9 then return (Value.array arr)
        handledAL9: (argLabelComplete
            :arr
            o: snap.st
            prog: snap.prog
            :ltv
            :ps9
            prefix: prefix9.stringview
            cursorPos: curPos9
        )
        if handledAL9 then return (Value.array arr)
        if trig == " " then return (Value.array arr)
        addScopeCompletions :snap :docRel :srcDir :l1u sink: cands
    }

    labels9: (List String)
    with cit9: cands.iterateItems do for ce9: cit9 loop {
        pv9: prefix9.stringview
        if pv9.length == 0 then {
            lc9: ce9.key.copy
            labels9.append lc9
        } else {
            kv9: ce9.key.stringview
            if kv9.startsWith pv9 then {
                lc2: ce9.key.copy
                labels9.append lc2
            }
        }
    }
    labels9.sort
    li9: u64
    ln9: labels9.length
    for li9 < ln9 loop {
        lb9: labels9.get i: li9
        kv2: lb9.copy
        ko9: cands.get key: kv2
        kind9: 6.u8
        match (
            ko9
        ) case some then {
            kind9 = ko9
        } case none then null
        it9: newObj
        it9.set key: "label".string value: (Value.text lb9.copy)
        it9.set key: "kind".string value: (Value.intval kind9.i64)
        arr.items.append (Value.object it9)
        li9 = li9 + 1
    }
    return (Value.array arr)
}

# ---- main ------------------------------------------------------------

# DEBOUNCE_MS -- interactive recheck coalescing window. A burst of edits
# within this window collapses to one recheck; ~100 ms clears typical
# inter-keystroke gaps while staying under the perception threshold.
DEBOUNCE_MS: 100.i32

serve: function {srv: Server} is {
    for srv.running loop {
        mo: srv.readMessage
        match (
            mo
        ) case some then {
            pr: json.parse source: mo.stringview
            match (
                pr
            ) case ok then {
                srv.handleMessage msg: pr
            } case err then {
                io.eprintln "zls: bad JSON payload"
            }
            if srv.debounce when srv.hasDirty then {
                if (srv.inputQuiet millis: DEBOUNCE_MS) then srv.flushDirty
            }
        } case none then {
            if srv.debounce when srv.hasDirty then srv.flushDirty
            srv.running = false
        }
    }
}

printUsage: function is {
    io.eprintln "usage: zls [--stdio] [--replay <file>] [--listen <port>]"
    io.eprintln "           [--src <dir>] [--system <dir>]"
}

main: function is {
    argv: os.args
    n: argv.length
    replay: String
    listenArg: String
    srcFlag: String
    sysFlag: String
    i: 1.u64
    for i < n loop {
        arg: (argv.get :i).copy
        av: arg.stringview
        if av == "--stdio" then {
        } else if av == "--replay" then {
            if (i + 1) < n then {
                i = i + 1
                replay = (argv.get :i).copy
            }
        } else if av == "--src" then {
            if (i + 1) < n then {
                i = i + 1
                srcFlag = (argv.get :i).copy
            }
        } else if av == "--system" then {
            if (i + 1) < n then {
                i = i + 1
                sysFlag = (argv.get :i).copy
            }
        } else if av == "--listen" then {
            if (i + 1) < n then {
                i = i + 1
                listenArg = (argv.get :i).copy
            }
        } else if av == "--help" then {
            printUsage
            os.exit code: 0
        } else {
            io.eprintln "zls: unknown argument"
            printUsage
            os.exit code: 2
        }
        i = i + 1
    }
    ib: Bytes
    srv: (Server
        docs: (Map String value: Document)
        srcDir: "".string
        systemDir: "".string
        :srcFlag
        :sysFlag
        encUtf32: false
        initialized: false
        shutdownReq: false
        running: true
        exitCode: 0
        inbuf: ib
        inpos: 0
        transport: (Transport.stdio)
        debounce: true
        dirty: (Map String value: bool)
        snapshots: (Map String value: zcheck.CheckResult)
    )
    if listenArg.length > 0 then {
        pr9: listenArg.stringview.parseU64
        match (
            pr9
        ) case ok then {
            if pr9 > 65535 then {
                io.eprintln "zls: --listen port out of range (0-65535)"
                os.exit code: 2
            }
            port9: pr9.u16.orPanic
            lo9: net.listen port: port9
            match (
                lo9
            ) case ok then {
                ao9: lo9.accept
                match (
                    ao9
                ) case ok then {
                    srv.transport = (Transport.tcp ao9)
                    serve :srv
                } case err then {
                    io.eprintln "zls: accept failed"
                    os.exit code: 3
                }
            } case err then {
                io.eprintln "zls: listen failed"
                os.exit code: 3
            }
        } case err then {
            io.eprintln "zls: --listen expects a port number"
            os.exit code: 2
        }
    } else if replay.length > 0 then {
        fo: io.open path: replay.stringview mode: io.openmode.read
        match (
            fo
        ) case ok then {
            srv.transport = (Transport.replay fo)
            srv.debounce = false
            serve :srv
        } case err then {
            io.eprintln "zls: cannot open replay file"
            os.exit code: 2
        }
    } else {
        serve :srv
    }
    os.exit code: srv.exitCode
}

# zgenerator.z -- generator-function lowering.
#
# Mirrors src/zgenerator.py: a generator is a function whose body contains
# a yield and whose declared return type resolves to the stdlib Iterator
# protocol (the caller decides that by resolved type id). Lowering turns it
# into a synthesized iterator class -- `state` cursor plus captured fields,
# a `create` forwarding to meta.create, and a `call` method holding the
# original body (yields stay intact; the state machine is the emitter's
# job) -- and rebinds the original function to a factory returning the
# class. Validation failures skip the lowering (the reference also reports
# errors; this port gates only -- the differential corpus is all-valid).

Node: zast.Node

# The lowering's synth-node id space: above every parsed id, below the
# typechecker's hoist-temp space (0x40000000), so ast_nodes ids never
# collide across the three sources.
GenIds: class {
    nextId: u32
} as {
    mint: function {:this} out u32 is {
        id: this.nextId
        this.nextId = this.nextId + 1
        return id
    }
}

newGenIds: function {} out GenIds is {
    return (GenIds nextId: 0x20000000)
}

# One lowered generator: the factory that replaces the original function
# definition, the synth class to append to the unit body, and the synth
# `.call` return wrapper-EXPRESSION's nodeid (the pendingMono key; the
# typechecker collapses that wrapper to optionval for valtype elements).
GenLowered: class {
    factory: Node
    synthClass: Node
    wrapperNodeId: u32
    noStamp: (List u32)
    # inner dotted nodes of receiver-lock field spines: each stamps the
    # receiver type through the deferred typeref pass (the reference's
    # marker-path stamps cover them).
    innerRefs: (List u32)
}

# innerDpId -- the parent dotted node's id of a two-level marker path
# (`Bag.private.lock` -> the `Bag.private` node); 0 otherwise.
innerDpId: function {n: Node} out u32 is {
    match (
        n
    ) case dottedpath then {
        return (dpNodeId n: n.parent)
    } else {
        return 0
    }
}

dpNodeId: function {n: Node} out u32 is {
    match (
        n
    ) case dottedpath then {
        return n.nodeid
    } else {
        return 0
    }
}

# topNodeId -- a cloned type-path's top node id (the typeref-stamp key the
# resolution records); 0 for unhandled shapes.
topNodeId: function {n: Node} out u32 is {
    match (
        n
    ) case atomid then {
        return n.nodeid
    } case labelvalue then {
        return n.nodeid
    } case dottedpath then {
        return n.nodeid
    } case expression then {
        return n.nodeid
    } case call then {
        return n.nodeid
    } else {
        return 0
    }
}

paramOpId: function {n: Node} out u32 is {
    match (
        n
    ) case namedoperation then {
        return (topNodeId n: n.operation)
    } else {
        return 0
    }
}

# bodyContainsYield -- a yield anywhere in this subtree, not descending
# into nested function literals (their yields belong to that function).
bodyContainsYield: function {n: Node} out bool is {
    match (
        n
    ) case yieldexpr then {
        return true
    } case functiondef then {
        return false
    } case statement then {
        siter: n.statements.iterate
        for s0: siter loop {
            if (bodyContainsYield n: s0) then return true
        }
        return false
    } case statementline then {
        return (bodyContainsYield n: n.statementline)
    } case expression then {
        return (bodyContainsYield n: n.expression)
    } case assignment then {
        return (bodyContainsYield n: n.value)
    } case reassignment then {
        return (bodyContainsYield n: n.value)
    } case ifexpr then {
        cliter: n.clauses.iterate
        for cl0: cliter loop {
            if (bodyContainsYield n: cl0) then return true
        }
        return (bodyContainsYieldOpt o: n.elseclause)
    } case ifclause then {
        coiter: n.conditions.iterate
        for c0: coiter loop {
            if (bodyContainsYield n: c0) then return true
        }
        return (bodyContainsYield n: n.statement)
    } case forexpr then {
        fiter: n.conditions.iterate
        for f0: fiter loop {
            if (bodyContainsYield n: f0) then return true
        }
        if (bodyContainsYieldOpt o: n.body) then return true
        piter: n.postconditions.iterate
        for p0: piter loop {
            if (bodyContainsYield n: p0) then return true
        }
        return false
    } case doexpr then {
        return (bodyContainsYield n: n.statement)
    } case withexpr then {
        if (bodyContainsYield n: n.value) then return true
        return (bodyContainsYield n: n.body)
    } case caseexpr then {
        if (bodyContainsYield n: n.subject) then return true
        mliter: n.clauses.iterate
        for m0: mliter loop {
            if (bodyContainsYield n: m0) then return true
        }
        return (bodyContainsYieldOpt o: n.elseclause)
    } case caseclause then {
        return (bodyContainsYield n: n.statement)
    } case namedoperation then {
        return (bodyContainsYield n: n.operation)
    } case call then {
        if (bodyContainsYield n: n.callable) then return true
        aiter: n.arguments.iterate
        for a0: aiter loop {
            if (bodyContainsYield n: a0) then return true
        }
        return false
    } case binop then {
        if (bodyContainsYield n: n.lhs) then return true
        return (bodyContainsYield n: n.rhs)
    } else {
        return false
    }
}

bodyContainsYieldOpt: function {o: Option Node} out bool is {
    match (
        o
    ) case some then {
        return (bodyContainsYield n: o)
    } case none then {
        return false
    }
}

# fnBodyHasYield -- the cheap structural generator pre-test on a
# functiondef Node (spec/native bodies are never generators).
fnBodyHasYield: function {n: Node} out bool is {
    match (
        n
    ) case functiondef then {
        return (bodyContainsYieldOpt o: n.body)
    } else {
        return false
    }
}

# leafAtomName -- an atom's name (owned copy); "" for other shapes.
leafAtomName: function {n: Node} out String is {
    match (
        n
    ) case atomid then {
        nv: n.name.stringview
        nc: nv.string
        return nc
    } else {
        return "".string
    }
}

# returnHeadName -- the callable head atom of a parenthesized return-type
# call (`out (Iterator gives: i64)` -> "Iterator"); "" for other shapes.
returnHeadName: function {n: Node} out String is {
    match (
        n
    ) case functiondef then {
        return (returnHeadOpt o: n.returntype)
    } else {
        return "".string
    }
}

returnHeadOpt: function {o: Option Node} out String is {
    match (
        o
    ) case some then {
        return (returnHeadOf n: o)
    } case none then {
        return "".string
    }
}

returnHeadOf: function {n: Node} out String is {
    match (
        n
    ) case expression then {
        return (returnHeadOf n: n.expression)
    } case call then {
        return (leafAtomName n: n.callable)
    } else {
        return "".string
    }
}

# pathLeafName -- the take/lock/borrow ownership leaf on a dotted path,
# "" when none.
pathLeafName: function {n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        ln: leafAtomName n: n.child
        if ln.stringview == "take" then return ln
        if ln.stringview == "lock" then return ln
        if ln.stringview == "borrow" then return ln
        return "".string
    } else {
        return "".string
    }
}

# clonePath -- deep-copy a type-path subtree (atom / labelvalue / dotted /
# expression / call / namedoperation shapes), minting fresh nodeids. The
# synth wrapper and field types embed clones because a node owns exactly
# one parent.
clonePath: function {ids: GenIds n: Node} out Node is {
    match (
        n
    ) case atomid then {
        ln0: n.lineno
        co0: n.colno
        nmv: n.name.stringview
        nm0: nmv.string
        return (Node.atomid (zast.AtomIdData nodeid: ids.mint lineno: ln0 colno: co0 name: nm0))
    } case labelvalue then {
        ln1: n.lineno
        co1: n.colno
        lmv: n.name.stringview
        lm0: lmv.string
        return (Node.labelvalue (zast.LabelValueData
            nodeid: ids.mint
            lineno: ln1
            colno: co1
            name: lm0)
        )
    } case dottedpath then {
        ln2: n.lineno
        co2: n.colno
        np: clonePath :ids n: n.parent
        nc: clonePath :ids n: n.child
        return (Node.dottedpath (zast.DottedPathData
            nodeid: ids.mint
            lineno: ln2
            colno: co2
            parent: np
            child: nc)
        )
    } case expression then {
        ln3: n.lineno
        co3: n.colno
        ne: clonePath :ids n: n.expression
        return (Node.expression (zast.ExpressionData
            nodeid: ids.mint
            lineno: ln3
            colno: co3
            expression: ne)
        )
    } case call then {
        ln4: n.lineno
        co4: n.colno
        ncal: clonePath :ids n: n.callable
        nargs: (List Node)
        aiter: n.arguments.iterate
        for a0: aiter loop {
            na0: clonePath :ids n: a0
            nargs.append na0
        }
        return (Node.call (zast.CallData
            nodeid: ids.mint
            lineno: ln4
            colno: co4
            callable: ncal
            arguments: nargs)
        )
    } case namedoperation then {
        ln5: n.lineno
        co5: n.colno
        nop: clonePath :ids n: n.operation
        nnm: cloneOptString o: n.name
        return (Node.namedoperation (zast.NamedOperationData
            nodeid: ids.mint
            lineno: ln5
            colno: co5
            name: nnm
            operation: nop)
        )
    } case binop then {
        ln6: n.lineno
        co6: n.colno
        nl6: clonePath :ids n: n.lhs
        no6: clonePath :ids n: n.operator
        nr6: clonePath :ids n: n.rhs
        return (Node.binop (zast.BinOpData
            nodeid: ids.mint
            lineno: ln6
            colno: co6
            lhs: nl6
            operator: no6
            rhs: nr6)
        )
    } case atomstring then {
        ln7: n.lineno
        co7: n.colno
        nparts: (List Node)
        spiter: n.stringparts.iterate
        for sp0: spiter loop {
            np0: clonePath :ids n: sp0
            nparts.append np0
        }
        return (Node.atomstring (zast.AtomStringData
            nodeid: ids.mint
            lineno: ln7
            colno: co7
            stringparts: nparts)
        )
    } case stringchunk then {
        ln8: n.lineno
        co8: n.colno
        tv8: n.text.stringview
        tc8: tv8.string
        ck8: n.chunkKind
        return (Node.stringchunk (zast.StringChunkData
            nodeid: ids.mint
            lineno: ln8
            colno: co8
            text: tc8
            chunkKind: ck8)
        )
    } else {
        # unsupported path shape -- an error atom keeps the tree total
        return (Node.atomid (zast.AtomIdData nodeid: ids.mint lineno: 0 colno: 0 name: "?".string))
    }
}

cloneOptString: function {o: Option String} out Option String is {
    match (
        o
    ) case some then {
        ov: o.stringview
        oc: ov.string
        return (Option.some oc)
    } case none then {
        return (Option.none String)
    }
}

optStringOr: function {o: Option String d: StringView} out String is {
    match (
        o
    ) case some then {
        ov: o.stringview
        oc: ov.string
        return oc
    } case none then {
        return d.string
    }
}

# givesParts -- split the iterator return into (gives base path CLONE,
# ownership leaf, accepts path CLONE or none). The base clone feeds the
# synth wrapper; leaf "take" selects Option, else OptionView.
GivesParts: class {
    base: (Option Node)
    leaf: String
    acceptsTy: (Option Node)
}

givesParts: function {ids: GenIds n: Node} out GivesParts is {
    result: (GivesParts base: (Option.none Node) leaf: "".string acceptsTy: (Option.none Node))
    match (
        n
    ) case functiondef then {
        givesPartsOpt :ids o: n.returntype dst: result
    } else {
    }
    return result
}

givesPartsOpt: function {ids: GenIds o: Option Node dst: GivesParts} is {
    match (
        o
    ) case some then {
        givesPartsOf :ids n: o :dst
    } case none then {
    }
}

givesPartsOf: function {ids: GenIds n: Node dst: GivesParts} is {
    match (
        n
    ) case expression then {
        givesPartsOf :ids n: n.expression :dst
    } case call then {
        aiter: n.arguments.iterate
        for a0: aiter loop {
            match (
                a0
            ) case namedoperation then {
                an: optStringOr o: a0.name d: ""
                if an.stringview == "gives" then {
                    givesFromOp :ids n: a0.operation :dst
                }
                if an.stringview == "accepts" then {
                    acceptsFromOp :ids n: a0.operation :dst
                }
            } else {
            }
        }
    } else {
    }
}

givesFromOp: function {ids: GenIds n: Node dst: GivesParts} is {
    isExpr: false
    match (
        n
    ) case expression then {
        isExpr = true
        givesFromOp :ids n: n.expression :dst
    } else {
    }
    if isExpr then return
    lf: pathLeafName :n
    if lf.length > 0 then {
        match (
            n
        ) case dottedpath then {
            bc: clonePath :ids n: n.parent
            dst.base = (Option.some bc)
            dst.leaf = lf
        } else {
        }
    } else {
        bc2: clonePath :ids :n
        dst.base = (Option.some bc2)
    }
}

acceptsFromOp: function {ids: GenIds n: Node dst: GivesParts} is {
    nm0: leafAtomName :n
    if nm0.stringview != "null" then {
        ac: clonePath :ids :n
        dst.acceptsTy = (Option.some ac)
    }
}

# resumeBaseId -- pathBaseAtomId over an optional path.
resumeBaseId: function {o: Option Node} out u32 is {
    match (
        o
    ) case some then {
        return (pathBaseAtomId n: o)
    } case none then {
        return 0
    }
}

# pathBaseAtomId -- the head atom's node id of a (possibly dotted /
# wrapped) type path; 0 for other shapes.
pathBaseAtomId: function {n: Node} out u32 is {
    match (
        n
    ) case atomid then {
        return n.nodeid
    } case labelvalue then {
        return n.nodeid
    } case dottedpath then {
        return (pathBaseAtomId n: n.parent)
    } case expression then {
        return (pathBaseAtomId n: n.expression)
    } else {
        return 0
    }
}

# cloneDottedParent -- a clone of a dotted path's parent (the ownership
# leaf stripped); none for non-dotted shapes.
cloneDottedParent: function {ids: GenIds n: Node} out Option Node is {
    match (
        n
    ) case dottedpath then {
        c: clonePath :ids n: n.parent
        return (Option.some c)
    } else {
        return (Option.none Node)
    }
}

# mkAtom / mkNamedOp / mkBareOp -- small node factories at a source
# position (the synthesized members all carry the function's start).
mkAtom: function {ids: GenIds line: u32 col: u32 name: StringView} out Node is {
    return (Node.atomid (zast.AtomIdData
        nodeid: ids.mint
        lineno: line
        colno: col
        name: name.string)
    )
}

mkNamedOp: function {ids: GenIds line: u32 col: u32 name: StringView op: Node.take} out Node is {
    nm: (Option.some name.string)
    return (Node.namedoperation (zast.NamedOperationData
        nodeid: ids.mint
        lineno: line
        colno: col
        name: nm
        operation: op)
    )
}

mkBareOp: function {ids: GenIds line: u32 col: u32 op: Node.take} out Node is {
    return (Node.namedoperation (zast.NamedOperationData
        nodeid: ids.mint
        lineno: line
        colno: col
        name: (Option.none String)
        operation: op)
    )
}

# mkReturnBody -- `{ return (<inner>) }`: the single-statement body both
# the create method and the factory share.
mkReturnBody: function {ids: GenIds line: u32 col: u32 inner: Node.take} out Node is {
    retCal: mkAtom :ids :line :col name: "return"
    retArg: mkBareOp :ids :line :col op: inner
    retArgs: (List Node)
    retArgs.append retArg
    retCall: (Node.call (zast.CallData
        nodeid: ids.mint
        lineno: line
        colno: col
        callable: retCal
        arguments: retArgs)
    )
    retExpr: (Node.expression (zast.ExpressionData
        nodeid: ids.mint
        lineno: line
        colno: col
        expression: retCall)
    )
    sline: (Node.statementline (zast.StatementLineData
        nodeid: ids.mint
        lineno: line
        colno: col
        statementline: retExpr)
    )
    slist: (List Node)
    slist.append sline
    return (Node.statement (zast.StatementData
        nodeid: ids.mint
        lineno: line
        colno: col
        statements: slist)
    )
}

# buildCreateMethod -- `create: function {<param-clones>} out this is {
# return (meta.create state: 0 p1: :p1 ...) }`: captured parameters
# forward by label-value shorthand; promoted locals are reserved fields
# the body's first write initialises.
buildCreateMethod: function {
    ids: GenIds
    line: u32
    col: u32
    params: (List Node).take
    fwdNames: List String
} out Node is {
    metaAtom: mkAtom :ids :line :col name: "meta"
    createAtom: mkAtom :ids :line :col name: "create"
    metaCreate: (Node.dottedpath (zast.DottedPathData
        nodeid: ids.mint
        lineno: line
        colno: col
        parent: metaAtom
        child: createAtom)
    )
    zeroAtom: mkAtom :ids :line :col name: "0"
    stArg: mkNamedOp :ids :line :col name: "state" op: zeroAtom
    cargs: (List Node)
    cargs.append stArg
    fi: 0.u64
    fn: fwdNames.length
    for fi < fn loop {
        f0: fwdNames.get i: fi
        f0v: f0.stringview
        f0s: f0v.string
        lv0: (Node.labelvalue (zast.LabelValueData
            nodeid: ids.mint
            lineno: line
            colno: col
            name: f0s)
        )
        fa0: mkNamedOp :ids :line :col name: f0v op: lv0
        cargs.append fa0
        fi = fi + 1
    }
    icall: (Node.call (zast.CallData
        nodeid: ids.mint
        lineno: line
        colno: col
        callable: metaCreate
        arguments: cargs)
    )
    body: mkReturnBody :ids :line :col inner: icall
    thisRet: mkAtom :ids :line :col name: "this"
    return (Node.functiondef (zast.FunctionData
        nodeid: ids.mint
        lineno: line
        colno: col
        returntype: (Option.some thisRet)
        parameters: params
        body: (Option.some body)
        isNative: false
        asItems: (List Node))
    )
}

# buildCallMethod -- the iterator protocol implementation: `call: function
# {this: this} out (<wrapper> t: <gives>) is <original body>`. Yields stay
# in place; promoted-name rewriting lands with the parameterized examples.
buildCallMethod: function {
    ids: GenIds
    line: u32
    col: u32
    body: Node.take
    wrapExpr: Node.take
    valueParam: (Option Node).take
} out Node is {
    thisP: mkAtom :ids :line :col name: "this"
    thisParam: mkNamedOp :ids :line :col name: "this" op: thisP
    params: (List Node)
    params.append thisParam
    vp9: valueParam.take
    match (
        vp9
    ) case some then {
        vparam: mkNamedOp :ids :line :col name: "value" op: vp9.take
        params.append vparam
    } case none then {
    }
    return (Node.functiondef (zast.FunctionData
        nodeid: ids.mint
        lineno: line
        colno: col
        returntype: (Option.some wrapExpr)
        parameters: params
        body: (Option.some body)
        isNative: false
        asItems: (List Node))
    )
}

# buildWrapper -- the synth `.call` return `(Option|OptionView t: <base>)`;
# leaf "take" selects Option, anything else OptionView.
buildWrapper: function {
    ids: GenIds
    line: u32
    col: u32
    base: Node.take
    leaf: StringView
} out Node is {
    wn: "OptionView"
    if leaf == "take" then wn = "Option"
    wAtom: mkAtom :ids :line :col name: wn
    tArg: mkNamedOp :ids :line :col name: "t" op: base
    wargs: (List Node)
    wargs.append tArg
    return (Node.call (zast.CallData
        nodeid: ids.mint
        lineno: line
        colno: col
        callable: wAtom
        arguments: wargs)
    )
}

# buildFactory -- the replacement for the original function: return type =
# the synth class, body = `return (<synth_name> p1: p1 ...)` forwarding
# each captured parameter by name.
buildFactory: function {
    ids: GenIds
    line: u32
    col: u32
    synthName: StringView
    params: (List Node).take
    fwdNames: List String
    privNames: (Map String value: bool)
} out Node is {
    synthAtom: mkAtom :ids :line :col name: synthName
    fargs: (List Node)
    fi: 0.u64
    fn: fwdNames.length
    for fi < fn loop {
        f0: fwdNames.get i: fi
        f0v: f0.stringview
        va0: mkAtom :ids :line :col name: f0v
        # a private-lock receiver forwards through `.private`: the synth
        # class's field needs friend access, while the factory's own
        # public `this.lock` parameter stays callable from outside.
        f0o: f0v.string
        isPriv: optBoolOr2 o: (privNames.get key: f0o) d: false
        if isPriv then {
            pa0: mkAtom :ids :line :col name: "private"
            vp0: (Node.dottedpath (zast.DottedPathData
                nodeid: ids.mint
                lineno: line
                colno: col
                parent: va0
                child: pa0)
            )
            fa1: mkNamedOp :ids :line :col name: f0v op: vp0
            fargs.append fa1
        } else {
            fa0: mkNamedOp :ids :line :col name: f0v op: va0
            fargs.append fa0
        }
        fi = fi + 1
    }
    icall: (Node.call (zast.CallData
        nodeid: ids.mint
        lineno: line
        colno: col
        callable: synthAtom
        arguments: fargs)
    )
    body: mkReturnBody :ids :line :col inner: icall
    retAtom: mkAtom :ids :line :col name: synthName
    return (Node.functiondef (zast.FunctionData
        nodeid: ids.mint
        lineno: line
        colno: col
        returntype: (Option.some retAtom)
        parameters: params
        body: (Option.some body)
        isNative: false
        asItems: (List Node))
    )
}

# isYieldValue -- the assignment RHS is a yield expression (through
# expression wrappers): the expression-form `name: yield E`.
isYieldValue: function {n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (isYieldValue n: n.expression)
    } case yieldexpr then {
        return true
    } else {
        return false
    }
}

# GenCross -- the crossing-locals walk state: yields passed so far, each
# local's first-definition yield count, its maximum-use yield count, and
# whether any reference sits inside a yielding loop (next iteration
# resumes past the suspension, so reuse crosses implicitly).
GenCross: class {
    yieldCount: u64
    firstDef: (Map String value: u64)
    maxUse: (Map String value: u64)
    inLoop: (Map String value: bool)
    params: (Map String value: bool)
    # `name: yield E` resume-input bindings: per-call borrowed aliases into
    # the caller's storage -- NEVER promoted (a stored pointer would dangle
    # across calls; the liveness rule already confines each to one window).
    yieldBound: (Map String value: bool)
}

crossWalk: function {gc: GenCross n: Node inYieldLoop: bool} is {
    match (
        n
    ) case functiondef then {
    } case yieldexpr then {
        crossWalk :gc n: n.expr :inYieldLoop
        gc.yieldCount = gc.yieldCount + 1
    } case assignment then {
        crossWalk :gc n: n.value :inYieldLoop
        anv: n.name.stringview
        if (isYieldValue n: n.value) then {
            ybk: anv.string
            ybv: true
            gc.yieldBound.set key: ybk value: ybv
        }

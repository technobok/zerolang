            name: cn0
            matcharm: nma
            statement: nstI)
        )
    } case yieldexpr then {
        lnJ: n.lineno
        coJ: n.colno
        nxJ: rewriteToThis :ids n: n.expr :promoted
        return (Node.yieldexpr (zast.YieldExprData
            nodeid: ids.mint
            lineno: lnJ
            colno: coJ
            expr: nxJ)
        )
    } case atomstring then {
        lnK: n.lineno
        coK: n.colno
        npartsK: (List Node)
        spiter: n.stringparts.iterate
        for sp0: spiter loop {
            nsp0: rewriteToThis :ids n: sp0 :promoted
            npartsK.append nsp0
        }
        return (Node.atomstring (zast.AtomStringData
            nodeid: ids.mint
            lineno: lnK
            colno: coK
            stringparts: npartsK)
        )
    } case stringchunk then {
        lnL: n.lineno
        coL: n.colno
        tvL: n.text.stringview
        tcL: tvL.string
        ckL: n.chunkKind
        return (Node.stringchunk (zast.StringChunkData
            nodeid: ids.mint
            lineno: lnL
            colno: coL
            text: tcL
            chunkKind: ckL)
        )
    } else {
        return (clonePath :ids :n)
    }
}

rewriteOptToThis: function {
    ids: GenIds
    o: Option Node
    promoted: (Map String value: bool)
} out Option Node is {
    match (
        o
    ) case some then {
        r: rewriteToThis :ids n: o :promoted
        return (Option.some r)
    } case none then {
        return (Option.none Node)
    }
}

mkThisDotted: function {ids: GenIds line: u32 col: u32 name: StringView} out Node is {
    thisAtom: mkAtom :ids :line :col name: "this"
    childAtom: mkAtom :ids :line :col :name
    return (Node.dottedpath (zast.DottedPathData
        nodeid: ids.mint
        lineno: line
        colno: col
        parent: thisAtom
        child: childAtom)
    )
}

# cloneWithThisHead -- clone a type path replacing its `this` head atom
# with the named receiver type (`this.private.lock` -> `Bag.private.lock`).
# cloneWithThisHead -- the rewritten spine carries the supplied position
# (the reference synthesizes the receiver rewrite at loc = func.start).
cloneWithThisHead: function {
    ids: GenIds
    n: Node
    receiverType: StringView
    line: u32
    col: u32
} out Node is {
    match (
        n
    ) case atomid then {
        if n.name.stringview == "this" then {
            return (mkAtom :ids :line :col name: receiverType)
        } else {
            nmv: n.name.stringview
            nm0: nmv.string
            return (Node.atomid (zast.AtomIdData
                nodeid: ids.mint
                lineno: line
                colno: col
                name: nm0)
            )
        }
    } case labelvalue then {
        if n.name.stringview == "this" then {
            return (mkAtom :ids :line :col name: receiverType)
        } else {
            lmv: n.name.stringview
            lm0: lmv.string
            return (Node.labelvalue (zast.LabelValueData
                nodeid: ids.mint
                lineno: line
                colno: col
                name: lm0)
            )
        }
    } case dottedpath then {
        np: cloneWithThisHead :ids n: n.parent :receiverType :line :col
        nc: clonePath :ids n: n.child
        return (Node.dottedpath (zast.DottedPathData
            nodeid: ids.mint
            lineno: line
            colno: col
            parent: np
            child: nc)
        )
    } case expression then {
        ne: cloneWithThisHead :ids n: n.expression :receiverType :line :col
        return (Node.expression (zast.ExpressionData
            nodeid: ids.mint
            lineno: line
            colno: col
            expression: ne)
        )
    } else {
        return (clonePath :ids :n)
    }
}

# isThisPrivateLock -- the `this.private.lock` friend-access receiver form.
isThisPrivateLock: function {n: Node} out bool is {
    match (
        n
    ) case dottedpath then {
        ln: leafAtomName n: n.child
        if ln.stringview == "lock" then {
            return (isThisPrivate n: n.parent)
        } else {
            return false
        }
    } else {
        return false
    }
}

isThisPrivate: function {n: Node} out bool is {
    match (
        n
    ) case dottedpath then {
        pn: leafAtomName n: n.child
        if pn.stringview == "private" then {
            return (pathHeadIsThis n: n.parent)
        } else {
            return false
        }
    } else {
        return false
    }
}

# paramFieldPath -- the synth class's field type for one captured
# parameter: a take-leaf strips (fields hold owned values), lock keeps
# its suffix, bare passes through. Receiver (`this`-headed) params
# capture as receiver-type lock fields.
paramFieldPath: function {ids: GenIds n: Node receiverType: StringView} out Node is {
    if receiverType.length > 0 then {
        if (pathHeadIsThis :n) then {
            fl0: nodeLineOf :n
            fc0: nodeColOf :n
            return (cloneWithThisHead :ids :n :receiverType line: fl0 col: fc0)
        }
    }
    lf: pathLeafName :n
    if lf.stringview == "take" then {
        match (
            n
        ) case dottedpath then {
            return (clonePath :ids n: n.parent)
        } else {
            return (clonePath :ids :n)
        }
    } else {
        return (clonePath :ids :n)
    }
}

# cloneCreateParam -- the synth create's parameter: a clone with any
# `this` head rewritten to the receiver type (inside the synth class,
# `this` is the iterator, not the original receiver).
cloneCreateParam: function {
    ids: GenIds
    n: Node
    receiverType: StringView
    fnLine: u32
    fnCol: u32
} out Node is {
    match (
        n
    ) case namedoperation then {
        ln0: n.lineno
        co0: n.colno
        nnm: cloneOptString o: n.name
        isTh0: false
        if receiverType.length > 0 then {
            isTh0 = pathHeadIsThis n: n.operation
        }
        if isTh0 then {
            nop1: cloneWithThisHead :ids n: n.operation :receiverType line: fnLine col: fnCol
            return (Node.namedoperation (zast.NamedOperationData
                nodeid: ids.mint
                lineno: ln0
                colno: co0
                name: nnm
                operation: nop1)
            )
        } else {
            nop: clonePath :ids n: n.operation
            return (Node.namedoperation (zast.NamedOperationData
                nodeid: ids.mint
                lineno: ln0
                colno: co0
                name: nnm
                operation: nop)
            )
        }
    } else {
        return (clonePath :ids :n)
    }
}

# cloneFactoryParam -- the factory's parameter: `this.private.lock`
# exposes publicly as `this.lock` (the body projects `.private` when
# forwarding); everything else clones as-is.
cloneFactoryParam: function {ids: GenIds n: Node fnLine: u32 fnCol: u32} out Node is {
    match (
        n
    ) case namedoperation then {
        ln0: n.lineno
        co0: n.colno
        nnm: cloneOptString o: n.name
        if (isThisPrivateLock n: n.operation) then {
            # the public this.lock replacement carries the function's start
            # (the reference synthesizes it at loc = func.start)
            ta0: mkAtom :ids line: fnLine col: fnCol name: "this"
            la0: mkAtom :ids line: fnLine col: fnCol name: "lock"
            nop2: (Node.dottedpath (zast.DottedPathData
                nodeid: ids.mint
                lineno: fnLine
                colno: fnCol
                parent: ta0
                child: la0)
            )
            return (Node.namedoperation (zast.NamedOperationData
                nodeid: ids.mint
                lineno: ln0
                colno: co0
                name: nnm
                operation: nop2)
            )
        } else {
            nop: clonePath :ids n: n.operation
            return (Node.namedoperation (zast.NamedOperationData
                nodeid: ids.mint
                lineno: ln0
                colno: co0
                name: nnm
                operation: nop)
            )
        }
    } else {
        return (clonePath :ids :n)
    }
}

# canLowerNow -- pre-surgery shape gate on the borrowed definition: a
# parenthesized gives, a real body, and no receiver (`this`-headed)
# parameter types (method generators land with the listiter slice).
canLowerNow: function {n: Node hasReceiver: bool} out bool is {
    match (
        n
    ) case functiondef then {
        piter: n.parameters.iterate
        for p0: piter loop {
            if (paramHeadIsThis n: p0) then {
                if hasReceiver then {
                    if (paramIsThisLock n: p0) == false then return false
                } else {
                    return false
                }
            }
        }
        hd: returnHeadOpt o: n.returntype
        if hd.length == 0 then return false

        match (
            n.body
        ) case some then {
            return true
        } case none then {
            return false
        }
    } else {
        return false
    }
}

# returnHasAccepts -- a non-null accepts: argument on the iterator return
# (the bidirectional form).
returnHasAccepts: function {o: Option Node} out bool is {
    match (
        o
    ) case some then {
        return (returnHasAcceptsOf n: o)
    } case none then {
        return false
    }
}

returnHasAcceptsOf: function {n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (returnHasAcceptsOf n: n.expression)
    } case call then {
        aiter: n.arguments.iterate
        for a0: aiter loop {
            match (
                a0
            ) case namedoperation then {
                an: optStringOr o: a0.name d: ""
                if an.stringview == "accepts" then {
                    nv0: leafAtomName n: a0.operation
                    if nv0.stringview != "null" then return true
                }
            } else {
            }
        }
        return false
    } else {
        return false
    }
}

paramHeadIsThis: function {n: Node} out bool is {
    match (
        n
    ) case namedoperation then {
        return (pathHeadIsThis n: n.operation)
    } else {
        return false
    }
}

# paramIsThisLock -- the receiver parameter forms a generator method may
# carry: `this.lock` or `this.private.lock`.
paramIsThisLock: function {n: Node} out bool is {
    match (
        n
    ) case namedoperation then {
        lf: pathLeafName n: n.operation
        if lf.stringview == "lock" then {
            return true
        } else {
            return false
        }
    } else {
        return false
    }
}

pathHeadIsThis: function {n: Node} out bool is {
    match (
        n
    ) case atomid then {
        return (n.name.stringview == "this")
    } case labelvalue then {
        return (n.name.stringview == "this")
    } case dottedpath then {
        return (pathHeadIsThis n: n.parent)
    } case expression then {
        return (pathHeadIsThis n: n.expression)
    } else {
        return false
    }
}

# lowerOne -- lower one generator: collect the captured parameters and
# yield-crossing locals, deep-clone the body with promoted names
# rewritten through `this`, and assemble the synth class (state +
# captured fields + create + call) plus the forwarding factory.
lowerOne: function {
    ids: GenIds
    fn: Node.take
    synthName: StringView
    receiverType: StringView
} out Option GenLowered is {
    gp: givesParts :ids n: fn
    match (
        fn
    ) case functiondef then {
        line: fn.lineno
        col: fn.colno
        gbase: gp.base.take
        match (
            gbase
        ) case some then {
            wrapper: buildWrapper :ids :line :col base: gbase.take leaf: gp.leaf.stringview
            # the EXPRESSION wrapper's id keys the pendingMono record; the
            # typechecker's valtype collapse looks it up there.
            wid: ids.mint
            wrapExpr: (Node.expression (zast.ExpressionData
                nodeid: wid
                lineno: line
                colno: col
                expression: wrapper)
            )
            # captured parameters: names, field paths, create/factory clones
            pNames: (List String)
            pFields: (List Node)
            createParams: (List Node)
            factoryParams: (List Node)
            noStamp: (List u32)
            innerRefs: (List u32)
            thisFlags: (List bool)
            privNames: (Map String value: bool)
            piter: fn.parameters.iterate
            for p0: piter loop {
                cp0: cloneCreateParam :ids n: p0 :receiverType fnLine: line fnCol: col
                isThP: paramHeadIsThis n: p0
                cpid0: paramOpId n: cp0
                if cpid0 > 0 when isThP then {} else {
                    if cpid0 > 0 then noStamp.append cpid0
                }
                fp0: cloneFactoryParam :ids n: p0 fnLine: line fnCol: col
                match (
                    p0
                ) case namedoperation then {
                    pn0: optStringOr o: p0.name d: ""
                    if pn0.length > 0 then {
                        if (isThisPrivateLock n: p0.operation) then {
                            pnv1: pn0.stringview
                            pk1: pnv1.string
                            pv1: true
                            privNames.set key: pk1 value: pv1
                        }
                        pf0: paramFieldPath :ids n: p0.operation :receiverType
                        pFields.append pf0
                        createParams.append cp0
                        factoryParams.append fp0
                        pNames.append pn0
                        tf0: isThP
                        thisFlags.append tf0
                    }
                } else {
                }
            }
            # the suspending-iterable promotion runs first; the analyses and
            # the this-rewrite read the promoted body.
            ictr: (GenIds nextId: 0)
            pBody: promoteIterablesOpt :ids ctr: ictr o: fn.body
            # promoted = parameters + yield-crossing locals
            gc: (GenCross
                yieldCount: 0
                firstDef: (Map String value: u64)
                maxUse: (Map String value: u64)
                inLoop: (Map String value: bool)
                params: (Map String value: bool)
                yieldBound: (Map String value: bool)
            )
            gi: 0.u64
            gn: pNames.length
            for gi < gn loop {
                g0: pNames.get i: gi
                g0v: g0.stringview
                gk0: g0v.string
                gv0: true
                gc.params.set key: gk0 value: gv0
                gi = gi + 1
            }
            crossWalkOpt :gc o: pBody inYieldLoop: false
            crossing: (List String)
            crossingLocals :gc dst: crossing
            promoted: (Map String value: bool)
            pi2: 0.u64
            pn2: pNames.length
            for pi2 < pn2 loop {
                pe2: pNames.get i: pi2
                pe2v: pe2.stringview
                pk2: pe2v.string
                pv2: true
                promoted.set key: pk2 value: pv2
                pi2 = pi2 + 1
            }
            ci2: 0.u64
            cn2: crossing.length
            for ci2 < cn2 loop {
                ce2: crossing.get i: ci2
                ce2v: ce2.stringview
                ck2: ce2v.string
                cv2: true
                promoted.set key: ck2 value: cv2
                ci2 = ci2 + 1
            }
            # the call body: a deep clone with promoted names through `this`
            newBodyOpt: rewriteOptToThis :ids o: pBody :promoted
            match (
                newBodyOpt
            ) case some then {
                # bidirectional: the accepts path becomes the call's value
                # parameter; the _resume_input field stores the most recent
                # resumed value (take strips to an owned field, lock keeps,
                # bare/borrow wraps in .lock -- the reference collapses the
                # lock back to a value field for valtypes).
                valueParam: (Option.none Node)
                resumeField: (Option.none Node)
                acc9: gp.acceptsTy.take
                match (
                    acc9
                ) case some then {
                    al9: nodeLineOf n: acc9
                    ac9: nodeColOf n: acc9
                    vp0: clonePath :ids n: acc9
                    valueParam = (Option.some vp0)
                    alf9: pathLeafName n: acc9
                    if alf9.stringview == "take" then {
                        resumeField = cloneDottedParent :ids n: acc9
                        rfb0: resumeBaseId o: resumeField
                        if rfb0 > 0 then noStamp.append rfb0
                    } else {
                        if alf9.stringview == "lock" then {
                            rf1: clonePath :ids n: acc9
                            # the field copy shares the param's stamp in the
                            # reference -- one stamp per ref (the recorder
                            # keys the head atom)
                            rfb1: pathBaseAtomId n: rf1
                            if rfb1 > 0 then noStamp.append rfb1
                            rfd1: topNodeId n: rf1
                            if rfd1 > 0 then noStamp.append rfd1
                            resumeField = (Option.some rf1)
                        } else {
                            base9: (Option.none Node)
                            if alf9.stringview == "borrow" then {
                                base9 = cloneDottedParent :ids n: acc9
                            } else {
                                b10: clonePath :ids n: acc9
                                base9 = (Option.some b10)
                            }
                            rfb2: resumeBaseId o: base9
                            if rfb2 > 0 then noStamp.append rfb2
                            bg9: base9.take
                            match (
                                bg9
                            ) case some then {
                                la9: mkAtom :ids line: al9 col: ac9 name: "lock"
                                rf2: (Node.dottedpath (zast.DottedPathData
                                    nodeid: ids.mint
                                    lineno: al9
                                    colno: ac9
                                    parent: bg9.take
                                    child: la9)
                                )
                                resumeField = (Option.some rf2)
                            } case none then {
                            }
                        }
                    }
                } case none then {
                }
                callM: buildCallMethod :ids :line :col body: newBodyOpt.take :wrapExpr :valueParam
                createM: buildCreateMethod :ids :line :col params: createParams fwdNames: pNames
                # class fields: the state cursor, captured params, then
                # typeof-typed yield-crossing locals (first-assignment order)
                sysAtom: mkAtom :ids :line :col name: "system"
                i64Leaf: mkAtom :ids :line :col name: "i64"
                i64Atom: (Node.dottedpath (zast.DottedPathData
                    nodeid: ids.mint
                    lineno: line
                    colno: col
                    parent: sysAtom
                    child: i64Leaf)
                )
                stField: mkNamedOp :ids :line :col name: "state" op: i64Atom
                isItems: (List Node)
                isItems.append stField
                fi3: 0.u64
                fn3: pNames.length
                for fi3 < fn3 loop {
                    f3: pNames.get i: fi3
                    f3v: f3.stringview
                    pf3: pFields.get i: fi3
                    # field paths staged owned: List.get is a borrow, the
                    # namedoperation stores owned -- clone out
                    pf3o: clonePath :ids n: pf3
                    # receiver-lock fields stamp (the reference builds them
                    # fresh); ordinary param fields share the factory's stamp
                    tf3: thisFlags.get i: fi3
                    if tf3 then {
                        # the installed clone's inner spine node stamps the
                        # receiver type through the deferred pass
                        idp3: innerDpId n: pf3o
                        if idp3 > 0 then innerRefs.append idp3
                    } else {
                        pfid3: topNodeId n: pf3o
                        if pfid3 > 0 then noStamp.append pfid3
                    }
                    nf3: mkNamedOp :ids :line :col name: f3v op: pf3o
                    isItems.append nf3
                    fi3 = fi3 + 1
                }
                li3: 0.u64
                ln3: crossing.length
                for li3 < ln3 loop {
                    l3: crossing.get i: li3
                    l3v: l3.stringview
                    rhsCar: (GivesParts
                        base: (Option.none Node)
                        leaf: "".string
                        acceptsTy: (Option.none Node)
                    )
                    firstRhsOfOpt :ids o: pBody name: l3v dst: rhsCar
                    rc3: rhsCar.base.take
                    match (
                        rc3
                    ) case some then {
                        tof3: (Node.typeofexpr (zast.TypeOfExprData
                            nodeid: ids.mint
                            lineno: line
                            colno: col
                            source: rc3.take)
                        )
                        nf4: mkNamedOp :ids :line :col name: l3v op: tof3
                        isItems.append nf4
                    } case none then {
                    }
                    li3 = li3 + 1
                }
                rfg9: resumeField.take
                match (
                    rfg9
                ) case some then {
                    rfn9: mkNamedOp :ids :line :col name: "_resume_input" op: rfg9.take
                    isItems.append rfn9
                } case none then {
                }
                createNamed: mkNamedOp :ids :line :col name: "create" op: createM
                callNamed: mkNamedOp :ids :line :col name: "call" op: callM
                asItems: (List Node)
                asItems.append createNamed
                asItems.append callNamed
                synthClass: (Node.objectdef (zast.ObjectDefData
                    nodeid: ids.mint
                    lineno: line
                    colno: col
                    kind: zast.nodetype.CLASS
                    :isItems
                    :asItems
                    isNative: false)
                )
                factory: (buildFactory
                    :ids
                    :line
                    :col
                    :synthName
                    params: factoryParams
                    fwdNames: pNames
                    :privNames
                )
                return (Option.some (GenLowered
                    :factory
                    :synthClass
                    wrapperNodeId: wid
                    :noStamp
                    :innerRefs)
                )
            } case none then {
                return (Option.none GenLowered)
            }
        } case none then {
            return (Option.none GenLowered)
        }
    } else {
        return (Option.none GenLowered)
    }
}

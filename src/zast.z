    # statement block holding two statementlines (exercises the list iterator).
    lines: (List of: Node)
    l1op: Node.atomid (AtomIdData nodeid: 50.u32 lineno: 29.u32 colno: 8.u32 name: "u".string)
    l1val: Node.expression (ExpressionData nodeid: 51.u32 lineno: 29.u32 colno: 8.u32 expression: l1op)
    l1asg: Node.assignment (AssignmentData nodeid: 52.u32 lineno: 29.u32 colno: 5.u32 name: "t".string value: l1val)
    lines.append (Node.statementline (StatementLineData nodeid: 53.u32 lineno: 29.u32 colno: 5.u32 statementline: l1asg))
    l2op: Node.atomid (AtomIdData nodeid: 54.u32 lineno: 30.u32 colno: 5.u32 name: "v".string)
    l2expr: Node.expression (ExpressionData nodeid: 55.u32 lineno: 30.u32 colno: 5.u32 expression: l2op)
    lines.append (Node.statementline (StatementLineData nodeid: 56.u32 lineno: 30.u32 colno: 5.u32 statementline: l2expr))
    n20: Node.statement (StatementData nodeid: 57.u32 lineno: 29.u32 colno: 1.u32 statements: lines)

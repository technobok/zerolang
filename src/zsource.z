# zsource -- the analysis facade for zl. Fast tier: read + fast-parse a single
# file (no VFS, no typecheck), build a 1-based line table, and collect any
# embedded parse errors as ERROR diagnostics. The Analysis carries what the
# reporter and (later) the fixer need. A full tier (project VFS + typecheck) is
# added in Phase 2 for type-dependent rules.

Node: zast.Node

# ---- AST query helpers for the parse-tier rules (behaviour-preserving port of
# the original zc lint helpers) ----

# atomName -- the identifier name of an atomid node, else "".
atomName: function {n: Node} out String is {
    match (
        n
    ) case atomid then {
        return n.name.copy
    } else {
        return "".string
    }
}

# isStatementArm -- the node is a braced `{ ... }` statement block.
isStatementArm: function {n: Node} out bool is {
    match (
        n
    ) case statement then {
        return true
    } else {
        return false
    }
}

# isEmptyBlock -- a statement block with no statement lines (`{}`).
isEmptyBlock: function {n: Node} out bool is {
    match (
        n
    ) case statement then {
        return n.statements.length == 0
    } else {
        return false
    }
}

# stmtPos -- the source position of a statement block.
stmtPos: function {n: Node} out zast.nodepos is {
    match (
        n
    ) case statement then {
        return (zast.nodepos line: n.lineno col: n.colno)
    } else {
        return (zast.nodepos line: 0 col: 0)
    }
}

# isIfArm -- the node is an `if` (through an `expression` wrapper).
isIfArm: function {n: Node} out bool is {
    match (
        n
    ) case ifexpr then {
        return true
    } case expression then {
        return (isIfArm n: n.expression)
    } else {
        return false
    }
}

# slIsIf -- a statement line wrapping an `if`.
slIsIf: function {sl: Node} out bool is {
    match (
        sl
    ) case statementline then {
        return (isIfArm n: sl.statementline)
    } else {
        return false
    }
}

# isElseIfWrap -- the else clause is the synthetic block an `else if` chain parses
# to (a single statement line wrapping an `if`), not a real braced `else { ... }`.
isElseIfWrap: function {n: Node} out bool is {
    match (
        n
    ) case statement then {
        if n.statements.length == 1 then {
            res: false
            it: n.statements.iterate
            for sl: it loop res = slIsIf :sl
            return res
        }
        return false
    } else {
        return false
    }
}

# debraceEligible -- the inner node of a single-statement clause body is a simple
# statement that de-braces safely: a call (including return/break/yield), a
# reassignment, a swap, a binop, a dotted path, or a bare atom -- never a binding
# `x: y`, a control-flow construct, or a data block.
debraceEligible: function {n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (debraceEligible n: n.expression)
    } case call then {
        return true
    } case reassignment then {
        return true
    } case swapstmt then {
        return true
    } case binop then {
        return true
    } case dottedpath then {
        return true
    } case atomid then {
        return true
    } case yieldexpr then {
        return true
    } else {
        return false
    }
}

# clauseBodiesOnLine -- every then-body and the else-body of an `if` sit on the
# construct's start line `ln` (the whole `if ... else` is a one-liner).
clauseBodiesOnLine: function {clauses: (List Node) elseOpt: (Option Node) ln: u32} out bool is {
    ok: true
    cit: clauses.iterate
    for cl: cit loop {
        match (
            cl
        ) case ifclause then {
            p: stmtPos n: cl.statement
            if p.line != ln then ok = false
        } else null
    }
    match (
        elseOpt
    ) case some then {
        pe: stmtPos n: elseOpt
        if pe.line != ln then ok = false
    } case none then null
    return ok
}

# caseBodiesOnLine -- every arm-body and the else-body of a `match` sit on the
# construct's start line `ln` (the whole `match` is a one-liner).
caseBodiesOnLine: function {clauses: (List Node) elseOpt: (Option Node) ln: u32} out bool is {
    ok: true
    cit: clauses.iterate
    for cl: cit loop {
        match (
            cl
        ) case caseclause then {
            p: stmtPos n: cl.statement
            if p.line != ln then ok = false
        } else null
    }
    match (
        elseOpt
    ) case some then {
        pe: stmtPos n: elseOpt
        if pe.line != ln then ok = false
    } case none then null
    return ok
}

# primaryGenericParam -- the elidable first parameter name of a built-in template,
# or "" when `name` is not such a template. Index 0 only.
primaryGenericParam: function {name: StringView} out String is {
    if name == "List" then return "of".string
    if name == "Set" then return "of".string
    if name == "array" then return "of".string
    if name == "Map" then return "key".string
    if name == "option" then return "t".string
    if name == "optionval" then return "t".string
    if name == "Option" then return "t".string
    if name == "OptionView" then return "t".string
    if name == "Result" then return "t".string
    return "".string
}

# optName -- an (Option String) as an owned String ("" when none).
optName: function {o: Option String} out String is {
    match (
        o
    ) case some then {
        return o.copy
    } case none then {
        return "".string
    }
}

# casingSuggest -- the lowerCamelCase form of an ALL-CAPS / SCREAMING_SNAKE member name:
# split on `_`, lowercase each segment, and capitalise the first letter of every segment
# after the first. Compounds without underscores become run-together lowercase.
casingSuggest: function {name: StringView} out String is {
    buf: String
    n: name.length
    cap: false
    i: u64
    for i < n loop {
        bo: name.byteAt :i
        match (
            bo
        ) case some then {
            if bo == 95 then {
                cap = true
            } else {
                c: bo
                if c >= 65 when (c <= 90) then c = c + 32
                if cap when (buf.length > 0) then {
                    if c >= 97 when (c <= 122) then c = c - 32
                }
                buf.appendByte b: c
                cap = false
            }
        } case none then null
        i = i + 1
    }
    return buf
}

# casingClash -- true when `s` (a proposed lowercase member name) collides with a language
# keyword or a future-reserved word, and so cannot be used as-is.
casingClash: function {s: StringView} out bool is {
    kr: zlexer.kwlookup sv: s
    if kr.found then return true
    return (zlexer.islookupReserved sv: s)
}

# casingMessage -- the L009 diagnostic text: a direct rename when the lowerCamelCase form is
# usable, or a role-suffixed alternative when it clashes with a keyword/reserved word.
casingMessage: function {orig: StringView sug: StringView} out String is {
    if (casingClash s: sug) then {
        return "member '\{orig}' is not lowerCamelCase -- '\{sug}' is a keyword; use a role suffix, e.g. '\{sug}Kind' (type-kind) / '\{sug}Def' (AST node)"
    }
    return "member '\{orig}' is not lowerCamelCase -- rename to '\{sug}'"
}

# trailingWsLen -- number of trailing ASCII-whitespace bytes (space, tab, CR) in
# `ln`. Computed by hand (StringView.trimEnd's native is not emitted).
trailingWsLen: function {ln: StringView} out u64 is {
    n: ln.length
    k: u64
    keep: true
    for keep loop {
        if k >= n then {
            keep = false
        } else {
            bo: ln.byteAt i: (n - 1 - k)
            isws: false
            match (
                bo
            ) case some then {
                if bo == 32 then isws = true
                if bo == 9 then isws = true
                if bo == 13 then isws = true
            } case none then null
            if isws then {
                k = k + 1
            } else {
                keep = false
            }
        }
    }
    return k
}

# endsWithNewline -- true if `src` is empty or its last byte is a newline.
endsWithNewline: function {src: StringView} out bool is {
    n: src.length
    if n == 0 then return true
    bo: src.byteAt i: (n - 1)
    match (
        bo
    ) case some then {
        if bo == 10 then return true
        return false
    } case none then {
        return true
    }
}

Analysis: class {
    path: String
    source: String
    lines: (List String)
    lineStart: (List u64)
    diags: (List zdiag.Diagnostic)
    edits: (List zfix.Edit)
    wrapWidth: u32
    wrapSkip: u64
    wrapFound: bool
    wrapStart: u64
    delimClose: (Map u64 value: u64)
    fastToks: (List tokenize.Token)
    funcDepth: u64
    wrapGroups: (List u64)
} as {
    # parseErrorCount -- how many collected diagnostics are hard (ERROR) -- i.e.
    # parse errors. The fmt parse gate refuses any file with a non-zero count.
    parseErrorCount: function {:this} out u64 is {
        c: u64
        with it: this.diags.iterate do for d: it loop {
            match (
                d.sev
            ) case error then {
                c = c + 1
            } else null
        }
        return c
    }

    # failCount -- diagnostics that fail the gate: everything except advisory INFO. `zl lint` exits
    # non-zero on a non-zero count, so INFO rules (line-length) report without failing.
    failCount: function {:this} out u64 is {
        c: u64
        with it: this.diags.iterate do for d: it loop {
            isInfo: false
            match (
                d.sev
            ) case info then {
                isInfo = true
            } else null
            if (isInfo) == false then c = c + 1
        }
        return c
    }

    # warnFix -- append a WARNING diagnostic AND its single safe fix edit (a
    # replacement of source[lo, hi) with `repl`). Used by the format rules.
    warnFix: function {:this code: StringView msg: String.take line: u32 col: u32 width: u32 lo: u64 hi: u64 repl: String.take} is {
        this.warn :code :msg :line :col :width
        this.edits.append (zfix.Edit byteLo: lo byteHi: hi replacement: repl)
    }

    # checkTrailingWs -- W001: trailing whitespace on a line. Byte-exact from line
    # byte-lengths (independent of the codepoint-based column).
    checkTrailingWs: function {:this} is {
        lls: linesOf src: this.source.stringview
        off: u64
        lno: 1.u32
        with it: lls.iterate do for ln: it loop {
            llen: ln.length
            twl: trailingWsLen ln: ln.stringview
            if twl > 0 then {
                keptLen: llen - twl
                (this.warnFix
                    code: "W001"
                    msg: "trailing whitespace".string
                    line: lno
                    col: (keptLen + 1).u32
                    width: twl.u32
                    lo: (off + keptLen)
                    hi: (off + llen)
                    repl: "".string
                )
            }
            off = off + llen + 1
            lno = lno + 1
        }
    }

    # checkFinalNewline -- W002: a non-empty file that does not end in a newline.
    checkFinalNewline: function {:this} is {
        n: this.source.length
        if n > 0 when ((endsWithNewline src: this.source.stringview) == false) then {
            (this.warnFix
                code: "W002"
                msg: "file does not end with a newline".string
                line: 0
                col: 0
                width: 0
                lo: n
                hi: n
                repl: "\n".string
            )
        }
    }

    # checkBlankLines -- W004: collapse a run of 3 or more consecutive blank lines (empty or
    # whitespace-only) to a single blank line, deleting the extras. Byte-exact from the line
    # start index; runs of two or fewer are left alone.
    checkBlankLines: function {:this} is {
        srcOwned: this.source.copy
        sv: srcOwned.stringview
        lls: linesOf src: sv
        lineStart: lineStartIndex src: sv
        nLines: lls.length
        srcLen: sv.length
        i: u64
        for i < nLines loop {
            ln: lls.get :i
            blank: (trailingWsLen ln: ln.stringview) == ln.length
            if blank then {
                e: i + 1
                scanning: true
                for scanning loop {
                    if e >= nLines then {
                        scanning = false
                    } else {
                        le: lls.get i: e
                        lblank: (trailingWsLen ln: le.stringview) == le.length
                        if lblank then {
                            e = e + 1
                        } else {
                            scanning = false
                        }
                    }
                }
                runLen: e - i
                if runLen >= 3 then {
                    lo: lineStart.get i: (i + 1)
                    hi: srcLen
                    if e < nLines then hi = lineStart.get i: e
                    (this.warnFix
                        code: "W004"
                        msg: "too many consecutive blank lines".string
                        line: (i + 2).u32
                        col: 1
                        width: 1
                        :lo
                        :hi
                        repl: "".string
                    )
                }
                i = e
            } else {
                i = i + 1
            }
        }
    }
    # walkOpt -- recurse into an optional child node when present.
    walkOpt: function {:this nodes: List Node o: Option Node} is {
        match (
            o
        ) case some then {
            this.walk :nodes n: o
        } case none then null
    }

    # warn -- append a WARNING lint diagnostic (fast tier: no fsno; the single-file
    # reporter resolves the source line from the line table).
    warn: function {:this code: StringView msg: String.take line: u32 col: u32 width: u32} is {
        d: (zdiag.Diagnostic
            code: code.string
            sev: zdiag.severity.warning
            fsno: 0
            lineno: line
            colno: col
            :width
            :msg
            note: "".string
            hint: "".string
        )
        this.diags.append d
    }

    # info -- append an advisory INFO diagnostic (does not fail the gate; carries no fix).
    info: function {:this code: StringView msg: String.take line: u32 col: u32 width: u32} is {
        d: (zdiag.Diagnostic
            code: code.string
            sev: zdiag.severity.info
            fsno: 0
            lineno: line
            colno: col
            :width
            :msg
            note: "".string
            hint: "".string
        )
        this.diags.append d
    }

    # checkLineLength -- W005 (advisory): a line wider than `width` codepoints. INFO severity, so it
    # reports but never fails the gate; runs only when a width is set (--line-length). No fix.
    checkLineLength: function {:this width: u32} is {
        if width == 0 then return
        lls: linesOf src: this.source.stringview
        lno: 1.u32
        with it: lls.iterate do for ln: it loop {
            cl: codepointLen s: ln.stringview
            if cl > width.u64 then {
                (this.info
                    code: "W005"
                    msg: "line exceeds \{width} columns (\{cl})"
                    line: lno
                    col: (width + 1)
                    width: 1
                )
            }
            lno = lno + 1
        }
    }

    # checkEmpty -- L001 empty `else {}` and, for a backwards single-condition `if`,
    # the empty `then {}` (via checkEmptyThen). Receives an ifexpr's else + clauses.
    checkEmpty: function {:this elseOpt: Option Node clauses: List Node} is {
        match (
            elseOpt
        ) case some then {
            if (isEmptyBlock n: elseOpt) then {
                p: stmtPos n: elseOpt
                (this.warn
                    code: "L001"
                    msg: "empty `else { }` clause".string
                    line: p.line
                    col: p.col
                    width: 2
                )
            } else if (isStatementArm n: elseOpt) when (clauses.length == 1) then {
                if (isElseIfWrap n: elseOpt) == false then {
                    citer: clauses.iterate
                    for c0: citer loop this.checkEmptyThen clause: c0
                }
            }
        } case none then null
    }

    # checkEmptyThen -- L002 a single-condition clause whose `then {}` is empty.
    checkEmptyThen: function {:this clause: Node} is {
        match (
            clause
        ) case ifclause then {
            if (isEmptyBlock n: clause.statement) when (clause.conditions.length == 1) then {
                p: stmtPos n: clause.statement
                (this.warn
                    code: "L002"
                    msg: "empty `then { }` clause".string
                    line: p.line
                    col: p.col
                    width: 2
                )
            }
        } else null
    }

    # checkElide -- L003 a built-in template call whose first argument carries its
    # primary parameter name. Receives the narrowed callable + argument list.
    checkElide: function {:this callable: Node arguments: List Node} is {
        cn: atomName n: callable
        if cn.length == 0 then return
        primary: primaryGenericParam name: cn.stringview
        if primary.length == 0 then return
        idx: u64
        aiter: arguments.iterate
        for a: aiter loop {
            if idx == 0 then this.checkElideFirst arg: a primary: primary.stringview
            idx = idx + 1
        }
    }

    # checkElideFirst -- flag the first generic argument when its label is the
    # template's primary parameter name.
    checkElideFirst: function {:this arg: Node primary: StringView} is {
        match (
            arg
        ) case namedoperation then {
            an: optName o: arg.name
            if an.stringview == primary then {
                w: primary.length + 1
                (this.warn
                    code: "L003"
                    msg: "redundant `\{primary}:` label on a built-in template's first argument"
                    line: arg.lineno
                    col: arg.colno
                    width: w.u32
                )
            }
        } else null
    }

    # checkCollapseName -- L006: a named argument `name: name` whose label equals its bare-atom
    # value collapses to the `:name` shorthand (same atomVariableId stamp -- codegen-neutral once
    # the emitter treats labelvalue == atomid). Fires on atomid values only, so it is idempotent:
    # a `:name` parses to a labelvalue and atomName returns "".
    checkCollapseName: function {:this nodes: List Node arguments: List Node} is {
        if this.lineStart.length == 0 then return
        aiter: arguments.iterate
        for a: aiter loop {
            match (
                a
            ) case namedoperation then {
                label: optName o: a.name
                val: atomName n: (nodes.get i: (a.operation - 1).u64)
                lsv: label.stringview
                vsv: val.stringview
                if lsv.length > 0 when vsv.length > 0 when lsv == vsv then {
                    lo9: (tokByteStart
                        lineStart: this.lineStart
                        srcLines: this.lines
                        lineno: a.lineno
                        colno: a.colno
                    )
                    vi9: nodeInfoOf n: (nodes.get i: (a.operation - 1).u64)
                    hi9: (tokByteStart
                        lineStart: this.lineStart
                        srcLines: this.lines
                        lineno: vi9.line
                        colno: vi9.col
                    )
                    (this.warnFix
                        code: "L006"
                        msg: "redundant label repeating its value; use the :name shorthand".string
                        line: a.lineno
                        col: a.colno
                        width: (lsv.length).u32
                        lo: lo9
                        hi: hi9
                        repl: ":".string
                    )
                }
            } else null
        }
    }

    # tryWrapCall -- wrap mode (--line-length): if this over-long single-line call has >= 2 named
    # args and starts at/after wrapSkip, emit the wrap edits (one arg per line at base+4; a `(` is
    # added when the call is bare) and set wrapFound. Only the first such call per pass is wrapped;
    # wrapSource's re-parse gate + fixpoint handle discards and the rest.
    tryWrapCall: function {:this nodes: List Node arguments: List Node line: u32 col: u32} is {
        if line.u64 == this.wrapStart then return
        ac: arguments.length
        if ac < 2 then return
        lidx: (line - 1).u64
        if lidx >= this.lines.length then return
        lnt: (this.lines.get i: lidx).copy
        cw: codepointLen s: lnt.stringview
        if cw <= this.wrapWidth.u64 then return
        if (hasHash line: lnt.stringview) then return
        cs: tokByteStart lineStart: this.lineStart srcLines: this.lines lineno: line colno: col
        ok: true
        with vit: arguments.iterate do for arg: vit loop {
            match (
                arg
            ) case namedoperation then {
                if arg.lineno != line then ok = false
                anm: optName o: arg.name
                if anm.length == 0 then ok = false
            } else {
                ok = false
            }
        }
        if ok == false then return
        base: leadingSpaces line: lnt.stringview
        srcOwned: this.source.copy
        srcv: srcOwned.stringview
        bare: true
        if cs > 0 then {
            pb: srcv.byteAt i: (cs - 1)
            match (
                pb
            ) case some then {
                if pb == 40 then bare = false
            } case none then null
        }
        lsb: this.lineStart.get i: lidx
        contentEnd: lsb + (rstripLen line: lnt.stringview)
        ind4: nlIndent n: (base + 4)
        ind0: nlIndent n: base
        closePos: contentEnd
        clo: "\{ind0})"
        if bare == false then {
            coff: this.delimClose.get key: (cs - 1)
            match (
                coff
            ) case some then {
                closePos = coff
                clo = ind0.copy
            } case none then {
                return
            }
        }
        this.wrapGroups.append this.edits.length
        if bare then this.edits.append (zfix.Edit byteLo: cs byteHi: cs replacement: "(".string)
        with ait: arguments.iterate do for arg: ait loop {
            match (
                arg
            ) case namedoperation then {
                as9: (tokByteStart
                    lineStart: this.lineStart
                    srcLines: this.lines
                    lineno: arg.lineno
                    colno: arg.colno
                )
                ap9: as9
                match (
                    (nodes.get i: (arg.operation - 1).u64)
                ) case labelvalue then {
                    ap9 = as9 - 1
                } else null
                ws9: wsRunStart src: srcv from: ap9
                this.edits.append (zfix.Edit byteLo: ws9 byteHi: ap9 replacement: ind4.copy)
            } else null
        }
        this.edits.append (zfix.Edit byteLo: closePos byteHi: closePos replacement: clo)
        this.wrapFound = true
        this.wrapStart = line.u64
    }

    # tryWrapParams -- wrap mode: an over-long single-line function signature with >= 2 params breaks
    # its `{ }` param block onto one-param-per-line (the `{ }` already filters eol). Same batch/fixpoint
    # bookkeeping as tryWrapCall; the close `}` is located via the delimiter map, not line-end.
    tryWrapParams: function {:this nodes: List Node parameters: List Node line: u32} is {
        if line.u64 == this.wrapStart then return
        pc: parameters.length
        if pc < 2 then return
        lidx: (line - 1).u64
        if lidx >= this.lines.length then return
        lnt: (this.lines.get i: lidx).copy
        cw: codepointLen s: lnt.stringview
        if cw <= this.wrapWidth.u64 then return
        if (hasHash line: lnt.stringview) then return
        ok: true
        with vit: parameters.iterate do for pm: vit loop {
            match (
                pm
            ) case namedoperation then {
                if pm.lineno != line then ok = false
            } else {
                ok = false
            }
        }
        if ok == false then return
        base: leadingSpaces line: lnt.stringview
        srcOwned: this.source.copy
        srcv: srcOwned.stringview
        p0: u64
        havep0: false
        {
            p0node: parameters.get i: 0
            match (
                p0node
            ) case namedoperation then {
                p0 = (tokByteStart
                    lineStart: this.lineStart
                    srcLines: this.lines
                    lineno: p0node.lineno
                    colno: p0node.colno
                )
                havep0 = true
            } else null
        }
        if havep0 == false then return
        obrace: (wsRunStart src: srcv from: p0) - 1
        bchk: srcv.byteAt i: obrace
        isBrace: false
        match (
            bchk
        ) case some then {
            if bchk == 123 then isBrace = true
        } case none then null
        if isBrace == false then return
        coff: this.delimClose.get key: obrace
        closeB: u64
        match (
            coff
        ) case some then {
            closeB = coff
        } case none then {
            return
        }
        ind4: nlIndent n: (base + 4)
        ind0: nlIndent n: base
        this.wrapGroups.append this.edits.length
        with ait: parameters.iterate do for pm: ait loop {
            match (
                pm
            ) case namedoperation then {
                ps9: (tokByteStart
                    lineStart: this.lineStart
                    srcLines: this.lines
                    lineno: pm.lineno
                    colno: pm.colno
                )
                pp9: ps9
                match (
                    (nodes.get i: (pm.operation - 1).u64)
                ) case labelvalue then {
                    pp9 = ps9 - 1
                } else null
                ws9: wsRunStart src: srcv from: pp9
                this.edits.append (zfix.Edit byteLo: ws9 byteHi: pp9 replacement: ind4.copy)
            } else null
        }
        wsC: wsRunStart src: srcv from: closeB
        this.edits.append (zfix.Edit byteLo: wsC byteHi: closeB replacement: ind0.copy)
        this.wrapFound = true
        this.wrapStart = line.u64
    }

    # checkForWhile -- L004 token tier: a `for` immediately followed by `while`.
    # Re-tokenizes the source (parse-free; immune to strings and comments).
    checkForWhile: function {:this} is {
        srcOwned: this.source.copy
        sv: srcOwned.stringview
        toks: tokenize.scan source: srcOwned.copy
        lineStart: lineStartIndex src: sv
        srcLines: linesOf src: sv
        m: toks.length
        prevFor: false
        i: u64
        for i < m loop {
            t: toks.get :i
            match (
                t.toktype
            ) case wsTok then null case eolTok then null case commentTok then null case forTok then {
                prevFor = true
            } case whileTok then {
                if prevFor then {
                    whileStart: tokByteStart :lineStart :srcLines lineno: t.lineno colno: t.colno
                    condStart: whileStart + t.tokstr.length
                    foundCond: false
                    j: i + 1
                    scanning: true
                    for scanning loop {
                        if j >= m then {
                            scanning = false
                        } else {
                            tj: toks.get i: j
                            triv: false
                            match (
                                tj.toktype
                            ) case wsTok then {
                                triv = true
                            } case eolTok then {
                                triv = true
                            } case commentTok then {
                                triv = true
                            } else null
                            if triv then {
                                j = j + 1
                            } else {
                                condStart = (tokByteStart
                                    :lineStart
                                    :srcLines
                                    lineno: tj.lineno
                                    colno: tj.colno
                                )
                                foundCond = true
                                scanning = false
                            }
                        }
                    }
                    if foundCond then {
                        (this.warnFix
                            code: "L004"
                            msg: "redundant `while`: a for loop's leading condition omits `while`".string
                            line: t.lineno
                            col: t.colno
                            width: t.tokstr.length.u32
                            lo: whileStart
                            hi: condStart
                            repl: "".string
                        )
                    }
                }
                prevFor = false
            } else {
                prevFor = false
            }
            i = i + 1
        }
    }

    # checkColonSpacing -- W003 token tier: exactly one space after a `:` when a value follows
    # on the same line. The `:label` shorthand (a colon immediately before a LABELPRE, e.g.
    # `:this`) and a colon at end of line (value continues below) are left alone. Walks the raw
    # token stream, so colons inside strings and comments are never touched.
    checkColonSpacing: function {:this} is {
        srcOwned: this.source.copy
        sv: srcOwned.stringview
        toks: tokenize.scan source: srcOwned.copy
        lineStart: lineStartIndex src: sv
        srcLines: linesOf src: sv
        m: toks.length
        i: u64
        for i < m loop {
            t: toks.get :i
            isColon: false
            match (
                t.toktype
            ) case colonTok then {
                isColon = true
            } else null
            if isColon then {
                cl: t.lineno
                cc: t.colno
                shorthand: false
                if (i + 1) < m then {
                    t1: toks.get i: (i + 1)
                    match (
                        t1.toktype
                    ) case labelPreTok then {
                        shorthand = true
                    } else null
                }
                if (shorthand) == false then {
                    j: i + 1
                    foundNxt: false
                    nxtContent: false
                    nl: u32
                    nc: u32
                    for j < m loop {
                        tj: toks.get i: j
                        isWs: false
                        isTerm: false
                        match (
                            tj.toktype
                        ) case wsTok then {
                            isWs = true
                        } case eolTok then {
                            isTerm = true
                        } case eofTok then {
                            isTerm = true
                        } case commentTok then {
                            isTerm = true
                        } case parenCloseTok then {
                            isTerm = true
                        } case braceCloseTok then {
                            isTerm = true
                        } case semicolonTok then {
                            isTerm = true
                        } else null
                        if isWs then {
                            j = j + 1
                        } else {
                            foundNxt = true
                            nl = tj.lineno
                            nc = tj.colno
                            nxtContent = (isTerm) == false
                            break
                        }
                    }
                    if foundNxt when nxtContent when (nl == cl) then {
                        colByteStart: tokByteStart :lineStart :srcLines lineno: cl colno: cc
                        colEnd: colByteStart + 1
                        valStart: tokByteStart :lineStart :srcLines lineno: nl colno: nc
                        doFix: false
                        if valStart == colEnd then {
                            doFix = true
                        } else if valStart == (colEnd + 1) then {
                            bo: sv.byteAt i: colEnd
                            issp: false
                            match (
                                bo
                            ) case some then {
                                if bo == 32 then issp = true
                            } case none then null
                            if (issp) == false then doFix = true
                        } else if valStart > colEnd then doFix = true
                        if doFix then {
                            (this.warnFix
                                code: "W003"
                                msg: "expected a single space after `:`".string
                                line: cl
                                col: cc
                                width: 1
                                lo: colEnd
                                hi: valStart
                                repl: " ".string
                            )
                        }
                    }
                }
            }
            i = i + 1
        }
    }

    # walk -- traversal collecting embedded parse errors as diagnostics, recursing
    # every child (all 29 arms, mirroring zast.printNodeCanonical).
    # walkProgram / walkCasingProgram -- root entries: the table rides
    # inside the program node.
    walkProgram: function {:this prog: Node} is {
        match (
            prog
        ) case program then {
            wpi9: u64
            wpn9: prog.units.length
            for wpi9 < wpn9 loop {
                wpid9: prog.units.get i: wpi9
                this.walk nodes: prog.nodes n: (prog.nodes.get i: (wpid9 - 1).u64)
                wpi9 = wpi9 + 1
            }
        } else null
    }

    walkCasingProgram: function {:this prog: Node} is {
        match (
            prog
        ) case program then {
            wci9: u64
            wcn9: prog.units.length
            for wci9 < wcn9 loop {
                wcid9: prog.units.get i: wci9
                this.walkCasing nodes: prog.nodes n: (prog.nodes.get i: (wcid9 - 1).u64)
                wci9 = wci9 + 1
            }
        } else null
    }

    walk: function {:this nodes: List Node n: Node} is {
        match (
            n
        ) case error then {
            d: (zdiag.errorDiag
                errv: n.err
                fsno: n.fsno
                lineno: n.lineno
                colno: n.colno
                width: n.width
                msg: n.msg.copy
                note: n.note.copy
                hint: n.hint.copy
            )
            this.diags.append d
        } case atomid then null case labelvalue then null case stringchunk then null case binop then {
            this.walk :nodes n: n.lhs
            this.walk :nodes n: n.operator
            this.walk :nodes n: n.rhs
        } case atomstring then {
            spit: n.stringparts.iterate
            for part: spit loop this.walk :nodes n: part
        } case dottedpath then {
            this.walk :nodes n: n.parent
            this.walk :nodes n: n.child
        } case call then {
            if this.wrapWidth > 0 then {
                this.tryWrapCall :nodes arguments: n.arguments line: n.lineno col: n.colno
            } else {
                this.checkElide callable: n.callable arguments: n.arguments
                this.checkCollapseName :nodes arguments: n.arguments
            }
            this.walk :nodes n: n.callable
            ait: n.arguments.iterate
            for arg: ait loop this.walk :nodes n: arg
        } case typeofexpr then {
            this.walk :nodes n: n.source
        } case namedoperation then {
            this.walk :nodes n: (nodes.get i: (n.operation - 1).u64)
        } case datablock then {
            elit: n.elements.iterate
            for el: elit loop this.walk :nodes n: el
            this.walkOpt :nodes o: n.outType
        } case yieldexpr then {
            this.walk :nodes n: n.expr
        } case statement then {
            stit: n.statements.iterate
            for stln: stit loop this.walk :nodes n: stln
        } case statementline then {
            this.walk :nodes n: n.statementline
        } case assignment then {
            if this.funcDepth > 0 then this.tryBareZeroInit value: n.value
            this.walk :nodes n: n.value
        } case reassignment then {
            this.walk :nodes n: n.topath
            this.walk :nodes n: n.value
        } case swapstmt then {
            this.walk :nodes n: n.lhs
            this.walk :nodes n: n.rhs
        } case expression then {
            this.walk :nodes n: n.expression
        } case ifexpr then {
            this.checkEmpty elseOpt: n.elseclause clauses: n.clauses
            this.checkBracesIf clauses: n.clauses elseOpt: n.elseclause ln: n.lineno
            this.checkChainBodyBreak clauses: n.clauses elseOpt: n.elseclause
            clit: n.clauses.iterate
            for cl: clit loop this.walk :nodes n: cl
            this.walkOpt :nodes o: n.elseclause
        } case ifclause then {
            coit: n.conditions.iterate
            for co: coit loop this.walk :nodes n: co
            this.walk :nodes n: n.statement
        } case forexpr then {
            this.checkBracesFor bodyOpt: n.body
            fcit: n.conditions.iterate
            for fc: fcit loop this.walk :nodes n: fc
            this.walkOpt :nodes o: n.body
            fpit: n.postconditions.iterate
            for fp: fpit loop this.walk :nodes n: fp
        } case doexpr then {
            this.walk :nodes n: n.statement
        } case withexpr then {
            this.walk :nodes n: n.value
            this.walk :nodes n: n.body
        } case caseexpr then {
            this.checkBracesMatch clauses: n.clauses elseOpt: n.elseclause ln: n.lineno
            this.checkChainBodyBreak clauses: n.clauses elseOpt: n.elseclause
            this.checkNullArms clauses: n.clauses elseOpt: n.elseclause
            this.walk :nodes n: n.subject
            ccit: n.clauses.iterate
            for cc: ccit loop this.walk :nodes n: cc
            this.walkOpt :nodes o: n.elseclause
        } case caseclause then {
            this.walk :nodes n: n.matcharm
            this.walk :nodes n: n.statement
        } case functiondef then {
            if this.wrapWidth > 0 then (this.tryWrapParams
                :nodes
                parameters: n.parameters
                line: n.lineno
            )
            this.walkOpt :nodes o: n.returntype
            pmit: n.parameters.iterate
            for pm: pmit loop this.walk :nodes n: pm
            this.funcDepth = this.funcDepth + 1
            this.walkOpt :nodes o: n.body
            this.funcDepth = this.funcDepth - 1
            fait: n.asItems.iterate
            for fam: fait loop this.walk :nodes n: fam
        } case objectdef then {
            isit: n.isItems.iterate
            for oim: isit loop this.walk :nodes n: oim
            asit: n.asItems.iterate
            for oam: asit loop this.walk :nodes n: oam
        } case unitdef then {
            udit: n.body.iterate
            for ubmId9: udit loop this.walk :nodes n: (nodes.get i: (ubmId9 - 1).u64)
        } case program then {
            puit: n.units.iterate
            for pumId9: puit loop this.walk :nodes n: (nodes.get i: (pumId9 - 1).u64)
        }
    }

    # walkCasing -- opt-in (L009): recurse to every type definition and check the member
    # casing of `variant` / `union` declarations. Runs only under `zl lint --casing`.
    walkCasing: function {:this nodes: List Node n: Node} is {
        match (
            n
        ) case program then {
            it: n.units.iterate
            for uId9: it loop this.walkCasing :nodes n: (nodes.get i: (uId9 - 1).u64)
        } case unitdef then {
            it: n.body.iterate
            for bId9: it loop this.walkCasing :nodes n: (nodes.get i: (bId9 - 1).u64)
        } case namedoperation then {
            this.walkCasing :nodes n: (nodes.get i: (n.operation - 1).u64)
        } case objectdef then {
            this.checkMemberCasing :nodes kind: n.kind items: n.isItems
        } else null
    }

    # checkMemberCasing -- flag each variant/union arm whose name starts with an uppercase
    # letter (not lowerCamelCase), with a suggested rename (see casingSuggest/casingMessage).
    checkMemberCasing: function {:this nodes: List Node kind: zast.nodetype items: (List Node)} is {
        isVU: false
        if kind == zast.nodetype.variantDef then isVU = true
        if kind == zast.nodetype.unionDef then isVU = true
        if isVU == false then return
        it: items.iterate
        for item: it loop {
            match (
                item
            ) case namedoperation then {
                isTypeRef: false
                match (
                    (nodes.get i: (item.operation - 1).u64)
                ) case labelvalue then {
                    isTypeRef = true
                } else null
                nm: optName o: item.name
                fb: nm.stringview.byteAt i: 0
                up: false
                match (
                    fb
                ) case some then {
                    if fb >= 65 when (fb <= 90) then up = true
                } case none then null
                if up when (isTypeRef == false) then {
                    sug: casingSuggest name: nm.stringview
                    (this.warn
                        code: "L009"
                        msg: (casingMessage orig: nm.stringview sug: sug.stringview)
                        line: item.lineno
                        col: item.colno
                        width: nm.length.u32
                    )
                }
            } else null
        }
    }

    # checkRedundantParens -- L007: a paren wrapping an ENTIRE `if` condition, when the condition
    # does not require it. A named-argument-call condition needs the parens (its args are greedy and
    # would swallow `then`), detected as a top-level colon inside the paren; those and sub-expression
    # precedence parens are left alone. Removes the `(` and `)`.
    # checkNullArms -- L010 over a match's arm and else bodies.
    checkNullArms: function {:this clauses: (List Node) elseOpt: (Option Node)} is {
        ccit: clauses.iterate
        for cc: ccit loop {
            match (
                cc
            ) case caseclause then {
                this.tryNullBody body: cc.statement
            } else null
        }
        match (
            elseOpt
        ) case some then {
            this.tryNullBody body: elseOpt
        } case none then null
    }

    # tryBareZeroInit -- L011: a zero/empty binding initializer written as a
    # literal (`"".string`, `0.u64`) where the bare type name constructs the
    # same value. Function-body binding initializers only: record/class
    # fields and parameter defaults keep literal values (a bare type name
    # there is an annotation), and reassignment right-hand sides prefer the
    # coerced bare literal (`x = 0`). The replacement span is byte-verified
    # against the expected source spelling before any edit is recorded.
    tryBareZeroInit: function {:this value: Node} is {
        match (
            value
        ) case expression then {
            this.tryBareZeroInit value: value.expression
        } case statementline then {
            this.tryBareZeroInit value: value.statementline
        } case statement then {
            if value.statements.length == 1 then {
                s0: value.statements.get i: 0
                this.tryBareZeroInit value: s0
            }
        } case dottedpath then {
            repl: bareZeroTypeName n: value.child
            if repl.length == 0 then return
            ptext: bareZeroParentText n: value.parent
            if ptext.length == 0 then return
            isStr9: ptext.stringview == "\"\""
            isStrRepl9: repl.stringview == "String"
            if isStr9 when (isStrRepl9) == false then return
            if (isStr9) == false when isStrRepl9 then return
            pin9: nodeInfoOf n: value.parent
            cin9: nodeInfoOf n: value.child
            if pin9.line != cin9.line then return
            srcOwned: this.source.copy
            srcv: srcOwned.stringview
            lo: (tokByteStart
                lineStart: this.lineStart
                srcLines: this.lines
                lineno: pin9.line
                colno: pin9.col
            )
            cs9: (tokByteStart
                lineStart: this.lineStart
                srcLines: this.lines
                lineno: cin9.line
                colno: cin9.col
            )
            hi: cs9 + repl.length
            if hi > srcv.length then return
            ctext9: repl.copy
            if isStr9 then ctext9 = "string".string
            expect9: "\{ptext}.\{ctext9}"
            actual9: srcv.substring from: lo to: hi
            if actual9 != expect9.stringview then return
            wm9: "zero/empty initializer: write the bare type name `\{repl}`"
            (this.warnFix
                code: "L011"
                msg: wm9
                line: pin9.line
                col: pin9.col
                width: (hi - lo).u32
                :lo
                :hi
                :repl
            )
        } else null
    }

    # tryNullBody -- L010: an empty `{ }` match arm/else body reads better as
    # the bare `null` body. Replaces the brace span (including any interior
    # newlines) with `null` when the merged line stays inside the wrap width;
    # commented empties are left alone. A body already written `null` starts
    # at the `n` byte, not `{`, so it never re-fires.
    tryNullBody: function {:this body: Node} is {
        match (
            body
        ) case statement then {
            if body.statements.length != 0 then return
            srcOwned: this.source.copy
            srcv: srcOwned.stringview
            openByte: (tokByteStart
                lineStart: this.lineStart
                srcLines: this.lines
                lineno: body.lineno
                colno: body.colno
            )
            ob: srcv.byteAt i: openByte
            isBrace: false
            match (
                ob
            ) case some then {
                if ob == 123 then isBrace = true
            } case none then null
            if isBrace == false then return
            coff: this.delimClose.get key: openByte
            closeByte: u64
            match (
                coff
            ) case some then {
                closeByte = coff
            } case none then {
                return
            }
            if (this.bracesBlocked :openByte :closeByte) then return
            closeLine: (byteToLine
                lineStart: this.lineStart
                off: closeByte
                nLines: this.lines.length
            )
            lineEndB: srcv.length
            if (closeLine + 1) < this.lineStart.length then {
                lineEndB = (this.lineStart.get i: (closeLine + 1)) - 1
            }
            tailLen: lineEndB - (closeByte + 1)
            limit: 100.u64
            if this.wrapWidth > 0 then limit = this.wrapWidth.u64
            resultLen: (body.colno.u64 - 1) + 4 + tailLen
            if resultLen > limit then return
            (this.warnFix
                code: "L010"
                msg: "empty match body: write `null`".string
                line: body.lineno
                col: body.colno
                width: 1
                lo: openByte
                hi: (closeByte + 1)
                repl: "null".string
            )
        } else null
    }

    # tryDebrace -- L008: strip the `{ }` around a single-statement clause `body`
    # when it de-braces safely and the result fits on one line. `collapse` is true
    # for a terminal single-clause body (for-loop, if-without-else), which may pull
    # a multi-line body onto the keyword line; false for a multi-clause construct
    # already proven to sit on one line, where stripping only shortens it.
    tryDebrace: function {:this body: Node collapse: bool} is {
        match (
            body
        ) case statement then {
            if body.statements.length != 1 then return
            sl0: body.statements.get i: 0
            match (
                sl0
            ) case statementline then {
                if (debraceEligible n: sl0.statementline) == false then return
                srcOwned: this.source.copy
                srcv: srcOwned.stringview
                openByte: (tokByteStart
                    lineStart: this.lineStart
                    srcLines: this.lines
                    lineno: body.lineno
                    colno: body.colno
                )
                ob: srcv.byteAt i: openByte
                isBrace: false
                match (
                    ob
                ) case some then {
                    if ob == 123 then isBrace = true
                } case none then null
                if isBrace == false then return
                coff: this.delimClose.get key: openByte
                closeByte: u64
                match (
                    coff
                ) case some then {
                    closeByte = coff
                } case none then {
                    return
                }
                if (this.bracesBlocked :openByte :closeByte) then return
                firstInner: (tokByteStart
                    lineStart: this.lineStart
                    srcLines: this.lines
                    lineno: sl0.lineno
                    colno: sl0.colno
                )
                tailStart: wsRunStartNL src: srcv from: closeByte
                cEndLine: (byteToLine
                    lineStart: this.lineStart
                    off: (tailStart - 1)
                    nLines: this.lines.length
                ) + 1
                if sl0.lineno.u64 != cEndLine then return
                closeLine: (byteToLine
                    lineStart: this.lineStart
                    off: closeByte
                    nLines: this.lines.length
                ) + 1
                sameLine: body.lineno.u64 == closeLine
                doStrip: false
                if collapse == false then {
                    doStrip = true
                } else if sameLine then {
                    doStrip = true
                } else {
                    limit: 100.u64
                    if this.wrapWidth > 0 then limit = this.wrapWidth.u64
                    resultLen: (body.colno.u64 - 1) + (tailStart - firstInner)
                    if resultLen <= limit then doStrip = true
                }
                if doStrip == false then return
                (this.warn
                    code: "L008"
                    msg: "redundant braces around a single-statement body".string
                    line: body.lineno
                    col: body.colno
                    width: 1
                )
                this.edits.append (zfix.Edit
                    byteLo: openByte
                    byteHi: firstInner
                    replacement: "".string
                )
                this.edits.append (zfix.Edit
                    byteLo: tailStart
                    byteHi: (closeByte + 1)
                    replacement: "".string
                )
            } else null
        } else null
    }

    # bracesBlocked -- true when the token span strictly between the open and close
    # brace bytes holds a top-level colon (a labelled call or binding, which cannot
    # lose its braces) or a comment (which a one-line collapse would swallow).
    bracesBlocked: function {:this openByte: u64 closeByte: u64} out bool is {
        m: this.fastToks.length
        depth: i64
        blocked: false
        i: u64
        for i < m loop {
            t: this.fastToks.get :i
            tb: (tokByteStart
                lineStart: this.lineStart
                srcLines: this.lines
                lineno: t.lineno
                colno: t.colno
            )
            if tb >= closeByte then break
            if tb > openByte then {
                match (
                    t.toktype
                ) case parenOpenTok then {
                    depth = depth + 1
                } case braceOpenTok then {
                    depth = depth + 1
                } case parenCloseTok then {
                    depth = depth - 1
                } case braceCloseTok then {
                    depth = depth - 1
                } case colonTok then {
                    if depth == 0 then blocked = true
                } case commentTok then {
                    blocked = true
                } else null
            }
            i = i + 1
        }
        return blocked
    }

    # checkBracesIf -- L008 entry for an `if`: a terminal single-clause `if ... then`
    # (no else) may collapse its then-body; an `if` with an else or extra clauses
    # de-braces only when the whole construct already sits on one line. Unit-level
    # `if`s (funcDepth == 0) keep their braces -- braceless branches are unsafe where
    # EOL filtering is on.
    checkBracesIf: function {:this clauses: (List Node) elseOpt: (Option Node) ln: u32} is {
        if this.funcDepth == 0 then return
        hasElse: false
        match (
            elseOpt
        ) case some then {
            hasElse = true
        } case none then null
        if (hasElse == false) when (clauses.length == 1) then {
            c0: clauses.get i: 0
            match (
                c0
            ) case ifclause then {
                this.tryDebrace body: c0.statement collapse: true
            } else null
            return
        }
        if (clauseBodiesOnLine :clauses :elseOpt :ln) == false then return
        cit: clauses.iterate
        for cl: cit loop {
            match (
                cl
            ) case ifclause then {
                this.tryDebrace body: cl.statement collapse: false
            } else null
        }
        match (
            elseOpt
        ) case some then {
            this.tryDebrace body: elseOpt collapse: false
        } case none then null
    }

    # checkBracesMatch -- L008 entry for a `match`: always multi-clause, so its arm
    # and else braces are stripped only when the whole match already sits on one line.
    checkBracesMatch: function {:this clauses: (List Node) elseOpt: (Option Node) ln: u32} is {
        if this.funcDepth == 0 then return
        if (caseBodiesOnLine :clauses :elseOpt :ln) == false then return
        cit: clauses.iterate
        for cl: cit loop {
            match (
                cl
            ) case caseclause then {
                this.tryDebrace body: cl.statement collapse: false
            } else null
        }
        match (
            elseOpt
        ) case some then {
            this.tryDebrace body: elseOpt collapse: false
        } case none then null
    }

    # checkChainBodyBreak -- fmt: in a multi-line `match` or `if`, break any arm/clause
    # body whose first statement clings to the opening `{` onto its own line.
    checkChainBodyBreak: function {:this clauses: (List Node) elseOpt: (Option Node)} is {
        if this.funcDepth == 0 then return
        cit: clauses.iterate
        for cl: cit loop {
            match (
                cl
            ) case caseclause then {
                this.forceBodyBreak body: cl.statement
            } case ifclause then {
                this.forceBodyBreak body: cl.statement
            } else null
        }
        match (
            elseOpt
        ) case some then {
            this.forceBodyBreak body: elseOpt
        } case none then null
    }

    # forceBodyBreak -- a braced body whose closing `}` is not on the opening `{` line (a
    # multi-line clause) starts its body on the next line at base+4; emit that edit when the
    # first statement still shares the `{` line AND is itself single-line. One-line bodies are
    # left to L008; a multi-line first statement is skipped (re-indenting it is out of scope).
    forceBodyBreak: function {:this body: Node} is {
        match (
            body
        ) case statement then {
            if body.statements.length == 0 then return
            openByte: (tokByteStart
                lineStart: this.lineStart
                srcLines: this.lines
                lineno: body.lineno
                colno: body.colno
            )
            coff: this.delimClose.get key: openByte
            closeByte: u64
            match (
                coff
            ) case some then {
                closeByte = coff
            } case none then {
                return
            }
            closeLine: (byteToLine
                lineStart: this.lineStart
                off: closeByte
                nLines: this.lines.length
            ) + 1
            if body.lineno.u64 == closeLine then return
            sl0: body.statements.get i: 0
            match (
                sl0
            ) case statementline then {
                if sl0.lineno != body.lineno then return
                firstEnd: (closeLine - 1)
                if body.statements.length > 1 then {
                    sl1: body.statements.get i: 1
                    match (
                        sl1
                    ) case statementline then {
                        firstEnd = (sl1.lineno.u64 - 1)
                    } else null
                }
                if firstEnd > body.lineno.u64 then return
                firstInner: (tokByteStart
                    lineStart: this.lineStart
                    srcLines: this.lines
                    lineno: sl0.lineno
                    colno: sl0.colno
                )
                oline: (byteToLine
                    lineStart: this.lineStart
                    off: openByte
                    nLines: this.lines.length
                )
                lt: this.lines.get i: oline
                base: (leadingSpaces line: lt.stringview)
                this.edits.append (zfix.Edit
                    byteLo: (openByte + 1)
                    byteHi: firstInner
                    replacement: (nlIndent n: (base + 4))
                )
            } else null
        } else null
    }

    # checkBracesFor -- L008 entry for a `for ... loop`: a terminal single-clause
    # body that may collapse onto the loop header.
    checkBracesFor: function {:this bodyOpt: (Option Node)} is {
        if this.funcDepth == 0 then return
        match (
            bodyOpt
        ) case some then {
            this.tryDebrace body: bodyOpt collapse: true
        } case none then null
    }

    checkRedundantParens: function {:this} is {
        srcOwned: this.source.copy
        sv: srcOwned.stringview
        toks: tokenize.scan source: srcOwned.copy
        lineStart: lineStartIndex src: sv
        srcLines: linesOf src: sv
        m: toks.length
        i: u64
        for i < m loop {
            t: toks.get :i
            isIf: false
            match (
                t.toktype
            ) case ifTok then {
                isIf = true
            } else null
            if isIf then {
                fs: i + 1
                fsScan: true
                for fsScan loop {
                    if fs >= m then {
                        fsScan = false
                    } else {
                        tf: toks.get i: fs
                        tv: false
                        match (
                            tf.toktype
                        ) case wsTok then {
                            tv = true
                        } case eolTok then {
                            tv = true
                        } case commentTok then {
                            tv = true
                        } else null
                        if tv then {
                            fs = fs + 1
                        } else {
                            fsScan = false
                        }
                    }
                }
                isOpen: false
                if fs < m then {
                    tf2: toks.get i: fs
                    match (
                        tf2.toktype
                    ) case parenOpenTok then {
                        isOpen = true
                    } else null
                }
                if isOpen then {
                    depth: 1.u64
                    j: fs + 1
                    matchIdx: m
                    hasColon: false
                    mScan: true
                    for mScan loop {
                        if j >= m then {
                            mScan = false
                        } else {
                            tj: toks.get i: j
                            kind: u32
                            match (
                                tj.toktype
                            ) case parenOpenTok then {
                                kind = 1
                            } case parenCloseTok then {
                                kind = 2
                            } case colonTok then {
                                kind = 3
                            } else null
                            if kind == 1 then {
                                depth = depth + 1
                            } else if kind == 2 then {
                                depth = depth - 1
                                if depth == 0 then {
                                    matchIdx = j
                                    mScan = false
                                }
                            } else if kind == 3 then {
                                if depth == 1 then hasColon = true
                            }
                            if mScan then j = j + 1
                        }
                    }
                    thenOk: false
                    if matchIdx < m then {
                        ns: matchIdx + 1
                        nScan: true
                        for nScan loop {
                            if ns >= m then {
                                nScan = false
                            } else {
                                tn: toks.get i: ns
                                tv2: false
                                match (
                                    tn.toktype
                                ) case wsTok then {
                                    tv2 = true
                                } case eolTok then {
                                    tv2 = true
                                } case commentTok then {
                                    tv2 = true
                                } else null
                                if tv2 then {
                                    ns = ns + 1
                                } else {
                                    nScan = false
                                }
                            }
                        }
                        if ns < m then {
                            tn2: toks.get i: ns
                            match (
                                tn2.toktype
                            ) case thenTok then {
                                thenOk = true
                            } else null
                        }
                    }
                    if thenOk when (hasColon == false) then {
                        to: toks.get i: fs
                        tc: toks.get i: matchIdx
                        oStart: tokByteStart :lineStart :srcLines lineno: to.lineno colno: to.colno
                        cStart: tokByteStart :lineStart :srcLines lineno: tc.lineno colno: tc.colno
                        (this.warn
                            code: "L007"
                            msg: "redundant parentheses around the condition".string
                            line: to.lineno
                            col: to.colno
                            width: 1
                        )
                        this.edits.append (zfix.Edit
                            byteLo: oStart
                            byteHi: (oStart + 1)
                            replacement: "".string
                        )
                        this.edits.append (zfix.Edit
                            byteLo: cStart
                            byteHi: (cStart + 1)
                            replacement: "".string
                        )
                    }
                }
            }
            i = i + 1
        }
    }

    # runFastChecks -- the fast-tier passes: parse-error/AST rules over `n`, then the token and
    # line rules over the source.
    runFastChecks: function {:this n: Node} is {
        this.lineStart = lineStartIndex src: this.source.stringview
        this.delimClose = (buildDelimMap
            src: this.source.stringview
            lineStart: this.lineStart
            srcLines: this.lines
        )
        this.fastToks = tokenize.scan source: this.source.copy
        this.walkProgram prog: n
        this.checkForWhile
        this.checkTrailingWs
        this.checkFinalNewline
        this.checkColonSpacing
        this.checkBlankLines
        this.checkRedundantParens
    }

    # sortEditsInPlace -- reorder the collected edits by byteLo so the applier and the diff
    # renderer see sorted, overlap-resolvable input.
    sortEditsInPlace: function {:this} is {
        se: sortEdits edits: this.edits
        this.edits = se
    }

    # emitSuf -- L005: a redundant numeric suffix. The safe fix removes the `.` and the type
    # name (e.g. `5.i32` -> `5`); the context already pins the type.
    emitSuf: function {:this uname: StringView ln: u32 col: u32 tname: StringView} is {
        srcOwned: this.source.copy
        sv: srcOwned.stringview
        lineStart: lineStartIndex src: sv
        srcLines: linesOf src: sv
        byteStart: tokByteStart :lineStart :srcLines lineno: ln colno: col
        lo: byteStart
        if byteStart > 0 then lo = byteStart - 1
        hi: byteStart + tname.length
        (this.warnFix
            code: "L005"
            msg: "redundant numeric suffix `.\{tname}`"
            line: ln
            :col
            width: tname.length.u32
            :lo
            :hi
            repl: "".string
        )
    }

    # sufBinop -- a binop operand whose numeric suffix the other (non-literal, same-type)
    # operand makes redundant.
    sufBinop: function {:this lhs: Node rhs: Node uname: StringView st: zenv.ZSymbolTable} is {
        ls: operandSuffix n: lhs
        if ls.tname.length > 0 when (isAnchor n: rhs tname: ls.tname.stringview :st) then {
            this.emitSuf :uname ln: ls.line col: ls.col tname: ls.tname.stringview
        }
        rs: operandSuffix n: rhs
        if rs.tname.length > 0 when (isAnchor n: lhs tname: rs.tname.stringview :st) then {
            this.emitSuf :uname ln: rs.line col: rs.col tname: rs.tname.stringview
        }
    }

    # sufReassign -- a reassignment value whose suffix the target's type fixes.
    sufReassign: function {:this topath: Node value: Node uname: StringView st: zenv.ZSymbolTable} is {
        vs: operandSuffix n: value
        if vs.tname.length > 0 then {
            tn: typeNameOfNode n: topath :st
            if tn.length > 0 when (tn.stringview == vs.tname.stringview) then {
                this.emitSuf :uname ln: vs.line col: vs.col tname: vs.tname.stringview
            }
        }
    }

    # sufNamedArg -- a named call/constructor argument whose suffix the parameter / field type
    # fixes.
    sufNamedArg: function {:this nodes: List Node arg: Node calleeType: u64 uname: StringView st: zenv.ZSymbolTable} is {
        match (
            arg
        ) case namedoperation then {
            an: optName o: arg.name
            if an.length > 0 then {
                s9: operandSuffix n: (nodes.get i: (arg.operation - 1).u64)
                if s9.tname.length > 0 then {
                    pto: st.typing.childOf parentTypeId: calleeType name: an.stringview
                    match (
                        pto
                    ) case some then {
                        ptn: nameOfTypeId tid: pto :st
                        if ptn.stringview == s9.tname.stringview then {
                            this.emitSuf :uname ln: s9.line col: s9.col tname: s9.tname.stringview
                        }
                    } case none then null
                }
            }
        } else null
    }

    # sufNamedArgReturn -- a return value whose suffix the enclosing function's return type
    # fixes.
    sufNamedArgReturn: function {:this nodes: List Node arg: Node rtName: StringView uname: StringView} is {
        match (
            arg
        ) case namedoperation then {
            s9: operandSuffix n: (nodes.get i: (arg.operation - 1).u64)
            if s9.tname.length > 0 when (s9.tname.stringview == rtName) then {
                this.emitSuf :uname ln: s9.line col: s9.col tname: s9.tname.stringview
            }
        } else {
            s8: operandSuffix n: arg
            if s8.tname.length > 0 when (s8.tname.stringview == rtName) then {
                this.emitSuf :uname ln: s8.line col: s8.col tname: s8.tname.stringview
            }
        }
    }

    # sufCall -- redundant suffixes in a call: a `return` uses the enclosing function's return
    # type; otherwise each named argument's parameter type.
    sufCall: function {:this nodes: List Node callNid: u32 callable: Node arguments: List Node uname: StringView st: zenv.ZSymbolTable funcret: Option Node} is {
        ck: st.typing.callKind.get key: callNid.u64
        isRet: false
        match (
            ck
        ) case some then {
            match (
                ck
            ) case returnCall then {
                isRet = true
            } else null
        } case none then null
        if isRet then {
            rtName: typeNameOfOpt o: funcret :st
            if rtName.length > 0 then {
                ait: arguments.iterate
                for a: ait loop (this.sufNamedArgReturn
                    :nodes
                    arg: a
                    rtName: rtName.stringview
                    :uname
                )
            }
        } else {
            cInfo: nodeInfoOf n: callable
            co: st.typing.nodeType.get key: cInfo.id.u64
            match (
                co
            ) case some then {
                ait: arguments.iterate
                for a: ait loop this.sufNamedArg :nodes arg: a calleeType: co :uname :st
            } case none then null
        }
    }

    # walkSuf -- preorder over the subtree running the typecheck-based suffix check, threading
    # the enclosing function's return type for `return`s.
    walkSuf: function {:this nodes: List Node n: Node uname: StringView st: zenv.ZSymbolTable funcret: Option Node} is {
        match (
            n
        ) case error then null case atomid then null case labelvalue then null case stringchunk then null case binop then {
            this.sufBinop lhs: n.lhs rhs: n.rhs :uname :st
            this.walkSuf :nodes n: n.lhs :uname :st :funcret
            this.walkSuf :nodes n: n.operator :uname :st :funcret
            this.walkSuf :nodes n: n.rhs :uname :st :funcret
        } case atomstring then {
            iter: n.stringparts.iterate
            for part: iter loop this.walkSuf :nodes n: part :uname :st :funcret
        } case dottedpath then {
            this.walkSuf :nodes n: n.parent :uname :st :funcret
            this.walkSuf :nodes n: n.child :uname :st :funcret
        } case call then {
            (this.sufCall :nodes
                callNid: n.nodeid
                callable: n.callable
                arguments: n.arguments
                :uname
                :st
                :funcret
            )
            this.walkSuf :nodes n: n.callable :uname :st :funcret
            argiter: n.arguments.iterate
            for arg: argiter loop this.walkSuf :nodes n: arg :uname :st :funcret
        } case typeofexpr then {
            this.walkSuf :nodes n: n.source :uname :st :funcret
        } case namedoperation then {
            this.walkSuf :nodes n: (nodes.get i: (n.operation - 1).u64) :uname :st :funcret
        } case datablock then {
            eiter: n.elements.iterate
            for el: eiter loop this.walkSuf :nodes n: el :uname :st :funcret
            this.walkSufOpt :nodes o: n.outType :uname :st :funcret
        } case yieldexpr then {
            this.walkSuf :nodes n: n.expr :uname :st :funcret
        } case statement then {
            siter: n.statements.iterate
            for sln: siter loop this.walkSuf :nodes n: sln :uname :st :funcret
        } case statementline then {
            this.walkSuf :nodes n: n.statementline :uname :st :funcret
        } case assignment then {
            this.walkSuf :nodes n: n.value :uname :st :funcret
        } case reassignment then {
            this.sufReassign topath: n.topath value: n.value :uname :st
            this.walkSuf :nodes n: n.topath :uname :st :funcret
            this.walkSuf :nodes n: n.value :uname :st :funcret
        } case swapstmt then {
            this.walkSuf :nodes n: n.lhs :uname :st :funcret
            this.walkSuf :nodes n: n.rhs :uname :st :funcret
        } case expression then {
            this.walkSuf :nodes n: n.expression :uname :st :funcret
        } case ifexpr then {
            clit: n.clauses.iterate
            for cl: clit loop this.walkSuf :nodes n: cl :uname :st :funcret
            this.walkSufOpt :nodes o: n.elseclause :uname :st :funcret
        } case ifclause then {
            coit: n.conditions.iterate
            for co: coit loop this.walkSuf :nodes n: co :uname :st :funcret
            this.walkSuf :nodes n: n.statement :uname :st :funcret
        } case forexpr then {
            fcit: n.conditions.iterate
            for fc: fcit loop this.walkSuf :nodes n: fc :uname :st :funcret
            this.walkSufOpt :nodes o: n.body :uname :st :funcret
            fpit: n.postconditions.iterate
            for fp: fpit loop this.walkSuf :nodes n: fp :uname :st :funcret
        } case doexpr then {
            this.walkSuf :nodes n: n.statement :uname :st :funcret
        } case withexpr then {
            this.walkSuf :nodes n: n.value :uname :st :funcret
            this.walkSuf :nodes n: n.body :uname :st :funcret
        } case caseexpr then {
            this.walkSuf :nodes n: n.subject :uname :st :funcret
            ccit: n.clauses.iterate
            for cc: ccit loop this.walkSuf :nodes n: cc :uname :st :funcret
            this.walkSufOpt :nodes o: n.elseclause :uname :st :funcret
        } case caseclause then {
            this.walkSuf :nodes n: n.matcharm :uname :st :funcret
            this.walkSuf :nodes n: n.statement :uname :st :funcret
        } case functiondef then {
            this.walkSufRet :nodes ret: n.returntype :uname :st
            piter: n.parameters.iterate
            for pm: piter loop this.walkSuf :nodes n: pm :uname :st funcret: n.returntype
            this.walkSufOpt :nodes o: n.body :uname :st funcret: n.returntype
            faiter: n.asItems.iterate
            for fam: faiter loop this.walkSuf :nodes n: fam :uname :st funcret: n.returntype
        } case objectdef then {
            oiiter: n.isItems.iterate
            for oim: oiiter loop this.walkSuf :nodes n: oim :uname :st :funcret
            oaiter: n.asItems.iterate
            for oam: oaiter loop this.walkSuf :nodes n: oam :uname :st :funcret
        } case unitdef then {
            ubiter: n.body.iterate
            for ubmId9: ubiter loop (this.walkSuf
                :nodes
                n: (nodes.get i: (ubmId9 - 1).u64)
                :uname
                :st
                :funcret
            )
        } case program then {
            puiter: n.units.iterate
            for pumId9: puiter loop (this.walkSuf
                :nodes
                n: (nodes.get i: (pumId9 - 1).u64)
                :uname
                :st
                :funcret
            )
        }
    }

    # walkSufOpt -- run the suffix check on an optional child node.
    walkSufOpt: function {:this nodes: List Node o: Option Node uname: StringView st: zenv.ZSymbolTable funcret: Option Node} is {
        match (
            o
        ) case some then {
            this.walkSuf :nodes n: o :uname :st :funcret
        } case none then null
    }

    # a functiondef returntype doubles as its own funcret: this frame lets
    # the two arguments share one root without aliasing one source path
    walkSufRet: function {:this nodes: List Node ret: Option Node uname: StringView st: zenv.ZSymbolTable} is {
        this.walkSufOpt :nodes o: ret :uname :st funcret: ret
    }

    # lintSuffixUnit -- run the suffix check over a typechecked program's main unit.
    lintSuffixUnit: function {:this prog: Node uname: StringView st: zenv.ZSymbolTable} is {
        mn: mainUnitNameOf program: prog
        match (
            prog
        ) case program then {
            uiter: prog.units.iterate
            for uId9: uiter loop {
                (this.lintSuffixNamedOp
                    nodes: prog.nodes
                    namedOp: (prog.nodes.get i: (uId9 - 1).u64)
                    mainName: mn.stringview
                    :uname
                    :st
                )
            }
        } else null
    }

    # lintSuffixNamedOp -- run the suffix check on the main unit only.
    lintSuffixNamedOp: function {:this nodes: List Node namedOp: Node mainName: StringView uname: StringView st: zenv.ZSymbolTable} is {
        match (
            namedOp
        ) case namedoperation then {
            un: optName o: namedOp.name
            if un.stringview == mainName then {
                (this.walkSuf
                    :nodes
                    n: (nodes.get i: (namedOp.operation - 1).u64)
                    :uname
                    :st
                    funcret: (Option.none Node)
                )
            }
        } else null
    }

    # checkSuffix -- L005 (typecheck tier): build the project VFS, parse this file's unit in the
    # project, typecheck, and walk the typed tree for redundant numeric suffixes. A missing
    # dependency (in-project parse error) skips the check silently.
    checkSuffix: function {:this srcdir: StringView systemdir: StringView uname: StringView} is {
        vfs: (zvfs.ZVfs
            providers: (List zvfs.ProviderBox)
            providerRoot: (Map u32 value: String)
            entrytable: (zvfs.DentryTable entries: (List zvfs.dentry))
            file_names: (List String)
            walk_cache: (Map String value: u32)
            rootid: 0
        )
        vfs.registerNull
        systemid: vfs.registerFS rootpath: systemdir.string parentpath: "".string
        srcid: vfs.registerFS rootpath: srcdir.string parentpath: "".string
        vfs.bindRoot newid: systemid kind: zvfs.bindkind.instead
        rootid: vfs.bindRoot newid: srcid kind: zvfs.bindkind.before
        p: zparser.Parser.create
        prog: p.parse :vfs :rootid mainUnitName: uname.string
        match (
            prog
        ) case error then null else {
            reg: ztypes.newRegistry
            st: ztypecheck.typecheck program: prog :reg full: true
            this.lintSuffixUnit :prog :uname :st
        }
    }
}

# ---- L005 redundant-suffix helpers (typecheck tier; run only under --full) ----

# nodeinfo -- a node's synthetic id and source position.
nodeinfo: record {
    id: u32
    line: u32
    col: u32
}

# nodeInfoOf -- the id and source position of any AST node.
nodeInfoOf: function {n: Node} out nodeinfo is {
    match (
        n
    ) case error then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case atomid then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case labelvalue then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case stringchunk then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case binop then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case atomstring then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case dottedpath then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case call then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case typeofexpr then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case namedoperation then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case datablock then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case yieldexpr then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case statement then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case statementline then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case assignment then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case reassignment then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case swapstmt then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case expression then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case ifexpr then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case ifclause then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case forexpr then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case doexpr then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case withexpr then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case caseexpr then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case caseclause then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case functiondef then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case objectdef then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case unitdef then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    } case program then {
        return (nodeinfo id: n.nodeid line: n.lineno col: n.colno)
    }
}

# bareZeroTypeName -- the bare-type replacement when a dotted child atom is a
# zero-init suffix candidate: `string` maps to String, a concrete numeric
# type name maps to itself, anything else to "" (c8/c32/f128 are not
# constructible stdlib types).
bareZeroTypeName: function {n: Node} out String is {
    match (
        n
    ) case atomid then {
        if n.name.stringview == "string" then return "String".string
        isNum9: isNumericTypeName name: n.name.stringview
        if isNum9 when n.name.stringview != "c8" then {
            if n.name.stringview != "c32" when n.name.stringview != "f128" then return n.name.copy
        }
    } else null
    return "".string
}

# bareZeroParentText -- the source spelling of a zero-literal dotted parent:
# `""` for the empty string literal, `0` / `0.0` for the numeric zeros; ""
# when the parent is not a zero literal.
bareZeroParentText: function {n: Node} out String is {
    match (
        n
    ) case atomstring then {
        if n.stringparts.length == 0 then return "\"\"".string
    } case atomid then {
        if n.name.stringview == "0" then return "0".string
        if n.name.stringview == "0.0" then return "0.0".string
    } else null
    return "".string
}

# isNumericTypeName -- a name in the numeric-type set the suffix check ranges over.
isNumericTypeName: function {name: StringView} out bool is {
    if name == "i8" then return true
    if name == "i16" then return true
    if name == "i32" then return true
    if name == "i64" then return true
    if name == "i128" then return true
    if name == "u8" then return true
    if name == "u16" then return true
    if name == "u32" then return true
    if name == "u64" then return true
    if name == "u128" then return true
    if name == "c8" then return true
    if name == "c32" then return true
    if name == "f32" then return true
    if name == "f64" then return true
    if name == "f128" then return true
    return false
}

# isNonDec -- a literal lexeme in hex / binary / octal form.
isNonDec: function {s: StringView} out bool is {
    if (s.startsWith prefix: "0x") then return true
    if (s.startsWith prefix: "0X") then return true
    if (s.startsWith prefix: "0b") then return true
    if (s.startsWith prefix: "0B") then return true
    if (s.startsWith prefix: "0o") then return true
    if (s.startsWith prefix: "0O") then return true
    return false
}

# literalFitsBase -- the literal value fits its base's default type (i64 for decimal, u64 for
# non-decimal). A literal that overflows the default keeps its suffix (load-bearing).
literalFitsBase: function {numstr: StringView} out bool is {
    pv: ztypes.parseLiteralValue :numstr
    if pv.ok == false then return false
    if pv.isFloat then return true
    if (isNonDec s: numstr) then return true
    iMax: 9223372036854775807.u64
    return pv.ival <= iMax
}

# sufrec -- a candidate suffix: the suffix type name ("" when not a candidate) and the
# position of the suffix's type token.
sufrec: class {
    tname: String
    line: u32
    col: u32
}

# operandSuffix -- peel an `expression` wrapper and report whether the operand is a redundant
# -suffix dotted path, with the type token's position.
operandSuffix: function {n: Node} out sufrec is {
    match (
        n
    ) case expression then {
        return (operandSuffix n: n.expression)
    } case dottedpath then {
        cn: atomName n: n.child
        if (isNumericTypeName name: cn.stringview) == false then {
            return (sufrec tname: "".string line: 0 col: 0)
        }
        pn: atomName n: n.parent
        if pn.length == 0 then return (sufrec tname: "".string line: 0 col: 0)
        if (literalFitsBase numstr: pn.stringview) == false then {
            return (sufrec tname: "".string line: 0 col: 0)
        }
        ci: nodeInfoOf n: n.child
        return (sufrec tname: cn line: ci.line col: ci.col)
    } else {
        return (sufrec tname: "".string line: 0 col: 0)
    }
}

# isNodeConst -- the node carries a compile-time const value.
isNodeConst: function {nid: u64 st: zenv.ZSymbolTable} out bool is {
    res: false
    it: st.typing.nodeConst.iterate
    for row: it loop {
        if row.nodeid == nid then res = true
    }
    return res
}

# nameOfTypeId -- the registered type's name for a type id ("" when absent).
nameOfTypeId: function {tid: u64 st: zenv.ZSymbolTable} out String is {
    zo: st.reg.typeById.get key: tid
    match (
        zo
    ) case some then {
        return zo.name.copy
    } case none then {
        return "".string
    }
}

# typeNameOfNode -- the resolved type name of a node ("" when unresolved).
typeNameOfNode: function {n: Node st: zenv.ZSymbolTable} out String is {
    info: nodeInfoOf :n
    to: st.typing.nodeType.get key: info.id.u64
    match (
        to
    ) case some then {
        return (nameOfTypeId tid: to :st)
    } case none then {
        return "".string
    }
}

# typeNameOfOpt -- the resolved type name of an optional node ("" when absent).
typeNameOfOpt: function {o: Option Node st: zenv.ZSymbolTable} out String is {
    match (
        o
    ) case some then {
        return (typeNameOfNode n: o :st)
    } case none then {
        return "".string
    }
}

# isAnchor -- the node is a concrete non-literal value of numeric type `tname`, a genuine
# type anchor that makes a same-type literal suffix redundant.
isAnchor: function {n: Node tname: StringView st: zenv.ZSymbolTable} out bool is {
    info: nodeInfoOf :n
    nid: info.id.u64
    to: st.typing.nodeType.get key: nid
    match (
        to
    ) case some then {
        zhit9: false
        zlit9: false
        znm9: String
        {
            zo: st.reg.typeById.get key: to
            match (
                zo
            ) case some then {
                zhit9 = true
                if zo.isLiteral then zlit9 = true
                znm9 = zo.name.copy
            } case none then null
        }
        if zhit9 == false then return false
        if zlit9 then return false
        if (znm9.stringview == tname) == false then return false
        if (isNodeConst :nid :st) then return false
        return true
    } case none then {
        return false
    }
}

# mainUnitNameOf -- the program's main unit name.
mainUnitNameOf: function {program: Node} out String is {
    match (
        program
    ) case program then {
        return program.mainUnitName.copy
    } else {
        return "".string
    }
}

# unitNameOf -- a file path's unit name: the final path segment without the ".z" suffix.
unitNameOf: function {path: StringView} out String is {
    base: path.string
    slashOpt: path.lastIndexOf needle: "/"
    match (
        slashOpt
    ) case some then {
        r: String
        i: slashOpt + 1
        n: path.length
        for i < n loop {
            b: path.byteAt :i
            match (
                b
            ) case some then {
                r.appendByte :b
            } case none then null
            i = i + 1
        }
        base = r
    } case none then null
    sfx: base.stringview.stripSuffix s: ".z"
    match (
        sfx
    ) case some then {
        return sfx.string
    } case none then {
        return base.copy
    }
}

# linesOf -- split source into a 1-based-addressable list of lines (newlines stripped).
linesOf: function {src: StringView} out (List String) is {
    ls: (List String)
    with it: src.lines do for ln: it loop ls.append ln.string
    return ls
}

# lineStartIndex -- byte offset of each line's first byte, one entry per line (matching
# linesOf). Extends the W001 `off += len + 1` accumulator; converts token/edit positions to
# byte offsets and back without depending on the tokenizer's escape-decoded widths.
lineStartIndex: function {src: StringView} out (List u64) is {
    ls: (List u64)
    off: u64
    lls: linesOf :src
    with it: lls.iterate do for ln: it loop {
        ls.append off
        off = off + ln.length + 1
    }
    return ls
}

# byteToLine -- the 0-based index of the line containing byte `off`: the largest i with
# lineStart[i] <= off. lineStart ascends, so the scan stops at the first line past off.
byteToLine: function {lineStart: (List u64).borrow off: u64 nLines: u64} out u64 is {
    r: u64
    i: u64
    for i < nLines loop {
        v: lineStart.get :i
        if v <= off then {
            r = i
        } else {
            break
        }
        i = i + 1
    }
    return r
}

# colToByteInLine -- byte offset within `lineText` of the 1-based codepoint column `colno`.
# Token columns are codepoint-based (multibyte-aware); this walks the line's bytes, consuming
# one codepoint (a lead byte plus its 0x80..0xBF continuations) per column. ASCII: colno - 1.
colToByteInLine: function {lineText: StringView colno: u32} out u64 is {
    if colno <= 1 then return 0
    target: (colno - 1).u64
    n: lineText.length
    b: u64
    cp: u64
    for cp < target loop {
        if b >= n then break
        b = b + 1
        cont: true
        for cont loop {
            if b >= n then {
                cont = false
            } else {
                nb: lineText.byteAt i: b
                isC: false
                match (
                    nb
                ) case some then {
                    if nb >= 128 when (nb < 192) then isC = true
                } case none then null
                if isC then {
                    b = b + 1
                } else {
                    cont = false
                }
            }
        }
        cp = cp + 1
    }
    return b
}

# tokByteStart -- absolute byte offset of a token from its 1-based (lineno, colno): the line's
# start offset plus the codepoint-column converted to a byte column.
tokByteStart: function {
    lineStart: (List u64).borrow
    srcLines: (List String).borrow
    lineno: u32
    colno: u32
} out u64 is {
    li: (lineno - 1).u64
    if li >= srcLines.length then return 0
    base: lineStart.get i: li
    lt: srcLines.get i: li
    return base + (colToByteInLine lineText: lt.stringview :colno)
}

# sortEdits -- a new edit list ordered by byteLo (ascending, stable for ties). applyEdits and
# renderDiff require sorted, non-overlapping input; each rule emits its own edits in order but
# they interleave across rules, so a global sort is run once all rules have contributed.
sortEdits: function {edits: (List zfix.Edit).borrow} out (List zfix.Edit) is {
    result: (List zfix.Edit)
    n: edits.length
    used: (List bool)
    p: u64
    for p < n loop {
        used.append false
        p = p + 1
    }
    k: u64
    for k < n loop {
        best: n
        bestLo: u64
        bestHi: u64
        i: u64
        for i < n loop {
            u: used.get :i
            if (u) == false then {
                e: edits.get :i
                take: false
                if best == n then {
                    take = true
                } else if e.byteLo < bestLo then {
                    take = true
                } else if e.byteLo == bestLo when (e.byteHi > bestHi) then take = true
                if take then {
                    best = i
                    bestLo = e.byteLo
                    bestHi = e.byteHi
                }
            }
            i = i + 1
        }
        be: edits.get i: best
        result.append (zfix.Edit
            byteLo: be.byteLo
            byteHi: be.byteHi
            replacement: be.replacement.copy
        )
        used.set i: best val: true
        k = k + 1
    }
    return result
}

# emitDiffHunk -- append one zero-context unified-diff hunk to `buf` for the cluster of edits
# [cStart, cEnd) spanning old lines [clLo, clHi]. The new-side block is the old bytes with the
# cluster's edits applied, so the hunk exactly reflects the formatted output. Returns the
# running new-minus-old line delta for the next hunk's + start.
emitDiffHunk: function {
    buf: String
    source: StringView
    edits: (List zfix.Edit).borrow
    cStart: u64
    cEnd: u64
    clLo: u64
    clHi: u64
    lineStart: (List u64).borrow
    srcLines: (List String).borrow
    newDelta: i64
} out i64 is {
    nLines: srcLines.length
    srcLen: source.length
    oldCount: (clHi - clLo) + 1
    aByte: lineStart.get i: clLo
    bByte: srcLen
    if (clHi + 1) < nLines then bByte = lineStart.get i: (clHi + 1)
    newBlock: String
    prev: aByte
    j: cStart
    for j < cEnd loop {
        e: edits.get i: j
        if e.byteLo >= prev when (e.byteLo <= e.byteHi) then {
            zfix.appendRange buf: newBlock src: source lo: prev hi: e.byteLo
            newBlock.append e.replacement.stringview
            prev = e.byteHi
        }
        j = j + 1
    }
    zfix.appendRange buf: newBlock src: source lo: prev hi: bByte
    newLines: (List String)
    if newBlock.length > 0 then newLines = linesOf src: newBlock.stringview
    newCount: newLines.length
    newStart: (clLo.i64 + newDelta) + 1
    hh: "@@ -\{clLo + 1},\{oldCount} +\{newStart},\{newCount} @@\n"
    buf.append hh.stringview
    oi: clLo
    for oi <= clHi loop {
        ol: srcLines.get i: oi
        dm: "-\{ol}\n"
        buf.append dm.stringview
        oi = oi + 1
    }
    if (clHi + 1) == nLines when ((endsWithNewline src: source) == false) then {
        buf.append "\\ No newline at end of file\n"
    }
    with nit: newLines.iterate do for nl: nit loop {
        pm: "+\{nl}\n"
        buf.append pm.stringview
    }
    if newBlock.length > 0 when ((endsWithNewline src: newBlock.stringview) == false) then {
        buf.append "\\ No newline at end of file\n"
    }
    return (newDelta + newCount.i64) - oldCount.i64
}

# byteAtLine -- byte offset of line `k`'s start, or `srcLen` when `k` is one past the last line.
byteAtLine: function {starts: (List u64).borrow srcLen: u64 k: u64} out u64 is {
    if k >= starts.length then return srcLen
    return (starts.get i: k)
}

# lineDiffEdits -- edits transforming `old` into `new`, one per changed line-block, shaped for
# renderDiff. fmt + wrap never reorder lines, so an in-order two-pointer with a bounded diagonal-band
# resync finds correct (within the window, minimal) blocks; applyEdits(old, result) == new.
lineDiffEdits: function {old: StringView new: StringView} out (List zfix.Edit) is {
    oldLines: linesOf src: old
    newLines: linesOf src: new
    oldStarts: lineStartIndex src: old
    newStarts: lineStartIndex src: new
    m: oldLines.length
    n: newLines.length
    oldLen: old.length
    newLen: new.length
    edits: (List zfix.Edit)
    i: u64
    p: u64
    for true loop {
        if i >= m when (p >= n) then break
        matched: false
        if i < m when (p < n) then {
            oi: oldLines.get :i
            pj9: newLines.get i: p
            if oi.stringview == pj9.stringview then matched = true
        }
        if matched then {
            i = i + 1
            p = p + 1
        } else {
            i2: m
            p2: n
            found: false
            t: 1.u64
            for t <= 256 loop {
                if found then break
                a: u64
                for a <= t loop {
                    if found then break
                    b: t - a
                    ii: i + a
                    pp: p + b
                    if ii < m when (pp < n) then {
                        oa: oldLines.get i: ii
                        pb9: newLines.get i: pp
                        if oa.stringview == pb9.stringview then {
                            i2 = ii
                            p2 = pp
                            found = true
                        }
                    }
                    a = a + 1
                }
                t = t + 1
            }
            if found == false then {
                we: i + 256
                if we > m then we = m
                wf: p + 256
                if wf > n then wf = n
                i2 = we
                p2 = wf
            }
            lo: byteAtLine starts: oldStarts srcLen: oldLen k: i
            hi: byteAtLine starts: oldStarts srcLen: oldLen k: i2
            nlo: byteAtLine starts: newStarts srcLen: newLen k: p
            nhi: byteAtLine starts: newStarts srcLen: newLen k: p2
            repl: String
            zfix.appendRange buf: repl src: new lo: nlo hi: nhi
            doEmit: false
            if hi > lo then doEmit = true
            if nhi > nlo then doEmit = true
            if doEmit then edits.append (zfix.Edit byteLo: lo byteHi: hi replacement: repl)
            i = i2
            p = p2
        }
    }
    return edits
}

# renderDiff -- a git-style unified diff (zero context) of `source` -> the formatted result,
# driven by `edits` (assumed sorted by byteLo). Adjacent edits touching the same or
# neighbouring lines share a hunk. Empty when there are no edits.
renderDiff: function {
    path: StringView
    source: StringView
    edits: (List zfix.Edit).borrow
} out String is {
    buf: String
    m: edits.length
    if m == 0 then return buf
    lineStart: lineStartIndex src: source
    srcLines: linesOf src: source
    nLines: srcLines.length

    hdr: "--- \{path}\n+++ \{path}\n"
    buf.append hdr.stringview

    newDelta: i64
    cActive: false
    cStart: u64
    clLo: u64
    clHi: u64
    i: u64
    for i < m loop {
        e: edits.get :i
        lo: byteToLine :lineStart off: e.byteLo :nLines
        hi: lo
        if e.byteHi > e.byteLo then hi = byteToLine :lineStart off: (e.byteHi - 1) :nLines
        if (cActive) == false then {
            cActive = true
            cStart = i
            clLo = lo
            clHi = hi
        } else if lo <= (clHi + 1) then {
            if hi > clHi then clHi = hi
        } else {
            newDelta = (emitDiffHunk
                :buf
                :source
                :edits
                :cStart
                cEnd: i
                :clLo
                :clHi
                :lineStart
                :srcLines
                :newDelta
            )
            cStart = i
            clLo = lo
            clHi = hi
        }
        i = i + 1
    }
    if cActive then {
        newDelta = (emitDiffHunk
            :buf
            :source
            :edits
            :cStart
            cEnd: m
            :clLo
            :clHi
            :lineStart
            :srcLines
            :newDelta
        )
    }
    return buf
}

# analyzeFile -- fast-tier analysis of one file: read, fast-parse (no VFS/typecheck),
# build the line table, and collect parse-error diagnostics.
# analyzeSource -- the fast-tier analysis over IN-MEMORY source: the
# read-then-analyze wrappers and zls's live editor buffers share it.
analyzeSource: function {
    source: String.take
    path: String.take
    lineLength: u32
    casing: bool
} out Analysis is {
    root: ast.parseSource source: source.copy
    lines: linesOf src: source.stringview
    a: (Analysis
        path: path.copy
        source: source.take
        :lines
        lineStart: (List u64)
        diags: (List zdiag.Diagnostic)
        edits: (List zfix.Edit)
        wrapWidth: 0
        wrapSkip: 0
        wrapFound: false
        wrapStart: 0
        delimClose: (Map u64 value: u64)
        fastToks: (List tokenize.Token)
        funcDepth: 0
        wrapGroups: (List u64)
    )
    a.runFastChecks n: root
    if casing then a.walkCasingProgram prog: root
    a.checkLineLength width: lineLength
    a.sortEditsInPlace
    return a
}

analyzeFile: function {path: String.take lineLength: u32 casing: bool} out Analysis is {
    rd: io.readText path: path.stringview
    match (
        rd
    ) case ok then {
        return (analyzeSource source: rd.take path: path.copy :lineLength :casing)
    } case err then {
        a: (Analysis
            path: path.copy
            source: "".string
            lines: (List String)
            lineStart: (List u64)
            diags: (List zdiag.Diagnostic)
            edits: (List zfix.Edit)
            wrapWidth: 0
            wrapSkip: 0
            wrapFound: false
            wrapStart: 0
            delimClose: (Map u64 value: u64)
            fastToks: (List tokenize.Token)
            funcDepth: 0
            wrapGroups: (List u64)
        )
        d: (zdiag.errorDiag
            errv: zast.err.ioError
            fsno: 0
            lineno: 0
            colno: 0
            width: 0
            msg: "could not read file".string
            note: "".string
            hint: "".string
        )
        a.diags.append d
        return a
    }
}

# analyzeFileFull -- fast-tier analysis plus the typecheck-tier suffix rule (L005). Builds the
# project VFS from `srcdir`/`systemdir` and typechecks this file's unit so the suffix check has
# resolved types. Slower than analyzeFile; only the --full path calls it.
analyzeFileFull: function {
    path: String.take
    srcdir: StringView
    systemdir: StringView
    lineLength: u32
} out Analysis is {
    rd: io.readText path: path.stringview
    match (
        rd
    ) case ok then {
        root: ast.parseSource source: rd.copy
        lines: linesOf src: rd.stringview
        a: (Analysis
            path: path.copy
            source: rd.take
            :lines
            lineStart: (List u64)
            diags: (List zdiag.Diagnostic)
            edits: (List zfix.Edit)
            wrapWidth: 0
            wrapSkip: 0
            wrapFound: false
            wrapStart: 0
            delimClose: (Map u64 value: u64)
            fastToks: (List tokenize.Token)
            funcDepth: 0
            wrapGroups: (List u64)
        )
        a.runFastChecks n: root
        un: unitNameOf path: a.path.stringview
        a.checkSuffix :srcdir :systemdir uname: un.stringview
        a.checkLineLength width: lineLength
        a.sortEditsInPlace
        return a
    } case err then {
        a: (Analysis
            path: path.copy
            source: "".string
            lines: (List String)
            lineStart: (List u64)
            diags: (List zdiag.Diagnostic)
            edits: (List zfix.Edit)
            wrapWidth: 0
            wrapSkip: 0
            wrapFound: false
            wrapStart: 0
            delimClose: (Map u64 value: u64)
            fastToks: (List tokenize.Token)
            funcDepth: 0
            wrapGroups: (List u64)
        )
        d: (zdiag.errorDiag
            errv: zast.err.ioError
            fsno: 0
            lineno: 0
            colno: 0
            width: 0
            msg: "could not read file".string
            note: "".string
            hint: "".string
        )
        a.diags.append d
        return a
    }
}

# analyzeFileTiered -- analyze one file at the requested tier: the fast tier by default, or
# the full (typecheck) tier under --full (which also needs the project src/system dirs).
analyzeFileTiered: function {
    path: String.take
    full: bool
    srcdir: StringView
    systemdir: StringView
    lineLength: u32
    casing: bool
} out Analysis is {
    if full then return (analyzeFileFull :path :srcdir :systemdir :lineLength)
    return (analyzeFile :path :lineLength :casing)
}

# codepointLen -- number of Unicode codepoints in `s` (UTF-8 continuation bytes 0x80..0xBF are not
# counted); the display "column" length for the line-length rule.
codepointLen: function {s: StringView} out u64 is {
    n: s.length
    c: u64
    b: u64
    for b < n loop {
        bo: s.byteAt i: b
        cont: false
        match (
            bo
        ) case some then {
            if bo >= 128 when (bo < 192) then cont = true
        } case none then null
        if (cont) == false then c = c + 1
        b = b + 1
    }
    return c
}

# sourceParses -- true if `source` parses with no embedded parse errors. `zl fmt`
# uses it to confirm an edited buffer is still valid before writing it out.
sourceParses: function {source: String.take} out bool is {
    a: (Analysis
        path: "".string
        source: "".string
        lines: (List String)
        lineStart: (List u64)
        diags: (List zdiag.Diagnostic)
        edits: (List zfix.Edit)
        wrapWidth: 0
        wrapSkip: 0
        wrapFound: false
        wrapStart: 0
        delimClose: (Map u64 value: u64)
        fastToks: (List tokenize.Token)
        funcDepth: 0
        wrapGroups: (List u64)
    )
    root: ast.parseSource :source
    a.walkProgram prog: root
    return a.parseErrorCount == 0
}

# nlIndent -- a newline followed by `n` spaces (the wrap indent unit).
nlIndent: function {n: u64} out String is {
    s: "\n".string
    i: u64
    for i < n loop {
        s.appendByte b: 32
        i = i + 1
    }
    return s
}

# leadingSpaces -- count of leading space bytes on a line.
leadingSpaces: function {line: StringView} out u64 is {
    n: u64
    for n < line.length loop {
        bo: line.byteAt i: n
        sp: false
        match (
            bo
        ) case some then {
            if bo == 32 then sp = true
        } case none then null
        if sp == false then return n
        n = n + 1
    }
    return n
}

# rstripLen -- byte length of a line excluding trailing spaces and tabs.
rstripLen: function {line: StringView} out u64 is {
    n: line.length
    for n > 0 loop {
        bo: line.byteAt i: (n - 1)
        ws: false
        match (
            bo
        ) case some then {
            if bo == 32 then ws = true
            if bo == 9 then ws = true
        } case none then null
        if ws == false then return n
        n = n - 1
    }
    return 0
}

# wsRunStart -- start byte of the whitespace run ending just before `from`.
# wsRunStartNL -- like wsRunStart but also swallows newline bytes: the start of
# the whitespace-and-newline run ending at `from`. Collapses the indentation and
# line break between a single-statement body and its closing brace.
wsRunStartNL: function {src: StringView from: u64} out u64 is {
    n: from
    for n > 0 loop {
        bo: src.byteAt i: (n - 1)
        ws: false
        match (
            bo
        ) case some then {
            if bo == 32 then ws = true
            if bo == 9 then ws = true
            if bo == 10 then ws = true
            if bo == 13 then ws = true
        } case none then null
        if ws == false then return n
        n = n - 1
    }
    return n
}

wsRunStart: function {src: StringView from: u64} out u64 is {
    n: from
    for n > 0 loop {
        bo: src.byteAt i: (n - 1)
        ws: false
        match (
            bo
        ) case some then {
            if bo == 32 then ws = true
            if bo == 9 then ws = true
        } case none then null
        if ws == false then return n
        n = n - 1
    }
    return n
}

# hasHash -- true if the line contains a `#` (a comment; wrapping skips such lines).
hasHash: function {line: StringView} out bool is {
    n: u64
    for n < line.length loop {
        bo: line.byteAt i: n
        match (
            bo
        ) case some then {
            if bo == 35 then return true
        } case none then null
        n = n + 1
    }
    return false
}

# buildDelimMap -- build a map of open-byte -> matching close-byte for every () and {} pair, from
# the token stream. String-literal and interpolation delimiters are distinct token kinds, so they
# are never counted.
buildDelimMap: function {
    src: StringView
    lineStart: (List u64).borrow
    srcLines: (List String).borrow
} out (Map u64 value: u64) is {
    m: (Map u64 value: u64)
    toks: tokenize.scan source: src.string
    nt: toks.length
    stack: (List u64)
    i: u64
    for i < nt loop {
        t: toks.get :i
        kind: u32
        match (
            t.toktype
        ) case parenOpenTok then {
            kind = 1
        } case braceOpenTok then {
            kind = 1
        } case parenCloseTok then {
            kind = 2
        } case braceCloseTok then {
            kind = 2
        } else null
        if kind == 1 then {
            b: tokByteStart :lineStart :srcLines lineno: t.lineno colno: t.colno
            stack.append b
        } else if kind == 2 then {
            if stack.length > 0 then {
                ob: stack.pop
                cb: tokByteStart :lineStart :srcLines lineno: t.lineno colno: t.colno
                m.set key: ob value: cb
            }
        }
        i = i + 1
    }
    return m
}

# wrapSource -- fixpoint auto-wrap of over-long named-arg calls under --line-length. Each pass wraps
# the first over-long single-line call (adding parens when bare), re-parses, and discards a wrap that
# would not parse (skipping past it); loops until no wrappable call remains.
wrapSource: function {source: StringView lineLength: u32} out String is {
    cur: source.string
    guard: u64
    for guard < 40 loop {
        guard = guard + 1
        rd: cur.copy
        a: (Analysis
            path: "".string
            source: rd.copy
            lines: (linesOf src: rd.stringview)
            lineStart: (lineStartIndex src: rd.stringview)
            diags: (List zdiag.Diagnostic)
            edits: (List zfix.Edit)
            wrapWidth: lineLength
            wrapSkip: 0
            wrapFound: false
            wrapStart: 0
            delimClose: (Map u64 value: u64)
            fastToks: (List tokenize.Token)
            funcDepth: 0
            wrapGroups: (List u64)
        )
        root: ast.parseSource source: rd.copy
        a.delimClose = buildDelimMap src: rd.stringview lineStart: a.lineStart srcLines: a.lines
        # the wrap pass runs the full visitor: bracesBlocked (the comment
        # guard for L008/L010 debraces) reads fastToks, so the token scan
        # must be populated here too or commented bodies lose their
        # comments whenever a wrap edit lands in the same batch
        a.fastToks = tokenize.scan source: rd.copy
        a.walkProgram prog: root
        if a.wrapFound == false then break
        se: sortEdits edits: a.edits
        cand: zfix.applyEdits source: cur.stringview edits: se
        cok: sourceParses source: cand.copy
        if cok then {
            cur = cand
        } else {
            good: (List zfix.Edit)
            ng: a.wrapGroups.length
            gi: u64
            for gi < ng loop {
                gstart: a.wrapGroups.get i: gi
                gend: a.edits.length
                if (gi + 1) < ng then gend = a.wrapGroups.get i: (gi + 1)
                added: u64
                k: gstart
                for k < gend loop {
                    e9: a.edits.get i: k
                    good.append (zfix.Edit
                        byteLo: e9.byteLo
                        byteHi: e9.byteHi
                        replacement: e9.replacement.copy
                    )
                    added = added + 1
                    k = k + 1
                }
                cnd2: zfix.applyEdits source: cur.stringview edits: good
                bad9: (sourceParses source: cnd2.copy) == false
                if bad9 then {
                    j: u64
                    for j < added loop {
                        pd9: good.pop
                        j = j + 1
                    }
                }
                gi = gi + 1
            }
            if good.length == 0 then break
            cur = zfix.applyEdits source: cur.stringview edits: good
        }
    }
    return cur
}

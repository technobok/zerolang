            dzt9: typedefChaseC :ast :symtab :ctx tid: izd9
            if dzt9.length > 0 then return "((\{dzt9})0)"
            dzm9: chaseColMono :ast :symtab tid: izd9
            if dzm9 != izd9 then {
                dzmc9: symtab.reg.cnameOf tid: dzm9
                if (originIsTid :symtab tid: dzm9 originTid: ctx.listOriginTid) then {

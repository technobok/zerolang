            match (
                a
            ) case namedoperation then {
                opf79: ast.nodes.get i: (a.operation - 1).u64
                ax = emitExpr :ast :symtab :ctx n: opf79
            } else null
        }
        e0: "z_\{bn}[\{ax}]"
        return e0
    }
    return "".string
}

# listCapArg -- the capacity: argument of a list construction value, or
# "0" when absent.
listCapArg: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out String is {
    match (
        n
    ) case expression then {
        return (listCapArg :ast :symtab :ctx n: (ast.nodes.get i: (n.expression - 1).u64))
    } case call then {
        aiter: n.arguments.iterate
        for aId9: aiter loop {
            a: ast.nodes.get i: (aId9 - 1).u64
            match (
                a
            ) case namedoperation then {
                an: zast.nameTextCopy :ast ref: a.name
                if an.stringview == "capacity" then return (emitExpr
                    :ast
                    :symtab
                    :ctx
                    n: (ast.nodes.get i: (a.operation - 1).u64)
                )
            } else null
        }
        return "0".string
    } else {
        return "0".string
    }
}

# emitListMethodCall -- a method call on a List-mono receiver. Maps the
# labeled arguments to the runtime method's positional C signature.
# emitDottedReceiver -- the C expression for the receiver of a dotted method
# call (call.callable = recv.method). Uses emitExpr on the base node so a nested
# receiver (this.field.method, obj.a.b.method) works, not just a bare atom. ""
# when the callable is not a dotted path.
emitDottedReceiver: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    callable: Node
} out String is {
    match (
        callable
    ) case dottedpath then {
        return (emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (callable.parent - 1).u64))
    } else {
        return "".string
    }
}

# dottedReceiverStampId -- the stamped type id of a dotted method call's
# receiver (the base node, via nodeIdOf9 which handles a nested dottedpath base).
# 0 when not a dotted path.
dottedReceiverStampId: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    callable: Node
} out u64 is {
    match (
        callable
    ) case dottedpath then {
        return (stampIdOf :symtab nid: (nodeIdOf9 n: (ast.nodes.get i: (callable.parent - 1).u64)))
    } else {
        return 0
    }
}

# dottedReceiverIsPtr -- true when a dotted method call's receiver is already a
# C pointer (a ptrVar like `this`, or a `.lock` field), so the call passes it
# directly rather than taking its address.
dottedReceiverIsPtr: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    callable: Node
} out bool is {
    match (
        callable
    ) case dottedpath then {
        return (pathIsPointer :ast :symtab :ctx n: (ast.nodes.get i: (callable.parent - 1).u64))
    } else {
        return false
    }
}

# emitStringArgMethod -- a String mutating method WITH an arg (appendByte /
# reserve): emit \{ctx.strC}_<native>(&recv, arg). The native cname is
# snake_case (append_byte). "" when the receiver is not a String or the method
# is not one of these. String is a value-native, so the cname is always ctx.strC.
emitStringArgMethod: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    mn: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    nativeM: String
    if mn.stringview == "appendByte" then nativeM = "append_byte".string
    if mn.stringview == "reserve" then nativeM = "reserve".string
    if mn.stringview == "append" then nativeM = "append".string
    if nativeM.length == 0 then return "".string
    xq189: ast.nodes.get i: (call.callable - 1).u64
    recvExpr: emitDottedReceiver :ast :symtab :ctx callable: xq189
    if recvExpr.length == 0 then return "".string
    rtid0: dottedReceiverStampId :ast :symtab callable: (ast.nodes.get i: (call.callable - 1).u64)
    rtid: chaseColMono :ast :symtab tid: rtid0
    rtid = chaseStrTypedef :symtab :ctx tid: rtid
    rtn: typeNameOfReg9 :symtab tid: rtid
    if rtn.stringview != "String" then return "".string
    rptr: dottedReceiverIsPtr :ast :symtab :ctx callable: (ast.nodes.get i: (call.callable - 1).u64)
    recvAddr: "&\{recvExpr}"
    if rptr then recvAddr = "\{recvExpr}"
    argval: String
    argTid9: u64
    argBor9: false
    argPtr9: false
    with aiter: call.arguments.iterate do for aId9: aiter loop {
        a: ast.nodes.get i: (aId9 - 1).u64
        match (
            a
        ) case namedoperation then {
            if argval.length == 0 then {
                # an interpolated-literal arg builds a multi-statement String:
                # hoist it to an _ah temp (freed at the statement flush, the
                # receiver only borrows), exactly like collection/user-fn args
                iv9: (emitColInterpArg
                    :ast
                    :symtab
                    :ctx
                    n: (ast.nodes.get i: (a.operation - 1).u64)
                    consumes: false
                )
                if iv9.length > 0 then {
                    argval = iv9
                    argTid9 = ctx.strTid
                } else {
                    av: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (a.operation - 1).u64)
                    argval = av
                    opf89: ast.nodes.get i: (a.operation - 1).u64
                    argBor9 = hoistExprIsBorrowRooted :ast :symtab :ctx n: opf89
                    opf99: ast.nodes.get i: (a.operation - 1).u64
                    argTid9 = stampIdOf :symtab nid: (nodeIdOf9 n: opf99)
                    opf109: ast.nodes.get i: (a.operation - 1).u64
                    argPtr9 = pathIsPointer :ast :symtab :ctx n: opf109
                }
            }
        } else null
    }
    if mn.stringview == "append" then {
        # The StringLike arg lowers to (data, length) by its concrete type:
        # an owned String reads .data/.size (through the pointer for a
        # borrowed param); a StringView reads .data/.length.
        if argTid9 == ctx.strTid then {
            aph9: (hoistBorrowValArg
                :ast
                :symtab
                :ctx
                av: argval.stringview
                pid: ctx.strTid
                paramTake: false
                isBorrow: argBor9
            )
            if aph9.length > 0 then argval = aph9
            aacc9: "."
            if argPtr9 then aacc9 = "->"
            rapps: "\{ctx.strC}_append(\{recvAddr}, (\{argval})\{aacc9}data, (\{argval})\{aacc9}size)"
            return rapps
        }
        rapp: "\{ctx.strC}_append(\{recvAddr}, (\{argval}).data, (\{argval}).length)"
        return rapp
    }
    r: "\{ctx.strC}_\{nativeM}(\{recvAddr}, \{argval})"
    return r
}

# isNonLvalueArg -- true when an emitted arg expression is a non-addressable
# rvalue (a call/cast result, e.g. `String_from_view(...)`) so `&expr` is invalid
# C and the arg must be hoisted to a named temp first. A deref projection
# `(*__borrow_x)` IS an lvalue, so it is excluded.
isNonLvalueArg: function {s: StringView} out bool is {
    if (s.contains needle: "(") == false then return false
    if (s.startsWith prefix: "(*") then return false
    return true
}

# flushArgHoists -- emit the `String_t _ahN = <rvalue>;` declarations recorded by
# emitInstanceMethodCall for borrow-String args that needed `&` on a non-lvalue.
# Called at statement level (which holds ind/tmp/buf) right after the call
# expression is built; registers each temp for scope-exit free.
flushArgHoists: function {ctx: Ctx ind: StringView tmp: TmpCtr buf: String.borrow} is {
    i: u64
    n: ctx.argHoistNames.length
    for i < n loop {
        nmo: ctx.argHoistNames.get :i
        vlo: ctx.argHoistVals.get :i
        cty: ctx.argHoistTypes.get :i
        decl: "\{ind}\{cty} \{nmo} = \{vlo};\n"
        buf.append decl.stringview
        dto: ctx.argHoistDtors.get :i
        if dto.length > 0 then {
            dtc: dto.copy
            tmp.listFrees.append dtc
            tmp.listFreeVars.append nmo.copy
        }
        i = i + 1
    }
    ri9: u64
    rn9: ctx.argHoistRaw.length
    for ri9 < rn9 loop {
        rdo9: ctx.argHoistRaw.get i: ri9
        buf.append rdo9.stringview
        ri9 = ri9 + 1
    }
    ctx.argHoistNames = (List String)
    ctx.argHoistVals = (List String)
    ctx.argHoistTypes = (List String)
    ctx.argHoistDtors = (List String)
    ctx.argHoistRaw = (List String)
}

# pushLoopLabel -- allocate a unique break-target label for a loop and push it.
# A zerolang `break` inside the loop emits `goto __zbrk_<id>`: a bare C `break`
# would only leave an enclosing match->switch, not the loop. The label is
# emitted after the loop by popLoopLabel, but only if a break referenced it.
pushLoopLabel: function {ctx: Ctx tmp: TmpCtr isDo: bool} out u64 is {
    id: ctx.breakLabelCtr
    ctx.breakLabelCtr = id + 1
    ctx.breakLabels.append id
    isDoC9: isDo
    ctx.breakLabelIsDo.append isDoC9
    ctx.breakFreesMarks.append tmp.frees.length
    ctx.breakListMarks.append tmp.listFrees.length
    cl9: String
    ctx.breakLabelCleanup.append cl9
    cv9: String
    ctx.breakLabelCleanupVar.append cv9
    return ctx.breakLabelCtr - 1
}

# emitContLabel -- the loop-body continue target: a `continue` inside a
# do{}while(0) wrapper jumps here (past the wrapper, before the loop's
# closing brace so the increment/condition re-evaluates). Emitted only
# when a continue referenced it.
emitContLabel: function {ctx: Ctx id: u64 ind: StringView buf: String.borrow} is {
    uo: ctx.contLabelUsed.get key: id
    match (
        uo
    ) case some then {
        lbl9: "\{ind}__zcont_\{id}: ;\n"
        buf.append lbl9.stringview
    } case none then null
}

popLoopLabel: function {ctx: Ctx id: u64 ind: StringView buf: String.borrow} is {
    if ctx.breakLabels.length > 0 then ctx.breakLabels.pop
    if ctx.breakLabelIsDo.length > 0 then ctx.breakLabelIsDo.pop
    if ctx.breakFreesMarks.length > 0 then {
        ctx.breakFreesMarks.pop
        ctx.breakListMarks.pop
    }
    if ctx.breakLabelCleanup.length > 0 then {
        dcl9: ctx.breakLabelCleanup.pop
        dcv9: ctx.breakLabelCleanupVar.pop
    }
    uo: ctx.breakLabelUsed.get key: id
    match (
        uo
    ) case some then {
        lbl9: "\{ind}__zbrk_\{id}: ;\n"
        buf.append lbl9.stringview
    } case none then null
}

# emitInstanceMethodCall -- `recv.method args` on a user CLASS instance (not a
# Type qualifier, not a collection / system native): emit
# {methodCname}(&recv, posArgs) with the receiver mapped to the :this param and
# the explicit args reordered by the method's param labels. "" when the receiver
# is not a user class or the method is unresolved.
# methodOwnerId -- the type id that actually owns method `mn`. A cross-unit
# receiver may be stamped a same-named SHELL id whose childOf lacks the method;
# scan for the same-named type that has it (emitter twin of canonicalChildBase).
methodOwnerId: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    rtid: u64
    mn: StringView
} out u64 is {
    direct: symtab.typing.childOf pool: ast.names parentTypeId: rtid name: mn
    match (
        direct
    ) case some then {
        return rtid
    } case none then null
    rn: typeNameOfReg9 :symtab tid: rtid
    if rn.length == 0 then return rtid
    last: symtab.reg.nextTypeId
    t: u64
    for t < last loop {
        tn: typeNameOfReg9 :symtab tid: t
        if tn.stringview == rn.stringview then {
            co: symtab.typing.childOf pool: ast.names parentTypeId: t name: mn
            match (
                co
            ) case some then {
                return t.u64
            } case none then null
        }
        t = t + 1
    }
    return rtid
}

# hoistBorrowValArg -- a by-value call argument that is an owned, destructible,
# non-lvalue temporary (e.g. a `Map.get` Option result) handed to a borrow param
# (not paramTake) is freed by neither side. Hoist it into a temp registered
# for scope-exit destroy (mirrors the by-ref `&`-hoist) and return the temp name;
# "" when no hoist is needed. `av` is borrowed -- the caller keeps ownership.
hoistBorrowValArg: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    av: StringView
    pid: u64
    paramTake: bool
    isBorrow: bool
} out String is {
    if (isNonLvalueArg s: av) == false then return "".string
    if paramTake then return "".string
    vrid: pid
    vduo: definedInUnitOf :symtab tid: pid
    match (
        vduo
    ) case none then {
        vtn: typeNameOfReg9 :symtab tid: pid
        vrr: resolveTypeIdByName :ast :symtab :ctx name: vtn.stringview
        if vrr > 0 then vrid = vrr
    } case some then null
    isStrH9: vrid == ctx.strTid
    if (isStrH9) == false when (symtab.reg.hasDestructorName typeId: vrid) == false then {
        return "".string
    }
    vhn: ctx.argHoistCtr
    ctx.argHoistCtr = ctx.argHoistCtr + 1
    vnmh: "_ah\{vhn}"
    vcty: typeRefC :ast :symtab :ctx tid: pid thisTid: 0
    vcb: symtab.reg.cnameOf tid: vrid
    vdt: "    \{vcb}_destroy(&\{vnmh});\n"
    if isStrH9 then vdt = "    \{ctx.strC}_free(&\{vnmh});\n"
    # a borrow-returning call result is a shared view: hoist for
    # lvalue-ness only, never destroy
    if isBorrow then vdt = "".string
    avc: av.string
    ctx.argHoistVals.append avc
    ctx.argHoistTypes.append vcty.copy
    ctx.argHoistDtors.append vdt
    ctx.argHoistNames.append vnmh.copy
    return vnmh
}

emitInstanceMethodCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    mn: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    if mn.length == 0 then return "".string
    xq179: ast.nodes.get i: (call.callable - 1).u64
    recvExpr: emitDottedReceiver :ast :symtab :ctx callable: xq179
    if recvExpr.length == 0 then return "".string
    rtid0: dottedReceiverStampId :ast :symtab callable: (ast.nodes.get i: (call.callable - 1).u64)
    rtidc: chaseColMono :ast :symtab tid: rtid0
    rtid: methodOwnerId :ast :symtab :ctx rtid: rtidc mn: mn.stringview
    if rtid == 0 then return "".string
    if (symtab.reg.typetypeOf typeId: rtid) != ztypes.ztypetype.classType then return "".string
    monoLk2: monoOriginName :symtab tid: rtid
    if monoLk2.length > 0 then {
        if (isUserClassMonoTid :symtab :ctx tid: rtid) == false then return "".string
    }
    # system natives (String/StringView/io/cli/os) have dedicated dispatchers.
    rdu9: definedInUnitOf :symtab tid: rtid
    match (
        rdu9
    ) case some then {
        if rdu9.stringview == "system" then return "".string
        if rdu9.stringview == "collections" then return "".string
        if rdu9.stringview == "io" then return "".string
        if rdu9.stringview == "cli" then return "".string
        if rdu9.stringview == "os" then return "".string
    } case none then null
    mco9: symtab.typing.childOf pool: ast.names parentTypeId: rtid name: mn.stringview
    match (
        mco9
    ) case some then {
        if (symtab.reg.typetypeOf typeId: mco9) == ztypes.ztypetype.functionType then {
            xq169: ast.nodes.get i: (call.callable - 1).u64
            rptr9: dottedReceiverIsPtr :ast :symtab :ctx callable: xq169
            mcn9: symtab.reg.cnameOf tid: mco9
            pnames: (List String)
            pids: (List u64)
            pidsNm: (List u64)
            recFieldLists :ast :symtab tid: mco9 names: pnames ids: pids nameIds: pidsNm
            # The receiver slot is identified by the method's receiver param name
            # (`this` for the `:this` shorthand, or the spelled name for a
            # `b: this.lock` receiver) -- matching how the definition site names
            # it. Matching the literal "this" alone drops a renamed receiver.
            recvNm9: "this".string
            {
                mto9: symtab.reg.typeById.get key: mco9
                match (
                    mto9
                ) case some then {
                    tpnm9: ztypecheck.optStrOrEmpty o: mto9.thisParamName
                    if tpnm9.length > 0 then recvNm9 = tpnm9
                } case none then null
            }
            args: String
            posIdx9: u64
            pi9: u64
            pn9: pnames.length
            for pi9 < pn9 loop {
                pname9: pnames.get i: pi9
                pid9: pids.get i: pi9
                if pi9 > 0 then args.append ", "
                if pname9.stringview == recvNm9.stringview then {
                    if rptr9 then {
                        args.append recvExpr.stringview
                    } else {
                        ra9: "&\{recvExpr}"
                        args.append ra9.stringview
                    }
                } else {
                    isLbl9b: ctorHasLabel :ast :call label: pname9.stringview
                    iiVal9: String
                    if isLbl9b then {
                        iiVal9 = (ctorInterpArgByLabel
                            :ast
                            :symtab
                            :ctx
                            :call
                            label: pname9.stringview
                            fid: mco9
                            pname: pname9.stringview
                            pid: pid9
                        )
                    } else {
                        iiVal9 = (ctorInterpArgByPosition
                            :ast
                            :symtab
                            :ctx
                            :call
                            idx: posIdx9
                            fid: mco9
                            pname: pname9.stringview
                            pid: pid9
                        )
                    }
                    av9: String
                    avBor9: false
                    usedInterp9: false
                    if iiVal9.length > 0 then {
                        av9 = iiVal9
                        usedInterp9 = true
                        if (isLbl9b) == false then posIdx9 = posIdx9 + 1
                    } else {
                        av9 = ctorArgByLabel :ast :symtab :ctx :call label: pname9.stringview
                        avBor9 = ctorArgIsBorrow :ast :symtab :ctx :call label: pname9.stringview
                        if (isLbl9b) == false then {
                            pv9: ctorArgByPosition :ast :symtab :ctx :call idx: posIdx9
                            if pv9.length > 0 then {
                                av9 = pv9
                                avBor9 = ctorArgIsBorrowPos :ast :symtab :ctx :call idx: posIdx9
                            }
                            posIdx9 = posIdx9 + 1
                        }
                    }
                    ptra9: false
                    isStrBorrow9: false
                    # a non-TAKE class arg passes by pointer (mirrors the method
                    # signature); isReftypeParam resolves a cross-unit class shell that
                    # a bare typetypeOf==CLASS check misses.
                    pTake9: (symtab.typing.childOwnershipIs
                        pool: ast.names
                        parentTypeId: mco9
                        name: pname9.stringview
                        own: ztypes.zparamownership.takeMode
                    )
                    isRef9: false
                    if pTake9 == false then {
                        if (isReftypeParam :ast :symtab :ctx tid: pid9) then isRef9 = true
                    }
                    if isRef9 then {
                        ptra9 = true
                    } else {
                        if (isBorrowStringParam
                            :ast
                            :symtab
                            fid: mco9
                            pname: pname9.stringview
                            pid: pid9
                        ) then {
                            ptra9 = true
                            isStrBorrow9 = true
                        }
                    }
                    if (ptra9) == false then {
                        if (isListPtrParam
                            :ast
                            :symtab
                            fid: mco9
                            pname: pname9.stringview
                            tid: pid9
                        ) then ptra9 = true
                    }
                    if usedInterp9 then ptra9 = false
                    byref9: false
                    if ptra9 then {
                        if (isPtrVar :ctx name: av9.stringview) == false then byref9 = true
                    }
                    if byref9 then {
                        if (isNonLvalueArg s: av9.stringview) then {
                            # `&` of a non-lvalue (a call result) is invalid C: hoist
                            # to a typed temp + destroy at block exit, mirroring the
                            # reference (`T _t = expr; f(&_t); T_destroy(&_t)`).
                            hn9: ctx.argHoistCtr
                            ctx.argHoistCtr = ctx.argHoistCtr + 1
                            nmH9: "_ah\{hn9}"
                            hcty9: typeRefC :ast :symtab :ctx tid: pid9 thisTid: 0
                            htyc9: hcty9.copy
                            hdt9: String
                            if isStrBorrow9 when (avBor9) == false then {
                                hdt9 = "    \{ctx.strC}_free(&\{nmH9});\n"
                            } else if (avBor9) == false then {
                                hrid9: pid9
                                hduo9: definedInUnitOf :symtab tid: pid9
                                match (
                                    hduo9
                                ) case none then {
                                    htn9: typeNameOfReg9 :symtab tid: pid9
                                    hrr9: (resolveTypeIdByName
                                        :ast
                                        :symtab
                                        :ctx
                                        name: htn9.stringview
                                    )
                                    if hrr9 > 0 then hrid9 = hrr9
                                } case some then null
                                if (symtab.reg.hasDestructorName typeId: hrid9) then {
                                    hcb9: symtab.reg.cnameOf tid: hrid9
                                    hdt9 = "    \{hcb9}_destroy(&\{nmH9});\n"
                                }
                            }
                            abh9: "&\{nmH9}"
                            args.append abh9.stringview
                            ctx.argHoistVals.append av9
                            ctx.argHoistTypes.append htyc9
                            ctx.argHoistDtors.append hdt9
                            ctx.argHoistNames.append nmH9
                        } else {
                            ab9: "&\{av9}"
                            args.append ab9.stringview
                        }
                    } else {
                        vbhm9: String
                        if (ptra9) == false when (usedInterp9) == false then {
                            vbhm9 = (hoistBorrowValArg
                                :ast
                                :symtab
                                :ctx
                                av: av9.stringview
                                pid: pid9
                                paramTake: pTake9
                                isBorrow: avBor9
                            )
                        }
                        if vbhm9.length > 0 then {
                            args.append vbhm9.stringview
                        } else {
                            args.append av9.stringview
                        }
                    }
                }
                pi9 = pi9 + 1
            }
            r9: "\{mcn9}(\{args})"
            return r9
        }
    } case none then null
    return "".string
}

# collectionValueCallRhs -- the binding RHS is a value-producing expression
# returning a collection (a call to a user function/method, or a bare dotted-path
# no-arg method auto-call / field access), as opposed to a collection construction
# (`(List of: T)` / `(Set ...)` / `(Map ...)` calls, or a bare typedef-collection
# atom like `Bytes` / `ByteView`). A value call must be emitted as the call;
# constructions emit the binding's mono create. Used by the List/Set/Map binding
# branches to choose between emitting the RHS expression and an empty create.
collectionValueCallRhs: function {ast: Ast n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (collectionValueCallRhs :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case statementline then {
        return (collectionValueCallRhs :ast n: (ast.nodes.get i: (n.statementline - 1).u64))
    } case dottedpath then {
        # a bare dotted path returning a collection (e.g. `st.allNames`) is a
        # no-arg method auto-call or field access -- a value, never a construction.
        atc9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        return atc9.length > 0
    } case call then {
        cn: atomTextOf :ast n: (ast.nodes.get i: (n.callable - 1).u64)
        if cn.length == 0 then {
            # a dotted-path method callable (e.g. `p.operationPaths lex: lx`)
            # returning a List is a value-producing call, not a construction --
            # emit the call rather than falling to the empty-collection default.
            dct9: dottedChildText :ast n: (ast.nodes.get i: (n.callable - 1).u64)
            return dct9.length > 0
        }
        if cn.stringview == "List" then return false
        if cn.stringview == "Set" then return false
        if cn.stringview == "Map" then return false
        if cn.stringview == "Bytes" then return false
        if cn.stringview == "ByteView" then return false
        return true
    } else {
        return false
    }
}

# bindingRhsIsBorrow -- the binding RHS yields a non-owning borrow, so the bound
# String local must NOT be freed at scope exit (its owner -- the list or the
# struct -- frees it; a premature free is a use-after-free / double-free). Two
# shapes: a `<list>.get i:` over a List/ListView (a shallow element view), and a
# plain field access `<base>.<field>` (the field's String is owned by `<base>`).
# A no-arg method call (the child resolves to a FUNCTION) returns an owned value
# and is NOT a borrow. (Map.get returns an owned Option, handled elsewhere;
# `.copy` / `.string` / `.take` are owned and handled before this check.)
funcBorrowFlag: function {symtab: zenv.ZSymbolTable tid: u64} out bool is {
    if tid == 0 then return false
    g9: symtab.typing.funcReturnsBorrow.get key: tid
    match (
        g9
    ) case some then {
        return g9
    } case none then {
        return false
    }
}

# hoistExprIsBorrowRooted -- the hoisted expression's ROOT is a
# borrow-returning call (an element get and any field chain off it): the
# hoist is a shared view and must not register a free. Field chains off
# NAMED bases keep their existing legs untouched (a destructor-less box's
# field interp-free is load-bearing today).
hoistExprIsBorrowRooted: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
} out bool is {
    match (
        n
    ) case expression then {
        iex59: ast.nodes.get i: (n.expression - 1).u64
        return (hoistExprIsBorrowRooted :ast :symtab :ctx n: iex59)
    } case statementline then {
        sln9: ast.nodes.get i: (n.statementline - 1).u64
        return (hoistExprIsBorrowRooted :ast :symtab :ctx n: sln9)
    } case call then {
        return (callRhsIsBorrow :ast :symtab :ctx call: n)
    } case dottedpath then {
        return (hoistExprIsBorrowRooted :ast :symtab :ctx n: (ast.nodes.get i: (n.parent - 1).u64))
    } else {
        return false
    }
}

# callRhsIsBorrow -- the call-shaped leg of bindingRhsIsBorrow: the callee's
# declared return carries the `.borrow` marker (funcReturnsBorrow, recorded
# from the signature). Dotted method calls whose callable stamp missed probe
# the receiver mono's method child -- fully signature-driven (List/ListView
# element gets arrive here through their declared `out of.borrow`).
callRhsIsBorrow: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out bool is {
    cstid9: stampIdOf :symtab nid: (nodeIdOf9 n: (ast.nodes.get i: (call.callable - 1).u64))
    if (funcBorrowFlag :symtab tid: cstid9) then return true
    cnm9: atomTextOf :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    if cnm9.length > 0 then {
        ufid9: userFnId :ast :symtab :ctx name: cnm9.stringview
        if (funcBorrowFlag :symtab tid: ufid9) then return true
    }
    ch: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    if ch.length == 0 then return false
    rid: dottedReceiverStampId :ast :symtab callable: (ast.nodes.get i: (call.callable - 1).u64)
    rid = chaseColMono :ast :symtab tid: rid
    mfid9: optU64Or9 o: (symtab.typing.childOf
        pool: ast.names
        parentTypeId: rid
        name: ch.stringview
    )
    return (funcBorrowFlag :symtab tid: mfid9)
}

bindingRhsIsBorrow: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
} out bool is {
    match (
        n
    ) case expression then {
        return (bindingRhsIsBorrow :ast :symtab :ctx n: (ast.nodes.get i: (n.expression - 1).u64))
    } case statementline then {
        sln9: ast.nodes.get i: (n.statementline - 1).u64
        return (bindingRhsIsBorrow :ast :symtab :ctx n: sln9)
    } case call then {
        return (callRhsIsBorrow :ast :symtab :ctx call: n)
    } case dottedpath then {
        ch9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        bnm9: atomTextOf :ast n: (ast.nodes.get i: (n.parent - 1).u64)
        if (nvHas xs: ctx.narrowBox name: bnm9.stringview) then {
            # a field read off a narrowed subject is a shallow-copy borrow (it aliases
            # the subject's heap); an ownership builtin yields an owned value, and so
            # does a method auto-call (FUNCTION child) on the narrowed payload.
            if ch9.stringview == "take" then return false
            if ch9.stringview == "copy" then return false
            if ch9.stringview == "string" then return false
            ntO2: ntGet xs: ctx.narrowTid name: bnm9.stringview
            match (
                ntO2
            ) case some then {
                ncc9: symtab.typing.childOf pool: ast.names parentTypeId: ntO2 name: ch9.stringview
                match (
                    ncc9
                ) case some then {
                    if (symtab.reg.typetypeOf typeId: ncc9) == ztypes.ztypetype.functionType then return false
                } case none then null
            } case none then null
            return true
        }
        ptid9: stampIdOf :symtab nid: (nodeIdOf9 n: (ast.nodes.get i: (n.parent - 1).u64))
        cco9: symtab.typing.childOf pool: ast.names parentTypeId: ptid9 name: ch9.stringview
        match (
            cco9
        ) case some then {
            if (symtab.reg.typetypeOf typeId: cco9) == ztypes.ztypetype.functionType then return false
            return true
        } case none then {
            return false
        }
    } else {
        return false
    }
}

# emitStrConvCall -- the `.str` sized-conversion method on a String / StringView
# / str parent: `<parent>.str to: N` -> z_String_to_<name>(data, len). "" when
# not a .str-to-str conversion. The capacity rides the result mono type.
emitStrConvCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    mn: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    if mn.stringview != "str" then return "".string
    rid0: stampIdOf :symtab nid: call.nodeid.u64
    rid: chaseColMono :ast :symtab tid: rid0
    rori: monoOriginName :symtab tid: rid
    if (originIsTid :symtab tid: rid originTid: ctx.strOriginTid) == false then return "".string
    rmn: typeNameOfReg9 :symtab tid: rid
    rnm: cbaseNoPrefix tid: rid name: rmn.stringview
    pv: emitDottedReceiver :ast :symtab :ctx callable: (ast.nodes.get i: (call.callable - 1).u64)
    ptid: dottedReceiverStampId :ast :symtab callable: (ast.nodes.get i: (call.callable - 1).u64)
    ptn: typeNameOfReg9 :symtab tid: ptid
    lenAcc: "len".string
    if ptid == ctx.strTid then lenAcc = "size".string
    if ptid == ctx.svTid then lenAcc = "length".string
    return "\{ctx.strC}_to_\{rnm}(\{pv}.data, \{pv}.\{lenAcc})"
}

# allDigits -- true when s is non-empty and every byte is an ASCII digit 0-9.
# Distinguishes a numeric array index member (`a.0`) from a named member.
allDigits: function {s: StringView} out bool is {
    if s.length == 0 then return false
    i9: u64
    n9: s.length
    for i9 < n9 loop {
        bo9: s.byteAt i: i9
        match (
            bo9
        ) case some then {
            if bo9 < 48 then return false
            if bo9 > 57 then return false
        } case none then {
            return false
        }
        i9 = i9 + 1
    }
    return true
}

# emitBoxCreate -- `Box from: x`: heap-alloc a cell for the element and store x.
# Gated on the BOX_CREATE callKind stamp; hoists the alloc+store and returns the
# pointer temp. Mirrors the reference _emit_box_create (valtype/String inner).
emitBoxCreate: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    cko9: symtab.typing.callKind.get key: call.nodeid.u64
    isBoxC9: false
    match (
        cko9
    ) case some then {
        if cko9 == zast.callkind.boxCreate then isBoxC9 = true
    } case none then null
    if (isBoxC9) == false then return "".string
    bmid9: stampIdOf :symtab nid: call.nodeid.u64
    bmn9: typeNameOfReg9 :symtab tid: bmid9
    ben9: monoElemName full: bmn9 prefixLen: 4
    beid9: resolveTypeIdByName :ast :symtab :ctx name: ben9.stringview
    binner9: typeRefC :ast :symtab :ctx tid: beid9 thisTid: 0
    bval9: ctorArgByLabel :ast :symtab :ctx :call label: "from"
    bN9: ctx.argHoistCtr
    ctx.argHoistCtr = ctx.argHoistCtr + 1
    bnm9: "_Box\{bN9}"
    braw9: "    \{binner9}* \{bnm9} = (\{binner9}*)z_xmalloc(sizeof(\{binner9}));\n    *\{bnm9} = \{bval9};\n"
    ctx.argHoistRaw.append braw9
    return bnm9
}

# emitEmptyColCreate -- an empty collection construction `(List of: T)` /
# `(Set of: T)` / `(Map ...)` as a value: emit the collection mono's create with
# capacity 0, resolved from the call-node stamp. "" when not such a construction.
emitEmptyColCreate: function {ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    cn0: StringView
} out String is {
    if cn0 == "array" then {
        amid0: stampIdOf :symtab nid: (nodeIdOf9 n: (ast.nodes.get i: (call.callable - 1).u64))
        amid9: chaseColMono :ast :symtab tid: amid0
        amo9: monoOriginName :symtab tid: amid9
        if (originIsTid :symtab tid: amid9 originTid: ctx.arrayOriginTid) then {
            acb9: symtab.reg.cnameOf tid: amid9
            return "\{acb9}_create()"
        }
    }
    if cn0 == "str" then {
        smid0: stampIdOf :symtab nid: (nodeIdOf9 n: (ast.nodes.get i: (call.callable - 1).u64))
        smid9: chaseColMono :ast :symtab tid: smid0
        smo9: monoOriginName :symtab tid: smid9
        if (originIsTid :symtab tid: smid9 originTid: ctx.strOriginTid) then {
            scb9: symtab.reg.cnameOf tid: smid9
            return "\{scb9}_create()"
        }
    }
    isCol9: false
    if cn0 == "List" then isCol9 = true
    if cn0 == "Set" then isCol9 = true
    if cn0 == "Map" then isCol9 = true
    if (isCol9) == false then return "".string
    mid9: stampIdOf :symtab nid: call.nodeid.u64
    mid9 = chaseColMono :ast :symtab tid: mid9
    monoLk3: monoOriginName :symtab tid: mid9
    if monoLk3.length <= 0 then return "".string
    cb9: symtab.reg.cnameOf tid: mid9
    ccap9: listCapArg :ast :symtab :ctx n: (ast.nodes.get i: (call.nodeid - 1).u64)
    return "\{cb9}_create((uint64_t)\{ccap9})"
}

# colRecvRef -- a collection (List) receiver as a C lvalue for a method call: a
# ptrVar List (a by-pointer param) is already a pointer and passes directly; a
# value List passes its address.
colRecvRef: function {ctx: Ctx bn: StringView} out String is {
    if (isPtrVar :ctx name: bn) then return bn.string
    return "&\{bn}"
}

# emitCollectionMethodCall -- the collection method handlers behind ONE
# receiver computation: the receiver expression and its chased mono id are
# computed once, then the origin tid picks the array/List/Set/Map handler.
# "" when the receiver is not a collection mono (or the call is not dotted).
emitCollectionMethodCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    bn: emitDottedReceiver :ast :symtab :ctx callable: (ast.nodes.get i: (call.callable - 1).u64)
    if bn.length == 0 then return "".string
    mn: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    brid9: dottedReceiverStampId :ast :symtab callable: (ast.nodes.get i: (call.callable - 1).u64)
    bt: chaseColMono :ast :symtab tid: brid9
    # classify by the mono's ORIGIN NAME (the graph-independent identity):
    # a by-name-resolved origin tid can diverge from the mono's captured
    # genericOriginId when extra units register their own List/Map shells
    on9: monoOriginName :symtab tid: bt
    ov9: on9.stringview
    if ov9 == "array" then return (emitArrayMethodCall :ast :symtab :ctx :call :mn :bn :bt)
    isList9: false
    if ov9 == "List" then isList9 = true
    if ov9 == "ListView" then isList9 = true
    if isList9 then return (emitListMethodCall :ast :symtab :ctx :call :mn :bn :bt)
    if ov9 == "Set" then return (emitSetMethodCall :ast :symtab :ctx :call :mn :bn :bt)
    if ov9 == "Map" then return (emitMapMethodCall :ast :symtab :ctx :call :mn :bn :bt)
    return "".string
}

emitListMethodCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    mn: String
    bn: String
    bt: u64
} out String is {
    cb: symtab.reg.cnameOf tid: bt
    recvR9: colRecvRef :ctx bn: bn.stringview
    if mn.stringview == "append" then {
        v: colArg :ast :symtab :ctx :call label: "from" consumes: true
        e0: "\{cb}_append(\{recvR9}, \{v})"
        return e0
    }
    if mn.stringview == "get" then {
        v: listArg :ast :symtab :ctx :call label: "i"
        e1: "\{cb}_get(\{recvR9}, \{v})"
        return e1
    }
    if mn.stringview == "set" then {
        vi: listArg :ast :symtab :ctx :call label: "i"
        vv: listArg :ast :symtab :ctx :call label: "val"
        e2: "\{cb}_set(\{recvR9}, \{vi}, \{vv})"
        return e2
    }
    if mn.stringview == "pop" then {
        e3: "\{cb}_pop(\{recvR9})"
        return e3
    }
    if mn.stringview == "insert" then {
        vf: listArg :ast :symtab :ctx :call label: "from"
        va: listArg :ast :symtab :ctx :call label: "at"
        e4: "\{cb}_insert(\{recvR9}, \{vf}, \{va})"
        return e4
    }
    if mn.stringview == "extend" then {
        eaa: listTakeArgBase :ast :symtab :ctx :call label: "from"
        ea: ztypes.mangleVarName name: eaa.stringview
        e5: "\{cb}_extend(\{recvR9}, &\{ea})"
        return e5
    }
    if mn.stringview == "contains" then {
        vc: listArg :ast :symtab :ctx :call label: "item"
        e6: "\{cb}_contains(\{recvR9}, \{vc})"
        return e6
    }
    if mn.stringview == "sort" then {
        e7: "\{cb}_sort(\{recvR9})"
        return e7
    }
    return "".string
}

# emitArrayMethodCall -- `.get i:` / `.set i: val:` on a fixed-size array mono
# receiver (a value type). get takes the receiver by value; set by address (it
# returns the previous element). "" when the receiver isn't an array mono.
emitArrayMethodCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    mn: String
    bn: String
    bt: u64
} out String is {
    cb: symtab.reg.cnameOf tid: bt
    if mn.stringview == "get" then {
        vi: listArg :ast :symtab :ctx :call label: "i"
        return "\{cb}_get(\{bn}, \{vi})"
    }
    if mn.stringview == "set" then {
        vi: listArg :ast :symtab :ctx :call label: "i"
        vv: listArg :ast :symtab :ctx :call label: "val"
        recvR9: colRecvRef :ctx bn: bn.stringview
        return "\{cb}_set(\{recvR9}, \{vi}, \{vv})"
    }
    return "".string
}

# emitSetMethodCall -- an arg-taking method on a Set-mono receiver (a heap
# pointer, so the receiver passes directly without `&`). "" when not a Set
# call; the no-arg `.length`/`.iterate` reads ride the dottedpath leg.
emitSetMethodCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    mn: String
    bn: String
    bt: u64
} out String is {
    cb: symtab.reg.cnameOf tid: bt
    if mn.stringview == "add" then {
        v: colArg :ast :symtab :ctx :call label: "item" consumes: true
        e0: "\{cb}_add(\{bn}, \{v})"
        return e0
    }
    if mn.stringview == "has" then {
        v: colArg :ast :symtab :ctx :call label: "item" consumes: false
        e1: "\{cb}_has(\{bn}, \{v})"
        return e1
    }
    if mn.stringview == "delete" then {
        v: colArg :ast :symtab :ctx :call label: "item" consumes: false
        e2: "\{cb}_delete(\{bn}, \{v})"
        return e2
    }
    return "".string
}

# emitMapMethodCall -- an arg-taking method on a Map-mono receiver (a heap
# pointer). set/get/has/delete pass the pointer directly; "" otherwise. The
# no-arg `.length`/`.capacity` reads ride the dottedpath leg.
emitMapMethodCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    mn: String
    bn: String
    bt: u64
} out String is {
    cb: symtab.reg.cnameOf tid: bt
    if mn.stringview == "set" then {
        vk: colArg :ast :symtab :ctx :call label: "key" consumes: true
        vv: colArg :ast :symtab :ctx :call label: "value" consumes: true
        e0: "\{cb}_set(\{bn}, \{vk}, \{vv})"
        return e0
    }
    if mn.stringview == "get" then {
        vk: colArg :ast :symtab :ctx :call label: "key" consumes: false
        e1: "\{cb}_get(\{bn}, \{vk})"
        return e1
    }
    if mn.stringview == "getv" then {
        vk: colArg :ast :symtab :ctx :call label: "key" consumes: false
        e19: "\{cb}_getv(\{bn}, \{vk})"
        return e19
    }
    if mn.stringview == "has" then {
        vk: colArg :ast :symtab :ctx :call label: "key" consumes: false
        e2: "\{cb}_has(\{bn}, \{vk})"
        return e2
    }
    if mn.stringview == "remove" then {
        vk: colArg :ast :symtab :ctx :call label: "key" consumes: false
        e9: "\{cb}_remove(\{bn}, \{vk})"
        return e9
    }
    return "".string
}

# emitInterpArgExpr -- if n is (or wraps/projects via .string/.stringview) an
# interpolated string literal, return a self-contained statement expression that
# builds and yields the owned String; "" otherwise. Used for inline argument
# positions, where the pure emitExpr cannot emit the multi-statement interp build.
emitInterpArgExpr: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
} out String is {
    match (
        n
    ) case expression then {
        return (emitInterpArgExpr :ast :symtab :ctx n: (ast.nodes.get i: (n.expression - 1).u64))
    } case atomstring then {
        if (isInterp :ast parts: n.stringparts) then {
            ltmp: (TmpCtr
                n: 0
                frees: (List String)
                listFrees: (List String)
                listFreeVars: (List String)
            )
            lbuf: String
            sM: (emitInterpBuild
                :ast
                :symtab
                :ctx
                parts: n.stringparts
                ind: " "
                tmp: ltmp
                buf: lbuf
            )
            r: "({ \{lbuf}_s\{sM}; })"
            return r
        }
        return "".string
    } case dottedpath then {
        cm: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if cm.stringview == "string" then {
            dpp9: ast.nodes.get i: (n.parent - 1).u64
            return (emitInterpArgExpr :ast :symtab :ctx n: dpp9)
        }
        if cm.stringview == "stringview" then return (emitInterpArgExpr
            :ast
            :symtab
            :ctx
            n: (ast.nodes.get i: (n.parent - 1).u64)
        )
        return "".string
    } else {
        return "".string
    }
}

# emitInterpStmtValue -- like emitInterpArgExpr, but emits the interp build chain
# as PRIOR statements into buf (so a referenced local is read at THIS point) and
# returns the owned-String temp name "_sN"; "" otherwise. Used where the build
# must precede the statement -- a reassignment drop-old, so `s = "\{s}x"` reads
# old s before the old value is freed (mirrors emitStringBindValue / the
# reference's _temp.decls). emitInterpBuild does NOT register _sN for free, so the
# assignment `nm2 = _sN` moves the storage into the lvalue with no double-free.
emitInterpStmtValue: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} out String is {
    match (
        n
    ) case expression then {
        iex49: ast.nodes.get i: (n.expression - 1).u64
        return (emitInterpStmtValue :ast :symtab :ctx n: iex49 :ind :tmp :buf)
    } case atomstring then {
        if (isInterp :ast parts: n.stringparts) then {
            sB: emitInterpBuild :ast :symtab :ctx parts: n.stringparts :ind :tmp :buf
            return "_s\{sB}"
        }
        return "".string
    } case dottedpath then {
        cm: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if cm.stringview == "string" then {
            dpr9: ast.nodes.get i: (n.parent - 1).u64
            return (emitInterpStmtValue :ast :symtab :ctx n: dpr9 :ind :tmp :buf)
        }
        if cm.stringview == "stringview" then {
            dpr9: ast.nodes.get i: (n.parent - 1).u64
            return (emitInterpStmtValue :ast :symtab :ctx n: dpr9 :ind :tmp :buf)
        }
        return "".string
    } else {
        return "".string
    }
}

# emitColInterpArg -- an interpolated-string collection-method argument hoisted to
# an owned String temp via the argHoist mechanism (flushed at the statement). When
# the method BORROWS the arg (consumes == false: has/delete/get), a scope-exit
# free is registered; a consuming method (add/set) moves the temp in. "" when n is
# not an interpolated string.
emitColInterpArg: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    consumes: bool
} out String is {
    sx: emitInterpArgExpr :ast :symtab :ctx :n
    if sx.length == 0 then {
        if consumes then return "".string
        tn9: stampNameDeep :ast :symtab :n
        if tn9.stringview != "String" then return "".string
        ex9: emitExpr :ast :symtab :ctx :n
        if (isNonLvalueArg s: ex9.stringview) == false then return "".string
        sx = ex9
    }
    hn: ctx.argHoistCtr
    ctx.argHoistCtr = ctx.argHoistCtr + 1
    nmH: "_ah\{hn}"
    hdt: String
    if (consumes) == false when (hoistExprIsBorrowRooted :ast :symtab :ctx :n) == false then {
        hdt = "    \{ctx.strC}_free(&\{nmH});\n"
    }
    retx: nmH.copy
    ctx.argHoistVals.append sx
    ctx.argHoistTypes.append "\{ctx.strC}_t"
    ctx.argHoistDtors.append hdt
    ctx.argHoistNames.append nmH
    return retx
}

# emitInterpArgForParam -- an interpolated-string-literal argument built into a
# hoisted temp `_ah<N>` and coerced to the parameter's C form: a String.take
# param moves the temp in (no free); a String borrow takes it by pointer; a
# StringView param gets a by-value view. The temp is freed at block exit unless
# moved into a take param. Returns "" when the argument is not an interpolated
# literal (the caller emits it normally). Mirrors emitColInterpArg's hoist but
# generalises the returned form across param kinds.
emitInterpArgForParam: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    fid: u64
    pname: StringView
    pid: u64
} out String is {
    sx: emitInterpArgExpr :ast :symtab :ctx :n
    if sx.length == 0 then return "".string
    isTake: false
    if pid == ctx.strTid when (symtab.typing.childOwnershipIs
        pool: ast.names
        parentTypeId: fid
        name: pname
        own: ztypes.zparamownership.takeMode
    ) then isTake = true
    hn: ctx.argHoistCtr
    ctx.argHoistCtr = ctx.argHoistCtr + 1
    nmH: "_ah\{hn}"
    hdt: String
    if (isTake) == false then hdt = "    \{ctx.strC}_free(&\{nmH});\n"
    retx: String
    if pid == ctx.strTid then {
        if isTake then {
            retx = nmH.copy
        } else {
            retx = "&\{nmH}"
        }
    } else {
        retx = svValueForm :ctx expr: nmH.stringview isStr: true
    }
    ctx.argHoistVals.append sx
    ctx.argHoistTypes.append "\{ctx.strC}_t"
    ctx.argHoistDtors.append hdt
    ctx.argHoistNames.append nmH
    return retx
}

# colArg -- a collection-method argument: the interp-string hoist when the arg is
# an interpolated literal, else the plain expression (mirrors listArg). consumes
# distinguishes take params (add/set) from borrow params (has/delete/get).
colArg: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    label: StringView
    consumes: bool
} out String is {
    posFirst: String
    havePos: false
    aiter: call.arguments.iterate
    for aId9: aiter loop {
        a: ast.nodes.get i: (aId9 - 1).u64
        match (
            a
        ) case namedoperation then {
            an: zast.nameTextCopy :ast ref: a.name
            if an.stringview == label then {
                ic: (emitColInterpArg
                    :ast
                    :symtab
                    :ctx
                    n: (ast.nodes.get i: (a.operation - 1).u64)
                    :consumes
                )
                if ic.length > 0 then return ic
                return (emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (a.operation - 1).u64))
            }
            if an.length == 0 when havePos == false then {
                havePos = true
                icp: (emitColInterpArg
                    :ast
                    :symtab
                    :ctx
                    n: (ast.nodes.get i: (a.operation - 1).u64)
                    :consumes
                )
                if icp.length > 0 then {
                    posFirst = icp
                } else {
                    opf119: ast.nodes.get i: (a.operation - 1).u64
                    posFirst = emitExpr :ast :symtab :ctx n: opf119
                }
            }
        } else null
    }
    if havePos then return posFirst
    return "0".string
}

# listArg -- the C expression for a labeled list-method argument ("0" if
# absent).
listArg: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    label: StringView
} out String is {
    posFirst: String
    havePos: false
    aiter: call.arguments.iterate
    for aId9: aiter loop {
        a: ast.nodes.get i: (aId9 - 1).u64
        match (
            a
        ) case namedoperation then {
            an: zast.nameTextCopy :ast ref: a.name
            if an.stringview == label then return (emitExpr
                :ast
                :symtab
                :ctx
                n: (ast.nodes.get i: (a.operation - 1).u64)
            )
            if an.length == 0 when havePos == false then {
                havePos = true
                opf129: ast.nodes.get i: (a.operation - 1).u64
                posFirst = emitExpr :ast :symtab :ctx n: opf129
            }
        } else null
    }
    # a single positional arg binds to the (sole) labelless call site, e.g.
    # `xs.get i2` -> the `i` param.
    if havePos then return posFirst
    return "0".string
}

# listTakeArgBase -- the base atom of a `x.take` list argument (the
# extend source); the bare atom text otherwise.
listTakeArgBase: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    label: StringView
} out String is {
    aiter: call.arguments.iterate
    for aId9: aiter loop {
        a: ast.nodes.get i: (aId9 - 1).u64
        match (
            a
        ) case namedoperation then {
            an: zast.nameTextCopy :ast ref: a.name
            if an.stringview == label then return (takeArgBase
                :ast
                n: (ast.nodes.get i: (a.operation - 1).u64)
            )
        } else null
    }
    return "0".string
}

takeArgBase: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case expression then {
        return (takeArgBase :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case dottedpath then {
        return (atomTextOf :ast n: (ast.nodes.get i: (n.parent - 1).u64))
    } case atomid then {
        return (zast.nameTextCopy :ast ref: n.name)
    } else {
        return "0".string
    }
}

# emitTypedefCreateCall -- `meters.create from: 42` / `meters 42`: a
# zero-overhead cast; emit the single argument expression.
emitTypedefCreateCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    calr9: ast.nodes.get i: (call.callable - 1).u64
    bn: dottedBaseAtom :ast n: calr9
    if bn.length == 0 then bn = atomTextOf :ast n: calr9
    if bn.length == 0 then return "".string
    tid: userFnId :ast :symtab :ctx name: bn.stringview
    if tid == 0 then {
        so9: (ztypecheck.resolveSystemChild
            :ast
            ty: symtab.typing
            reg: symtab.reg
            name: bn.stringview
        )
        match (
            so9
        ) case some then {
            tid = so9
        } case none then null
    }
    if tid == 0 then return "".string
    if (isTypedefType :symtab :tid) == false then return "".string
    aiter: call.arguments.iterate
    for aId9: aiter loop {
        a: ast.nodes.get i: (aId9 - 1).u64
        match (
            a
        ) case namedoperation then {
            return (emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (a.operation - 1).u64))
        } else null
    }
    return "0".string
}

# emitVariantCtorCall -- `result.ok 42`: a dotted callee whose base is a
# variant type and whose member is a payload arm; emits a designated
# compound literal.
# emitInlineVariantCtor -- a value (inline-payload) variant/optionval/resultval
# constructor as a compound literal: some-arm carries the first arg in .data.arm,
# none-arm just the tag. tid is the concrete VARIANT/mono type.
emitInlineVariantCtor: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    tid: u64
    arm: StringView
} out String is {
    pc: armPayloadC :ast :symtab :ctx :tid :arm
    tg: variantTag :symtab :tid :arm
    vc: symtab.reg.cnameOf :tid
    if pc.length > 0 then {
        av: "0".string
        aiter: call.arguments.iterate
        got: false
        for aId9: aiter loop {
            a: ast.nodes.get i: (aId9 - 1).u64
            match (
                a
            ) case namedoperation then {
                if (got) == false then {
                    got = true
                    opf139: ast.nodes.get i: (a.operation - 1).u64
                    av = emitExpr :ast :symtab :ctx n: opf139
                }
            } else null
        }
        e0: "((\{vc}_t){ .tag = \{tg}, .data.\{arm} = (\{av}) })"
        return e0
    } else {
        e1: "((\{vc}_t){ .tag = \{tg} })"
        return e1
    }
}

# emitUnionCtor -- a main-unit user union arm construction (`U.arm payload`):
# a GCC statement-expression building the heap-payload union value (tag + a
# malloc'd box for the payload, or NULL data for a payload-less arm). Generic
# monos (Option/Result) keep their own emission paths.
emitUnionCtor: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    bn: dottedBaseAtom :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    if bn.length == 0 then return "".string
    mn: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    if mn.length == 0 then return "".string
    smid0: stampIdOf :symtab nid: call.nodeid.u64
    smOrig9: monoOriginName :symtab tid: smid0
    # system union monos (optionval/resultval/Option/Result) are built by
    # emitVariantCtorCall; only USER generic union monos are built here.
    if smOrig9.length > 0 then {
        sysU9: false
        if (originIsTid :symtab tid: smid0 originTid: ctx.optionvalOriginTid) then sysU9 = true
        if (originIsTid :symtab tid: smid0 originTid: ctx.resultvalOriginTid) then sysU9 = true
        if (originIsTid :symtab tid: smid0 originTid: ctx.optionOriginTid) then sysU9 = true
        if (originIsTid :symtab tid: smid0 originTid: ctx.resultOriginTid) then sysU9 = true
        if sysU9 then return "".string
    }
    utid: resolveTypeIdByName :ast :symtab :ctx name: bn.stringview
    if utid == 0 then return "".string
    if (symtab.reg.typetypeOf typeId: utid) != ztypes.ztypetype.unionType then return "".string
    # build from the mono (smid0) for a user generic union; else the named template
    ctid9: utid
    if smOrig9.length > 0 when (symtab.reg.typetypeOf typeId: smid0) == ztypes.ztypetype.unionType then {
        ctid9 = smid0
    }
    vc: symtab.reg.cnameOf tid: ctid9
    tg: variantTag :symtab tid: ctid9 arm: mn.stringview
    payC: armPayloadC :ast :symtab :ctx tid: ctid9 arm: mn.stringview
    if payC.length > 0 then {
        av: String
        got: false
        aiter: call.arguments.iterate
        for aId9: aiter loop {
            a: ast.nodes.get i: (aId9 - 1).u64
            match (
                a
            ) case namedoperation then {
                if (got) == false then {
                    got = true
                    # an interpolated payload builds via a self-contained
                    # statement expression (emitExpr cannot emit the chain)
                    opf149: ast.nodes.get i: (a.operation - 1).u64
                    av = emitInterpArgExpr :ast :symtab :ctx n: opf149
                    if av.length == 0 then {
                        opf1019: ast.nodes.get i: (a.operation - 1).u64
                        av = emitExpr :ast :symtab :ctx n: opf1019
                    }
                }
            } else null
        }
        e: "({ \{vc}_t _u = {0}; _u.tag = \{tg}; \{payC}* _b = (\{payC}*)z_xmalloc(sizeof(\{payC})); *_b = \{av}; _u.data = _b; _u; })"
        return e
    } else {
        e2: "({ \{vc}_t _u = {0}; _u.tag = \{tg}; _u.data = NULL; _u; })"
        return e2
    }
}

emitVariantCtorCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    bn: dottedBaseAtom :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    mn: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    if bn.length == 0 then return "".string
    # system monos (optionval/resultval inline, Option none) -- the call node is
    # stamped with the concrete mono id (userFnId fails for these). Option.some
    # is a heap box handled by emitOptionBoxHoist at the statement site.
    smid: stampIdOf :symtab nid: call.nodeid.u64
    sorig: monoOriginName :symtab tid: smid
    sInline: false
    if (originIsTid
        :symtab
        tid: smid
        originTid: ctx.optionvalOriginTid
    ) when bn.stringview == "optionval" then sInline = true
    if (originIsTid
        :symtab
        tid: smid
        originTid: ctx.resultvalOriginTid
    ) when bn.stringview == "resultval" then sInline = true
    if sInline then return (emitInlineVariantCtor
        :ast
        :symtab
        :ctx
        :call
        tid: smid
        arm: mn.stringview
    )
    if (originIsTid :symtab tid: smid originTid: ctx.optionOriginTid) then {
        ovc9: symtab.reg.cnameOf tid: smid
        if mn.stringview == "none" then {
            otg9: variantTag :symtab tid: smid arm: "none"
            en9: "((\{ovc9}_t){ .tag = \{otg9}, .data = NULL })"
            return en9
        }
        if mn.stringview == "some" then {
            otg9s: variantTag :symtab tid: smid arm: "some"
            opayC9: armPayloadC :ast :symtab :ctx tid: smid arm: "some"
            if opayC9.length == 0 then return "".string
            oav9: "0".string
            ogot9: false
            oaiter9: call.arguments.iterate
            for oa9Id9: oaiter9 loop {
                oa9: ast.nodes.get i: (oa9Id9 - 1).u64
                match (
                    oa9
                ) case namedoperation then {
                    if (ogot9) == false then {
                        ogot9 = true
                        # an interpolated payload builds via a self-contained
                        # statement expression (emitExpr cannot emit the chain)
                        opf159: ast.nodes.get i: (oa9.operation - 1).u64
                        oav9 = emitInterpArgExpr :ast :symtab :ctx n: opf159
                        if oav9.length == 0 then {
                            opf1029: ast.nodes.get i: (oa9.operation - 1).u64
                            oav9 = emitExpr :ast :symtab :ctx n: opf1029
                        }
                    }
                } else null
            }
            es9: "({ \{ovc9}_t _u = {0}; _u.tag = \{otg9s}; \{opayC9}* _b = (\{opayC9}*)z_xmalloc(sizeof(\{opayC9})); *_b = \{oav9}; _u.data = _b; _u; })"
            return es9
        }
        return "".string
    }
    vtid: userFnId :ast :symtab :ctx name: bn.stringview
    if vtid == 0 then return "".string
    if (symtab.reg.typetypeOf typeId: vtid) != ztypes.ztypetype.variantType then return "".string
    return (emitInlineVariantCtor :ast :symtab :ctx :call tid: vtid arm: mn.stringview)
}

# emitColTypedefCall -- `ByteView.borrow from: X` / `Bytes.create from: X` on a
# collection-typedef-class (Bytes/ByteView): the typedef is a zero-overhead
# alias, so the borrow/create is transparent -- emit the underlying arg. ""
# for any non-collection-typedef base.
emitColTypedefCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    bn: dottedBaseAtom :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    if bn.length == 0 then return "".string
    mn: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    isBC: false
    if mn.stringview == "borrow" then isBC = true
    if mn.stringview == "create" then isBC = true
    if (isBC) == false then return "".string
    bid: resolveTypeIdByName :ast :symtab :ctx name: bn.stringview
    if bid == 0 then return "".string
    mid: chaseColMono :ast :symtab tid: bid
    if mid == bid then return "".string
    return (ctorArgByLabel :ast :symtab :ctx :call label: "from")
}

# emitTypeQualCall -- `point.add a: x b: y`: a dotted callee whose base
# resolves to a record type and whose member is a FUNCTION child; args
# reorder to the method's param order by label.
emitTypeQualCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    bn: dottedBaseAtom :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    mn: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    if bn.length == 0 then return "".string
    btid: userFnId :ast :symtab :ctx name: bn.stringview
    if btid == 0 then return "".string
    bttq: symtab.reg.typetypeOf typeId: btid
    isStructQ: false
    if bttq == ztypes.ztypetype.recordType then isStructQ = true
    if bttq == ztypes.ztypetype.classType then isStructQ = true
    if (isStructQ) == false then return "".string
    mco: symtab.typing.childOf pool: ast.names parentTypeId: btid name: mn.stringview
    match (
        mco
    ) case some then {
        if (symtab.reg.typetypeOf typeId: mco) == ztypes.ztypetype.functionType then {
            pnames: (List String)
            pids: (List u64)
            pidsNm: (List u64)
            recFieldLists :ast :symtab tid: mco names: pnames ids: pids nameIds: pidsNm
            # a synthesized `create` (no body) has field-shaped params but no
            # emitted create fn -- route it to the type's field-wise ctor, the
            # path bare-name construction uses; a user create (a body) is called.
            mcBody9: false
            {
                mcrn9: symtab.typing.funcReturnNode.get key: mco
                match (
                    mcrn9
                ) case some then {
                    mcBody9 = true
                } case none then null
            }
            if mn.stringview == "create" when mcBody9 == false then {
                return (emitRecordCtor :ast :symtab :ctx :call tid: btid name: bn.stringview)
            }
            pn: pnames.length
            args: String
            if mn.stringview == "create" then {
                # user create: args by the create's own param labels
                pi: u64
                for pi < pn loop {
                    pname: pnames.get i: pi
                    av: ctorArgByLabel :ast :symtab :ctx :call label: pname.stringview
                    if pi > 0 then args.append ", "
                    args.append av.stringview
                    pi = pi + 1
                }
            } else {
                # a method: positional args; a CLASS receiver passes by address
                clsNmQ: typeNameOfReg9 :symtab tid: btid
                ai9: u64
                with aiterQ: call.arguments.iterate do for aQId9: aiterQ loop {
                    aQ: ast.nodes.get i: (aQId9 - 1).u64
                    match (
                        aQ
                    ) case namedoperation then {
                        avq: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (aQ.operation - 1).u64)
                        byRef9: false
                        if bttq == ztypes.ztypetype.classType when ai9 < pn then {
                            ppid9: pids.get i: ai9
                            pptn9: typeNameOfReg9 :symtab tid: ppid9
                            if pptn9.stringview == "this" then byRef9 = true
                            if pptn9.stringview == clsNmQ.stringview then byRef9 = true
                            if ppid9 == btid then byRef9 = true
                        }
                        if (pathIsPointer
                            :ast
                            :symtab
                            :ctx
                            n: (ast.nodes.get i: (aQ.operation - 1).u64)
                        ) then byRef9 = false
                        if ai9 > 0 then args.append ", "
                        if byRef9 then {
                            argq9: "&\{avq}"
                            args.append argq9.stringview
                        } else {
                            args.append avq.stringview
                        }
                        ai9 = ai9 + 1
                    } else null
                }
            }
            mc3: symtab.reg.cnameOf tid: mco
            e7: "\{mc3}(\{args})"
            return e7
        }
    } case none then null
    return "".string
}

# emitRecordCtor -- a record construction call: args reordered to field
# order by label, emitted through the create alias.
# sliceAfterColon -- the substring after the first ':' (the payload of a tagged
# default encoding `#kind:payload`).
sliceAfterColon: function {s: StringView} out String is {
    r: String
    n: s.length
    i: u64
    found: false
    for i < n loop {
        b: s.byteAt :i
        match (
            b
        ) case some then {
            if found then {
                r.appendByte :b
            } else {
                if b == 58 then found = true
            }
        } case none then null
        i = i + 1
    }
    return r
}

# renderDefault -- a stored default string as a C expression. Numeric defaults
# pass through; `#function:NAME` -> the target FUNCTION type's symbol (the param
# IS that function); `#variant:ARM` -> a tag-only struct literal of the target.
renderDefault: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    default: StringView
    targetTid: u64
} out String is {
    if default.length == 0 then return "".string
    fb: default.byteAt i: 0
    isHash: false
    match (
        fb
    ) case some then {
        if fb == 35 then isHash = true
    } case none then null
    if isHash == false then return default.string
    b1: default.byteAt i: 1
    match (
        b1
    ) case some then {
        if b1 == 102 then {
            tn: typeNameOfReg9 :symtab tid: targetTid
            cf9: userFnId :ast :symtab :ctx name: tn.stringview
            if cf9 > 0 then return (cnameOf tid: cf9 name: tn.stringview)
            return (cnameOf tid: targetTid name: tn.stringview)
        }
        if b1 == 118 then {
            arm: sliceAfterColon s: default
            tn2: typeNameOfReg9 :symtab tid: targetTid
            cv9: userFnId :ast :symtab :ctx name: tn2.stringview
            vtarget9: targetTid
            if cv9 > 0 then vtarget9 = cv9
            tg: variantTag :symtab tid: vtarget9 arm: arm.stringview
            tc: typeRefC :ast :symtab :ctx tid: vtarget9 thisTid: 0
            return "(\{tc}){ .tag = \{tg} }"
        }
    } case none then null
    return default.string
}

# fnTypeTakesThis -- a FUNCTION type whose signature carries a `this` receiver
# (a method-ref slot auto-calls through itself with the receiver).
fnTypeTakesThis: function {symtab: zenv.ZSymbolTable tid: u64} out bool is {
    t: symtab.reg.typeById.get key: tid
    match (
        t
    ) case some then {
        match (
            t.thisParamName
        ) case some then {
            return true
        } case none then {
            return false
        }
    } case none then {
        return false
    }
}

# emitAllDefaultedCall -- a bare reference to a function whose params are ALL
# defaulted is a no-arg auto-call: `describe` -> `z_..._describe(<defaults>)`.
# "" when the function has no params or any param lacks a default.
emitAllDefaultedCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    fnTid: u64
    fcn: StringView
} out String is {
    pn: (List String)
    pidl: (List u64)
    pidlNm: (List u64)
    recFieldLists :ast :symtab tid: fnTid names: pn ids: pidl nameIds: pidlNm
    m: pn.length
    if m == 0 then return "".string
    j: u64
    allDef: true
    for j < m loop {
        pnjId: pidlNm.get i: j
        if (symtab.typing.hasChildDefaultId parentTypeId: fnTid nameId: pnjId) == false then {
            allDef = false
        }
        j = j + 1
    }
    if allDef == false then return "".string
    args: String
    k: u64
    for k < m loop {
        pik: pidl.get i: k
        pnkId: pidlNm.get i: k
        dt: symtab.typing.childDefaultTextId parentTypeId: fnTid nameId: pnkId
        rv: renderDefault :ast :symtab :ctx default: dt.stringview targetTid: pik
        if k > 0 then args.append ", "
        args.append rv.stringview
        k = k + 1
    }
    r: "\{fcn}(\{args})"
    return r
}

# renderedMethodDefaultArgs -- the comma-joined rendered defaults for every
# non-receiver parameter of a method, when ALL of them carry defaults; ""
# when any is required or there are none (the caller keeps its emission).
renderedMethodDefaultArgs: function {
    ast: Ast

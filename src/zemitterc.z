emitPrintArg: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    match (
        n
    ) case expression then {
        emitPrintArg :ast :symtab :ctx n: (ast.nodes.get i: (n.expression - 1).u64) :ind :tmp :buf
    } case atomstring then {
        if (isInterp :ast parts: n.stringparts) then {
            emitInterpPrint :ast :symtab :ctx parts: n.stringparts :ind :tmp :buf
        } else {
            li: litIndexOf :ctx nid: n.nodeid.u64
            if li > 0 then {
                l9: "\{ind}\{ctx.svC}_print(_zs\{li});\n"
                buf.append l9.stringview
            } else {
                buf.append "    /* zemitterc: unpooled literal */\n"
            }
        }
    } case atomid then {
        tn9: stampNameOf :symtab nid: n.nodeid.u64
        anC9: zast.nameTextCopy :ast ref: n.name
        an9: anC9.stringview
        anm: aliasResolve :ctx name: an9
        if (stampIdOf :symtab nid: n.nodeid.u64) == ctx.strTid then {
            if (isPtrVar :ctx name: anm.stringview) then {
                lps: "\{ind}\{ctx.strC}_print(\{anm});\n"
                buf.append lps.stringview
            } else {
                lps2: "\{ind}\{ctx.strC}_print(&\{anm});\n"
                buf.append lps2.stringview
            }
        } else if (stampIdOf :symtab nid: n.nodeid.u64) == ctx.svTid then {
            lpv: "\{ind}\{ctx.svC}_print(\{anm});\n"
            buf.append lpv.stringview
        } else {
            argTid: stampIdOf :symtab nid: n.nodeid.u64
            pOrig9: monoOriginName :symtab tid: argTid
            if (originIsTid :symtab tid: argTid originTid: ctx.strOriginTid) then {
                lpstr9: "\{ind}\{ctx.svC}_print((\{ctx.svC}_t){\{anm}.data, \{anm}.len});\n"
                buf.append lpstr9.stringview
                return
            }
            svco: symtab.typing.childOfId parentTypeId: argTid nameId: wkStringview
            match (
                svco
            ) case some then {
                mcb: symtab.reg.cnameOf tid: svco
                amn: monoOriginName :symtab tid: argTid
                usesAmp: false
                if (symtab.reg.typetypeOf typeId: argTid) == ztypes.ztypetype.classType when amn.length == 0 then {
                    if (isPtrVar :ctx name: anm.stringview) == false then usesAmp = true
                }
                if usesAmp then {
                    lpt: "\{ind}\{ctx.svC}_print(\{mcb}(&\{anm}));\n"
                    buf.append lpt.stringview
                } else {
                    lpt2: "\{ind}\{ctx.svC}_print(\{mcb}(\{anm}));\n"
                    buf.append lpt2.stringview
                }
            } case none then {
                lpu: "\{ind}/* zemitterc: unhandled print of \{anm} type \{tn9} */\n"
                buf.append lpu.stringview
            }
        }
    } case call then {
        ce9: emitCallValue :ast :symtab :ctx call: n
        flushArgHoists :ctx :ind :tmp :buf
        rtn9: stampNameOf :symtab nid: n.nodeid.u64
        if (stampIdOf :symtab nid: n.nodeid.u64) == ctx.svTid then {
            lpcv9: "\{ind}\{ctx.svC}_print(\{ce9});\n"
            buf.append lpcv9.stringview
        } else {
            hpc9: tmp.next
            lpa9: "\{ind}\{ctx.strC}_t _h\{hpc9} = \{ce9};\n"
            buf.append lpa9.stringview
            lpb9: "\{ind}\{ctx.strC}_print(&_h\{hpc9});\n"
            buf.append lpb9.stringview
            lpf9: "\{ind}\{ctx.strC}_free(&_h\{hpc9});\n"
            buf.append lpf9.stringview
        }
    } else {
        eid9: nodeIdOf9 :n
        etn9: stampNameOf :symtab nid: eid9
        if (stampIdOf :symtab nid: eid9) == ctx.svTid then {
            ev9: emitExpr :ast :symtab :ctx :n
            flushArgHoists :ctx :ind :tmp :buf
            lpe9: "\{ind}\{ctx.svC}_print(\{ev9});\n"
            buf.append lpe9.stringview
        } else if (stampIdOf :symtab nid: eid9) == ctx.strTid then {
            es9: emitExpr :ast :symtab :ctx :n
            flushArgHoists :ctx :ind :tmp :buf
            if (isNonLvalueArg s: es9.stringview) then {
                hps9: tmp.next
                lsa9: "\{ind}\{ctx.strC}_t _h\{hps9} = \{es9};\n"
                buf.append lsa9.stringview
                lsb9: "\{ind}\{ctx.strC}_print(&_h\{hps9});\n"
                buf.append lsb9.stringview
                lsf9: "\{ind}\{ctx.strC}_free(&_h\{hps9});\n"
                buf.append lsf9.stringview
            } else {
                lsl9: "\{ind}\{ctx.strC}_print(&\{es9});\n"
                buf.append lsl9.stringview
            }
        } else {
            buf.append "    /* zemitterc: unhandled print argument */\n"
        }
    }
}

# bindLitIndex -- the pool index of a plain-literal value node (0 = none).
bindLitIndex: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out u64 is {
    match (
        n
    ) case expression then {
        return (bindLitIndex :ast :symtab :ctx n: (ast.nodes.get i: (n.expression - 1).u64))
    } case atomstring then {
        if (isInterp :ast parts: n.stringparts) then {
            return 0
        } else {
            return (litIndexOf :ctx nid: n.nodeid.u64)
        }
    } else {
        return 0
    }
}

# stringviewOfBase -- the base name of `X.stringview` over a String local
# ("" otherwise).
stringviewOfBase: function {ast: Ast symtab: zenv.ZSymbolTable n: Node} out String is {
    match (
        n
    ) case expression then {
        return (stringviewOfBase :ast :symtab n: (ast.nodes.get i: (n.expression - 1).u64))
    } case dottedpath then {
        mn: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if mn.stringview == "stringview" then {
            bnid: atomNodeId9 n: (ast.nodes.get i: (n.parent - 1).u64)
            bt: stampNameOf :symtab nid: bnid
            if (stampIdOf :symtab nid: bnid) == (builtinTid :ast :symtab base: "String") then {
                return (atomTextOf :ast n: (ast.nodes.get i: (n.parent - 1).u64))
            }
        }
        return "".string
    } else {
        return "".string
    }
}

# stringCopyLitIndex -- the pool index of `\"lit\".string` (0 otherwise).
stringCopyLitIndex: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
} out u64 is {
    match (
        n
    ) case expression then {
        return (stringCopyLitIndex :ast :symtab :ctx n: (ast.nodes.get i: (n.expression - 1).u64))
    } case dottedpath then {
        mn: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if mn.stringview == "string" then {
            return (bindLitIndex :ast :symtab :ctx n: (ast.nodes.get i: (n.parent - 1).u64))
        } else {
            return 0
        }
    } else {
        return 0
    }
}

# copyRvalueHoist -- `<rvalue>.copy` over a String (e.g. `(list.get i: n).copy`):
# the receiver is a non-lvalue, so hoist it to a borrowed temp (`list.get` returns
# a shallow view -- never freed) and return `String_copy(&temp)`. "" otherwise.
copyRvalueHoist: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    ind: StringView
    buf: String.borrow
} out String is {
    match (
        n
    ) case expression then {
        iex29: ast.nodes.get i: (n.expression - 1).u64
        return (copyRvalueHoist :ast :symtab :ctx n: iex29 :ind :buf)
    } case dottedpath then {
        cn9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if cn9.stringview != "copy" then return "".string
        pnm9: stampNameDeep :ast :symtab n: (ast.nodes.get i: (n.parent - 1).u64)
        if pnm9.stringview != "String" then return "".string
        pv9: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (n.parent - 1).u64)
        if (isNonLvalueArg s: pv9.stringview) == false then return "".string
        hn9: ctx.argHoistCtr
        ctx.argHoistCtr = ctx.argHoistCtr + 1
        tnm9: "_cpv\{hn9}"
        th9: "\{ind}\{ctx.strC}_t \{tnm9} = \{pv9};\n"
        buf.append th9.stringview
        return "\{ctx.strC}_copy(&\{tnm9})"
    } else {
        return "".string
    }
}

# emitStringBindValue -- bind an interpolated-literal value to a String
# local (build chain + binding + scope-end free); false when the value
# is not an interpolated literal.
emitStringBindValue: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    nm: StringView
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} out bool is {
    match (
        n
    ) case expression then {
        iex9: ast.nodes.get i: (n.expression - 1).u64
        return (emitStringBindValue :ast :symtab :ctx n: iex9 :nm :ind :tmp :buf)
    } case atomstring then {
        if (isInterp :ast parts: n.stringparts) then {
            sB: emitInterpBuild :ast :symtab :ctx parts: n.stringparts :ind :tmp :buf
            lst: "\{ind}\{ctx.strC}_t \{nm} = _s\{sB};\n"
            buf.append lst.stringview
            nmc: nm.string
            tmp.frees.append nmc
            return true
        } else {
            return false
        }
    } case dottedpath then {
        cnd9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if cnd9.stringview == "string" then {
            dpv9: ast.nodes.get i: (n.parent - 1).u64
            return (emitStringBindValue :ast :symtab :ctx n: dpv9 :nm :ind :tmp :buf)
        }
        if cnd9.stringview == "copy" then {
            # `<rvalue>.copy` over a String (e.g. `(list.get i: n).copy`): the
            # receiver is a non-lvalue, so hoist it to a borrowed temp (List.get
            # returns a shallow view -- never freed) before String_copy(&temp).
            pnm9: stampNameDeep :ast :symtab n: (ast.nodes.get i: (n.parent - 1).u64)
            if pnm9.stringview == "String" then {
                pv9: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (n.parent - 1).u64)
                if (isNonLvalueArg s: pv9.stringview) then {
                    hn9: ctx.argHoistCtr
                    ctx.argHoistCtr = ctx.argHoistCtr + 1
                    tnm9: "_cpv\{hn9}"
                    th9: "\{ind}\{ctx.strC}_t \{tnm9} = \{pv9};\n"
                    buf.append th9.stringview
                    lc9: "\{ind}\{ctx.strC}_t \{nm} = \{ctx.strC}_copy(&\{tnm9});\n"
                    buf.append lc9.stringview
                    nmc9: nm.string
                    tmp.frees.append nmc9
                    return true
                }
            }
            return false
        }
        return false
    } else {
        return false
    }
}

# emitOptionBoxHoist -- `Option.some <val>`: a heap-boxed union ctor, emitted as
# statements (the box can't be an expression). Returns the `_cN` temp name, or ""
# when n is not an Option.some (so the caller falls back to the expression path).
emitOptionBoxHoist: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} out String is {
    match (
        n
    ) case expression then {
        iexG9: ast.nodes.get i: (n.expression - 1).u64
        return (emitOptionBoxHoist :ast :symtab :ctx n: iexG9 :ind :tmp :buf)
    } case statementline then {
        sln9: ast.nodes.get i: (n.statementline - 1).u64
        return (emitOptionBoxHoist :ast :symtab :ctx n: sln9 :ind :tmp :buf)
    } case call then {
        cn: dottedChildText :ast n: (ast.nodes.get i: (n.callable - 1).u64)
        if cn.stringview != "some" then return "".string
        mid: stampIdOf :symtab nid: n.nodeid.u64
        mo9: monoOriginName :symtab tid: mid
        if (originIsTid :symtab tid: mid originTid: ctx.optionOriginTid) == false then {
            return "".string
        }
        av: "0".string
        got: false
        aiter9: n.arguments.iterate
        for a9Id9: aiter9 loop {
            a9: ast.nodes.get i: (a9Id9 - 1).u64
            match (
                a9
            ) case namedoperation then {
                if (got) == false then {
                    got = true
                    opf199: ast.nodes.get i: (a9.operation - 1).u64
                    av = emitExpr :ast :symtab :ctx n: opf199
                }
            } else null
        }
        vc: symtab.reg.cnameOf tid: mid
        payC: armPayloadC :ast :symtab :ctx tid: mid arm: "some"
        tg: variantTag :symtab tid: mid arm: "some"
        bN: tmp.next
        b0: "\{ind}\{vc}_t _c\{bN} = {0};\n"
        buf.append b0.stringview
        b1: "\{ind}_c\{bN}.tag = \{tg};\n"
        buf.append b1.stringview
        b2: "\{ind}\{payC} _t\{bN} = \{av};\n"
        buf.append b2.stringview
        b3: "\{ind}\{payC}* _Box\{bN} = (\{payC}*)z_xmalloc(sizeof(\{payC}));\n"
        buf.append b3.stringview
        b4: "\{ind}*_Box\{bN} = _t\{bN};\n"
        buf.append b4.stringview
        if (isBareCName s: av.stringview) when (isRegisteredOwned :tmp name: av.stringview) then {
            invB: "\{ind}\{av} = (\{payC}){0};\n"
            if (strHasSub hay: payC.stringview needle: "*") then invB = "\{ind}\{av} = NULL;\n"
            buf.append invB.stringview
        }
        b5: "\{ind}_c\{bN}.data = _Box\{bN};\n"
        buf.append b5.stringview
        return "_c\{bN}"
    } else {
        return "".string
    }
}

# emitStringReturnValue -- a `return "\{...}".string` whose value is an
# interpolated-String literal: build it (emitInterpBuild) then return the owned
# temp. Mirrors emitStringBindValue but the built String is the return value
# (ownership transfers to the caller -> no free registered). false when the
# value is not an interp-String-literal (caller falls back to emitExpr).
emitStringReturnValue: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} out bool is {
    match (
        n
    ) case expression then {
        iexH9: ast.nodes.get i: (n.expression - 1).u64
        return (emitStringReturnValue :ast :symtab :ctx n: iexH9 :ind :tmp :buf)
    } case atomstring then {
        if (isInterp :ast parts: n.stringparts) then {
            sB: emitInterpBuild :ast :symtab :ctx parts: n.stringparts :ind :tmp :buf
            rexp9: "_s\{sB}"
            emitReturnCleanup :ctx :tmp retExpr: rexp9.stringview keepRefd: true :ind :buf
            lst: "\{ind}return _s\{sB};\n"
            buf.append lst.stringview
            return true
        } else {
            return false
        }
    } case dottedpath then {
        cnd9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if cnd9.stringview == "string" then {
            dpw9: ast.nodes.get i: (n.parent - 1).u64
            return (emitStringReturnValue :ast :symtab :ctx n: dpw9 :ind :tmp :buf)
        } else {
            return false
        }
    } else {
        return false
    }
}

# emitCallStmt -- one call-shaped statement: return / print / a plain call.
# emitDiscardedResult -- a statement-position call (explicit, dotted auto-call,
# or bare-atom auto-call) whose result is discarded: when the stamped result
# type is an owned destructible value (String / class / union) and the RHS is
# not a borrow by the declared signature (bindingRhsIsBorrow: funcReturnsBorrow
# markers, container element views), bind the result to a temp and destroy it.
# Emits `expr;` alone otherwise.
emitDiscardedResult: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    isBorrow: bool
    ce: StringView
    rtid: u64
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    dctt9: symtab.reg.typetypeOf typeId: rtid
    dcnm9: typeNameOfReg9 :symtab tid: rtid
    dcdrop9: false
    if (symtab.reg.hasDestructorName typeId: rtid) when isBorrow == false then {
        if rtid == ctx.strTid then dcdrop9 = true
        if dctt9 == ztypes.ztypetype.classType then dcdrop9 = true
        if dctt9 == ztypes.ztypetype.unionType then dcdrop9 = true
    }
    if dcdrop9 when (isNonLvalueArg s: ce) then {
        dctn9: tmp.next
        dctnm9: "_c\{dctn9}"
        dcct9: "\{ctx.strC}_t"
        dcfree9: "\{ind}\{ctx.strC}_free(&\{dctnm9});\n"
        if rtid != ctx.strTid then {
            dcct9 = typeRefC :ast :symtab :ctx tid: rtid thisTid: 0
            dccb9: cnameOf tid: rtid name: dcnm9.stringview
            dcref9: "&\{dctnm9}"
            if (ctEndsWithStar ct: dcct9.stringview) then dcref9 = "\{dctnm9}"
            dcfree9 = "\{ind}\{dccb9}_destroy(\{dcref9});\n"
        }
        dcdecl9: "\{ind}\{dcct9} \{dctnm9} = \{ce};\n"
        buf.append dcdecl9.stringview
        buf.append dcfree9.stringview
    } else {
        lc: "\{ind}(void)(\{ce});\n"
        buf.append lc.stringview
    }
}

emitCallStmt: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    relmn: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    if relmn.stringview == "release" then {
        relbnid: dottedBaseNodeId :ast n: (ast.nodes.get i: (call.callable - 1).u64)
        reltid: stampIdOf :symtab nid: relbnid
        if (symtab.reg.typetypeOf typeId: reltid) == ztypes.ztypetype.protocolType then return
    }
    cn0: atomTextOf :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    if cn0.stringview == "print" then {
        emitPrintStmt :ast :symtab :ctx :call :ind :tmp :buf
        return
    }
    if cn0.stringview == "panic" then {
        emitPanicStmt :ast :symtab :ctx :call :ind :buf
        return
    }
    if cn0.stringview == "error" then {
        emitErrorStmt :ast :symtab :ctx :call :ind :buf
        return
    }
    if cn0.stringview == "return" then {
        hasArg: false
        aiter: call.arguments.iterate
        for aId9: aiter loop {
            a: ast.nodes.get i: (aId9 - 1).u64
            match (
                a
            ) case namedoperation then {
                if (hasArg) == false then {
                    hasArg = true
                    emitReturnOfNode :ast :symtab :ctx vid: a.operation :ind :tmp :buf
                }
            } else null
        }
        if (hasArg) == false then {
            if ctx.genActive then {
                lgd: "\{ind}goto L_done;\n"
                buf.append lgd.stringview
            } else {
                emitReturnCleanup :ctx :tmp retExpr: "" keepRefd: true :ind :buf
                lr2: "\{ind}return;\n"
                buf.append lr2.stringview
            }
        }
        return
    }
    ce: emitCallValue :ast :symtab :ctx :call
    flushArgHoists :ctx :ind :tmp :buf
    dcrtid9: stampIdOf :symtab nid: call.nodeid.u64
    (emitDiscardedResult
        :ast
        :symtab
        :ctx
        isBorrow: (callRhsIsBorrow :ast :symtab :ctx :call)
        ce: ce.stringview
        rtid: dcrtid9
        :ind
        :tmp
        :buf
    )
    emitCallTakeInvalidations :ast :symtab :ctx :call :ind :buf
}

# nodeIsDotted9 -- the node is a dotted-path auto-call (a no-arg method
# reference used in statement position).
nodeIsDotted9: function {n: Node} out bool is {
    match (
        n
    ) case dottedpath then {
        return true
    } else {
        return false
    }
}

# emitStmt -- one statement of a function body.
emitStmt: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    match (
        n
    ) case statementline then {
        sln9: ast.nodes.get i: (n.statementline - 1).u64
        emitStmt :ast :symtab :ctx n: sln9 :ind :tmp :buf
    } case expression then {
        emitStmt :ast :symtab :ctx n: (ast.nodes.get i: (n.expression - 1).u64) :ind :tmp :buf
    } case statement then {
        siter9: n.statements.iterate
        for s9Id9: siter9 loop {
            emitStmt :ast :symtab :ctx n: (ast.nodes.get i: (s9Id9 - 1).u64) :ind :tmp :buf
        }
    } case doexpr then {
        if (ztypecheck.blockHasBreak :ast n: (ast.nodes.get i: (n.statement - 1).u64)) then {
            ldo9: "\{ind}do {\n"
            buf.append ldo9.stringview
            indd9: "\{ind}    "
            # the block is its own break target: a break inside frees the
            # block's owned temps (since these marks) and lands after the
            # block, not on an enclosing loop's label
            sdoId9: pushLoopLabel :ctx :tmp isDo: true
            sfL9: tmp.frees.length
            slL9: tmp.listFrees.length
            dst9: ast.nodes.get i: (n.statement - 1).u64
            emitBodyNode :ast :symtab :ctx n: dst9 ind: indd9.stringview :tmp :buf
            flushBlockFrees :ctx :tmp fL: sfL9 lL: slL9 :buf
            lwh9: "\{ind}} while (0);\n"
            buf.append lwh9.stringview
            popLoopLabel :ctx id: sdoId9 :ind :buf
        } else {
            (emitBodyNode
                :ast
                :symtab
                :ctx
                n: (ast.nodes.get i: (n.statement - 1).u64)
                :ind
                :tmp
                :buf
            )
        }
    } case call then {
        emitCallStmt :ast :symtab :ctx call: n :ind :tmp :buf
    } case assignment then {
        avn9: ast.nodes.get i: (n.value - 1).u64
        tn: stampNameOf :symtab nid: n.nodeid.u64
        ct: cTypeOf name: tn.stringview
        if ct.length > 0 then {
            btid9: stampIdOf :symtab nid: n.nodeid.u64
            if btid9 > 0 then {
                bDu9: definedInUnitOf :symtab tid: btid9
                match (
                    bDu9
                ) case some then {
                    if (ztypecheck.isStdlibUnitName name: bDu9.stringview) == false then {
                        ct = typeRefC :ast :symtab :ctx tid: btid9 thisTid: 0
                    }
                } case none then null
            }
        }
        if ct.length == 0 then {
            tgo: symtab.typing.nodeType.get key: n.nodeid.u64
            match (
                tgo
            ) case some then {
                ct = typeRefC :ast :symtab :ctx tid: tgo thisTid: 0
            } case none then {
                vgo9: symtab.typing.nodeType.get key: (nodeIdOf9 n: avn9)
                match (
                    vgo9
                ) case some then {
                    ct = typeRefC :ast :symtab :ctx tid: vgo9 thisTid: 0
                } case none then null
            }
        }
        nm: ztypes.mangleVarName name: n.name.stringview
        nbrw9: bindingRhsIsBorrow :ast :symtab :ctx n: avn9
        ctx.borrowedVars.set key: nm.copy value: nbrw9
        if ctx.genActive when (isYieldNode :ast n: avn9) then {
            (emitExprFormYield
                :ast
                :symtab
                :ctx
                value: avn9
                aid: n.nodeid.u64
                nm: nm.stringview
                :ind
                :tmp
                :buf
            )
            return
        }
        # `x: <inst>.take` over a record/class is an ownership alias: record
        # `x => inst` and emit no storage (subsequent `x` resolves to `inst`).
        tabA: takeAliasBase :ast :symtab n: avn9
        if tabA.length > 0 then {
            # a narrowed-subject `.take` binding MOVES the payload out of
            # the match arm's box: real storage from the narrowed cast plus
            # box zeroing, so the subject's post-match destroy no-ops (a
            # pure alias would re-resolve to the whole un-narrowed subject)
            if (nvHas xs: ctx.narrowBox name: tabA.stringview) then {
                ntO9: ntGet xs: ctx.narrowTid name: tabA.stringview
                match (
                    ntO9
                ) case some then {
                    ctB9: typeRefC :ast :symtab :ctx tid: ntO9 thisTid: 0
                    valB9: takeSourceResolve :ctx name: tabA.stringview
                    lnB1: "\{ind}\{ctB9} \{nm} = \{valB9};\n"
                    buf.append lnB1.stringview
                    lnB2: "\{ind}\{valB9} = (\{ctB9}){0};\n"
                    buf.append lnB2.stringview
                    if (symtab.reg.hasDestructorName typeId: ntO9) then {
                        ldcbB: symtab.reg.cnameOf tid: ntO9
                        ldfB: "    \{ldcbB}_destroy(&\{nm});\n"
                        ldfsB: ldfB.copy
                        tmp.listFrees.append ldfsB
                        tmp.listFreeVars.append nm.copy
                    }
                    return
                } case none then null
            }
            lalA: "\{ind}/* alias: \{nm} => \{tabA} */\n"
            buf.append lalA.stringview
            nvSet xs: ctx.aliases name: nm.stringview val: tabA.stringview
            return
        }
        ltid: stampIdOf :symtab nid: n.nodeid.u64
        if ltid == 0 then ltid = stampIdOf :symtab nid: (nodeIdOf9 n: avn9)
        ltid = chaseColMono :ast :symtab tid: ltid
        ltmn: monoOriginName :symtab tid: ltid
        if (originIsTid :symtab tid: ltid originTid: ctx.listOriginTid) then {
            lcb: symtab.reg.cnameOf tid: ltid
            if (osNoArgCallRhs :ast n: avn9) then {
                # owned List returned by os.args / os.envNames: emit the call.
                losr: emitExpr :ast :symtab :ctx n: avn9
                losb: "\{ind}\{lcb}_t \{nm} = \{losr};\n"
                buf.append losb.stringview
            } else {
                if (forexprValue :ast n: avn9) then {
                    # list comprehension: `xs: for ... loop { expr }` create + populate
                    lc0: "\{ind}\{lcb}_t \{nm} = \{lcb}_create((uint64_t)0);\n"
                    buf.append lc0.stringview
                    (emitListComprehension
                        :ast
                        :symtab
                        :ctx
                        forNode: avn9
                        listCb: lcb.stringview
                        listVar: nm.stringview
                        :ind
                        :tmp
                        :buf
                    )
                } else {
                    if (collectionValueCallRhs :ast n: avn9) then {
                        lvr0: emitExpr :ast :symtab :ctx n: avn9
                        lb0: "\{ind}\{lcb}_t \{nm} = \{lvr0};\n"
                        buf.append lb0.stringview
                        emitValueTakeInvalidations :ast :symtab :ctx n: avn9 :ind :buf
                    } else {
                        lcap: listCapArg :ast :symtab :ctx n: avn9
                        lb1: "\{ind}\{lcb}_t \{nm} = \{lcb}_create((uint64_t)\{lcap});\n"
                        buf.append lb1.stringview
                    }
                }
            }
            lfree: "    \{lcb}_destroy(&\{nm});\n"
            lfsv: lfree.stringview
            lfv: lfsv.string
            tmp.listFrees.append lfv
            tmp.listFreeVars.append nm.copy
            return
        }
        if (originIsTid :symtab tid: ltid originTid: ctx.setOriginTid) then {
            scb: symtab.reg.cnameOf tid: ltid
            if (collectionValueCallRhs :ast n: avn9) then {
                svr: emitExpr :ast :symtab :ctx n: avn9
                sbc: "\{ind}\{scb}_t* \{nm} = \{svr};\n"
                buf.append sbc.stringview
                emitValueTakeInvalidations :ast :symtab :ctx n: avn9 :ind :buf
            } else {
                scap: listCapArg :ast :symtab :ctx n: avn9
                sb0: "\{ind}\{scb}_t* \{nm} = \{scb}_create((uint64_t)\{scap});\n"
                buf.append sb0.stringview
            }
            sfree: "    \{scb}_destroy(\{nm});\n"
            sfsv: sfree.stringview
            sfv: sfsv.string
            tmp.listFrees.append sfv
            tmp.listFreeVars.append nm.copy
            return
        }
        if (originIsTid :symtab tid: ltid originTid: ctx.mapOriginTid) then {
            mcb: symtab.reg.cnameOf tid: ltid
            if (collectionValueCallRhs :ast n: avn9) then {
                mvr: emitExpr :ast :symtab :ctx n: avn9
                mbc: "\{ind}\{mcb}_t* \{nm} = \{mvr};\n"
                buf.append mbc.stringview
                emitValueTakeInvalidations :ast :symtab :ctx n: avn9 :ind :buf
            } else {
                mcap: listCapArg :ast :symtab :ctx n: avn9
                mb0: "\{ind}\{mcb}_t* \{nm} = \{mcb}_create((uint64_t)\{mcap});\n"
                buf.append mb0.stringview
            }
            mfree: "    \{mcb}_destroy(\{nm});\n"
            mfsv: mfree.stringview
            mfv: mfsv.string
            tmp.listFrees.append mfv
            tmp.listFreeVars.append nm.copy
            return
        }
        if (stampIdOf :symtab nid: n.nodeid.u64) == ctx.svTid then {
            lvN: bindLitIndex :ast :symtab :ctx n: avn9
            if lvN > 0 then {
                lsv2: "\{ind}\{ctx.svC}_t \{nm} = _zs\{lvN};\n"
                buf.append lsv2.stringview
                return
            }
            svb: stringviewOfBase :ast :symtab n: avn9
            if svb.length > 0 then {
                svacc4: ".".string
                if (isPtrVar :ctx name: svb.stringview) then svacc4 = "->".string
                svbR4a: aliasResolve :ctx name: svb.stringview
                svbR4: ztypes.mangleVarName name: svbR4a.stringview
                lsv4: "\{ind}\{ctx.svC}_t \{nm} = (\{ctx.svC}_t){ \{svbR4}\{svacc4}data, \{svbR4}\{svacc4}size };\n"
                buf.append lsv4.stringview
                return
            }
            vx: emitExpr :ast :symtab :ctx n: avn9
            flushArgHoists :ctx :ind :tmp :buf
            if (vx.stringview.startsWith prefix: "/*") then {
                lsv3: "\{ind}/* zemitterc: unhandled StringView binding \{nm} */\n"
                buf.append lsv3.stringview
            } else {
                lsv5: "\{ind}\{ctx.svC}_t \{nm} = \{vx};\n"
                buf.append lsv5.stringview
            }
            return
        }
        if (stampIdOf :symtab nid: n.nodeid.u64) == ctx.strTid then {
            fvN: stringCopyLitIndex :ast :symtab :ctx n: avn9
            if fvN > 0 then {
                lsc: "\{ind}\{ctx.strC}_t \{nm} = \{ctx.strC}_from_view(_zs\{fvN});\n"
                buf.append lsc.stringview
                nmc2: nm.copy
                tmp.frees.append nmc2
                return
            }
            did9: (emitStringBindValue
                :ast
                :symtab
                :ctx
                n: avn9
                nm: nm.stringview
                :ind
                :tmp
                :buf
            )
            if did9 then return
            sx: emitExpr :ast :symtab :ctx n: avn9
            flushArgHoists :ctx :ind :tmp :buf
            if (sx.stringview.startsWith prefix: "/*") then {
                lst2: "\{ind}/* zemitterc: unhandled String binding \{nm} */\n"
                buf.append lst2.stringview
            } else {
                lst3: "\{ind}\{ctx.strC}_t \{nm} = \{sx};\n"
                buf.append lst3.stringview
                if (bindingRhsIsBorrow :ast :symtab :ctx n: avn9) == false then {
                    nmc3: nm.copy
                    tmp.frees.append nmc3
                }
            }
            return
        }
        if ct.length > 0 then {
            dm9: (emitMatchBindValue
                :ast
                :symtab
                :ctx
                n: avn9
                nm: nm.stringview
                ct: ct.stringview
                :ind
                :tmp
                :buf
            )
            if dm9 then return
            di9: (emitIfBindValue
                :ast
                :symtab
                :ctx
                n: avn9
                nm: nm.stringview
                ct: ct.stringview
                :ind
                :tmp
                :buf
            )
            if di9 then return
            dd9: (emitDoBindValue
                :ast
                :symtab
                :ctx
                n: avn9
                nm: nm.stringview
                ct: ct.stringview
                tid: ltid
                :ind
                :tmp
                :buf
            )
            if dd9 then return
        }
        rv: emitExpr :ast :symtab :ctx n: avn9
        flushArgHoists :ctx :ind :tmp :buf
        if ct.length > 0 then {
            la: "\{ind}\{ct} \{nm} = \{rv};\n"
            buf.append la.stringview
            emitValueTakeInvalidations :ast :symtab :ctx n: avn9 :ind :buf
            ftFn9: false
            ftnid9: nodeIdOf9 n: avn9
            if ftnid9 > 0 then {
                ftst9: stampIdOf :symtab nid: ftnid9
                if ftst9 > 0 then {
                    if (symtab.reg.typetypeOf typeId: ftst9) == ztypes.ztypetype.functionType then {
                        # a function reference is POD: taking it moves nothing,
                        # so the source (a unit fn symbol or an fnptr field)
                        # is never zeroed
                        ftFn9 = true
                    }
                }
            }
            if (isFieldTake :ast n: avn9) when ftFn9 == false then {
                ftz9: "\{ind}\{rv} = (\{ct}){0};\n"
                buf.append ftz9.stringview
            } else {
                bts9: takeStringSource :ast :symtab :ctx n: avn9
                if bts9.length > 0 then {
                    bzz9: "\{ind}\{rv} = (\{ct}){0};\n"
                    buf.append bzz9.stringview
                }
            }
            # an owned class/record local with heap fields is destroyed at scope
            # exit (String/collection locals returned earlier; take-aliases too).
            ltHasDtor9: false
            if (symtab.reg.hasDestructorName typeId: ltid) then ltHasDtor9 = true
            ltUmn9: monoOriginName :symtab tid: ltid
            if ltUmn9.length > 0 when (symtab.reg.typetypeOf typeId: ltid) == ztypes.ztypetype.unionType then {
                ltHasDtor9 = true
            }
            if ltHasDtor9 then {
                if (bindingRhsIsBorrow :ast :symtab :ctx n: avn9) == false then {
                    ldcb: cnameOf tid: ltid name: tn.stringview
                    ldRef9: "&\{nm}"
                    if (isBoxTid :symtab tid: ltid) then ldRef9 = "\{nm}"
                    ldf: "    \{ldcb}_destroy(\{ldRef9});\n"
                    ldfs: ldf.copy
                    tmp.listFrees.append ldfs
                    tmp.listFreeVars.append nm.copy
                }
            }
        } else {
            lb: "\{ind}/* zemitterc: unhandled binding type \{tn} for \{nm} */\n"
            buf.append lb.stringview
        }
    } case reassignment then {
        tpn29: ast.nodes.get i: (n.topath - 1).u64
        rvn29: ast.nodes.get i: (n.value - 1).u64
        nm2: emitReassignLvalue :ast :symtab :ctx n: tpn29
        rcph9: copyRvalueHoist :ast :symtab :ctx n: rvn29 :ind :buf
        rv2: String
        if rcph9.length > 0 then {
            rv2 = rcph9
        } else {
            rvi9: emitInterpStmtValue :ast :symtab :ctx n: rvn29 :ind :tmp :buf
            if rvi9.length > 0 then {
                rv2 = rvi9
            } else {
                rv2 = emitExpr :ast :symtab :ctx n: rvn29
            }
        }
        rtnid9: nodeIdOf9 n: tpn29
        rtsid9: stampIdOf :symtab nid: rtnid9
        rttn9: stampNameOf :symtab nid: rtnid9
        # a collection-typedef lvalue (Bytes) stores and destroys as its
        # chased underlying mono, exactly like the binding path
        rtch9: chaseColMono :ast :symtab tid: rtsid9
        rtChased9: false
        if rtch9 != rtsid9 then {
            rtsid9 = rtch9
            rtChased9 = true
        }
        rdrop9: false
        if (stampIdOf :symtab nid: rtnid9) == ctx.strTid then {
            rdrop9 = true
        } else {
            if (symtab.reg.hasDestructorName typeId: rtsid9) then rdrop9 = true
        }
        if rdrop9 then {
            if (isNonLvalueArg s: rv2.stringview) then {
                rrt9: "\{ctx.strC}_t"
                if (stampIdOf :symtab nid: rtnid9) != ctx.strTid then {
                    rrt9 = typeRefC :ast :symtab :ctx tid: rtsid9 thisTid: 0
                    if (isHeapPtrCollection :ast :symtab :ctx tid: rtsid9) then rrt9 = "\{rrt9}*"
                }
                rrn9: tmp.next
                rrh9: "\{ind}\{rrt9} _rr\{rrn9} = \{rv2};\n"
                buf.append rrh9.stringview
                rv2 = "_rr\{rrn9}"
            }
        }
        if (stampIdOf :symtab nid: rtnid9) == ctx.strTid then {
            rdo9: "\{ind}\{ctx.strC}_free(&\{nm2});\n"
            buf.append rdo9.stringview
        } else {
            if (symtab.reg.hasDestructorName typeId: rtsid9) then {
                rdcb9: cnameOf tid: rtsid9 name: rttn9.stringview
                # the chased mono's registry cname is authoritative (the
                # stamp name still says the typedef)
                if rtChased9 then rdcb9 = symtab.reg.cnameOf tid: rtsid9
                if (isHeapPtrCollection :ast :symtab :ctx tid: rtsid9) then {
                    rdoh9: "\{ind}\{rdcb9}_destroy(\{nm2});\n"
                    buf.append rdoh9.stringview
                } else {
                    rdov9: "\{ind}\{rdcb9}_destroy(&\{nm2});\n"
                    buf.append rdov9.stringview
                }
            }
        }
        lc2: "\{ind}\{nm2} = \{rv2};\n"
        buf.append lc2.stringview
        # a `<obj>.field.take` RHS moved the field out as a shallow struct
        # copy: zero the field lvalue so the owner's destructor does not
        # double-free the payload (mirrors the binding case; fn-typed fields
        # are POD references and move nothing).
        rftFn9: false
        rftnid9: nodeIdOf9 n: rvn29
        if rftnid9 > 0 then {
            rftst9: stampIdOf :symtab nid: rftnid9
            if rftst9 > 0 then {
                if (symtab.reg.typetypeOf typeId: rftst9) == ztypes.ztypetype.functionType then {
                    rftFn9 = true
                }
            }
        }
        if (isFieldTake :ast n: rvn29) when rftFn9 == false then {
            if (isHeapPtrCollection :ast :symtab :ctx tid: rtsid9) then {
                rftzh9: "\{ind}\{rv2} = NULL;\n"
                buf.append rftzh9.stringview
            } else {
                rfct9: "\{ctx.strC}_t"
                if (stampIdOf :symtab nid: rtnid9) != ctx.strTid then {
                    rfct9 = typeRefC :ast :symtab :ctx tid: rtsid9 thisTid: 0
                }
                rftz9: "\{ind}\{rv2} = (\{rfct9}){0};\n"
                buf.append rftz9.stringview
            }
        }
        # args moved into a construction/call RHS (e.g. `v.f = Option.some bo`)
        # are consumed by it -- invalidate each moved source so its scope-exit
        # free no-ops (mirrors the binding case; disjoint from the bare-local
        # move below, which a construction RHS never matches).
        emitValueTakeInvalidations :ast :symtab :ctx n: rvn29 :ind :buf
        emitNarrowedTakeZero :ast :symtab :ctx n: rvn29 :ind :buf
        # a reassignment from a bare owned local is a MOVE: zero the source so its
        # scope-exit free no-ops (the lvalue -- a local or a struct field appended
        # into a container -- now owns the heap). Scalars/valtypes have no
        # destructor and are left untouched.
        zsrc9: implicitTakeSource :ast :symtab :ctx n: rvn29
        if zsrc9.length > 0 then {
            znid9: nodeIdOf9 n: rvn29
            zid9: stampIdOf :symtab nid: znid9
            znm9: stampNameOf :symtab nid: znid9
            if (isHeapPtrCollection :ast :symtab :ctx tid: zid9) then {
                zinvh9: "\{ind}\{zsrc9} = NULL;\n"
                buf.append zinvh9.stringview
            } else {
                zct9: String
                if (stampIdOf :symtab nid: znid9) == ctx.strTid then {
                    zct9 = "\{ctx.strC}_t"
                } else {
                    if (symtab.reg.hasDestructorName typeId: zid9) then {
                        zct9 = typeRefC :ast :symtab :ctx tid: zid9 thisTid: 0
                    }
                }
                if zct9.length > 0 then {
                    zinv9: "\{ind}\{zsrc9} = (\{zct9}){0};\n"
                    buf.append zinv9.stringview
                }
            }
        }
    } case swapstmt then {
        lhn9: ast.nodes.get i: (n.lhs - 1).u64
        rhn9: ast.nodes.get i: (n.rhs - 1).u64
        lx: emitExpr :ast :symtab :ctx n: lhn9
        rx: emitExpr :ast :symtab :ctx n: rhn9
        lnid: nodeIdOf9 n: lhn9
        lsid: stampIdOf :symtab nid: lnid
        lct: typeRefC :ast :symtab :ctx tid: lsid thisTid: 0
        if lct.length == 0 then {
            pmsg6: "zemitterc: unspellable swap operand type id \{lsid}"
            panic pmsg6
        }
        sN: tmp.next
        s0: "\{ind}{\n"
        buf.append s0.stringview
        s1: "\{ind}    \{lct} _sw\{sN} = \{lx};\n"
        buf.append s1.stringview
        s2: "\{ind}    \{lx} = \{rx};\n"
        buf.append s2.stringview
        s3: "\{ind}    \{rx} = _sw\{sN};\n"
        buf.append s3.stringview
        s4: "\{ind}}\n"
        buf.append s4.stringview
    } case ifexpr then {
        # constant guards: when every clause folds at emit time, only the
        # winning body is emitted -- provably-dead branches (including dead
        # `error` arms) are eliminated from the C.
        efold9: true
        ewin9: u32
        with pciter: n.clauses.iterate do for pcId9: pciter loop {
            if efold9 then {
                pcn9: ast.nodes.get i: (pcId9 - 1).u64
                match (
                    pcn9
                ) case ifclause then {
                    fr9: foldIfClause9 :ast :ctx conds: pcn9.conditions
                    if fr9.ok then {
                        if fr9.val == 1 when ewin9 == 0 then ewin9 = pcn9.statement
                    } else {
                        efold9 = false
                    }
                } else {
                    efold9 = false
                }
            }
        }
        if efold9 then {
            ewb9: ewin9
            if ewb9 == 0 then ewb9 = n.elseclause
            if ewb9 > 0 then {
                lfo9: "\{ind}{\n"
                buf.append lfo9.stringview
                indE9: "\{ind}    "
                fLE9: tmp.frees.length
                lLE9: tmp.listFrees.length
                ewn9: ast.nodes.get i: (ewb9 - 1).u64
                emitBodyNode :ast :symtab :ctx n: ewn9 ind: indE9.stringview :tmp :buf
                flushBlockFrees :ctx :tmp fL: fLE9 lL: lLE9 :buf
                lfc9: "\{ind}}\n"
                buf.append lfc9.stringview
            }
            return
        }
        ctx.condDepth = ctx.condDepth + 1
        ifAssign: String
        first: true
        with citer: n.clauses.iterate do for cId9: citer loop {
            isFirst: first
            first = false
            c: ast.nodes.get i: (cId9 - 1).u64
            (emitIfClause
                :ast
                :symtab
                :ctx
                n: c
                :isFirst
                assignTo: ifAssign.stringview
                :ind
                :tmp
                :buf
            )
        }
        chS9: (List String)
        chA9: (List String)
        chT9: (List u64)
        chN9: (List bool)
        chR9: (List String)
        (chainFactsOfClauses9
            :ast
            :symtab
            :ctx
            clauses: n.clauses
            subjects: chS9
            arms: chA9
            tids: chT9
            negs: chN9
            recvs: chR9
        )
        (emitElse9
            :ast
            :symtab
            :ctx
            oId: n.elseclause
            assignTo: ifAssign.stringview
            :ind
            :tmp
            chSubjects: chS9
            chArms: chA9
            chTids: chT9
            chNegs: chN9
            chRecvs: chR9
            :buf
        )
        le: "\{ind}}\n"
        buf.append le.stringview
        ctx.condDepth = ctx.condDepth - 1
    } case caseexpr then {
        # constant subject over literal arms: emit only the matching arm.
        msub9: evalConstI64 :ast :ctx n: (ast.nodes.get i: (n.subject - 1).u64)
        melim9: msub9.ok
        mwin9: u32
        if melim9 then {
            with mciter: n.clauses.iterate do for mcId9: mciter loop {
                if melim9 then {
                    mcn9: ast.nodes.get i: (mcId9 - 1).u64
                    match (
                        mcn9
                    ) case caseclause then {
                        if mcn9.name.length > 0 then {
                            melim9 = false
                        } else {
                            maf9: (evalConstI64
                                :ast
                                :ctx
                                n: (ast.nodes.get i: (mcn9.matcharm - 1).u64)
                            )
                            if maf9.ok then {
                                if maf9.val == msub9.val when mwin9 == 0 then mwin9 = mcn9.statement
                            } else {
                                melim9 = false
                            }
                        }
                    } else {
                        melim9 = false
                    }
                }
            }
        }
        if melim9 then {
            mwb9: mwin9
            if mwb9 == 0 then mwb9 = n.elseclause
            if mwb9 > 0 then {
                lmo9: "\{ind}{\n"
                buf.append lmo9.stringview
                indM9: "\{ind}    "
                fLM9: tmp.frees.length
                lLM9: tmp.listFrees.length
                mwn9: ast.nodes.get i: (mwb9 - 1).u64
                emitBodyNode :ast :symtab :ctx n: mwn9 ind: indM9.stringview :tmp :buf
                flushBlockFrees :ctx :tmp fL: fLM9 lL: lLM9 :buf
                lmc9: "\{ind}}\n"
                buf.append lmc9.stringview
            }
            return
        }
        ctx.condDepth = ctx.condDepth + 1
        emitMatchStmt :ast :symtab :ctx m: n assignTo: "" :ind :tmp :buf
        ctx.condDepth = ctx.condDepth - 1
    } case withexpr then {
        wn9: n.name.stringview
        wnm: wn9.string
        wtn: stampNameDeep :ast :symtab n: (ast.nodes.get i: (n.value - 1).u64)
        wct: cTypeForName :ast :symtab :ctx name: wtn.stringview
        wv: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (n.value - 1).u64)
        if wct.length > 0 then {
            lwv: "\{ind}\{wct} \{wnm} = \{wv};\n"
            buf.append lwv.stringview
        } else {
            lwv2: "\{ind}int64_t \{wnm} = \{wv};\n"
            buf.append lwv2.stringview
        }
        emitBodyNode :ast :symtab :ctx n: (ast.nodes.get i: (n.body - 1).u64) :ind :tmp :buf
    } case forexpr then {
        ctx.condDepth = ctx.condDepth + 1
        if (emitObjIterFor :ast :symtab :ctx m: n :ind :tmp :buf) then {
            ctx.condDepth = ctx.condDepth - 1
            return
        }
        if (emitIntRangeFor :ast :symtab :ctx m: n :ind :tmp :buf) then {
            ctx.condDepth = ctx.condDepth - 1
            return
        }
        # do-while: no pre-conditions, a post-condition (`for loop {...} while C`).
        if n.conditions.length == 0 when n.postconditions.length > 0 then {
            lidDW: pushLoopLabel :ctx :tmp isDo: false
            ldw: "\{ind}do {\n"
            buf.append ldw.stringview
            ind2d: "\{ind}    "
            fLd9: tmp.frees.length
            lLd9: tmp.listFrees.length
            if n.body > 0 then {
                fbd9: ast.nodes.get i: (n.body - 1).u64
                emitBodyNode :ast :symtab :ctx n: fbd9 ind: ind2d.stringview :tmp :buf
            }
            flushBlockFrees :ctx :tmp fL: fLd9 lL: lLd9 :buf
            pcond: String
            pkiter: n.postconditions.iterate
            for pk: pkiter loop {
                pcv: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (pk - 1).u64)
                if pcond.length > 0 then pcond.append " && "
                pcond.append pcv.stringview
            }
            if pcond.length == 0 then pcond.append "0"
            emitContLabel :ctx id: lidDW ind: ind2d.stringview :buf
            lpw: "\{ind}} while (\{pcond});\n"
            buf.append lpw.stringview
            popLoopLabel :ctx id: lidDW :ind :buf
            ctx.condDepth = ctx.condDepth - 1
            return
        }
        cond: String
        kiter: n.conditions.iterate
        for kId9: kiter loop {
            k9r: ast.nodes.get i: (kId9 - 1).u64
            emitForCond :ast :symtab :ctx n: k9r :cond :ind :tmp :buf
        }
        # `for loop { ... }` -- no conditions, no postconditions: an
        # unconditional loop that exits via break/return.
        if cond.length == 0 then cond.append "1"
        lidW: pushLoopLabel :ctx :tmp isDo: false
        lw: "\{ind}while (\{cond}) {\n"
        buf.append lw.stringview
        ind2: "\{ind}    "
        fLw9: tmp.frees.length
        lLw9: tmp.listFrees.length
        if n.body > 0 then {
            fbw9: ast.nodes.get i: (n.body - 1).u64
            emitBodyNode :ast :symtab :ctx n: fbw9 ind: ind2.stringview :tmp :buf
        }
        flushBlockFrees :ctx :tmp fL: fLw9 lL: lLw9 :buf
        emitContLabel :ctx id: lidW ind: ind2.stringview :buf
        lwc: "\{ind}}\n"
        buf.append lwc.stringview
        popLoopLabel :ctx id: lidW :ind :buf
        ctx.condDepth = ctx.condDepth - 1
    } case yieldexpr then {
        emitYieldStmt :ast :symtab :ctx yd: n :ind :tmp :buf
    } else {
        # a no-arg method auto-call in statement position (this.accept,
        # this.statepop) is a dotted path: emit the call expression as a statement.
        if (nodeIsDotted9 :n) then {
            # `.release` on a protocol is a transfer marker (scope-exit destroy
            # covers it) -- emit nothing, like emitCallStmt.
            dct9: dottedChildText :ast :n
            if dct9.stringview == "release" then {
                rrid9: dottedReceiverStampId :ast :symtab callable: n
                rtt9: symtab.reg.typetypeOf typeId: rrid9
                if rtt9 == ztypes.ztypetype.protocolType then return
                rcvNm9: dottedBaseAtom :ast :n
                rcvKey9: ztypes.mangleVarName name: rcvNm9.stringview
                rbrw9: false
                bvg9: ctx.borrowedVars.get key: rcvKey9.copy
                match (
                    bvg9
                ) case some then {
                    rbrw9 = bvg9
                } case none then null
                if rbrw9 then return
                rcvV9: emitDottedReceiver :ast :symtab :ctx callable: n
                rtn9: typeNameOfReg9 :symtab tid: rrid9
                if rrid9 == ctx.strTid then {
                    rdf9: "\{ind}\{ctx.strC}_free(&\{rcvV9});\n"
                    buf.append rdf9.stringview
                } else {
                    if (symtab.reg.hasDestructorName typeId: rrid9) then {
                        rdcb9: cnameOf tid: rrid9 name: rtn9.stringview
                        rdref9: "&\{rcvV9}"
                        if (isBoxTid :symtab tid: rrid9) then rdref9 = "\{rcvV9}"
                        rdc9: "\{ind}\{rdcb9}_destroy(\{rdref9});\n"
                        buf.append rdc9.stringview
                    }
                }
                rinv9: false
                if rrid9 == ctx.strTid then rinv9 = true
                if rtt9 == ztypes.ztypetype.classType then rinv9 = true
                if rtt9 == ztypes.ztypetype.unionType then rinv9 = true
                if rinv9 then {
                    rci9: typeRefC :ast :symtab :ctx tid: rrid9 thisTid: 0
                    riv9: "\{ind}\{rcvV9} = (\{rci9}){0};\n"
                    buf.append riv9.stringview
                }
                return
            }
            de9: emitExpr :ast :symtab :ctx :n
            if (de9.stringview.startsWith prefix: "/*") then {
                lud9: "\{ind}/* zemitterc: unhandled statement */\n"
                buf.append lud9.stringview
            } else {
                drtid9: stampIdOf :symtab nid: (nodeIdOf9 :n)
                (emitDiscardedResult
                    :ast
                    :symtab
                    :ctx
                    isBorrow: (bindingRhsIsBorrow :ast :symtab :ctx :n)
                    ce: de9.stringview
                    rtid: drtid9
                    :ind
                    :tmp
                    :buf
                )
            }
            return
        }
        # a bare no-arg function call as a statement (`check_mode`): typecheck
        # coerced the atom to a call; emit the call expression as a statement.
        fcs9: atomTextOf :ast :n
        ffid9: userFnId :ast :symtab :ctx name: fcs9.stringview
        if ffid9 > 0 when (symtab.reg.typetypeOf typeId: ffid9) == ztypes.ztypetype.functionType then {
            fce9: emitExpr :ast :symtab :ctx :n
            if (fce9.stringview.startsWith prefix: "/*") == false then {
                artid9: stampIdOf :symtab nid: (nodeIdOf9 :n)
                (emitDiscardedResult
                    :ast
                    :symtab
                    :ctx
                    isBorrow: (bindingRhsIsBorrow :ast :symtab :ctx :n)
                    ce: fce9.stringview
                    rtid: artid9
                    :ind
                    :tmp
                    :buf
                )
                return
            }
        }
        # bare control keywords parse as an AtomId reference (no value): a
        # no-value `return` (goto L_done inside a generator), `break`, `continue`.
        bkw9: atomTextOf :ast :n
        if bkw9.stringview == "return" then {
            if ctx.genActive then {
                lgd9: "\{ind}goto L_done;\n"
                buf.append lgd9.stringview
            } else {
                emitReturnCleanup :ctx :tmp retExpr: "" keepRefd: true :ind :buf
                lrt9: "\{ind}return;\n"
                buf.append lrt9.stringview
            }
        } else {
            if bkw9.stringview == "break" then {
                emitBreakFrees :ctx :tmp :ind :buf
                if ctx.breakLabels.length > 0 then {
                    bid9: ctx.breakLabels.get i: (ctx.breakLabels.length - 1)
                    # an owned-payload loop's per-iteration dtor: the jump
                    # skips the fall-through line, so emit its copy here (a
                    # do-block entry carries an empty cleanup).
                    bcl9: ctx.breakLabelCleanup.get i: (ctx.breakLabels.length - 1)
                    if bcl9.length > 0 then {
                        lbc9: "\{ind}\{bcl9}"
                        buf.append lbc9.stringview
                    }
                    lbkg9: "\{ind}goto __zbrk_\{bid9};\n"
                    buf.append lbkg9.stringview
                    ubk9: true
                    ctx.breakLabelUsed.set key: bid9 value: ubk9
                } else {
                    lbk9: "\{ind}break;\n"
                    buf.append lbk9.stringview
                }
            } else {
                if bkw9.stringview == "continue" then {
                    # inside a do{}while(0) block wrapper a C continue exits
                    # the wrapper, not the loop: jump to the nearest LOOP
                    # entry's __zcont label instead (frees since that loop).
                    inDo9: false
                    loopIdx9: u64
                    hasLoop9: false
                    li9: ctx.breakLabelIsDo.length
                    if li9 > 0 then {
                        if (ctx.breakLabelIsDo.get i: (li9 - 1)) then inDo9 = true
                        sj9: li9
                        for sj9 > 0 loop {
                            sj9 = sj9 - 1
                            if (ctx.breakLabelIsDo.get i: sj9) == false when (hasLoop9) == false then {
                                loopIdx9 = sj9
                                hasLoop9 = true
                            }
                        }
                    }
                    if inDo9 when hasLoop9 then {
                        emitContinueFrees :ctx :tmp idx: loopIdx9 :ind :buf
                        ccl9: ctx.breakLabelCleanup.get i: loopIdx9
                        if ccl9.length > 0 then {
                            lcc9: "\{ind}\{ccl9}"
                            buf.append lcc9.stringview
                        }
                        cid9: ctx.breakLabels.get i: loopIdx9
                        lcg9: "\{ind}goto __zcont_\{cid9};\n"
                        buf.append lcg9.stringview
                        ucn9: true
                        ctx.contLabelUsed.set key: cid9 value: ucn9
                    } else {
                        emitBreakFrees :ctx :tmp :ind :buf
                        if ctx.breakLabelCleanup.length > 0 then {
                            pcl0: (ctx.breakLabelCleanup.get
                                i: (ctx.breakLabelCleanup.length - 1)
                            )
                            if pcl0.length > 0 then {
                                lpc9: "\{ind}\{pcl0}"
                                buf.append lpc9.stringview
                            }
                        }
                        lct9: "\{ind}continue;\n"
                        buf.append lct9.stringview
                    }
                } else {
                    ue9: emitExpr :ast :symtab :ctx :n
                    if (ue9.stringview.startsWith prefix: "/*") then {
                        lu: "\{ind}/* zemitterc: unhandled statement */\n"
                        buf.append lu.stringview
                    } else {
                        urtid9: stampIdOf :symtab nid: (nodeIdOf9 :n)
                        (emitDiscardedResult
                            :ast
                            :symtab
                            :ctx
                            isBorrow: (bindingRhsIsBorrow :ast :symtab :ctx :n)
                            ce: ue9.stringview
                            rtid: urtid9
                            :ind
                            :tmp
                            :buf
                        )
                    }
                }
            }
        }
    }
}

# ensureUnitCache -- build the emit-stable unit lists (tids for the id probe,
# keys for the composed-key fallback) once per Ctx. unitNameTid is populated in
# typecheck and never mutated during emit, so the snapshot stays valid; this
# replaces the per-resolve List rebuild that iterated unitNameTid every call.
ensureUnitCache: function {ctx: Ctx reg: ztypes.ZTypeRegistry} is {
    if ctx.unitCacheBuilt then return
    with uit: reg.unitNameTid.iterateItems do for ue: uit loop {
        ukc9: ue.key.copy
        ctx.unitKeysC.append ukc9
        ctx.unitTidsC.append ue.value
    }
    ctx.unitCacheBuilt = true
}

# resolveTypeIdByNameId -- a type id for an already-interned name (Ast.names
# pool id): main-unit, then system, then the cross-unit lookup. 0 when
# unresolved (incl. a 0 id -- a name not in the pool matches no child edge).
# Every stage is id-keyed (childOfId); the name text is materialised only on
# the rare composed-key fallback.
resolveTypeIdByNameId: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    nameId: u32
} out u64 is {
    if nameId == 0 then return 0
    f: userFnIdById :ast :symtab :ctx :nameId
    if f > 0 then return f
    mo: ztypecheck.resolveSystemChildById :ast ty: symtab.typing reg: symtab.reg :nameId
    match (
        mo
    ) case some then {
        return mo
    } case none then null
    lr9: optU64Or9 o: (ztypecheck.walkLookupTyperefById
        :ast
        ty: symtab.typing
        reg: symtab.reg
        currentUnit: ctx.mainName.stringview
        baseId: nameId
    )
    if lr9 > 0 then return lr9
    # cross-unit: the type may live in a dep unit (zlexer/zast/zvfs) outside
    # walkLookupTyperefById's search list. Pass 1 probes each unit scope by id
    # (no key composition); the composed-key resolvedByKey pass (which also
    # follows unit-level aliases) runs only when every direct probe missed.
    found2: u64
    ensureUnitCache :ctx reg: symtab.reg
    uki9: u64
    ukn9: ctx.unitTidsC.length
    for uki9 < ukn9 loop {
        if found2 == 0 then {
            co9: (symtab.typing.childOfId
                parentTypeId: (ctx.unitTidsC.get i: uki9)
                nameId: nameId.u64
            )
            match (
                co9
            ) case some then {
                found2 = co9
            } case none then null
        }
        uki9 = uki9 + 1
    }
    if found2 == 0 then {
        nmTxt9: zast.poolTextCopy pool: ast.names ref: nameId
        uki8: u64
        ukn8: ctx.unitKeysC.length
        for uki8 < ukn8 loop {
            if found2 == 0 then {
                uk9: ctx.unitKeysC.get i: uki8
                k2: "\{uk9}.\{nmTxt9}"
                r2: (ztypecheck.resolvedByKey
                    :ast
                    ty: symtab.typing
                    reg: symtab.reg
                    key: k2
                )
                match (
                    r2
                ) case some then {
                    found2 = r2
                } case none then null
            }
            uki8 = uki8 + 1
        }
    }
    return found2
}

# resolveTypeIdByName -- text entry point: intern-probe the name to a pool id
# (a name not in the pool matches no interned child edge, so 0 resolves to 0,
# preserving the old text behaviour) and resolve id-keyed. The per-stage
# StringPool.find the old body paid once per stage collapses to this single
# probe.
resolveTypeIdByName: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    name: StringView
} out u64 is {
    nid9: (zast.poolFind pool: ast.names text: name)
    return (resolveTypeIdByNameId :ast :symtab :ctx nameId: nid9)
}

# fnReturnTidOf -- the registry-recorded return tid for a FUNCTION id, 0 when
# absent. Scopes the typeById view so no lock outlives the read.
fnReturnTidOf: function {symtab: zenv.ZSymbolTable tid: u64} out u64 is {
    r9: u64
    {
        t9: symtab.reg.typeById.get key: tid
        match (
            t9
        ) case some then {
            rt9: t9.returnTypeId
            match (
                rt9
            ) case some then {
                r9 = rt9
            } case none then null
        } case none then null
    }
    return r9
}

# genericOriginOf9 -- the registry-recorded generic origin for `tid`, 0 when
# absent. Scopes the typeById view like fnReturnTidOf.
genericOriginOf9: function {symtab: zenv.ZSymbolTable tid: u64} out u64 is {
    g9: u64
    {
        t9: symtab.reg.typeById.get key: tid
        match (
            t9
        ) case some then {
            go9: t9.genericOriginId
            match (
                go9
            ) case some then {
                g9 = go9
            } case none then null
        } case none then null
    }
    return g9
}

# definedInUnitOf -- the defining unit recorded for `tid`, as an OWNED option.
# The map view lives only inside this body: a view bound at a call site would
# hold its shared lock across symtab-passing calls and conflict.
definedInUnitOf: function {symtab: zenv.ZSymbolTable tid: u64} out (Option of: String) is {
    r9: (Option.none String)
    {
        g9: symtab.typing.definedInUnit.get key: tid
        match (
            g9
        ) case some then {
            gc9: g9.copy
            r9 = (Option.some gc9)
        } case none then null
    }
    return r9
}

# emitReassignLvalue -- the C lvalue for a reassignment target. A `got.field`
# whose base atom is a narrowed match-arm binding over a borrowed reftype view
# (seeded in narrowBox) writes THROUGH the box into the live entry; the local
# read-copy is not the backing storage. Other targets emit normally.
emitReassignLvalue: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
} out String is {
    match (
        n
    ) case dottedpath then {
        ba9: atomTextOf :ast n: (ast.nodes.get i: (n.parent - 1).u64)
        if ba9.length > 0 then {
            nbo9: nvGet xs: ctx.narrowBox name: ba9.stringview
            if nbo9.length > 0 then {
                mem9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
                bx9: nbo9.copy
                lvx9: "\{bx9}.\{mem9}"
                return lvx9
            }
        }
        memFp9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        rpnid9: nodeIdOf9 n: (ast.nodes.get i: (n.parent - 1).u64)
        rs09: stampIdOf :symtab nid: rpnid9
        rsn9: typeNameOfReg9 :symtab tid: rs09
        rsc9: userFnId :ast :symtab :ctx name: rsn9.stringview
        rsFp9: rs09
        if rsc9 > 0 then rsFp9 = rsc9
        rsFpc9: chaseColMono :ast :symtab tid: rsFp9
        if (symtab.typing.isChildFnptrField
            pool: ast.names
            parentTypeId: rsFpc9
            name: memFp9.stringview
        ) then {
            recvFp9: atomTextOf :ast n: (ast.nodes.get i: (n.parent - 1).u64)
            accFpL9: ".".string
            if (isPtrVar :ctx name: recvFp9.stringview) then accFpL9 = "->".string
            recvFpC9: ztypes.mangleVarName name: recvFp9.stringview
            return "\{recvFpC9}\{accFpL9}\{memFp9}"
        }
    } else null
    return (emitExpr :ast :symtab :ctx :n)
}

# emitMatchStmt -- a variant-subject match as a tag switch over a temp;
# payload arms shadow the subject name with the payload value.
# emitGenericDissect -- compile-time `match` on a generic parameter. The concrete
# type bound to the parameter for the current mono instance (ctx.curThisTid) is
# resolved via genericArgOf; the arm whose label names that type is emitted
# inline and every other arm is dropped (no runtime switch). No matching arm and
# no `else` emits nothing (the caller-level no-match check is a compile error).
genericOwnerKey9: function {symtab: zenv.ZSymbolTable ownerTid: u64} out String is {
    orig9: genericOriginOf9 :symtab tid: ownerTid
    if orig9 == 0 then return "".string
    onm9: typeNameOfReg9 :symtab tid: orig9
    if (symtab.reg.typetypeOf typeId: orig9) == ztypes.ztypetype.unitType then return onm9
    ounit9: String
    {
        duo9: symtab.typing.definedInUnit.get key: orig9
        match (
            duo9
        ) case some then {
            ounit9 = duo9.copy
        } case none then null
    }
    tk9: "\{ounit9}.\{onm9}"
    return tk9
}

emitGenericDissect: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    m: zast.CaseData
    ownerTid: u64
    paramName: StringView
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    concrete9: u64
    isVal9: false
    if ownerTid > 0 then {
        tk9: genericOwnerKey9 :symtab :ownerTid
        if tk9.length > 0 then {
            pnames9: symtab.reg.genericParamNamesOf typeKey: tk9.stringview
            found9: false
            ord9: u64
            k9: u64
            with pnit9: pnames9.iterate do for pn9: pnit9 loop {
                if (found9) == false then {
                    if pn9.stringview == paramName then {
                        found9 = true
                        ord9 = k9
                    } else {
                        k9 = k9 + 1
                    }
                }
            }
            if found9 then {
                concrete9 = symtab.reg.genericArgAt specId: ownerTid ordinal: ord9
                isVal9 = symtab.reg.genericArgIsValueAt specId: ownerTid ordinal: ord9
            }
        }
    }
    win9: u32
    subjDesc9: String
    if isVal9 then {
        subjDesc9 = "\{concrete9}"
        with cit9: m.clauses.iterate do for cId9: cit9 loop {
            cnode9: ast.nodes.get i: (cId9 - 1).u64
            match (
                cnode9
            ) case caseclause then {
                if win9 == 0 then {
                    if cnode9.name.length > 0 then {
                        pu9: cnode9.name.stringview.parseU64
                        match (
                            pu9
                        ) case ok then {
                            if pu9 == concrete9 then win9 = cnode9.statement
                        } case err then null
                    }
                }
            } else null
        }
    } else {
        cn0: String
        if concrete9 > 0 then cn0 = typeNameOfReg9 :symtab tid: concrete9
        with cit9: m.clauses.iterate do for cId9: cit9 loop {
            cnode9: ast.nodes.get i: (cId9 - 1).u64
            match (
                cnode9
            ) case caseclause then {
                if win9 == 0 then {
                    if cn0.length > 0 when cnode9.name.stringview == cn0.stringview then win9 = cnode9.statement
                }
            } else null
        }
        subjDesc9 = cn0
    }
    if win9 == 0 then win9 = m.elseclause
    if win9 > 0 then {
        buf.append ind
        buf.append "{\n"
        emitBodyNode :ast :symtab :ctx n: (ast.nodes.get i: (win9 - 1).u64) :ind :tmp :buf
        buf.append ind
        buf.append "}\n"
    } else {
        cnm9: "generic match on '\{paramName}' has no case for '\{subjDesc9}' and no else"
        ctx.emitErrors.append from: cnm9.copy
        ef9: "\{ind}z_panic(\"(compile-time error)\");\n"
        buf.append ef9.stringview
    }
}

matchSubjectCore9: function {ast: Ast nid: u64} out u64 is {
    n9: ast.nodes.get i: (nid - 1).u64
    match (
        n9
    ) case expression then {
        return (matchSubjectCore9 :ast nid: n9.expression)
    } else {
        return nid
    }
}

emitMatchStmt: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    m: zast.CaseData
    assignTo: StringView
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    sx: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (m.subject - 1).u64)
    stn: stampNameDeep :ast :symtab n: (ast.nodes.get i: (m.subject - 1).u64)
    if stn.stringview == "bool" then {
        emitBoolMatch :ast :symtab :ctx :m subj: sx.stringview :assignTo :ind :tmp :buf
        return
    }
    vtid: resolveTypeIdByName :ast :symtab :ctx name: stn.stringview
    subjSid9: stampIdOf :symtab nid: (nodeIdOf9 n: (ast.nodes.get i: (m.subject - 1).u64))
    if subjSid9 > 0 then {
        if (symtab.reg.typetypeOf typeId: subjSid9) == ztypes.ztypetype.genericParam then {
            (emitGenericDissect
                :ast
                :symtab
                :ctx
                :m
                ownerTid: ctx.curThisTid
                paramName: stn.stringview
                :ind
                :tmp
                :buf
            )
            return
        }
    }
    dcore9: matchSubjectCore9 :ast nid: m.subject
    dcn9: ast.nodes.get i: (dcore9 - 1).u64
    match (
        dcn9
    ) case dottedpath then {
        dleaf9: dottedChildText :ast n: (ast.nodes.get i: (dcore9 - 1).u64)
        dbnid9: dottedBaseNodeId :ast n: (ast.nodes.get i: (dcore9 - 1).u64)
        dbst9: stampIdOf :symtab nid: dbnid9
        downer9: ctx.curThisTid
        if (symtab.reg.genericArgCount specId: dbst9) > 0 then downer9 = dbst9
        if downer9 > 0 when dleaf9.length > 0 then {
            dkey9: genericOwnerKey9 :symtab ownerTid: downer9
            if dkey9.length > 0 then {
                if (symtab.reg.isGenericParamOf
                    typeKey: dkey9.stringview
                    name: dleaf9.stringview
                ) then {
                    (emitGenericDissect
                        :ast
                        :symtab
                        :ctx
                        :m
                        ownerTid: downer9
                        paramName: dleaf9.stringview
                        :ind
                        :tmp
                        :buf
                    )
                    return
                }
            }
        }
    } else null
    isVar: false
    isUni: false
    if vtid > 0 then {
        vtt0: symtab.reg.typetypeOf typeId: vtid
        if vtt0 == ztypes.ztypetype.variantType then isVar = true
        if vtt0 == ztypes.ztypetype.unionType then isUni = true
    }
    if (isVar) == false then {
        if (isUni) == false then {
            sct: scalarCTypeFor :symtab name: stn.stringview tid: vtid
            if sct.length > 0 then {
                emitScalarMatch :ast :symtab :ctx :m subj: sx.stringview :assignTo :ind :tmp :buf
                return
            }
            lu0: "\{ind}/* zemitterc: unhandled match subject type \{stn} */\n"
            buf.append lu0.stringview
            return
        }
    }
    vc: symtab.reg.cnameOf tid: vtid
    mN: tmp.next
    l0: "\{ind}\{vc}_t _m\{mN} = \{sx};\n"
    buf.append l0.stringview
    l1: "\{ind}switch (_m\{mN}.tag) {\n"
    buf.append l1.stringview
    sname: atomTextDeep :ast n: (ast.nodes.get i: (m.subject - 1).u64)
    ind2: "\{ind}    "
    with citer: m.clauses.iterate do for cId9: citer loop {
        c: ast.nodes.get i: (cId9 - 1).u64
        (emitMatchClause
            :ast
            :symtab
            :ctx
            :c
            :vtid
            :isUni
            :mN
            sname: sname.stringview
            :assignTo
            ind: ind2.stringview
            :tmp
            :buf
        )
    }
    covA9: (List String)
    with c3iter: m.clauses.iterate do for c3Id9: c3iter loop {
        c3: ast.nodes.get i: (c3Id9 - 1).u64
        match (
            c3
        ) case caseclause then {
            cnm9: c3.name.copy
            covA9.append cnm9
        } else null
    }
    meN9: String
    meV9: String
    meT9: u64
    meSeed9: false
    if m.elseclause > 0 then {
        if sname.length > 0 then {
            allME9: (List String)
            sumArmNames9 :ast :symtab tid: vtid names: allME9
            remME9: u64
            armME9: String
            with mit9: allME9.iterate do for ma9: mit9 loop {
                cov9: false
                with cvi9: covA9.iterate do for cv9: cvi9 loop {
                    if cv9.stringview == ma9.stringview then cov9 = true
                }
                if (cov9) == false then {
                    remME9 = remME9 + 1
                    mv9: ma9.copy
                    armME9 = mv9
                }
            }
            if remME9 == 1 then {
                mre9: false
                if m.elseclause > 0 then {
                    mec9: ast.nodes.get i: (m.elseclause - 1).u64
                    mre9 = bodyReassigns9 :ast n: mec9 name: sname.stringview
                }
                if (mre9) == false then {
                    mrecv9: "_m\{mN}"
                    alias9: (armAliasText9
                        :ast
                        :symtab
                        :ctx
                        tid: vtid
                        arm: armME9.stringview
                        recv: mrecv9.stringview
                        acc: "."
                    )
                    if alias9.length > 0 then {
                        msn9: sname.copy
                        meN9 = msn9
                        meV9 = alias9.copy
                        meT9 = (optU64Or9
                            o: (symtab.typing.childOf
                                pool: ast.names
                                parentTypeId: vtid
                                name: armME9.stringview
                            )
                        )
                        meSeed9 = true
                    }
                }
            }
        }
    }
    mePrevV9: String
    mePrevT9: u64
    if meSeed9 then {
        pv9: nvGet xs: ctx.narrowBox name: meN9.stringview
        mePrevV9 = pv9
        mePrevT9 = optU64Or9 o: (ntGet xs: ctx.narrowTid name: meN9.stringview)
        nvSet xs: ctx.narrowBox name: meN9.stringview val: meV9.stringview
        ntSet xs: ctx.narrowTid name: meN9.stringview tid: meT9
    }
    mdvg: matchDiverges :symtab nid: m.nodeid.u64
    (emitMatchElse
        :ast
        :symtab
        :ctx
        oId: m.elseclause
        :assignTo
        ind: ind2.stringview
        :tmp
        diverges: mdvg
        :buf
    )
    if meSeed9 then {
        if mePrevV9.length > 0 then {
            nvSet xs: ctx.narrowBox name: meN9.stringview val: mePrevV9.stringview
        } else {
            nvRemove xs: ctx.narrowBox name: meN9.stringview
        }
        if mePrevT9 > 0 then {
            ntSet xs: ctx.narrowTid name: meN9.stringview tid: mePrevT9
        } else {
            ntRemove xs: ctx.narrowTid name: meN9.stringview
        }
    }
    l9: "\{ind}}\n"
    buf.append l9.stringview
}

# emitScalarMatch -- a value match over a scalar subject: a C switch with
# constant arm labels (arm names resolve through the constant pool).
emitScalarMatch: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    m: zast.CaseData
    subj: StringView
    assignTo: StringView
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    l0: "\{ind}switch (\{subj}) {\n"
    buf.append l0.stringview
    ind2: "\{ind}    "
    citer: m.clauses.iterate
    for cId9: citer loop (emitScalarClause
        :ast
        :symtab
        :ctx
        c: (ast.nodes.get i: (cId9 - 1).u64)
        :assignTo
        ind: ind2.stringview
        :tmp
        :buf
    )
    mdvg: matchDiverges :symtab nid: m.nodeid.u64
    (emitMatchElse
        :ast
        :symtab
        :ctx
        oId: m.elseclause
        :assignTo
        ind: ind2.stringview
        :tmp
        diverges: mdvg
        :buf
    )
    l9: "\{ind}}\n"
    buf.append l9.stringview
}

# emitBoolMatch -- a match over a bool subject. `case true`/`case false` become
# an if (subj) / else if (!subj) chain (a bool is a primitive C bool, not a
# tagged variant), the optional else arm a trailing `else`. assignTo writes the
# arm value in each branch.
emitBoolMatch: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    m: zast.CaseData
    subj: StringView
    assignTo: StringView
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    firstB9: true
    citer: m.clauses.iterate
    for cId9: citer loop {
        c: ast.nodes.get i: (cId9 - 1).u64
        match (
            c
        ) case caseclause then {
            condB9: subj.string
            if c.name.stringview == "false" then condB9 = "!\{subj}"
            kwB9: "if"
            if (firstB9) == false then kwB9 = "else if"
            firstB9 = false
            lhB9: "\{ind}\{kwB9} (\{condB9}) {\n"
            buf.append lhB9.stringview
            indB9: "\{ind}    "
            if assignTo.length > 0 then {
                vxB9: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (c.statement - 1).u64)
                laB9: "\{ind}    \{assignTo} = \{vxB9};\n"
                buf.append laB9.stringview
            } else {
                fLB9: tmp.frees.length
                lLB9: tmp.listFrees.length
                cstB9: ast.nodes.get i: (c.statement - 1).u64
                emitBodyNode :ast :symtab :ctx n: cstB9 ind: indB9.stringview :tmp :buf
                flushBlockFrees :ctx :tmp fL: fLB9 lL: lLB9 :buf
            }
            lcB9: "\{ind}}\n"
            buf.append lcB9.stringview
        } else null
    }
    bdvg: matchDiverges :symtab nid: m.nodeid.u64
    emitBoolElse :ast :symtab :ctx oId: m.elseclause :assignTo :ind :tmp diverges: bdvg :buf
}

# emitBoolElse -- the trailing `else { ... }` of a bool match (none = nothing).
emitBoolElse: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    oId: u32
    assignTo: StringView
    ind: StringView
    tmp: TmpCtr
    diverges: bool
    buf: String.borrow
} is {
    if oId > 0 then {
        o: ast.nodes.get i: (oId - 1).u64
        leB9: "\{ind}else {\n"
        buf.append leB9.stringview
        indE9: "\{ind}    "
        if assignTo.length > 0 then {
            veB9: emitExpr :ast :symtab :ctx n: o
            laE9: "\{ind}    \{assignTo} = \{veB9};\n"
            buf.append laE9.stringview
        } else {
            fLE9: tmp.frees.length
            lLE9: tmp.listFrees.length
            emitBodyNode :ast :symtab :ctx n: o ind: indE9.stringview :tmp :buf
            flushBlockFrees :ctx :tmp fL: fLE9 lL: lLE9 :buf
        }
        lceB9: "\{ind}}\n"
        buf.append lceB9.stringview
    } else {
        if diverges then {
            leD9: "\{ind}else {\n"
            buf.append leD9.stringview
            lzD9: "\{ind}    z_unreachable();\n"
            buf.append lzD9.stringview
            lcD9: "\{ind}}\n"
            buf.append lcD9.stringview
        }
    }
}

# scalarArmLabel -- the C case label for a scalar arm: the constant
# pool's rendering when the arm names a constant, else the name itself.
scalarArmLabel: function {ctx: Ctx arm: StringView} out String is {
    ck: arm.string
    cgo: ctx.constVals.get key: ck
    match (
        cgo
    ) case some then {
        cvv: cgo.stringview
        cvc: cvv.string
        return cvc
    } case none then {
        ac: arm.string
        return ac
    }
}

# flushBlockFrees -- emit + reclaim the heap/collection destructors registered
# since (fL, lL) so a local declared inside a block (a match arm) is freed at
# block end, not function end (where it is out of C scope). LIFO order.
flushBlockFrees: function {ctx: Ctx tmp: TmpCtr fL: u64 lL: u64 buf: String.borrow} is {
    for tmp.listFrees.length > lL loop {
        lvo: tmp.listFrees.pop
        lvfo: tmp.listFreeVars.pop
        buf.append lvo.stringview
    }
    for tmp.frees.length > fL loop {
        fvo: tmp.frees.pop
        ff9: "    \{ctx.strC}_free(&\{fvo});\n"
        buf.append ff9.stringview
    }
}

# emitBreakFrees -- free the loop-body owned locals (everything bound since the
# innermost loop entry) before a `break`/`continue`, which skips the loop body's
# end-of-block flushBlockFrees. Non-destructive (reads by index, no pop): the
# normal fall-through still flushes them at block close. Mirrors flushBlockFrees
# order (listFrees newest-first, then frees).
emitBreakFrees: function {ctx: Ctx tmp: TmpCtr ind: StringView buf: String.borrow} is {
    if ctx.breakFreesMarks.length == 0 then return
    fMark: ctx.breakFreesMarks.get i: (ctx.breakFreesMarks.length - 1)
    lMark: ctx.breakListMarks.get i: (ctx.breakListMarks.length - 1)
    i9: tmp.listFrees.length
    for i9 > lMark loop {
        i9 = i9 - 1
        st9: tmp.listFrees.get i: i9
        buf.append st9.stringview
    }
    j9: tmp.frees.length
    for j9 > fMark loop {
        j9 = j9 - 1
        nm9: tmp.frees.get i: j9
        ff0: "\{ind}\{ctx.strC}_free(&\{nm9});\n"
        buf.append ff0.stringview
    }
}

# emitContinueFrees -- free the owned locals bound since the mark-stack entry
# at `idx` (the targeted LOOP's entry) before a continue that jumps out of a
# do-block wrapper. Non-destructive, mirroring emitBreakFrees.
emitContinueFrees: function {ctx: Ctx tmp: TmpCtr idx: u64 ind: StringView buf: String.borrow} is {
    fMark: ctx.breakFreesMarks.get i: idx
    lMark: ctx.breakListMarks.get i: idx
    i9: tmp.listFrees.length
    for i9 > lMark loop {
        i9 = i9 - 1
        st9: tmp.listFrees.get i: i9
        buf.append st9.stringview
    }
    j9: tmp.frees.length
    for j9 > fMark loop {
        j9 = j9 - 1
        nm9: tmp.frees.get i: j9
        ff0: "\{ind}\{ctx.strC}_free(&\{nm9});\n"
        buf.append ff0.stringview
    }
}

emitScalarClause: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    c: Node
    assignTo: StringView
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    match (
        c
    ) case caseclause then {
        arm: c.name.stringview
    lbl: scalarArmLabel :ctx :arm
        l2: "\{ind}case \{lbl}: {\n"
        buf.append l2.stringview
        ind3: "\{ind}    "
        if assignTo.length > 0 then {
            vx9: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (c.statement - 1).u64)
            la9: "\{ind}    \{assignTo} = \{vx9};\n"
            buf.append la9.stringview
        } else {
            fL9: tmp.frees.length
            lL9: tmp.listFrees.length
            cst9: ast.nodes.get i: (c.statement - 1).u64
            emitBodyNode :ast :symtab :ctx n: cst9 ind: ind3.stringview :tmp :buf
            flushBlockFrees :ctx :tmp fL: fL9 lL: lL9 :buf
        }
        l5: "\{ind}    break;\n"
        buf.append l5.stringview
        l6: "\{ind}}\n"
        buf.append l6.stringview
    } else null
}

emitMatchClause: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    c: Node
    vtid: u64
    isUni: bool
    mN: u64
    sname: StringView
    assignTo: StringView
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    match (
        c
    ) case caseclause then {
        arm: c.name.stringview
        tg: variantTag :symtab tid: vtid :arm
        l2: "\{ind}case \{tg}: {\n"
        buf.append l2.stringview
        pc: armPayloadC :ast :symtab :ctx tid: vtid :arm
        ind3: "\{ind}    "
        didSeed: false
        if pc.length > 0 when sname.length > 0 then {
            if isUni then {
                cmt9: "\{ind}    /* alias: \{sname} => (*(\{pc}*)_m\{mN}.data) */\n"
                buf.append cmt9.stringview
                nbv: "(*(\{pc}*)_m\{mN}.data)"
                nvSet xs: ctx.narrowBox name: sname val: nbv.stringview
                co: symtab.typing.childOf pool: ast.names parentTypeId: vtid name: arm
                match (
                    co
                ) case some then {
                    ntSet xs: ctx.narrowTid name: sname tid: co
                } case none then null
                didSeed = true
            } else {
                l3: "\{ind}    \{pc} \{sname} = _m\{mN}.data.\{arm};\n"
                buf.append l3.stringview
                l4: "\{ind}    (void)\{sname};\n"
                buf.append l4.stringview
            }
        }
        if assignTo.length > 0 then {
            vx9: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (c.statement - 1).u64)
            la9: "\{ind}    \{assignTo} = \{vx9};\n"
            buf.append la9.stringview
        } else {
            fL9: tmp.frees.length
            lL9: tmp.listFrees.length
            cst9: ast.nodes.get i: (c.statement - 1).u64
            emitBodyNode :ast :symtab :ctx n: cst9 ind: ind3.stringview :tmp :buf
            flushBlockFrees :ctx :tmp fL: fL9 lL: lL9 :buf
        }
        if didSeed then {
            nvRemove xs: ctx.narrowBox name: sname
            ntRemove xs: ctx.narrowTid name: sname
        }
        l5: "\{ind}    break;\n"
        buf.append l5.stringview
        l6: "\{ind}}\n"
        buf.append l6.stringview
    } else null
}

emitMatchElse: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    oId: u32
    assignTo: StringView
    ind: StringView
    tmp: TmpCtr
    diverges: bool
    buf: String.borrow
} is {
    if oId > 0 then {
        o: ast.nodes.get i: (oId - 1).u64
        l7: "\{ind}default: {\n"
        buf.append l7.stringview
        ind3: "\{ind}    "
        if assignTo.length > 0 then {
            vx8: emitExpr :ast :symtab :ctx n: o
            la8: "\{ind}    \{assignTo} = \{vx8};\n"
            buf.append la8.stringview
        } else {
            fLe9: tmp.frees.length
            lLe9: tmp.listFrees.length
            emitBodyNode :ast :symtab :ctx n: o ind: ind3.stringview :tmp :buf
            flushBlockFrees :ctx :tmp fL: fLe9 lL: lLe9 :buf
        }
        l8: "\{ind}    break;\n"
        buf.append l8.stringview
        l9: "\{ind}}\n"
        buf.append l9.stringview
    } else {
        if diverges then {
            ld0: "\{ind}default: z_unreachable();\n"
            buf.append ld0.stringview
        } else {
            ld1: "\{ind}default: break;\n"
            buf.append ld1.stringview
        }
    }
}

# emitBranchAssignOptional -- emit a do-block-with-break body, wrapping the final
# value in the optional's `some` arm (tag + data.some); a `break` reached first
# leaves the result at its pre-set `none` tag.
# emitOptionalAssign -- the some-arm assignment for a break-carrying do value:
# inline for a valtype optionval (payC ""), a malloc'd box for a reftype
# Option payload.
emitOptionalAssign: function {
    target: StringView
    someTag: StringView
    payC: StringView
    vx: StringView
    ind: StringView
    buf: String.borrow
} is {
    if payC.length > 0 then {
        lb: "\{ind}\{target}.tag = \{someTag};\n\{ind}{ \{payC}* _zb = (\{payC}*)z_xmalloc(sizeof(\{payC})); *_zb = \{vx}; \{target}.data = _zb; }\n"
        buf.append lb.stringview
    } else {
        la: "\{ind}\{target}.tag = \{someTag};\n\{ind}\{target}.data.some = \{vx};\n"
        buf.append la.stringview
    }
}

emitBranchAssignOptional: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    target: StringView
    someTag: StringView
    payC: StringView
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    match (
        n
    ) case statement then {
        cnt: n.statements.length
        si: u64
        for si < cnt loop {
            sxId9: n.statements.get i: si
            sx: ast.nodes.get i: (sxId9 - 1).u64
            if si + 1 == cnt then {
                vx: emitExpr :ast :symtab :ctx n: sx
                emitOptionalAssign :target :someTag :payC vx: vx.stringview :ind :buf
                emitValueTakeInvalidations :ast :symtab :ctx n: sx :ind :buf
            } else {
                emitStmt :ast :symtab :ctx n: sx :ind :tmp :buf
            }
            si = si + 1
        }
    } else {
        vx2: emitExpr :ast :symtab :ctx :n
        emitOptionalAssign :target :someTag :payC vx: vx2.stringview :ind :buf
        emitValueTakeInvalidations :ast :symtab :ctx :n :ind :buf
    }
}

# emitDoBindValue -- `x: { ... }` (a do block): declare the local and emit the
# block. A do block whose own body breaks yields an optionval (default `none`,
# `some(last)` on normal completion, in a do/while(0) so a break exits to none);
# a breakless do block is a plain scoped block assigning the last value.
emitDoBindValue: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    nm: StringView
    ct: StringView
    tid: u64
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} out bool is {
    match (
        n
    ) case expression then {
        iexK9: ast.nodes.get i: (n.expression - 1).u64
        return (emitDoBindValue :ast :symtab :ctx n: iexK9 :nm :ct :tid :ind :tmp :buf)
    } case doexpr then {
        ld: "\{ind}\{ct} \{nm};\n"
        buf.append ld.stringview
        if (ztypecheck.blockHasBreak :ast n: (ast.nodes.get i: (n.statement - 1).u64)) then {
            noneTag: variantTag :symtab :tid arm: "none"
            someTag: variantTag :symtab :tid arm: "some"
            # a reftype value wraps in Option: the payload lives in a
            # malloc'd box, none carries NULL data, and the local owns the
            # box (scope-exit destroy).
            boxedC9: String
            if (originIsTid :symtab :tid originTid: ctx.optionOriginTid) then {
                boxedC9 = armPayloadC :ast :symtab :ctx :tid arm: "some"
            }
            l0: "\{ind}\{nm}.tag = \{noneTag};\n"
            buf.append l0.stringview
            if boxedC9.length > 0 then {
                l0b: "\{ind}\{nm}.data = NULL;\n"
                buf.append l0b.stringview
                dcb9: symtab.reg.cnameOf :tid
                ldf9: "    \{dcb9}_destroy(&\{nm});\n"
                ldfs9: ldf9.copy
                tmp.listFrees.append ldfs9
                tmp.listFreeVars.append nm.string
            }
            l1: "\{ind}do {\n"
            buf.append l1.stringview
            ind2: "\{ind}    "
            # the block is its own break target: a break inside frees the
            # block's owned temps (since these marks) and lands after the
            # block, not on an enclosing loop's label
            doId9: pushLoopLabel :ctx :tmp isDo: true
            fLd9: tmp.frees.length
            lLd9: tmp.listFrees.length
            (emitBranchAssignOptional
                :ast
                :symtab
                :ctx
                n: (ast.nodes.get i: (n.statement - 1).u64)
                target: nm
                someTag: someTag.stringview
                payC: boxedC9.stringview
                ind: ind2.stringview
                :tmp
                :buf
            )
            flushBlockFrees :ctx :tmp fL: fLd9 lL: lLd9 :buf
            l2: "\{ind}} while (0);\n"
            buf.append l2.stringview
            popLoopLabel :ctx id: doId9 :ind :buf
        } else {
            # an owned destructible block value is destroyed at scope exit
            # (the binding path returns before its own registration).
            if (symtab.reg.hasDestructorName typeId: tid) then {
                pdcb9: symtab.reg.cnameOf :tid
                pldf9: "    \{pdcb9}_destroy(&\{nm});\n"
                pldfs9: pldf9.copy
                tmp.listFrees.append pldfs9
                tmp.listFreeVars.append nm.string
            }
            l3: "\{ind}{\n"
            buf.append l3.stringview
            ind3: "\{ind}    "
            fLe9: tmp.frees.length
            lLe9: tmp.listFrees.length
            (emitBranchAssign
                :ast
                :symtab
                :ctx
                n: (ast.nodes.get i: (n.statement - 1).u64)
                target: nm
                ind: ind3.stringview
                :tmp
                :buf
            )
            flushBlockFrees :ctx :tmp fL: fLe9 lL: lLe9 :buf
            l4: "\{ind}}\n"
            buf.append l4.stringview
        }
        return true
    } else {
        return false
    }
}

# emitMatchBindValue -- `x: (match c case ok then 1 ...)`: declare the
# local and assign per arm; false when the value is not a match.
emitMatchBindValue: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    nm: StringView
    ct: StringView
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} out bool is {
    match (
        n
    ) case expression then {
        iexJ9: ast.nodes.get i: (n.expression - 1).u64
        return (emitMatchBindValue :ast :symtab :ctx n: iexJ9 :nm :ct :ind :tmp :buf)
    } case caseexpr then {
        ld: "\{ind}\{ct} \{nm};\n"
        buf.append ld.stringview
        emitMatchStmt :ast :symtab :ctx m: n assignTo: nm :ind :tmp :buf
        return true
    } else {
        return false
    }
}

# emitIfBindValue -- `s: if c then a else b`: declare the local and emit
# an if-statement assigning the branch value to it; false otherwise.
emitIfBindValue: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    nm: StringView
    ct: StringView
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} out bool is {
    match (
        n
    ) case expression then {
        iexI9: ast.nodes.get i: (n.expression - 1).u64
        return (emitIfBindValue :ast :symtab :ctx n: iexI9 :nm :ct :ind :tmp :buf)
    } case ifexpr then {
        ld: "\{ind}\{ct} \{nm};\n"
        buf.append ld.stringview
        first: true
        with citer: n.clauses.iterate do for cId9: citer loop {
            isFirst: first
            first = false
            (emitIfClause
                :ast
                :symtab
                :ctx
                n: (ast.nodes.get i: (cId9 - 1).u64)
                :isFirst
                assignTo: nm
                :ind
                :tmp
                :buf
            )
        }
        chS9: (List String)
        chA9: (List String)
        chT9: (List u64)
        chN9: (List bool)
        chR9: (List String)
        (chainFactsOfClauses9
            :ast
            :symtab
            :ctx
            clauses: n.clauses
            subjects: chS9
            arms: chA9
            tids: chT9
            negs: chN9
            recvs: chR9
        )
        (emitElse9
            :ast
            :symtab
            :ctx
            oId: n.elseclause
            assignTo: nm
            :ind
            :tmp
            chSubjects: chS9
            chArms: chA9
            chTids: chT9
            chNegs: chN9
            chRecvs: chR9
            :buf
        )
        le: "\{ind}}\n"
        buf.append le.stringview
        return true
    } else {
        return false
    }
}

# loopVarTypeName -- the yield type name of an iterator loop, read from
# the loop variable's first stamped reference in the body ("" if none).
loopVarTypeName: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    bodyId: u32
    lbl: StringView
} out String is {
    res: String
    if bodyId > 0 then {
        b9: ast.nodes.get i: (bodyId - 1).u64
        scanLoopVar :ast :symtab n: b9 :lbl :res
    }
    return res
}

scanLoopVar: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    n: Node
    lbl: StringView
    res: String.borrow
} is {
    if res.length > 0 then return
    match (
        n
    ) case atomid then {
        if (zast.nameTextEq :ast ref: n.name s: lbl) then {
            tid: stampIdOf :symtab nid: n.nodeid.u64
            if tid > 0 then {
                tn: typeNameOfReg9 :symtab :tid
                if tn.length > 0 then {
                    tv: tn.stringview
                    res.append tv
                }
            }
        }
    } case expression then {
        scanLoopVar :ast :symtab n: (ast.nodes.get i: (n.expression - 1).u64) :lbl :res
    } case statement then {
        with sit: n.statements.iterate do for sId9: sit loop {
            scanLoopVar :ast :symtab n: (ast.nodes.get i: (sId9 - 1).u64) :lbl :res
        }
    } case statementline then {
        scanLoopVar :ast :symtab n: (ast.nodes.get i: (n.statementline - 1).u64) :lbl :res
    } case call then {
        with ait: n.arguments.iterate do for a: ait loop {
            an9: ast.nodes.get i: (a - 1).u64
            scanLoopVar :ast :symtab n: an9 :lbl :res
        }
    } case namedoperation then {
        scanLoopVar :ast :symtab n: (ast.nodes.get i: (n.operation - 1).u64) :lbl :res
    } case binop then {
        scanLoopVar :ast :symtab n: (ast.nodes.get i: (n.lhs - 1).u64) :lbl :res
        scanLoopVar :ast :symtab n: (ast.nodes.get i: (n.rhs - 1).u64) :lbl :res
    } case atomstring then {
        with pit: n.stringparts.iterate do for pId9: pit loop {
            scanLoopVar :ast :symtab n: (ast.nodes.get i: (pId9 - 1).u64) :lbl :res
        }
    } else null
}

# emitObjIterFor -- `for x: <iter> loop` where <iter> is an iterator value
# (a type with a `.call` child returning optionval/Option). Emits the
# while(1) / call / tag==NONE break / payload-extract pattern. Value
# payloads (optionval) extract `.data.some`; reftype payloads (Option)
# wait on the heap-extract slice. Returns false when not an iterator loop.
# iterableNodeId -- the stamped node id of a for-loop iterable: peel expression
# wrappers, then take the inner atom / dotted-field / call node (the expression
# wrapper itself may be unstamped for a `this._iterN` field iterator).
iterableNodeId: function {ast: Ast n: Node} out u64 is {
    match (
        n
    ) case expression then {
        return (iterableNodeId :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case atomid then {
        return n.nodeid.u64
    } case dottedpath then {
        return n.nodeid.u64
    } case call then {
        return n.nodeid.u64
    } else {
        return 0
    }
}

# isForIterCall -- the for-loop iterable is a call expression (an rvalue that
# must be hoisted to a temp before `&recv`); a bare atom / dotted field is an
# lvalue used directly.
isForIterCall: function {ast: Ast n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (isForIterCall :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case call then {
        return true
    } case dottedpath then {
        cn: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        return cn.stringview == "iterate"
    } else {
        return false
    }
}

emitObjIterFor: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    m: zast.ForData
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} out bool is {
    if m.conditions.length != 1 then return false
    c0Id9: m.conditions.get i: 0
    c0: ast.nodes.get i: (c0Id9 - 1).u64
    match (
        c0
    ) case namedoperation then {
        lbl: zast.nameTextCopy :ast ref: c0.name
        if lbl.length == 0 then return false
        oeid: iterableNodeId :ast n: (ast.nodes.get i: (c0.operation - 1).u64)
        itid0: stampIdOf :symtab nid: oeid
        if itid0 == 0 then {
            oeidF: exprNodeId9 n: (ast.nodes.get i: (c0.operation - 1).u64)
            itid0 = stampIdOf :symtab nid: oeidF
        }
        itid: itid0
        # bare generator-fn iterable (`for x: counter loop`): itid0 is the
        # generator function itself; resolve via its return type (the iterator
        # class) and auto-call it below.
        bareFnId9: u64
        if (symtab.reg.typetypeOf typeId: itid0) == ztypes.ztypetype.functionType then {
            brt9: u64
            brt9 = fnReturnTidOf :symtab tid: itid0
            if brt9 == 0 then {
                mro9: ztypecheck.methodReturnOf st: symtab mid: itid0
                match (
                    mro9
                ) case some then {
                    brt9 = mro9
                } case none then null
            }
            if brt9 > 0 when (symtab.typing.hasChildId parentTypeId: brt9 nameId: wkCall) then {
                itid = brt9
                bareFnId9 = itid0
            }
        }
        if itid == 0 then return false
        if bareFnId9 == 0 then {
            itn0: typeNameOfReg9 :symtab tid: itid0
            cano: (ztypecheck.walkLookupTyperef
                :ast
                ty: symtab.typing
                reg: symtab.reg
                currentUnit: ctx.mainName.stringview
                base: itn0.stringview
            )
            match (
                cano
            ) case some then {
                if (symtab.typing.hasChildId parentTypeId: cano nameId: wkCall) then itid = cano
            } case none then null
        }
        cco: symtab.typing.childOfId parentTypeId: itid nameId: wkCall
        match (
            cco
        ) case some then {
            ovid: u64
            {
                ct: symtab.reg.typeById.get key: cco
                match (
                    ct
                ) case some then {
                    rto: ct.returnTypeId
                    match (
                        rto
                    ) case some then {
                        ovid = rto
                    } case none then null
                } case none then null
            }
            if ovid == 0 then {
                # user-class iterator: returnTypeId unset, but the .call return
                # node carries the mono stamp.
                mro: ztypecheck.methodReturnOf st: symtab mid: cco
                match (
                    mro
                ) case some then {
                    ovid = mro
                } case none then null
            }
            if ovid == 0 then {
                # native iterator call: returnTypeId unset. Resolve the
                # yield type from the loop var's body usage -> optionval_T.
                ytn: loopVarTypeName :ast :symtab bodyId: m.body lbl: lbl.stringview
                if ytn.length == 0 then return false
                ovnm: "optionval_\{ytn}"
                ovo: (ztypecheck.resolveSystemChild
                    :ast
                    ty: symtab.typing
                    reg: symtab.reg
                    name: ovnm.stringview
                )
                match (
                    ovo
                ) case some then {
                    ovid = ovo
                } case none then {
                    return false
                }
            }
            itn: typeNameOfReg9 :symtab tid: itid
            # a main-unit user-class iterator's .call is emitted by emitOneMethod
            # (its own cname id); native/collection iterators (CpIter, SetIter,
            # emitted with the type-id cname) keep the template's `{type}_call`.
            callC: String
            itUfn9: userFnId :ast :symtab :ctx name: itn.stringview
            isUserCls9: false
            if itUfn9 > 0 when (symtab.reg.typetypeOf typeId: itid) == ztypes.ztypetype.classType then {
                # exclude collection monos (SetIter etc., monoOriginName != "")
                itorig9: monoOriginName :symtab tid: itid
                if itorig9.length == 0 then isUserCls9 = true
            }
            if isUserCls9 then {
                callC = symtab.reg.cnameOf tid: cco
            } else {
                itc9: cnameOf tid: itid name: itn.stringview
                callC = "\{itc9}_call"
            }
            ovn: typeNameOfReg9 :symtab tid: ovid
            ovc: symtab.reg.cnameOf tid: ovid
            ovu: cUpperOf text: ovn.stringview
            payC: armPayloadC :ast :symtab :ctx tid: ovid arm: "some"
            oovorig: monoOriginName :symtab tid: ovid
            mN: tmp.next
            itCb9: cnameOf tid: itid name: itn.stringview
            iterRecv9: String
            ownGit9: false
            if bareFnId9 > 0 then {
                bcn9: symtab.reg.cnameOf tid: bareFnId9
                lgh9: "\{ind}\{itCb9}_t _git\{mN} = \{bcn9}();\n"
                buf.append lgh9.stringview
                iterRecv9 = "_git\{mN}"
                ownGit9 = true
            } else {
                ivex9: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (c0.operation - 1).u64)
                if (isForIterCall :ast n: (ast.nodes.get i: (c0.operation - 1).u64)) then {
                    lgi9: "\{ind}\{itCb9}_t _git\{mN} = \{ivex9};\n"
                    buf.append lgi9.stringview
                    iterRecv9 = "_git\{mN}"
                    ownGit9 = true
                } else {
                    iterRecv9 = ivex9
                }
            }
            # the loop owns the iterator instance: register its destroy for the
            # enclosing block's flush (and the return path), freeing owned
            # captured params. Registered BEFORE the loop label so break /
            # continue inside the loop never free the live instance.
            if ownGit9 then {
                if (symtab.reg.hasDestructorName typeId: itid) when (structDestroyNontrivial
                    :ast
                    :symtab
                    :ctx
                    tid: itid
                ) then {
                    gdt9: "    \{itCb9}_destroy(&_git\{mN});\n"
                    tmp.listFrees.append gdt9
                    gdn9: "_git\{mN}"
                    tmp.listFreeVars.append gdn9
                }
            }
            lidO: pushLoopLabel :ctx :tmp isDo: false
            # owned payloads register a per-iteration cleanup line with the
            # loop entry: continue/break/return jump past the fall-through
            # dtor line below, so the jump sites emit this copy instead.
            payCleanup9: String
            if (originIsTid :symtab tid: ovid originTid: ctx.optionOriginTid) then {
                pfree9: payloadDestructor :ast :symtab :ctx tid: ovid arm: "some"
                if pfree9.length > 0 then payCleanup9 = "\{pfree9}(&\{lbl});\n"
            }
            if payCleanup9.length > 0 then {
                ecl9: ctx.breakLabelCleanup.pop
                pcl9: payCleanup9.copy
                ctx.breakLabelCleanup.append pcl9
                ecv9: ctx.breakLabelCleanupVar.pop
                pcv9: lbl.copy
                ctx.breakLabelCleanupVar.append pcv9
            }
            l0: "\{ind}while (1) {\n"
            buf.append l0.stringview
            l1: "\{ind}    \{ovc}_t _iter\{mN} = \{callC}(&\{iterRecv9});\n"
            buf.append l1.stringview
            if (originIsTid :symtab tid: ovid originTid: ctx.optionOriginTid) then {
                # owned heap-payload union: destroy the box on the NONE arm too.
                l2o: "\{ind}    if (_iter\{mN}.tag == Z_\{ovu}_TAG_NONE) { \{ovc}_destroy(&_iter\{mN}); break; }\n"
                buf.append l2o.stringview
            } else {
                l2: "\{ind}    if (_iter\{mN}.tag == Z_\{ovu}_TAG_NONE) break;\n"
                buf.append l2.stringview
            }
            if (originIsTid :symtab tid: ovid originTid: ctx.optionViewOriginTid) then {
                # borrowed-view yield: scalar payloads copy by value; aggregate
                # payloads bind a borrowed pointer (no copy -> the shared fields
                # are never double-freed).
                payElemPfx: oovorig.length + 1
                payElemName: monoElemName full: ovn prefixLen: payElemPfx
                payElemTid9: optU64Or9 o: (symtab.typing.childOfId
                    parentTypeId: ovid
                    nameId: wkSome
                )
                payScalarC: (cTypeForNameTid
                    :ast
                    :symtab
                    :ctx
                    name: payElemName.stringview
                    tid: payElemTid9
                )
                if payScalarC.length > 0 then {
                    l3v: "\{ind}    \{payC} \{lbl} = *(\{payC}*)_iter\{mN}.data;\n"
                    buf.append l3v.stringview
                } else {
                    l3p: "\{ind}    \{payC}* __borrow_\{lbl} = (\{payC}*)_iter\{mN}.data;\n"
                    buf.append l3p.stringview
                    l3pa: "\{ind}    /* alias: \{lbl} => (*__borrow_\{lbl}) */\n"
                    buf.append l3pa.stringview
                    av3p: "(*__borrow_\{lbl})"
                    nvSet xs: ctx.aliases name: lbl.stringview val: av3p.stringview
                }
            } else if (originIsTid :symtab tid: ovid originTid: ctx.optionOriginTid) then {
                # owned heap yield: move the payload out, free just the box; the
                # loop var owns it and is freed at the end of each iteration.
                l3op: "\{ind}    \{payC} \{lbl} = *(\{payC}*)_iter\{mN}.data;\n"
                buf.append l3op.stringview
                l3of: "\{ind}    free(_iter\{mN}.data);\n"
                buf.append l3of.stringview
            } else {
                l3: "\{ind}    \{payC} \{lbl} = _iter\{mN}.data.some;\n"
                buf.append l3.stringview
            }
            ind2: "\{ind}    "
            fLO9: tmp.frees.length
            lLO9: tmp.listFrees.length
            if m.body > 0 then {
                mb9: ast.nodes.get i: (m.body - 1).u64
                emitBodyNode :ast :symtab :ctx n: mb9 ind: ind2.stringview :tmp :buf
            }
            if payCleanup9.length > 0 then {
                l3od: "\{ind}    \{payCleanup9}"
                buf.append l3od.stringview
            }
            flushBlockFrees :ctx :tmp fL: fLO9 lL: lLO9 :buf
            indO9: "\{ind}    "
            emitContLabel :ctx id: lidO ind: indO9.stringview :buf
            l9: "\{ind}}\n"
            buf.append l9.stringview
            popLoopLabel :ctx id: lidO :ind :buf
            return true
        } case none then {
            return false
        }
    } else {
        return false
    }
}

# emitIntRangeFor -- `for x: N.iterate loop` / `for x: (N.iterate from: F)`:
# a counted C for-loop `for (T x = F; x < N; x++)`. Returns false when the
# header is not a single integer-range binding.
emitIntRangeFor: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    m: zast.ForData
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} out bool is {
    if m.conditions.length != 1 then return false
    c0Id9: m.conditions.get i: 0
    c0: ast.nodes.get i: (c0Id9 - 1).u64
    match (
        c0
    ) case namedoperation then {
        lbl: zast.nameTextCopy :ast ref: c0.name
        if lbl.length == 0 then return false
        bound: rangeBoundExpr :ast :symtab :ctx n: (ast.nodes.get i: (c0.operation - 1).u64)
        if bound.length == 0 then return false
        fromx: rangeFromExpr :ast :symtab :ctx n: (ast.nodes.get i: (c0.operation - 1).u64)
        lidR: pushLoopLabel :ctx :tmp isDo: false
        lh: "\{ind}for (int64_t \{lbl} = \{fromx}; \{lbl} < (int64_t)(\{bound}); \{lbl}++) {\n"
        buf.append lh.stringview
        ind2: "\{ind}    "
        if m.body > 0 then {
            mb29: ast.nodes.get i: (m.body - 1).u64
            emitBodyNode :ast :symtab :ctx n: mb29 ind: ind2.stringview :tmp :buf
        }
        emitContLabel :ctx id: lidR ind: ind2.stringview :buf
        lc: "\{ind}}\n"
        buf.append lc.stringview
        popLoopLabel :ctx id: lidR :ind :buf
        return true
    } else {
        return false
    }
}

# rangeBoundExpr -- the upper bound of an `N.iterate` range (the dotted
# receiver N); "" when the operation is not an iterate call.
rangeBoundExpr: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
} out String is {
    match (
        n
    ) case expression then {
        return (rangeBoundExpr :ast :symtab :ctx n: (ast.nodes.get i: (n.expression - 1).u64))
    } case call then {
        mn: dottedChildText :ast n: (ast.nodes.get i: (n.callable - 1).u64)
        xq139: ast.nodes.get i: (n.callable - 1).u64
        if mn.stringview == "iterate" then return (rangeReceiver :ast :symtab :ctx n: xq139)
        return "".string
    } case dottedpath then {
        cmn: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if cmn.stringview == "iterate" then {
            # the receiver may be a dotted-path itself (squares.length.iterate)
            # -- stampNameDeep resolves its scalar type either way.
            btn: stampNameDeep :ast :symtab n: (ast.nodes.get i: (n.parent - 1).u64)
            cTypeLk1: cTypeOf name: btn.stringview
            if cTypeLk1.length > 0 then {
                return (emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (n.parent - 1).u64))
            }
        }
        return "".string
    } else {
        return "".string
    }
}

# rangeReceiver -- the C expression for the receiver of a `.iterate`
# dotted callable.
rangeReceiver: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
} out String is {
    match (
        n
    ) case dottedpath then {
        return (emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (n.parent - 1).u64))
    } else {
        return "".string
    }
}

# rangeFromExpr -- the `from:` argument of an iterate range, or "0".
rangeFromExpr: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
} out String is {
    match (
        n
    ) case expression then {
        return (rangeFromExpr :ast :symtab :ctx n: (ast.nodes.get i: (n.expression - 1).u64))
    } case call then {
        aiter: n.arguments.iterate
        for aId9: aiter loop {
            a: ast.nodes.get i: (aId9 - 1).u64
            match (
                a
            ) case namedoperation then {
                an: zast.nameTextCopy :ast ref: a.name
                if an.stringview == "from" then return (emitExpr
                    :ast
                    :symtab
                    :ctx
                    n: (ast.nodes.get i: (a.operation - 1).u64)
                )
            } else null
        }
        return "0".string
    } else {
        return "0".string
    }
}

# emitForCond -- one for-header arm: a `while:` arm joins the loop
# condition; a named binding arm emits its init before the loop.
emitForCond: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    cond: String.borrow
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    match (
        n
    ) case namedoperation then {
        lbl: zast.nameTextCopy :ast ref: n.name
        if lbl.length == 0 then {
            cv: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (n.operation - 1).u64)
            if cond.length > 0 then cond.append " && "
            cond.append cv.stringview
        } else {
            onid: exprNodeId9 n: (ast.nodes.get i: (n.operation - 1).u64)
            tn: stampNameOf :symtab nid: onid
            ftid9: stampIdOf :symtab nid: onid
            ct: scalarCTypeFor :symtab name: tn.stringview tid: ftid9
            iv: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (n.operation - 1).u64)
            if ct.length > 0 then {
                li: "\{ind}\{ct} \{lbl} = \{iv};\n"
                buf.append li.stringview
            } else {
                li2: "\{ind}int64_t \{lbl} = \{iv};\n"
                buf.append li2.stringview
            }
        }
    } else null
}

exprNodeId9: function {n: Node} out u64 is {
    match (
        n
    ) case expression then {
        return n.nodeid.u64
    } case atomid then {
        return n.nodeid.u64
    } else {
        return 0
    }
}

# sumArmNames9 -- the excludable arm names of a sum type, in declaration
# order (the checker's exclusion universe).
sumArmNames9: function {ast: Ast symtab: zenv.ZSymbolTable tid: u64 names: List String} is {
    b0: symtab.typing.childIndex.get key: tid
    match (
        b0
    ) case some then {
        with bit9: b0.rows.iterate do for r9: bit9 loop {
            row9: symtab.typing.typeChild.get i: r9
            cto9: symtab.typing.childTypeById.get key: row9.childNameId
            match (
                cto9
            ) case some then {
                k9: symtab.reg.typetypeOf typeId: cto9
                if (zenv.isExcludableKind k: k9) then {
                    if (symtab.reg.isTagGenericOriginOf typeId: cto9) == false then {
                        rnBe9: ast.names.texts.get i: (row9.nameId - 1).u64
                        names.append rnBe9.copy
                    }
                }
            } case none then null
        }
    } case none then null
}

# armAliasText9 -- the C lvalue for `recv`'s payload of `arm` on sum type
# `tid`: the inline union member for variants, the heap cast for unions.
# "" when the arm carries no payload.
armAliasText9: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    tid: u64
    arm: StringView
    recv: StringView
    acc: StringView
} out String is {
    pc9: armPayloadC :ast :symtab :ctx :tid :arm
    if pc9.length == 0 then return "".string
    if (symtab.reg.typetypeOf typeId: tid) == ztypes.ztypetype.unionType then {
        return "(*(\{pc9}*)\{recv}\{acc}data)"
    }
    return "\{recv}\{acc}data.\{arm}"
}

# remainingArm9 -- the single arm of `tid` left after removing the
# ambient exclusions recorded for `subject` (ctx.exclArms) plus the
# `extra` space-joined arms; "" when zero or more than one remain.
remainingArm9: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    subject: StringView
    tid: u64
    extra: StringView
} out String is {
    exv9: nvGet xs: ctx.exclArms name: subject
    all9: (List String)
    sumArmNames9 :ast :symtab :tid names: all9
    remN9: u64
    rem9: String
    with ait9: all9.iterate do for a9: ait9 loop {
        hit9: false
        if exv9.length > 0 then {
            if (svHasWord9 hay: exv9.stringview word: a9.stringview) then hit9 = true
        }
        if (hit9) == false when extra.length > 0 then {
            if (svHasWord9 hay: extra word: a9.stringview) then hit9 = true
        }
        if (hit9) == false then {
            remN9 = remN9 + 1
            rv9: a9.copy
            rem9 = rv9
        }
    }
    if remN9 != 1 then return "".string
    return rem9
}

# svHasWord9 -- space-delimited word membership.
svHasWord9: function {hay: StringView word: StringView} out bool is {
    with wit9: (hay.split sep: " ") do for w9: wit9 loop {
        if w9 == word then return true
    }
    return false
}

# bodyReassigns9 -- true when the body (at any depth through the common
# statement containers) reassigns `name`, which would stale a narrowBox
# alias for it.
bodyReassigns9: function {ast: Ast n: Node name: StringView} out bool is {
    match (
        n
    ) case statement then {
        hit9: false
        with sit9: n.statements.iterate do for s9Id9: sit9 loop {
            if (bodyReassigns9 :ast n: (ast.nodes.get i: (s9Id9 - 1).u64) :name) then hit9 = true
        }
        return hit9
    } case statementline then {
        sln9: ast.nodes.get i: (n.statementline - 1).u64
        return (bodyReassigns9 :ast n: sln9 :name)
    } case expression then {
        return (bodyReassigns9 :ast n: (ast.nodes.get i: (n.expression - 1).u64) :name)
    } case reassignment then {
        tpn9: ast.nodes.get i: (n.topath - 1).u64
        rb9: atomTextOf :ast n: tpn9
        if rb9.length == 0 then rb9 = dottedBaseAtom :ast n: tpn9
        return rb9.stringview == name
    } case ifexpr then {
        hif9: false
        with cit9: n.clauses.iterate do for c9: cit9 loop {
            if (bodyReassigns9 :ast n: (ast.nodes.get i: (c9 - 1).u64) :name) then hif9 = true
        }
        if hif9 then return true
        if n.elseclause == 0 then return false
        return (bodyReassigns9 :ast n: (ast.nodes.get i: (n.elseclause - 1).u64) :name)
    } case ifclause then {
        return (bodyReassigns9 :ast n: (ast.nodes.get i: (n.statement - 1).u64) :name)
    } case caseexpr then {
        hce9: false
        with kit9: n.clauses.iterate do for k9: kit9 loop {
            if (bodyReassigns9 :ast n: (ast.nodes.get i: (k9 - 1).u64) :name) then hce9 = true
        }
        if hce9 then return true
        if n.elseclause == 0 then return false
        return (bodyReassigns9 :ast n: (ast.nodes.get i: (n.elseclause - 1).u64) :name)
    } case caseclause then {
        return (bodyReassigns9 :ast n: (ast.nodes.get i: (n.statement - 1).u64) :name)
    } case forexpr then {
        if n.body == 0 then return false
        return (bodyReassigns9 :ast n: (ast.nodes.get i: (n.body - 1).u64) :name)
    } case doexpr then {
        return (bodyReassigns9 :ast n: (ast.nodes.get i: (n.statement - 1).u64) :name)
    } case withexpr then {
        return (bodyReassigns9 :ast n: (ast.nodes.get i: (n.body - 1).u64) :name)
    } else {
        return false
    }
}

# seedFromPred9 -- one POSITIVE bare arm predicate dotted node: admit a
# non-bool receiver variable whose arm carries a payload and whose
# subject the body does not reassign; append its narrowBox seed
# (subject, alias text, payload tid). The condition-form dispatch
# (trailing .true/.false, == true/false) lives in seedCondOp9.
seedFromPred9: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    body: Node
    names: List String
    vals: List String
    tids: List u64
} is {
    match (
        n
    ) case expression then {
        iexA9: ast.nodes.get i: (n.expression - 1).u64
        seedFromPred9 :ast :symtab :ctx n: iexA9 :body :names :vals :tids
    } case dottedpath then {
        arm0: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        (seedPosCore9
            :ast
            :symtab
            :ctx
            nid: n.nodeid.u64
            parent: (ast.nodes.get i: (n.parent - 1).u64)
            childName: arm0.stringview
            :body
            :names
            :vals
            :tids
        )
    } else null
}

# seedPosCore9 -- the exploded positive-seed core (dotted node fields).
seedPosCore9: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    nid: u64
    parent: Node
    childName: StringView
    body: Node
    names: List String
    vals: List String
    tids: List u64
} is {
    dap9: dpArmPredicateOf9 :symtab :nid
    if dap9 == 0 then return
    bsn9: stampNameDeep :ast :symtab n: parent
    if bsn9.stringview == "bool" then return
    subj9: atomTextOf :ast n: parent
    if subj9.length == 0 then return
    if (bodyReassigns9 :ast n: body name: subj9.stringview) then return
    recv9: emitExpr :ast :symtab :ctx n: parent
    acc9: ".".string
    if (isPtrVar :ctx name: subj9.stringview) then acc9 = "->".string
    alias9: (armAliasText9
        :ast
        :symtab
        :ctx
        tid: dap9
        arm: childName
        recv: recv9.stringview
        acc: acc9.stringview
    )
    if alias9.length == 0 then return
    names.append subj9
    vals.append alias9
    pt9: optU64Or9 o: (symtab.typing.childOf pool: ast.names parentTypeId: dap9 name: childName)
    tids.append pt9
}

# seedNegFromPred9 -- a NEGATED bare arm predicate: the branch knows the
# subject does NOT hold `arm`. When exactly one payload arm remains, seed
# its alias (exclusion collapse, mirroring the checker).
seedNegFromPred9: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    body: Node
    names: List String
    vals: List String
    tids: List u64
} is {
    match (
        n
    ) case expression then {
        iexB9: ast.nodes.get i: (n.expression - 1).u64
        seedNegFromPred9 :ast :symtab :ctx n: iexB9 :body :names :vals :tids
    } case dottedpath then {
        dap9: dpArmPredicateOf9 :symtab nid: n.nodeid.u64
        if dap9 == 0 then return
        bsn9: stampNameDeep :ast :symtab n: (ast.nodes.get i: (n.parent - 1).u64)
        if bsn9.stringview == "bool" then return
        subj9: atomTextOf :ast n: (ast.nodes.get i: (n.parent - 1).u64)
        if subj9.length == 0 then return
        arm9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        rem9: (remainingArm9
            :ast
            :symtab
            :ctx
            subject: subj9.stringview
            tid: dap9
            extra: arm9.stringview
        )
        if rem9.length == 0 then return
        if (bodyReassigns9 :ast n: body name: subj9.stringview) then return
        recv9: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (n.parent - 1).u64)
        acc9: ".".string
        if (isPtrVar :ctx name: subj9.stringview) then acc9 = "->".string
        alias9: (armAliasText9
            :ast
            :symtab
            :ctx
            tid: dap9
            arm: rem9.stringview
            recv: recv9.stringview
            acc: acc9.stringview
        )
        if alias9.length == 0 then return
        names.append subj9
        vals.append alias9
        pt9: optU64Or9 o: (symtab.typing.childOf
            pool: ast.names
            parentTypeId: dap9
            name: rem9.stringview
        )
        tids.append pt9
    } else null
}

# seedCondOp9 -- one if-condition operation, dispatched by form: bare
# `x.a` (positive), `x.a.true` (positive inner), `x.a.false` (negated
# inner), and the `(x.a) == true/false` comparisons.
seedCondOp9: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    body: Node
    names: List String
    vals: List String
    tids: List u64
} is {
    match (
        n
    ) case expression then {
        iexC9: ast.nodes.get i: (n.expression - 1).u64
        seedCondOp9 :ast :symtab :ctx n: iexC9 :body :names :vals :tids
    } case dottedpath then {
        cn9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if cn9.stringview == "true" then {
            dpp9: ast.nodes.get i: (n.parent - 1).u64
            seedFromPred9 :ast :symtab :ctx n: dpp9 :body :names :vals :tids
            return
        }
        if cn9.stringview == "false" then {
            dpq9: ast.nodes.get i: (n.parent - 1).u64
            seedNegFromPred9 :ast :symtab :ctx n: dpq9 :body :names :vals :tids
            return
        }
        (seedPosCore9
            :ast
            :symtab
            :ctx
            nid: n.nodeid.u64
            parent: (ast.nodes.get i: (n.parent - 1).u64)
            childName: cn9.stringview
            :body
            :names
            :vals
            :tids
        )
    } case binop then {
        opn9: bareAtomText9 :ast n: (ast.nodes.get i: (n.operator - 1).u64)
        if opn9.stringview == "==" then {
            ln9: bareAtomText9 :ast n: (ast.nodes.get i: (n.lhs - 1).u64)
            rn9: bareAtomText9 :ast n: (ast.nodes.get i: (n.rhs - 1).u64)
            if rn9.stringview == "true" then {
                bl9: ast.nodes.get i: (n.lhs - 1).u64
                seedFromPred9 :ast :symtab :ctx n: bl9 :body :names :vals :tids
                return
            }
            if rn9.stringview == "false" then {
                bl29: ast.nodes.get i: (n.lhs - 1).u64
                seedNegFromPred9 :ast :symtab :ctx n: bl29 :body :names :vals :tids
                return
            }
            if ln9.stringview == "true" then {
                br9: ast.nodes.get i: (n.rhs - 1).u64
                seedFromPred9 :ast :symtab :ctx n: br9 :body :names :vals :tids
                return
            }
            if ln9.stringview == "false" then {
                br29: ast.nodes.get i: (n.rhs - 1).u64
                seedNegFromPred9 :ast :symtab :ctx n: br29 :body :names :vals :tids
            }
        }
    } else null
}

# bareAtomText9 -- the expression-unwrapped bare atom text of a node,
# "" for any other shape.
bareAtomText9: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case expression then {
        return (bareAtomText9 :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case atomid then {
        return (zast.nameTextCopy :ast ref: n.name)
    } else {
        return "".string
    }
}

# ifPredSeeds9 -- collect the narrowBox seeds for a clause's bare
# arm-predicate conjuncts, all condition forms (parallel lists).
ifPredSeeds9: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    conds: List u32
    bodyId: u32
    names: List String
    vals: List String
    tids: List u64
} is {
    body: ast.nodes.get i: (bodyId - 1).u64
    with kit9: conds.iterate do for k9Id9: kit9 loop {
        k9: ast.nodes.get i: (k9Id9 - 1).u64
        match (
            k9
        ) case namedoperation then {
            (seedCondOp9
                :ast
                :symtab
                :ctx
                n: (ast.nodes.get i: (k9.operation - 1).u64)
                :body
                :names
                :vals
                :tids
            )
        } else null
    }
}

# chainFactsOfClauses9 -- the accumulated single-bare-conjunct facts of an
# if chain (subject/arm/tid/negated parallel lists), mirroring the
# checker's accumulation rule exactly.
chainFactsOfClauses9: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    clauses: List u32
    subjects: List String
    arms: List String
    tids: List u64
    negs: List bool
    recvs: List String
} is {
    with cit9: clauses.iterate do for c9Id9: cit9 loop {
        c9: ast.nodes.get i: (c9Id9 - 1).u64
        match (
            c9
        ) case ifclause then {
            if c9.conditions.length == 1 then {
                tS9: (List String)
                tA9: (List String)
                tT9: (List u64)
                tN9: (List bool)
                tR9: (List String)
                with kit9: c9.conditions.iterate do for k9Id9: kit9 loop {
                    k9: ast.nodes.get i: (k9Id9 - 1).u64
                    match (
                        k9
                    ) case namedoperation then {
                        (chainCondFact9
                            :ast
                            :symtab
                            :ctx
                            n: (ast.nodes.get i: (k9.operation - 1).u64)
                            subjects: tS9
                            arms: tA9
                            tids: tT9
                            negs: tN9
                            recvs: tR9
                        )
                    } else null
                }
                if tS9.length == 1 then {
                    ms9: tS9.pop
                    subjects.append ms9
                    ma9: tA9.pop
                    arms.append ma9
                    tids.append (tT9.get i: 0)
                    negs.append (tN9.get i: 0)
                    mr9: tR9.pop
                    recvs.append mr9
                }
            }
        } else null
    }
}

# chainCondFact9 -- recognize one condition operation as a bare arm
# predicate for chain accumulation (all four forms).
chainCondFact9: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    subjects: List String
    arms: List String
    tids: List u64
    negs: List bool
    recvs: List String
} is {
    match (
        n
    ) case expression then {
        iexD9: ast.nodes.get i: (n.expression - 1).u64
        chainCondFact9 :ast :symtab :ctx n: iexD9 :subjects :arms :tids :negs :recvs
    } case dottedpath then {
        cn9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if cn9.stringview == "true" then {
            (chainInnerFact9
                :ast
                :symtab
                :ctx
                n: (ast.nodes.get i: (n.parent - 1).u64)
                neg: false
                :subjects
                :arms
                :tids
                :negs
                :recvs
            )
            return
        }
        if cn9.stringview == "false" then {
            (chainInnerFact9
                :ast
                :symtab
                :ctx
                n: (ast.nodes.get i: (n.parent - 1).u64)
                neg: true
                :subjects
                :arms
                :tids
                :negs
                :recvs
            )
            return
        }
        (chainFactCore9
            :ast
            :symtab
            :ctx
            nid: n.nodeid.u64
            parent: (ast.nodes.get i: (n.parent - 1).u64)
            childName: cn9.stringview
            neg: false
            :subjects
            :arms
            :tids
            :negs
            :recvs
        )
    } case binop then {
        opn9: bareAtomText9 :ast n: (ast.nodes.get i: (n.operator - 1).u64)
        if opn9.stringview == "==" then {
            ln9: bareAtomText9 :ast n: (ast.nodes.get i: (n.lhs - 1).u64)
            rn9: bareAtomText9 :ast n: (ast.nodes.get i: (n.rhs - 1).u64)
            if rn9.stringview == "true" then {
                (chainInnerFact9
                    :ast
                    :symtab
                    :ctx
                    n: (ast.nodes.get i: (n.lhs - 1).u64)
                    neg: false
                    :subjects
                    :arms
                    :tids
                    :negs
                    :recvs
                )
                return
            }
            if rn9.stringview == "false" then {
                (chainInnerFact9
                    :ast
                    :symtab
                    :ctx
                    n: (ast.nodes.get i: (n.lhs - 1).u64)
                    neg: true
                    :subjects
                    :arms
                    :tids
                    :negs
                    :recvs
                )
                return
            }
            if ln9.stringview == "true" then {
                (chainInnerFact9
                    :ast
                    :symtab
                    :ctx
                    n: (ast.nodes.get i: (n.rhs - 1).u64)
                    neg: false
                    :subjects
                    :arms
                    :tids
                    :negs
                    :recvs
                )
                return
            }
            if ln9.stringview == "false" then {
                (chainInnerFact9
                    :ast
                    :symtab
                    :ctx
                    n: (ast.nodes.get i: (n.rhs - 1).u64)
                    neg: true
                    :subjects
                    :arms
                    :tids
                    :negs
                    :recvs
                )
            }
        }
    } else null
}

# chainInnerFact9 -- the stamped bare-predicate core for chain facts.
chainInnerFact9: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    neg: bool
    subjects: List String
    arms: List String
    tids: List u64
    negs: List bool
    recvs: List String
} is {
    match (
        n
    ) case expression then {
        iexE9: ast.nodes.get i: (n.expression - 1).u64
        chainInnerFact9 :ast :symtab :ctx n: iexE9 :neg :subjects :arms :tids :negs :recvs
    } case dottedpath then {
        arm0: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        (chainFactCore9
            :ast
            :symtab
            :ctx
            nid: n.nodeid.u64
            parent: (ast.nodes.get i: (n.parent - 1).u64)
            childName: arm0.stringview
            :neg
            :subjects
            :arms
            :tids
            :negs
            :recvs
        )
    } else null
}

# chainFactCore9 -- the exploded chain-fact core (dotted node fields).
# Captures the emitted receiver text alongside the fact so the else
# emission never re-derives it from the name.
chainFactCore9: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    nid: u64
    parent: Node
    childName: StringView
    neg: bool
    subjects: List String
    arms: List String
    tids: List u64
    negs: List bool
    recvs: List String
} is {
    dap9: dpArmPredicateOf9 :symtab :nid
    if dap9 == 0 then return
    bsn9: stampNameDeep :ast :symtab n: parent
    if bsn9.stringview == "bool" then return
    subj9: atomTextOf :ast n: parent
    if subj9.length == 0 then return
    an9: childName.string
    rv9: emitExpr :ast :symtab :ctx n: parent
    subjects.append subj9
    arms.append an9
    tids.append dap9
    negs.append neg
    recvs.append rv9
}

emitIfClause: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    isFirst: bool
    assignTo: StringView
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    match (
        n
    ) case ifclause then {
        cond: String
        with kiter: n.conditions.iterate do for kId9: kiter loop {
            k: ast.nodes.get i: (kId9 - 1).u64
            match (
                k
            ) case namedoperation then {
                cv: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (k.operation - 1).u64)
                if cond.length > 0 then cond.append " && "
                cond.append cv.stringview
            } else null
        }
        if isFirst then {
            flushArgHoists :ctx :ind :tmp :buf
            lf: "\{ind}if (\{cond}) {\n"
            buf.append lf.stringview
        } else {
            lg: "\{ind}} else if (\{cond}) {\n"
            buf.append lg.stringview
        }
        ind2: "\{ind}    "
        sN9: (List String)
        sV9: (List String)
        sT9: (List u64)
        (ifPredSeeds9
            :ast
            :symtab
            :ctx
            conds: n.conditions
            bodyId: n.statement
            names: sN9
            vals: sV9
            tids: sT9
        )
        sPrevV9: (List String)
        sPrevT9: (List u64)
        si9: u64
        for si9 < sN9.length loop {
            snm9: sN9.get i: si9
            pv9: nvGet xs: ctx.narrowBox name: snm9.stringview
            sPrevV9.append pv9
            ptv9: optU64Or9 o: (ntGet xs: ctx.narrowTid name: snm9.stringview)
            sPrevT9.append ptv9
            svv9: sV9.get i: si9
            nvSet xs: ctx.narrowBox name: snm9.stringview val: svv9.stringview
            stt9: sT9.get i: si9
            ntSet xs: ctx.narrowTid name: snm9.stringview tid: stt9
            cmtS9: "\{ind}    /* alias: \{snm9} => \{svv9} */\n"
            buf.append cmtS9.stringview
            si9 = si9 + 1
        }
        cst9: ast.nodes.get i: (n.statement - 1).u64
        if assignTo.length > 0 then {
            (emitBranchAssign
                :ast
                :symtab
                :ctx
                n: cst9
                target: assignTo
                ind: ind2.stringview
                :tmp
                :buf
            )
        } else {
            fLi9: tmp.frees.length
            lLi9: tmp.listFrees.length
            emitBodyNode :ast :symtab :ctx n: cst9 ind: ind2.stringview :tmp :buf
            flushBlockFrees :ctx :tmp fL: fLi9 lL: lLi9 :buf
        }
        ri9: u64
        for ri9 < sN9.length loop {
            rnm9: sN9.get i: ri9
            rv9: sPrevV9.get i: ri9
            if rv9.length > 0 then {
                nvSet xs: ctx.narrowBox name: rnm9.stringview val: rv9.stringview
            } else {
                nvRemove xs: ctx.narrowBox name: rnm9.stringview
            }
            rt9: sPrevT9.get i: ri9
            if rt9 > 0 then {
                ntSet xs: ctx.narrowTid name: rnm9.stringview tid: rt9
            } else {
                ntRemove xs: ctx.narrowTid name: rnm9.stringview
            }
            ri9 = ri9 + 1
        }
    } else null
}

emitElse9: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    oId: u32
    assignTo: StringView
    ind: StringView
    tmp: TmpCtr
    chSubjects: List String
    chArms: List String
    chTids: List u64
    chNegs: List bool
    chRecvs: List String
    buf: String.borrow
} is {
    if oId > 0 then {
        o: ast.nodes.get i: (oId - 1).u64
        lh: "\{ind}} else {\n"
        buf.append lh.stringview
        ind2: "\{ind}    "
        # condition-false knowledge: each positive chain fact excludes its
        # arm for the else body (layered in ctx.exclArms so nested else-if
        # wraps compose); a negated fact IS the arm directly.
        exN9: (List String)
        exPrevV9: (List String)
        exPrevT9: (List u64)
        fi9: u64
        for fi9 < chSubjects.length loop {
            if (chNegs.get i: fi9) == false then {
                fs9: chSubjects.get i: fi9
                pv0: nvGet xs: ctx.exclArms name: fs9.stringview
                fsv9: fs9.copy
                exN9.append fsv9
                pvc9: pv0.copy
                exPrevV9.append pvc9
                exPrevT9.append (optU64Or9 o: (ntGet xs: ctx.exclTids name: fs9.stringview))
                fa9: chArms.get i: fi9
                nx9: String
                if pv0.length > 0 then {
                    nj9: "\{pv0} \{fa9}"
                    nx9 = nj9
                } else {
                    na0: fa9.copy
                    nx9 = na0
                }
                nvSet xs: ctx.exclArms name: fs9.stringview val: nx9.stringview
                ntSet xs: ctx.exclTids name: fs9.stringview tid: (chTids.get i: fi9)
            }
            fi9 = fi9 + 1
        }
        sN9: (List String)
        sPrevV9: (List String)
        sPrevT9: (List u64)
        doneS9: (Set String)
        gi9: u64
        for gi9 < chSubjects.length loop {
            gs9: chSubjects.get i: gi9
            if (doneS9.has item: gs9) == false then {
                gsc9: gs9.copy
                doneS9.add item: gsc9
                gtid9: chTids.get i: gi9
                negArm9: String
                hj9: u64
                for hj9 < chSubjects.length loop {
                    h2s9: chSubjects.get i: hj9
                    if h2s9.stringview == gs9.stringview then {
                        if (chNegs.get i: hj9) then {
                            hav9: chArms.get i: hj9
                            hac9: hav9.copy
                            negArm9 = hac9
                        }
                    }
                    hj9 = hj9 + 1
                }
                fArm9: negArm9.copy
                if fArm9.length == 0 then {
                    rr9: (remainingArm9
                        :ast
                        :symtab
                        :ctx
                        subject: gs9.stringview
                        tid: gtid9
                        extra: ""
                    )
                    fArm9 = rr9
                }
                if fArm9.length > 0 then {
                    if (bodyReassigns9 :ast n: o name: gs9.stringview) == false then {
                        mrecv9: chRecvs.get i: gi9
                        macc9: ".".string
                        if (isPtrVar :ctx name: gs9.stringview) then macc9 = "->".string
                        alias9: (armAliasText9
                            :ast
                            :symtab
                            :ctx
                            tid: gtid9
                            arm: fArm9.stringview
                            recv: mrecv9.stringview
                            acc: macc9.stringview
                        )
                        if alias9.length > 0 then {
                            pv9: nvGet xs: ctx.narrowBox name: gs9.stringview
                            sPrevV9.append pv9
                            ptv9: (optU64Or9
                                o: (ntGet xs: ctx.narrowTid name: gs9.stringview)
                            )
                            sPrevT9.append ptv9
                            gsv9: gs9.copy
                            sN9.append gsv9
                            nvSet xs: ctx.narrowBox name: gs9.stringview val: alias9.stringview
                            pt9: (optU64Or9
                                o: (symtab.typing.childOf
                                    pool: ast.names
                                    parentTypeId: gtid9
                                    name: fArm9.stringview
                                )
                            )
                            ntSet xs: ctx.narrowTid name: gs9.stringview tid: pt9
                            cmtS9: "\{ind}    /* alias: \{gs9} => \{alias9} */\n"
                            buf.append cmtS9.stringview
                        }
                    }
                }
            }
            gi9 = gi9 + 1
        }
        if assignTo.length > 0 then {
            (emitBranchAssign
                :ast
                :symtab
                :ctx
                n: o
                target: assignTo
                ind: ind2.stringview
                :tmp
                :buf
            )
        } else {
            fLe9: tmp.frees.length
            lLe9: tmp.listFrees.length
            emitBodyNode :ast :symtab :ctx n: o ind: ind2.stringview :tmp :buf
            flushBlockFrees :ctx :tmp fL: fLe9 lL: lLe9 :buf
        }
        ri9: u64
        for ri9 < sN9.length loop {
            rnm9: sN9.get i: ri9
            rv9: sPrevV9.get i: ri9
            if rv9.length > 0 then {
                nvSet xs: ctx.narrowBox name: rnm9.stringview val: rv9.stringview
            } else {
                nvRemove xs: ctx.narrowBox name: rnm9.stringview
            }
            rt9: sPrevT9.get i: ri9
            if rt9 > 0 then {
                ntSet xs: ctx.narrowTid name: rnm9.stringview tid: rt9
            } else {
                ntRemove xs: ctx.narrowTid name: rnm9.stringview
            }
            ri9 = ri9 + 1
        }
        xi9: exN9.length
        for xi9 > 0 loop {
            xi9 = xi9 - 1
            xn9: exN9.get i: xi9
            xv9: exPrevV9.get i: xi9
            if xv9.length > 0 then {
                nvSet xs: ctx.exclArms name: xn9.stringview val: xv9.stringview
            } else {
                nvRemove xs: ctx.exclArms name: xn9.stringview
            }
            xt9: exPrevT9.get i: xi9
            if xt9 > 0 then {
                ntSet xs: ctx.exclTids name: xn9.stringview tid: xt9
            } else {
                ntRemove xs: ctx.exclTids name: xn9.stringview
            }
        }
    }
}

# emitBranchAssign -- emit an if/match branch whose final value assigns
# to a target: a block emits all but its last statement normally, the
# last as `target = <value>`; a single node assigns directly.
# emitReturnOfNode -- `return <value of node vid>;` with the explicit-return
# machinery: option-box hoist, string-return fast path, and the leak-safe
# temp-materialization + cleanup ordering. Shared by the `return` call arm
# and tail-position value yields.
emitReturnOfNode: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    vid: u32
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    bx: (emitOptionBoxHoist
        :ast
        :symtab
        :ctx
        n: (ast.nodes.get i: (vid - 1).u64)
        :ind
        :tmp
        :buf
    )
    if bx.length > 0 then {
        (emitValueTakeInvalidations
            :ast
            :symtab
            :ctx
            n: (ast.nodes.get i: (vid - 1).u64)
            :ind
            :buf
        )
        emitReturnCleanup :ctx :tmp retExpr: bx.stringview keepRefd: true :ind :buf
        lrb: "\{ind}return \{bx};\n"
        buf.append lrb.stringview
    } else {
        sret: (emitStringReturnValue
            :ast
            :symtab
            :ctx
            n: (ast.nodes.get i: (vid - 1).u64)
            :ind
            :tmp
            :buf
        )
        if (sret) == false then {
            rv: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (vid - 1).u64)
            flushArgHoists :ctx :ind :tmp :buf
            # A non-trivial value-type return may read an owned local the
            # cleanup would free -- a borrowed element or view (e.g.
            # `container.get idx`, or a StringView into a local String).
            # Materialize rv into a temp FIRST, then free. When an owned
            # local is named in rv (leakFix9), free ALL owned locals
            # (clFull9) after zeroing the moved-in call-arg sources
            # (emitValueTakeInvalidations): a read-from local is reclaimed
            # and a moved-in local's free is a no-op. Pointer returns
            # (protocol / Map / Set / by-ref class -- isPtr9) arrive as bare
            # temps; hoisting a shallow pointer copy then freeing it would
            # dangle, so they keep the refsLocal (clProbe9) cleanup inline.
            clProbe9: String
            (emitReturnCleanup
                :ctx
                :tmp
                retExpr: rv.stringview
                keepRefd: true
                :ind
                buf: clProbe9
            )
            clFull9: String
            (emitReturnCleanup
                :ctx
                :tmp
                retExpr: rv.stringview
                keepRefd: false
                :ind
                buf: clFull9
            )
            leakFix9: false
            if clFull9.length > clProbe9.length then leakFix9 = true
            rtid9: (stampIdOf
                :symtab
                nid: (nodeIdOf9 n: (ast.nodes.get i: (vid - 1).u64))
            )
            retCt9: typeRefC :ast :symtab :ctx tid: rtid9 thisTid: 0
            isPtr9: ctEndsWithStar ct: retCt9.stringview
            if (isHeapPtrCollection :ast :symtab :ctx tid: rtid9) then isPtr9 = true
            trivial9: isBareCName s: rv.stringview
            hoist9: false
            if (trivial9 == false) when (isPtr9 == false) when (retCt9.length > 0) then {
                if clProbe9.length > 0 then hoist9 = true
                if leakFix9 then hoist9 = true
            }
            if hoist9 then {
                rtmpN9: tmp.next
                retNm9: "_ret\{rtmpN9}"
                hdecl9: "\{ind}\{retCt9} \{retNm9} = \{rv};\n"
                buf.append hdecl9.stringview
                if leakFix9 then {
                    (emitValueTakeInvalidations
                        :ast
                        :symtab
                        :ctx
                        n: (ast.nodes.get i: (vid - 1).u64)
                        :ind
                        :buf
                    )
                }
                (emitNarrowedTakeZero
                    :ast
                    :symtab
                    :ctx
                    n: (ast.nodes.get i: (vid - 1).u64)
                    :ind
                    :buf
                )
                if leakFix9 then {
                    buf.append clFull9.stringview
                } else {
                    buf.append clProbe9.stringview
                }
                hret9: "\{ind}return \{retNm9};\n"
                buf.append hret9.stringview
            } else {
                buf.append clProbe9.stringview
                lr: "\{ind}return \{rv};\n"
                buf.append lr.stringview
            }
        }
    }
}

# emitTailStmt -- the last statement of an `out`-typed function body sits in
# return position: a bare value expression becomes `return <expr>;`, and a
# with/do block forwards return position into its own final statement. False
# when the statement is not a tail-value shape (the caller emits it normally).
emitTailStmt: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} out bool is {
    match (
        n
    ) case statementline then {
        return (emitTailStmt
            :ast
            :symtab
            :ctx
            n: (ast.nodes.get i: (n.statementline - 1).u64)
            :ind
            :tmp
            :buf
        )
    } case expression then {
        return (emitTailStmt
            :ast
            :symtab
            :ctx
            n: (ast.nodes.get i: (n.expression - 1).u64)
            :ind
            :tmp
            :buf
        )
    } case atomid then {
        if n.name == wkReturn then return false
        if n.name == wkBreak then return false
        if n.name == wkContinue then return false
        if (zast.nameTextEq :ast ref: n.name s: "null") then return false
        emitReturnOfNode :ast :symtab :ctx vid: n.nodeid :ind :tmp :buf
        return true
    } case binop then {
        emitReturnOfNode :ast :symtab :ctx vid: n.nodeid :ind :tmp :buf
        return true
    } case atomstring then {
        emitReturnOfNode :ast :symtab :ctx vid: n.nodeid :ind :tmp :buf
        return true
    } case withexpr then {
        wnT9: n.name.stringview
        wnmT9: wnT9.string
        wtnT9: stampNameDeep :ast :symtab n: (ast.nodes.get i: (n.value - 1).u64)
        wctT9: cTypeForName :ast :symtab :ctx name: wtnT9.stringview
        wvT9: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (n.value - 1).u64)
        if wctT9.length > 0 then {
            lwT9: "\{ind}\{wctT9} \{wnmT9} = \{wvT9};\n"
            buf.append lwT9.stringview
        } else {
            lwT8: "\{ind}int64_t \{wnmT9} = \{wvT9};\n"
            buf.append lwT8.stringview
        }
        ctx.tailRetActive = true
        emitBodyNode :ast :symtab :ctx n: (ast.nodes.get i: (n.body - 1).u64) :ind :tmp :buf
        return true
    } case doexpr then {
        dstT9: ast.nodes.get i: (n.statement - 1).u64
        if (ztypecheck.blockHasBreak :ast n: dstT9) then return false
        ctx.tailRetActive = true
        emitBodyNode :ast :symtab :ctx n: dstT9 :ind :tmp :buf
        return true
    } else {
        return false
    }
}

emitBranchAssign: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    target: StringView
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    match (
        n
    ) case statement then {
        cnt: n.statements.length
        si: u64
        for si < cnt loop {
            sxId9: n.statements.get i: si
            sx: ast.nodes.get i: (sxId9 - 1).u64
            if si + 1 == cnt then {
                vx: emitExpr :ast :symtab :ctx n: sx
                la: "\{ind}\{target} = \{vx};\n"
                buf.append la.stringview
                emitValueTakeInvalidations :ast :symtab :ctx n: sx :ind :buf
            } else {
                emitStmt :ast :symtab :ctx n: sx :ind :tmp :buf
            }
            si = si + 1
        }
    } else {
        vx2: emitExpr :ast :symtab :ctx :n
        la2: "\{ind}\{target} = \{vx2};\n"
        buf.append la2.stringview
        emitValueTakeInvalidations :ast :symtab :ctx :n :ind :buf
    }
}

# postGuardStmtId9 -- the node id of a guarding if/match statement that
# recorded a post-guard narrowing; 0 otherwise.
postGuardStmtId9: function {ast: Ast symtab: zenv.ZSymbolTable n: Node} out u64 is {
    match (
        n
    ) case statementline then {
        return (postGuardStmtId9 :ast :symtab n: (ast.nodes.get i: (n.statementline - 1).u64))
    } case expression then {
        return (postGuardStmtId9 :ast :symtab n: (ast.nodes.get i: (n.expression - 1).u64))
    } case ifexpr then {
        po9: symtab.typing.postGuardName.get key: n.nodeid.u64
        match (
            po9
        ) case some then {
            return n.nodeid.u64
        } case none then {
            return 0
        }
    } case caseexpr then {
        po9: symtab.typing.postGuardName.get key: n.nodeid.u64
        match (
            po9
        ) case some then {
            return n.nodeid.u64
        } case none then {
            return 0
        }
    } else {
        return 0
    }
}

emitBodyNode: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    match (
        n
    ) case statement then {
        trTail9: ctx.tailRetActive
        ctx.tailRetActive = false
        pgN9: (List String)
        pgPrevV9: (List String)
        pgPrevT9: (List u64)
        pgDead9: (Set String)
        i9: u64
        nst9: n.statements.length
        for i9 < nst9 loop {
            s9Id9: n.statements.get i: i9
            s9: ast.nodes.get i: (s9Id9 - 1).u64
            # a reassignment of a seeded name ends its post-guard alias
            ri9: u64
            for ri9 < pgN9.length loop {
                rn9: pgN9.get i: ri9
                if (pgDead9.has item: rn9) == false then {
                    if (bodyReassigns9 :ast n: s9 name: rn9.stringview) then {
                        rv9: pgPrevV9.get i: ri9
                        if rv9.length > 0 then {
                            nvSet xs: ctx.narrowBox name: rn9.stringview val: rv9.stringview
                        } else {
                            nvRemove xs: ctx.narrowBox name: rn9.stringview
                        }
                        rt9: pgPrevT9.get i: ri9
                        if rt9 > 0 then {
                            ntSet xs: ctx.narrowTid name: rn9.stringview tid: rt9
                        } else {
                            ntRemove xs: ctx.narrowTid name: rn9.stringview
                        }
                        rd9: rn9.copy
                        pgDead9.add item: rd9
                    }
                }
                ri9 = ri9 + 1
            }
            tailNow9: false
            if trTail9 when i9 + 1 == nst9 then tailNow9 = true
            handled9: false
            if tailNow9 then {
                handled9 = emitTailStmt :ast :symtab :ctx n: s9 :ind :tmp :buf
            }
            if handled9 == false then emitStmt :ast :symtab :ctx n: s9 :ind :tmp :buf
            pgid9: postGuardStmtId9 :ast :symtab n: s9
            if pgid9 > 0 then {
                pgRawN9: String
                {
                    pgnO9: symtab.typing.postGuardName.get key: pgid9
                    match (
                        pgnO9
                    ) case some then {
                        pgv0: pgnO9.copy
                        pgRawN9 = pgv0
                    } case none then null
                }
                pgRecv9: String
                {
                    pgrO9: symtab.typing.postGuardRecv.get key: pgid9
                    match (
                        pgrO9
                    ) case some then {
                        pgrc9: pgrO9.copy
                        pgRecv9 = pgrc9
                    } case none then null
                }
                pgTid0: u64
                {
                    pgtO9: symtab.typing.postGuardTid.get key: pgid9
                    match (
                        pgtO9
                    ) case some then {
                        pgTid0 = pgtO9
                    } case none then null
                }
                pgArm0: String
                {
                    pgaO9: symtab.typing.postGuardArm.get key: pgid9
                    match (
                        pgaO9
                    ) case some then {
                        pgav9: pgaO9.copy
                        pgArm0 = pgav9
                    } case none then null
                }
                {
                    if pgRawN9.length > 0 when pgRecv9.length > 0 when pgTid0 > 0 when pgArm0.length > 0 then {
                        acc9: ".".string
                        if (isPtrVar :ctx name: pgRawN9.stringview) then acc9 = "->".string
                        alias9: (armAliasText9
                            :ast
                            :symtab
                            :ctx
                            tid: pgTid0
                            arm: pgArm0.stringview
                            recv: pgRecv9.stringview
                            acc: acc9.stringview
                        )
                        if alias9.length > 0 then {
                            pv9: nvGet xs: ctx.narrowBox name: pgRawN9.stringview
                            pgPrevV9.append pv9
                            ptv9: (optU64Or9
                                o: (ntGet xs: ctx.narrowTid name: pgRawN9.stringview)
                            )
                            pgPrevT9.append ptv9
                            nvSet xs: ctx.narrowBox name: pgRawN9.stringview val: alias9.stringview
                            pt9: (optU64Or9
                                o: (symtab.typing.childOf
                                    pool: ast.names
                                    parentTypeId: pgTid0
                                    name: pgArm0.stringview
                                )
                            )
                            ntSet xs: ctx.narrowTid name: pgRawN9.stringview tid: pt9
                            cmt9: "\{ind}/* post-guard alias: \{pgRawN9} => \{alias9} */\n"
                            buf.append cmt9.stringview
                            pgrn9: pgRawN9.copy
                            pgN9.append pgrn9
                        }
                    }
                }
            }
            i9 = i9 + 1
        }
        zi9: pgN9.length
        for zi9 > 0 loop {
            zi9 = zi9 - 1
            zn9: pgN9.get i: zi9
            if (pgDead9.has item: zn9) == false then {
                zv9: pgPrevV9.get i: zi9
                if zv9.length > 0 then {
                    nvSet xs: ctx.narrowBox name: zn9.stringview val: zv9.stringview
                } else {
                    nvRemove xs: ctx.narrowBox name: zn9.stringview
                }
                zt9: pgPrevT9.get i: zi9
                if zt9 > 0 then {
                    ntSet xs: ctx.narrowTid name: zn9.stringview tid: zt9
                } else {
                    ntRemove xs: ctx.narrowTid name: zn9.stringview
                }
            }
        }
    } else {
        emitStmt :ast :symtab :ctx :n :ind :tmp :buf
    }
}

# forexprValue -- the value being bound is a for-loop (a list comprehension).
forexprValue: function {ast: Ast n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (forexprValue :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case forexpr then {
        return true
    } else {
        return false
    }
}

# emitComprehensionBody -- unwrap the body Option (borrowed via the param) and
# emit its statements, the last appended to the list.
emitComprehensionBody: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    body: Node
    listCb: StringView
    listVar: StringView
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    emitComprehensionNode :ast :symtab :ctx n: body :listCb :listVar :ind :tmp :buf
}

# emitComprehensionNode -- the body's statements: each but the last emits
# normally; the last is the value expression, appended to the list.
emitComprehensionNode: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    listCb: StringView
    listVar: StringView
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    match (
        n
    ) case statement then {
        cnt: n.statements.length
        si: u64
        for si < cnt loop {
            stId9: n.statements.get i: si
            st: ast.nodes.get i: (stId9 - 1).u64
            if si == (cnt - 1) then {
                av: emitExpr :ast :symtab :ctx n: st
                la: "\{ind}\{listCb}_append(&\{listVar}, (\{av}));\n"
                buf.append la.stringview
            } else {
                emitStmt :ast :symtab :ctx n: st :ind :tmp :buf
            }
            si = si + 1
        }
    } else {
        av2: emitExpr :ast :symtab :ctx :n
        la2: "\{ind}\{listCb}_append(&\{listVar}, (\{av2}));\n"
        buf.append la2.stringview
    }
}

# emitListComprehension -- populate listVar from `for x: N.iterate loop { expr }`:
# a counted for-loop whose body appends the comprehension's value expression.
emitListComprehension: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    forNode: Node
    listCb: StringView
    listVar: StringView
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    match (
        forNode
    ) case expression then {
        (emitListComprehension
            :ast
            :symtab
            :ctx
            forNode: (ast.nodes.get i: (forNode.expression - 1).u64)
            :listCb
            :listVar
            :ind
            :tmp
            :buf
        )
    } case forexpr then {
        if forNode.conditions.length != 1 then return
        c0Id9: forNode.conditions.get i: 0
        c0: ast.nodes.get i: (c0Id9 - 1).u64
        match (
            c0
        ) case namedoperation then {
            lbl: zast.nameTextCopy :ast ref: c0.name
            bound: rangeBoundExpr :ast :symtab :ctx n: (ast.nodes.get i: (c0.operation - 1).u64)
            from: rangeFromExpr :ast :symtab :ctx n: (ast.nodes.get i: (c0.operation - 1).u64)
            if bound.length == 0 then return
            fh: "\{ind}for (int64_t \{lbl} = \{from}; \{lbl} < \{bound}; \{lbl}++) {\n"
            buf.append fh.stringview
            ind2: "\{ind}    "
            (emitComprehensionBody
                :ast
                :symtab
                :ctx
                body: (ast.nodes.get i: (forNode.body - 1).u64)
                :listCb
                :listVar
                ind: ind2.stringview
                :tmp
                :buf
            )
            lcc9: "\{ind}}\n"
            buf.append lcc9.stringview
        } else null
    } else null
}


# fnSignature -- "RET cname(PARAMS)" for a user function from its
# resolved type's children and return stamp (z_main for main).
# fnReturnTypeId -- the stamped type id of a function's return-type node (the
# typecheck stamps `op.returntype`, even for concrete fns whose registry
# returnTypeId is unset). 0 when the fn has no return type.
fnReturnTypeId: function {ast: Ast symtab: zenv.ZSymbolTable op: Node} out u64 is {
    match (
        op
    ) case functiondef then {
        rtId9: op.returntype
        if rtId9 > 0 then {
            rt9: ast.nodes.get i: (rtId9 - 1).u64
            return (stampIdOf :symtab nid: (nodeIdOf9 n: rt9))
        } else {
            return 0
        }
    } else {
        return 0
    }
}

# isReftypeParam -- a user reftype (class/union) param, passed BY REFERENCE: a
# function param that is a CLASS or UNION, not a collection mono (List/Map/Set),
# and not a value-native (String/StringView live in the system/collections
# units). Records/variants/facets (valtypes) and natives stay by value.
# isUserClassMonoTid -- a specialization of a non-native user CLASS template
# (its instances behave like ordinary classes: pointer receivers, method
# children cloned per spec).
isUserClassMonoTid: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64} out bool is {
    og4: genericOriginOf9 :symtab :tid
    if og4 > 0 then {
        if (symtab.reg.typetypeOf typeId: og4) == ztypes.ztypetype.classType then {
            if (isCollectionOriginTid :ctx originTid: og4) == false then {
                hit4: false
                nat4: false
                {
                    oz4: symtab.reg.typeById.get key: og4
                    match (
                        oz4
                    ) case some then {
                        hit4 = true
                        if oz4.isNative then nat4 = true
                    } case none then null
                }
                if hit4 then return (nat4 == false)
            }
        }
    }
    return false
}

isReftypeParam: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx tid: u64} out bool is {
    cid: tid
    rduo0: definedInUnitOf :symtab :tid
    isShell0: true
    match (
        rduo0
    ) case some then {
        isShell0 = false
    } case none then null
    if isShell0 then {
        rtn0: typeNameOfReg9 :symtab :tid
        rrid0: resolveTypeIdByName :ast :symtab :ctx name: rtn0.stringview
        if rrid0 > 0 then cid = rrid0
    }
    tt: symtab.reg.typetypeOf typeId: cid
    # Only CLASS params pass by reference. A UNION is a small value-stable
    # {tag, void* data} struct passed BY VALUE (the data pointer is shared with
    # the source; the borrow is tracked separately), matching the reference.
    if tt != ztypes.ztypetype.classType then return false
    monoLk4: monoOriginName :symtab tid: cid
    if monoLk4.length > 0 then {
        if (isUserClassMonoTid :symtab :ctx tid: cid) == false then return false
    }
    duo: definedInUnitOf :symtab tid: cid
    match (
        duo
    ) case some then {
        if duo.stringview == "system" then return false
        if duo.stringview == "collections" then return false
    } case none then null
    return true
}

# isBorrowStringParam -- a String param with BORROW/LOCK ownership, passed BY
# REFERENCE so the callee's mutations (append/reserve) persist to the caller. A
# `.take` String param is moved by value instead; StringView is value-passed.
isBorrowStringParam: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    fid: u64
    pname: StringView
    pid: u64
} out bool is {
    ptn9: typeNameOfReg9 :symtab tid: pid
    if ptn9.stringview != "String" then return false
    if (symtab.typing.childOwnershipIs
        pool: ast.names
        parentTypeId: fid
        name: pname
        own: ztypes.zparamownership.borrowMode
    ) then return true
    return (symtab.typing.childOwnershipIs
        pool: ast.names
        parentTypeId: fid
        name: pname
        own: ztypes.zparamownership.lockMode
    )
}

# registerReftypeParams -- add a top-level function's reftype (class/union)
# params to ctx.ptrVars, so the body reads them as `param->field` and method
# calls pass them directly (they arrive as pointers). Caller resets ptrVars.
# isSetMapPtrParam -- a non-TAKE Set/Map param. Set/Map are heap pointers, so the
# param is passed BY POINTER (Set_t*) and its arg (a Set/Map local/field, also a
# pointer) is passed directly -- unlike a by-value List param which needs &.
isSetMapPtrParam: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    fid: u64
    pname: StringView
    tid: u64
} out bool is {
    if (symtab.typing.childOwnershipIs
        pool: ast.names
        parentTypeId: fid
        name: pname
        own: ztypes.zparamownership.takeMode
    ) then return false
    cid: tid
    omn0: monoOriginName :symtab :tid
    if omn0.length == 0 then {
        tn: typeNameOfReg9 :symtab :tid
        mo: ztypecheck.resolveSystemChild :ast ty: symtab.typing reg: symtab.reg name: tn.stringview
        match (
            mo
        ) case some then {
            cid = mo
        } case none then null
    }
    bt: chaseColMono :ast :symtab tid: cid
    omn: monoOriginName :symtab tid: bt
    setT9: builtinTid :ast :symtab base: "Set"
    if (originIsTid :symtab tid: bt originTid: setT9) then return true
    mapT9: builtinTid :ast :symtab base: "Map"
    if (originIsTid :symtab tid: bt originTid: mapT9) then return true
    return false
}

# isListPtrParam -- a non-TAKE List param (a value-struct collection) passes BY
# POINTER so the callee's append/pop/set persist to the caller. A `.take` List is
# moved by value; Set/Map monos are already heap pointers (no extra `*`).
isListPtrParam: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    fid: u64
    pname: StringView
    tid: u64
} out bool is {
    if (symtab.typing.childOwnershipIs
        pool: ast.names
        parentTypeId: fid
        name: pname
        own: ztypes.zparamownership.takeMode
    ) then return false
    cid: tid
    omn0: monoOriginName :symtab :tid
    listT9: builtinTid :ast :symtab base: "List"
    if (originIsTid :symtab :tid originTid: listT9) == false then {
        # a param type is a List SHELL (no genericOriginId, definedInUnit none);
        # resolve the canonical mono by its mangled name to read its origin.
        tn: typeNameOfReg9 :symtab :tid
        mo: ztypecheck.resolveSystemChild :ast ty: symtab.typing reg: symtab.reg name: tn.stringview
        match (
            mo
        ) case some then {
            cid = mo
        } case none then null
    }
    bt: chaseColMono :ast :symtab tid: cid
    omn: monoOriginName :symtab tid: bt
    listT8: builtinTid :ast :symtab base: "List"
    if (originIsTid :symtab tid: bt originTid: listT8) then return true
    return false
}

registerReftypeParams: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx fid: u64} is {
    pNames: (List String)
    pIds: (List u64)
    {
        b2: symtab.typing.childIndex.get key: fid
        match (
            b2
        ) case some then {
            with rit2: b2.rows.iterate do for ri2: rit2 loop {
                tc: symtab.typing.typeChild.get i: ri2
                cto: symtab.typing.childTypeById.get key: tc.childNameId
                match (
                    cto
                ) case some then {
                    nmBe9: ast.names.texts.get i: (tc.nameId - 1).u64
                    nm: nmBe9.copy
                    pNames.append nm
                    pIds.append cto
                } case none then null
            }
        } case none then null
    }
    ri: u64
    rn: pNames.length
    for ri < rn loop {
        rpid: pIds.get i: ri
        rpn: pNames.get i: ri
        regp9: false
        if (symtab.typing.childOwnershipIs
            pool: ast.names
            parentTypeId: fid
            name: rpn.stringview
            own: ztypes.zparamownership.takeMode
        ) == false when (isReftypeParam :ast :symtab :ctx tid: rpid) then {
            regp9 = true
        } else {
            if (isBorrowStringParam
                :ast
                :symtab
                :fid
                pname: rpn.stringview
                pid: rpid
            ) then regp9 = true
        }
        if (isListPtrParam :ast :symtab :fid pname: rpn.stringview tid: rpid) then regp9 = true
        if (isSetMapPtrParam :ast :symtab :fid pname: rpn.stringview tid: rpid) then regp9 = true
        if regp9 then {
            rpc: rpn.copy
            ctx.ptrVars.append rpc
        }
        ri = ri + 1
    }
}

fnSignature: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    name: StringView
    fid: u64
    op: Node
} out String is {
    if name == "main" then return "void z_main(void)".string
    ret: "void".string
    rbn: ztypecheck.fnReturnBaseNameOf :ast :op
    if rbn.length > 0 then {
        rbc: cTypeOf name: rbn.stringview
        rtid0: fnReturnTypeId :ast :symtab :op
        if rtid0 == ctx.strTid then {
            rs0: "\{ctx.strC}_t"
            ret = rs0
        } else if rtid0 == ctx.svTid then {
            rs1: "\{ctx.svC}_t"
            ret = rs1
        } else if rbc.length > 0 then {
            if (ztypecheck.isUserShadowElem ty: symtab.typing reg: symtab.reg elemTid: rtid0) then {
                ret = typeRefC :ast :symtab :ctx tid: rtid0 thisTid: 0
            } else {
                ret = rbc
            }
        } else {
            rbi9: userFnId :ast :symtab :ctx name: rbn.stringview
            if rbi9 > 0 then {
                rr9: typeRefC :ast :symtab :ctx tid: rbi9 thisTid: 0
                if rr9.length > 0 then ret = rr9
            }
        }
    }
    {
        rto: fnReturnTidOf :symtab tid: fid
        if rto > 0 then {
            {
                rn: typeNameOfReg9 :symtab tid: rto
                rc: cTypeOf name: rn.stringview
                if rc.length > 0 then {
                    if (ztypecheck.isUserShadowElem
                        ty: symtab.typing
                        reg: symtab.reg
                        elemTid: rto
                    ) then {
                        ret = typeRefC :ast :symtab :ctx tid: rto thisTid: 0
                    } else {
                        ret = rc
                    }
                } else {
                    # a non-scalar return the rbn block didn't resolve -- e.g. an
                    # optionval/resultval (or other) mono. Use typeRefC, which
                    # gives the mono's C type. Only when ret is still void, so a
                    # resolution from rbn above is never overridden.
                    if ret.stringview == "void" then {
                        rr2: typeRefC :ast :symtab :ctx tid: rto thisTid: 0
                        if rr2.length > 0 then ret = rr2
                    }
                }
            }
        }
    }
    if ret.stringview == "void" then {
        rtnid9: fnReturnTypeId :ast :symtab :op
        if rtnid9 > 0 then {
            rtr9: typeRefC :ast :symtab :ctx tid: rtnid9 thisTid: 0
            if rtr9.length > 0 then ret = rtr9
        }
    }
    if ret.stringview != "void" then {
        retColId9: fnReturnTidOf :symtab tid: fid
        if retColId9 == 0 then retColId9 = fnReturnTypeId :ast :symtab :op
        if retColId9 > 0 when (isHeapPtrCollection
            :ast
            :symtab
            :ctx
            tid: retColId9
        ) then ret = "\{ret}*"
    }
    params: String
    cNames: (List String)
    cIds: (List u64)
    {
        b3: symtab.typing.childIndex.get key: fid
        match (
            b3
        ) case some then {
            with rit3: b3.rows.iterate do for ri3: rit3 loop {
                tc: symtab.typing.typeChild.get i: ri3
                cto: symtab.typing.childTypeById.get key: tc.childNameId
                match (
                    cto
                ) case some then {
                    cnBe0: ast.names.texts.get i: (tc.nameId - 1).u64
                    cn0: cnBe0.copy
                    cNames.append cn0
                    cid2: cto
                    cIds.append cid2
                } case none then null
            }
        } case none then null
    }
    pi: u64
    pn: cNames.length
    for pi < pn loop {
        pname: cNames.get i: pi
        pid: cIds.get i: pi
        ct: typeRefC :ast :symtab :ctx tid: pid thisTid: 0
        ptrp9: false
        if (symtab.typing.childOwnershipIs
            pool: ast.names
            parentTypeId: fid
            name: pname.stringview
            own: ztypes.zparamownership.takeMode
        ) == false when (isReftypeParam :ast :symtab :ctx tid: pid) then {
            ptrp9 = true
        } else {
            if (isBorrowStringParam
                :ast
                :symtab
                :fid
                pname: pname.stringview
                :pid
            ) then ptrp9 = true
        }
        if (isListPtrParam :ast :symtab :fid pname: pname.stringview tid: pid) then ptrp9 = true
        if (isSetMapPtrParam :ast :symtab :fid pname: pname.stringview tid: pid) then ptrp9 = true
        if ptrp9 then {
            if ct.length > 0 then {
                ctp9: "\{ct}*"
                ct = ctp9
            }
        }
        if pi > 0 then params.append ", "
        if ct.length > 0 then {
            params.append ct.stringview
        } else {
            params.append "int64_t"
        }
        params.append " "
        pmnDecl9: ztypes.mangleVarName name: pname.stringview
        params.append pmnDecl9.stringview
        pi = pi + 1
    }
    if pn == 0 then params.append "void"
    fc: cnameOf tid: fid :name
    sig: "\{ret} \{fc}(\{params})"
    return sig
}

# typedefChaseC -- the underlying C scalar of a typedef record, chasing
# the typedef-base chain (meters -> i64, height -> meters -> i64); ""
# when the type is not a typedef.
typedefChaseC: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx tid: u64} out String is {
    bnX9: String
    hitB9: false
    {
        bo: symtab.typing.typedefBaseName.get key: tid
        match (
            bo
        ) case some then {
            hitB9 = true
            bnX9 = bo.copy
        } case none then null
    }
    if hitB9 then {
        bc: cTypeOf name: bnX9.stringview
        if bc.length > 0 then return bc
        bid: userFnId :ast :symtab :ctx name: bnX9.stringview
        if bid > 0 then return (typeRefC :ast :symtab :ctx tid: bid thisTid: 0)
        pmsg8: "zemitterc: unresolvable typedef base \{bnX9} for id \{tid}"
        panic pmsg8
    }
    return "".string
}

# isTypedefType -- the type id carries a typedef base.
isTypedefType: function {symtab: zenv.ZSymbolTable tid: u64} out bool is {
    return (symtab.typing.typedefBaseName.has key: tid)
}

# isBoxTid -- the type is a builtin Box mono (heap pointer), as flagged by the
# typechecker (isBox). Distinguishes the builtin Box from a user class also
# named Box (e.g. linkedlist's generic Box).
isBoxTid: function {symtab: zenv.ZSymbolTable tid: u64} out bool is {
    t: symtab.reg.typeById.get key: tid
    match (
        t
    ) case some then {
        return t.isBox
    } case none then {
        return false
    }
}

# nodeIsAtomBox -- n is a bare atom whose type is a builtin Box (a heap pointer),
# so an arithmetic/compare operand must auto-deref (`b` -> `(*b)`).
nodeIsAtomBox: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (nodeIsAtomBox :ast :symtab :ctx n: (ast.nodes.get i: (n.expression - 1).u64))
    } case atomid then {
        bxt9: stampIdOf :symtab nid: n.nodeid.u64
        return (isBoxTid :symtab tid: bxt9)
    } else {
        return false
    }
}

# isCollectionOrigin -- a generic-origin template name that mints a C
# struct type (List/ListView/Set/Map/MapEntry and the iterators).
isCollectionOrigin: function {name: StringView} out bool is {
    if name == "List" then return true
    if name == "ListView" then return true
    if name == "Set" then return true
    if name == "Map" then return true
    if name == "MapEntry" then return true
    if name == "ListIter" then return true
    if name == "SetIter" then return true
    if name == "MapKeyIter" then return true
    if name == "MapItemIter" then return true
    return false
}

# isCollectionOriginTid -- the id form of isCollectionOrigin: originTid (a
# genericOriginId) is one of the nine cached collection/iterator origin ids.
isCollectionOriginTid: function {ctx: Ctx originTid: u64} out bool is {
    if originTid == 0 then return false
    if originTid == ctx.listOriginTid then return true
    if originTid == ctx.listViewOriginTid then return true
    if originTid == ctx.setOriginTid then return true
    if originTid == ctx.mapOriginTid then return true
    if originTid == ctx.mapEntryOriginTid then return true
    if originTid == ctx.listIterOriginTid then return true
    if originTid == ctx.setIterOriginTid then return true
    if originTid == ctx.mapKeyIterOriginTid then return true
    if originTid == ctx.mapItemIterOriginTid then return true
    return false
}

# cTypeForNameTid -- like cTypeForName, but a user type SHADOWING a scalar (its
# tid is defined in a user unit) emits its struct (typeRefC), not the by-name C
# scalar. For collection-mono VAL_T/KEY_T/ELEM_T where the element/key/value tid
# is known. A non-shadow tid (system scalar or shell) keeps the by-name path.
cTypeForNameTid: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    name: StringView
    tid: u64
} out String is {
    if (ztypecheck.isUserShadowElem ty: symtab.typing reg: symtab.reg elemTid: tid) then {
        return (typeRefC :ast :symtab :ctx :tid thisTid: 0)
    }
    return (cTypeForName :ast :symtab :ctx :name)
}

# cTypeForName -- the C type for a type NAME: scalar via cTypeOf, else
# resolve the type id (across units) and use typeRefC; "" when unknown.
cTypeForName: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    name: StringView
} out String is {
    sc: cTypeOf :name
    if sc.length > 0 then return sc
    to: (ztypecheck.walkLookupTyperef
        :ast
        ty: symtab.typing
        reg: symtab.reg
        currentUnit: ctx.mainName.stringview
        base: name
    )
    match (
        to
    ) case some then {
        return (typeRefC :ast :symtab :ctx tid: to thisTid: 0)
    } case none then {
        # cross-unit: a dep-unit type (e.g. ztypes.zownership used as a ztyping
        # Map value) is outside walkLookupTyperef's search list; resolve via
        # the registry-wide cross-unit scan.
        xid9: resolveTypeIdByName :ast :symtab :ctx :name
        if xid9 > 0 then return (typeRefC :ast :symtab :ctx tid: xid9 thisTid: 0)
        return "".string
    }
}

# typeRefC -- the C spelling for a type id: scalars by name, records by
# their id-based cname ("" when unsupported).
# chaseColMono -- if tid is a typedef-class over a collection mono (Bytes ->
# List_u8, ByteView -> ListView_u8), the underlying mono id; else tid. The
# emitter treats Bytes/ByteView as zero-overhead aliases of their collection.
chaseColMono: function {ast: Ast symtab: zenv.ZSymbolTable tid: u64} out u64 is {
    bmX9: String
    hitM9: false
    {
        bo: symtab.typing.typedefBaseMangled.get key: tid
        match (
            bo
        ) case some then {
            hitM9 = true
            bmX9 = bo.copy
        } case none then null
    }
    if hitM9 then {
        mo: (ztypecheck.resolveSystemChild
            :ast
            ty: symtab.typing
            reg: symtab.reg
            name: bmX9.stringview
        )
        match (
            mo
        ) case some then {
            cmo9: monoOriginName :symtab tid: mo
            if (isCollectionOrigin name: cmo9.stringview) then return mo
        } case none then null
    }
    return tid
}

# chaseStrTypedef -- a class typedef over String/StringView (Path, PathView)
# canonicalizes to the base tid: the wrapper shares the base's struct,
# methods, and cleanup. Single-level chase (stdlib typedefs are one level).
chaseStrTypedef: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64} out u64 is {
    bo: symtab.typing.typedefBaseMangled.get key: tid
    match (
        bo
    ) case some then {
        if bo.stringview == "String" then return ctx.strTid
        if bo.stringview == "StringView" then return ctx.svTid
    } case none then null
    return tid
}

typeRefC: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    tid: u64
    thisTid: u64
} out String is {
    tn: typeNameOfReg9 :symtab :tid
    ct: cTypeOf name: tn.stringview
    if ct.length > 0 then {
        # A user type shadowing a builtin scalar carries the scalar NAME but is
        # defined in a USER unit -- emit its struct, not the C scalar. System
        # scalars (definedInUnit a stdlib unit) and shells (none) keep the C type.
        scDu9: definedInUnitOf :symtab :tid
        scShadow9: false
        match (
            scDu9
        ) case some then {
            if (ztypecheck.isStdlibUnitName name: scDu9.stringview) == false then scShadow9 = true
        } case none then null
        if (scShadow9) == false then return ct
    }
    # canonicalize shells: a param/field child may be a fresh shell id
    # named after the real type; this-typed params take the receiver.
    cid: tid
    if tn.stringview == "this" when thisTid > 0 then {
        cid = thisTid
        tn = typeNameOfReg9 :symtab tid: cid
    }
    cmid9: chaseColMono :ast :symtab tid: cid
    if cmid9 != cid then {
        cmc9: symtab.reg.cnameOf tid: cmid9
        return "\{cmc9}_t"
    }
    cid = chaseStrTypedef :symtab :ctx tid: cid
    tdc: typedefChaseC :ast :symtab :ctx tid: cid
    if tdc.length > 0 then return tdc
    if cid == ctx.strTid then {
        ts0: "\{ctx.strC}_t"
        return ts0
    }
    if cid == ctx.svTid then {
        ts1: "\{ctx.svC}_t"
        return ts1
    }
    if (isBoxTid :symtab tid: cid) then {
        bxmn9: typeNameOfReg9 :symtab tid: cid
        bxen9: monoElemName full: bxmn9 prefixLen: 4
        bxeid9: resolveTypeIdByName :ast :symtab :ctx name: bxen9.stringview
        bxinner9: typeRefC :ast :symtab :ctx tid: bxeid9 thisTid: 0
        return "\{bxinner9}*"
    }
    if (isCollectionOriginTid :ctx originTid: (originTidOf :symtab tid: cid)) then {
        cc9: cnameOf tid: cid name: tn.stringview
        ct9: "\{cc9}_t"
        return ct9
    }
    if (originIsTid :symtab tid: cid originTid: ctx.arrayOriginTid) then {
        aca9: cnameOf tid: cid name: tn.stringview
        act9: "\{aca9}_t"
        return act9
    }
    ctt: symtab.reg.typetypeOf typeId: cid
    if ctt == ztypes.ztypetype.recordType then {
        rc: cnameOf tid: cid name: tn.stringview
        rt9: "\{rc}_t"
        return rt9
    }
    if ctt == ztypes.ztypetype.variantType then {
        rc2: cnameOf tid: cid name: tn.stringview
        rt8: "\{rc2}_t"
        return rt8
    }
    if ctt == ztypes.ztypetype.classType then {
        rc3: cnameOf tid: cid name: tn.stringview
        rt7: "\{rc3}_t"
        return rt7
    }
    if ctt == ztypes.ztypetype.unionType then {
        rc4: cnameOf tid: cid name: tn.stringview
        rt6: "\{rc4}_t"
        return rt6
    }
    if ctt == ztypes.ztypetype.protocolType then {
        rc5: cnameOf tid: cid name: tn.stringview
        rt5: "\{rc5}_t"
        return rt5
    }
    if ctt == ztypes.ztypetype.facetType then {
        rc55: cnameOf tid: cid name: tn.stringview
        rt55: "\{rc55}_t"
        return rt55
    }
    if ctt == ztypes.ztypetype.functionType then {
        rcf: cnameOf tid: cid name: tn.stringview
        rtf: "\{rcf}_ft"
        return rtf
    }
    return "".string
}

# variantArms -- a variant's arm names and payload ids in order
# (non-FUNCTION children, the tag child excluded).
variantArms: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    tid: u64
    names: List String
    ids: List u64
    nameIds: List u64
} is {
    b1: symtab.typing.childIndex.get key: tid
    match (
        b1
    ) case some then {
        with rit1: b1.rows.iterate do for ri1: rit1 loop {
            tc: symtab.typing.typeChild.get i: ri1
            cto: symtab.typing.childTypeById.get key: tc.childNameId
            match (
                cto
            ) case some then {
                if (symtab.reg.typetypeOf typeId: cto) != ztypes.ztypetype.functionType then {
                    if tc.nameId != wkTag then {
                        cnBe1: ast.names.texts.get i: (tc.nameId - 1).u64
                        cn0: cnBe1.copy
                        names.append cn0
                        cid0: cto
                        ids.append cid0
                        nid0: tc.nameId
                        nameIds.append nid0
                    }
                }
            } case none then null
        }
    } case none then null
}

# variantTag -- the C tag constant for an arm.
variantTag: function {symtab: zenv.ZSymbolTable tid: u64 arm: StringView} out String is {
    vn: typeNameOfReg9 :symtab :tid
    vu: cUpperOf text: vn.stringview
    au: cUpperOf text: arm
    t9: "Z_\{vu}_TAG_\{au}"
    return t9
}

# armPayloadC -- an arm's payload C type ("" for null arms).
armPayloadC: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    tid: u64
    arm: StringView
} out String is {
    co: symtab.typing.childOf pool: ast.names parentTypeId: tid name: arm
    match (
        co
    ) case some then {
        pn: typeNameOfReg9 :symtab tid: co
        if pn.stringview == "null" then return "".string
        return (typeRefC :ast :symtab :ctx tid: co thisTid: 0)
    } case none then {
        return "".string
    }
}

# isConformanceMarker -- is (tid, name) an as-block protocol/facet conformance
# marker (`label: Spec` / `:Spec`) rather than a stored field? Such children
# carry the spec type id but must never be emitted as struct fields.
isConformanceMarker: function {
    conf: List ztypes.ZConformance
    tid: u64
    name: StringView
} out bool is {
    found: false
    with citer: conf.iterate do for row: citer loop {
        if row.implTypeId == tid when row.label.stringview == name then found = true
    }
    return found
}

# recFieldLists -- a record type's field names and type ids in order
# (non-FUNCTION children, conformance markers excluded).
recFieldLists: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    tid: u64
    names: List String
    ids: List u64
    nameIds: List u64
} is {
    parentFn0: false
    if (symtab.reg.typetypeOf typeId: tid) == ztypes.ztypetype.functionType then parentFn0 = true
    # this type's conformance-marker labels, collected once (the per-field
    # probe below is a scan over these few names, not the whole table)
    mkNames0: (List String)
    if parentFn0 == false then {
        with cfit0: symtab.typing.conformance.iterate do for crow0: cfit0 loop {
            if crow0.implTypeId == tid then mkNames0.append crow0.label.copy
        }
    }
    b0: symtab.typing.childIndex.get key: tid
    match (
        b0
    ) case some then {
        with rit0: b0.rows.iterate do for ri0: rit0 loop {
            tc: symtab.typing.typeChild.get i: ri0
            cto: symtab.typing.childTypeById.get key: tc.childNameId
            match (
                cto
            ) case some then {
                includeFld0: false
                if parentFn0 then {
                    includeFld0 = true
                } else {
                    fptrFld0: false
                    fpo0: symtab.typing.childIsFnptrField.get key: tc.childNameId
                    match (
                        fpo0
                    ) case some then {
                        fptrFld0 = fpo0
                    } case none then null
                    if fptrFld0 then {
                        includeFld0 = true
                    } else {
                        if (symtab.reg.typetypeOf typeId: cto) != ztypes.ztypetype.functionType then {
                            isConst0: false
                            aco0: symtab.typing.asConstClone.get key: cto
                            match (
                                aco0
                            ) case some then {
                                isConst0 = aco0
                            } case none then null
                            if isConst0 == false then {
                                isMk0: false
                                mi0: u64
                                cnBe2: ast.names.texts.get i: (tc.nameId - 1).u64
                                mn0: mkNames0.length
                                for mi0 < mn0 loop {
                                    mv0: mkNames0.get i: mi0
                                    if mv0.stringview == cnBe2.stringview then isMk0 = true
                                    mi0 = mi0 + 1
                                }
                                if isMk0 == false then includeFld0 = true
                            }
                        }
                    }
                }
                if includeFld0 then {
                    cnBe3: ast.names.texts.get i: (tc.nameId - 1).u64
                    cn0: cnBe3.copy
                    names.append cn0
                    cid0: cto
                    ids.append cid0
                    nid0: tc.nameId
                    nameIds.append nid0
                }
            } case none then null
        }
    } case none then null
}

# regNameIs -- compare a type's registry name without materializing it
# (borrowed typeById view, StringView compare). The none arm mirrors
# comparing against the empty string.
regNameIs: function {symtab: zenv.ZSymbolTable tid: u64 name: StringView} out bool is {
    t: symtab.reg.typeById.get key: tid
    match (
        t
    ) case some then {
        return t.name.stringview == name
    } case none then {
        return name.length == 0
    }
}

# unitIdOf9 -- the interned id for a unit name; 0 when never recorded as a
# defining unit.
unitIdOf9: function {ctx: Ctx name: StringView} out u64 is {
    g9: ctx.unitIdByName.getv key: name
    match (
        g9
    ) case some then {
        return g9
    } case none then {
        return 0
    }
}

# defUnitIdOf9 -- the interned defining-unit id for tid (0 when none).
defUnitIdOf9: function {ctx: Ctx tid: u64} out u64 is {
    g9: ctx.defUnitId.get key: tid
    match (
        g9
    ) case some then {
        return g9
    } case none then {
        return 0
    }
}

typeNameOfReg9: function {symtab: zenv.ZSymbolTable tid: u64} out String is {
    t: symtab.reg.typeById.get key: tid
    match (
        t
    ) case some then {
        return t.name.copy
    } case none then {
        return "".string
    }
}

# isConstShape -- a unit member value that folds to a C constant
# expression: numeric/float atoms, already-rendered constant names, and
# binop trees over those.
isConstShape: function {ast: Ast ctx: Ctx n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (isConstShape :ast :ctx n: (ast.nodes.get i: (n.expression - 1).u64))
    } case atomid then {
        avK9: ast.names.texts.get i: (n.name - 1).u64
        av: avK9.stringview
        b0: av.byteAt i: 0
        match (
            b0
        ) case some then {
            if b0 >= 48 then {
                if b0 <= 57 then return true
            }
        } case none then null
        ak: avK9.copy
        cgo: ctx.constVals.get key: ak
        match (
            cgo
        ) case some then {
            return true
        } case none then {
            return false
        }
    } case binop then {
        if (isConstShape :ast :ctx n: (ast.nodes.get i: (n.lhs - 1).u64)) then {
            return (isConstShape :ast :ctx n: (ast.nodes.get i: (n.rhs - 1).u64))
        } else {
            return false
        }
    } case ifexpr then {
        return true
    } case dottedpath then {
        # a typed numeric literal `0x7F.u64` / `42.i128` folds to a C constant.
        pc9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        cTypeLk4: cTypeOf name: pc9.stringview
        if cTypeLk4.length > 0 then {
            pb9: atomTextOf :ast n: (ast.nodes.get i: (n.parent - 1).u64)
            db9: pb9.stringview.byteAt i: 0
            match (
                db9
            ) case some then {
                if db9 >= 48 then {
                    if db9 <= 57 then return true
                }
            } case none then null
        }
        return false
    } else {
        return false
    }
}

# fillMethodReturns -- record each main-unit type method's return
# format name (TypeName.method -> i64/f64/...), so interpolation can
# format auto-call results whose node carries only a FUNCTION stamp.
fillDataElems: function {program: Node symtab: zenv.ZSymbolTable ctx: Ctx} is {
    match (
        program
    ) case program then {
        uCnt9a: program.ast.units.length
        uIdx9a: u64
        for uIdx9a < uCnt9a loop {
            uId9: program.ast.units.get i: uIdx9a
            uIdx9a = uIdx9a + 1
            opId9: u32
            {
                u: program.ast.nodes.get i: (uId9 - 1).u64
                if u.namedoperation then {
                    un: zast.poolTextCopy pool: program.ast.names ref: u.name
                    if (isEmittableFileUnit name: un.stringview) then opId9 = u.operation
                }
            }
            if opId9 > 0 then {
                (fillDataElemsIn
                    :symtab
                    :ctx
                    ast: program.ast
                    mainOpId: opId9
                )
            }
        }
    } else null
}

fillDataElemsIn: function {
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    ast: Ast
    mainOpId: u32
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: mainOpId
    with biter: bodyIds9.iterate do for bm: biter loop {
        bmNode9: ast.nodes.get i: (bm - 1).u64
        if bmNode9.namedoperation then {
            dnm: zast.nameTextCopy :ast ref: bmNode9.name
            (fillOneDataElem
                :ast
                :symtab
                :ctx
                name: dnm.stringview
                op: (ast.nodes.get i: (bmNode9.operation - 1).u64)
            )
        }
    }
}

fillOneDataElem: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    name: StringView
    op: Node
} is {
    match (
        op
    ) case expression then {
        fillOneDataElem :ast :symtab :ctx :name op: (ast.nodes.get i: (op.expression - 1).u64)
    } case datablock then {
        ebn: dataElemBaseName :ast oId: op.outType
        k9: name.string
        if ebn.length > 0 then {
            ebv9: ebn.stringview
            ev9: ebv9.string
            ctx.dataElems.set key: k9 value: ev9
        } else {
            iv9: "i64".string
            ctx.dataElems.set key: k9 value: iv9
        }
        idx9: u64
        eiter9: op.elements.iterate
        for e9: eiter9 loop {
            vx9: emitDataElem :ast :symtab :ctx n: (ast.nodes.get i: (e9 - 1).u64)
            ik9: "\{name}.\{idx9}"
            iv2: vx9.copy
            ctx.dataConst.set key: ik9 value: iv2
            elbl: dataElemLabel :ast n: (ast.nodes.get i: (e9 - 1).u64)
            if elbl.length > 0 then {
                lk9: "\{name}.\{elbl}"
                lv9: vx9.copy
                ctx.dataConst.set key: lk9 value: lv9
            }
            idx9 = idx9 + 1
        }
    } else null
}

dataElemLabel: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case namedoperation then {
        return (zast.nameTextCopy :ast ref: n.name)
    } else {
        return "".string
    }
}

fillNeeds: function {program: Node ctx: Ctx} is {
    match (
        program
    ) case program then {
        uCnt9b: program.ast.units.length
        uIdx9b: u64
        for uIdx9b < uCnt9b loop {
            uId9: program.ast.units.get i: uIdx9b
            uIdx9b = uIdx9b + 1
            opId9: u32
            {
                u: program.ast.nodes.get i: (uId9 - 1).u64
                if u.namedoperation then {
                    un: zast.poolTextCopy pool: program.ast.names ref: u.name
                    if (isEmittableFileUnit name: un.stringview) then opId9 = u.operation
                }
            }
            if opId9 > 0 then {
                (fillNeedsIn
                    :ctx
                    ast: program.ast
                    mainOpId: opId9
                )
            }
        }
    } else null
}

fillNeedsIn: function {ctx: Ctx ast: Ast mainOpId: u32} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: mainOpId
    with biter: bodyIds9.iterate do for bm: biter loop {
        bmNode9: ast.nodes.get i: (bm - 1).u64
        if bmNode9.namedoperation then {
            scanNeeds :ast :ctx n: (ast.nodes.get i: (bmNode9.operation - 1).u64)
        }
    }
}

# scanNeeds -- recursively register io/os native needs for every call in a
# def/body. Structurally mirrors collectLiterals; emitFns registers free-fn
# needs ahead of emitRuntimeIo, but type-method bodies emit afterwards (via
# emitRecordDefs), so a native used only inside a method (e.g. io.stat in
# zvfs's providers) would never have its runtime body emitted. At a call node
# it inspects the callable's `base.member` shape and registers io/os +
# io_<m>/os_<m> (an unrecognized member gates no fragment, so over-registering
# is harmless).
scanNeeds: function {ast: Ast ctx: Ctx n: Node} is {
    match (
        n
    ) case functiondef then {
        if n.body > 0 then scanNeeds :ast :ctx n: (ast.nodes.get i: (n.body - 1).u64)
    } case objectdef then {
        with aiter: n.asItems.iterate do for amId9: aiter loop {
            am: ast.nodes.get i: (amId9 - 1).u64
            match (
                am
            ) case namedoperation then {
                scanNeeds :ast :ctx n: (ast.nodes.get i: (am.operation - 1).u64)
            } else null
        }
    } case statement then {
        siter: n.statements.iterate
        for sId9: siter loop scanNeeds :ast :ctx n: (ast.nodes.get i: (sId9 - 1).u64)
    } case statementline then {
        scanNeeds :ast :ctx n: (ast.nodes.get i: (n.statementline - 1).u64)
    } case expression then {
        scanNeeds :ast :ctx n: (ast.nodes.get i: (n.expression - 1).u64)
    } case namedoperation then {
        scanNeeds :ast :ctx n: (ast.nodes.get i: (n.operation - 1).u64)
    } case call then {
        bn0: dottedBaseAtom :ast n: (ast.nodes.get i: (n.callable - 1).u64)
        mn0: dottedChildText :ast n: (ast.nodes.get i: (n.callable - 1).u64)
        if bn0.stringview == "io" when mn0.length > 0 then {
            needsAdd :ctx name: "io"
            iname0: "io_\{mn0}"
            needsAdd :ctx name: iname0.stringview
        }
        if bn0.stringview == "os" when mn0.length > 0 then {
            needsAdd :ctx name: "os"
            oname0: "os_\{mn0}"
            needsAdd :ctx name: oname0.stringview
        }
        if bn0.stringview == "net" when mn0.length > 0 then needsAdd :ctx name: "net"
        if (isSvArgNative name: mn0.stringview) then needsAdd :ctx name: mn0.stringview
        if (isSvSimpleNative name: mn0.stringview) then needsAdd :ctx name: mn0.stringview
        # substring emits through its own leg (recv/from/to), so the arg-native
        # table cannot carry it; the need still must pre-register for method
        # bodies, which emit after emitNeededNatives runs
        if mn0.stringview == "substring" then needsAdd :ctx name: "substring"
        if (isSvParseNative name: mn0.stringview) then needsAdd :ctx name: mn0.stringview
        if (isSvNoArgNative name: mn0.stringview) then needsAdd :ctx name: mn0.stringview
        cjn0: atomTextOf :ast n: (ast.nodes.get i: (n.callable - 1).u64)
        if cjn0.stringview == "stringJoin" then needsAdd :ctx name: "coll_join"
        aiter2: n.arguments.iterate
        for a: aiter2 loop scanNeeds :ast :ctx n: (ast.nodes.get i: (a - 1).u64)
    } case dottedpath then {
        pdm9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if pdm9.stringview == "parseF64" then needsAdd :ctx name: "parseF64"
        if pdm9.stringview == "parseI64" then needsAdd :ctx name: "parseI64"
        if pdm9.stringview == "parseU64" then needsAdd :ctx name: "parseU64"
        if (isSvNoArgNative name: pdm9.stringview) then needsAdd :ctx name: pdm9.stringview
        scanNeeds :ast :ctx n: (ast.nodes.get i: (n.parent - 1).u64)
    } case binop then {
        scanNeeds :ast :ctx n: (ast.nodes.get i: (n.lhs - 1).u64)
        scanNeeds :ast :ctx n: (ast.nodes.get i: (n.rhs - 1).u64)
    } case assignment then {
        scanNeeds :ast :ctx n: (ast.nodes.get i: (n.value - 1).u64)
    } case reassignment then {
        scanNeeds :ast :ctx n: (ast.nodes.get i: (n.value - 1).u64)
    } case ifexpr then {
        citer: n.clauses.iterate
        for cId9: citer loop scanNeeds :ast :ctx n: (ast.nodes.get i: (cId9 - 1).u64)
        if n.elseclause > 0 then scanNeeds :ast :ctx n: (ast.nodes.get i: (n.elseclause - 1).u64)
    } case caseexpr then {
        scanNeeds :ast :ctx n: (ast.nodes.get i: (n.subject - 1).u64)
        miter9: n.clauses.iterate
        for mc9Id9: miter9 loop scanNeeds :ast :ctx n: (ast.nodes.get i: (mc9Id9 - 1).u64)
        if n.elseclause > 0 then scanNeeds :ast :ctx n: (ast.nodes.get i: (n.elseclause - 1).u64)
    } case caseclause then {
        scanNeeds :ast :ctx n: (ast.nodes.get i: (n.statement - 1).u64)
    } case ifclause then {
        kiter: n.conditions.iterate
        for kId9: kiter loop scanNeeds :ast :ctx n: (ast.nodes.get i: (kId9 - 1).u64)
        scanNeeds :ast :ctx n: (ast.nodes.get i: (n.statement - 1).u64)
    } case withexpr then {
        scanNeeds :ast :ctx n: (ast.nodes.get i: (n.value - 1).u64)
        scanNeeds :ast :ctx n: (ast.nodes.get i: (n.body - 1).u64)
    } case doexpr then {
        scanNeeds :ast :ctx n: (ast.nodes.get i: (n.statement - 1).u64)
    } case forexpr then {
        fiter: n.conditions.iterate
        for fId9: fiter loop scanNeeds :ast :ctx n: (ast.nodes.get i: (fId9 - 1).u64)
        if n.body > 0 then scanNeeds :ast :ctx n: (ast.nodes.get i: (n.body - 1).u64)
    } else null
}

fillMethodReturns: function {program: Node symtab: zenv.ZSymbolTable ctx: Ctx} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        uCnt9c: program.ast.units.length
        uIdx9c: u64
        for uIdx9c < uCnt9c loop {
            uId9: program.ast.units.get i: uIdx9c
            uIdx9c = uIdx9c + 1
            opId9: u32
            {
                u: program.ast.nodes.get i: (uId9 - 1).u64
                if u.namedoperation then {
                    un: zast.poolTextCopy pool: program.ast.names ref: u.name
                    if un.stringview == mainName then opId9 = u.operation
                }
            }
            if opId9 > 0 then {
                (fillMethodReturnsIn
                    :symtab
                    :ctx
                    ast: program.ast
                    mainOpId: opId9
                )
            }
        }
    } else null
}

fillMethodReturnsIn: function {
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    ast: Ast
    mainOpId: u32
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: mainOpId
    with biter: bodyIds9.iterate do for bm: biter loop {
        bmNode9: ast.nodes.get i: (bm - 1).u64
        if bmNode9.namedoperation then {
            tnm: zast.nameTextCopy :ast ref: bmNode9.name
            (fillTypeMethodReturns
                :ast
                :symtab
                :ctx
                typeName: tnm.stringview
                op: (ast.nodes.get i: (bmNode9.operation - 1).u64)
            )
        }
    }
}

fillTypeMethodReturns: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    typeName: StringView
    op: Node
} is {
    match (
        op
    ) case objectdef then {
        with aiter: op.asItems.iterate do for amId9: aiter loop {
            am: ast.nodes.get i: (amId9 - 1).u64
            match (
                am
            ) case namedoperation then {
                if (isFunctionDefWithBody9 n: (ast.nodes.get i: (am.operation - 1).u64)) then {
                    mnm: zast.nameTextCopy :ast ref: am.name
                    rbn: (ztypecheck.fnReturnBaseNameOf
                        :ast
                        op: (ast.nodes.get i: (am.operation - 1).u64)
                    )
                    if rbn.length > 0 then {
                        k9: "\{typeName}.\{mnm}"
                        rbv: rbn.stringview
                        v9: rbv.string
                        ctx.methodReturns.set key: k9 value: v9
                    }
                }
            } else null
        }
    } else null
}

# fillConstVals -- pre-render each main-unit constant's C text in
# definition order (constants reference only earlier ones; C folds the
# arithmetic in the emitted expression).
fillConstVals: function {program: Node symtab: zenv.ZSymbolTable ctx: Ctx} is {
    match (
        program
    ) case program then {
        uCnt9d: program.ast.units.length
        uIdx9d: u64
        for uIdx9d < uCnt9d loop {
            uId9: program.ast.units.get i: uIdx9d
            uIdx9d = uIdx9d + 1
            opId9: u32
            un9: String
            {
                u: program.ast.nodes.get i: (uId9 - 1).u64
                if u.namedoperation then {
                    un: zast.poolTextCopy pool: program.ast.names ref: u.name
                    if (isEmittableFileUnit name: un.stringview) then {
                        opId9 = u.operation
                        un9 = un.copy
                    }
                }
            }
            if opId9 > 0 then {
                sm9: ctx.mainName.copy
                ctxBindMain :ctx name: un9.stringview
                (fillConstValsIn
                    :symtab
                    :ctx
                    ast: program.ast
                    mainOpId: opId9
                )
                ctxBindMain :ctx name: sm9.stringview
            }
        }
    } else null
}

fillConstValsIn: function {
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    ast: Ast
    mainOpId: u32
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: mainOpId
    with biter: bodyIds9.iterate do for bm: biter loop {
        bmNode9: ast.nodes.get i: (bm - 1).u64
        if bmNode9.namedoperation then {
            if (isConstShape :ast :ctx n: (ast.nodes.get i: (bmNode9.operation - 1).u64)) then {
                nm: zast.nameTextCopy :ast ref: bmNode9.name
                cv: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (bmNode9.operation - 1).u64)
                nmv: nm.stringview
                nk: nmv.string
                cvv: cv.stringview
                ck: cvv.string
                ctx.constVals.set key: nk value: ck
            }
        }
    }
}

# emitFns -- the main unit's function declarations then definitions
# (two-phase index walk so the body list is free during emission).
# isEmittableFileUnit -- a user FILE unit (main or a dependency) whose defs are
# emitted as zerolang C; system library units (their types ride the registry
# sweeps, their fns are native fragments) are skipped.
isEmittableFileUnit: function {name: StringView} out bool is {
    if name == "system" then return false
    if name == "core" then return false
    if name == "collections" then return false
    if name == "io" then return false
    if name == "os" then return false
    if name == "cli" then return false
    return true
}

# isEmittableUnitFns -- every file unit's bodied FREE functions emit,
# including the runtime-backed stdlib units (their TYPES stay excluded
# via isEmittableFileUnit; the per-member body filter in emitFnsIn keeps
# native declarations and type members out).
isEmittableUnitFns: function {name: StringView} out bool is {
    if name.length == 0 then return false
    return true
}

# stdFnUndemanded -- a bodied free fn in a runtime-backed stdlib unit that
# the program never referenced: its def was not resolved (no composed key),
# so its body carries no stamps -- skip it everywhere (definition, needs
# pre-scan, literal pooling). Emittable user/dep units always emit.
stdFnUndemanded: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    unitName: StringView
    fnName: StringView
} out bool is {
    if (isEmittableFileUnit name: unitName) then return false
    k9: "\{unitName}.\{fnName}"
    ro9: ztypecheck.resolvedByKey :ast ty: symtab.typing reg: symtab.reg key: k9
    match (
        ro9
    ) case some then {
        return false
    } case none then {
        return true
    }
}

# isGenericTemplateUnitOp -- a file unit that is a generic template (declares a
# bare `t: Any.generic` member). Its raw functions reference the unbound type
# param, so they are not emitted directly; emitUnitMonoInstances emits one
# concrete C function per (instantiation, method) instead.
isGenericTemplateUnitOp: function {ast: Ast opId: u32} out bool is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: opId
    mit9: bodyIds9.iterate
    for m9: mit9 loop {
        m9Node9: ast.nodes.get i: (m9 - 1).u64
        if m9Node9.namedoperation then {
            if (ztypecheck.isGenericParam
                :ast
                op: (ast.nodes.get i: (m9Node9.operation - 1).u64)
            ) then return true
        }
    }
    return false
}

# emitUnitMonoInstances -- emit the monomorphized methods of a generic file unit
# (genmath instantiated as intmath: i64, i32math: i32). For each registry UNIT
# type whose generic origin is this template, emit one C function per template
# method keyed by the mono's concrete FUNCTION child id (so the signature carries
# the substituted types); the body AST is the template method itself (lock-safe:
# its root is the program AST, not symtab, so emitFnBody can borrow symtab).
emitUnitMonoInstances: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    templateName: StringView
    templateUnitOpId: u32
    declOnly: bool
    buf: String.borrow
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: templateUnitOpId
    tplId9: u64
    tk9: templateName.string
    tgo9: symtab.reg.unitNameTid.get key: tk9
    match (
        tgo9
    ) case some then {
        tplId9 = tgo9
    } case none then null
    if tplId9 == 0 then {
        sgo9: u64
        rid9: u32
        {
            tuo9: ast.nodes.get i: (templateUnitOpId - 1).u64
            if tuo9.unitdef then rid9 = tuo9.nodeid
        }
        if rid9 > 0 then sgo9 = stampIdOf :symtab nid: rid9.u64
        if sgo9 > 0 then tplId9 = sgo9
    }
    if tplId9 == 0 then return
    last9: symtab.reg.nextTypeId
    t9: u64
    for t9 < last9 loop {
        isMono9: false
        if (symtab.reg.typetypeOf typeId: t9) == ztypes.ztypetype.unitType then {
            go9opt: (optionval.none u64)
            {
                to9: symtab.reg.typeById.get key: t9
                match (
                    to9
                ) case some then {
                    go9opt = to9.genericOriginId
                } case none then null
            }
            match (
                go9opt
            ) case some then {
                if go9opt == tplId9 then isMono9 = true
            } case none then null
        }
        if isMono9 then {
            {
                fit9: bodyIds9.iterate
                for fm9: fit9 loop {
                    fm9Node9: ast.nodes.get i: (fm9 - 1).u64
                    match (
                        fm9Node9
                    ) case namedoperation then {
                        if (isFunctionDefWithBody9 n: (ast.nodes.get i: (fm9Node9.operation - 1).u64)) then {
                            mname9: zast.nameTextCopy :ast ref: fm9Node9.name
                            cfo9: (symtab.typing.childOf
                                pool: ast.names
                                parentTypeId: t9
                                name: mname9.stringview
                            )
                            match (
                                cfo9
                            ) case some then {
                                cfid9: cfo9
                                if (symtab.reg.typetypeOf typeId: cfid9) == ztypes.ztypetype.functionType then {
                                    fnm9: typeNameOfReg9 :symtab tid: cfid9
                                    sig9: (fnSignature
                                        :ast
                                        :symtab
                                        :ctx
                                        name: fnm9.stringview
                                        fid: cfid9
                                        op: (ast.nodes.get i: (fm9Node9.operation - 1).u64)
                                    )
                                    if declOnly then {
                                        ld9: "\{sig9};\n"
                                        buf.append ld9.stringview
                                    } else {
                                        lo9: "\{sig9} {\n"
                                        buf.append lo9.stringview
                                        ctx.ptrVars = (List String)
                                        ctx.aliases = (List NameVal)
                                        ctx.narrowBox = (List NameVal)
                                        registerReftypeParams :ast :symtab :ctx fid: cfid9
                                        ctx.curThisTid = t9
                                        (emitFnBody
                                            :ast
                                            :symtab
                                            :ctx
                                            op: (ast.nodes.get i: (fm9Node9.operation - 1).u64)
                                            fid: cfid9
                                            :buf
                                        )
                                        ctx.curThisTid = 0
                                        buf.append "}\n\n"
                                    }
                                }
                            } case none then null
                        }
                    } else null
                }
            }
        }
        t9 = t9 + 1
    }
}

# emitFnsPass -- one declOnly-parameterized sweep over every emittable file
# unit, routing generic template units to their mono instances and plain units
# to emitFnsIn. ctx.mainName is rebound to each unit for the duration.
emitFnsPass: function {
    program: Node
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    declOnly: bool
    buf: String.borrow
} is {
    match (
        program
    ) case program then {
        uCnt9e: program.ast.units.length
        uIdx9e: u64
        for uIdx9e < uCnt9e loop {
            uId9: program.ast.units.get i: uIdx9e
            uIdx9e = uIdx9e + 1
            opId9: u32
            un9: String
            {
                u: program.ast.nodes.get i: (uId9 - 1).u64
                if u.namedoperation then {
                    un: zast.poolTextCopy pool: program.ast.names ref: u.name
                    if (isEmittableUnitFns name: un.stringview) then {
                        opId9 = u.operation
                        un9 = un.copy
                    }
                }
            }
            if opId9 > 0 then {
                sm: ctx.mainName.copy
                ctxBindMain :ctx name: un9.stringview
                isTpl9: isGenericTemplateUnitOp ast: program.ast opId: opId9
                if isTpl9 then {
                    (emitUnitMonoInstances
                        :symtab
                        ast: program.ast
                        :ctx
                        templateName: un9.stringview
                        templateUnitOpId: opId9
                        :declOnly
                        :buf
                    )
                } else {
                    (emitFnsIn
                        :symtab
                        :ctx
                        ast: program.ast
                        mainOpId: opId9
                        :declOnly
                        :buf
                    )
                }
                ctxBindMain :ctx name: sm.stringview
            }
        }
    } else null
}

emitFns: function {program: Node symtab: zenv.ZSymbolTable ctx: Ctx buf: String.borrow} is {
    # every file unit's fn DECLARATIONS first, then every file unit's
    # DEFINITIONS -- a main-unit body may call a dep-unit fn declared
    # earlier (and vice versa).
    emitFnsPass :program :symtab :ctx declOnly: true :buf
    emitFnsPass :program :symtab :ctx declOnly: false :buf
}

# emitFnMonoInstances -- emit the monomorphized instances of a generic free
# function (identity_i64, identity_f64, first_i64_f64, ...). Each instance was
# minted by the typechecker (mintMono, params already substituted); emit one C
# function per registry FUNCTION whose generic origin is this template, keyed by
# the mono FUNCTION id (concrete signature) with the template body AST (lock-safe:
# the body AST root is the program, not symtab).
emitFnMonoInstances: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    templateFnId: u64
    templateFnOp: Node
    declOnly: bool
    buf: String.borrow
} is {
    last9: symtab.reg.nextTypeId
    t9: u64
    for t9 < last9 loop {
        isMono9: false
        if (symtab.reg.typetypeOf typeId: t9) == ztypes.ztypetype.functionType then {
            go9opt: (optionval.none u64)
            {
                to9: symtab.reg.typeById.get key: t9
                match (
                    to9
                ) case some then {
                    go9opt = to9.genericOriginId
                } case none then null
            }
            match (
                go9opt
            ) case some then {
                if go9opt == templateFnId then isMono9 = true
            } case none then null
        }
        if isMono9 then {
            fnm9: typeNameOfReg9 :symtab tid: t9
            sig9: fnSignature :ast :symtab :ctx name: fnm9.stringview fid: t9 op: templateFnOp
            if declOnly then {
                ld9: "\{sig9};\n"
                buf.append ld9.stringview
            } else {
                lo9: "\{sig9} {\n"
                buf.append lo9.stringview
                ctx.ptrVars = (List String)
                ctx.aliases = (List NameVal)
                ctx.narrowBox = (List NameVal)
                registerReftypeParams :ast :symtab :ctx fid: t9
                ctx.curThisTid = t9
                emitFnBody :ast :symtab :ctx op: templateFnOp fid: t9 :buf
                ctx.curThisTid = 0
                buf.append "}\n\n"
            }
        }
        t9 = t9 + 1
    }
}

emitFnsIn: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    mainOpId: u32
    declOnly: bool
    buf: String.borrow
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: mainOpId
    {
        with iuit9: bodyIds9.iterate do for ium9Id9: iuit9 loop {
            ium9: ast.nodes.get i: (ium9Id9 - 1).u64
            if ium9.namedoperation then {
                iuOpId9: ium9.operation
                if (isGenericTemplateUnitOp :ast opId: iuOpId9) then {
                    iunm9: zast.nameTextCopy :ast ref: ium9.name
                    (emitUnitMonoInstances
                        :symtab
                        :ast
                        :ctx
                        templateName: iunm9.stringview
                        templateUnitOpId: iuOpId9
                        :declOnly
                        :buf
                    )
                }
            }
        }
        idxs: (List u64)
        names: (List String)
        di: u64
        with biter: bodyIds9.iterate do for bmId9: biter loop {
            bm: ast.nodes.get i: (bmId9 - 1).u64
            match (
                bm
            ) case namedoperation then {
                if (isFunctionDefWithBody9 n: (ast.nodes.get i: (bm.operation - 1).u64)) then {
                    nm: zast.nameTextCopy :ast ref: bm.name
                    skipDepMain: false
                    # a runtime-backed unit's bodied fn only emits when the
                    # program referenced it (undemanded bodies carry no stamps)
                    if (stdFnUndemanded
                        :ast
                        :symtab
                        unitName: ctx.mainName.stringview
                        fnName: nm.stringview
                    ) then skipDepMain = true
                    if nm.stringview == "main" then {
                        if ctx.mainName.stringview != ctx.realMain.stringview then {
                            skipDepMain = true
                        }
                    }
                    if (skipDepMain) == false then {
                        dv: di
                        idxs.append dv
                        names.append nm
                    }
                }
            } else null
            di = di + 1
        }
        wn: idxs.length
        wi: u64
        for wi < wn loop {
            nm2: names.get i: wi
            didx: idxs.get i: wi
            dm2Id9: bodyIds9.get i: didx
            dm2: ast.nodes.get i: (dm2Id9 - 1).u64
            match (
                dm2
            ) case namedoperation then {
                fid: userFnId :ast :symtab :ctx name: nm2.stringview
                isGenFn9: false
                if fid > 0 then {
                    if (isGenericType :symtab tid: fid) then {
                        if (symtab.reg.typetypeOf typeId: fid) == ztypes.ztypetype.functionType then {
                            isGenFn9 = true
                        }
                    }
                }
                if isGenFn9 then {
                    (emitFnMonoInstances
                        :ast
                        :symtab
                        :ctx
                        templateFnId: fid
                        templateFnOp: (ast.nodes.get i: (dm2.operation - 1).u64)
                        :declOnly
                        :buf
                    )
                } else {
                    sig: (fnSignature
                        :ast
                        :symtab
                        :ctx
                        name: nm2.stringview
                        :fid
                        op: (ast.nodes.get i: (dm2.operation - 1).u64)
                    )
                    if declOnly then {
                        ld: "\{sig};\n"
                        buf.append ld.stringview
                    } else {
                        lo: "\{sig} {\n"
                        buf.append lo.stringview
                        ctx.ptrVars = (List String)
                        ctx.aliases = (List NameVal)
                        ctx.narrowBox = (List NameVal)
                        registerReftypeParams :ast :symtab :ctx :fid
                        (emitFnBody
                            :ast
                            :symtab
                            :ctx
                            op: (ast.nodes.get i: (dm2.operation - 1).u64)
                            :fid
                            :buf
                        )
                        buf.append "}\n\n"
                    }
                }
            } else null
            wi = wi + 1
        }
        if declOnly then buf.append "\n"
    }
}

isFunctionDefWithBody9: function {n: Node} out bool is {
    match (
        n
    ) case functiondef then {
        return n.body > 0
    } else {
        return false
    }
}

# strHasSub -- substring containment with a dynamic needle, routed through a
# StringView receiver: the emitter resolves .contains on a param, not on a
# for-loop iterate element used directly as a method-call receiver.
strHasSub: function {hay: StringView needle: StringView} out bool is {
    return (hay.contains :needle)
}

# isBareCName -- true if s is a plain C identifier (only [A-Za-z0-9_]); such a
# return value is a bare local whose scope cleanup can safely run before the
# return. A compound expression (call / deref / field / cast) must be hoisted
# into a temp first, handled separately.
isBareCName: function {s: StringView} out bool is {
    if s.length == 0 then return false
    i: u64
    for i < s.length loop {
        bo: s.byteAt i
        match (
            bo
        ) case some then {
            ok: false
            if bo >= 48 when bo <= 57 then ok = true
            if bo >= 65 when bo <= 90 then ok = true
            if bo >= 97 when bo <= 122 then ok = true
            if bo == 95 then ok = true
            if (ok) == false then return false
        } case none then {
            return false
        }
        i = i + 1
    }
    return true
}

# optU8Or -- an (optionval u8) to a plain u8 with a default.
optU8Or: function {o: optionval u8 d: u8} out u8 is {
    match (
        o
    ) case some then {
        return o
    } case none then {
        return d
    }
}

# ctEndsWithStar -- true if the C type string ends in '*' (a pointer return:
# union, protocol, Map/Set, or a user reftype passed by reference). Takes a `ct`
# param so `.length`/`.byteAt` emit as field/method ops (a chained `.stringview`
# receiver mis-emits a free function call).
ctEndsWithStar: function {ct: StringView} out bool is {
    if ct.length == 0 then return false
    lb: optU8Or o: (ct.byteAt (ct.length - 1)) d: 0
    if lb == 42 then return true
    return false
}

# isIdChar -- a C-identifier byte [A-Za-z0-9_].
isIdChar: function {b: u8} out bool is {
    if b >= 48 when b <= 57 then return true
    if b >= 65 when b <= 90 then return true
    if b >= 97 when b <= 122 then return true
    if b == 95 then return true
    return false
}

# refsLocal -- true if `name` occurs in `expr` as a maximal C identifier (bounded
# by non-identifier bytes). A local referenced in the return expression is part of
# (or borrowed by) the return value, so it must NOT be freed before the return.
refsLocal: function {expr: StringView name: StringView} out bool is {
    nl: name.length
    el: expr.length
    if nl == 0 then return false
    if nl > el then return false
    i: u64
    for i + nl <= el loop {
        eq: true
        k: u64
        for k < nl loop {
            ebv: optU8Or o: (expr.byteAt (i + k)) d: 0
            nbv: optU8Or o: (name.byteAt k) d: 1
            if ebv != nbv then eq = false
            k = k + 1
        }
        if eq then {
            beforeOk: true
            if i > 0 then {
                if (isIdChar b: (optU8Or o: (expr.byteAt (i - 1)) d: 0)) then beforeOk = false
            }
            afterOk: true
            ep: i + nl
            if ep < el then {
                if (isIdChar b: (optU8Or o: (expr.byteAt ep) d: 0)) then afterOk = false
            }
            if beforeOk when afterOk then return true
        }
        i = i + 1
    }
    return false
}

# isRegisteredOwned -- true if `name` is a registered owned local (a String in
# tmp.frees or a collection/class in tmp.listFreeVars). Decides whether a value
# moved into an inline construction must be zeroed so its scope-cleanup destructor
# becomes a no-op.
isRegisteredOwned: function {tmp: TmpCtr name: StringView} out bool is {
    fit: tmp.frees.iterate
    for fv: fit loop {
        if fv.stringview == name then return true
    }
    vit: tmp.listFreeVars.iterate
    for vv: vit loop {
        if vv.stringview == name then return true
    }
    return false
}

# emitReturnCleanup -- free the registered owned locals (tmp.frees + tmp.listFrees)
# BEFORE a return, reclaiming them on the diverging path the function-end flush
# never reaches. Does NOT pop (other returns + the end flush still need them).
# Skips any local REFERENCED in the return expression `retExpr` (it is part of, or
# borrowed by, the return value) and any non-owning alias (`ctx.aliases`). A
# match-arm-narrowed subject is NOT skipped -- the arm aliases it via narrowBox (no
# shadow), so it stays a normal owned local whose destructor is correctly typed here.
emitReturnCleanup: function {
    ctx: Ctx
    tmp: TmpCtr
    retExpr: StringView
    keepRefd: bool
    ind: StringView
    buf: String.borrow
} is {
    fiterR: tmp.frees.iterate
    for fvR: fiterR loop {
        keepF: true
        if keepRefd then {
            if (refsLocal expr: retExpr name: fvR.stringview) then keepF = false
        }
        if (nvHas xs: ctx.aliases name: fvR.stringview) then keepF = false
        if keepF then {
            lfR: "\{ind}\{ctx.strC}_free(&\{fvR});\n"
            buf.append lfR.stringview
        }
    }
    li9: u64
    nL9: tmp.listFrees.length
    for li9 < nL9 loop {
        stmt9: tmp.listFrees.get i: li9
        var9: tmp.listFreeVars.get i: li9
        keepL: true
        if keepRefd then {
            if (refsLocal expr: retExpr name: var9.stringview) then keepL = false
        }
        if (nvHas xs: ctx.aliases name: var9.stringview) then keepL = false
        if keepL then buf.append stmt9.stringview
        li9 = li9 + 1
    }
    # a return exits every enclosing loop: emit each owned-payload loop's
    # per-iteration cleanup (empty for plain loops and do entries), unless
    # the payload is part of the return value or a non-owning alias.
    ci9: u64
    cn9: ctx.breakLabelCleanup.length
    for ci9 < cn9 loop {
        ccl0: ctx.breakLabelCleanup.get i: ci9
        ccv0: ctx.breakLabelCleanupVar.get i: ci9
        if ccl0.length > 0 then {
            keepC: true
            if keepRefd then {
                if (refsLocal expr: retExpr name: ccv0.stringview) then keepC = false
            }
            if (nvHas xs: ctx.aliases name: ccv0.stringview) then keepC = false
            if keepC then {
                lcr9: "\{ind}\{ccl0}"
                buf.append lcr9.stringview
            }
        }
        ci9 = ci9 + 1
    }
}

emitFnBody: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    op: Node
    fid: u64
    buf: String.borrow
} is {
    match (
        op
    ) case functiondef then {
        tmp: (TmpCtr n: 0 frees: (List String) listFrees: (List String) listFreeVars: (List String))
        pnames9: (List String)
        pids9: (List u64)
        pids9Nm: (List u64)
        recFieldLists :ast :symtab tid: fid names: pnames9 ids: pids9 nameIds: pids9Nm
        pj9: u64
        pn9: pnames9.length
        for pj9 < pn9 loop {
            ppn9: pnames9.get i: pj9
            ppid9: pids9.get i: pj9
            if (symtab.typing.childOwnershipIs
                pool: ast.names
                parentTypeId: fid
                name: ppn9.stringview
                own: ztypes.zparamownership.takeMode
            ) then {
                ptnm9: typeNameOfReg9 :symtab tid: ppid9
                pmn9: ztypes.mangleVarName name: ppn9.stringview
                if ppid9 == ctx.strTid then {
                    pms9: pmn9.copy
                    tmp.frees.append pms9
                } else {
                    # owned .take Set/Map params are skipped: declared by value, but a
                    # Set/Map _destroy frees the container as a heap pointer (would need
                    # &name); none exist in the self-host.
                    if (isHeapPtrCollection :ast :symtab :ctx tid: ppid9) == false then {
                        pcm9: chaseColMono :ast :symtab tid: ppid9
                        puse9: pcm9
                        if (symtab.reg.hasDestructorName typeId: pcm9) == false then {
                            prbn9: resolveTypeIdByName :ast :symtab :ctx name: ptnm9.stringview
                            if prbn9 > 0 then puse9 = prbn9
                        }
                        if (symtab.reg.hasDestructorName typeId: puse9) then {
                            pcb9: cnameOf tid: puse9 name: ptnm9.stringview
                            pdf9: "    \{pcb9}_destroy(&\{pmn9});\n"
                            pdfs9: pdf9.copy
                            tmp.listFrees.append pdfs9
                            tmp.listFreeVars.append pmn9.copy
                        }
                    }
                }
            }
            pj9 = pj9 + 1
        }
        if op.body > 0 then {
            opb9: ast.nodes.get i: (op.body - 1).u64
            rbnT9: (ztypecheck.fnReturnBaseNameOf
                :ast
                op: (ast.nodes.get i: (op.nodeid - 1).u64)
            )
            if rbnT9.length > 0 when ctx.genActive == false then ctx.tailRetActive = true
            emitBodyNode :ast :symtab :ctx n: opb9 ind: "    " :tmp :buf
            ctx.tailRetActive = false
        }
        fiter9: tmp.frees.iterate
        for fv: fiter9 loop {
            lf9: "    \{ctx.strC}_free(&\{fv});\n"
            buf.append lf9.stringview
        }
        lfi9: tmp.listFrees.iterate
        for lfs: lfi9 loop buf.append lfs.stringview
    } else null
}

# collectUnitLiterals -- pool the plain literals of every main-unit
# function body.
collectUnitLiterals: function {
    program: Node
    symtab: zenv.ZSymbolTable
    ids: List u64
    texts: List String
} is {
    match (
        program
    ) case program then {
        uCnt9f: program.ast.units.length
        uIdx9f: u64
        for uIdx9f < uCnt9f loop {
            uId9: program.ast.units.get i: uIdx9f
            uIdx9f = uIdx9f + 1
            opId9: u32
            un9: String
            {
                u: program.ast.nodes.get i: (uId9 - 1).u64
                if u.namedoperation then {
                    un: zast.poolTextCopy pool: program.ast.names ref: u.name
                    if (isEmittableUnitFns name: un.stringview) then {
                        opId9 = u.operation
                        un9 = un.copy
                    }
                }
            }
            if opId9 > 0 then {
                (collectUnitLiteralsIn
                    ast: program.ast
                    mainOpId: opId9
                    :symtab
                    unitName: un9.stringview
                    :ids
                    :texts
                )
            }
        }
    } else null
}

collectUnitLiteralsIn: function {
    ast: Ast
    mainOpId: u32
    symtab: zenv.ZSymbolTable
    unitName: StringView
    ids: List u64
    texts: List String
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: mainOpId
    biter: bodyIds9.iterate
    for bm: biter loop {
        bmNode9: ast.nodes.get i: (bm - 1).u64
        if bmNode9.namedoperation then {
            bn9: zast.nameTextCopy :ast ref: bmNode9.name
            skipU9: stdFnUndemanded :ast :symtab :unitName fnName: bn9.stringview
            if (skipU9) == false then (collectFnLiterals
                :ast
                n: (ast.nodes.get i: (bmNode9.operation - 1).u64)
                :ids
                :texts
            )
        }
    }
}

collectFnLiterals: function {ast: Ast n: Node ids: List u64 texts: List String} is {
    match (
        n
    ) case functiondef then {
        if n.body > 0 then collectLiterals :ast n: (ast.nodes.get i: (n.body - 1).u64) :ids :texts
    } case objectdef then {
        with iiter9: n.isItems.iterate do for imId9: iiter9 loop {
            im9: ast.nodes.get i: (imId9 - 1).u64
            match (
                im9
            ) case namedoperation then {
                collectFnLiterals :ast n: (ast.nodes.get i: (im9.operation - 1).u64) :ids :texts
            } else null
        }
        with aiter: n.asItems.iterate do for amId9: aiter loop {
            am: ast.nodes.get i: (amId9 - 1).u64
            match (
                am
            ) case namedoperation then {
                collectFnLiterals :ast n: (ast.nodes.get i: (am.operation - 1).u64) :ids :texts
            } else null
        }
    } case unitdef then {
        with ubiter9: n.body.iterate do for ubm9: ubiter9 loop {
            ubn9: ast.nodes.get i: (ubm9 - 1).u64
            match (
                ubn9
            ) case namedoperation then {
                collectFnLiterals :ast n: (ast.nodes.get i: (ubn9.operation - 1).u64) :ids :texts
            } else null
        }
    } else null
}

# emitC -- emit the C translation unit for a typechecked program.
emitC: function {
    program: Node
    symtab: zenv.ZSymbolTable
    runtimeDir: StringView
    fastHash: bool
    errs: List String
} out String is {
    buf: String
    buf.append "/* Generated by zerolang compiler */\n"
    buf.append "\n"
    buf.append "#define _POSIX_C_SOURCE 200809L\n"
    buf.append "#define _DEFAULT_SOURCE\n"
    buf.append "\n"
    buf.append "#include <stdio.h>\n"
    buf.append "#include <stdint.h>\n"
    buf.append "#include <stdlib.h>\n"
    buf.append "#include <stdbool.h>\n"
    buf.append "#include <string.h>\n"
    buf.append "#include <errno.h>\n"
    buf.append "#include <fcntl.h>\n"
    buf.append "#include <unistd.h>\n"
    buf.append "#include <sys/stat.h>\n"
    buf.append "#include <sys/types.h>\n"
    buf.append "#include <dirent.h>\n"
    buf.append "#include <pwd.h>\n"
    buf.append "#include <sys/wait.h>\n"
    buf.append "#include <signal.h>\n"
    buf.append "#include <sys/socket.h>\n"
    buf.append "#include <netinet/in.h>\n"
    buf.append "#include <arpa/inet.h>\n"
    buf.append "#include <poll.h>\n"
    buf.append "#include <sys/random.h>\n"
    buf.append "#include <sys/syscall.h>\n"
    buf.append "\n"
    buf.append "static _Noreturn void z_panic(const char* msg) {\n"
    buf.append "    fprintf(stderr, \"zpanic: %s\\n\", msg);\n"
    buf.append "    exit(1);\n"
    buf.append "}\n"
    buf.append "static _Noreturn void z_unreachable(void) { z_panic(\"unreachable\"); }\n"
    buf.append "static void* z_xmalloc(size_t n) {\n"
    buf.append "    void* p = malloc(n);\n"
    buf.append "    if (!p) z_panic(\"out of memory\");\n"
    buf.append "    return p;\n"
    buf.append "}\n"
    buf.append "static void* z_xcalloc(size_t count, size_t size) {\n"
    buf.append "    void* p = calloc(count, size);\n"
    buf.append "    if (!p) z_panic(\"out of memory\");\n"
    buf.append "    return p;\n"
    buf.append "}\n"
    buf.append "static void* z_xrealloc(void* p, size_t n) {\n"
    buf.append "    void* q = realloc(p, n);\n"
    buf.append "    if (!q) z_panic(\"out of memory\");\n"
    buf.append "    return q;\n"
    buf.append "}\n"
    buf.append "\n"
    strId: u64
    svId: u64
    k1: "system.String".string
    sgo: (optionval.none u64)
    match (
        program
    ) case program then {
        sgo = (ztypecheck.resolvedByKey
            ast: program.ast
            ty: symtab.typing
            reg: symtab.reg
            key: k1
        )
    } else null
    match (
        sgo
    ) case some then {
        strId = sgo
    } case none then null
    k2: "system.StringView".string
    vgo: (optionval.none u64)
    match (
        program
    ) case program then {
        vgo = (ztypecheck.resolvedByKey
            ast: program.ast
            ty: symtab.typing
            reg: symtab.reg
            key: k2
        )
    } else null
    match (
        vgo
    ) case some then {
        svId = vgo
    } case none then null
    strC: cnameOf tid: strId name: "String"
    svC: cnameOf tid: svId name: "StringView"
    strOriginTid: u64
    arrayOriginTid: u64
    listOriginTid: u64
    listViewOriginTid: u64
    mapOriginTid: u64
    setOriginTid: u64
    mapEntryOriginTid: u64
    listIterOriginTid: u64
    setIterOriginTid: u64
    mapKeyIterOriginTid: u64
    mapItemIterOriginTid: u64
    optionOriginTid: u64
    optionViewOriginTid: u64
    resultOriginTid: u64
    optionvalOriginTid: u64
    resultvalOriginTid: u64
    match (
        program
    ) case program then {
        strOriginTid = builtinTid ast: program.ast :symtab base: "str"
        arrayOriginTid = builtinTid ast: program.ast :symtab base: "array"
        listOriginTid = builtinTid ast: program.ast :symtab base: "List"
        listViewOriginTid = builtinTid ast: program.ast :symtab base: "ListView"
        mapOriginTid = builtinTid ast: program.ast :symtab base: "Map"
        setOriginTid = builtinTid ast: program.ast :symtab base: "Set"
        mapEntryOriginTid = builtinTid ast: program.ast :symtab base: "MapEntry"
        listIterOriginTid = builtinTid ast: program.ast :symtab base: "ListIter"
        setIterOriginTid = builtinTid ast: program.ast :symtab base: "SetIter"
        mapKeyIterOriginTid = builtinTid ast: program.ast :symtab base: "MapKeyIter"
        mapItemIterOriginTid = builtinTid ast: program.ast :symtab base: "MapItemIter"
        optionOriginTid = builtinTid ast: program.ast :symtab base: "Option"
        optionViewOriginTid = builtinTid ast: program.ast :symtab base: "OptionView"
        resultOriginTid = builtinTid ast: program.ast :symtab base: "Result"
        optionvalOriginTid = builtinTid ast: program.ast :symtab base: "optionval"
        resultvalOriginTid = builtinTid ast: program.ast :symtab base: "resultval"
    } else null
    p1: "\{runtimeDir}/z_String.inc"
    f1: loadFragment path: p1.stringview svC: svC.stringview strC: strC.stringview
    buf.append f1.stringview
    buf.append "\n"
    # a String-typedef class (Path) shares the String struct: alias its
    # registered destructor to the String free so every generic destroy
    # site links (unused wrappers are fine: -Wno-unused-function)
    with sdit9: symtab.typing.typedefBaseMangled.iterateItems do for sde9: sdit9 loop {
        if sde9.value.stringview == "String" then {
            if (symtab.reg.hasDestructorName typeId: sde9.key) then {
                sdc9: symtab.reg.cnameOf tid: sde9.key
                sdw9: "static void \{sdc9}_destroy(\{strC}_t* p) { \{strC}_free(p); }\n"
                buf.append sdw9.stringview
            }
        }
    }
    p2: "\{runtimeDir}/z_StringView.inc"
    f2: loadFragment path: p2.stringview svC: svC.stringview strC: strC.stringview
    buf.append f2.stringview
    buf.append "\n"
    ph: "\{runtimeDir}/z_hash.inc"
    fh: loadFragment path: ph.stringview svC: svC.stringview strC: strC.stringview
    buf.append fh.stringview
    buf.append "\n"
    mn: mainNameOf9 :program
    litIds: (List u64)
    litTexts: (List String)
    collectUnitLiterals :program :symtab ids: litIds texts: litTexts
    rm: mn.copy
    ctx: (Ctx
        mainName: mn
        realMain: rm
        :fastHash
        :strC
        :svC
        :litIds
        usedLits: (Map u64 value: bool)
        constVals: (Map String value: String)
        tailRetActive: false
        defUnitId: (Map u64 value: u64)
        unitIdByName: (Map String value: u64)
        unitTidsC: (List u64)
        unitKeysC: (List String)
        unitCacheBuilt: false
        unitIdCtr: 0
        mainUnitId: 0
        condDepth: 0
        emitErrors: (List String)
        needs: (Map String value: bool)
        methodReturns: (Map String value: String)
        dataElems: (Map String value: String)
        dataConst: (Map String value: String)
        ptrVars: (List String)
        aliases: (List NameVal)
        narrowBox: (List NameVal)
        narrowTid: (List NameTid)
        exclArms: (List NameVal)
        exclTids: (List NameTid)
        genActive: false
        genYieldCount: 0
        genYieldNext: 0
        genWrap: "".string
        genSomeTag: "".string
        genNoneTag: "".string
        genPayC: "".string
        genHasValue: false
        curThisTid: 0
        emittedUserTypes: (Map u64 value: bool)
        fwdDeclaredTypes: (Map u64 value: bool)
        tmplCache: (Map String value: String)
        argHoistNames: (List String)
        argHoistVals: (List String)
        argHoistTypes: (List String)
        argHoistDtors: (List String)
        argHoistRaw: (List String)
        argHoistCtr: 0
        breakLabels: (List u64)
        breakLabelIsDo: (List bool)
        contLabelUsed: (Map u64 value: bool)
        breakLabelCtr: 0
        breakLabelUsed: (Map u64 value: bool)
        breakFreesMarks: (List u64)
        breakListMarks: (List u64)
        breakLabelCleanup: (List String)
        breakLabelCleanupVar: (List String)
        borrowedVars: (Map String value: bool)
        strTid: strId
        svTid: svId
        :strOriginTid
        :arrayOriginTid
        :listOriginTid
        :listViewOriginTid
        :mapOriginTid
        :setOriginTid
        :mapEntryOriginTid
        :listIterOriginTid
        :setIterOriginTid
        :mapKeyIterOriginTid
        :mapItemIterOriginTid
        :optionOriginTid
        :optionViewOriginTid
        :resultOriginTid
        :optionvalOriginTid
        :resultvalOriginTid
    )
    buildDefUnitIndex :symtab :ctx
    ctxBindMain :ctx name: ctx.realMain.stringview
    fillConstVals :program :symtab :ctx
    fillMethodReturns :program :symtab :ctx
    fillDataElems :program :symtab :ctx
    fillNeeds :program :ctx
    nodeEstE9: u64
    match (
        program
    ) case program then {
        nodeEstE9 = program.ast.nodes.length
    } else null
    fnsBuf: String
    fnsBuf.reserve n: nodeEstE9 * 24
    emitFns :program :symtab :ctx buf: fnsBuf
    hasMain: programHasMain :program
    if (hasMain) == false then {
        fnsBuf.append "void z_main(void) {\n"
        fnsBuf.append "}\n\n"
    }
    # emit all _zsN-referencing code into codeBuf first (each reference marks
    # ctx.usedLits via litIndexOf), then write the literal pool with only the
    # referenced entries so unused literals never reach the output. The pool must
    # still precede the code in the file, so it is prepended below.
    codeBuf: String
    codeBuf.reserve n: nodeEstE9 * 8
    match (
        program
    ) case program then {
        emitMonos ast: program.ast :symtab :ctx :runtimeDir buf: codeBuf
        emitRuntimeSvIter ast: program.ast :symtab :ctx :runtimeDir buf: codeBuf
        emitNeededNatives ast: program.ast :symtab :ctx :runtimeDir buf: codeBuf
        if (ioFileLive ast: program.ast :symtab :ctx) then {
            needsAdd :ctx name: "io"
            needsAdd :ctx name: "io_file_close"
            needsAdd :ctx name: "io_file_read"
            needsAdd :ctx name: "io_file_write"
            needsAdd :ctx name: "io_file_seek"
            needsAdd :ctx name: "io_file_flush"
        }
        emitRuntimeIo ast: program.ast :symtab :ctx :runtimeDir buf: codeBuf
        emitIoFileConformance ast: program.ast :symtab :ctx buf: codeBuf
        emitIoStdStreams ast: program.ast :symtab :ctx buf: codeBuf
        emitRuntimeCli ast: program.ast :symtab :ctx :runtimeDir buf: codeBuf
        emitRuntimeOs ast: program.ast :symtab :ctx :runtimeDir buf: codeBuf
        emitRuntimeNet ast: program.ast :symtab :ctx :runtimeDir buf: codeBuf
    } else null
    match (
        program
    ) case program then {
        emitFnptrTypedefs ast: program.ast :symtab :ctx buf: codeBuf
        emitUserStructsOrdered ast: program.ast :symtab :ctx :runtimeDir buf: codeBuf
    } else null
    emitRecordDefs :program :symtab :ctx buf: codeBuf
    poolBuf: String
    pi9: u64
    pn9: ctx.litIds.length
    for pi9 < pn9 loop {
        plid9: ctx.litIds.get i: pi9
        puo9: ctx.usedLits.get key: plid9
        match (
            puo9
        ) case some then {
            pt9: litTexts.get i: pi9
            ptv9: pt9.stringview
            pesc9: cEscape text: ptv9
            pblen9: ptv9.length
            pidx9: pi9 + 1
            pl19: "static const char _zs\{pidx9}_d[] = \"\{pesc9}\";\n"
            poolBuf.append pl19.stringview
            pl29: "static const \{ctx.svC}_t _zs\{pidx9} = { _zs\{pidx9}_d, \{pblen9} };\n"
            poolBuf.append pl29.stringview
        } case none then null
        pi9 = pi9 + 1
    }
    buf.reserve n: poolBuf.length + codeBuf.length + fnsBuf.length + 4096
    buf.append poolBuf.stringview
    buf.append "\n"
    buf.append codeBuf.stringview
    buf.append fnsBuf.stringview
    buf.append "int main(int argc, char* argv[]) {\n"
    if (needsHas :ctx name: "os_args") then {
        buf.append "    z_os_argc_g = argc;\n"
        buf.append "    z_os_argv_g = argv;\n"
    }
    buf.append "    z_siphash_init();\n"
    buf.append "    z_main();\n"
    buf.append "    return 0;\n"
    buf.append "}\n"
    with eeit: ctx.emitErrors.iterate do for ee: eeit loop errs.append from: ee.copy
    return buf
}

programHasMain: function {program: Node} out bool is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        uCnt9g: program.ast.units.length
        uIdx9g: u64
        for uIdx9g < uCnt9g loop {
            uId9: program.ast.units.get i: uIdx9g
            uIdx9g = uIdx9g + 1
            opId9: u32
            {
                u: program.ast.nodes.get i: (uId9 - 1).u64
                if u.namedoperation then {
                    un: zast.poolTextCopy pool: program.ast.names ref: u.name
                    if un.stringview == mainName then opId9 = u.operation
                }
            }
            if opId9 > 0 then {
                if (unitHasMain9 ast: program.ast mainOpId: opId9) then return true
            }
        }
        return false
    } else {
        return false
    }
}

unitHasMain9: function {ast: Ast mainOpId: u32} out bool is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: mainOpId
    biter: bodyIds9.iterate
    for bm: biter loop {
        bmNode9: ast.nodes.get i: (bm - 1).u64
        if bmNode9.namedoperation then {
            bn: zast.nameTextCopy :ast ref: bmNode9.name
            if bn.stringview == "main" then return true
        }
    }
    return false
}

# emitNeededNatives -- the gated native fragments for the needs the body
# walk collected, in the reference's emission order.
emitNeededNatives: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    buf: String.borrow
} is {
    emitNativeIf :ctx need: "isEmpty" frag: "_Z_SV_IS_EMPTY" :runtimeDir :buf
    emitNativeIf :ctx need: "isAscii" frag: "_Z_SV_IS_ASCII" :runtimeDir :buf
    emitNativeIf :ctx need: "startsWith" frag: "_Z_SV_STARTS_WITH" :runtimeDir :buf
    emitNativeIf :ctx need: "endsWith" frag: "_Z_SV_ENDS_WITH" :runtimeDir :buf
    needRaw: needsHas :ctx name: "contains"
    if (needsHas :ctx name: "indexOf") then needRaw = true
    if (needsHas :ctx name: "lastIndexOf") then needRaw = true
    if needRaw then (emitMonoNative
        :ast
        :symtab
        :ctx
        :runtimeDir
        frag: "_Z_SV_INDEX_OF_RAW"
        mono: ""
        :buf
    )
    emitNativeIf :ctx need: "contains" frag: "_Z_SV_CONTAINS" :runtimeDir :buf
    hasTrim: needsHas :ctx name: "trim"
    hasTrimS: needsHas :ctx name: "trimStart"
    hasTrimE: needsHas :ctx name: "trimEnd"
    anyTrim: hasTrim
    if hasTrimS then anyTrim = true
    if hasTrimE then anyTrim = true
    if anyTrim then {
        p0: nativePath :runtimeDir frag: "_Z_SV_IS_ASCII_WS"
        sc0: ctx.svC.copy
        tc0: ctx.strC.copy
        f0: loadFragment path: p0.stringview svC: sc0.stringview strC: tc0.stringview
        buf.append f0.stringview
    }
    emitNativeIf :ctx need: "substring" frag: "_Z_SV_SUBSTRING" :runtimeDir :buf
    emitNativeIf :ctx need: "hash" frag: "_Z_SV_HASH" :runtimeDir :buf
    emitNativeIf :ctx need: "trim" frag: "_Z_SV_TRIM" :runtimeDir :buf
    emitNativeIf :ctx need: "trimStart" frag: "_Z_SV_TRIM_START" :runtimeDir :buf
    emitNativeIf :ctx need: "trimEnd" frag: "_Z_SV_TRIM_END" :runtimeDir :buf
    emitNativeIf :ctx need: "toLowerAscii" frag: "_Z_SV_TO_LOWER_ASCII" :runtimeDir :buf
    hasRep: needsHas :ctx name: "replace"
    hasRepF: needsHas :ctx name: "replaceFirst"
    anyRep: hasRep
    if hasRepF then anyRep = true
    if anyRep then {
        pR: nativePath :runtimeDir frag: "_Z_SV_REPLACE_IMPL"
        scR: ctx.svC.copy
        tcR: ctx.strC.copy
        fR: loadFragment path: pR.stringview svC: scR.stringview strC: tcR.stringview
        buf.append fR.stringview
    }
    emitNativeIf :ctx need: "replace" frag: "_Z_SV_REPLACE" :runtimeDir :buf
    emitNativeIf :ctx need: "replaceFirst" frag: "_Z_SV_REPLACE_FIRST" :runtimeDir :buf
    emitNativeIf :ctx need: "repeated" frag: "_Z_SV_REPEAT" :runtimeDir :buf
    emitNativeIf :ctx need: "concat" frag: "_Z_SV_CONCAT" :runtimeDir :buf
    emitNativeIf :ctx need: "toUpperAscii" frag: "_Z_SV_TO_UPPER_ASCII" :runtimeDir :buf
    hasCount: needsHas :ctx name: "count"
    hasCp: needsHas :ctx name: "codepoints"
    anyUtf8: hasCount
    if hasCp then anyUtf8 = true
    if anyUtf8 then {
        pu: nativePath :runtimeDir frag: "_Z_SV_UTF8_DECODE"
        scu: ctx.svC.copy
        tcu: ctx.strC.copy
        fu: loadFragment path: pu.stringview svC: scu.stringview strC: tcu.stringview
        buf.append fu.stringview
    }
    emitNativeIf :ctx need: "count" frag: "_Z_SV_COUNT" :runtimeDir :buf
    if hasCp then emitCodepointsNatives :ast :symtab :ctx :runtimeDir :buf
    if (needsHas :ctx name: "indexOf") then {
        (emitMonoNative
            :ast
            :symtab
            :ctx
            :runtimeDir
            frag: "_Z_SV_INDEX_OF"
            mono: "optionval_u64"
            :buf
        )
    }
    if (needsHas :ctx name: "lastIndexOf") then {
        (emitMonoNative
            :ast
            :symtab
            :ctx
            :runtimeDir
            frag: "_Z_SV_LAST_INDEX_OF"
            mono: "optionval_u64"
            :buf
        )
    }
    if (needsHas :ctx name: "byteAt") then {
        emitMonoNative :ast :symtab :ctx :runtimeDir frag: "_Z_SV_BYTE_AT" mono: "optionval_u8" :buf
    }
    if (needsHas :ctx name: "stripPrefix") then {
        (emitMonoNative
            :ast
            :symtab
            :ctx
            :runtimeDir
            frag: "_Z_SV_STRIP_PREFIX"
            mono: "Option_StringView"
            :buf
        )
    }
    if (needsHas :ctx name: "stripSuffix") then {
        (emitMonoNative
            :ast
            :symtab
            :ctx
            :runtimeDir
            frag: "_Z_SV_STRIP_SUFFIX"
            mono: "Option_StringView"
            :buf
        )
    }
    if (needsHas :ctx name: "splitOnce") then {
        (emitMonoNative
            :ast
            :symtab
            :ctx
            :runtimeDir
            frag: "_Z_SV_SPLIT_ONCE"
            mono: "optionval_u64"
            :buf
        )
    }
    if (needsHas :ctx name: "parseI64") then {
        (emitParseNative
            :ast
            :symtab
            :ctx
            :runtimeDir
            frag: "_Z_SV_PARSE_I64"
            mono: "resultval_i64_parseerror"
            :buf
        )
    }
    if (needsHas :ctx name: "parseU64") then {
        (emitParseNative
            :ast
            :symtab
            :ctx
            :runtimeDir
            frag: "_Z_SV_PARSE_U64"
            mono: "resultval_u64_parseerror"
            :buf
        )
    }
    if (needsHas :ctx name: "parseF64") then {
        (emitParseNative
            :ast
            :symtab
            :ctx
            :runtimeDir
            frag: "_Z_SV_PARSE_F64"
            mono: "resultval_f64_parseerror"
            :buf
        )
    }
}

nativePath: function {runtimeDir: StringView frag: StringView} out String is {
    p: "\{runtimeDir}/natives/\{frag}.inc"
    return p
}

emitNativeIf: function {
    ctx: Ctx
    need: StringView
    frag: StringView
    runtimeDir: StringView
    buf: String.borrow
} is {
    if (needsHas :ctx name: need) then {
        p9: nativePath :runtimeDir :frag
        sc9: ctx.svC.copy
        tc9: ctx.strC.copy
        f9: loadFragment path: p9.stringview svC: sc9.stringview strC: tc9.stringview
        buf.append f9.stringview
    }
}

# cbaseNoPrefix -- the id-based cname without the leading "z_" (the runtime
# templates spell z_@@NAME@@, so NAME omits the prefix).
cbaseNoPrefix: function {tid: u64 name: StringView} out String is {
    full: cnameOf :tid :name
    fl: full.length
    rest: (full.substring from: 2 to: fl)
    return rest.string
}

# applyTmpl -- substitute one @@KEY@@ placeholder in template text.
applyTmpl: function {text: String key: StringView val: StringView} out String is {
    needle: "@@\{key}@@"
    return (substituteAll :text needle: needle.stringview repl: val)
}

# monoOriginName -- the template name a mono derives from (List/Map/Set),
# "" when not a mono.
monoOriginName: function {symtab: zenv.ZSymbolTable tid: u64} out String is {
    # partial specs (GENERIC_PARAM typetype) are trie bookkeeping, not monos
    if (symtab.reg.typetypeOf typeId: tid) == ztypes.ztypetype.genericParam then return "".string
    go: genericOriginOf9 :symtab :tid
    if go > 0 then return (typeNameOfReg9 :symtab tid: go)
    return "".string
}

# listElemType -- a List/ListView mono's element type id (the get-child
# return), 0 when absent.
listElemType: function {symtab: zenv.ZSymbolTable monoId: u64} out u64 is {
    go: symtab.typing.childOfId parentTypeId: monoId nameId: wkGet
    match (
        go
    ) case some then {
        t: symtab.reg.typeById.get key: go
        match (
            t
        ) case some then {
            rt: t.returnTypeId
            match (
                rt
            ) case some then {
                return rt
            } case none then null
        } case none then null
    } case none then null
    return 0
}

# ctypeOrI64 -- the given C type name as an owned String, or int64_t
# when empty.
ctypeOrI64: function {s: StringView} out String is {
    if s.length > 0 then {
        return s.string
    } else {
        return "int64_t".string
    }
}

# emitListMono -- substitute z_List.c.tmpl for a List instance + the
# linear-scan contains companion (scalar element equality).
emitArrayMono: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    monoId: u64
    buf: String.borrow
} is {
    mn: typeNameOfReg9 :symtab tid: monoId
    nm: cbaseNoPrefix tid: monoId name: mn.stringview
    eid: listElemType :symtab :monoId
    eln9: typeNameOfReg9 :symtab tid: eid
    ect0: typeRefC :ast :symtab :ctx tid: eid thisTid: 0
    ect: ctypeOrI64 s: ect0.stringview
    lenPfx: 7 + eln9.length
    lenStr: monoElemName full: mn prefixLen: lenPfx
    createBody: "    z_\{nm}_t _this = {0};"
    eqBody: String
    eqo: symtab.typing.childOfId parentTypeId: monoId nameId: wkOpEq
    match (
        eqo
    ) case some then {
        eqBody = "static bool z_\{nm}_eq(z_\{nm}_t a, z_\{nm}_t b) {\n    for (int _i = 0; _i < \{lenStr.stringview}; _i++) { if (a.data[_i] != b.data[_i]) return false; }\n    return true;\n}\n"
    } case none then null
    p: "\{runtimeDir}/z_array.c.tmpl"
    raw: readTemplateCached :ctx path: p.stringview
    if raw.length > 0 then {
        t1: applyTmpl text: raw key: "NAME" val: nm.stringview
        t2: applyTmpl text: t1 key: "ELEM_T" val: ect.stringview
        t3: applyTmpl text: t2 key: "LEN" val: lenStr.stringview
        t4: applyTmpl text: t3 key: "CREATE_BODY" val: createBody.stringview
        t5: applyTmpl text: t4 key: "EQ_BODY" val: eqBody.stringview
        buf.append t5.stringview
        buf.append "\n"
    }
}

# capLenT -- the C length-field type for a str mono of the given capacity:
# uint8/16/32 by capacity, keeping small str monos compact (mirrors the
# reference's len-type selection).
capLenT: function {cap: StringView} out String is {
    v: u64
    i: u64
    n: cap.length
    for i < n loop {
        bo: cap.byteAt :i
        match (
            bo
        ) case some then {
            v = (v * 10) + (bo - 48).u64
        } case none then null
        i = i + 1
    }
    if v <= 255 then return "uint8_t".string
    if v <= 65535 then return "uint16_t".string
    return "uint32_t".string
}

# emitStrMono -- a str valtype mono (fixed-capacity inline string). Substitutes
# z_str.c.tmpl (struct + create + .string + String_to_<name>). Read via
# loadFragment so the template's hardcoded z_String becomes the port's strC.
# Capacity is the trailing segment of the mono name (str_<cap>), prefix "str_"=4.
emitStrMono: function {
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    monoId: u64
    buf: String.borrow
} is {
    mn: typeNameOfReg9 :symtab tid: monoId
    nm: cbaseNoPrefix tid: monoId name: mn.stringview
    capStr: monoElemName full: mn prefixLen: 4
    lenT: capLenT cap: capStr.stringview
    eqBody: String
    eqo: symtab.typing.childOfId parentTypeId: monoId nameId: wkOpEq
    match (
        eqo
    ) case some then {
        eqBody = "static bool z_\{nm}_eq(z_\{nm}_t a, z_\{nm}_t b) {\n    return a.len == b.len && memcmp(a.data, b.data, a.len) == 0;\n}\n"
    } case none then null
    p: "\{runtimeDir}/z_str.c.tmpl"
    svL9: ctx.svC.copy
    strL9: ctx.strC.copy
    raw: loadFragment path: p.stringview svC: svL9.stringview strC: strL9.stringview
    t1: applyTmpl text: raw key: "NAME" val: nm.stringview
    t2: applyTmpl text: t1 key: "CAP" val: capStr.stringview
    t3: applyTmpl text: t2 key: "LEN_T" val: lenT.stringview
    t4: applyTmpl text: t3 key: "EQ_BODY" val: eqBody.stringview
    buf.append t4.stringview
    buf.append "\n"
}

# emitBoxMono -- a builtin Box mono (heap pointer). No struct (the type is
# <inner>*); emit only the destructor: free the inner (String/destructor) then
# the cell. Mirrors the reference _emit_mono_box.
emitBoxMono: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    monoId: u64
    buf: String.borrow
} is {
    mn: typeNameOfReg9 :symtab tid: monoId
    nm: cbaseNoPrefix tid: monoId name: mn.stringview
    beName9: monoElemName full: mn prefixLen: 4
    beid9: resolveTypeIdByName :ast :symtab :ctx name: beName9.stringview
    binner9: typeRefC :ast :symtab :ctx tid: beid9 thisTid: 0
    bdecl9: "static void z_\{nm}_destroy(\{binner9}* v);\n"
    buf.append bdecl9.stringview
    bsig9: "static void z_\{nm}_destroy(\{binner9}* v) {\n"
    buf.append bsig9.stringview
    buf.append "    if (!v) return;\n"
    if beid9 == ctx.strTid then {
        bfree9: "    \{ctx.strC}_free(v);\n"
        buf.append bfree9.stringview
    } else {
        if (symtab.reg.hasDestructorName typeId: beid9) then {
            bicb9: cnameOf tid: beid9 name: beName9.stringview
            bidf9: "    \{bicb9}_destroy(v);\n"
            buf.append bidf9.stringview
        }
    }
    buf.append "    free(v);\n"
    buf.append "}\n\n"
}

emitListMono: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    monoId: u64
    buf: String.borrow
} is {
    mn: typeNameOfReg9 :symtab tid: monoId
    nm: cbaseNoPrefix tid: monoId name: mn.stringview
    eid: listElemType :symtab :monoId
    eln9: typeNameOfReg9 :symtab tid: eid
    isStrEl9: false
    if eid == ctx.strTid then isStrEl9 = true
    ect0: typeRefC :ast :symtab :ctx tid: eid thisTid: 0
    ect: ctypeOrI64 s: ect0.stringview
    p: "\{runtimeDir}/z_List.c.tmpl"
    raw: readTemplateCached :ctx path: p.stringview
    if raw.length == 0 then return
    {
        t1: applyTmpl text: raw key: "NAME" val: nm.stringview
        t2: applyTmpl text: t1 key: "ELEM_T" val: ect.stringview
        delems9: String
        if isStrEl9 then {
            delems9 = "    for (uint64_t _di = 0; _di < p->length; _di++) {\n        \{ctx.strC}_free(&p->data[_di]);\n    }\n"
        } else {
            ecid9: eid
            if (symtab.reg.hasDestructorName typeId: ecid9) == false then {
                rbn9: resolveTypeIdByName :ast :symtab :ctx name: eln9.stringview
                if rbn9 > 0 then ecid9 = rbn9
            }
            if (symtab.reg.hasDestructorName typeId: ecid9) then {
                ecb9: cnameOf tid: ecid9 name: eln9.stringview
                delems9 = "    for (uint64_t _di = 0; _di < p->length; _di++) {\n        \{ecb9}_destroy(&p->data[_di]);\n    }\n"
            }
        }
        t3: applyTmpl text: t2 key: "DESTROY_ELEMS" val: delems9.stringview
        lvm: listviewMethods :symtab :ctx :monoId nm: nm.stringview ect: ect.stringview
        t4: applyTmpl text: t3 key: "LISTVIEW_METHODS" val: lvm.stringview
        buf.append t4.stringview
        buf.append "\n"
    }
    co: symtab.typing.childOfId parentTypeId: monoId nameId: wkContains
    match (
        co
    ) case some then {
        c0: "static bool z_\{nm}_contains(z_\{nm}_t* _this, \{ect} _needle);\n"
        buf.append c0.stringview
        c1: "static bool z_\{nm}_contains(z_\{nm}_t* _this, \{ect} _needle) {\n"
        buf.append c1.stringview
        buf.append "    for (uint64_t i = 0; i < _this->length; i++) {\n"
        if isStrEl9 then {
            buf.append "        if (_this->data[i].size == _needle.size && memcmp(_this->data[i].data, _needle.data, _needle.size) == 0) return true;\n"
        } else {
            buf.append "        if (_this->data[i] == _needle) return true;\n"
        }
        buf.append "    }\n"
        buf.append "    return false;\n"
        buf.append "}\n\n"
    } case none then null
    so: symtab.typing.childOfId parentTypeId: monoId nameId: wkSort
    match (
        so
    ) case some then {
        (emitListSort
            nm: nm.stringview
            ect: ect.stringview
            isStr: isStrEl9
            strC: ctx.strC.stringview
            :buf
        )
    } case none then null
    emitListIter :ast :symtab :ctx :monoId nm: nm.stringview elemName: eln9.stringview :buf
}

# emitListIter -- the borrowed-view iterator over a List mono (a `{List*; idx}`
# cursor yielding OptionView<T> by reference), emitted only when List.iterate is
# used (the ListIter / OptionView monos were minted). The OptionView mono is
# emitted by the earlier OptionView pass, so this can reference it.
emitListIter: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    monoId: u64
    nm: StringView
    elemName: StringView
    buf: String.borrow
} is {
    liId: monoMethodReturn :symtab :monoId nameId: wkIterate
    if liId == 0 then {
        liNameF: "ListIter_\{elemName}"
        liId = monoIdByName :ast :symtab name: liNameF.stringview
    }
    if liId == 0 then return
    liName: typeNameOfReg9 :symtab tid: liId
    ovId: monoMethodReturn :symtab monoId: liId nameId: wkCall
    if ovId == 0 then {
        ovNameF: "OptionView_\{elemName}"
        ovId = monoIdByName :ast :symtab name: ovNameF.stringview
    }
    if ovId == 0 then return
    ovName: typeNameOfReg9 :symtab tid: ovId
    li: cbaseNoPrefix tid: liId name: liName.stringview
    ov: cbaseNoPrefix tid: ovId name: ovName.stringview
    ovu: cUpperOf text: ovName.stringview
    s0: "typedef struct {\n    z_\{nm}_t* list;\n    uint64_t idx;\n} z_\{li}_t;\n"
    buf.append s0.stringview
    s1: "static z_\{ov}_t z_\{li}_call(z_\{li}_t* _it);\n"
    buf.append s1.stringview
    s2: "static z_\{ov}_t z_\{li}_call(z_\{li}_t* _it) {\n"
    buf.append s2.stringview
    s3: "    z_\{ov}_t _out = {0};\n"
    buf.append s3.stringview
    s4: "    if (_it->idx >= _it->list->length) { _out.tag = Z_\{ovu}_TAG_NONE; return _out; }\n"
    buf.append s4.stringview
    s5: "    _out.tag = Z_\{ovu}_TAG_SOME;\n"
    buf.append s5.stringview
    s6: "    _out.data = &_it->list->data[_it->idx];\n"
    buf.append s6
    s7: "    _it->idx++;\n    return _out;\n}\n"
    buf.append s7
    s8: "static z_\{li}_t z_\{nm}_iterate(z_\{nm}_t* _this);\n"
    buf.append s8.stringview
    s9: "static z_\{li}_t z_\{nm}_iterate(z_\{nm}_t* _this) {\n    z_\{li}_t _it = {0};\n    _it.list = _this;\n    _it.idx = 0;\n    return _it;\n}\n\n"
    buf.append s9.stringview
}

# emitListSort -- stable in-place mergesort companion (scalar `<`).
emitListSort: function {
    nm: StringView
    ect: StringView
    isStr: bool
    strC: StringView
    buf: String.borrow
} is {
    if isStr then {
        s0s: "static int z_\{nm}_sort_lt(\{ect} _a, \{ect} _b) { return \{strC}_cmp(&_a, &_b) < 0; }\n"
        buf.append s0s.stringview
    } else {
        s0: "static int z_\{nm}_sort_lt(\{ect} _a, \{ect} _b) { return _a < _b; }\n"
        buf.append s0.stringview
    }
    s1: "static void z_\{nm}_sort_merge(\{ect}* data, \{ect}* scratch, uint64_t lo, uint64_t mid, uint64_t hi) {\n"
    buf.append s1.stringview
    buf.append "    uint64_t i = lo, j = mid, k = lo;\n"
    buf.append "    while (i < mid && j < hi) {\n"
    sm: "        if (!z_\{nm}_sort_lt(data[j], data[i])) scratch[k++] = data[i++];\n"
    buf.append sm.stringview
    buf.append "        else scratch[k++] = data[j++];\n"
    buf.append "    }\n"
    buf.append "    while (i < mid) scratch[k++] = data[i++];\n"
    buf.append "    while (j < hi) scratch[k++] = data[j++];\n"
    buf.append "    memcpy(&data[lo], &scratch[lo], (hi - lo) * sizeof(*data));\n"
    buf.append "}\n"
    s2: "static void z_\{nm}_sort_rec(\{ect}* data, \{ect}* scratch, uint64_t lo, uint64_t hi) {\n"
    buf.append s2.stringview
    buf.append "    if (hi - lo <= 1) return;\n"
    buf.append "    uint64_t mid = lo + (hi - lo) / 2;\n"
    sr1: "    z_\{nm}_sort_rec(data, scratch, lo, mid);\n"
    buf.append sr1.stringview
    sr2: "    z_\{nm}_sort_rec(data, scratch, mid, hi);\n"
    buf.append sr2.stringview
    sr3: "    z_\{nm}_sort_merge(data, scratch, lo, mid, hi);\n"
    buf.append sr3.stringview
    buf.append "}\n"
    s3: "static void z_\{nm}_sort(z_\{nm}_t* _this) {\n"
    buf.append s3.stringview
    buf.append "    if (_this->length < 2) return;\n"
    sa: "    \{ect}* scratch = (\{ect}*)z_xmalloc(_this->length * sizeof(\{ect}));\n"
    buf.append sa.stringview
    sd: "    z_\{nm}_sort_rec(_this->data, scratch, 0, _this->length);\n"
    buf.append sd.stringview
    buf.append "    free(scratch);\n"
    buf.append "}\n\n"
}

# emitListViewMono -- substitute z_ListView.c.tmpl for a ListView mono.
emitListViewMono: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    monoId: u64
    buf: String.borrow
} is {
    mn: typeNameOfReg9 :symtab tid: monoId
    nm: cbaseNoPrefix tid: monoId name: mn.stringview
    eid: listElemType :symtab :monoId
    ect0: typeRefC :ast :symtab :ctx tid: eid thisTid: 0
    ect: ctypeOrI64 s: ect0.stringview
    p: "\{runtimeDir}/z_ListView.c.tmpl"
    raw: readTemplateCached :ctx path: p.stringview
    if raw.length > 0 then {
        t1: applyTmpl text: raw key: "NAME" val: nm.stringview
        t2: applyTmpl text: t1 key: "ELEM_T" val: ect.stringview
        buf.append t2.stringview
        buf.append "\n"
    }
}

# listviewMethods -- the _listview cast + _extendView companions when a
# List mono carries a listview child; "" otherwise.
listviewMethods: function {
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    monoId: u64
    nm: StringView
    ect: StringView
} out String is {
    lo: symtab.typing.childOfId parentTypeId: monoId nameId: wkListview
    match (
        lo
    ) case some then {
        rt: fnReturnTidOf :symtab tid: lo
        if rt > 0 then {
            {
                lvc: symtab.reg.cnameOf tid: rt
                buf: String
                m0: "static \{lvc}_t z_\{nm}_listview(z_\{nm}_t* _this) { return *(\{lvc}_t*)_this; }\n"
                buf.append m0.stringview
                m1: "static void z_\{nm}_extendView(z_\{nm}_t* _this, \{lvc}_t _from) {\n"
                buf.append m1.stringview
                m2: "    z_\{nm}_grow(_this, _this->length + _from.length);\n"
                buf.append m2.stringview
                m3: "    memcpy(&_this->data[_this->length], _from.data, _from.length * sizeof(\{ect}));\n"
                buf.append m3.stringview
                buf.append "    _this->length += _from.length;\n"
                buf.append "}\n\n"
                return buf
            }
        }
    } case none then null
    return "".string
}

# isGenericType -- the type is a generic template (arms typed by generic
# params; never emitted as a concrete struct).
isGenericType: function {symtab: zenv.ZSymbolTable tid: u64} out bool is {
    t: symtab.reg.typeById.get key: tid
    match (
        t
    ) case some then {
        return t.isgeneric
    } case none then {
        return false
    }
}

# internUnitId9 -- the interned id for a unit name; minted on first sight.
# Ids are >= 1, so 0 is the "no defining unit recorded" sentinel.
internUnitId9: function {ctx: Ctx name: StringView} out u64 is {
    {
        g9: ctx.unitIdByName.getv key: name
        match (
            g9
        ) case some then {
            return g9
        } case none then null
    }
    ctx.unitIdCtr = ctx.unitIdCtr + 1
    nid9: ctx.unitIdCtr
    k9: name.string
    ctx.unitIdByName.set key: k9 value: nid9
    return nid9
}

# buildDefUnitIndex -- snapshot tid -> interned defining-unit id once per
# emission. typing.definedInUnit is written only during typecheck, so the
# index is immutable here; zero-alloc id lookups then serve the hot
# definedInNonMain path instead of per-query owned-Option rewraps.
buildDefUnitIndex: function {symtab: zenv.ZSymbolTable ctx: Ctx} is {
    keys9: (List u64)
    names9: (List String)
    with dit: symtab.typing.definedInUnit.iterateItems do for de: dit loop {
        keys9.append de.key
        dv9: de.value.copy
        names9.append dv9
    }
    di9: u64
    dn9: keys9.length
    for di9 < dn9 loop {
        dnm9: names9.get i: di9
        uid9: internUnitId9 :ctx name: dnm9.stringview
        ctx.defUnitId.set key: (keys9.get i: di9) value: uid9
        di9 = di9 + 1
    }
}

# ctxBindMain -- rebind the emission main unit: mainName plus its interned
# id. Every mainName assignment must route here so mainUnitId never goes
# stale (definedInNonMain compares against it).
ctxBindMain: function {ctx: Ctx name: StringView} is {
    nm9: name.string
    ctx.mainName = nm9
    mid9: u64
    {
        g9: ctx.unitIdByName.get key: ctx.mainName
        match (
            g9
        ) case some then {
            mid9 = g9
        } case none then null
    }
    ctx.mainUnitId = mid9
}

# definedInNonMain -- the type is defined in a non-main (system/io/...)
# unit (a reachable library type to emit alongside the main closure).
definedInNonMain: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64} out bool is {
    dgo: ctx.defUnitId.get key: tid
    match (
        dgo
    ) case some then {
        return dgo != ctx.mainUnitId
    } case none then {
        return false
    }
}

# emitUnionMono -- a UNION mono (Option/Result): tag enum + { tag; void*
# data } heap-payload struct + destroy (free the payload on non-null arms,
# recursing into an aggregate payload's destructor first).
emitUnionMono: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    tid: u64
    name: StringView
    buf: String.borrow
} is {
    egu9: ctx.emittedUserTypes.get key: tid
    match (
        egu9
    ) case some then {
        return
    } case none then null
    ctx.emittedUserTypes.set key: tid.u64 value: true
    anames: (List String)
    aids: (List u64)
    aidsNm: (List u64)
    variantArms :ast :symtab :tid names: anames ids: aids nameIds: aidsNm
    vc: cnameOf :tid :name
    buf.append "typedef enum {\n"
    ai: u64
    an: anames.length
    for ai < an loop {
        aname: anames.get i: ai
        tg: variantTag :symtab :tid arm: aname.stringview
        lt: "    \{tg},\n"
        buf.append lt.stringview
        ai = ai + 1
    }
    le: "} \{vc}_tag_t;\n"
    buf.append le.stringview
    if (isFwdDeclared :ctx :tid) then {
        lopenU: "struct \{vc}_t {\n"
        buf.append lopenU.stringview
    } else {
        buf.append "typedef struct {\n"
    }
    lf: "    \{vc}_tag_t tag;\n"
    buf.append lf.stringview
    buf.append "    void* data;\n"
    if (isFwdDeclared :ctx :tid) then {
        buf.append "};\n"
    } else {
        lg: "} \{vc}_t;\n"
        buf.append lg.stringview
    }
    ld: "static void \{vc}_destroy(\{vc}_t* u) {\n"
    buf.append ld.stringview
    buf.append "    if (!u) return;\n"
    buf.append "    if (!u->data) return;\n"
    buf.append "    switch (u->tag) {\n"
    pj: u64
    for pj < an loop {
        pname: anames.get i: pj
        pc: armPayloadC :ast :symtab :ctx :tid arm: pname.stringview
        if pc.length > 0 then {
            ptg: variantTag :symtab :tid arm: pname.stringview
            lcase: "        case \{ptg}:\n"
            buf.append lcase.stringview
            pdtr: payloadDestructor :ast :symtab :ctx :tid arm: pname.stringview
            if pdtr.length > 0 then {
                ldd: "            \{pdtr}((\{pc}*)u->data);\n"
                buf.append ldd.stringview
            }
            buf.append "            free(u->data);\n"
            buf.append "            break;\n"
        }
        pj = pj + 1
    }
    buf.append "        default: break;\n"
    buf.append "    }\n"
    buf.append "}\n\n"
}

# payloadDestructor -- the destructor cname for an arm whose payload is an
# aggregate with a destructor ("" for scalar/view payloads).
payloadDestructor: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    tid: u64
    arm: StringView
} out String is {
    co: symtab.typing.childOf pool: ast.names parentTypeId: tid name: arm
    match (
        co
    ) case some then {
        pn: typeNameOfReg9 :symtab tid: co
        if pn.stringview == "null" then return "".string
        if co == ctx.strTid then return "\{ctx.strC}_free"
        # childOf already resolves the arm to its concrete (possibly cross-unit)
        # payload id; canonicalize a destructor-less shell via resolveTypeIdByName,
        # the same way the List-element destructor does. Build the cname with
        # cnameOf (a fresh String) -- never bind the borrowed destructorName, which
        # would move out of the registry borrow (scope-exit free -> UAF).
        rid: co
        if (symtab.reg.hasDestructorName typeId: co) == false then {
            rbn: resolveTypeIdByName :ast :symtab :ctx name: pn.stringview
            if rbn > 0 then rid = rbn
        }
        if (symtab.reg.hasDestructorName typeId: rid) then {
            cb: cnameOf tid: rid name: pn.stringview
            return "\{cb}_destroy"
        }
    } case none then null
    return "".string
}

# monoIdByName -- a mono instance id looked up by its registry name, 0 absent.
monoIdByName: function {ast: Ast symtab: zenv.ZSymbolTable name: StringView} out u64 is {
    mo: ztypecheck.resolveSystemChild :ast ty: symtab.typing reg: symtab.reg :name
    match (
        mo
    ) case some then {
        return mo
    } case none then {
        return 0
    }
}

# monoMethodReturn -- a mono method child's registered return id (0 when the
# method or its return is absent). The id-first way to reach a collection's
# iterator/view/wrapper companions.
monoMethodReturn: function {symtab: zenv.ZSymbolTable monoId: u64 nameId: u64} out u64 is {
    co: symtab.typing.childOfId parentTypeId: monoId :nameId
    match (
        co
    ) case some then {
        mro: ztypecheck.methodReturnOf st: symtab mid: co
        match (
            mro
        ) case some then {
            return mro
        } case none then null
    } case none then null
    return 0
}

# monoElemName -- a mono name's element segment, dropping a known prefix
# (e.g. "Set_i64" with prefixLen 4 -> "i64"). Substring rides String.stringview
# (a bare StringView receiver mis-resolves `from:/to:` to a .create).
monoElemName: function {full: String prefixLen: u64} out String is {
    fl: full.length
    rest: (full.substring from: prefixLen to: fl)
    return rest.string
}

# setHashBody / setEqBody / setDestroyItems -- the element-kind-specific
# fragments of a Set mono: the keyed byte hash (SipHash by default,
# z_fasthash_* under --fast-hash) + memcmp + per-item free for String keys,
# the integer hash + `==` + no item cleanup otherwise.
# keyHashKind -- classify a Set element / Map key by canonical id (never by
# name, so a user shadow is handled by its nature): 1 native String, 2
# StringView, 3 by-value struct (record/variant -> byte hash over contents), 0
# scalar or pointer (cast hash, the prior `else`). A heap-owning struct lands in
# 3 and fails to build at its `_eq` until the typecheck rejection lands (Slice 3).
keyHashKind: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64} out u64 is {
    if tid == ctx.strTid then return 1
    if tid == ctx.svTid then return 2
    tt: symtab.reg.typetypeOf typeId: tid
    if tt == ztypes.ztypetype.recordType then return 3
    if tt == ztypes.ztypetype.variantType then return 3
    return 0
}

setHashBody: function {kind: u64 fast: bool} out String is {
    if fast then {
        if kind == 1 then return "z_fasthash_string(_key)".string
        if kind == 2 then return "z_fasthash_stringview(_key)".string
        if kind == 3 then return "z_fasthash_bytes(&_key, sizeof(_key))".string
    } else {
        if kind == 1 then return "z_siphash_string(_key)".string
        if kind == 2 then return "z_siphash_stringview(_key)".string
        if kind == 3 then return "z_siphash_bytes(&_key, sizeof(_key))".string
    }
    return "z_hash_u64((uint64_t)_key)".string
}

setEqBody: function {kind: u64} out String is {
    if kind == 1 then return "_a.size == _b.size && memcmp(_a.data, _b.data, _a.size) == 0".string
    if kind == 2 then {
        return "_a.length == _b.length && memcmp(_a.data, _b.data, _a.length) == 0".string
    }
    if kind == 3 then return "memcmp(&_a, &_b, sizeof(_a)) == 0".string
    return "_a == _b".string
}

setDestroyItems: function {isStr: bool strC: StringView} out String is {
    if isStr then {
        return "    for (uint64_t i = 0; i < p->entries_len; i++) {\n        if (p->entries[i].alive) {\n            \{strC}_free(&p->entries[i].item);\n        }\n    }\n"
    }
    return "".string
}

setFreeItemDup: function {isStr: bool strC: StringView} out String is {
    if isStr then return "        \{strC}_free(&_item);\n"
    return "".string
}

setFreeItemDel: function {isStr: bool strC: StringView} out String is {
    if isStr then return "    \{strC}_free(&_this->entries[idx].item);\n"
    return "".string
}

# emitOptionViewMono -- the borrowed-view option a collection iterator yields:
# a {tag; void* data} struct with a no-op destroy (the view owns nothing).
emitOptionViewMono: function {
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    monoId: u64
    buf: String.borrow
} is {
    mn: typeNameOfReg9 :symtab tid: monoId
    nm: cbaseNoPrefix tid: monoId name: mn.stringview
    ovu: cUpperOf text: mn.stringview
    buf.append "typedef enum {\n"
    l1: "    Z_\{ovu}_TAG_NONE,\n"
    buf.append l1.stringview
    l2: "    Z_\{ovu}_TAG_SOME,\n"
    buf.append l2.stringview
    l3: "} z_\{nm}_tag_t;\n"
    buf.append l3.stringview
    buf.append "typedef struct {\n"
    l4: "    z_\{nm}_tag_t tag;\n"
    buf.append l4.stringview
    buf.append "    void* data;\n"
    l5: "} z_\{nm}_t;\n"
    buf.append l5.stringview
    l6: "static void z_\{nm}_destroy(z_\{nm}_t* u) { (void)u; }\n\n"
    buf.append l6.stringview
}

# emitSetMono -- substitute z_Set.c.tmpl for a Set instance (compact-dict
# struct + add/has/delete/iterate + the SetIter companion). Depends on the
# element's OptionView mono being emitted first (the iterator yields it).
emitSetMono: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    monoId: u64
    buf: String.borrow
} is {
    mn: typeNameOfReg9 :symtab tid: monoId
    nm: cbaseNoPrefix tid: monoId name: mn.stringview
    mcr: cUpperOf text: nm.stringview
    elemName: monoElemName full: mn prefixLen: 4
    elemTid: setElemType :symtab :monoId
    itemT: cTypeForNameTid :ast :symtab :ctx name: elemName.stringview tid: elemTid
    ekind: keyHashKind :symtab :ctx tid: elemTid
    isStr: ekind == 1
    siId: monoMethodReturn :symtab :monoId nameId: wkIterate
    if siId == 0 then {
        siNameF: "SetIter_\{elemName}"
        siId = monoIdByName :ast :symtab name: siNameF.stringview
    }
    if siId == 0 then return
    siName: typeNameOfReg9 :symtab tid: siId
    ovId: monoMethodReturn :symtab monoId: siId nameId: wkCall
    if ovId == 0 then {
        ovNameF: "OptionView_\{elemName}"
        ovId = monoIdByName :ast :symtab name: ovNameF.stringview
    }
    if ovId == 0 then return
    ovName: typeNameOfReg9 :symtab tid: ovId
    ov: cbaseNoPrefix tid: ovId name: ovName.stringview
    ovu: cUpperOf text: ovName.stringview
    si: cbaseNoPrefix tid: siId name: siName.stringview
    hashBody: setHashBody kind: ekind fast: ctx.fastHash
    eqBody: setEqBody kind: ekind
    destroyItems: setDestroyItems :isStr strC: ctx.strC.stringview
    freeItemDup: setFreeItemDup :isStr strC: ctx.strC.stringview
    freeItemDel: setFreeItemDel :isStr strC: ctx.strC.stringview
    p: "\{runtimeDir}/z_Set.c.tmpl"
    raw: readTemplateCached :ctx path: p.stringview
    if raw.length > 0 then {
        t1: applyTmpl text: raw key: "NAME" val: nm.stringview
        t2: applyTmpl text: t1 key: "MACRO" val: mcr.stringview
        t3: applyTmpl text: t2 key: "ITEM_T" val: itemT.stringview
        t4: applyTmpl text: t3 key: "HASH_BODY" val: hashBody.stringview
        t5: applyTmpl text: t4 key: "EQ_BODY" val: eqBody.stringview
        t6: applyTmpl text: t5 key: "DESTROY_ITEMS" val: destroyItems.stringview
        t6b: applyTmpl text: t6 key: "FREE_ITEM_DUP" val: freeItemDup.stringview
        t6c: applyTmpl text: t6b key: "FREE_ITEM_DEL" val: freeItemDel.stringview
        t7: applyTmpl text: t6c key: "OPTIONVIEW" val: ov.stringview
        t8: applyTmpl text: t7 key: "OPTIONVIEW_TAG" val: ovu.stringview
        t9: applyTmpl text: t8 key: "SETITER" val: si.stringview
        buf.append t9.stringview
        buf.append "\n"
    }
}

# mapKeyName -- a Map mono's key segment: "Map_<K>_<V>" minus the "Map_"
# prefix and the trailing "_<V>" (vlen is the value name's length).
mapKeyName: function {full: String vlen: u64} out String is {
    fl: full.length
    endx: fl - vlen - 1
    rest: (full.substring from: 4 to: endx)
    return rest.string
}

# mapDestroyEntries / mapFreeKeyDup / mapFreeKeyDel -- String-key cleanup
# fragments: per-entry key free on destroy, incoming-key free when a set hits
# an existing key, stored-key free on delete. Empty for non-heap keys.
mapDestroyEntries: function {isStr: bool strC: StringView valFree: StringView} out String is {
    keyLine: String
    if isStr then keyLine = "            \{strC}_free(&p->entries[i].key);\n"
    valLine: String
    if valFree.length > 0 then valLine = "            \{valFree}\n"
    if (keyLine.length + valLine.length) == 0 then return "".string
    return "    for (uint64_t i = 0; i < p->entries_len; i++) {\n        if (p->entries[i].alive) {\n\{keyLine}\{valLine}        }\n    }\n"
}

mapFreeKeyDup: function {isStr: bool strC: StringView} out String is {
    if isStr then return "        \{strC}_free(&_key);\n"
    return "".string
}

mapFreeKeyDel: function {isStr: bool strC: StringView valFree: StringView} out String is {
    res: String
    if isStr then res = "    \{strC}_free(&_this->entries[idx].key);\n"
    if valFree.length > 0 then res = "\{res}    \{valFree}\n"
    return res
}

# mapValFreeStmt -- the value-free statement for a Map value slot: String value
# via the String free, reftype / heap-collection value via its destructor, empty
# for scalars. Mirrors emitStructDestructor's per-field cleanup.
mapValFreeStmt: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    valName: StringView
    valTid: u64
    slot: StringView
} out String is {
    if valTid == ctx.strTid then return "\{ctx.strC}_free(&\{slot});"
    if valTid > 0 then {
        vmid: chaseColMono :ast :symtab tid: valTid
        needs: false
        if (symtab.reg.hasDestructorName typeId: vmid) then needs = true
        if (isHeapPtrCollection :ast :symtab :ctx tid: valTid) then needs = true
        if needs then {
            vcb: symtab.reg.cnameOf tid: vmid
            if (isHeapPtrCollection
                :ast
                :symtab
                :ctx
                tid: valTid
            ) then return "\{vcb}_destroy(\{slot});"
            return "\{vcb}_destroy(&\{slot});"
        }
    }
    return "".string
}

# emitMapIters -- the MapKeyIter/MapItemIter/MapEntry block for a Map mono,
# emitted only when those iterator monos were minted. Their OptionView returns
# (OptionView_<K>, OptionView_MapEntry_<K>_<V>) are defined by the earlier
# OptionView leg.
emitMapIters: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    monoId: u64
    runtimeDir: StringView
    nm: StringView
    keyName: StringView
    valName: StringView
    keyT: StringView
    valT: StringView
    buf: String.borrow
} is {
    miiId: monoMethodReturn :symtab :monoId nameId: wkIterateItems
    if miiId == 0 then {
        miiNameF: "MapItemIter_\{keyName}_\{valName}"
        miiId = monoIdByName :ast :symtab name: miiNameF.stringview
    }
    if miiId == 0 then return
    miiName: typeNameOfReg9 :symtab tid: miiId
    mkiId: monoMethodReturn :symtab :monoId nameId: wkIterate
    if mkiId == 0 then {
        mkiNameF: "MapKeyIter_\{keyName}_\{valName}"
        mkiId = monoIdByName :ast :symtab name: mkiNameF.stringview
    }
    if mkiId == 0 then return
    mkiName: typeNameOfReg9 :symtab tid: mkiId
    ovkId: monoMethodReturn :symtab monoId: mkiId nameId: wkCall
    if ovkId == 0 then {
        ovkNameF: "OptionView_\{keyName}"
        ovkId = monoIdByName :ast :symtab name: ovkNameF.stringview
    }
    if ovkId == 0 then return
    ovkName: typeNameOfReg9 :symtab tid: ovkId
    oveId: monoMethodReturn :symtab monoId: miiId nameId: wkCall
    if oveId == 0 then {
        oveNameF: "OptionView_MapEntry_\{keyName}_\{valName}"
        oveId = monoIdByName :ast :symtab name: oveNameF.stringview
    }
    if oveId == 0 then return
    oveName: typeNameOfReg9 :symtab tid: oveId
    meId: u64
    meo: symtab.typing.childOfId parentTypeId: oveId nameId: wkSome
    match (
        meo
    ) case some then {
        meId = meo
    } case none then null
    if meId == 0 then {
        meNameF: "MapEntry_\{keyName}_\{valName}"
        meId = monoIdByName :ast :symtab name: meNameF.stringview
    }
    if meId == 0 then return
    meName: typeNameOfReg9 :symtab tid: meId
    mki: cbaseNoPrefix tid: mkiId name: mkiName.stringview
    mii: cbaseNoPrefix tid: miiId name: miiName.stringview
    me: cbaseNoPrefix tid: meId name: meName.stringview
    ovk: cbaseNoPrefix tid: ovkId name: ovkName.stringview
    ovku: cUpperOf text: ovkName.stringview
    ove: cbaseNoPrefix tid: oveId name: oveName.stringview
    oveu: cUpperOf text: oveName.stringview
    pi: "\{runtimeDir}/z_MapIter.c.tmpl"
    rawi: readTemplateCached :ctx path: pi.stringview
    if rawi.length > 0 then {
        i1: applyTmpl text: rawi key: "NAME" val: nm
        i2: applyTmpl text: i1 key: "KEY_T" val: keyT
        i3: applyTmpl text: i2 key: "VAL_T" val: valT
        i4: applyTmpl text: i3 key: "MAPKEYITER" val: mki.stringview
        i5: applyTmpl text: i4 key: "OPTIONVIEW_K" val: ovk.stringview
        i6: applyTmpl text: i5 key: "OPTIONVIEW_K_TAG" val: ovku.stringview
        i7: applyTmpl text: i6 key: "MAPENTRY" val: me.stringview
        i8: applyTmpl text: i7 key: "MAPITEMITER" val: mii.stringview
        i9: applyTmpl text: i8 key: "OPTIONVIEW_ENTRY" val: ove.stringview
        i10: applyTmpl text: i9 key: "OPTIONVIEW_ENTRY_TAG" val: oveu.stringview
        buf.append i10.stringview
        buf.append "\n"
    }
}

# emitMapMono -- substitute z_Map.c.tmpl for a Map instance (compact-dict +
# set/get/has/delete). The value's optionval mono (get's return) supplies the
# value type and the OPTIONVAL placeholders; the key name is the remainder.
# mapValType -- the canonical Map value type id, off the "set" method's "value"
# param (mirrors listElemType). 0 when absent.
mapKeyType: function {symtab: zenv.ZSymbolTable monoId: u64} out u64 is {
    so: symtab.typing.childOfId parentTypeId: monoId nameId: wkSet
    match (
        so
    ) case some then {
        ko: symtab.typing.childOfId parentTypeId: so nameId: wkKey
        match (
            ko
        ) case some then {
            return ko
        } case none then null
    } case none then null
    return 0
}

setElemType: function {symtab: zenv.ZSymbolTable monoId: u64} out u64 is {
    ao: symtab.typing.childOfId parentTypeId: monoId nameId: wkAdd
    match (
        ao
    ) case some then {
        io: symtab.typing.childOfId parentTypeId: ao nameId: wkItem
        match (
            io
        ) case some then {
            return io
        } case none then null
    } case none then null
    return 0
}

mapValType: function {symtab: zenv.ZSymbolTable monoId: u64} out u64 is {
    so: symtab.typing.childOfId parentTypeId: monoId nameId: wkSet
    match (
        so
    ) case some then {
        vo: symtab.typing.childOfId parentTypeId: so nameId: wkValue
        match (
            vo
        ) case some then {
            return vo
        } case none then null
    } case none then null
    return 0
}

emitMapMono: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    monoId: u64
    buf: String.borrow
} is {
    mn: typeNameOfReg9 :symtab tid: monoId
    nm: cbaseNoPrefix tid: monoId name: mn.stringview
    mcr: cUpperOf text: nm.stringview
    ovId: u64
    go: symtab.typing.childOfId parentTypeId: monoId nameId: wkGet
    match (
        go
    ) case some then {
        gt: symtab.reg.typeById.get key: go
        match (
            gt
        ) case some then {
            rto: gt.returnTypeId
            match (
                rto
            ) case some then {
                ovId = rto
            } case none then null
        } case none then null
    } case none then null
    if ovId == 0 then return
    ovName: typeNameOfReg9 :symtab tid: ovId
    ovOrigin: monoOriginName :symtab tid: ovId
    valTid: mapValType :symtab :monoId
    valName: typeNameOfReg9 :symtab tid: valTid
    valT: cTypeForNameTid :ast :symtab :ctx name: valName.stringview tid: valTid
    ov: cbaseNoPrefix tid: ovId name: ovName.stringview
    ovu: cUpperOf text: ovName.stringview
    keyName: mapKeyName full: mn vlen: valName.length
    keyTid: mapKeyType :symtab :monoId
    keyT: cTypeForNameTid :ast :symtab :ctx name: keyName.stringview tid: keyTid
    kkind: keyHashKind :symtab :ctx tid: keyTid
    keyIsStr: kkind == 1
    hashKeyBody: setHashBody kind: kkind fast: ctx.fastHash
    keysEqBody: setEqBody kind: kkind
    vfDestroy: (mapValFreeStmt
        :ast
        :symtab
        :ctx
        valName: valName.stringview
        :valTid
        slot: "p->entries[i].value"
    )
    vfDup: (mapValFreeStmt
        :ast
        :symtab
        :ctx
        valName: valName.stringview
        :valTid
        slot: "_this->entries[existing].value"
    )
    freeValDup: String
    if vfDup.length > 0 then freeValDup = "        \{vfDup}\n"
    destroyEntries: (mapDestroyEntries
        isStr: keyIsStr
        strC: ctx.strC.stringview
        valFree: vfDestroy.stringview
    )
    freeKeyDup: mapFreeKeyDup isStr: keyIsStr strC: ctx.strC.stringview
    getBody: String
    if (originIsTid :symtab tid: ovId originTid: ctx.optionvalOriginTid) then {
        gbV: "    z_\{ov}_t _r;\n    if (idx >= 0) {\n        _r.tag = Z_\{ovu}_TAG_SOME;\n        _r.data.some = _this->entries[idx].value;\n    } else {\n        _r.tag = Z_\{ovu}_TAG_NONE;\n    }\n    return _r;"
        getBody = gbV
    } else {
        # every OptionView-producing value kind (class, String, union,
        # protocol, ...) borrows a pointer into the entry storage: the
        # view's SHARED lock pins the map, and OptionView destroy is a
        # no-op, so a malloc'd box here would leak (the audited get
        # contract is "no deep-copy on get")
        gbR: "    z_\{ov}_t _r = {0};\n    if (idx >= 0) {\n        _r.tag = Z_\{ovu}_TAG_SOME;\n        _r.data = &_this->entries[idx].value;\n    } else {\n        _r.tag = Z_\{ovu}_TAG_NONE;\n        _r.data = NULL;\n    }\n    return _r;"
        getBody = gbR
    }
    rmWrapId9: u64
    roMm9: symtab.typing.childOfId parentTypeId: monoId nameId: wkRemove
    match (
        roMm9
    ) case some then {
        rtMm9: symtab.reg.typeById.get key: roMm9
        match (
            rtMm9
        ) case some then {
            rrtoMm9: rtMm9.returnTypeId
            match (
                rrtoMm9
            ) case some then {
                rmWrapId9 = rrtoMm9
            } case none then null
        } case none then null
    } case none then null
    rmWrapName9: typeNameOfReg9 :symtab tid: rmWrapId9
    rmWrap9: cbaseNoPrefix tid: rmWrapId9 name: rmWrapName9.stringview
    rmWrapU9: cUpperOf text: rmWrapName9.stringview
    rmWrapOrigin9: monoOriginName :symtab tid: rmWrapId9
    keyOnlyFree9: mapFreeKeyDel isStr: keyIsStr strC: ctx.strC.stringview valFree: ""
    delTail9: "\{keyOnlyFree9}    _this->entries[idx].alive = 0;\n    _this->indices[slot] = Z_\{mcr}_INDEX_DELETED;\n    _this->length--;\n"
    removeBody9: String
    if (originIsTid :symtab tid: rmWrapId9 originTid: ctx.optionvalOriginTid) then {
        removeBody9 = "    z_\{rmWrap9}_t _r;\n    if (idx < 0) {\n        _r.tag = Z_\{rmWrapU9}_TAG_NONE;\n        return _r;\n    }\n    _r.tag = Z_\{rmWrapU9}_TAG_SOME;\n    _r.data.some = _this->entries[idx].value;\n\{delTail9}    return _r;"
    } else {
        removeBody9 = "    z_\{rmWrap9}_t _r = {0};\n    if (idx < 0) {\n        _r.tag = Z_\{rmWrapU9}_TAG_NONE;\n        _r.data = NULL;\n        return _r;\n    }\n    _r.tag = Z_\{rmWrapU9}_TAG_SOME;\n    \{valT}* _box = (\{valT}*)z_xmalloc(sizeof(\{valT}));\n    *_box = _this->entries[idx].value;\n    _r.data = _box;\n\{delTail9}    return _r;"
    }
    p: "\{runtimeDir}/z_Map.c.tmpl"
    raw: readTemplateCached :ctx path: p.stringview
    if raw.length == 0 then return
    {
        t1: applyTmpl text: raw key: "NAME" val: nm.stringview
        t2: applyTmpl text: t1 key: "MACRO" val: mcr.stringview
        t3: applyTmpl text: t2 key: "KEY_T" val: keyT.stringview
        t4: applyTmpl text: t3 key: "VAL_T" val: valT.stringview
        t5: applyTmpl text: t4 key: "HASH_KEY_BODY" val: hashKeyBody.stringview
        t6: applyTmpl text: t5 key: "KEYS_EQUAL_BODY" val: keysEqBody.stringview
        t7: applyTmpl text: t6 key: "DESTROY_ENTRIES" val: destroyEntries.stringview
        t8: applyTmpl text: t7 key: "FREE_KEY_DUP" val: freeKeyDup.stringview
        t10: applyTmpl text: t8 key: "OPTIONVAL" val: ov.stringview
        t11: applyTmpl text: t10 key: "OPTIONVAL_TAG" val: ovu.stringview
        t12: applyTmpl text: t11 key: "GET_BODY" val: getBody.stringview
        t13: applyTmpl text: t12 key: "FREE_VAL_DUP" val: freeValDup.stringview
        t14: applyTmpl text: t13 key: "REMOVE_WRAP" val: rmWrap9.stringview
        t15: applyTmpl text: t14 key: "REMOVE_BODY" val: removeBody9.stringview
        buf.append t15.stringview
        buf.append "\n"
    }
    if kkind == 1 then {
        # String-keyed maps: a view-keyed get. The temporary String header
        # aliases the view bytes; get/find only hash and compare the key,
        # never store or free it.
        gv0: "static z_\{ov}_t z_\{nm}_getv(z_\{nm}_t* _this, \{ctx.svC}_t _key) {\n"
        buf.append gv0.stringview
        gv1: "    \{ctx.strC}_t _k = { _key.length, (char*)_key.data, _key.length };\n"
        buf.append gv1.stringview
        gv2: "    return z_\{nm}_get(_this, _k);\n}\n\n"
        buf.append gv2.stringview
    }
    (emitMapIters
        :ast
        :symtab
        :ctx
        :monoId
        :runtimeDir
        nm: nm.stringview
        keyName: keyName.stringview
        valName: valName.stringview
        keyT: keyT.stringview
        valT: valT.stringview
        :buf
    )
}

# emitMonos -- emit every collection-mono instance in the registry (List
# today; Map/Set/iterators land with their slices).
# ioCanonCname -- the id-based cname for an io canonical stem (the part after
# `z_` in a runtime fragment): a mono (Result_*/List_u8/...) via its
# else a named system type (IoError/File/filestat/Reader/...) by registry name.
# "" when the type is not in the (demand-driven) registry for this program.
ioCanonCname: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    canon: StringView
} out String is {
    mo: ztypecheck.resolveSystemChild :ast ty: symtab.typing reg: symtab.reg name: canon
    match (
        mo
    ) case some then {
        return (cnameOf tid: mo name: canon)
    } case none then null
    last: symtab.reg.nextTypeId
    found: u64
    ti: 1.u64
    for ti < last loop {
        if found == 0 then {
            if (definedInNonMain :symtab :ctx tid: ti) then {
                if (regNameIs :symtab tid: ti name: canon) then found = ti
            }
        }
        ti = ti + 1
    }
    if found > 0 then return (cnameOf tid: found name: canon)
    return "".string
}

# loadIoFragment -- read an io/cli runtime `.inc` and substitute the canonical
# names it references (`z_<canon>` -> the typecheck cname) plus StringView/
# String. Tags (Z_IOERROR_TAG_*) are name-based and already match. Unregistered
# canons resolve to "" and are skipped. StringView before String (prefix).
loadIoFragment: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    path: StringView
} out String is {
    rd: io.readText :path
    match (
        rd
    ) case ok then {
        cur: substituteAll text: rd needle: "z_StringView" repl: ctx.svC.stringview
        canons: (List String)
        canons.append "Option_StringView".string
        canons.append "Splitter".string
        canons.append "LinesIter".string
        canons.append "Result_List_String_IoError".string
        canons.append "Result_filestat_IoError".string
        canons.append "Result_String_IoError".string
        canons.append "Result_File_IoError".string
        canons.append "Result_null_IoError".string
        canons.append "Result_u64_IoError".string
        canons.append "Result_Listener_IoError".string
        canons.append "Result_Conn_IoError".string
        canons.append "Result_bool_IoError".string
        canons.append "Option_String".string
        canons.append "OptionView_String".string
        canons.append "ListView_u8".string
        canons.append "List_String".string
        canons.append "List_u8".string
        canons.append "BufWriter".string
        canons.append "BufReader".string
        canons.append "TextWriter".string
        canons.append "TextReader".string
        canons.append "IoError".string
        canons.append "filestat".string
        canons.append "openmode".string
        canons.append "seekorigin".string
        canons.append "filekind".string
        canons.append "Reader".string
        canons.append "Writer".string
        canons.append "Closer".string
        canons.append "Seeker".string
        canons.append "File".string
        canons.append "Listener".string
        canons.append "Conn".string
        canons.append "Result_Parsed_CliError".string
        canons.append "Map_String_String".string
        canons.append "List_PositionalDef".string
        canons.append "List_OptionDef".string
        canons.append "List_FlagDef".string
        canons.append "PositionalDef".string
        canons.append "OptionDef".string
        canons.append "FlagDef".string
        canons.append "CliError".string
        canons.append "Parsed".string
        canons.append "Spec".string
        canons.append "platformkind".string
        canons.append "procexit".string
        canons.append "archkind".string
        ci: u64
        cn: canons.length
        for ci < cn loop {
            canon: canons.get i: ci
            cc: ioCanonCname :ast :symtab :ctx canon: canon.stringview
            if cc.length > 0 then {
                needle: "z_\{canon}"
                cur = substituteAll text: cur needle: needle.stringview repl: cc.stringview
            }
            ci = ci + 1
        }
        cur = substituteAll text: cur needle: "z_String" repl: ctx.strC.stringview
        return cur
    } case err then {
        return "/* zemitterc: missing io fragment \{path} */\n"
    }
}

# ioFragIf -- emit an io runtime fragment when its need flag is set.
ioFragIf: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    need: StringView
    frag: StringView
    buf: String.borrow
} is {
    if (needsHas :ctx name: need) then {
        p9: nativePath :runtimeDir :frag
        f9: loadIoFragment :ast :symtab :ctx path: p9.stringview
        buf.append f9.stringview
        buf.append "\n"
    }
}

# ioFileId -- the io File class type id (0 when File is not reachable).
ioFileId: function {symtab: zenv.ZSymbolTable ctx: Ctx} out u64 is {
    last: symtab.reg.nextTypeId
    ti: 1.u64
    for ti < last loop {
        if (symtab.reg.typetypeOf typeId: ti) == ztypes.ztypetype.classType then {
            if (regNameIs :symtab tid: ti name: "File") then {
                if (definedInNonMain :symtab :ctx tid: ti) then return ti
            }
        }
        ti = ti + 1
    }
    return 0
}

# ioFileLive -- the File class is present AND its read/write param monos
# (List_u8 / ListView_u8) exist, i.e. a File is actually live (constructed /
# io.open / a file method called). This is the order-independent gate for
# emitting File's natives + Reader/Writer conformance: it is true exactly when
# that emitted code's referenced monos have been demanded, so it always compiles.
ioFileLive: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx} out bool is {
    fid9: ioFileId :symtab :ctx
    if fid9 == 0 then return false
    lo9: (ztypecheck.resolvedByKey
        :ast
        ty: symtab.typing
        reg: symtab.reg
        key: "system.List_u8".string
    )
    hasL9: false
    match (
        lo9
    ) case some then {
        hasL9 = true
    } case none then null
    lvo9: (ztypecheck.resolvedByKey
        :ast
        ty: symtab.typing
        reg: symtab.reg
        key: "system.ListView_u8".string
    )
    hasLV9: false
    match (
        lvo9
    ) case some then {
        hasLV9 = true
    } case none then null
    if hasL9 when hasLV9 then return true
    return false
}

# cliClassTypeId -- the type id of a cli-unit CLASS named `name` (0 absent).
cliClassTypeId: function {symtab: zenv.ZSymbolTable ctx: Ctx name: StringView} out u64 is {
    cliUid9: unitIdOf9 :ctx name: "cli"
    if cliUid9 == 0 then return 0
    last: symtab.reg.nextTypeId
    ti: 1.u64
    for ti < last loop {
        if (symtab.reg.typetypeOf typeId: ti) == ztypes.ztypetype.classType then {
            if (regNameIs :symtab tid: ti :name) then {
                if (defUnitIdOf9 :ctx tid: ti) == cliUid9 then return ti
            }
        }
        ti = ti + 1
    }
    return 0
}

# isHeapPtrCollection -- a Map/Set mono is stored as a heap pointer (List is
# embedded by value); a struct field of one is a pointer, freed without `&`.
isHeapPtrCollection: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx tid: u64} out bool is {
    cm: chaseColMono :ast :symtab :tid
    if (originIsTid :symtab tid: cm originTid: ctx.mapOriginTid) then return true
    if (originIsTid :symtab tid: cm originTid: ctx.setOriginTid) then return true
    return false
}

# cliClassIsComposite -- a cli class holding any List/Map/Set field; such a
# class must be emitted after the collection monos it embeds (Spec/Parsed),
# while leaf classes (FlagDef/OptionDef/PositionalDef) emit before them.
cliClassIsComposite: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx tid: u64} out bool is {
    fnames: (List String)
    fids: (List u64)
    fidsNm: (List u64)
    recFieldLists :ast :symtab :tid names: fnames ids: fids nameIds: fidsNm
    fi: u64
    fn0: fnames.length
    for fi < fn0 loop {
        fid: fids.get i: fi
        cm: chaseColMono :ast :symtab tid: fid
        onm: monoOriginName :symtab tid: cm
        if (originIsTid :symtab tid: cm originTid: ctx.listOriginTid) then return true
        if (originIsTid :symtab tid: cm originTid: ctx.mapOriginTid) then return true
        if (originIsTid :symtab tid: cm originTid: ctx.setOriginTid) then return true
        fi = fi + 1
    }
    return false
}

# emitCliFwdDecls -- Parsed is the ok-arm payload of Result_Parsed_CliError,
# whose destructor (emitted with the Option/Result monos) casts to and frees a
# Parsed before Parsed's own body emits (late, after its collection monos). A
# named-tag forward typedef + a destructor prototype satisfy that forward use.
emitCliFwdDecls: function {symtab: zenv.ZSymbolTable ctx: Ctx buf: String.borrow} is {
    pid: cliClassTypeId :symtab :ctx name: "Parsed"
    if pid == 0 then return
    pc: cnameOf tid: pid name: "Parsed"
    l0: "typedef struct \{pc}_t \{pc}_t;\n"
    buf.append l0.stringview
    l1: "static void \{pc}_destroy(\{pc}_t* p);\n"
    buf.append l1.stringview
}

# ioFrag -- load + append an io runtime fragment unconditionally.
ioFrag: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    frag: StringView
    buf: String.borrow
} is {
    p9: nativePath :runtimeDir :frag
    f9: loadIoFragment :ast :symtab :ctx path: p9.stringview
    buf.append f9.stringview
    buf.append "\n"
}

# emitIoFileConformance -- protocol conformance helpers for every reachable io
# class (File -> Reader/Writer/Closer/Seeker; BufWriter -> Writer; BufReader ->
# Reader), emitted after the io natives the wrappers forward to.
emitIoFileConformance: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    buf: String.borrow
} is {
    ioUid9: unitIdOf9 :ctx name: "io"
    osUid9: unitIdOf9 :ctx name: "os"
    cliUid9: unitIdOf9 :ctx name: "cli"
    last: symtab.reg.nextTypeId
    ti: 1.u64
    for ti < last loop {
        if (symtab.reg.typetypeOf typeId: ti) == ztypes.ztypetype.classType then {
            cmo9: monoOriginName :symtab tid: ti
            if cmo9.length == 0 then {
                duId9: defUnitIdOf9 :ctx tid: ti
                isIoC9: false
                if duId9 > 0 then {
                    if duId9 == ioUid9 then isIoC9 = true
                    if duId9 == osUid9 then isIoC9 = true
                    if duId9 == cliUid9 then isIoC9 = true
                }
                if isIoC9 then {
                    cn9: typeNameOfReg9 :symtab tid: ti
                    okEmit9: false
                    if cn9.stringview == "File" then {
                        okEmit9 = ioFileLive :ast :symtab :ctx
                    } else {
                        unc9: "io_uses_\{cn9}"
                        if (needsHas :ctx name: unc9.stringview) then okEmit9 = true
                    }
                    if okEmit9 then {
                        (emitProtocolImplsForType
                            :ast
                            :symtab
                            :ctx
                            implTid: ti
                            implName: cn9.stringview
                            :buf
                        )
                    }
                }
            }
        }
        ti = ti + 1
    }
}

# emitIoStdStreams -- io.stdin/stdout/stderr: a borrowed Reader/Writer over a
# static backing File on fd 0/1/2 (closed=true so RAII never closes it).
emitIoStdStreams: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx buf: String.borrow} is {
    needAny: false
    if (needsHas :ctx name: "io_stdout") then needAny = true
    if (needsHas :ctx name: "io_stderr") then needAny = true
    if (needsHas :ctx name: "io_stdin") then needAny = true
    if (needAny) == false then return
    fid: ioFileId :symtab :ctx
    if fid == 0 then return
    fbase: cnameOf tid: fid name: "File"
    wcn: ioCanonCname :ast :symtab :ctx canon: "Writer"
    rcn: ioCanonCname :ast :symtab :ctx canon: "Reader"
    if (needsHas :ctx name: "io_stdout") then {
        b0: "static \{fbase}_t z_io_stdout_File = { 1, true };\nstatic \{wcn}_t z_io_stdout(void) {\n    return \{fbase}_Writer_create(&z_io_stdout_File);\n}\n\n"
        buf.append b0.stringview
    }
    if (needsHas :ctx name: "io_stderr") then {
        b1: "static \{fbase}_t z_io_stderr_File = { 2, true };\nstatic \{wcn}_t z_io_stderr(void) {\n    return \{fbase}_Writer_create(&z_io_stderr_File);\n}\n\n"
        buf.append b1.stringview
    }
    if (needsHas :ctx name: "io_stdin") then {
        b2: "static \{fbase}_t z_io_stdin_File = { 0, true };\nstatic \{rcn}_t z_io_stdin(void) {\n    return \{fbase}_Reader_create(&z_io_stdin_File);\n}\n\n"
        buf.append b2.stringview
    }
}

# emitIoFileClass -- the io.File value rep: { int32_t fd; bool closed } + a
# destructor that closes the fd once (RAII). Emitted only when File is reachable
# (in the demand-driven registry). The generic record path can't produce the
# close-fd destructor, so File gets this dedicated emitter.
emitIoFileClass: function {symtab: zenv.ZSymbolTable ctx: Ctx buf: String.borrow} is {
    last: symtab.reg.nextTypeId
    fid: u64
    ti: 1.u64
    for ti < last loop {
        if fid == 0 then {
            if (symtab.reg.typetypeOf typeId: ti) == ztypes.ztypetype.classType then {
                if (regNameIs :symtab tid: ti name: "File") then {
                    if (definedInNonMain :symtab :ctx tid: ti) then fid = ti
                }
            }
        }
        ti = ti + 1
    }
    if fid == 0 then return
    fc: cnameOf tid: fid name: "File"
    l0: "typedef struct {\n    int32_t fd;\n    bool closed;\n} \{fc}_t;\n"
    buf.append l0.stringview
    l1: "static void \{fc}_destroy(\{fc}_t* p) {\n    if (!p) return;\n    if (p->closed) return;\n    close(p->fd);\n    p->closed = true;\n}\n\n"
    buf.append l1.stringview
}

# emitNetFdClass -- one net fd-holder class ({ int32_t fd; bool closed } + a
# close-once destructor), the net analogue of emitIoFileClass. The net runtime
# fragments dereference the fields, so the body is pre-emitted here and the
# type marked in ctx.emittedUserTypes so the ordered user-struct pass skips it
# (that pass runs after the fragments -- too late).
emitNetFdClass: function {
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    name: StringView
    buf: String.borrow
} is {
    netUid9: unitIdOf9 :ctx name: "net"
    last: symtab.reg.nextTypeId
    fid: u64
    ti: 1.u64
    for ti < last loop {
        if fid == 0 then {
            if (symtab.reg.typetypeOf typeId: ti) == ztypes.ztypetype.classType then {
                if (regNameIs :symtab tid: ti :name) then {
                    duId9: defUnitIdOf9 :ctx tid: ti
                    if duId9 > 0 when duId9 == netUid9 then fid = ti
                }
            }
        }
        ti = ti + 1
    }
    if fid == 0 then return
    ego9: ctx.emittedUserTypes.get key: fid
    match (
        ego9
    ) case some then {
        return
    } case none then null
    ctx.emittedUserTypes.set key: fid.u64 value: true
    fc: cnameOf tid: fid :name
    if (isFwdDeclared :ctx tid: fid) then {
        l0: "struct \{fc}_t {\n    int32_t fd;\n    bool closed;\n};\n"
        buf.append l0.stringview
    } else {
        l0: "typedef struct {\n    int32_t fd;\n    bool closed;\n} \{fc}_t;\n"
        buf.append l0.stringview
    }
    l1: "static void \{fc}_destroy(\{fc}_t* p) {\n    if (!p) return;\n    if (p->closed) return;\n    close(p->fd);\n    p->closed = true;\n}\n\n"
    buf.append l1.stringview
}

# emitNetClasses -- the net fd-holder value reps (Listener/Conn), need-gated.
emitNetClasses: function {symtab: zenv.ZSymbolTable ctx: Ctx buf: String.borrow} is {
    if (needsHas :ctx name: "net") == false then return
    emitNetFdClass :symtab :ctx name: "Listener" :buf
    emitNetFdClass :symtab :ctx name: "Conn" :buf
}

# emitRuntimeSvIter -- the StringView split/lines iterator natives (Splitter +
# LinesIter struct, builders, and .call). Need-gated; emitted after the monos so
# Option_StringView (the .call yield) is already defined.
emitRuntimeSvIter: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    buf: String.borrow
} is {
    anyNeed: false
    svNeed9: false
    if (needsHas :ctx name: "sv_split") then {
        anyNeed = true
        svNeed9 = true
    }
    if (needsHas :ctx name: "sv_lines") then {
        anyNeed = true
        svNeed9 = true
    }
    if (needsHas :ctx name: "coll_join") then anyNeed = true
    if (anyNeed) == false then return
    if svNeed9 then ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_SV_SPLITTER_STRUCT" :buf
    ioFragIf :ast :symtab :ctx :runtimeDir need: "sv_split" frag: "_Z_SV_SPLIT" :buf
    ioFragIf :ast :symtab :ctx :runtimeDir need: "sv_split" frag: "_Z_SV_SPLITTER_CALL" :buf
    ioFragIf :ast :symtab :ctx :runtimeDir need: "sv_lines" frag: "_Z_SV_LINES" :buf
    ioFragIf :ast :symtab :ctx :runtimeDir need: "sv_lines" frag: "_Z_SV_LINES_CALL" :buf
    ioFragIf :ast :symtab :ctx :runtimeDir need: "coll_join" frag: "_Z_COLL_STRING_JOIN" :buf
}

# emitRuntimeIo -- the io runtime bodies (need-gated, dependency-ordered). The
# universal helpers (z_sv_to_cstr inline, errno-map) emit whenever any io call
# is present; the rest gate on their specific need.
# upperSnakeOf -- camelCase (or snake_case) to UPPER_SNAKE: `listDir` ->
# `LIST_DIR`, `spec_create` -> `SPEC_CREATE`. Fragment-name convention.
upperSnakeOf: function {name: StringView} out String is {
    r: String
    i: u64
    n: name.length
    for i < n loop {
        bo: name.byteAt :i
        match (
            bo
        ) case some then {
            if bo >= 97 when bo <= 122 then {
                r.appendByte b: (bo - 32)
            } else {
                if bo >= 65 when bo <= 90 then r.appendByte b: 95
                r.appendByte b: bo
            }
        } case none then null
        i = i + 1
    }
    return r
}

# loadConventionFrags -- load the convention-named runtime fragment for
# every recorded `<unit>_<name>` need: `_Z_<UNIT>_<UPPER_SNAKE(name)>.inc`.
# Needs whose fragment is a bundle/rename/base (listed in `skip`, bare
# member names) are the caller's explicit business. Sorted for
# deterministic output (the needs map iterates in hash order).
loadConventionFrags: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    uname: StringView
    skip: List String
    buf: String.borrow
} is {
    pre9: "\{uname}_"
    names9: (List String)
    with kit9: ctx.needs.iterate do for k9: kit9 loop {
        kv9: k9.stringview
        if kv9.startsWith pre9.stringview then {
            rest9: kv9.substring from: pre9.length to: kv9.length
            skipped9: false
            with sit9: skip.iterate do for sk9: sit9 loop {
                if sk9.stringview == rest9 then skipped9 = true
            }
            if (skipped9) == false then names9.append rest9.string
        }
    }
    names9.sort
    un9: upperSnakeOf name: uname
    ni9: u64
    nn9: names9.length
    for ni9 < nn9 loop {
        nm9: names9.get i: ni9
        ni9 = ni9 + 1
        sn9: upperSnakeOf name: nm9.stringview
        fr9: "_Z_\{un9}_\{sn9}"
        nd9: "\{uname}_\{nm9}"
        ioFragIf :ast :symtab :ctx :runtimeDir need: nd9.stringview frag: fr9.stringview :buf
    }
}

emitRuntimeIo: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    buf: String.borrow
} is {
    ioAct9: needsHas :ctx name: "io"
    osEr9: osNeedsErrno :ctx
    runIo9: ioAct9
    if (osNeedsSvCstr :ctx) then runIo9 = true
    if osEr9 then runIo9 = true
    if (runIo9) == false then return
    csc: "static char* z_sv_to_cstr(\{ctx.svC}_t v) {\n    char* buf = (char*)z_xmalloc(v.length + 1);\n    if (v.length > 0) memcpy(buf, v.data, v.length);\n    buf[v.length] = '\\0';\n    return buf;\n}\n\n"
    buf.append csc.stringview
    needErr9: ioAct9
    if osEr9 then needErr9 = true
    if needErr9 then ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_IO_ERRNO_MAP" :buf
    needWC: needsHas :ctx name: "io_writeText"
    if (needsHas :ctx name: "io_appendText") then needWC = true
    if needWC then {
        p8: nativePath :runtimeDir frag: "_Z_IO_WRITE_COMMON"
        f8: loadIoFragment :ast :symtab :ctx path: p8.stringview
        buf.append f8.stringview
        buf.append "\n"
    }
    needU64: needsHas :ctx name: "io_file_read"
    if (needsHas :ctx name: "io_file_write") then needU64 = true
    if (needsHas :ctx name: "io_file_seek") then needU64 = true
    if needU64 then {
        pwu: nativePath :runtimeDir frag: "_Z_IO_WRAP_U64_RESULT"
        fwu: loadIoFragment :ast :symtab :ctx path: pwu.stringview
        buf.append fwu.stringview
        buf.append "\n"
    }
    needNull: needsHas :ctx name: "io_file_close"
    if (needsHas :ctx name: "io_file_flush") then needNull = true
    if (needsHas :ctx name: "io_mkdir") then needNull = true
    if (needsHas :ctx name: "io_mkdirp") then needNull = true
    if (needsHas :ctx name: "io_remove") then needNull = true
    if (needsHas :ctx name: "io_rename") then needNull = true
    if needNull then {
        pwn: nativePath :runtimeDir frag: "_Z_IO_WRAP_NULL_RESULT"
        fwn: loadIoFragment :ast :symtab :ctx path: pwn.stringview
        buf.append fwn.stringview
        buf.append "\n"
    }
    needFstat: needsHas :ctx name: "io_stat"
    if (needsHas :ctx name: "io_lstat") then needFstat = true
    if needFstat then {
        psf: nativePath :runtimeDir frag: "_Z_IO_STAT_FILL"
        fsf: loadIoFragment :ast :symtab :ctx path: psf.stringview
        buf.append fsf.stringview
        buf.append "\n"
    }
    # every remaining io_<name> need loads its convention fragment
    # (_Z_IO_<UPPER_SNAKE>); the File-method and stream families load
    # from their own explicit blocks below
    ioSkip9: (List String)
    ioSkip9.append "file_close".string
    ioSkip9.append "file_write".string
    ioSkip9.append "file_read".string
    ioSkip9.append "file_seek".string
    ioSkip9.append "file_flush".string
    ioSkip9.append "uses_BufWriter".string
    ioSkip9.append "uses_BufReader".string
    ioSkip9.append "uses_TextWriter".string
    ioSkip9.append "uses_TextReader".string
    loadConventionFrags :ast :symtab :ctx :runtimeDir uname: "io" skip: ioSkip9 :buf
    ioFragIf :ast :symtab :ctx :runtimeDir need: "io_file_close" frag: "_Z_FILE_CLOSE" :buf
    ioFragIf :ast :symtab :ctx :runtimeDir need: "io_file_write" frag: "_Z_FILE_WRITE" :buf
    ioFragIf :ast :symtab :ctx :runtimeDir need: "io_file_read" frag: "_Z_FILE_READ" :buf
    ioFragIf :ast :symtab :ctx :runtimeDir need: "io_file_seek" frag: "_Z_FILE_SEEK" :buf
    ioFragIf :ast :symtab :ctx :runtimeDir need: "io_file_flush" frag: "_Z_FILE_FLUSH" :buf
    if (needsHas :ctx name: "io_uses_BufWriter") then {
        ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_BUFWRITER_CREATE" :buf
        ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_BUFWRITER_FLUSH" :buf
        ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_BUFWRITER_WRITE" :buf
    }
    if (needsHas :ctx name: "io_uses_BufReader") then {
        ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_BUFREADER_CREATE" :buf
        ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_BUFREADER_READ" :buf
    }
    if (needsHas :ctx name: "io_uses_TextWriter") then {
        ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_TEXTWRITER_CREATE" :buf
        ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_TEXTWRITER_WRITE" :buf
        ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_TEXTWRITER_WRITE_LINE" :buf
        ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_TEXTWRITER_FLUSH" :buf
    }
    if (needsHas :ctx name: "io_uses_TextReader") then {
        ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_IO_UTF8_VALIDATE" :buf
        ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_TEXTREADER_CREATE" :buf
        ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_TEXTREADER_READ_LINE" :buf
        ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_TEXTREADER_CALL" :buf
    }
}

# emitRuntimeCli -- the cli runtime bodies (need-gated, dependency-ordered),
# reusing the io fragment loader/gate. The helpers ride the parse need (parse is
# their only caller) and precede parse's body for a clean forward declaration.
emitRuntimeCli: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    buf: String.borrow
} is {
    if (needsHas :ctx name: "cli") == false then return
    # parse is a bundle (helpers precede its body); the Parsed methods load
    # the renamed _Z_PARSED_* family. Every other cli_<name> need is
    # convention-loaded.
    cliSkip9: (List String)
    cliSkip9.append "parse".string
    cliSkip9.append "hasFlag".string
    cliSkip9.append "option".string
    cliSkip9.append "positional".string
    loadConventionFrags :ast :symtab :ctx :runtimeDir uname: "cli" skip: cliSkip9 :buf
    ioFragIf :ast :symtab :ctx :runtimeDir need: "cli_parse" frag: "_Z_CLI_HELPERS" :buf
    ioFragIf :ast :symtab :ctx :runtimeDir need: "cli_parse" frag: "_Z_CLI_PARSE" :buf
    ioFragIf :ast :symtab :ctx :runtimeDir need: "cli_hasFlag" frag: "_Z_PARSED_HAS_FLAG" :buf
    ioFragIf :ast :symtab :ctx :runtimeDir need: "cli_option" frag: "_Z_PARSED_GET_OPTION" :buf
    (ioFragIf
        :ast
        :symtab
        :ctx
        :runtimeDir
        need: "cli_positional"
        frag: "_Z_PARSED_GET_POSITIONAL"
        :buf
    )
}

# emitRuntimeOs -- the os runtime bodies (need-gated). Only os.args is wired so
# far: its argc/argv globals + the args() copy, both gated on the os_args need
# (main() captures argc/argv into the globals when the same need is set).
emitRuntimeOs: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    buf: String.borrow
} is {
    if (needsHas :ctx name: "os") == false then return
    if (needsHas :ctx name: "os_args") then {
        ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_OS_ARGV_GLOBALS" :buf
        ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_OS_ARGS" :buf
    }
    # env's fragment is renamed (GET_ENV); args is a bundle -- both above.
    # Every other os_<name> need is convention-loaded.
    ioFragIf :ast :symtab :ctx :runtimeDir need: "os_env" frag: "_Z_OS_GET_ENV" :buf
    osSkip9: (List String)
    osSkip9.append "env".string
    osSkip9.append "args".string
    loadConventionFrags :ast :symtab :ctx :runtimeDir uname: "os" skip: osSkip9 :buf
}

# emitRuntimeNet -- the net runtime bodies (need-gated on any net use).
emitRuntimeNet: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    buf: String.borrow
} is {
    if (needsHas :ctx name: "net") == false then return
    ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_NET_LISTEN" :buf
    ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_NET_ACCEPT" :buf
    ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_NET_CONNECT" :buf
    ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_NET_CONN_READ" :buf
    ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_NET_CONN_WRITE" :buf
    ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_NET_CONN_CLOSE" :buf
    ioFrag :ast :symtab :ctx :runtimeDir frag: "_Z_NET_POLL" :buf
}

# maybePreEmitElem -- a user type (variant/record/class/union) used as a
# collection element is embedded BY VALUE by the List/ListView mono, so its
# struct must precede the mono. Emit it here (guarded by ctx.emittedUserTypes);
# its methods still emit later in emitRecordDefsIn. Covers main-unit AND dep
# file-unit element types (the cross-unit Node union returned by value from a
# ListView_Node mono); monos / generics / typedefs and system-unit types (which
# have their own dedicated sweeps above) are skipped.
maybePreEmitElem: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    eid: u64
    buf: String.borrow
} is {
    if eid == 0 then return
    rid0: eid
    snm0: typeNameOfReg9 :symtab tid: eid
    sduo: definedInUnitOf :symtab tid: eid
    match (
        sduo
    ) case some then null case none then {
        if snm0.length > 0 then {
            srid: resolveTypeIdByName :ast :symtab :ctx name: snm0.stringview
            if srid > 0 then rid0 = srid
        }
    }
    cid: chaseColMono :ast :symtab tid: rid0
    monoLk4: monoOriginName :symtab tid: cid
    if monoLk4.length > 0 then return
    if (isGenericType :symtab tid: cid) then return
    duoPe: definedInUnitOf :symtab tid: cid
    peUnit: ctx.mainName.copy
    match (
        duoPe
    ) case some then {
        if (isEmittableFileUnit name: duoPe.stringview) == false then return
        peUnit = duoPe.copy
    } case none then null
    nm: typeNameOfReg9 :symtab tid: cid
    if nm.length == 0 then return
    tt: symtab.reg.typetypeOf typeId: cid
    smPe: ctx.mainName.copy
    ctxBindMain :ctx name: peUnit.stringview
    if tt == ztypes.ztypetype.variantType then {
        emitOneVariant :ast :symtab :ctx tid: cid name: nm.stringview :buf
    }
    if tt == ztypes.ztypetype.recordType then {
        emitOneRecord :ast :symtab :ctx tid: cid name: nm.stringview :buf
    }
    if tt == ztypes.ztypetype.classType then {
        emitOneRecord :ast :symtab :ctx tid: cid name: nm.stringview :buf
    }
    if tt == ztypes.ztypetype.protocolType then {
        emitOneProtocol :ast :symtab :ctx tid: cid name: nm.stringview :buf
    }
    if tt == ztypes.ztypetype.facetType then {
        emitOneFacet :ast :symtab :ctx tid: cid name: nm.stringview :buf
    }
    if tt == ztypes.ztypetype.unionType then {
        emitUnionMono :ast :symtab :ctx tid: cid name: nm.stringview :buf
    }
    ctxBindMain :ctx name: smPe.stringview
}

# preEmitEmbeddedTypes -- emit the main-unit user types a variant/record/class
# embeds BY VALUE (arm payloads, field types) before its own struct, so they are
# declared first. Idempotent via ctx.emittedUserTypes, which also breaks cycles.
preEmitEmbeddedTypes: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    ids: List u64
    buf: String.borrow
} is {
    pi: u64
    pn: ids.length
    for pi < pn loop {
        eidv: ids.get i: pi
        maybePreEmitElem :ast :symtab :ctx eid: eidv :buf
        pi = pi + 1
    }
}

# isFwdDeclared -- the type was forward-declared by emitMainFwdDecls, so its
# body must be emitted as a named `struct X_t { ... };` (the typedef is already
# in the forward-decl block).
isFwdDeclared: function {ctx: Ctx tid: u64} out bool is {
    o: ctx.fwdDeclaredTypes.get key: tid
    match (
        o
    ) case some then {
        return o
    } case none then {
        return false
    }
}

# emitMainFwdDecls -- forward-declare the main unit's RECORD + UNION types
# (named-struct typedef + a destructor prototype) before the monos. The AST is
# a self-referential Node union: Node_destroy + the Option/List monos + the
# print functions reference Node and the arm *Data structs by pointer (or call
# their destroys) ahead of the bodies, so without forward declarations they are
# undeclared. Mirrors the reference's forward-decl block; the bodies then emit
# as plain `struct X_t { ... };` via isFwdDeclared.
emitMainFwdDecls: function {symtab: zenv.ZSymbolTable ctx: Ctx buf: String.borrow} is {
    last: symtab.reg.nextTypeId
    t: u64
    for t < last loop {
        tt: symtab.reg.typetypeOf typeId: t
        isStructType: false
        isUnion: false
        if tt == ztypes.ztypetype.recordType then isStructType = true
        if tt == ztypes.ztypetype.unionType then {
            isStructType = true
            isUnion = true
        }
        if tt == ztypes.ztypetype.classType then isStructType = true
        if isStructType then {
            gen: isGenericType :symtab tid: t
            mo: monoOriginName :symtab tid: t
            if mo.length == 0 when gen == false then {
                duo: definedInUnitOf :symtab tid: t
                match (
                    duo
                ) case some then {
                    if (isEmittableFileUnit name: duo.stringview) then {
                        if (isTypedefType
                            :symtab
                            tid: t
                        ) == false when (isBoxTid :symtab tid: t) == false then {
                            cn: symtab.reg.cnameOf tid: t
                            ctx.fwdDeclaredTypes.set key: t.u64 value: true
                            l0: "typedef struct \{cn}_t \{cn}_t;\n"
                            buf.append l0.stringview
                            needDtor: isUnion
                            if (symtab.reg.hasDestructorName typeId: t) then needDtor = true
                            if needDtor then {
                                l1: "static void \{cn}_destroy(\{cn}_t* p);\n"
                                buf.append l1.stringview
                            }
                        }
                    }
                } case none then null
            } else {
                fwdM9: false
                if mo.length > 0 then {
                    if (symtab.reg.hasDestructorName typeId: t) then fwdM9 = true
                    if (originIsTid :symtab tid: t originTid: ctx.listOriginTid) then fwdM9 = true
                    if (originIsTid :symtab tid: t originTid: ctx.listViewOriginTid) then {
                        fwdM9 = true
                    }
                    if (originIsTid :symtab tid: t originTid: ctx.setOriginTid) then fwdM9 = true
                    if (originIsTid :symtab tid: t originTid: ctx.mapOriginTid) then fwdM9 = true
                }
                if (isBoxTid :symtab tid: t) then fwdM9 = false
                if fwdM9 then {
                    cnX: symtab.reg.cnameOf tid: t
                    ctx.fwdDeclaredTypes.set key: t.u64 value: true
                    lx0: "typedef struct \{cnX}_t \{cnX}_t;\n"
                    buf.append lx0.stringview
                    fwdDtor9: false
                    if (symtab.reg.hasDestructorName typeId: t) then fwdDtor9 = true
                    if (originIsTid :symtab tid: t originTid: ctx.mapOriginTid) then fwdDtor9 = true
                    if (originIsTid :symtab tid: t originTid: ctx.setOriginTid) then fwdDtor9 = true
                    if fwdDtor9 then {
                        lx1: "static void \{cnX}_destroy(\{cnX}_t* p);\n"
                        buf.append lx1.stringview
                    }
                }
            }
        }
        t = t + 1
    }
}

# monoMapKV -- a Map/MapEntry mono's value + key type ids. The port has no
# concrete generic-arg rows on monos (setGenericArg stamps a 0 placeholder), so
# resolve the value via the get-return OptionView's element name and the key via
# the mangled-name remainder, mirroring emitMapMono.
monoMapKV: function {symtab: zenv.ZSymbolTable ctx: Ctx monoId: u64 acc: List u64} is {
    go: symtab.typing.childOfId parentTypeId: monoId nameId: wkGet
    match (
        go
    ) case some then {
        vid: mapValType :symtab :monoId
        if vid > 0 then acc.append vid
        kid: mapKeyType :symtab :monoId
        if kid > 0 then acc.append kid
    } case none then null
}

# monoElemIdsOf -- the type ids a collection/wrapper mono references by its
# element/key/value (List/ListView/Set/Map) or arm payloads (optionval/resultval/
# Option/Result/OptionView), or its fields for a user-generic record/class mono.
# Used by the early/late split to find which monos embed a user type.
monoElemIdsOf: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx monoId: u64 acc: List u64} is {
    origin: monoOriginName :symtab tid: monoId
    isLV: false
    if (originIsTid :symtab tid: monoId originTid: ctx.listOriginTid) then isLV = true
    if (originIsTid :symtab tid: monoId originTid: ctx.listViewOriginTid) then isLV = true
    if isLV then {
        e: listElemType :symtab :monoId
        if e > 0 then acc.append e
        return
    }
    if (originIsTid :symtab tid: monoId originTid: ctx.setOriginTid) then {
        snm: typeNameOfReg9 :symtab tid: monoId
        en: monoElemName full: snm prefixLen: 4
        eid: resolveTypeIdByName :ast :symtab :ctx name: en.stringview
        if eid > 0 then acc.append eid
        return
    }
    if (originIsTid :symtab tid: monoId originTid: ctx.mapOriginTid) then {
        monoMapKV :symtab :ctx :monoId :acc
        return
    }
    isWrap: false
    if (originIsTid :symtab tid: monoId originTid: ctx.optionvalOriginTid) then isWrap = true
    if (originIsTid :symtab tid: monoId originTid: ctx.resultvalOriginTid) then isWrap = true
    if (originIsTid :symtab tid: monoId originTid: ctx.optionOriginTid) then isWrap = true
    if (originIsTid :symtab tid: monoId originTid: ctx.resultOriginTid) then isWrap = true
    if (originIsTid :symtab tid: monoId originTid: ctx.optionViewOriginTid) then isWrap = true
    if isWrap then {
        anames: (List String)
        aids: (List u64)
        aidsNm: (List u64)
        variantArms :ast :symtab tid: monoId names: anames ids: aids nameIds: aidsNm
        ai: u64
        an: aids.length
        for ai < an loop {
            av: aids.get i: ai
            acc.append av
            ai = ai + 1
        }
        return
    }
    fnames: (List String)
    fids: (List u64)
    fidsNm: (List u64)
    recFieldLists :ast :symtab tid: monoId names: fnames ids: fids nameIds: fidsNm
    fi: u64
    fn: fids.length
    for fi < fn loop {
        fv: fids.get i: fi
        acc.append fv
        fi = fi + 1
    }
}

# buildUserTypeList -- the file-unit (main + dep) struct types: RECORD / CLASS /
# UNION / VARIANT that are not monos and not generic templates. A mono embedding
# one of these by value must be emitted after it.
buildUserTypeList: function {symtab: zenv.ZSymbolTable ctx: Ctx acc: List u64} is {
    last: symtab.reg.nextTypeId
    t: u64
    for t < last loop {
        tt: symtab.reg.typetypeOf typeId: t
        isStruct: false
        if tt == ztypes.ztypetype.recordType then isStruct = true
        if tt == ztypes.ztypetype.classType then isStruct = true
        if tt == ztypes.ztypetype.unionType then isStruct = true
        if tt == ztypes.ztypetype.variantType then isStruct = true
        if tt == ztypes.ztypetype.facetType then isStruct = true
        if isStruct then {
            mo: monoOriginName :symtab tid: t
            gen: isGenericType :symtab tid: t
            if mo.length == 0 when gen == false then {
                duo: definedInUnitOf :symtab tid: t
                match (
                    duo
                ) case some then {
                    if (isEmittableFileUnit name: duo.stringview) then acc.append t.u64
                } case none then null
            }
        }
        t = t + 1
    }
}

# monoDependsOnUser -- does the mono's layout reference a user type, directly or
# through a nested mono? Mirrors the reference _mono_depends_on_user; the seen
# list breaks cycles through boxed monos.
monoDependsOnUser: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    monoId: u64
    userList: List u64
    seen: List u64
} out bool is {
    if (seen.contains item: monoId) then return false
    seen.append monoId.u64
    elems: (List u64)
    monoElemIdsOf :ast :symtab :ctx :monoId acc: elems
    ei: u64
    en: elems.length
    for ei < en loop {
        eid: elems.get i: ei
        ceid: chaseColMono :ast :symtab tid: eid
        if (userList.contains item: ceid) then return true
        emo: monoOriginName :symtab tid: ceid
        if emo.length > 0 then {
            if (monoDependsOnUser :ast :symtab :ctx monoId: ceid :userList :seen) then return true
        }
        ei = ei + 1
    }
    return false
}

# monoIsLate -- the mono embeds a user type by value (a fresh seen per query).
monoIsLate: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    monoId: u64
    userList: List u64
} out bool is {
    seen: (List u64)
    return (monoDependsOnUser :ast :symtab :ctx :monoId :userList :seen)
}

# idSetHas -- membership in a Map-u64-bool id set.
idSetHas: function {s: (Map u64 value: bool) id: u64} out bool is {
    got: s.get key: id
    match (
        got
    ) case some then {
        return got
    } case none then {
        return false
    }
}

# userDefnRefsUnemitted -- does the user type have a by-value field whose type is
# in groupList but not yet in emittedList? Map/Set fields are heap pointers in the
# port (fwd-decl suffices) so they impose no ordering edge; a UNION is boxed so it
# is never dragged by its own arms. Passing an empty emittedList answers the plain
# "references any group member" question used by the late-type closure.
userDefnRefsUnemitted: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    typeId: u64
    group: (Map u64 value: bool)
    emitted: (Map u64 value: bool)
} out bool is {
    tt: symtab.reg.typetypeOf :typeId
    if tt == ztypes.ztypetype.unionType then return false
    fnames: (List String)
    fids: (List u64)
    if tt == ztypes.ztypetype.variantType then {
        fidsNm: (List u64)
        variantArms :ast :symtab tid: typeId names: fnames ids: fids nameIds: fidsNm
    } else if tt == ztypes.ztypetype.facetType then {
        # a facet's ordering edges are its conforming impls (embedded by
        # value in the data union), not record fields
        facetImplTids :symtab tid: typeId acc: fids
    } else {
        fidsNm: (List u64)
        recFieldLists :ast :symtab tid: typeId names: fnames ids: fids nameIds: fidsNm
    }
    fi: u64
    fn: fids.length
    for fi < fn loop {
        fid: fids.get i: fi
        cfid: chaseColMono :ast :symtab tid: fid
        skip: isHeapPtrCollection :ast :symtab :ctx tid: fid
        if skip == false then {
            if (idSetHas s: group id: cfid) then {
                if (idSetHas s: emitted id: cfid) == false then return true
            }
        }
        fi = fi + 1
    }
    return false
}

# monoLateDepsMet -- every late-group member the mono references by value is
# already emitted (so the mono can be emitted now).
monoLateDepsMet: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    monoId: u64
    group: (Map u64 value: bool)
    emitted: (Map u64 value: bool)
    seen: List u64
} out bool is {
    if (seen.contains item: monoId) then return true
    seen.append monoId.u64
    elems: (List u64)
    monoElemIdsOf :ast :symtab :ctx :monoId acc: elems
    ei: u64
    en: elems.length
    for ei < en loop {
        eid: elems.get i: ei
        ceid: chaseColMono :ast :symtab tid: eid
        if (idSetHas s: group id: ceid) then {
            if (idSetHas s: emitted id: ceid) == false then return false
        }
        emo: monoOriginName :symtab tid: ceid
        if emo.length > 0 then {
            if (monoLateDepsMet
                :ast
                :symtab
                :ctx
                monoId: ceid
                :group
                :emitted
                :seen
            ) == false then return false
        }
        ei = ei + 1
    }
    return true
}

# emitUserTypeById -- emit one user RECORD/CLASS/UNION/VARIANT/PROTOCOL struct by
# id, with ctx.mainName set to its defining unit (cross-unit create macros and
# resolution read it). Idempotent via ctx.emittedUserTypes inside each emitter.
emitUserTypeById: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    tid: u64
    buf: String.borrow
} is {
    nm: typeNameOfReg9 :symtab :tid
    if nm.length == 0 then return
    duo: definedInUnitOf :symtab :tid
    sm: ctx.mainName.copy
    match (
        duo
    ) case some then {
        ctxBindMain :ctx name: duo.stringview
    } case none then null
    tt: symtab.reg.typetypeOf typeId: tid
    if tt == ztypes.ztypetype.variantType then (emitOneVariant
        :ast
        :symtab
        :ctx
        :tid
        name: nm.stringview
        :buf
    )
    if tt == ztypes.ztypetype.recordType then (emitOneRecord
        :ast
        :symtab
        :ctx
        :tid
        name: nm.stringview
        :buf
    )
    if tt == ztypes.ztypetype.classType then (emitOneRecord
        :ast
        :symtab
        :ctx
        :tid
        name: nm.stringview
        :buf
    )
    if tt == ztypes.ztypetype.unionType then (emitUnionMono
        :ast
        :symtab
        :ctx
        :tid
        name: nm.stringview
        :buf
    )
    if tt == ztypes.ztypetype.protocolType then {
        emitOneProtocol :ast :symtab :ctx :tid name: nm.stringview :buf
    }
    if tt == ztypes.ztypetype.facetType then {
        emitOneFacet :ast :symtab :ctx :tid name: nm.stringview :buf
    }
    ctxBindMain :ctx name: sm.stringview
}

# emitMonoById -- emit one late collection/variant mono by id (dispatch on origin).
emitMonoById: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    monoId: u64
    buf: String.borrow
} is {
    if (originIsTid :symtab tid: monoId originTid: ctx.optionvalOriginTid) then {
        nm: typeNameOfReg9 :symtab tid: monoId
        emitOneVariant :ast :symtab :ctx tid: monoId name: nm.stringview :buf
        return
    }
    if (originIsTid :symtab tid: monoId originTid: ctx.resultvalOriginTid) then {
        nm2: typeNameOfReg9 :symtab tid: monoId
        emitOneVariant :ast :symtab :ctx tid: monoId name: nm2.stringview :buf
        return
    }
    if (originIsTid :symtab tid: monoId originTid: ctx.listViewOriginTid) then {
        emitListViewMono :ast :symtab :ctx :runtimeDir :monoId :buf
        return
    }
    if (originIsTid :symtab tid: monoId originTid: ctx.arrayOriginTid) then {
        emitArrayMono :ast :symtab :ctx :runtimeDir :monoId :buf
        return
    }
    if (originIsTid :symtab tid: monoId originTid: ctx.listOriginTid) then {
        emitListMono :ast :symtab :ctx :runtimeDir :monoId :buf
        return
    }
    if (originIsTid :symtab tid: monoId originTid: ctx.setOriginTid) then {
        emitSetMono :ast :symtab :ctx :runtimeDir :monoId :buf
        return
    }
    if (originIsTid :symtab tid: monoId originTid: ctx.mapOriginTid) then {
        emitMapMono :ast :symtab :ctx :runtimeDir :monoId :buf
        return
    }
}

# emitUserStructsOrdered -- emit user struct defs and the collection monos that
# embed them by value in dependency order, resolving the bidirectional
# constraint: a user record embeds an early (system-element) mono, while a late
# mono embeds a user type. Order: protocols -> early-user structs -> a fixpoint
# interleaving late monos and late-user structs. Mirrors the reference emitter's
# early/late split + fixpoint (zemitterc.py). The early collection monos and the
# system scaffolding are already emitted by emitMonos; this owns user struct
# layout (emitRecordDefsIn phase 1 no longer emits structs).
# collectLateMonosKind -- append late monos of one origin to acc. Called in
# kind-priority order so a mono returned by value by another (List.listview ->
# ListView, Map.get -> optionval) is collected, and thus emitted, before it.
collectLateMonosKind: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    originTid: u64
    userList: List u64
    acc: List u64
    last: u64
} is {
    tm: u64
    for tm < last loop {
        if (originIsTid :symtab tid: tm :originTid) then {
            if (monoIsLate :ast :symtab :ctx monoId: tm :userList) then acc.append tm.u64
        }
        tm = tm + 1
    }
}

# fnptrTypedefEligible -- a FUNCTION type worth a `_ft` typedef: a real spec /
# free function / method defined in an emittable unit. Synthetic create/==/!=
# carry no definedInUnit; generic templates and monos are skipped.
# stdFnRefEmittable -- a FUNCTION worth a reference cname / _ft typedef:
# emittable-unit fns always; a runtime-backed unit's fn only when it is a
# BODIED (non-native), DEMANDED free fn (natives keep routing through the
# declaration-driven call emitter and have no id-cname definition).
stdFnRefEmittable: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx fid: u64} out bool is {
    duo9: definedInUnitOf :symtab tid: fid
    match (
        duo9
    ) case some then {
        if (isEmittableFileUnit name: duo9.stringview) then return true
        if (fnIsNativeId :symtab :fid) then return false
        # demand is recorded under the composed "unit.fn" key; read the fn
        # name off the id-keyed registry entry to compose it
        te9: symtab.reg.typeById.get key: fid
        match (
            te9
        ) case some then {
            return (
                stdFnUndemanded :ast :symtab unitName: duo9.stringview fnName: te9.name.stringview
            ) == false
        } case none then {
            return false
        }
    } case none then {
        return false
    }
}

fnptrTypedefEligible: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx tid: u64} out bool is {
    if (isGenericType :symtab :tid) then return false
    mo: monoOriginName :symtab :tid
    if mo.length > 0 then return false
    return (stdFnRefEmittable :ast :symtab :ctx fid: tid)
}

# fnRegReturnId -- a FUNCTION type's registered return type id (0 when none).
fnRegReturnId: function {symtab: zenv.ZSymbolTable tid: u64} out u64 is {
    t: symtab.reg.typeById.get key: tid
    match (
        t
    ) case some then {
        rto: t.returnTypeId
        match (
            rto
        ) case some then {
            return rto
        } case none then {
            return 0
        }
    } case none then {
        return 0
    }
}

# fnptrRetTypeC -- C return type for a FUNCTION's `_ft` typedef. The return type
# is read from funcReturnNode (the registry returnTypeId is not populated for
# top-level functions) via the node stamp, mirroring fnReturnTypeId.
fnptrRetTypeC: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx tid: u64} out String is {
    rtid: u64
    rno: symtab.typing.funcReturnNode.get key: tid
    match (
        rno
    ) case some then {
        rtid = stampIdOf :symtab nid: rno
    } case none then null
    if rtid == 0 then rtid = fnRegReturnId :symtab :tid
    if rtid == 0 then return "void".string
    rn: typeNameOfReg9 :symtab tid: rtid
    if rtid == ctx.strTid then return "\{ctx.strC}_t"
    if rtid == ctx.svTid then return "\{ctx.svC}_t"
    rc: scalarCTypeFor :symtab name: rn.stringview tid: rtid
    if rc.length > 0 then return rc
    rr: typeRefC :ast :symtab :ctx tid: rtid thisTid: 0
    if rr.length > 0 then return rr
    return "int64_t".string
}

# fnptrParamTypeC -- C type for one param of a FUNCTION's `_ft` typedef, applying
# the same pointer promotions as fnSignature so the typedef matches the emitted
# signature.
fnptrParamTypeC: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    fid: u64
    pname: StringView
    pid: u64
} out String is {
    ct: typeRefC :ast :symtab :ctx tid: pid thisTid: 0
    ptrp: false
    if (symtab.typing.childOwnershipIs
        pool: ast.names
        parentTypeId: fid
        name: pname
        own: ztypes.zparamownership.takeMode
    ) == false when (isReftypeParam :ast :symtab :ctx tid: pid) then {
        ptrp = true
    } else {
        if (isBorrowStringParam :ast :symtab :fid :pname :pid) then ptrp = true
    }
    if (isListPtrParam :ast :symtab :fid :pname tid: pid) then ptrp = true
    if (isSetMapPtrParam :ast :symtab :fid :pname tid: pid) then ptrp = true
    if ptrp then {
        if ct.length > 0 then {
            ctp: "\{ct}*"
            ct = ctp
        }
    }
    if ct.length == 0 then return "int64_t".string
    return ct
}

# ensureFwdStruct -- forward-declare a user record/class referenced by a fnptr
# typedef (a pointer-to-incomplete or uncalled by-value return typedef is legal
# C). Guarded so emitUserStructsOrdered later emits the named struct body.
ensureFwdStruct: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64 buf: String.borrow} is {
    nmS: typeNameOfReg9 :symtab :tid
    cTypeLk5: scalarCTypeFor :symtab name: nmS.stringview :tid
    if cTypeLk5.length > 0 then return
    duo5: definedInUnitOf :symtab :tid
    match (
        duo5
    ) case some then {
        if (isEmittableFileUnit name: duo5.stringview) == false then return
    } case none then null
    tt: symtab.reg.typetypeOf typeId: tid
    isStruct: false
    if tt == ztypes.ztypetype.recordType then isStruct = true
    if tt == ztypes.ztypetype.classType then isStruct = true
    if isStruct then {
        if (originIsTid :symtab :tid originTid: ctx.strOriginTid) then isStruct = false
        if (originIsTid :symtab :tid originTid: ctx.arrayOriginTid) then isStruct = false
    }
    if isStruct then {
        o: ctx.fwdDeclaredTypes.get key: tid
        match (
            o
        ) case some then null case none then {
            nm: typeNameOfReg9 :symtab :tid
            cn: symtab.reg.cnameOf :tid
            ctx.fwdDeclaredTypes.set key: tid.u64 value: true
            l0: "typedef struct \{cn}_t \{cn}_t;\n"
            buf.append l0.stringview
        }
    }
}

# emitOneFnptrTypedef -- emit one `typedef RET (*<cname>_ft)(PARAMS);`,
# dependency-first (fnptr-typed params emitted before this one) with referenced
# structs forward-declared. `seen` dedupes by tid.
# isComplexFnptrParam -- a PROTOCOL/FACET/UNION/VARIANT type is not cleanly
# forward-declarable as a by-value fnptr param/return (vtable fat pointers,
# anonymous tagged-union structs); a function using one is never an fnptr value.
isComplexFnptrParam: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx tid: u64} out bool is {
    nm: typeNameOfReg9 :symtab :tid
    ct: tid
    can: userFnId :ast :symtab :ctx name: nm.stringview
    if can > 0 then ct = can
    tt: symtab.reg.typetypeOf typeId: ct
    if tt == ztypes.ztypetype.protocolType then return true
    if tt == ztypes.ztypetype.facetType then return true
    if tt == ztypes.ztypetype.unionType then return true
    if tt == ztypes.ztypetype.variantType then return true
    return false
}

emitOneFnptrTypedef: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    tid: u64
    seen: List u64
    fnOwner: (Map u64 value: u64)
    buf: String.borrow
} is {
    if (seen.contains item: tid) then return
    seen.append tid.u64
    pNames: (List String)
    pIds: (List u64)
    pIdsNm: (List u64)
    recFieldLists :ast :symtab :tid names: pNames ids: pIds nameIds: pIdsNm
    # A method's `this`/self-typed receiver child is a fresh shell named after
    # the owner; resolve it to the owner's canonical id so the typedef matches
    # the method's emitted signature (a by-name canonicalization can land on an
    # unrelated same-named type, e.g. a stdlib generic template).
    ownT9: u64
    fno9: fnOwner.get key: tid
    match (
        fno9
    ) case some then {
        ownT9 = fno9
    } case none then null
    ownNm9: typeNameOfReg9 :symtab tid: ownT9
    rIds9: (List u64)
    ri9: u64
    rn9: pIds.length
    for ri9 < rn9 loop {
        rpv9: pIds.get i: ri9
        if ownT9 > 0 then {
            rpn9: pNames.get i: ri9
            rtn9: typeNameOfReg9 :symtab tid: rpv9
            isRecv9: false
            if rpn9.stringview == "this" then isRecv9 = true
            if rtn9.stringview == "this" then isRecv9 = true
            if rtn9.stringview == ownNm9.stringview then isRecv9 = true
            if rpv9 == ownT9 then isRecv9 = true
            if isRecv9 then rpv9 = ownT9
        }
        rIds9.append rpv9.u64
        ri9 = ri9 + 1
    }
    skipIt9: false
    sj9: u64
    sn9: pIds.length
    for sj9 < sn9 loop {
        spid9: rIds9.get i: sj9
        if (isComplexFnptrParam :ast :symtab :ctx tid: spid9) then skipIt9 = true
        sj9 = sj9 + 1
    }
    srt9: fnRegReturnId :symtab :tid
    if srt9 == 0 then {
        srno9: symtab.typing.funcReturnNode.get key: tid
        match (
            srno9
        ) case some then {
            srt9 = stampIdOf :symtab nid: srno9
        } case none then null
    }
    if srt9 > 0 then {
        if (isComplexFnptrParam :ast :symtab :ctx tid: srt9) then skipIt9 = true
    }
    if skipIt9 then return
    di: u64
    dn: pIds.length
    for di < dn loop {
        pidd: rIds9.get i: di
        if (symtab.reg.typetypeOf typeId: pidd) == ztypes.ztypetype.functionType then {
            emitOneFnptrTypedef :ast :symtab :ctx tid: pidd :seen :fnOwner :buf
        }
        ensureFwdStruct :symtab :ctx tid: pidd :buf
        di = di + 1
    }
    rtid: fnRegReturnId :symtab :tid
    if rtid > 0 then ensureFwdStruct :symtab :ctx tid: rtid :buf
    params: String
    pi: u64
    pn: pNames.length
    for pi < pn loop {
        pnm: pNames.get i: pi
        pidp: rIds9.get i: pi
        pct: fnptrParamTypeC :ast :symtab :ctx fid: tid pname: pnm.stringview pid: pidp
        if pi > 0 then params.append ", "
        params.append pct.stringview
        pi = pi + 1
    }
    if pn == 0 then params.append "void"
    retc: fnptrRetTypeC :ast :symtab :ctx :tid
    cb: symtab.reg.cnameOf :tid
    line: "typedef \{retc} (*\{cb}_ft)(\{params});\n"
    buf.append line.stringview
}

# emitFnptrTypedefs -- one `_ft` typedef per eligible user FUNCTION value-type so
# typeRefC's FUNCTION case (`<cname>_ft`) resolves at struct fields, params,
# locals, and signatures. Emitted before the user structs that embed them.
emitFnptrTypedefs: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx buf: String.borrow} is {
    last: symtab.reg.nextTypeId
    seen: (List u64)
    # method FUNCTION tid -> owning object tid, for receiver-param resolution
    fnOwner: (Map u64 value: u64)
    with fociter: symtab.typing.typeChild.iterate do for foc: fociter loop {
        fco: symtab.typing.childTypeById.get key: foc.childNameId
        match (
            fco
        ) case some then {
            if (symtab.reg.typetypeOf typeId: fco) == ztypes.ztypetype.functionType then {
                fpt0: symtab.reg.typetypeOf typeId: foc.parentTypeId
                isObj0: false
                if fpt0 == ztypes.ztypetype.recordType then isObj0 = true
                if fpt0 == ztypes.ztypetype.classType then isObj0 = true
                if fpt0 == ztypes.ztypetype.unionType then isObj0 = true
                if fpt0 == ztypes.ztypetype.variantType then isObj0 = true
                if fpt0 == ztypes.ztypetype.protocolType then isObj0 = true
                if fpt0 == ztypes.ztypetype.facetType then isObj0 = true
                if isObj0 then fnOwner.set key: fco value: foc.parentTypeId
            }
        } case none then null
    }
    t0: u64
    for t0 < last loop {
        if (symtab.reg.typetypeOf typeId: t0) == ztypes.ztypetype.functionType then {
            if (fnptrTypedefEligible :ast :symtab :ctx tid: t0) then {
                emitOneFnptrTypedef :ast :symtab :ctx tid: t0 :seen :fnOwner :buf
            }
        }
        t0 = t0 + 1
    }
}

emitUserStructsOrdered: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    buf: String.borrow
} is {
    last: symtab.reg.nextTypeId
    userList: (List u64)
    buildUserTypeList :symtab :ctx acc: userList
    # user PROTOCOLs upfront (fat pointer; no by-value user embedding)
    tp: u64
    for tp < last loop {
        if (symtab.reg.typetypeOf typeId: tp) == ztypes.ztypetype.protocolType then {
            pgen: isGenericType :symtab tid: tp
            pmo: monoOriginName :symtab tid: tp
            if pmo.length == 0 when pgen == false then {
                pduo: definedInUnitOf :symtab tid: tp
                match (
                    pduo
                ) case some then {
                    if (isEmittableFileUnit name: pduo.stringview) then {
                        emitUserTypeById :ast :symtab :ctx tid: tp :buf
                    }
                } case none then null
            }
        }
        tp = tp + 1
    }
    # late collection/variant monos (the by-value kinds embedding a user type)
    lateGroup: (List u64)
    (collectLateMonosKind
        :ast
        :symtab
        :ctx
        originTid: ctx.optionvalOriginTid
        :userList
        acc: lateGroup
        :last
    )
    (collectLateMonosKind
        :ast
        :symtab
        :ctx
        originTid: ctx.resultvalOriginTid
        :userList
        acc: lateGroup
        :last
    )
    (collectLateMonosKind
        :ast
        :symtab
        :ctx
        originTid: ctx.listViewOriginTid
        :userList
        acc: lateGroup
        :last
    )
    (collectLateMonosKind
        :ast
        :symtab
        :ctx
        originTid: ctx.listOriginTid
        :userList
        acc: lateGroup
        :last
    )
    (collectLateMonosKind
        :ast
        :symtab
        :ctx
        originTid: ctx.setOriginTid
        :userList
        acc: lateGroup
        :last
    )
    (collectLateMonosKind
        :ast
        :symtab
        :ctx
        originTid: ctx.mapOriginTid
        :userList
        acc: lateGroup
        :last
    )
    # membership id-set mirroring lateGroup (the list keeps emission order)
    lateSet: (Map u64 value: bool)
    li0: u64
    ln0: lateGroup.length
    for li0 < ln0 loop {
        lv0: lateGroup.get i: li0
        lateSet.set key: lv0 value: true
        li0 = li0 + 1
    }
    # closure: a user struct embedding a late-group member by value is late too
    emptySet: (Map u64 value: bool)
    changed: true
    for changed loop {
        changed = false
        ui: u64
        un: userList.length
        for ui < un loop {
            uid: userList.get i: ui
            if (idSetHas s: lateSet id: uid) == false then {
                if (userDefnRefsUnemitted
                    :ast
                    :symtab
                    :ctx
                    typeId: uid
                    group: lateSet
                    emitted: emptySet
                ) then {
                    lateGroup.append uid.u64
                    lateSet.set key: uid value: true
                    changed = true
                }
            }
            ui = ui + 1
        }
    }
    # early-user structs: users not in the late group, in type-id order
    # (preEmitEmbeddedTypes inside each emitter fixes intra-pass user->user order)
    e0: u64
    n0: userList.length
    for e0 < n0 loop {
        uid0: userList.get i: e0
        if (idSetHas
            s: lateSet
            id: uid0
        ) == false then emitUserTypeById :ast :symtab :ctx tid: uid0 :buf
        e0 = e0 + 1
    }
    # fixpoint: emit late monos + late-user structs in dependency order
    emittedSet: (Map u64 value: bool)
    totalPend: lateGroup.length
    emittedCount: u64
    done: false
    stuck: false
    for done == false loop {
        progressed: false
        pi: u64
        pn: lateGroup.length
        for pi < pn loop {
            x: lateGroup.get i: pi
            if (idSetHas s: emittedSet id: x) == false then {
                xorigin: monoOriginName :symtab tid: x
                if xorigin.length > 0 then {
                    seen: (List u64)
                    if (monoLateDepsMet
                        :ast
                        :symtab
                        :ctx
                        monoId: x
                        group: lateSet
                        emitted: emittedSet
                        :seen
                    ) then {
                        emitMonoById :ast :symtab :ctx :runtimeDir monoId: x :buf
                        emittedSet.set key: x value: true
                        emittedCount = emittedCount + 1
                        progressed = true
                    }
                } else {
                    if (userDefnRefsUnemitted
                        :ast
                        :symtab
                        :ctx
                        typeId: x
                        group: lateSet
                        emitted: emittedSet
                    ) == false then {
                        emitUserTypeById :ast :symtab :ctx tid: x :buf
                        emittedSet.set key: x value: true
                        emittedCount = emittedCount + 1
                        progressed = true
                    }
                }
            }
            pi = pi + 1
        }
        if emittedCount >= totalPend then {
            done = true
        } else {
            if progressed == false then {
                done = true
                stuck = true
            }
        }
    }
    if stuck then {
        f0: u64
        f1: lateGroup.length
        for f0 < f1 loop {
            x2: lateGroup.get i: f0
            if (idSetHas s: emittedSet id: x2) == false then {
                xo2: monoOriginName :symtab tid: x2
                if xo2.length > 0 then {
                    emitMonoById :ast :symtab :ctx :runtimeDir monoId: x2 :buf
                } else {
                    emitUserTypeById :ast :symtab :ctx tid: x2 :buf
                }
                emittedSet.set key: x2 value: true
            }
            f0 = f0 + 1
        }
    }
}

emitMonos: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    buf: String.borrow
} is {
    last: symtab.reg.nextTypeId
    userListM: (List u64)
    buildUserTypeList :symtab :ctx acc: userListM
    emitCliFwdDecls :symtab :ctx :buf
    emitMainFwdDecls :symtab :ctx :buf
    # one classification sweep over the registry fills the per-category
    # worklists; the category loops below emit in the original sequence.
    # Every predicate reads only registry/typing state (immutable during
    # emission); the io-wrapper needsHas gate stays at emission time.
    wStr9: (List u64)
    wBox9: (List u64)
    wIoUnion9: (List u64)
    wCliLeaf9: (List u64)
    wSysVar9: (List u64)
    wSysRec9: (List u64)
    wValMono9: (List u64)
    wOptRes9: (List u64)
    wUgUnion9: (List u64)
    wOptView9: (List u64)
    wArr9: (List u64)
    wListView9: (List u64)
    wList9: (List u64)
    wSet9: (List u64)
    wMap9: (List u64)
    wCliComp9: (List u64)
    wProto9: (List u64)
    wIoWrap9: (List u64)
    wUgRec9: (List u64)
    tcl9: u64
    for tcl9 < last loop {
        tv9: tcl9
        tt9: symtab.reg.typetypeOf typeId: tcl9
        onm9: monoOriginName :symtab tid: tcl9
        gen9: isGenericType :symtab tid: tcl9
        isMono9: onm9.length > 0
        inIo9: false
        inCli9: false
        {
            duo9: definedInUnitOf :symtab tid: tcl9
            match (
                duo9
            ) case some then {
                if duo9.stringview == "io" then inIo9 = true
                if duo9.stringview == "os" then inIo9 = true
                if duo9.stringview == "cli" then {
                    inIo9 = true
                    inCli9 = true
                }
            } case none then null
        }
        if (originIsTid :symtab tid: tcl9 originTid: ctx.strOriginTid) then wStr9.append tv9
        if (isBoxTid :symtab tid: tcl9) then wBox9.append tv9
        if tt9 == ztypes.ztypetype.unionType then {
            if isMono9 == false when gen9 == false when inIo9 then wIoUnion9.append tv9
        }
        if tt9 == ztypes.ztypetype.classType then {
            if isMono9 == false when gen9 == false then {
                if inCli9 then {
                    if (cliClassIsComposite :ast :symtab :ctx tid: tcl9) then {
                        wCliComp9.append tv9
                    } else {
                        wCliLeaf9.append tv9
                    }
                }
                if inIo9 then {
                    wnm9: typeNameOfReg9 :symtab tid: tcl9
                    if wnm9.stringview != "File" then wIoWrap9.append tv9
                }
            }
        }
        if tt9 == ztypes.ztypetype.variantType then {
            if isMono9 == false when gen9 == false then {
                if (definedInNonMain :symtab :ctx tid: tcl9) then wSysVar9.append tv9
            }
        }
        if tt9 == ztypes.ztypetype.recordType then {
            if isMono9 == false when gen9 == false when inIo9 then wSysRec9.append tv9
        }
        isValMono9: false
        if (originIsTid
            :symtab
            tid: tcl9
            originTid: ctx.optionvalOriginTid
        ) then isValMono9 = true
        if (originIsTid
            :symtab
            tid: tcl9
            originTid: ctx.resultvalOriginTid
        ) then isValMono9 = true
        if isValMono9 then {
            if (monoIsLate :ast :symtab :ctx monoId: tcl9 userList: userListM) == false then {
                wValMono9.append tv9
            }
        }
        isOptRes9: false
        if (originIsTid :symtab tid: tcl9 originTid: ctx.optionOriginTid) then isOptRes9 = true
        if (originIsTid :symtab tid: tcl9 originTid: ctx.resultOriginTid) then isOptRes9 = true
        if isOptRes9 then wOptRes9.append tv9
        if isMono9 when tt9 == ztypes.ztypetype.unionType then {
            ugu9: true
            if isOptRes9 then ugu9 = false
            if ugu9 when isValMono9 then ugu9 = false
            if ugu9 when (originIsTid
                :symtab
                tid: tcl9
                originTid: ctx.optionViewOriginTid
            ) then ugu9 = false
            if ugu9 when (isCollectionOriginTid
                :ctx
                originTid: (originTidOf :symtab tid: tcl9)
            ) then ugu9 = false
            if ugu9 then wUgUnion9.append tv9
        }
        if (originIsTid :symtab tid: tcl9 originTid: ctx.optionViewOriginTid) then {
            wOptView9.append tv9
        }
        isColKind9: false
        colDst9: u64
        if (originIsTid :symtab tid: tcl9 originTid: ctx.arrayOriginTid) then {
            isColKind9 = true
            colDst9 = 1
        }
        if (originIsTid :symtab tid: tcl9 originTid: ctx.listViewOriginTid) then {
            isColKind9 = true
            colDst9 = 2
        }
        if (originIsTid :symtab tid: tcl9 originTid: ctx.listOriginTid) then {
            isColKind9 = true
            colDst9 = 3
        }
        if (originIsTid :symtab tid: tcl9 originTid: ctx.setOriginTid) then {
            isColKind9 = true
            colDst9 = 4
        }
        if (originIsTid :symtab tid: tcl9 originTid: ctx.mapOriginTid) then {
            isColKind9 = true
            colDst9 = 5
        }
        if isColKind9 then {
            if (monoIsLate :ast :symtab :ctx monoId: tcl9 userList: userListM) == false then {
                if colDst9 == 1 then wArr9.append tv9
                if colDst9 == 2 then wListView9.append tv9
                if colDst9 == 3 then wList9.append tv9
                if colDst9 == 4 then wSet9.append tv9
                if colDst9 == 5 then wMap9.append tv9
            }
        }
        if tt9 == ztypes.ztypetype.protocolType then {
            if gen9 == false then {
                if (definedInNonMain :symtab :ctx tid: tcl9) then wProto9.append tv9
            }
        }
        if isMono9 then {
            ugr9: false
            if tt9 == ztypes.ztypetype.recordType then ugr9 = true
            if tt9 == ztypes.ztypetype.classType then ugr9 = true
            if ugr9 when (isCollectionOriginTid
                :ctx
                originTid: (originTidOf :symtab tid: tcl9)
            ) then ugr9 = false
            if ugr9 when (originIsTid
                :symtab
                tid: tcl9
                originTid: ctx.arrayOriginTid
            ) then ugr9 = false
            if ugr9 when (originIsTid
                :symtab
                tid: tcl9
                originTid: ctx.strOriginTid
            ) then ugr9 = false
            if ugr9 when (isBoxTid :symtab tid: tcl9) then ugr9 = false
            if ugr9 then wUgRec9.append tv9
        }
        tcl9 = tcl9 + 1
    }
    # str valtype monos are leaf PODs that user records embed by value, so emit
    # them first (before any user struct / collection mono that references them).
    tstr9: u64
    for tstr9 < wStr9.length loop {
        strId9: wStr9.get i: tstr9
        emitStrMono :symtab :ctx :runtimeDir monoId: strId9 :buf
        tstr9 = tstr9 + 1
    }
    # builtin Box monos (heap pointers): destructor-only, leaf -- emit early.
    tbox9: u64
    for tbox9 < wBox9.length loop {
        boxId9: wBox9.get i: tbox9
        emitBoxMono :ast :symtab :ctx monoId: boxId9 :buf
        tbox9 = tbox9 + 1
    }
    # reachable non-mono system UNIONs (IoError) -- the error payload of the
    # Result monos; emit before them so the mono destructors can call IoError's.
    tsu: u64
    for tsu < wIoUnion9.length loop {
        iuId9: wIoUnion9.get i: tsu
        iun: typeNameOfReg9 :symtab tid: iuId9
        emitUnionMono :ast :symtab :ctx tid: iuId9 name: iun.stringview :buf
        tsu = tsu + 1
    }
    emitIoFileClass :symtab :ctx :buf
    emitNetClasses :symtab :ctx :buf
    # reachable cli LEAF classes (FlagDef/OptionDef/PositionalDef) -- pure-string
    # classes the List monos below embed; emitted before those monos.
    tclf: u64
    for tclf < wCliLeaf9.length loop {
        clfId9: wCliLeaf9.get i: tclf
        clfn: typeNameOfReg9 :symtab tid: clfId9
        emitOneRecord :ast :symtab :ctx tid: clfId9 name: clfn.stringview :buf
        tclf = tclf + 1
    }
    # reachable non-mono system VARIANTs (parseerror, seekorigin, ...) --
    # payloads of the variant monos / used directly.
    tsv: u64
    for tsv < wSysVar9.length loop {
        svId9: wSysVar9.get i: tsv
        svn: typeNameOfReg9 :symtab tid: svId9
        emitOneVariant :ast :symtab :ctx tid: svId9 name: svn.stringview :buf
        tsv = tsv + 1
    }
    # reachable non-mono system RECORDs (filestat) -- the ok payload of a Result
    # mono; after its filekind variant, before the Result monos that box it.
    tsr: u64
    for tsr < wSysRec9.length loop {
        srId9: wSysRec9.get i: tsr
        srn: typeNameOfReg9 :symtab tid: srId9
        emitOneRecord :ast :symtab :ctx tid: srId9 name: srn.stringview :buf
        tsr = tsr + 1
    }
    # optionval + resultval variant monos -- iterators/collection-gets /
    # parsers return them by value (payloads now resolvable).
    tido: u64
    for tido < wValMono9.length loop {
        vmId9: wValMono9.get i: tido
        oovn: typeNameOfReg9 :symtab tid: vmId9
        emitOneVariant :ast :symtab :ctx tid: vmId9 name: oovn.stringview :buf
        tido = tido + 1
    }
    # Option union monos (tag + void* data heap payload) -- reftype
    # option returns (string strip/split, map get over reftype).
    tiu: u64
    for tiu < wOptRes9.length loop {
        orId9: wOptRes9.get i: tiu
        uvn: typeNameOfReg9 :symtab tid: orId9
        emitUnionMono :ast :symtab :ctx tid: orId9 name: uvn.stringview :buf
        tiu = tiu + 1
    }
    # user generic UNION monos (e.g. MyOption<i64>): struct + tags via
    # emitUnionMono. The wUgRec9 list handles only RECORD/CLASS; system
    # option/result monos are handled above.
    tugu9: u64
    for tugu9 < wUgUnion9.length loop {
        uguId9: wUgUnion9.get i: tugu9
        uguvn9: typeNameOfReg9 :symtab tid: uguId9
        emitUnionMono :ast :symtab :ctx tid: uguId9 name: uguvn9.stringview :buf
        tugu9 = tugu9 + 1
    }
    # OptionView structs -- the borrowed-view option every collection
    # iterator yields; emitted before the collections that reference it.
    tiov: u64
    for tiov < wOptView9.length loop {
        ovId9: wOptView9.get i: tiov
        emitOptionViewMono :symtab :ctx monoId: ovId9 :buf
        tiov = tiov + 1
    }
    # ListView structs next -- a List's listview companion references
    # the ListView struct by value.
    tarr9: u64
    for tarr9 < wArr9.length loop {
        arrId9: wArr9.get i: tarr9
        emitArrayMono :ast :symtab :ctx :runtimeDir monoId: arrId9 :buf
        tarr9 = tarr9 + 1
    }
    tid: u64
    for tid < wListView9.length loop {
        lvId9: wListView9.get i: tid
        emitListViewMono :ast :symtab :ctx :runtimeDir monoId: lvId9 :buf
        tid = tid + 1
    }
    tid2: u64
    for tid2 < wList9.length loop {
        liId9: wList9.get i: tid2
        emitListMono :ast :symtab :ctx :runtimeDir monoId: liId9 :buf
        tid2 = tid2 + 1
    }
    # Set monos last -- the compact-dict + SetIter; needs its element's
    # OptionView (above) already defined.
    tset: u64
    for tset < wSet9.length loop {
        seId9: wSet9.get i: tset
        emitSetMono :ast :symtab :ctx :runtimeDir monoId: seId9 :buf
        tset = tset + 1
    }
    # Map monos -- the compact-dict over key+value; get's return optionval
    # (emitted above) supplies the value type.
    tmap: u64
    for tmap < wMap9.length loop {
        maId9: wMap9.get i: tmap
        emitMapMono :ast :symtab :ctx :runtimeDir monoId: maId9 :buf
        tmap = tmap + 1
    }
    # reachable cli COMPOSITE classes (Spec/Parsed) -- after the List/Map monos
    # they embed; Parsed was forward-declared above for the Result mono destroy.
    tclc: u64
    for tclc < wCliComp9.length loop {
        clcId9: wCliComp9.get i: tclc
        clcn: typeNameOfReg9 :symtab tid: clcId9
        fwd9: false
        if clcn.stringview == "Parsed" then fwd9 = true
        (emitCliCompositeClass
            :ast
            :symtab
            :ctx
            tid: clcId9
            name: clcn.stringview
            fwdDeclared: fwd9
            :buf
        )
        tclc = tclc + 1
    }
    # reachable system PROTOCOLs (Reader/Writer/Closer/Seeker) -- emitted after
    # the collection monos their vtable function-pointer signatures reference.
    tsp: u64
    for tsp < wProto9.length loop {
        spId9: wProto9.get i: tsp
        spn: typeNameOfReg9 :symtab tid: spId9
        emitOneProtocol :ast :symtab :ctx tid: spId9 name: spn.stringview :buf
        tsp = tsp + 1
    }
    # reachable io wrapper CLASSes (BufWriter/BufReader/TextWriter/TextReader) --
    # after the protocols their .lock fields hold. File has its own emitter.
    # The needsHas gate stays here (needs may accrue during emission).
    tsc: u64
    for tsc < wIoWrap9.length loop {
        scId9: wIoWrap9.get i: tsc
        scn: typeNameOfReg9 :symtab tid: scId9
        unb9: "io_uses_\{scn}"
        if (needsHas :ctx name: unb9.stringview) then {
            emitOneRecord :ast :symtab :ctx tid: scId9 name: scn.stringview :buf
        }
        tsc = tsc + 1
    }
    # user generic class/record monos (e.g. Box<i64>): RECORD/CLASS monos whose
    # origin is a user generic type. The collection / array / str / option / box
    # monos are handled by their own worklists; emit the rest via emitOneRecord.
    tug9: u64
    for tug9 < wUgRec9.length loop {
        ugId9: wUgRec9.get i: tug9
        ugnm9: typeNameOfReg9 :symtab tid: ugId9
        emitOneRecord :ast :symtab :ctx tid: ugId9 name: ugnm9.stringview :buf
        tug9 = tug9 + 1
    }
}

# emitRecordDefs -- main-unit record structs + meta_create constructors
# (scalar/record fields; the create alias mirrors the reference).
emitRecordDefs: function {program: Node symtab: zenv.ZSymbolTable ctx: Ctx buf: String.borrow} is {
    match (
        program
    ) case program then {
        # 3 phases across ALL file units so cross-unit refs resolve: every unit's
        # structs, then every unit's fwd-decls, then every unit's method bodies.
        ph: 1.u64
        for ph <= 3 loop {
            uCnt9h: program.ast.units.length
            uIdx9h: u64
            for uIdx9h < uCnt9h loop {
                uId9: program.ast.units.get i: uIdx9h
                uIdx9h = uIdx9h + 1
                opId9: u32
                un9: String
                {
                    u: program.ast.nodes.get i: (uId9 - 1).u64
                    if u.namedoperation then {
                        un: zast.poolTextCopy pool: program.ast.names ref: u.name
                        if (isEmittableFileUnit name: un.stringview) then {
                            opId9 = u.operation
                            un9 = un.copy
                        }
                    }
                }
                if opId9 > 0 then {
                    sm: ctx.mainName.copy
                    ctxBindMain :ctx name: un9.stringview
                    (emitRecordDefsIn
                        :symtab
                        :ctx
                        ast: program.ast
                        mainOpId: opId9
                        phase: ph
                        :buf
                    )
                    ctxBindMain :ctx name: sm.stringview
                }
            }
            ph = ph + 1
        }
    } else null
}

# emitDefMethods -- emit a record/class def's as-block methods (forward decls
# when declOnly, bodies otherwise). Used by the method passes of emitRecordDefsIn.
emitDefMethods: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    bm: Node
    declOnly: bool
    buf: String.borrow
} is {
    match (
        bm
    ) case namedoperation then {
        if (isRecordDef9 n: (ast.nodes.get i: (bm.operation - 1).u64)) then {
            nm: zast.nameTextCopy :ast ref: bm.name
            rid: userFnId :ast :symtab :ctx name: nm.stringview
            if rid > 0 then (emitRecordMethods
                :ast
                :symtab
                :ctx
                tid: rid
                op: (ast.nodes.get i: (bm.operation - 1).u64)
                :declOnly
                :buf
            )
        }
        if (isClassDef9 n: (ast.nodes.get i: (bm.operation - 1).u64)) then {
            nmc: zast.nameTextCopy :ast ref: bm.name
            cid9: userFnId :ast :symtab :ctx name: nmc.stringview
            if cid9 > 0 then {
                (emitRecordMethods
                    :ast
                    :symtab
                    :ctx
                    tid: cid9
                    op: (ast.nodes.get i: (bm.operation - 1).u64)
                    :declOnly
                    :buf
                )
            }
        }
    } else null
}

# isProtocolDef9 -- an objectdef whose kind is PROTOCOL.
isProtocolDef9: function {n: Node} out bool is {
    match (
        n
    ) case objectdef then {
        if n.kind == zast.nodetype.protocolDef then {
            return true
        } else {
            return false
        }
    } else {
        return false
    }
}

# protoChildMethods -- a protocol's spec-method children (FUNCTION children,
# excluding the synth create/borrow), names + ids in registration order.
protoChildMethods: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    tid: u64
    names: List String
    ids: List u64
    nameIds: List u64
} is {
    b4: symtab.typing.childIndex.get key: tid
    match (
        b4
    ) case some then {
        with rit4: b4.rows.iterate do for ri4: rit4 loop {
            tc: symtab.typing.typeChild.get i: ri4
            cto: symtab.typing.childTypeById.get key: tc.childNameId
            match (
                cto
            ) case some then {
                if (symtab.reg.typetypeOf typeId: cto) == ztypes.ztypetype.functionType then {
                    isSynth: false
                    if tc.nameId == wkCreate then isSynth = true
                    if tc.nameId == wkBorrow then isSynth = true
                    if (isSynth) == false then {
                        cnBe4: ast.names.texts.get i: (tc.nameId - 1).u64
                        cn0: cnBe4.copy
                        names.append cn0
                        ids.append cto
                        nid0: tc.nameId
                        nameIds.append nid0
                    }
                }
            } case none then null
        }
    } case none then null
}

# methodRetCtype -- a method's C return type via the registry returnTypeId
# (scalars/records/classes resolve through typeRefC); "void" when unset.
methodRetCtype: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    mid: u64
    thisTid: u64
} out String is {
    mro: ztypecheck.methodReturnOf st: symtab :mid
    match (
        mro
    ) case some then {
        rr: typeRefC :ast :symtab :ctx tid: mro :thisTid
        if rr.length > 0 then return rr
    } case none then null
    return "void".string
}

# protoParamCtype -- a protocol spec-method param's C type: typeRefC, with a
# `*` for collection params (List/ListView/Map and the Bytes/ByteView typedefs),
# which the vtable function pointers and wrappers pass by pointer.
protoParamCtype: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    pid: u64
    thisTid: u64
} out String is {
    # The spec param is usually a SHELL named after the system type; canonicalize
    # it by name (resolveTypeIdByName covers system types) so typeRefC resolves it
    # (and chases ByteView/Bytes to their collection mono). But a param already
    # resolved to a CANONICAL id (definedInUnit set, e.g. system i64) is trusted
    # as-is -- re-resolving "i64" by name would wrongly pick up a user shadow of
    # the scalar in the main unit. Mirrors typeRefC's none-branch shell gate.
    cpid: pid
    pidDu9: definedInUnitOf :symtab tid: pid
    pidShell9: false
    match (
        pidDu9
    ) case some then null case none then {
        pidShell9 = true
    }
    if pidShell9 then {
        pn9: typeNameOfReg9 :symtab tid: pid
        rcid: resolveTypeIdByName :ast :symtab :ctx name: pn9.stringview
        if rcid > 0 then cpid = rcid
    }
    pct: typeRefC :ast :symtab :ctx tid: cpid :thisTid
    if pct.length == 0 then pct = "int64_t".string
    isCol: false
    if (chaseColMono :ast :symtab tid: cpid) != cpid then isCol = true
    pco9: monoOriginName :symtab tid: cpid
    if (isCollectionOriginTid :ctx originTid: (originTidOf :symtab tid: cpid)) then isCol = true
    if isCol then return "\{pct}*"
    return pct
}

# emitOneProtocol -- the protocol value representation: vtable typedef (one
# function pointer per spec method, `this` dropped for a leading void*),
# the fat-pointer struct {data, vtable, destroy}, and the destroy helper.
# facetImplTids -- the deduplicated impl type ids conforming to facet `tid`,
# in conformance-row (declaration) order.
facetImplTids: function {symtab: zenv.ZSymbolTable tid: u64 acc: List u64} is {
    with citer: symtab.typing.conformance.iterate do for row: citer loop {
        if row.specTypeId == tid then {
            if (acc.contains item: row.implTypeId) == false then acc.append row.implTypeId
        }
    }
}

# emitOneFacet -- the facet value representation: a vtable typedef (one fn
# pointer per spec, void* receiver), an inline data union over the conforming
# impls (copied by value -- facets are valtype existentials), and the
# {vtable*, data} struct. No destroy helper: impls are valtypes. The impl
# structs are pre-emitted first because the union embeds them by value.
emitOneFacet: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    tid: u64
    name: StringView
    buf: String.borrow
} is {
    egf9: ctx.emittedUserTypes.get key: tid
    match (
        egf9
    ) case some then {
        return
    } case none then null
    ctx.emittedUserTypes.set key: tid.u64 value: true
    pbase: cnameOf :tid :name
    impls9: (List u64)
    facetImplTids :symtab :tid acc: impls9
    preEmitEmbeddedTypes :ast :symtab :ctx ids: impls9 :buf
    mnames: (List String)
    mids: (List u64)
    midsNm: (List u64)
    protoChildMethods :ast :symtab :tid names: mnames ids: mids nameIds: midsNm
    vfuncs: String
    mi: u64
    mn: mnames.length
    for mi < mn loop {
        mname: mnames.get i: mi
        smid: mids.get i: mi
        mroP: ztypecheck.methodReturnOf st: symtab mid: smid
        match (
            mroP
        ) case some then {
            maybePreEmitElem :ast :symtab :ctx eid: mroP :buf
        } case none then null
        ret: methodRetCtype :ast :symtab :ctx mid: smid thisTid: tid
        vparams: "void*".string
        pnames: (List String)
        pids: (List u64)
        pidsNm: (List u64)
        recFieldLists :ast :symtab tid: smid names: pnames ids: pids nameIds: pidsNm
        preEmitEmbeddedTypes :ast :symtab :ctx ids: pids :buf
        pi: u64
        pn: pnames.length
        for pi < pn loop {
            pnm: pnames.get i: pi
            pid: pids.get i: pi
            # spec receivers are dropped by resolveSpecFn; the name and id
            # legs cover a self-typed param without a by-name resolution
            isThis: false
            if pnm.stringview == "this" then isThis = true
            if pid == tid then isThis = true
            if (isThis) == false then {
                pct: protoParamCtype :ast :symtab :ctx :pid thisTid: tid
                vparams.append ", "
                vparams.append pct.stringview
            }
            pi = pi + 1
        }
        vline: "    \{ret} (*\{mname})(\{vparams});\n"
        vfuncs.append vline.stringview
        mi = mi + 1
    }
    l0: "typedef struct {\n\{vfuncs}} \{pbase}_vtable_t;\n\n"
    buf.append l0.stringview
    du9: String
    with iiter: impls9.iterate do for itid9: iiter loop {
        icn9: symtab.reg.cnameOf tid: itid9
        drow9: "    \{icn9}_t _i\{itid9};\n"
        du9.append drow9.stringview
    }
    if du9.length == 0 then du9.append "    char _none;\n"
    l1: "typedef union {\n\{du9}} \{pbase}_data_u;\n\n"
    buf.append l1.stringview
    l2: "typedef struct {\n    \{pbase}_vtable_t* vtable;\n    \{pbase}_data_u data;\n} \{pbase}_t;\n\n"
    buf.append l2.stringview
}

emitOneProtocol: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    tid: u64
    name: StringView
    buf: String.borrow
} is {
    egp9: ctx.emittedUserTypes.get key: tid
    match (
        egp9
    ) case some then {
        return
    } case none then null
    ctx.emittedUserTypes.set key: tid.u64 value: true
    pbase: cnameOf :tid :name
    mnames: (List String)
    mids: (List u64)
    midsNm: (List u64)
    protoChildMethods :ast :symtab :tid names: mnames ids: mids nameIds: midsNm
    vfuncs: String
    mi: u64
    mn: mnames.length
    for mi < mn loop {
        mname: mnames.get i: mi
        smid: mids.get i: mi
        mroP: ztypecheck.methodReturnOf st: symtab mid: smid
        match (
            mroP
        ) case some then {
            maybePreEmitElem :ast :symtab :ctx eid: mroP :buf
        } case none then null
        ret: methodRetCtype :ast :symtab :ctx mid: smid thisTid: tid
        vparams: "void*".string
        pnames: (List String)
        pids: (List u64)
        pidsNm: (List u64)
        recFieldLists :ast :symtab tid: smid names: pnames ids: pids nameIds: pidsNm
        preEmitEmbeddedTypes :ast :symtab :ctx ids: pids :buf
        pi: u64
        pn: pnames.length
        for pi < pn loop {
            pnm: pnames.get i: pi
            pid: pids.get i: pi
            ptn: typeNameOfReg9 :symtab tid: pid
            isThis: false
            if pnm.stringview == "this" then isThis = true
            if ptn.stringview == "this" then isThis = true
            if ptn.stringview == name then isThis = true
            if pid == tid then isThis = true
            if (isThis) == false then {
                pct: protoParamCtype :ast :symtab :ctx :pid thisTid: tid
                vparams.append ", "
                vparams.append pct.stringview
            }
            pi = pi + 1
        }
        vline: "    \{ret} (*\{mname})(\{vparams});\n"
        vfuncs.append vline.stringview
        mi = mi + 1
    }
    l0: "typedef struct {\n\{vfuncs}} \{pbase}_vtable_t;\n\n"
    buf.append l0.stringview
    l1: "typedef struct {\n    void* data;\n    \{pbase}_vtable_t* vtable;\n    void (*destroy)(void*);\n} \{pbase}_t;\n\n"
    buf.append l1.stringview
    l2: "static void \{pbase}_destroy(\{pbase}_t* proto) {\n    if (!proto) return;\n    if (proto->destroy) proto->destroy(proto->data);\n    proto->destroy = NULL;\n}\n\n"
    buf.append l2.stringview
}

# emitProtocolImpl -- the per-(impl,label) conformance helpers: one wrapper per
# spec method (casts void* -> impl, calls the impl method), the static vtable
# instance, the borrowed create (data=val, no destroy), and the owned
# create/destroy (heap-box the value, free + impl-destroy on drop).
emitProtocolImpl: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    implTid: u64
    implName: StringView
    protoTid: u64
    protoName: StringView
    label: StringView
    buf: String.borrow
} is {
    omn: monoOriginName :symtab tid: implTid
    if omn.length != 0 then return
    implBase: cnameOf tid: implTid name: implName
    implCtype: "\{implBase}_t"
    protoBase: cnameOf tid: protoTid name: protoName
    protoCtype: "\{protoBase}_t"
    vtableCtype: "\{protoBase}_vtable_t"
    wbase: "\{implBase}_\{label}"
    implIsClass: false
    if (symtab.reg.typetypeOf typeId: implTid) == ztypes.ztypetype.classType then implIsClass = true
    mnames: (List String)
    mids: (List u64)
    midsNm: (List u64)
    protoChildMethods :ast :symtab tid: protoTid names: mnames ids: mids nameIds: midsNm
    mi: u64
    mn: mnames.length
    for mi < mn loop {
        mname: mnames.get i: mi
        mnameId: midsNm.get i: mi
        smid: mids.get i: mi
        ret: methodRetCtype :ast :symtab :ctx mid: smid thisTid: protoTid
        wparams: "void* _data".string
        cargs: "_self".string
        if (implIsClass) == false then cargs = "(*_self)".string
        pnames: (List String)
        pids: (List u64)
        pidsNm: (List u64)
        recFieldLists :ast :symtab tid: smid names: pnames ids: pids nameIds: pidsNm
        pi: u64
        pn: pnames.length
        for pi < pn loop {
            pnm: pnames.get i: pi
            pid: pids.get i: pi
            ptn: typeNameOfReg9 :symtab tid: pid
            isThis: false
            if pnm.stringview == "this" then isThis = true
            if ptn.stringview == "this" then isThis = true
            if ptn.stringview == protoName then isThis = true
            if pid == protoTid then isThis = true
            if (isThis) == false then {
                pct: protoParamCtype :ast :symtab :ctx :pid thisTid: protoTid
                wparams.append ", "
                wparams.append pct.stringview
                wparams.append " "
                wparams.append pnm.stringview
                cargs.append ", "
                cargs.append pnm.stringview
            }
            pi = pi + 1
        }
        implMid: u64
        imo: symtab.typing.childOfId parentTypeId: implTid nameId: mnameId
        match (
            imo
        ) case some then {
            implMid = imo
        } case none then null
        implMc: String
        # a fragment-backed stdlib impl's methods carry canon-named C
        # symbols regardless of which unit is being emitted (the per-unit
        # emission pass rebinds mainName, defeating the nonmain test)
        implFrag9: false
        {
            fduW9: definedInUnitOf :symtab tid: implTid
            match (
                fduW9
            ) case some then {
                if fduW9.stringview == "io" then implFrag9 = true
                if fduW9.stringview == "os" then implFrag9 = true
                if fduW9.stringview == "cli" then implFrag9 = true
                if fduW9.stringview == "net" then implFrag9 = true
            } case none then null
        }
        if implFrag9 then {
            implMc = "\{implBase}_\{mname}"
        } else {
            if (definedInNonMain :symtab :ctx tid: implTid) then {
                implMc = "\{implBase}_\{mname}"
            } else {
                implMc = (symtab.reg.cnameOf tid: implMid)
            }
        }
        retkw: "return ".string
        if ret.stringview == "void" then retkw = "".string
        w0: "static \{ret} \{wbase}_\{mname}_wrapper(\{wparams}) {\n"
        buf.append w0.stringview
        w1: "    \{implCtype}* _self = (\{implCtype}*)_data;\n"
        buf.append w1.stringview
        w2: "    \{retkw}\{implMc}(\{cargs});\n"
        buf.append w2.stringview
        buf.append "}\n\n"
        mi = mi + 1
    }
    vi0: "static \{vtableCtype} \{wbase}_vtable = {\n"
    buf.append vi0.stringview
    mj: u64
    for mj < mn loop {
        mname2: mnames.get i: mj
        vrow: "    .\{mname2} = \{wbase}_\{mname2}_wrapper,\n"
        buf.append vrow.stringview
        mj = mj + 1
    }
    buf.append "};\n\n"
    bc0: "static \{protoCtype} \{wbase}_create(\{implCtype}* val) {\n    \{protoCtype} proto = {0};\n    proto.data = val;\n    proto.vtable = &\{wbase}_vtable;\n    proto.destroy = NULL;\n    return proto;\n}\n\n"
    buf.append bc0.stringview
    od0: "static void \{wbase}_owned_destroy(void* p) {\n"
    buf.append od0.stringview
    if (symtab.reg.hasDestructorName typeId: implTid) then {
        od1: "    \{implBase}_destroy((\{implCtype}*)p);\n"
        buf.append od1.stringview
    }
    buf.append "    free(p);\n}\n\n"
    oc0: "static \{protoCtype} \{wbase}_create_owned(\{implCtype}* val) {\n    \{protoCtype} proto = {0};\n    \{implCtype}* boxed = (\{implCtype}*)z_xmalloc(sizeof(\{implCtype}));\n    *boxed = *val;\n    proto.data = boxed;\n    proto.vtable = &\{wbase}_vtable;\n    proto.destroy = \{wbase}_owned_destroy;\n    return proto;\n}\n\n"
    buf.append oc0.stringview
}

# emitFacetImpl -- the per-(impl,label) facet conformance helpers: one
# wrapper per spec method (casts void* -> impl, calls the impl method), the
# static vtable instance, and a single copy-create (serves `.create` and
# `.borrow` -- a facet copies its source; borrow differs only at typecheck
# time). No owned variant, no heap, no destroy: impls are valtypes.
emitFacetImpl: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    implTid: u64
    implName: StringView
    facetTid: u64
    facetName: StringView
    label: StringView
    buf: String.borrow
} is {
    if (isGenericType :symtab tid: implTid) then return
    implBase: cnameOf tid: implTid name: implName
    implCtype: "\{implBase}_t"
    facetBase: symtab.reg.cnameOf tid: facetTid
    facetCtype: "\{facetBase}_t"
    vtableCtype: "\{facetBase}_vtable_t"
    wbase: "\{implBase}_\{label}"
    mnames: (List String)
    mids: (List u64)
    midsNm: (List u64)
    protoChildMethods :ast :symtab tid: facetTid names: mnames ids: mids nameIds: midsNm
    mi: u64
    mn: mnames.length
    for mi < mn loop {
        mname: mnames.get i: mi
        mnameId: midsNm.get i: mi
        smid: mids.get i: mi
        ret: methodRetCtype :ast :symtab :ctx mid: smid thisTid: facetTid
        wparams: "void* _data".string
        cargs: "(*_self)".string
        pnames: (List String)
        pids: (List u64)
        pidsNm: (List u64)
        recFieldLists :ast :symtab tid: smid names: pnames ids: pids nameIds: pidsNm
        pi: u64
        pn: pnames.length
        for pi < pn loop {
            pnm: pnames.get i: pi
            pid: pids.get i: pi
            isThis: false
            if pnm.stringview == "this" then isThis = true
            if pid == facetTid then isThis = true
            if (isThis) == false then {
                pct: protoParamCtype :ast :symtab :ctx :pid thisTid: facetTid
                wparams.append ", "
                wparams.append pct.stringview
                wparams.append " "
                wparams.append pnm.stringview
                cargs.append ", "
                cargs.append pnm.stringview
            }
            pi = pi + 1
        }
        implMid: u64
        imo: symtab.typing.childOfId parentTypeId: implTid nameId: mnameId
        match (
            imo
        ) case some then {
            implMid = imo
        } case none then null
        implMc: String
        # a fragment-backed stdlib impl's methods carry canon-named C
        # symbols regardless of which unit is being emitted (the per-unit
        # emission pass rebinds mainName, defeating the nonmain test)
        implFrag9: false
        {
            fduW9: definedInUnitOf :symtab tid: implTid
            match (
                fduW9
            ) case some then {
                if fduW9.stringview == "io" then implFrag9 = true
                if fduW9.stringview == "os" then implFrag9 = true
                if fduW9.stringview == "cli" then implFrag9 = true
                if fduW9.stringview == "net" then implFrag9 = true
            } case none then null
        }
        if implFrag9 then {
            implMc = "\{implBase}_\{mname}"
        } else {
            if (definedInNonMain :symtab :ctx tid: implTid) then {
                implMc = "\{implBase}_\{mname}"
            } else {
                implMc = (symtab.reg.cnameOf tid: implMid)
            }
        }
        retkw: "return ".string
        if ret.stringview == "void" then retkw = "".string
        w0: "static \{ret} \{wbase}_\{mname}_wrapper(\{wparams}) {\n"
        buf.append w0.stringview
        w1: "    \{implCtype}* _self = (\{implCtype}*)_data;\n"
        buf.append w1.stringview
        w2: "    \{retkw}\{implMc}(\{cargs});\n"
        buf.append w2.stringview
        buf.append "}\n\n"
        mi = mi + 1
    }
    vi0: "static \{vtableCtype} \{wbase}_vtable = {\n"
    buf.append vi0.stringview
    mj: u64
    for mj < mn loop {
        mname2: mnames.get i: mj
        vrow: "    .\{mname2} = \{wbase}_\{mname2}_wrapper,\n"
        buf.append vrow.stringview
        mj = mj + 1
    }
    buf.append "};\n\n"
    fc0: "static \{facetCtype} \{wbase}_create(\{implCtype}* val) {\n    \{facetCtype} facet = {0};\n    facet.vtable = &\{wbase}_vtable;\n    facet.data._i\{implTid} = *val;\n    return facet;\n}\n\n"
    buf.append fc0.stringview
}

# emitFacetImplsForType -- emit facet conformance helpers for every FACET the
# given impl type satisfies. Class impls are skipped (a class copied into an
# inline union would violate the valtype guarantee; the checker gap is
# front-end work).
emitFacetImplsForType: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    implTid: u64
    implName: StringView
    buf: String.borrow
} is {
    if (symtab.reg.typetypeOf typeId: implTid) != ztypes.ztypetype.recordType then return
    ftids: (List u64)
    flabels: (List String)
    with citer: symtab.typing.conformance.iterate do for row: citer loop {
        if row.implTypeId == implTid then {
            ftids.append row.specTypeId
            flabels.append row.label.copy
        }
    }
    fi: u64
    fn: ftids.length
    for fi < fn loop {
        ftid: ftids.get i: fi
        flabel: flabels.get i: fi
        if (symtab.reg.typetypeOf typeId: ftid) == ztypes.ztypetype.facetType then {
            (emitFacetImpl
                :ast
                :symtab
                :ctx
                :implTid
                :implName
                facetTid: ftid
                facetName: ""
                label: flabel.stringview
                :buf
            )
        }
        fi = fi + 1
    }
}

# emitProtocolImplsForType -- emit conformance helpers for every PROTOCOL the
# given impl type satisfies (facet conformances emit via emitFacetImplsForType).
emitProtocolImplsForType: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    implTid: u64
    implName: StringView
    buf: String.borrow
} is {
    ptids: (List u64)
    plabels: (List String)
    with citer: symtab.typing.conformance.iterate do for row: citer loop {
        if row.implTypeId == implTid then {
            ptids.append row.specTypeId
            plabels.append row.label.copy
        }
    }
    pi: u64
    pn: ptids.length
    for pi < pn loop {
        ptid: ptids.get i: pi
        plabel: plabels.get i: pi
        if (symtab.reg.typetypeOf typeId: ptid) == ztypes.ztypetype.protocolType then {
            pname: typeNameOfReg9 :symtab tid: ptid
            (emitProtocolImpl
                :ast
                :symtab
                :ctx
                :implTid
                :implName
                protoTid: ptid
                protoName: pname.stringview
                label: plabel.stringview
                :buf
            )
        }
        pi = pi + 1
    }
}

# conformanceLabelFor -- the as-block label under which implTid satisfies
# protoTid (e.g. "myreader"); "" when not found.
conformanceLabelFor: function {symtab: zenv.ZSymbolTable implTid: u64 protoTid: u64} out String is {
    res: String
    with citer: symtab.typing.conformance.iterate do for row: citer loop {
        if row.implTypeId == implTid when row.specTypeId == protoTid then {
            if res.length == 0 then res.append row.label.stringview
        }
    }
    return res
}

# emitProtocolDispatch -- a method call on a protocol-typed receiver routes
# through the vtable: `r.read b: 5` -> `r.vtable->read(r.data, 5)`.
# fileTypeIdOf -- the io File class type id if `nid` stamps as File, else 0.
fileTypeIdOf: function {symtab: zenv.ZSymbolTable ctx: Ctx nid: u64} out u64 is {
    tid: stampIdOf :symtab :nid
    if tid == 0 then return 0
    if (symtab.reg.typetypeOf typeId: tid) != ztypes.ztypetype.classType then return 0
    omn9: monoOriginName :symtab :tid
    if omn9.length != 0 then return 0
    duo9: definedInUnitOf :symtab :tid
    isIoT9: false
    match (
        duo9
    ) case some then {
        if duo9.stringview == "io" then isIoT9 = true
        if duo9.stringview == "os" then isIoT9 = true
        if duo9.stringview == "cli" then isIoT9 = true
        if duo9.stringview == "net" then isIoT9 = true
    } case none then null
    if isIoT9 then return tid
    return 0
}

# fileFromArgCoerce -- the emitted `from:` argument of a file-method call,
# projected to a by-value view when the arg is an owned String (TextWriter's
# StringLike param; ByteView args pass through unchanged). A non-lvalue
# String temp hoists for scope-exit free.
fileFromArgCoerce: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    av: StringView
} out String is {
    with fiter9: call.arguments.iterate do for fa9Id9: fiter9 loop {
        fa9: ast.nodes.get i: (fa9Id9 - 1).u64
        match (
            fa9
        ) case namedoperation then {
            opf2129: ast.nodes.get i: (fa9.operation - 1).u64
            fl9: zast.nameTextCopy :ast ref: fa9.name
            if fl9.stringview == "from" then {
                if (stampIdOf
                    :symtab
                    nid: (nodeIdOf9 n: (ast.nodes.get i: (fa9.operation - 1).u64))
                ) == ctx.strTid then {
                    fh9: (hoistBorrowValArg
                        :ast
                        :symtab
                        :ctx
                        :av
                        pid: ctx.strTid
                        paramTake: false
                        isBorrow: (hoistExprIsBorrowRooted :ast :symtab :ctx n: opf2129)
                    )
                    fb9: av.string
                    if fh9.length > 0 then fb9 = fh9
                    return (svValueForm :ctx expr: fb9.stringview isStr: true)
                }
            }
        } else null
    }
    return av.string
}

# emitFileMethodCall -- a File method (close/read/write/seek/flush), native,
# taking the receiver by pointer and collection args (Bytes/ByteView) by
# pointer. "" for any non-File receiver.
emitFileMethodCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    bn: dottedBaseAtom :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    if bn.length == 0 then return "".string
    mn: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    isFM: false
    if mn.stringview == "close" then isFM = true
    if mn.stringview == "read" then isFM = true
    if mn.stringview == "write" then isFM = true
    if mn.stringview == "seek" then isFM = true
    if mn.stringview == "flush" then isFM = true
    if mn.stringview == "writeLine" then isFM = true
    if mn.stringview == "accept" then isFM = true
    if (isFM) == false then return "".string
    bnid: dottedBaseNodeId :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    fid: fileTypeIdOf :symtab :ctx nid: bnid
    if fid == 0 then return "".string
    fc: symtab.reg.cnameOf tid: fid
    {
        fcn9: typeNameOfReg9 :symtab tid: fid
        fcc9: ioCanonCname :ast :symtab :ctx canon: fcn9.stringview
        if fcc9.length > 0 then fc = fcc9
    }
    recv: aliasResolve :ctx name: bn.stringview
    recvC: ztypes.mangleVarName name: recv.stringview
    recvExpr: "&\{recvC}"
    if (isPtrVar :ctx name: recv.stringview) then recvExpr = recvC
    isNet9: false
    {
        fduo9: definedInUnitOf :symtab tid: fid
        match (
            fduo9
        ) case some then {
            if fduo9.stringview == "net" then isNet9 = true
        } case none then null
    }
    if isNet9 then {
        needsAdd :ctx name: "net"
    } else {
        needsAdd :ctx name: "io"
        fmn: "io_file_\{mn}"
        needsAdd :ctx name: fmn.stringview
    }
    if mn.stringview == "accept" then {
        if (isNet9) == false then return "".string
        return "\{fc}_accept(\{recvExpr})"
    }
    if mn.stringview == "close" then return "\{fc}_close(\{recvExpr})"
    if mn.stringview == "flush" then return "\{fc}_flush(\{recvExpr})"
    if mn.stringview == "write" then {
        fv: ctorArgByLabel :ast :symtab :ctx :call label: "from"
        fvc: fileFromArgCoerce :ast :symtab :ctx :call av: fv.stringview
        return "\{fc}_write(\{recvExpr}, &\{fvc})"
    }
    if mn.stringview == "read" then {
        iv: ctorArgByLabel :ast :symtab :ctx :call label: "into"
        mv: ctorArgByLabel :ast :symtab :ctx :call label: "max"
        ivptr9: argIsPointerByLabel :ast :symtab :ctx :call label: "into"
        if ivptr9 then return "\{fc}_read(\{recvExpr}, \{iv}, \{mv})"
        return "\{fc}_read(\{recvExpr}, &\{iv}, \{mv})"
    }
    if mn.stringview == "seek" then {
        tv: ctorArgByLabel :ast :symtab :ctx :call label: "to"
        ov: ctorArgByLabel :ast :symtab :ctx :call label: "from"
        return "\{fc}_seek(\{recvExpr}, \{tv}, \{ov})"
    }
    if mn.stringview == "writeLine" then {
        wlv: ctorArgByLabel :ast :symtab :ctx :call label: "from"
        wlc: fileFromArgCoerce :ast :symtab :ctx :call av: wlv.stringview
        return "\{fc}_writeLine(\{recvExpr}, &\{wlc})"
    }
    return "".string
}

# ioCreateWrapper -- the wrapper name X of an `io.X.create` callable, else "".
ioCreateWrapper: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        ccn: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if ccn.stringview == "create" then {
            pb: dottedBaseAtom :ast n: (ast.nodes.get i: (n.parent - 1).u64)
            if pb.stringview == "io" then {
                return (dottedChildText :ast n: (ast.nodes.get i: (n.parent - 1).u64))
            }
        }
    } else null
    return "".string
}

# wrapperCreateArg -- one io-wrapper create arg by the create-param type: a
# protocol-lock param projects the `.lock` base to that protocol; a class-lock
# param takes the base's address; a scalar param emits the arg directly.
wrapperCreateArg: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    label: StringView
    ptid: u64
} out String is {
    prtn: typeNameOfReg9 :symtab tid: ptid
    prtid: resolveTypeIdByName :ast :symtab :ctx name: prtn.stringview
    aiter: call.arguments.iterate
    for aId9: aiter loop {
        a: ast.nodes.get i: (aId9 - 1).u64
        match (
            a
        ) case namedoperation then {
            al: zast.nameTextCopy :ast ref: a.name
            if al.stringview == label then {
                if (symtab.reg.typetypeOf typeId: prtid) == ztypes.ztypetype.protocolType then {
                    ab: dottedBaseAtom :ast n: (ast.nodes.get i: (a.operation - 1).u64)
                    abr: aliasResolve :ctx name: ab.stringview
                    abrC: ztypes.mangleVarName name: abr.stringview
                    abnid: dottedBaseNodeId :ast n: (ast.nodes.get i: (a.operation - 1).u64)
                    abtid: stampIdOf :symtab nid: abnid
                    abcb: symtab.reg.cnameOf tid: abtid
                    ablab: conformanceLabelFor :symtab implTid: abtid protoTid: prtid
                    abpfx9: "&".string
                    if (isPtrVar :ctx name: abr.stringview) then abpfx9 = "".string
                    return "\{abcb}_\{ablab}_create(\{abpfx9}\{abrC})"
                }
                if (symtab.reg.typetypeOf typeId: prtid) == ztypes.ztypetype.classType then {
                    ab2: dottedBaseAtom :ast n: (ast.nodes.get i: (a.operation - 1).u64)
                    abr2: aliasResolve :ctx name: ab2.stringview
                    abr2C: ztypes.mangleVarName name: abr2.stringview
                    ab2pfx9: "&".string
                    if (isPtrVar :ctx name: abr2.stringview) then ab2pfx9 = "".string
                    return "\{ab2pfx9}\{abr2C}"
                }
                return (emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (a.operation - 1).u64))
            }
        } else null
    }
    return "0".string
}

# emitIoWrapperCreate -- `io.BufWriter.create to: w.lock capacity: 16` ->
# z_t{id}_BufWriter_create(<projected/addressed args in param order>). "" for
# any non-io-wrapper-create callee.
emitIoWrapperCreate: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    wn: ioCreateWrapper :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    if wn.length == 0 then return "".string
    wid: resolveTypeIdByName :ast :symtab :ctx name: wn.stringview
    if wid == 0 then return "".string
    if (symtab.reg.typetypeOf typeId: wid) != ztypes.ztypetype.classType then return "".string
    cco: symtab.typing.childOfId parentTypeId: wid nameId: wkCreate
    cid: u64
    match (
        cco
    ) case some then {
        cid = cco
    } case none then null
    if cid == 0 then return "".string
    pnames: (List String)
    pids: (List u64)
    pidsNm: (List u64)
    recFieldLists :ast :symtab tid: cid names: pnames ids: pids nameIds: pidsNm
    args: String
    pi: u64
    pn: pnames.length
    for pi < pn loop {
        pnm: pnames.get i: pi
        ptid: pids.get i: pi
        astr: wrapperCreateArg :ast :symtab :ctx :call label: pnm.stringview :ptid
        if pi > 0 then args.append ", "
        args.append astr.stringview
        pi = pi + 1
    }
    wcn: cnameOf tid: wid name: wn.stringview
    un9w: "io_uses_\{wn}"
    needsAdd :ctx name: un9w.stringview
    return "\{wcn}_create(\{args})"
}

# emitIoCall -- a free io.* native call (io.readText/writeText/appendText/
# eprintln/open/exists/mkdir/.../stat/listDir): `z_io_<name>(args...)` in the
# native's parameter order, setting the per-call need so emitRuntimeIo emits
# the body. Returns "" for any non-io callee.
# isOsNoArgFn -- a no-arg os.* function (auto-called bare: os.pid / os.platform
# / os.cwd / ...). args is here too (the existing os.args leg).
isOsNoArgFn: function {name: StringView} out bool is {
    if name == "args" then return true
    if name == "pid" then return true
    if name == "ppid" then return true
    if name == "monotonicMillis" then return true
    if name == "waitAny" then return true
    if name == "platform" then return true
    if name == "arch" then return true
    if name == "cwd" then return true
    if name == "hostname" then return true
    if name == "userName" then return true
    if name == "homeDir" then return true
    if name == "envNames" then return true
    if name == "exePath" then return true
    return false
}

# osNoArgCallRhs -- a binding RHS that is a bare `os.<noArgFn>` auto-call
# (os.args / os.envNames return an owned List, so the binding's List branch
# must emit the call, not a fresh empty list).
osNoArgCallRhs: function {ast: Ast n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (osNoArgCallRhs :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case statementline then {
        return (osNoArgCallRhs :ast n: (ast.nodes.get i: (n.statementline - 1).u64))
    } case dottedpath then {
        base9: atomTextOf :ast n: (ast.nodes.get i: (n.parent - 1).u64)
        if base9.stringview != "os" then return false
        memb9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        return (isOsNoArgFn name: memb9.stringview)
    } else {
        return false
    }
}

# osNeedsSvCstr -- an os native that converts a StringView arg to a C string.
osNeedsSvCstr: function {ctx: Ctx} out bool is {
    if (needsHas :ctx name: "os_env") then return true
    if (needsHas :ctx name: "os_setEnv") then return true
    if (needsHas :ctx name: "os_unsetEnv") then return true
    if (needsHas :ctx name: "os_setCwd") then return true
    if (needsHas :ctx name: "os_spawn") then return true
    return false
}

# osNeedsErrno -- an os native that maps errno to an IoError.
osNeedsErrno: function {ctx: Ctx} out bool is {
    if (needsHas :ctx name: "os_setEnv") then return true
    if (needsHas :ctx name: "os_unsetEnv") then return true
    if (needsHas :ctx name: "os_cwd") then return true
    if (needsHas :ctx name: "os_setCwd") then return true
    if (needsHas :ctx name: "os_userName") then return true
    if (needsHas :ctx name: "os_homeDir") then return true
    if (needsHas :ctx name: "os_hostname") then return true
    if (needsHas :ctx name: "os_exePath") then return true
    return false
}

# emitOsCall -- an arg-taking os.* native (env/setEnv/unsetEnv/setCwd/exit):
# `z_os_<name>(args...)` in source order. "" for any non-os callee. (No-arg os
# fns ride the emitExpr dotted leg.)
# isNativeRuntimeUnit -- a unit whose `is native` FREE functions follow the
# runtime convention: C symbol `z_<unit>_<name>`, fragment
# `_Z_<UNIT>_<UPPER_SNAKE(name)>.inc`. system/core/collections natives use
# bespoke legacy symbols (z_stringJoin, statement-special print/panic) and
# stay outside; adding a new convention unit is one line here.
isNativeRuntimeUnit: function {name: StringView} out bool is {
    if name == "io" then return true
    if name == "os" then return true
    if name == "net" then return true
    if name == "cli" then return true
    return false
}

# lowerNativeArg -- lower one native-call argument from the DECLARED
# parameter: StringView / StringLike-generic params take a by-value view
# (String args project, interpolations hoist to a view); class and
# borrowed-List params pass by pointer; take params pass the owned value;
# scalars pass verbatim.
lowerNativeArg: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    fid: u64
    pname: StringView
    pid: u64
    op: Node
} out String is {
    isViewP9: false
    if pid == ctx.svTid then isViewP9 = true
    if (symtab.reg.typetypeOf typeId: pid) == ztypes.ztypetype.genericParam then isViewP9 = true
    if isViewP9 then {
        avh9: emitColInterpArg :ast :symtab :ctx n: op consumes: false
        if avh9.length > 0 then return (svValueForm :ctx expr: avh9.stringview isStr: true)
        av0: emitExpr :ast :symtab :ctx n: op
        if (stampIdOf :symtab nid: (nodeIdOf9 n: op)) == ctx.strTid then {
            hb9: (hoistBorrowValArg
                :ast
                :symtab
                :ctx
                av: av0.stringview
                pid: ctx.strTid
                paramTake: false
                isBorrow: (hoistExprIsBorrowRooted :ast :symtab :ctx n: op)
            )
            if hb9.length > 0 then av0 = hb9
            return (svValueForm :ctx expr: av0.stringview isStr: true)
        }
        return av0
    }
    iv9: emitInterpArgExpr :ast :symtab :ctx n: op
    if iv9.length > 0 then return iv9
    isTake9: (symtab.typing.childOwnershipIs
        pool: ast.names
        parentTypeId: fid
        name: pname
        own: ztypes.zparamownership.takeMode
    )
    needAmp9: false
    if (isTake9) == false then {
        if (isReftypeParam :ast :symtab :ctx tid: pid) then needAmp9 = true
        if (isListPtrParam :ast :symtab :fid :pname tid: pid) then needAmp9 = true
    }
    av1: emitExpr :ast :symtab :ctx n: op
    if needAmp9 when (pathIsPointer :ast :symtab :ctx n: op) == false then return "&\{av1}"
    return av1
}

# emitNativeArg -- find one native-call argument by label, else by the
# positional cursor, and lower it (lowerNativeArg).
emitNativeArg: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    fid: u64
    pname: StringView
    pid: u64
    usePos: bool
    posIdx: u64
} out String is {
    seen9: u64
    with aiter: call.arguments.iterate do for aId9: aiter loop {
        a: ast.nodes.get i: (aId9 - 1).u64
        match (
            a
        ) case namedoperation then {
            al: zast.nameTextCopy :ast ref: a.name
            if usePos then {
                if al.length == 0 then {
                    if seen9 == posIdx then {
                        return (lowerNativeArg
                            :ast
                            :symtab
                            :ctx
                            :fid
                            :pname
                            :pid
                            op: (ast.nodes.get i: (a.operation - 1).u64)
                        )
                    }
                    seen9 = seen9 + 1
                }
            } else {
                if al.stringview == pname then {
                    return (lowerNativeArg
                        :ast
                        :symtab
                        :ctx
                        :fid
                        :pname
                        :pid
                        op: (ast.nodes.get i: (a.operation - 1).u64)
                    )
                }
            }
        } else null
    }
    return "0".string
}

# emitNativeFreeFnCall -- ANY call (dotted `io.remove ...` or a bare sibling
# `remove ...` inside the unit) that resolves to an `is native` FREE function
# of a runtime-convention unit emits `z_<unit>_<name>(<args>)`, each argument
# lowered from the declared parameter (emitNativeArg). "" for anything else:
# bodied siblings fall through to the id-cname route, methods to their own
# legs, non-convention natives (stringJoin/print/panic) to theirs.
emitNativeFreeFnCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    un: String
    mn: String
    bn: dottedBaseAtom :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    if bn.length > 0 then {
        if (isNativeRuntimeUnit name: bn.stringview) == false then return "".string
        calr9: ast.nodes.get i: (call.callable - 1).u64
        mn = dottedChildText :ast n: calr9
        un = bn
    } else {
        cn0: atomTextOf :ast n: (ast.nodes.get i: (call.callable - 1).u64)
        if cn0.length == 0 then return "".string
        fid0: userFnId :ast :symtab :ctx name: cn0.stringview
        if fid0 == 0 then return "".string
        if (fnIsNativeId :symtab fid: fid0) == false then return "".string
        duo0: definedInUnitOf :symtab tid: fid0
        match (
            duo0
        ) case some then {
            if (isNativeRuntimeUnit name: duo0.stringview) == false then return "".string
            un = duo0.copy
        } case none then {
            return "".string
        }
        mn = cn0
    }
    if mn.length == 0 then return "".string
    fk9: "\{un}.\{mn}"
    fo9: ztypecheck.resolvedByKey :ast ty: symtab.typing reg: symtab.reg key: fk9
    fid: u64
    match (
        fo9
    ) case some then {
        fid = fo9
    } case none then {
        return "".string
    }
    if (symtab.reg.typetypeOf typeId: fid) != ztypes.ztypetype.functionType then return "".string
    if (fnIsNativeId :symtab :fid) == false then return "".string
    needsAdd :ctx name: un.stringview
    nk9: "\{un}_\{mn}"
    needsAdd :ctx name: nk9.stringview
    pn: (List String)
    pidl: (List u64)
    pidlNm: (List u64)
    recFieldLists :ast :symtab tid: fid names: pn ids: pidl nameIds: pidlNm
    args: String
    m: pn.length
    j: u64
    posIdx9: u64
    for j < m loop {
        pname: pn.get i: j
        pid: pidl.get i: j
        j = j + 1
        hasL9: ctorHasLabel :ast :call label: pname.stringview
        av: String
        if hasL9 then {
            av = (emitNativeArg
                :ast
                :symtab
                :ctx
                :call
                :fid
                pname: pname.stringview
                :pid
                usePos: false
                posIdx: 0
            )
        } else {
            av = (emitNativeArg
                :ast
                :symtab
                :ctx
                :call
                :fid
                pname: pname.stringview
                :pid
                usePos: true
                posIdx: posIdx9
            )
            posIdx9 = posIdx9 + 1
        }
        if args.length > 0 then args.append ", "
        args.append av.stringview
    }
    return "z_\{un}_\{mn}(\{args})"
}

# cliCreateClass -- the class name X of a `cli.X.create` callable, else "".
cliCreateClass: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        ccn: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if ccn.stringview == "create" then {
            pb: dottedBaseAtom :ast n: (ast.nodes.get i: (n.parent - 1).u64)
            if pb.stringview == "cli" then {
                return (dottedChildText :ast n: (ast.nodes.get i: (n.parent - 1).u64))
            }
        }
    } else null
    return "".string
}

# emitCliSpecCreate -- `cli.Spec.create programName: ... summary: ...` ->
# z_t{id}_Spec_create(<args in param order>). "" for any non-cli-create callee.
emitCliSpecCreate: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    cn: cliCreateClass :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    if cn.length == 0 then return "".string
    cid: cliClassTypeId :symtab :ctx name: cn.stringview
    if cid == 0 then return "".string
    cco: symtab.typing.childOfId parentTypeId: cid nameId: wkCreate
    crid: u64
    match (
        cco
    ) case some then {
        crid = cco
    } case none then null
    if crid == 0 then return "".string
    pnames: (List String)
    pids: (List u64)
    pidsNm: (List u64)
    recFieldLists :ast :symtab tid: crid names: pnames ids: pids nameIds: pidsNm
    args: String
    pi: u64
    pn: pnames.length
    for pi < pn loop {
        pnm: pnames.get i: pi
        astr: ctorArgByLabel :ast :symtab :ctx :call label: pnm.stringview
        if pi > 0 then args.append ", "
        args.append astr.stringview
        pi = pi + 1
    }
    needsAdd :ctx name: "cli"
    needsAdd :ctx name: "cli_spec_create"
    ccb: cnameOf tid: cid name: cn.stringview
    return "\{ccb}_create(\{args})"
}

# emitParsedMethodCall -- a Parsed accessor (hasFlag/option/positional), native,
# receiver by pointer (incl. the narrowed Result ok-arm projection) and the
# StringView name by pointer. "" for any non-Parsed receiver.
# emitResultCombinator -- inline lowering of the built-in result combinators
# `.orPanic` (unwrap the ok payload or abort) and `.or d:` (unwrap or default)
# on a `resultval`/`Result` receiver. Branchless statement-expression, no
# result struct call. "" when the call is not one of these.
emitResultCombinator: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    mn: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    isP9: false
    if mn.stringview == "orPanic" then isP9 = true
    isO9: false
    if mn.stringview == "or" then isO9 = true
    bothMiss9: (isP9) == false
    if bothMiss9 when (isO9) == false then return "".string
    bnid: u32
    {
        cnDp9: ast.nodes.get i: (call.callable - 1).u64
        match (
            cnDp9
        ) case dottedpath then {
            bnid = cnDp9.parent
        } else null
    }
    if bnid == 0 then return "".string
    rtid0: stampIdOf :symtab nid: (nodeIdOf9 n: (ast.nodes.get i: (bnid - 1).u64))
    rtid: chaseColMono :ast :symtab tid: rtid0
    if rtid == 0 then return "".string
    orig: monoOriginName :symtab tid: rtid
    okR9: false
    if orig.stringview == "resultval" then okR9 = true
    if orig.stringview == "Result" then okR9 = true
    if (okR9) == false then return "".string
    recvExpr: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (bnid - 1).u64)
    if recvExpr.length == 0 then return "".string
    okTag: variantTag :symtab tid: rtid arm: "ok"
    if isP9 then {
        rp9: "({ __auto_type _rc = (\{recvExpr.stringview}); if (_rc.tag != \{okTag.stringview}) z_panic(\"orPanic: result is err\"); _rc.data.ok; })"
        return rp9
    }
    argN9: call.arguments.length
    if argN9 == 0 then return "".string
    argId0: call.arguments.get i: 0
    opId9: u32
    {
        a9: ast.nodes.get i: (argId0 - 1).u64
        match (
            a9
        ) case namedoperation then {
            opId9 = a9.operation
        } else null
    }
    if opId9 == 0 then return "".string
    dExpr: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (opId9 - 1).u64)
    if dExpr.length == 0 then return "".string
    ro9: "({ __auto_type _rc = (\{recvExpr.stringview}); (_rc.tag == \{okTag.stringview}) ? _rc.data.ok : (\{dExpr.stringview}); })"
    return ro9
}

emitParsedMethodCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    bn: dottedBaseAtom :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    if bn.length == 0 then return "".string
    mn: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    isPM: false
    if mn.stringview == "hasFlag" then isPM = true
    if mn.stringview == "option" then isPM = true
    if mn.stringview == "positional" then isPM = true
    if (isPM) == false then return "".string
    bnid: dottedBaseNodeId :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    pid: fileTypeIdOf :symtab :ctx nid: bnid
    if pid == 0 then return "".string
    pcn: typeNameOfReg9 :symtab tid: pid
    if pcn.stringview != "Parsed" then return "".string
    pc: cnameOf tid: pid name: pcn.stringview
    recv: aliasResolve :ctx name: bn.stringview
    recvC: ztypes.mangleVarName name: recv.stringview
    recvExpr: "&\{recvC}"
    if (isPtrVar :ctx name: recv.stringview) then recvExpr = recvC
    needsAdd :ctx name: "cli"
    pneed: "cli_\{mn}"
    needsAdd :ctx name: pneed.stringview
    nameArg: ctorArgByLabel :ast :symtab :ctx :call label: "name"
    return "\{pc}_\{mn}(\{recvExpr}, &\{nameArg})"
}

# isLockArg -- the argument (through expression wrappers) is an `x.lock` borrow
# projection; such a value passes by address to a borrow param.
isLockArg: function {ast: Ast n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (isLockArg :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case dottedpath then {
        cn9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        return cn9.stringview == "lock"
    } else {
        return false
    }
}

# emitUserIterCall -- a manual `g.call value: X` on a user iterator class (a
# generator's iter): `z_t{id}_{Fn}_iter_call(&g, X)`; a `.lock` borrow value
# passes by address. "" for any non-user-iter `.call`.
emitUserIterCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    bn: dottedBaseAtom :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    if bn.length == 0 then return "".string
    mn: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    if mn.stringview != "call" then return "".string
    bnid: dottedBaseNodeId :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    rid0: stampIdOf :symtab nid: bnid
    if rid0 == 0 then return "".string
    iterId: rid0
    rtn9: typeNameOfReg9 :symtab tid: rid0
    cano9: (ztypecheck.walkLookupTyperef
        :ast
        ty: symtab.typing
        reg: symtab.reg
        currentUnit: ctx.mainName.stringview
        base: rtn9.stringview
    )
    match (
        cano9
    ) case some then {
        if (symtab.typing.hasChildId parentTypeId: cano9 nameId: wkCall) then iterId = cano9
    } case none then null
    if (symtab.reg.typetypeOf typeId: iterId) != ztypes.ztypetype.classType then return "".string
    itorig9: monoOriginName :symtab tid: iterId
    if itorig9.length != 0 then return "".string
    itn9: typeNameOfReg9 :symtab tid: iterId
    if (userFnId :ast :symtab :ctx name: itn9.stringview) <= 0 then return "".string
    cco9: symtab.typing.childOfId parentTypeId: iterId nameId: wkCall
    match (
        cco9
    ) case some then {
        callC9: symtab.reg.cnameOf tid: cco9
        recv9: aliasResolve :ctx name: bn.stringview
        recvC9: ztypes.mangleVarName name: recv9.stringview
        recvExpr9: "&\{recvC9}"
        if (isPtrVar :ctx name: recv9.stringview) then recvExpr9 = recvC9
        valArg9: String
        hasVal9: false
        with aiter9: call.arguments.iterate do for av9Id9: aiter9 loop {
            av9: ast.nodes.get i: (av9Id9 - 1).u64
            match (
                av9
            ) case namedoperation then {
                al9: zast.nameTextCopy :ast ref: av9.name
                if al9.stringview == "value" then {
                    hasVal9 = true
                    ve9: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (av9.operation - 1).u64)
                    if (isLockArg :ast n: (ast.nodes.get i: (av9.operation - 1).u64)) then {
                        vbase9: dottedBaseAtom :ast n: (ast.nodes.get i: (av9.operation - 1).u64)
                        vbr9: aliasResolve :ctx name: vbase9.stringview
                        vpfx9: "&".string
                        if (isPtrVar :ctx name: vbr9.stringview) then vpfx9 = "".string
                        valArg9 = "\{vpfx9}\{ve9}"
                    } else {
                        valArg9 = ve9
                    }
                }
            } else null
        }
        if hasVal9 then return "\{callC9}(\{recvExpr9}, \{valArg9})"
        return "\{callC9}(\{recvExpr9})"
    } case none then {
        return "".string
    }
}

# dispatchableTid9 -- a vtable-dispatch receiver type: protocol or facet.
dispatchableTid9: function {symtab: zenv.ZSymbolTable tid: u64} out bool is {
    tt9: symtab.reg.typetypeOf typeId: tid
    if tt9 == ztypes.ztypetype.protocolType then return true
    return tt9 == ztypes.ztypetype.facetType
}

emitProtocolDispatch: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    mn: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    if mn.length == 0 then return "".string
    if mn.stringview == "create" then return "".string
    if mn.stringview == "borrow" then return "".string
    if mn.stringview == "release" then return "".string
    rtid: dottedReceiverStampId :ast :symtab callable: (ast.nodes.get i: (call.callable - 1).u64)
    if (dispatchableTid9 :symtab tid: rtid) == false then {
        rtn0: typeNameOfReg9 :symtab tid: rtid
        if rtn0.length > 0 then {
            brid: resolveTypeIdByName :ast :symtab :ctx name: rtn0.stringview
            if (dispatchableTid9 :symtab tid: brid) then rtid = brid
        }
    }
    if (dispatchableTid9 :symtab tid: rtid) == false then return "".string
    isFacetR9: (symtab.reg.typetypeOf typeId: rtid) == ztypes.ztypetype.facetType
    recv: emitDottedReceiver :ast :symtab :ctx callable: (ast.nodes.get i: (call.callable - 1).u64)
    if recv.length == 0 then return "".string
    acc: ".".string
    xq129: ast.nodes.get i: (call.callable - 1).u64
    if (dottedReceiverIsPtr :ast :symtab :ctx callable: xq129) then acc = "->".string
    dargs: "\{recv}\{acc}data"
    if isFacetR9 then dargs = "&\{recv}\{acc}data"
    mtid9: optU64Or9 o: (symtab.typing.childOf
        pool: ast.names
        parentTypeId: rtid
        name: mn.stringview
    )
    mpNames9: (List String)
    mpIds9: (List u64)
    mpIds9Nm: (List u64)
    if mtid9 > 0 then (recFieldLists
        :ast
        :symtab
        tid: mtid9
        names: mpNames9
        ids: mpIds9
        nameIds: mpIds9Nm
    )
    vpn9: (List String)
    vi9: u64
    for vi9 < mpNames9.length loop {
        nm9: mpNames9.get i: vi9
        if nm9.stringview != "this" then vpn9.append nm9.copy
        vi9 = vi9 + 1
    }
    if vpn9.length > 0 then {
        slots9p: argSlotList :ast :call fpNames: vpn9
        valBySlot9p: (Map u64 value: String)
        ai9p: u64
        with aiter: call.arguments.iterate do for aId9: aiter loop {
            a: ast.nodes.get i: (aId9 - 1).u64
            match (
                a
            ) case namedoperation then {
                slot9p: slots9p.get i: ai9p
                if slot9p < vpn9.length then {
                    av: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (a.operation - 1).u64)
                    atid9: (stampIdOf
                        :symtab
                        nid: (nodeIdOf9 n: (ast.nodes.get i: (a.operation - 1).u64))
                    )
                    apfx9: String
                    if (chaseColMono :ast :symtab tid: atid9) != atid9 then apfx9 = "&".string
                    aco9: monoOriginName :symtab tid: atid9
                    if (isCollectionOriginTid
                        :ctx
                        originTid: (originTidOf :symtab tid: atid9)
                    ) then apfx9 = "&".string
                    if (pathIsPointer
                        :ast
                        :symtab
                        :ctx
                        n: (ast.nodes.get i: (a.operation - 1).u64)
                    ) then apfx9 = "".string
                    fs9p: "\{apfx9}\{av}"
                    valBySlot9p.set key: slot9p value: fs9p
                }
                ai9p = ai9p + 1
            } else null
        }
        pp9p: u64
        ppn9p: vpn9.length
        for pp9p < ppn9p loop {
            vo9p: valBySlot9p.get key: pp9p
            match (
                vo9p
            ) case some then {
                dargs.append ", "
                dargs.append vo9p.stringview
            } case none then null
            pp9p = pp9p + 1
        }
    } else {
        with aiter: call.arguments.iterate do for aId9: aiter loop {
            a: ast.nodes.get i: (aId9 - 1).u64
            match (
                a
            ) case namedoperation then {
                av: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (a.operation - 1).u64)
                atid9: (stampIdOf
                    :symtab
                    nid: (nodeIdOf9 n: (ast.nodes.get i: (a.operation - 1).u64))
                )
                apfx9: String
                if (chaseColMono :ast :symtab tid: atid9) != atid9 then apfx9 = "&".string
                aco9: monoOriginName :symtab tid: atid9
                if (isCollectionOriginTid :ctx originTid: (originTidOf :symtab tid: atid9)) then {
                    apfx9 = "&".string
                }
                if (pathIsPointer
                    :ast
                    :symtab
                    :ctx
                    n: (ast.nodes.get i: (a.operation - 1).u64)
                ) then apfx9 = "".string
                dargs.append ", "
                dargs.append apfx9.stringview
                dargs.append av.stringview
            } else null
        }
    }
    de: "\{recv}\{acc}vtable->\{mn}(\{dargs})"
    return de
}

# emitProtocolCreateCall -- `Reader.create from: g.take` (owned, heap-box +
# source invalidation) / `Provider.borrow from: m.lock` (borrowed, shares the
# source). Both route to the impl's conformance helper for the protocol.
emitProtocolCreateCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    bn: dottedBaseAtom :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    if bn.length == 0 then return "".string
    mn: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    isCreate: false
    if mn.stringview == "create" then isCreate = true
    if mn.stringview == "borrow" then isCreate = true
    if (isCreate) == false then return "".string
    protoTid: resolveTypeIdByName :ast :symtab :ctx name: bn.stringview
    ptt9: symtab.reg.typetypeOf typeId: protoTid
    isFct9: ptt9 == ztypes.ztypetype.facetType
    if ptt9 != ztypes.ztypetype.protocolType when isFct9 == false then return "".string
    suffix: "create_owned".string
    if mn.stringview == "borrow" then suffix = "create".string
    # a facet copies its source either way: one helper serves both verbs
    if isFct9 then suffix = "create".string
    aiter: call.arguments.iterate
    for aId9: aiter loop {
        a: ast.nodes.get i: (aId9 - 1).u64
        match (
            a
        ) case namedoperation then {
            an: zast.nameTextCopy :ast ref: a.name
            if an.stringview == "from" then {
                fromBase: dottedBaseAtom :ast n: (ast.nodes.get i: (a.operation - 1).u64)
                if fromBase.length == 0 then {
                    opf1049: ast.nodes.get i: (a.operation - 1).u64
                    fromBase = (atomTextOf :ast n: opf1049)
                }
                fdn: stampNameDeep :ast :symtab n: (ast.nodes.get i: (a.operation - 1).u64)
                fromTid: resolveTypeIdByName :ast :symtab :ctx name: fdn.stringview
                if fromTid == 0 then return "".string
                implBase: symtab.reg.cnameOf tid: fromTid
                label: conformanceLabelFor :symtab implTid: fromTid :protoTid
                if label.length == 0 then return "".string
                valVar: aliasResolve :ctx name: fromBase.stringview
                valVarC: ztypes.mangleVarName name: valVar.stringview
                refPfx9: "&".string
                if (isPtrVar :ctx name: valVar.stringview) then refPfx9 = "".string
                ce: "\{implBase}_\{label}_\{suffix}(\{refPfx9}\{valVarC})"
                return ce
            }
        } else null
    }
    return "".string
}

# emitRecordDefsIn -- three passes so cross-class references resolve: all structs
# (+ variants + data blocks), then all method forward decls, then all method
# bodies (a method may return/construct a class defined later in the unit).
emitRecordDefsIn: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    mainOpId: u32
    phase: u64
    buf: String.borrow
} is {
    bodyIds9: zast.unitBodyIdsAt :ast unitId: mainOpId
    {
        if phase == 1 then {
        with biterU: bodyIds9.iterate do for buId9: biterU loop {
            bu: ast.nodes.get i: (buId9 - 1).u64
            match (
                bu
            ) case namedoperation then {
                if (isUnionDef9 n: (ast.nodes.get i: (bu.operation - 1).u64)) then {
                    nmu: zast.nameTextCopy :ast ref: bu.name
                    uidu: userFnId :ast :symtab :ctx name: nmu.stringview
                    if uidu > 0 then (emitUnionMono
                        :ast
                        :symtab
                        :ctx
                        tid: uidu
                        name: nmu.stringview
                        :buf
                    )
                }
            } else null
        }
        with biterP: bodyIds9.iterate do for bpId9: biterP loop {
            bp: ast.nodes.get i: (bpId9 - 1).u64
            match (
                bp
            ) case namedoperation then {
                if (isProtocolDef9 n: (ast.nodes.get i: (bp.operation - 1).u64)) then {
                    nmp: zast.nameTextCopy :ast ref: bp.name
                    pid7: userFnId :ast :symtab :ctx name: nmp.stringview
                    if pid7 > 0 then {
                        emitOneProtocol :ast :symtab :ctx tid: pid7 name: nmp.stringview :buf
                    }
                }
            } else null
        }
        with biterA: bodyIds9.iterate do for bmId9: biterA loop {
            bm: ast.nodes.get i: (bmId9 - 1).u64
            match (
                bm
            ) case namedoperation then {
                if (isRecordDef9 n: (ast.nodes.get i: (bm.operation - 1).u64)) then {
                    nm: zast.nameTextCopy :ast ref: bm.name
                    rid: userFnId :ast :symtab :ctx name: nm.stringview
                    if rid > 0 when (isGenericType :symtab tid: rid) == false then {
                        emitOneRecord :ast :symtab :ctx tid: rid name: nm.stringview :buf
                        (emitAsConsts
                            :ast
                            :symtab
                            :ctx
                            tid: rid
                            name: nm.stringview
                            op: (ast.nodes.get i: (bm.operation - 1).u64)
                            :buf
                        )
                    }
                }
                if (isClassDef9 n: (ast.nodes.get i: (bm.operation - 1).u64)) then {
                    nmc: zast.nameTextCopy :ast ref: bm.name
                    cid9: userFnId :ast :symtab :ctx name: nmc.stringview
                    if cid9 > 0 when (isGenericType :symtab tid: cid9) == false then {
                        emitOneRecord :ast :symtab :ctx tid: cid9 name: nmc.stringview :buf
                        (emitAsConsts
                            :ast
                            :symtab
                            :ctx
                            tid: cid9
                            name: nmc.stringview
                            op: (ast.nodes.get i: (bm.operation - 1).u64)
                            :buf
                        )
                    }
                }
                if (isVariantDef9 n: (ast.nodes.get i: (bm.operation - 1).u64)) then {
                    nm5: zast.nameTextCopy :ast ref: bm.name
                    vid5: userFnId :ast :symtab :ctx name: nm5.stringview
                    if vid5 > 0 then (emitOneVariant
                        :ast
                        :symtab
                        :ctx
                        tid: vid5
                        name: nm5.stringview
                        :buf
                    )
                }
                nm6: zast.nameTextCopy :ast ref: bm.name
                (emitDataBlock
                    :ast
                    :symtab
                    :ctx
                    name: nm6.stringview
                    op: (ast.nodes.get i: (bm.operation - 1).u64)
                    :buf
                )
            } else null
        }
        }
        if phase == 2 then {
        with biterB: bodyIds9.iterate do for bmdId9: biterB loop {
            bmd: ast.nodes.get i: (bmdId9 - 1).u64
            emitDefMethods :ast :symtab :ctx bm: bmd declOnly: true :buf
        }
        with biterI: bodyIds9.iterate do for biId9: biterI loop {
            bi: ast.nodes.get i: (biId9 - 1).u64
            match (
                bi
            ) case namedoperation then {
                isImpl7: false
                if (isClassDef9 n: (ast.nodes.get i: (bi.operation - 1).u64)) then isImpl7 = true
                if (isRecordDef9 n: (ast.nodes.get i: (bi.operation - 1).u64)) then isImpl7 = true
                if isImpl7 then {
                    nmi7: zast.nameTextCopy :ast ref: bi.name
                    iid7: userFnId :ast :symtab :ctx name: nmi7.stringview
                    if iid7 > 0 then {
                        (emitProtocolImplsForType
                            :ast
                            :symtab
                            :ctx
                            implTid: iid7
                            implName: nmi7.stringview
                            :buf
                        )
                        (emitFacetImplsForType
                            :ast
                            :symtab
                            :ctx
                            implTid: iid7
                            implName: nmi7.stringview
                            :buf
                        )
                    }
                }
            } else null
        }
        # main-unit function forward decls, after the struct defs (so a generator
        # function returning its synth iter class resolves) and before the method
        # bodies (a synth iterator's call body may call another generator's fn).
        with biterFD: bodyIds9.iterate do for bfdId9: biterFD loop {
            bfd: ast.nodes.get i: (bfdId9 - 1).u64
            match (
                bfd
            ) case namedoperation then {
                if (isFunctionDefWithBody9 n: (ast.nodes.get i: (bfd.operation - 1).u64)) then {
                    fdn: zast.nameTextCopy :ast ref: bfd.name
                    fdid: userFnId :ast :symtab :ctx name: fdn.stringview
                    isGenFnFD9: false
                    if fdid > 0 then {
                        if (isGenericType :symtab tid: fdid) then {
                            if (symtab.reg.typetypeOf typeId: fdid) == ztypes.ztypetype.functionType then {
                                isGenFnFD9 = true
                            }
                        }
                    }
                    if isGenFnFD9 == false then {
                        fdsig: (fnSignature
                            :ast
                            :symtab
                            :ctx
                            name: fdn.stringview
                            fid: fdid
                            op: (ast.nodes.get i: (bfd.operation - 1).u64)
                        )
                        fdl: "\{fdsig};\n"
                        buf.append fdl.stringview
                    }
                }
            } else null
        }
        }
        if phase == 3 then {
        with biterC: bodyIds9.iterate do for bmbId9: biterC loop {
            bmb: ast.nodes.get i: (bmbId9 - 1).u64
            emitDefMethods :ast :symtab :ctx bm: bmb declOnly: false :buf
        }
        }
    }
}

# emitDataBlock -- `name: data { e0 e1 ... } out T`: a static const array
# z_{name}[] plus z_{name}_len, with the element C type from out T (i64
# default). The plain z_{name} cname matches the reference.
emitDataBlock: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    name: StringView
    op: Node
    buf: String.borrow
} is {
    match (
        op
    ) case expression then {
        emitDataBlock :ast :symtab :ctx :name op: (ast.nodes.get i: (op.expression - 1).u64) :buf
    } case datablock then {
        ridtid9: userFnId :ast :symtab :ctx :name
        ri9: false
        {
            rio9: symtab.reg.typeById.get key: ridtid9
            match (
                rio9
            ) case some then {
                ri9 = rio9.runtimeIndexed
            } case none then null
        }
        if ri9 then {
            ect: "int64_t".string
            rbn: dataElemBaseName :ast oId: op.outType
            if rbn.length > 0 then {
                rc: cTypeOf name: rbn.stringview
                if rc.length > 0 then ect = rc
            }
            elems: String
            cnt: u64
            eiter: op.elements.iterate
            for e: eiter loop {
                ev: emitDataElem :ast :symtab :ctx n: (ast.nodes.get i: (e - 1).u64)
                if cnt > 0 then elems.append ", "
                elems.append ev.stringview
                cnt = cnt + 1
            }
            l0: "static const \{ect} z_\{name}[] = {\{elems}};\n\n"
            buf.append l0.stringview
        }
    } else null
}

# emitDataElem -- a data-block element (a NamedOperation wrapping the
# value atom); emit its inner expression.
emitDataElem: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out String is {
    match (
        n
    ) case namedoperation then {
        return (emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (n.operation - 1).u64))
    } else {
        return (emitExpr :ast :symtab :ctx :n)
    }
}

dataElemBaseName: function {ast: Ast oId: u32} out String is {
    if oId == 0 then return "".string
    return (atomTextDeep :ast n: (ast.nodes.get i: (oId - 1).u64))
}

isVariantDef9: function {n: Node} out bool is {
    match (
        n
    ) case objectdef then {
        if n.kind == zast.nodetype.variantDef then {
            return true
        } else {
            return false
        }
    } else {
        return false
    }
}

isUnionDef9: function {n: Node} out bool is {
    match (
        n
    ) case objectdef then {
        if n.kind == zast.nodetype.unionDef then {
            return true
        } else {
            return false
        }
    } else {
        return false
    }
}

# emitOneVariant -- tag enum + tagged struct (+ payload union when any
# arm carries one) + the by-tag/value eq helper.
emitOneVariant: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    tid: u64
    name: StringView
    buf: String.borrow
} is {
    egv9: ctx.emittedUserTypes.get key: tid
    match (
        egv9
    ) case some then {
        return
    } case none then null
    ctx.emittedUserTypes.set key: tid.u64 value: true
    anames: (List String)
    aids: (List u64)
    aidsNm: (List u64)
    variantArms :ast :symtab :tid names: anames ids: aids nameIds: aidsNm
    preEmitEmbeddedTypes :ast :symtab :ctx ids: aids :buf
    vc: cnameOf :tid :name
    buf.append "typedef enum {\n"
    ai: u64
    an: anames.length
    for ai < an loop {
        aname: anames.get i: ai
        tg: variantTag :symtab :tid arm: aname.stringview
        lt: "    \{tg},\n"
        buf.append lt.stringview
        ai = ai + 1
    }
    le: "} \{vc}_tag_t;\n"
    buf.append le.stringview
    buf.append "typedef struct {\n"
    lf: "    \{vc}_tag_t tag;\n"
    buf.append lf.stringview
    haveP: false
    pj: u64
    for pj < an loop {
        pname: anames.get i: pj
        pc: armPayloadC :ast :symtab :ctx :tid arm: pname.stringview
        if pc.length > 0 then {
            if (haveP) == false then {
                haveP = true
                buf.append "    union {\n"
            }
            lp: "        \{pc} \{pname};\n"
            buf.append lp.stringview
        }
        pj = pj + 1
    }
    if haveP then buf.append "    } data;\n"
    lg: "} \{vc}_t;\n"
    buf.append lg.stringview
    lq: "static bool \{vc}_eq(\{vc}_t a, \{vc}_t b) {\n"
    buf.append lq.stringview
    if haveP then {
        buf.append "    if (a.tag != b.tag) return false;\n"
        buf.append "    switch (a.tag) {\n"
        qk: u64
        for qk < an loop {
            qname: anames.get i: qk
            qnameId: aidsNm.get i: qk
            qc: armPayloadC :ast :symtab :ctx :tid arm: qname.stringview
            if qc.length > 0 then {
                qtg: variantTag :symtab :tid arm: qname.stringview
                qco: symtab.typing.childOfId parentTypeId: tid nameId: qnameId
                qeq: String
                match (
                    qco
                ) case some then {
                    qtn: typeNameOfReg9 :symtab tid: qco
                    qsc: scalarCTypeFor :symtab name: qtn.stringview tid: qco
                    if qsc.length == 0 then {
                        qrid: resolveTypeIdByName :ast :symtab :ctx name: qtn.stringview
                        if qrid > 0 then {
                            qtt: symtab.reg.typetypeOf typeId: qrid
                            isAgg: false
                            if qtt == ztypes.ztypetype.recordType then isAgg = true
                            if qtt == ztypes.ztypetype.variantType then isAgg = true
                            if isAgg then {
                                qrc: cnameOf tid: qrid name: qtn.stringview
                                qe: "\{qrc}_eq(a.data.\{qname}, b.data.\{qname})"
                                qeq.append qe.stringview
                            }
                        }
                    }
                } case none then null
                if qeq.length == 0 then {
                    qe2: "a.data.\{qname} == b.data.\{qname}"
                    qeq.append qe2.stringview
                }
                lr: "        case \{qtg}: return \{qeq};\n"
                buf.append lr.stringview
            }
            qk = qk + 1
        }
        buf.append "        default: return true;\n"
        buf.append "    }\n"
    } else {
        buf.append "    return a.tag == b.tag;\n"
    }
    buf.append "}\n\n"
}

isClassDef9: function {n: Node} out bool is {
    match (
        n
    ) case objectdef then {
        if n.kind == zast.nodetype.classDef then {
            return true
        } else {
            return false
        }
    } else {
        return false
    }
}

isRecordDef9: function {n: Node} out bool is {
    match (
        n
    ) case objectdef then {
        if n.kind == zast.nodetype.recordDef then {
            return true
        } else {
            return false
        }
    } else {
        return false
    }
}

# structDestroyNontrivial -- the type's destructor frees at least one field.
# Mirrors emitStructDestructor's per-field tests (String, destructible
# aggregate, heap-ptr collection; `.lock` fields never free). Gates call-site
# destroys for loop-owned iterator instances: an all-borrowed iterator has
# nothing to free and keeps its emission unchanged.
structDestroyNontrivial: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    tid: u64
} out bool is {
    fnames: (List String)
    fids: (List u64)
    fidsNm: (List u64)
    recFieldLists :ast :symtab :tid names: fnames ids: fids nameIds: fidsNm
    fi: u64
    fn0: fnames.length
    for fi < fn0 loop {
        fid: fids.get i: fi
        fnameId: fidsNm.get i: fi
        if (symtab.typing.isChildLockFieldId parentTypeId: tid nameId: fnameId) == false then {
            if fid == ctx.strTid then return true
            fmid9: chaseColMono :ast :symtab tid: fid
            if (symtab.reg.hasDestructorName typeId: fmid9) then return true
            if (isHeapPtrCollection :ast :symtab :ctx tid: fid) then return true
        }
        fi = fi + 1
    }
    return false
}

# emitStructDestructor -- a record/class destructor freeing each heap-owning
# field: String fields via the String free, aggregate fields with a destructor
# recursively; scalars are skipped. Emitted only when the type has a destructor.
# structDestroyNontrivial mirrors the per-field tests below -- keep them in sync.
emitStructDestructor: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    tid: u64
    name: StringView
    fnames: List String
    fids: List u64
    buf: String.borrow
} is {
    rc: cnameOf :tid :name
    d0: "static void \{rc}_destroy(\{rc}_t* p);\n"
    buf.append d0.stringview
    d1: "static void \{rc}_destroy(\{rc}_t* p) {\n"
    buf.append d1.stringview
    buf.append "    if (!p) return;\n"
    fi: u64
    fn0: fnames.length
    for fi < fn0 loop {
        fname: fnames.get i: fi
        fid: fids.get i: fi
        # a `.lock` field is a borrowed pointer -- never freed by the destructor.
        if (symtab.typing.isChildLockField
            pool: ast.names
            parentTypeId: tid
            name: fname.stringview
        ) == false then {
            if fid == ctx.strTid then {
                ds: "    \{ctx.strC}_free(&p->\{fname});\n"
                buf.append ds.stringview
            } else {
                fmid9: chaseColMono :ast :symtab tid: fid
                fneeds9: false
                if (symtab.reg.hasDestructorName typeId: fmid9) then fneeds9 = true
                if (isHeapPtrCollection :ast :symtab :ctx tid: fid) then fneeds9 = true
                if fneeds9 then {
                    fcb: symtab.reg.cnameOf tid: fmid9
                    if (isHeapPtrCollection :ast :symtab :ctx tid: fid) then {
                        df: "    \{fcb}_destroy(p->\{fname});\n"
                        buf.append df.stringview
                    } else {
                        df2: "    \{fcb}_destroy(&p->\{fname});\n"
                        buf.append df2.stringview
                    }
                }
            }
        }
        fi = fi + 1
    }
    buf.append "}\n\n"
}

# lockFieldIsReftypePtr -- a `.lock` field is stored as a pointer to its container
# only when that container is a reftype (class/union); a protocol lock is the fat
# pointer by value, and a valtype lock (a bidirectional generator's bool resume
# input) is stored by value.
lockFieldIsReftypePtr: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx fid: u64} out bool is {
    ftn: typeNameOfReg9 :symtab tid: fid
    ftid: resolveTypeIdByName :ast :symtab :ctx name: ftn.stringview
    if ftid == 0 then ftid = fid
    tt: symtab.reg.typetypeOf typeId: ftid
    if tt == ztypes.ztypetype.classType then return true
    if tt == ztypes.ztypetype.unionType then return true
    return false
}

emitOneRecord: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    tid: u64
    name: StringView
    buf: String.borrow
} is {
    egr9: ctx.emittedUserTypes.get key: tid
    match (
        egr9
    ) case some then {
        return
    } case none then null
    ctx.emittedUserTypes.set key: tid.u64 value: true
    if (isTypedefType :symtab :tid) then return
    fnames: (List String)
    fids: (List u64)
    fidsNm: (List u64)
    recFieldLists :ast :symtab :tid names: fnames ids: fids nameIds: fidsNm
    preEmitEmbeddedTypes :ast :symtab :ctx ids: fids :buf
    rc: cnameOf :tid :name
    if (isFwdDeclared :ctx :tid) then {
        lopenR: "struct \{rc}_t {\n"
        buf.append lopenR.stringview
    } else {
        buf.append "typedef struct {\n"
    }
    fi: u64
    fn0: fnames.length
    for fi < fn0 loop {
        fname: fnames.get i: fi
        fid: fids.get i: fi
        fnameId: fidsNm.get i: fi
        fct: typeRefC :ast :symtab :ctx tid: fid thisTid: 0
        if fct.length == 0 then fct = "int64_t".string
        # a `.lock` field borrows the container: protocol-typed -> fat pointer by
        # value; class-typed -> a pointer to the container.
        if (symtab.typing.isChildLockFieldId parentTypeId: tid nameId: fnameId) then {
            if (lockFieldIsReftypePtr :ast :symtab :ctx :fid) then fct = "\{fct}*"
        }
        if (isHeapPtrCollection :ast :symtab :ctx tid: fid) then fct = "\{fct}*"
        l1: "    \{fct} \{fname};\n"
        buf.append l1.stringview
        fi = fi + 1
    }
    if (isFwdDeclared :ctx :tid) then {
        buf.append "};\n"
    } else {
        l2: "} \{rc}_t;\n"
        buf.append l2.stringview
    }
    params: String
    inits: String
    fj: u64
    for fj < fn0 loop {
        fname2: fnames.get i: fj
        fid2: fids.get i: fj
        fname2Id: fidsNm.get i: fj
        fct2: typeRefC :ast :symtab :ctx tid: fid2 thisTid: 0
        if fct2.length == 0 then fct2 = "int64_t".string
        # a `.lock` field's meta_create param matches the field (protocol by value).
        if (symtab.typing.isChildLockFieldId parentTypeId: tid nameId: fname2Id) then {
            if (lockFieldIsReftypePtr :ast :symtab :ctx fid: fid2) then fct2 = "\{fct2}*"
        }
        if (isHeapPtrCollection :ast :symtab :ctx tid: fid2) then fct2 = "\{fct2}*"
        if fj > 0 then {
            params.append ", "
            inits.append ", "
        }
        params.append fct2.stringview
        params.append " "
        params.append fname2.stringview
        inits.append fname2.stringview
        fj = fj + 1
    }
    l3: "static \{rc}_t \{rc}_meta_create(\{params}) {\n"
    buf.append l3.stringview
    l4: "    \{rc}_t _this = { \{inits} };\n"
    buf.append l4.stringview
    buf.append "    return _this;\n"
    buf.append "}\n"
    if (definedInNonMain :symtab :ctx :tid) == false then {
        l5: "#define \{rc}_create \{rc}_meta_create\n"
        buf.append l5.stringview
    }
    skipEqR: false
    if (symtab.reg.typetypeOf typeId: tid) == ztypes.ztypetype.classType then skipEqR = true
    if (skipEqR) == false then {
    lq: "static bool \{rc}_eq(\{rc}_t a, \{rc}_t b) {\n"
    buf.append lq.stringview
    if fn0 == 0 then {
        buf.append "    (void)a; (void)b;\n"
        buf.append "    return true;\n"
    } else {
        eqx: String
        fk: u64
        for fk < fn0 loop {
            fkn: fnames.get i: fk
            fki: fids.get i: fk
            if fk > 0 then eqx.append " && "
            ftn: typeNameOfReg9 :symtab tid: fki
            fscalar: scalarCTypeFor :symtab name: ftn.stringview tid: fki
            fdone: false
            if fscalar.length == 0 then {
                frid: resolveTypeIdByName :ast :symtab :ctx name: ftn.stringview
                if frid > 0 then {
                    ftt: symtab.reg.typetypeOf typeId: frid
                    isAggF: false
                    if ftt == ztypes.ztypetype.recordType then isAggF = true
                    if ftt == ztypes.ztypetype.variantType then isAggF = true
                    if isAggF then {
                        frc: cnameOf tid: frid name: ftn.stringview
                        fe: "\{frc}_eq(a.\{fkn}, b.\{fkn})"
                        eqx.append fe.stringview
                        fdone = true
                    }
                }
            }
            if (fdone) == false then {
                fe2: "a.\{fkn} == b.\{fkn}"
                eqx.append fe2.stringview
            }
            fk = fk + 1
        }
        lr: "    return \{eqx};\n"
        buf.append lr.stringview
    }
    buf.append "}\n\n"
    }
    if (symtab.reg.hasDestructorName typeId: tid) then {
        emitStructDestructor :ast :symtab :ctx :tid :name :fnames :fids :buf
    }
}

# emitCliCompositeClass -- a cli class holding collection fields (Spec/Parsed).
# Lists embed by value; Maps/Sets are heap pointers. Parsed is forward-declared
# (named tag) so the Result_Parsed_CliError destructor can reference it before
# this body emits; Spec emits its own typedef inline. No `_create` alias (the
# create is native / inline) and no `_eq` (a class).
emitCliCompositeClass: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    tid: u64
    name: StringView
    fwdDeclared: bool
    buf: String.borrow
} is {
    fnames: (List String)
    fids: (List u64)
    fidsNm: (List u64)
    recFieldLists :ast :symtab :tid names: fnames ids: fids nameIds: fidsNm
    rc: cnameOf :tid :name
    if (fwdDeclared) == false then {
        lt: "typedef struct \{rc}_t \{rc}_t;\n"
        buf.append lt.stringview
    }
    l0: "struct \{rc}_t {\n"
    buf.append l0.stringview
    fi: u64
    fn0: fnames.length
    for fi < fn0 loop {
        fname: fnames.get i: fi
        fid: fids.get i: fi
        fct: typeRefC :ast :symtab :ctx tid: fid thisTid: 0
        if fct.length == 0 then fct = "int64_t".string
        if (isHeapPtrCollection :ast :symtab :ctx tid: fid) then fct = "\{fct}*"
        l1: "    \{fct} \{fname};\n"
        buf.append l1.stringview
        fi = fi + 1
    }
    buf.append "};\n"
    params: String
    inits: String
    fj: u64
    for fj < fn0 loop {
        fname2: fnames.get i: fj
        fid2: fids.get i: fj
        fct2: typeRefC :ast :symtab :ctx tid: fid2 thisTid: 0
        if fct2.length == 0 then fct2 = "int64_t".string
        if (isHeapPtrCollection :ast :symtab :ctx tid: fid2) then fct2 = "\{fct2}*"
        if fj > 0 then {
            params.append ", "
            inits.append ", "
        }
        params.append fct2.stringview
        params.append " "
        params.append fname2.stringview
        inits.append fname2.stringview
        fj = fj + 1
    }
    l3: "static \{rc}_t \{rc}_meta_create(\{params}) {\n"
    buf.append l3.stringview
    l4: "    \{rc}_t _this = { \{inits} };\n"
    buf.append l4.stringview
    buf.append "    return _this;\n"
    buf.append "}\n"
    if (definedInNonMain :symtab :ctx :tid) == false then {
        ldf0: "#define \{rc}_create \{rc}_meta_create\n"
        buf.append ldf0.stringview
    }
    d0: "static void \{rc}_destroy(\{rc}_t* p);\n"
    buf.append d0.stringview
    d1: "static void \{rc}_destroy(\{rc}_t* p) {\n"
    buf.append d1.stringview
    buf.append "    if (!p) return;\n"
    dk: u64
    for dk < fn0 loop {
        dfn: fnames.get i: dk
        dfi: fids.get i: dk
        if dfi == ctx.strTid then {
            ds: "    \{ctx.strC}_free(&p->\{dfn});\n"
            buf.append ds.stringview
        } else {
            dcm: chaseColMono :ast :symtab tid: dfi
            dneeds9: false
            if (symtab.reg.hasDestructorName typeId: dcm) then dneeds9 = true
            if (isHeapPtrCollection :ast :symtab :ctx tid: dfi) then dneeds9 = true
            if dneeds9 then {
                dcb: symtab.reg.cnameOf tid: dcm
                if (isHeapPtrCollection :ast :symtab :ctx tid: dfi) then {
                    df: "    \{dcb}_destroy(p->\{dfn});\n"
                    buf.append df.stringview
                } else {
                    df2: "    \{dcb}_destroy(&p->\{dfn});\n"
                    buf.append df2.stringview
                }
            }
        }
        dk = dk + 1
    }
    buf.append "}\n\n"
}

# emitRecordMethods -- the record's as-block functions as free C
# functions taking the record by value (params from the method type's
# children; the AST return fallback covers unstamped returns).
# emitAsConsts -- a record/class `as`-block plain constant (`as { version: 1 }`)
# becomes a `static const` read as `Type.label` (see the Type.constlabel leg in
# emitExpr). Const items are the markAsConstClone children; methods/markers skip.
emitAsConsts: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    tid: u64
    name: StringView
    op: Node
    buf: String.borrow
} is {
    match (
        op
    ) case objectdef then {
        with aiter: op.asItems.iterate do for amId9: aiter loop {
            am: ast.nodes.get i: (amId9 - 1).u64
            match (
                am
            ) case namedoperation then {
                albl: zast.nameTextCopy :ast ref: am.name
                cco: symtab.typing.childOf pool: ast.names parentTypeId: tid name: albl.stringview
                match (
                    cco
                ) case some then {
                    if (symtab.typing.isAsConstClone typeId: cco) then {
                        cv: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (am.operation - 1).u64)
                        if cv.length > 0 then {
                            ctA: "int64_t".string
                            vtidA: (stampIdOf
                                :symtab
                                nid: (nodeIdOf9 n: (ast.nodes.get i: (am.operation - 1).u64))
                            )
                            if vtidA > 0 then {
                                vtnA: typeNameOfReg9 :symtab tid: vtidA
                                vtcA: cTypeOf name: vtnA.stringview
                                if vtcA.length > 0 then ctA = vtcA
                            }
                            qnA: "\{name}.\{albl}"
                            csymA: cnameOf :tid name: qnA.stringview
                            lA: "static const \{ctA} \{csymA} = \{cv};\n"
                            buf.append lA.stringview
                        }
                    }
                } case none then null
            } else null
        }
    } else null
}

# emitClassMonoMethods -- emit every specialization's bodied methods for a
# generic class template: the clone's FUNCTION id supplies the substituted
# signature and the template item supplies the body (the unit-mono pattern).
emitClassMonoMethods: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    tplId: u64
    op: Node
    declOnly: bool
    buf: String.borrow
} is {
    match (
        op
    ) case objectdef then {
        last8: symtab.reg.nextTypeId
        t8: u64
        for t8 < last8 loop {
            isMono8: false
            go8opt: (optionval.none u64)
            {
                to8: symtab.reg.typeById.get key: t8
                match (
                    to8
                ) case some then {
                    go8opt = to8.genericOriginId
                } case none then null
            }
            match (
                go8opt
            ) case some then {
                if go8opt == tplId then isMono8 = true
            } case none then null
            if isMono8 then {
                ait8: op.isItems.iterate
                for am8Id9: ait8 loop {
                    am8: ast.nodes.get i: (am8Id9 - 1).u64
                    match (
                        am8
                    ) case namedoperation then {
                        if (isFunctionDefWithBody9 n: (ast.nodes.get i: (am8.operation - 1).u64)) then {
                            mn8: zast.nameTextCopy :ast ref: am8.name
                            co8: (symtab.typing.childOf
                                pool: ast.names
                                parentTypeId: t8
                                name: mn8.stringview
                            )
                            match (
                                co8
                            ) case some then {
                                cf8: co8
                                if (symtab.reg.typetypeOf typeId: cf8) == ztypes.ztypetype.functionType then {
                                    fn8: typeNameOfReg9 :symtab tid: cf8
                                    sg8: (fnSignature
                                        :ast
                                        :symtab
                                        :ctx
                                        name: fn8.stringview
                                        fid: cf8
                                        op: (ast.nodes.get i: (am8.operation - 1).u64)
                                    )
                                    if declOnly then {
                                        ld8: "\{sg8};\n"
                                        buf.append ld8.stringview
                                    } else {
                                        lo8: "\{sg8} {\n"
                                        buf.append lo8.stringview
                                        ctx.ptrVars = (List String)
                                        ctx.aliases = (List NameVal)
                                        ctx.narrowBox = (List NameVal)
                                        registerReftypeParams :ast :symtab :ctx fid: cf8
                                        ctx.curThisTid = t8
                                        (emitFnBody
                                            :ast
                                            :symtab
                                            :ctx
                                            op: (ast.nodes.get i: (am8.operation - 1).u64)
                                            fid: cf8
                                            :buf
                                        )
                                        ctx.curThisTid = 0
                                        buf.append "}\n\n"
                                    }
                                }
                            } case none then null
                        }
                    } else null
                }
                ait8b: op.asItems.iterate
                for am8bId9: ait8b loop {
                    am8b: ast.nodes.get i: (am8bId9 - 1).u64
                    match (
                        am8b
                    ) case namedoperation then {
                        if (isFunctionDefWithBody9 n: (ast.nodes.get i: (am8b.operation - 1).u64)) then {
                            mn8b: zast.nameTextCopy :ast ref: am8b.name
                            co8b: (symtab.typing.childOf
                                pool: ast.names
                                parentTypeId: t8
                                name: mn8b.stringview
                            )
                            match (
                                co8b
                            ) case some then {
                                cf8b: co8b
                                if (symtab.reg.typetypeOf typeId: cf8b) == ztypes.ztypetype.functionType then {
                                    fn8b: typeNameOfReg9 :symtab tid: cf8b
                                    sg8b: (fnSignature
                                        :ast
                                        :symtab
                                        :ctx
                                        name: fn8b.stringview
                                        fid: cf8b
                                        op: (ast.nodes.get i: (am8b.operation - 1).u64)
                                    )
                                    if declOnly then {
                                        ld8b: "\{sg8b};\n"
                                        buf.append ld8b.stringview
                                    } else {
                                        lo8b: "\{sg8b} {\n"
                                        buf.append lo8b.stringview
                                        ctx.ptrVars = (List String)
                                        ctx.aliases = (List NameVal)
                                        ctx.narrowBox = (List NameVal)
                                        registerReftypeParams :ast :symtab :ctx fid: cf8b
                                        ctx.curThisTid = t8
                                        (emitFnBody
                                            :ast
                                            :symtab
                                            :ctx
                                            op: (ast.nodes.get i: (am8b.operation - 1).u64)
                                            fid: cf8b
                                            :buf
                                        )
                                        ctx.curThisTid = 0
                                        buf.append "}\n\n"
                                    }
                                }
                            } case none then null

}

# emitStringMethod -- a String value-context method call. String is a native
# singleton whose struct + methods emit once under ctx.strC; dispatch by name so
# the cname is canonical (not a per-shell receiver id). `recv` is the receiver C
# expression; recvIsPtr picks `->`/no-`&`. "" for an unrecognized method.
emitStringMethod: function {
    ctx: Ctx
    recv: StringView
    recvIsPtr: bool
    mn: StringView
} out String is {
    if mn == "copy" then {
        if recvIsPtr then return "\{ctx.strC}_copy(\{recv})"
        return "\{ctx.strC}_copy(&\{recv})"
    }
    if mn == "length" then {
        if recvIsPtr then return "\{recv}->size"
        return "\{recv}.size"
    }
    if mn == "capacity" then {
        if recvIsPtr then return "\{recv}->capacity"
        return "\{recv}.capacity"
    }
    if mn == "stringview" then return (svValueForm :ctx expr: recv isStr: true)
    if mn == "shrink" then {
        if recvIsPtr then return "\{ctx.strC}_shrink(\{recv})"
        return "\{ctx.strC}_shrink(&\{recv})"
    }
    return "".string
}

# emitLocalAtomName -- a local variable's C spelling: alias-resolved then
# C-mangled. Shared by the atomid and labelvalue (:name shorthand) value legs.
emitLocalAtomName: function {ctx: Ctx name: StringView} out String is {
    acv: aliasResolve :ctx :name
    return (ztypes.mangleVarName name: acv.stringview)
}

# emitExpr -- the C expression text for a node (calls inline; the scalar
# examples carry no order-sensitive multi-call arguments).
emitExpr: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out String is {
    cv9: nodeConstText :symtab nid: (nodeIdOf9 :n)
    if cv9.length > 0 then return cv9
    match (
        n
    ) case expression then {
        return (emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (n.expression - 1).u64))
    } case statementline then {
        return (emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (n.statementline - 1).u64))
    } case statement then {
        if n.statements.length == 1 then {
            s0Id9: n.statements.get i: 0
            return (emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (s0Id9 - 1).u64))
        }
        return "/* zemitterc: unhandled expr */0".string
    } case atomid then {
        avC9: ast.names.texts.get i: (n.name - 1).u64
        av: avC9.stringview
        # `0c<char>` literal: the raw lexeme is not a C token, so decode
        # to its codepoint here (decimal/hex lexemes pass through below
        # as valid C text; identifiers never start with a digit)

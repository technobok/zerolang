                    cpnameId: cpiNm.get i: ci
                    ci = ci + 1
                    cav: "0".string
                    if (symtab.typing.hasChildDefaultId parentTypeId: tid nameId: cpnameId) then {
                        cdt: symtab.typing.childDefaultTextId parentTypeId: tid nameId: cpnameId
                        cav = (renderDefault
                            :ast
                            :symtab
                            :ctx
                            default: cdt.stringview
                            targetTid: cpid
                        )
                    }
                    if cargs.length > 0 then cargs.append ", "
                    cargs.append cav.stringview
                }
                ccb: symtab.reg.cnameOf tid: cco
                return "\{ccb}(\{cargs})"
            }
        }
    } case none then null
    fnames: (List String)
    fids: (List u64)
    fidsNm: (List u64)
    recFieldLists :ast :symtab :tid names: fnames ids: fids nameIds: fidsNm
    args: String
    fi: u64
    fn0: fnames.length
    for fi < fn0 loop {
        ffid: fids.get i: fi
        fnameId: fidsNm.get i: fi
        fi = fi + 1
        av: "0".string
        if (symtab.typing.hasChildDefaultId parentTypeId: tid nameId: fnameId) then {
            cdt1: symtab.typing.childDefaultTextId parentTypeId: tid nameId: fnameId
            av = renderDefault :ast :symtab :ctx default: cdt1.stringview targetTid: ffid
        } else {
            if (symtab.typing.isChildFnptrFieldId parentTypeId: tid nameId: fnameId) then {
                av = symtab.reg.cnameOf tid: ffid
            }
        }
        if args.length > 0 then args.append ", "
        args.append av.stringview

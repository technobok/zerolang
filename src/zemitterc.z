            return (emitCtorDefaultsFill :ast :symtab :ctx tid: izd9)
        } case none then null
        dpUb9: atomTextOf :ast n: (ast.nodes.get i: (n.parent - 1).u64)
        if (symtab.reg.isUnitName name: dpUb9.stringview) then {
            dpUc9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
            dpUk9: "\{dpUb9}.\{dpUc9}"
            dpUfo9: (ztypecheck.resolvedByKey

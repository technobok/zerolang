emitCrossUnitFnCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    base: dottedBaseAtom :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    child: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    if base.length == 0 then return "".string
    if child.length == 0 then return "".string
    if (symtab.reg.isUnitName name: base.stringview) == false then return "".string
    k: "\{base}.\{child}"
    go: ztypecheck.resolvedByKey :ast ty: symtab.typing reg: symtab.reg key: k
    fid: u64
    match (
        go
    ) case some then {
        fid = go
    } case none then null
    if fid == 0 then return "".string
    if (symtab.reg.typetypeOf typeId: fid) != ztypes.ztypetype.functionType then return "".string
    fc: cnameOf tid: fid name: child.stringview
    fpNames: (List String)
    fpIds: (List u64)
    fpIdsNm: (List u64)
    recFieldLists :ast :symtab tid: fid names: fpNames ids: fpIds nameIds: fpIdsNm
    slots9c: argSlotList :ast :call :fpNames
    valBySlot9c: (Map u64 value: String)
    ai8: u64
    aiter: call.arguments.iterate
    for aId9: aiter loop {
        a: ast.nodes.get i: (aId9 - 1).u64
        match (
            a
        ) case namedoperation then {
            opf2099: ast.nodes.get i: (a.operation - 1).u64
            opf2089: ast.nodes.get i: (a.operation - 1).u64
            slot9c: slots9c.get i: ai8
            if slot9c < fpNames.length then {
                fpid8: fpIds.get i: slot9c
                fpnO8: fpNames.get i: slot9c
                iav8: (emitInterpArgForParam
                    :ast
                    :symtab
                    :ctx
                    n: (ast.nodes.get i: (a.operation - 1).u64)
                    :fid
                    pname: fpnO8.stringview
                    pid: fpid8
                )
                if iav8.length > 0 then {
                    valBySlot9c.set key: slot9c value: iav8
                } else {
                    av9: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (a.operation - 1).u64)
                    byref8: false
                    argRef8: String
                    vbh8c: String
                    ptra8: false
                    if (symtab.typing.childOwnershipIs
                        pool: ast.names
                        parentTypeId: fid
                        name: fpnO8.stringview
                        own: ztypes.zparamownership.takeMode
                    ) == false when (isReftypeParam :ast :symtab :ctx tid: fpid8) then {
                        ptra8 = true
                    } else {
                        if (isBorrowStringParam
                            :ast
                            :symtab
                            :fid
                            pname: fpnO8.stringview
                            pid: fpid8
                        ) then ptra8 = true
                    }
                    if (ptra8) == false then {
                        if (isListPtrParam
                            :ast
                            :symtab
                            :fid
                            pname: fpnO8.stringview
                            tid: fpid8
                        ) then ptra8 = true
                    }
                    if ptra8 then {
                        if (isPtrVar :ctx name: av9.stringview) == false then {
                            byref8 = true
                            argRef8 = (emitByrefArg
                                :ast
                                :symtab
                                :ctx
                                av: av9.stringview
                                pid: fpid8
                                isBorrow: (hoistExprIsBorrowRooted :ast :symtab :ctx n: opf2089)
                            )
                        }
                    }
                    if (ptra8) == false then {
                        vbh8c = (hoistBorrowValArg
                            :ast
                            :symtab
                            :ctx
                            av: av9.stringview
                            pid: fpid8
                            paramTake: (symtab.typing.childOwnershipIs
                                pool: ast.names
                                parentTypeId: fid
                                name: fpnO8.stringview
                                own: ztypes.zparamownership.takeMode
                            )
                            isBorrow: (hoistExprIsBorrowRooted :ast :symtab :ctx n: opf2099)
                        )
                    }
                    finalS9c: av9.copy
                    if byref8 then {
                        finalS9c = argRef8.copy
                    } else {
                        if vbh8c.length > 0 then finalS9c = vbh8c.copy
                    }
                    valBySlot9c.set key: slot9c value: finalS9c
                }
            }
            ai8 = ai8 + 1
        } else null
    }
    args: String
    emitted9c: u64
    pp9c: u64
    ppn9c: fpNames.length
    for pp9c < ppn9c loop {
        vo9c: valBySlot9c.get key: pp9c
        match (
            vo9c
        ) case some then {
            if emitted9c > 0 then args.append ", "
            args.append vo9c.stringview
            emitted9c = emitted9c + 1
        } case none then null
        pp9c = pp9c + 1
    }
    e8: "\{fc}(\{args})"
    return e8
}

# emitCrossUnitCtor -- construction of a cross-unit record/class
# `unit.TypeName field: val ...` (e.g. a Node arm's zast.ErrorData payload):
# resolve the type via the shared cross-unit identity and route to the field-wise
# (or user-create) constructor. "" when not such a construction.
# dottedParentChild -- the middle segment of a 3-segment dotted path `a.b.c`:
# the child text of the parent (`b`). "" when not a nested dotted path.
dottedParentChild: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case expression then {
        return (dottedParentChild :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case dottedpath then {
        return (dottedChildText :ast n: (ast.nodes.get i: (n.parent - 1).u64))
    } else {
        return "".string
    }
}

# emitCrossUnitBareCreate -- a bare (no-arg) cross-unit construction
# `unit.Type.create` written as a dotted path (not a call): emit `<Type>_create()`
# (the user create, no receiver). "" when not such a 3-segment bare create.
emitCrossUnitBareCreate: function {ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    parent: Node
    child: StringView
} out String is {
    if child != "create" then return "".string
    pbase9: dottedBaseAtom :ast n: parent
    ptype9: dottedChildText :ast n: parent
    if pbase9.length == 0 then return "".string
    if ptype9.length == 0 then return "".string
    if (symtab.reg.isUnitName name: pbase9.stringview) == false then return "".string
    k9: "\{pbase9}.\{ptype9}"
    go9: ztypecheck.resolvedByKey :ast ty: symtab.typing reg: symtab.reg key: k9
    tid9: u64
    match (
        go9
    ) case some then {
        tid9 = go9
    } case none then null
    if tid9 == 0 then return "".string
    cco9: symtab.typing.childOfId parentTypeId: tid9 nameId: wkCreate
    match (
        cco9
    ) case some then {
        if (symtab.reg.typetypeOf typeId: cco9) == ztypes.ztypetype.functionType then {
            ccb9: symtab.reg.cnameOf tid: cco9
            return "\{ccb9}()"
        }
    } case none then null
    return "".string
}

# emitCrossUnitExplicitCreate -- an explicit cross-unit construction
# `unit.Type.create args`: resolve `unit.Type` and emit the user `create` call
# `<Type>_create(args)` (no receiver). "" when not such a 3-segment create.
emitCrossUnitExplicitCreate: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    pbase: dottedBaseAtom :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    ptype: dottedParentChild :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    if pbase.length == 0 then return "".string
    if ptype.length == 0 then return "".string
    if (symtab.reg.isUnitName name: pbase.stringview) == false then return "".string
    k: "\{pbase}.\{ptype}"
    go: ztypecheck.resolvedByKey :ast ty: symtab.typing reg: symtab.reg key: k
    tid: u64
    match (
        go
    ) case some then {
        tid = go
    } case none then null
    if tid == 0 then return "".string
    cco: symtab.typing.childOfId parentTypeId: tid nameId: wkCreate
    match (
        cco
    ) case some then {
        if (symtab.reg.typetypeOf typeId: cco) == ztypes.ztypetype.functionType then {
            cpn: (List String)
            cpi: (List u64)
            cpiNm: (List u64)
            recFieldLists :ast :symtab tid: cco names: cpn ids: cpi nameIds: cpiNm
            cargs: String
            ci: u64
            ccn: cpn.length
            for ci < ccn loop {
                cpname: cpn.get i: ci
                cav: ctorArgByLabel :ast :symtab :ctx :call label: cpname.stringview
                if ci > 0 then cargs.append ", "
                cargs.append cav.stringview
                ci = ci + 1
            }
            ccBody9: false
            {
                ccrn9: symtab.typing.funcReturnNode.get key: cco
                match (
                    ccrn9
                ) case some then {
                    ccBody9 = true
                } case none then null
            }
            if ccBody9 then {
                ccb: symtab.reg.cnameOf tid: cco
                return "\{ccb}(\{cargs})"
            }
            fwcb9: symtab.reg.cnameOf :tid
            return "\{fwcb9}_create(\{cargs})"
        }
    } case none then null
    return "".string
}

# outerBaseAtom -- the leftmost atom of a LEFT-nested three-segment
# dotted path `(a.B).c`: "a". "" for shallower shapes.
outerBaseAtom: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case expression then {
        return (outerBaseAtom :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case dottedpath then {
        return (dottedBaseAtom :ast n: (ast.nodes.get i: (n.parent - 1).u64))
    } else {
        return "".string
    }
}

# emitCrossUnitUnionCtor -- a three-segment qualified union-arm
# construction (`json.Value.text s`): the in-unit form resolves the
# union by bare name, so the qualified middle segment needs its own
# leg, resolved through the defining unit's key like the create legs.
emitCrossUnitUnionCtor: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx

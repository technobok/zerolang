# user's own create may override -> recursion). "" when not a meta.create.
# ctorHasLabel -- whether a call carries a named argument with this label.
ctorHasLabel: function {call: zast.CallData label: StringView} out bool is {
    aiter: call.arguments.iterate
    for a: aiter loop {
        match (
            a
        ) case namedoperation then {
            an: unitLabel9 o: a.name
            if an.stringview == label then {
                return true
            } else {}
        } else {}
    }
    return false
}

emitMetaCreateCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    mcb: ztypecheck.metaCreateBaseId n: call.callable
    match (

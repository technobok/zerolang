} out String is {
    pbase: outerBaseAtom :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    ptype: dottedParentChild :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    if pbase.length == 0 then return "".string
    if ptype.length == 0 then return "".string
    arm9: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    if arm9.length == 0 then return "".string
    if arm9.stringview == "create" then return "".string
    if arm9.stringview == "borrow" then return "".string
    if (symtab.reg.isUnitName name: pbase.stringview) == false then return "".string
    k: "\{pbase}.\{ptype}"
    go: ztypecheck.resolvedByKey :ast ty: symtab.typing reg: symtab.reg key: k
    utid: u64
    match (
        go
    ) case some then {
        utid = go
    } case none then null
    if utid == 0 then return "".string
    if (symtab.reg.typetypeOf typeId: utid) != ztypes.ztypetype.unionType then return "".string
    vc: symtab.reg.cnameOf tid: utid
    tg: variantTag :symtab tid: utid arm: arm9.stringview
    payC: armPayloadC :ast :symtab :ctx tid: utid arm: arm9.stringview
    if payC.length > 0 then {
        av: String
        got: false
        aiter: call.arguments.iterate
        for aId9: aiter loop {
            a: ast.nodes.get i: (aId9 - 1).u64
            match (
                a
            ) case namedoperation then {
                if (got) == false then {
                    got = true
                    opf169: ast.nodes.get i: (a.operation - 1).u64
                    av = emitInterpArgExpr :ast :symtab :ctx n: opf169
                    if av.length == 0 then {
                        opf1039: ast.nodes.get i: (a.operation - 1).u64
                        av = emitExpr :ast :symtab :ctx n: opf1039
                    }
                }
            } else null
        }
        e: "({ \{vc}_t _u = {0}; _u.tag = \{tg}; \{payC}* _b = (\{payC}*)z_xmalloc(sizeof(\{payC})); *_b = \{av}; _u.data = _b; _u; })"
        return e
    } else {
        e2: "({ \{vc}_t _u = {0}; _u.tag = \{tg}; _u.data = NULL; _u; })"
        return e2
    }
}

emitCrossUnitCtor: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    base: dottedBaseAtom :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    child: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    if base.length == 0 then return "".string
    if child.length == 0 then return "".string
    if child.stringview == "create" then {
        ce9: emitCrossUnitExplicitCreate :ast :symtab :ctx :call
        if ce9.length > 0 then return ce9
    }
    if (symtab.reg.isUnitName name: base.stringview) == false then return "".string
    k: "\{base}.\{child}"
    go: ztypecheck.resolvedByKey :ast ty: symtab.typing reg: symtab.reg key: k
    tid: u64
    match (
        go
    ) case some then {
        tid = go
    } case none then null
    if tid == 0 then return "".string
    tt: symtab.reg.typetypeOf typeId: tid
    isRc: false
    if tt == ztypes.ztypetype.recordType then isRc = true
    if tt == ztypes.ztypetype.classType then isRc = true
    if (isRc) == false then return "".string
    return (emitRecordCtor :ast :symtab :ctx :call :tid name: child.stringview)
}

# emitCrossUnitTag -- a 3-segment cross-unit variant/enum tag value
# `unit.Type.arm` (zlexer.TT.dotTok, zast.err.badReference): pbase=unit, ptype=Type,
# arm=arm. Resolve the variant via the shared cross-unit identity and emit the
# no-payload tag value. "" when not such a reference.
emitCrossUnitTag: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    pbase: StringView
    ptype: StringView
    arm: StringView
} out String is {
    if pbase.length == 0 then return "".string
    if ptype.length == 0 then return "".string
    if arm.length == 0 then return "".string
    if (symtab.reg.isUnitName name: pbase) == false then return "".string
    k: "\{pbase}.\{ptype}"
    go: ztypecheck.resolvedByKey :ast ty: symtab.typing reg: symtab.reg key: k
    vtid: u64
    match (
        go
    ) case some then {
        vtid = go
    } case none then null
    if vtid == 0 then return "".string
    vtt: symtab.reg.typetypeOf typeId: vtid
    isTagged: false
    if vtt == ztypes.ztypetype.variantType then isTagged = true
    if vtt == ztypes.ztypetype.unionType then isTagged = true
    if (isTagged) == false then return "".string
    pc: armPayloadC :ast :symtab :ctx tid: vtid :arm
    if pc.length == 0 then {
        tg: variantTag :symtab tid: vtid :arm
        vc: symtab.reg.cnameOf tid: vtid
        e: "((\{vc}_t){ .tag = \{tg} })"
        return e
    }
    return "".string
}

# emitCallValue -- the C expression for a call (the dispatch chain:
# dotted/list/typedef/data/record-ctor/type-qual/variant/user-fn).
# Shared by emitExpr's call arm and the statement-position call leg
# so neither clones the node (clones lose the type stamps).
# emitFnptrFieldCall -- a call through a record/class fnptr field
# (`c.op a: 100 b: 200` -> `c.op(100, 200)`). "" when the callee member is not
# a flagged fnptr field. Explicit args only (slot params carry no `this`).
emitFnptrFieldCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    mn: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    if mn.length == 0 then return "".string
    rtid0: dottedReceiverStampId :ast :symtab callable: (ast.nodes.get i: (call.callable - 1).u64)
    rtid: chaseColMono :ast :symtab tid: rtid0
    if rtid == 0 then return "".string
    if (symtab.typing.isChildFnptrField
        pool: ast.names
        parentTypeId: rtid
        name: mn.stringview
    ) == false then return "".string
    xq159: ast.nodes.get i: (call.callable - 1).u64
    recvExpr: emitDottedReceiver :ast :symtab :ctx callable: xq159
    if recvExpr.length == 0 then return "".string
    rptr: dottedReceiverIsPtr :ast :symtab :ctx callable: (ast.nodes.get i: (call.callable - 1).u64)
    acc: ".".string
    if rptr then acc = "->".string
    args: String
    ai: u64
    aiter: call.arguments.iterate
    for aId9: aiter loop {
        a: ast.nodes.get i: (aId9 - 1).u64
        match (
            a
        ) case namedoperation then {
            av: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (a.operation - 1).u64)
            if ai > 0 then args.append ", "
            args.append av.stringview
            ai = ai + 1
        } else null
    }
    r: "\{recvExpr}\{acc}\{mn}(\{args})"
    return r
}

# emitFnptrLocalCall -- a call through a bare local/param of FUNCTION type
# (`cb a: 5 b: 7` -> `cb(5, 7)`, `f a: a b: b` -> `f(a, b)`). "" unless the
# callee is a bare atom whose stamped type is a FUNCTION (and not a top-level fn).
emitFnptrLocalCall: function {

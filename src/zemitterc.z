        pnjId: pidlNm.get i: j
        j = j + 1
        isRecv9: false
        if pnjId == wkThis.u64 then isRecv9 = true
        if thisPn9.length > 0 when thisPn9.stringview == pnj.stringview then isRecv9 = true
        if (isRecv9) == false then {

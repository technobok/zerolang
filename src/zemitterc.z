        if (originIsTid :symtab tid: nlid9 originTid: ctx.listOriginTid) then {
            nlcb9: symtab.reg.cnameOf tid: nlid9
            recvB9: colRecvRef :ctx bn: base9.stringview
            if mn2.stringview == "pop" then return "\{nlcb9}_pop(\{recvB9})"
            if mn2.stringview == "sort" then return "\{nlcb9}_sort(\{recvB9})"
            if mn2.stringview == "listview" then return "\{nlcb9}_listview(\{recvB9})"
            if mn2.stringview == "iterate" then return "\{nlcb9}_iterate(\{recvB9})"

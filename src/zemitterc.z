# zemitterc -- the C emitter (Phase C port of src/zemitterc.py).
#
# C1: preamble, String/StringView runtime fragments, string-literal pool,
# user-function emission, and a statement/expression walk covering the
# scalar core (locals, binops, if/for-while, return, recursion) plus
# print of plain and interpolated literals. Unhandled shapes emit marker
# comments so the C compiles and the gate reports honest RUN-DIFFs.

Node: zast.Node
Ast: zast.Ast

# Well-known Ast.names pool ids (fixed by Ast.create's intern order in
# zast.z -- the authority).
wkThis: 1.u32
wkReturn: 2.u32
wkBreak: 3.u32
wkContinue: 4.u32

# Well-known member-name pool ids (zast.z is the authority; append-only),
# widened to u64 for ZTypeChild.nameId keys.
wkCreate: 5.u64
wkCall: 7.u64
wkGet: 8.u64
wkSet: 9.u64
wkRemove: 11.u64
wkAdd: 12.u64
wkContains: 13.u64
wkSort: 14.u64
wkKey: 18.u64
wkValue: 19.u64
wkItem: 20.u64
wkSome: 21.u64
wkStringview: 25.u64
wkListview: 26.u64
wkIterate: 27.u64
wkIterateItems: 28.u64
wkOpEq: 29.u64
wkTag: 22.u64
wkBorrow: 6.u64


# TmpCtr -- per-function temp name counter.
TmpCtr: class {
    n: u64
    frees: (List String)
    listFrees: (List String)
    listFreeVars: (List String)
} as {
    next: function {:this} out u64 is {
        v: this.n
        this.n = this.n + 1
        return v
    }
}

# optU64Or9 -- an (optionval t: u64) to a plain u64 (0 when none).
optU64Or9: function {o: optionval u64} out u64 is {
    match (
        o
    ) case some then {
        return o
    } case none then {
        return 0
    }
}

# cnameOf -- the id-based C name base for a type ("z_t{id}_{name}", dots
# joined with underscores). Mirrors the reference's _assign_cname scheme;
# ids differ between the two typecheckers by design.
cnameOf: function {tid: u64 name: StringView} out String is {
    flat: String
    biter: u64
    n: name.length
    for biter < n loop {
        bo: name.byteAt i: biter
        match (
            bo
        ) case some then {
            if bo == 46 then {
                flat.append "_"
            } else {
                flat.appendByte b: bo
            }
        } case none then null
        biter = biter + 1
    }
    return "z_t\{tid}_\{flat}"
}

# cTypeOf -- the C spelling of a scalar type name ("" when not scalar).
cTypeOf: function {name: StringView} out String is {
    if name == "i8" then return "int8_t".string
    if name == "i16" then return "int16_t".string
    if name == "i32" then return "int32_t".string
    if name == "i64" then return "int64_t".string
    if name == "u8" then return "uint8_t".string
    if name == "u16" then return "uint16_t".string
    if name == "u32" then return "uint32_t".string
    if name == "u64" then return "uint64_t".string
    if name == "i128" then return "__int128".string
    if name == "u128" then return "unsigned __int128".string
    if name == "f32" then return "float".string
    if name == "f64" then return "double".string
    if name == "c8" then return "uint8_t".string
    if name == "c32" then return "uint32_t".string
    if name == "bool" then return "bool".string
    if name == "literal_int" then return "int64_t".string
    return "".string
}

# scalarCTypeFor -- the C scalar type for a builtin-named tid, BUT empty when the
# tid is a user type SHADOWING the scalar (defined in a user unit). The caller then
# emits the user struct (typeRefC / cnameOf) instead of the C scalar. The single
# "trust the canonical id, not the name" gate for the by-name C-type sites.
scalarCTypeFor: function {symtab: zenv.ZSymbolTable name: StringView tid: u64} out String is {
    sc: cTypeOf :name
    if sc.length == 0 then return sc
    if (ztypecheck.isUserShadowElem ty: symtab.typing reg: symtab.reg elemTid: tid) then {
        return "".string
    }
    return sc
}

# isIntName -- integer scalar family check (snprintf %ld path).
isIntName: function {name: StringView} out bool is {
    if name == "i8" then return true
    if name == "i16" then return true
    if name == "i32" then return true
    if name == "i64" then return true
    if name == "u8" then return true
    if name == "u16" then return true
    if name == "u32" then return true
    if name == "u64" then return true
    if name == "i128" then return true
    if name == "u128" then return true
    if name == "c8" then return true
    if name == "c32" then return true
    if name == "bool" then return true
    return false
}

isFloatName: function {name: StringView} out bool is {
    if name == "f32" then return true
    if name == "f64" then return true
    return false
}

# numBits -- integer numeric type bit width (0 if not an integer type).
numBits: function {name: StringView} out u64 is {
    if name == "i8" then return 8
    if name == "u8" then return 8
    if name == "c8" then return 8
    if name == "i16" then return 16
    if name == "u16" then return 16
    if name == "i32" then return 32
    if name == "u32" then return 32
    if name == "c32" then return 32
    if name == "i64" then return 64
    if name == "u64" then return 64
    if name == "i128" then return 128
    if name == "u128" then return 128
    return 0
}

# numSigned -- true for the signed integer family.
numSigned: function {name: StringView} out bool is {
    if name == "i8" then return true
    if name == "i16" then return true
    if name == "i32" then return true
    if name == "i64" then return true
    if name == "i128" then return true
    return false
}

# numLoStr / numHiStr -- decimal range bounds, the comparands of the
# overflow check emitted on a narrowing cast.
numLoStr: function {name: StringView} out String is {
    if name == "i8" then return "-128".string
    if name == "i16" then return "-32768".string
    if name == "i32" then return "-2147483648".string
    if name == "i64" then return "(-9223372036854775807LL - 1)".string
    if name == "i128" then return "-170141183460469231731687303715884105728".string
    return "0".string
}
numHiStr: function {name: StringView} out String is {
    if name == "i8" then return "127".string
    if name == "i16" then return "32767".string
    if name == "i32" then return "2147483647".string
    if name == "i64" then return "9223372036854775807".string
    if name == "i128" then return "170141183460469231731687303715884105727".string
    if name == "u8" then return "255".string
    if name == "c8" then return "255".string
    if name == "u16" then return "65535".string
    if name == "u32" then return "4294967295U".string
    if name == "c32" then return "4294967295U".string
    if name == "u64" then return "18446744073709551615ULL".string
    if name == "u128" then return "340282366920938463463374607431768211455".string
    return "0".string
}

# numLitSuffix -- the C integer-literal suffix for an unsigned type, so a large
# decimal literal (e.g. u64 max) is unambiguously unsigned to the C compiler.
numLitSuffix: function {name: StringView} out String is {
    if name == "u64" then return "ULL".string
    if name == "u32" then return "U".string
    if name == "c32" then return "U".string
    return "".string
}

# castLitVal -- val with the unsigned C suffix appended when it is a bare decimal
# literal cast to an unsigned type, so large u64 constants don't warn as signed.
castLitVal: function {val: StringView dstName: StringView} out String is {
    r: val.string
    sfx: numLitSuffix name: dstName
    if sfx.length == 0 then return r
    if val.length == 0 then return r
    allDig: true
    i: u64
    n: val.length
    for i < n loop {
        bo: val.byteAt :i
        match (
            bo
        ) case some then {
            if bo < 48 then allDig = false
            if bo > 57 then allDig = false
        } case none then null
        i = i + 1
    }
    if allDig then r.append sfx.stringview
    return r
}

# emitNumericCastResult -- build a `resultval t: <dstName> e: convError` value for
# a lossy numeric conversion `<val>.<dstName>` from `srcName`. Branchless: an
# int-narrowing range test, an int->float mantissa-span test, a float->int
# power-of-2 bounds + round-trip test, or an f64->f32 exact-representation test.
# retTid is the stamped resultval mono; okTag/errTag/RT are named from it.
emitNumericCastResult: function {
    srcName: StringView
    dstName: StringView
    val: StringView
    symtab: zenv.ZSymbolTable
    retTid: u64
} out String is {
    scT: cTypeOf name: srcName
    tcT: cTypeOf name: dstName
    rtBase: symtab.reg.cnameOf tid: retTid
    okTag: variantTag :symtab tid: retTid arm: "ok"
    errTag: variantTag :symtab tid: retTid arm: "err"
    sFloat: isFloatName name: srcName
    dFloat: isFloatName name: dstName
    okSet: "_r.tag = \{okTag}; _r.data.ok = (\{tcT})_v;"
    body: String
    if sFloat then {
        if dFloat then {
            errInf: "_r.tag = \{errTag}; _r.data.err.tag = Z_CONVERROR_TAG_OUTOFRANGE;"
            errPrecF: "_r.tag = \{errTag}; _r.data.err.tag = Z_CONVERROR_TAG_PRECISIONLOSS;"
            okF: "_r.tag = \{okTag}; _r.data.ok = _f;"
            body = "float _f = (float)_v; if (__builtin_isinf(_f) && !__builtin_isinf(_v)) { \{errInf} } else if ((double)_f != (double)_v) { \{errPrecF} } else { \{okF} }"
        } else {
            b: numBits name: dstName
            dsig: numSigned name: dstName
            inRange: String
            if dsig then {
                bm1: b - 1
                inRange = "(_v >= -0x1p\{bm1} && _v < 0x1p\{bm1})"
            } else {
                inRange = "(_v >= 0.0 && _v < 0x1p\{b})"
            }
            errOor: "_r.tag = \{errTag}; _r.data.err.tag = Z_CONVERROR_TAG_OUTOFRANGE;"
            errPrecI: "_r.tag = \{errTag}; _r.data.err.tag = Z_CONVERROR_TAG_PRECISIONLOSS;"
            body = "if (!\{inRange}) { \{errOor} } else if ((double)(\{tcT})_v != (double)_v) { \{errPrecI} } else { \{okSet} }"
        }
    } else {
        if dFloat then {
            p9: 53
            if dstName == "f32" then p9 = 24
            ssig: numSigned name: srcName
            magExpr: String
            if ssig then {
                magExpr = "(_v < 0 ? (uint64_t)(0 - (uint64_t)_v) : (uint64_t)_v)".string
            } else {
                magExpr = "(uint64_t)_v".string
            }
            errPrecX: "_r.tag = \{errTag}; _r.data.err.tag = Z_CONVERROR_TAG_PRECISIONLOSS;"
            body = "uint64_t _mag = \{magExpr}; if (_v == 0 || (64 - __builtin_clzll(_mag) - __builtin_ctzll(_mag)) <= \{p9}) { \{okSet} } else { \{errPrecX} }"
        } else {
            needsLo: true
            needsHi: true
            sbits: numBits name: srcName
            dbits: numBits name: dstName
            ssig: numSigned name: srcName
            dsig: numSigned name: dstName
            if ssig then {
                if dsig then {
                    if sbits <= dbits then needsLo = false
                }
            } else {
                needsLo = false
            }
            if ssig == dsig then {
                if sbits <= dbits then needsHi = false
            } else {
                if ssig then {
                    if sbits <= dbits then needsHi = false
                } else {
                    if sbits < dbits then needsHi = false
                }
            }
            cond: String
            if needsLo then {
                if needsHi then {
                    lo: numLoStr name: dstName
                    hi: numHiStr name: dstName
                    cond = "_v < \{lo} || _v > \{hi}"
                } else {
                    lo2: numLoStr name: dstName
                    cond = "_v < \{lo2}"
                }
            } else {
                if needsHi then {
                    hi2: numHiStr name: dstName
                    cond = "_v > \{hi2}"
                } else {
                    cond = "0".string
                }
            }
            errOor2: "_r.tag = \{errTag}; _r.data.err.tag = Z_CONVERROR_TAG_OUTOFRANGE;"
            body = "if (\{cond}) { \{errOor2} } else { \{okSet} }"
        }
    }
    r: "({ \{scT} _v = \{val}; \{rtBase}_t _r = {0}; \{body} _r; })"
    return r
}

# emitNumericCast -- a runtime numeric conversion `<val>.<dstName>` from source
# type `srcName`. When the stamped return type is a resultval mono the conversion
# is lossy and builds a `resultval t: <dst> e: convError` via emitNumericCastResult.
# Otherwise widening is a plain cast and narrowing emits an overflow-checked
# statement-expression (z_panic when out of range); unknown / non-integer source
# falls back to a plain cast.
emitNumericCast: function {
    srcName: StringView
    dstName: StringView
    val: StringView
    symtab: zenv.ZSymbolTable
    retTid: u64
} out String is {
    resOrig9: monoOriginName :symtab tid: retTid
    if resOrig9.stringview == "resultval" then return (emitNumericCastResult
        :srcName
        :dstName
        :val
        :symtab
        :retTid
    )
    dct: cTypeOf name: dstName
    if dct.length == 0 then return val.string
    sval: castLitVal :val :dstName
    dbits: numBits name: dstName
    if dbits == 0 then return "((\{dct})\{sval})"
    sbits: numBits name: srcName
    if sbits == 0 then return "((\{dct})\{sval})"
    ssig: numSigned name: srcName
    dsig: numSigned name: dstName
    needsLo: true
    needsHi: true
    if ssig then {
        if dsig then {
            if sbits <= dbits then needsLo = false
        }
    } else {
        needsLo = false
    }
    if ssig == dsig then {
        if sbits <= dbits then needsHi = false
    } else {
        if ssig then {
            if sbits <= dbits then needsHi = false
        } else {
            if sbits < dbits then needsHi = false
        }
    }
    if (needsLo) == false then {
        if (needsHi) == false then return "((\{dct})\{sval})"
    }
    sct: cTypeOf name: srcName
    cond: String
    if needsLo then {
        if needsHi then {
            lo: numLoStr name: dstName
            hi: numHiStr name: dstName
            cond = "_v < \{lo} || _v > \{hi}"
        } else {
            lo2: numLoStr name: dstName
            cond = "_v < \{lo2}"
        }
    } else {
        hi2: numHiStr name: dstName
        cond = "_v > \{hi2}"
    }
    r: "({ \{sct} _v = \{val}; if (\{cond}) z_panic(\"numeric cast overflow: \{srcName} to \{dstName}\"); (\{dct})_v; })"
    return r
}

# cUpperOf -- ASCII upper-case for tag spellings.
cUpperOf: function {text: StringView} out String is {
    buf: String
    i: u64
    n: text.length
    for i < n loop {
        bo: text.byteAt :i
        match (
            bo
        ) case some then {
            if bo >= 97 then {
                if bo <= 122 then {
                    buf.appendByte b: bo - 32
                } else {
                    buf.appendByte b: bo
                }
            } else {
                buf.appendByte b: bo
            }
        } case none then null
        i = i + 1
    }
    return buf
}

# cEscape -- escape literal text for a C string body.
cEscape: function {text: StringView} out String is {
    buf: String
    i: u64
    n: text.length
    for i < n loop {
        bo: text.byteAt :i
        match (
            bo
        ) case some then {
            if bo == 92 then {
                buf.append "\\\\"
            } else if bo == 34 then {
                buf.append "\\\""
            } else if bo == 10 then {
                buf.append "\\n"
            } else if bo == 9 then {
                buf.append "\\t"
            } else {
                buf.appendByte b: bo
            }
        } case none then null
        i = i + 1
    }
    return buf
}

# substituteAll -- replace every occurrence of needle in text.
substituteAll: function {text: String needle: StringView repl: StringView} out String is {
    buf: String
    pos: u64
    total: text.length
    for pos < total loop {
        remv: (text.substring from: pos to: total)
        fo: remv.indexOf :needle
        match (
            fo
        ) case some then {
            pre: (remv.substring from: 0 to: fo)
            buf.append pre
            buf.append repl
            pos = pos + fo + needle.length
        } case none then {
            buf.append remv
            pos = total
        }
    }
    return buf
}

# readTemplateCached -- the raw text of a runtime template file, read once
# per emit and cached by path. "" when the file is missing -- callers treat
# an empty read as the missing-template path.
readTemplateCached: function {ctx: Ctx path: StringView} out String is {
    cached9: String
    hit9: false
    {
        got: ctx.tmplCache.get key: path.string
        match (
            got
        ) case some then {
            cached9 = got.copy
            hit9 = true
        } case none then null
    }
    if hit9 then return cached9
    txt: String
    rd: io.readText :path
    match (
        rd
    ) case ok then {
        txt = rd.take
    } case err then null
    ctx.tmplCache.set key: path.string value: txt.copy
    return txt
}

# loadFragment -- read a runtime fragment and substitute the canonical
# z_StringView / z_String names with the registry's id-based ones
# (StringView first: z_String is its prefix).
loadFragment: function {path: StringView svC: StringView strC: StringView} out String is {
    rd: io.readText :path
    match (
        rd
    ) case ok then {
        s1: substituteAll text: rd needle: "z_StringView" repl: svC
        s2: substituteAll text: s1 needle: "z_String" repl: strC
        return s2
    } case err then {
        m9: "/* zemitterc: missing runtime fragment \{path} */\n"
        return m9
    }
}

# chunkText -- a stringchunk's text ("" for any other shape).
chunkText9: function {n: Node} out String is {
    match (
        n
    ) case stringchunk then {
        pv: n.text.stringview
        tc: pv.string
        return tc
    } else {
        return "".string
    }
}

# isInterp -- true when a literal has any non-chunk part.
isInterp: function {ast: Ast parts: List u32} out bool is {
    piter: parts.iterate
    for pId9: piter loop {
        p: ast.nodes.get i: (pId9 - 1).u64
        isC: false
        match (
            p
        ) case stringchunk then {
            isC = true
        } else null
        if (isC) == false then return true
    }
    return false
}

# wholeText -- a plain literal's joined chunk text.
wholeText: function {ast: Ast parts: List u32} out String is {
    buf: String
    piter: parts.iterate
    for pId9: piter loop {
        t: chunkText9 n: (ast.nodes.get i: (pId9 - 1).u64)
        buf.append t.stringview
    }
    return buf
}

# collectLiterals -- pool every PLAIN string-literal atom in walk order:
# parallel lists of (nodeid, text). Interpolated literals build at the
# use site instead.
collectLiterals: function {ast: Ast n: Node ids: List u64 texts: List String} is {
    match (
        n
    ) case statement then {
        siter: n.statements.iterate
        for sId9: siter loop collectLiterals :ast n: (ast.nodes.get i: (sId9 - 1).u64) :ids :texts
    } case statementline then {
        collectLiterals :ast n: (ast.nodes.get i: (n.statementline - 1).u64) :ids :texts
    } case expression then {
        collectLiterals :ast n: (ast.nodes.get i: (n.expression - 1).u64) :ids :texts
    } case namedoperation then {
        collectLiterals :ast n: (ast.nodes.get i: (n.operation - 1).u64) :ids :texts
    } case call then {
        collectLiterals :ast n: (ast.nodes.get i: (n.callable - 1).u64) :ids :texts
        aiter: n.arguments.iterate
        for a: aiter loop collectLiterals :ast n: (ast.nodes.get i: (a - 1).u64) :ids :texts
    } case dottedpath then {
        collectLiterals :ast n: (ast.nodes.get i: (n.parent - 1).u64) :ids :texts
    } case binop then {
        collectLiterals :ast n: (ast.nodes.get i: (n.lhs - 1).u64) :ids :texts
        collectLiterals :ast n: (ast.nodes.get i: (n.rhs - 1).u64) :ids :texts
    } case assignment then {
        collectLiterals :ast n: (ast.nodes.get i: (n.value - 1).u64) :ids :texts
    } case reassignment then {
        collectLiterals :ast n: (ast.nodes.get i: (n.value - 1).u64) :ids :texts
    } case ifexpr then {
        citer: n.clauses.iterate
        for cId9: citer loop collectLiterals :ast n: (ast.nodes.get i: (cId9 - 1).u64) :ids :texts
        if n.elseclause > 0 then {
            ec9: ast.nodes.get i: (n.elseclause - 1).u64
            collectLiterals :ast n: ec9 :ids :texts
        }
    } case caseexpr then {
        collectLiterals :ast n: (ast.nodes.get i: (n.subject - 1).u64) :ids :texts
        miter9: n.clauses.iterate
        for mc9: miter9 loop collectLiterals :ast n: (ast.nodes.get i: (mc9 - 1).u64) :ids :texts
        if n.elseclause > 0 then {
            ecl9: ast.nodes.get i: (n.elseclause - 1).u64
            collectLiterals :ast n: ecl9 :ids :texts
        }
    } case caseclause then {
        collectLiterals :ast n: (ast.nodes.get i: (n.statement - 1).u64) :ids :texts
    } case ifclause then {
        kiter: n.conditions.iterate
        for kId9: kiter loop collectLiterals :ast n: (ast.nodes.get i: (kId9 - 1).u64) :ids :texts
        collectLiterals :ast n: (ast.nodes.get i: (n.statement - 1).u64) :ids :texts
    } case withexpr then {
        collectLiterals :ast n: (ast.nodes.get i: (n.value - 1).u64) :ids :texts
        collectLiterals :ast n: (ast.nodes.get i: (n.body - 1).u64) :ids :texts
    } case doexpr then {
        collectLiterals :ast n: (ast.nodes.get i: (n.statement - 1).u64) :ids :texts
    } case yieldexpr then {
        collectLiterals :ast n: (ast.nodes.get i: (n.expr - 1).u64) :ids :texts
    } case forexpr then {
        fiter: n.conditions.iterate
        for f: fiter loop collectLiterals :ast n: (ast.nodes.get i: (f - 1).u64) :ids :texts
        if n.body > 0 then {
            fbl9: ast.nodes.get i: (n.body - 1).u64
            collectLiterals :ast n: fbl9 :ids :texts
        }
    } case atomstring then {
        if (isInterp :ast parts: n.stringparts) == false then {
            t: wholeText :ast parts: n.stringparts
            nid: n.nodeid.u64
            ids.append nid
            texts.append t
        } else {
            piter: n.stringparts.iterate
            for p: piter loop collectLiterals :ast n: (ast.nodes.get i: (p - 1).u64) :ids :texts
        }
    } else null
}

# litIndexOf -- the 1-based pool index for a literal's nodeid (0 = absent).
litIndexOf: function {ctx: Ctx nid: u64} out u64 is {
    i: u64
    n: ctx.litIds.length
    for i < n loop {
        v: ctx.litIds.get :i
        if v == nid then {
            ctx.usedLits.set key: nid value: true
            return i + 1
        }
        i = i + 1
    }
    return 0
}

# ternaryClause / ternaryElse -- if-expression rendering as nested C
# ternaries: each clause opens "(cond ? value : " and the else closes.
ternaryClause: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    c: Node
} out String is {
    match (
        c
    ) case ifclause then {
        cond: String
        kiter: c.conditions.iterate
        for kId9: kiter loop {
            k: ast.nodes.get i: (kId9 - 1).u64
            match (
                k
            ) case namedoperation then {
                cv: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (k.operation - 1).u64)
                if cond.length > 0 then cond.append " && "
                cond.append cv.stringview
            } else null
        }
        vx: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (c.statement - 1).u64)
        t0: "((\{cond}) ? (\{vx}) : "
        return t0
    } else {
        return "(0 ? 0 : ".string
    }
}

ternaryElse: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    oId: u32
} out String is {
    if oId > 0 then {
        ev: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (oId - 1).u64)
        e0: "(\{ev})"
        return e0
    } else {
        return "(0)".string
    }
}

# atomTextOf -- an atomid node's name text ("" for any other shape).
atomTextOf: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case atomid then {
        return (zast.nameTextCopy :ast ref: n.name)
    } else {
        return "".string
    }
}

# atomTextDeep -- atom text through expression wrappers.
atomTextDeep: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case expression then {
        return (atomTextDeep :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case atomid then {
        return (zast.nameTextCopy :ast ref: n.name)
    } else {
        return "".string
    }
}

# atomNodeId9 -- an atomid node's id (0 for any other shape).
atomNodeId9: function {n: Node} out u64 is {
    match (
        n
    ) case atomid then {
        return n.nodeid.u64
    } else {
        return 0
    }
}

stampIdOf: function {symtab: zenv.ZSymbolTable nid: u64} out u64 is {
    go: symtab.typing.nodeType.get key: nid
    match (
        go
    ) case some then {
        return go
    } case none then {
        return 0
    }
}

# dpTaggedOf9 -- the tagged-construction stamp for a dotted node: the
# variant/union type id when the path names a subtype member on the TYPE
# (`Type.arm`); 0 otherwise.
dpTaggedOf9: function {symtab: zenv.ZSymbolTable nid: u64} out u64 is {
    go: symtab.typing.dpTaggedParent.get key: nid
    match (
        go
    ) case some then {
        return go
    } case none then {
        return 0
    }
}

# dpArmPredicateOf9 -- the arm-predicate stamp for a dotted node: the
# variant/union type id when `value.arm` is a tag test; 0 otherwise.
dpArmPredicateOf9: function {symtab: zenv.ZSymbolTable nid: u64} out u64 is {
    go: symtab.typing.dpArmPredicate.get key: nid
    match (
        go
    ) case some then {
        return go
    } case none then {
        return 0
    }
}

# dpTagReadOf9 -- the tag-accessor stamp for a dotted node: the variant/
# union type id when `value.<accessor>` reads the discriminator; 0 otherwise.
dpTagReadOf9: function {symtab: zenv.ZSymbolTable nid: u64} out u64 is {
    go: symtab.typing.dpTagRead.get key: nid
    match (
        go
    ) case some then {
        return go
    } case none then {
        return 0
    }
}

# memberOwnerOf9 -- the receiver's canonical type id for a dotted member
# node; 0 when the path resolved through a non-member leg.
memberOwnerOf9: function {symtab: zenv.ZSymbolTable nid: u64} out u64 is {
    go: symtab.typing.memberOwnerTid.get key: nid
    match (
        go
    ) case some then {
        return go
    } case none then {
        return 0
    }
}

# matchDiverges -- true when a match node is stamped `never` (the typechecker's
# exhaustive + all-arms-diverge result), so its `default:` is provably unreachable.
matchDiverges: function {symtab: zenv.ZSymbolTable nid: u64} out bool is {
    tid: stampIdOf :symtab :nid
    if tid == 0 then return false
    tt: symtab.reg.typetypeOf typeId: tid
    if tt == ztypes.ztypetype.neverType then return true
    return false
}

# stampNameOf -- the registry name of a node's stamped type ("" unstamped).
stampNameOf: function {symtab: zenv.ZSymbolTable nid: u64} out String is {
    go: symtab.typing.nodeType.get key: nid
    match (
        go
    ) case some then {
        t: symtab.reg.typeById.get key: go
        match (
            t
        ) case some then {
            return t.name.copy
        } case none then null
    } case none then null
    return "".string
}

# builtinTid -- the canonical registry id of a stdlib builtin type (String, List,
# Map, ...) resolved by base name against system/collections; mainName "" so a
# user type of the same name never shadows it. 0 when absent from the program.
builtinTid: function {ast: Ast symtab: zenv.ZSymbolTable base: StringView} out u64 is {
    return (optU64Or9 o: (ztypecheck.walkLookupTyperef
        :ast
        ty: symtab.typing
        reg: symtab.reg
        currentUnit: ""
        :base)
    )
}

# originTidOf -- a type's genericOriginId (the template it monomorphized from), or
# 0 when it has none. The id form of monoOriginName.
originTidOf: function {symtab: zenv.ZSymbolTable tid: u64} out u64 is {
    # a partial spec (GENERIC_PARAM typetype) is trie bookkeeping, never an
    # emittable mono; origin-keyed sweeps must not select it
    if (symtab.reg.typetypeOf typeId: tid) == ztypes.ztypetype.genericParam then return 0
    t: symtab.reg.typeById.get key: tid
    match (
        t
    ) case some then {
        go: t.genericOriginId
        match (
            go
        ) case some then {
            return go
        } case none then null
    } case none then null
    return 0
}

# originIsTid -- true when tid's generic origin equals the (nonzero) originTid.
# The 0-guard means an origin-less type never matches an unresolved (0) builtin.
originIsTid: function {symtab: zenv.ZSymbolTable tid: u64 originTid: u64} out bool is {
    if originTid == 0 then return false
    return (originTidOf :symtab :tid) == originTid
}

# Ctx -- the per-program emission context (anchor cnames, main unit name,
# the literal pool, and the resolved-name map access).
Ctx: class {
    mainName: String
    realMain: String
    strC: String
    svC: String
    litIds: (List u64)
    usedLits: (Map u64 value: bool)
    constVals: (Map String value: String)
    needs: (Map String value: bool)
    methodReturns: (Map String value: String)
    dataElems: (Map String value: String)
    dataConst: (Map String value: String)
    ptrVars: (List String)
    aliases: (List NameVal)
    narrowBox: (List NameVal)
    narrowTid: (List NameTid)
    exclArms: (List NameVal)
    exclTids: (List NameTid)
    genActive: bool
    genYieldCount: u64
    genYieldNext: u64
    genWrap: String
    genSomeTag: String
    genNoneTag: String
    genPayC: String
    genHasValue: bool
    curThisTid: u64
    fastHash: bool
    tailRetActive: bool
    defUnitId: (Map u64 value: u64)
    unitIdByName: (Map String value: u64)
    unitTidsC: (List u64)
    unitKeysC: (List String)
    unitCacheBuilt: bool
    unitIdCtr: u64
    mainUnitId: u64
    condDepth: u64
    emitErrors: (List String)
    emittedUserTypes: (Map u64 value: bool)
    fwdDeclaredTypes: (Map u64 value: bool)
    tmplCache: (Map String value: String)
    argHoistNames: (List String)
    argHoistVals: (List String)
    argHoistTypes: (List String)
    argHoistDtors: (List String)
    argHoistRaw: (List String)
    argHoistCtr: u64
    breakLabels: (List u64)
    breakLabelIsDo: (List bool)
    contLabelUsed: (Map u64 value: bool)
    breakLabelCtr: u64
    breakLabelUsed: (Map u64 value: bool)
    breakFreesMarks: (List u64)
    breakListMarks: (List u64)
    breakLabelCleanup: (List String)
    breakLabelCleanupVar: (List String)
    borrowedVars: (Map String value: bool)
    strTid: u64
    svTid: u64
    strOriginTid: u64
    arrayOriginTid: u64
    listOriginTid: u64
    listViewOriginTid: u64
    mapOriginTid: u64
    setOriginTid: u64
    mapEntryOriginTid: u64
    listIterOriginTid: u64
    setIterOriginTid: u64
    mapKeyIterOriginTid: u64
    mapItemIterOriginTid: u64
    optionOriginTid: u64
    optionViewOriginTid: u64
    resultOriginTid: u64
    optionvalOriginTid: u64
    resultvalOriginTid: u64
}

# userFnId -- the resolved type id of a main-unit function name (0 absent).
userFnId: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx name: StringView} out u64 is {
    go: (ztypecheck.resolveUnitChild
        :ast
        ty: symtab.typing
        reg: symtab.reg
        unitName: ctx.mainName.stringview
        :name
    )
    match (
        go
    ) case some then {
        return go
    } case none then {
        return 0
    }
}

# userFnIdById -- id-keyed userFnId: the child name is already an Ast.names id.
userFnIdById: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx nameId: u32} out u64 is {
    go: (ztypecheck.resolveUnitChildById
        :ast
        ty: symtab.typing
        reg: symtab.reg
        unitName: ctx.mainName.stringview
        :nameId
    )
    match (
        go
    ) case some then {
        return go
    } case none then {
        return 0
    }
}

# isPtrVar -- true when a local name is a pointer-receiver param of the current
# class method body (so field reads emit `->` instead of `.`).
isPtrVar: function {ctx: Ctx name: StringView} out bool is {
    pi: u64
    pn: ctx.ptrVars.length
    for pi < pn loop {
        pv: ctx.ptrVars.get i: pi
        if pv.stringview == name then return true
        pi = pi + 1
    }
    return false
}

# pathIsPointer -- does the expression evaluate to a C pointer? A ptrVar atom
# (pointer receiver / lock param) or a dotted read of a `.lock` field both do,
# so field access on them chains with `->`.
pathIsPointer: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (pathIsPointer :ast :symtab :ctx n: (ast.nodes.get i: (n.expression - 1).u64))
    } case atomid then {
        anP9: ast.names.texts.get i: (n.name - 1).u64
        rn: aliasResolve :ctx name: anP9.stringview
        return (isPtrVar :ctx name: rn.stringview)
    } case labelvalue then {
        lnP9: ast.names.texts.get i: (n.name - 1).u64
        rln: aliasResolve :ctx name: lnP9.stringview
        return (isPtrVar :ctx name: rln.stringview)
    } case dottedpath then {
        cn: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        pnid: atomNodeId9 n: (ast.nodes.get i: (n.parent - 1).u64)
        pstamp: stampIdOf :symtab nid: pnid
        pstn: typeNameOfReg9 :symtab tid: pstamp
        prid: resolveTypeIdByName :ast :symtab :ctx name: pstn.stringview
        ptid: pstamp
        if prid > 0 then ptid = prid
        return (symtab.typing.isChildLockField
            pool: ast.names
            parentTypeId: ptid
            name: cn.stringview
        )
    } else {
        return false
    }
}

# NameVal / NameTid -- assoc-list entries for the per-function narrowing and
# alias state. A handful of entries at most, so linear StringView probes beat
# a map's per-probe owned-key allocation and hash.
NameVal: class {
    name: String
    val: String
}

NameTid: class {
    name: String
    tid: u64
}

# nvGet -- the value recorded for name, "" when absent (values never empty).
nvGet: function {xs: List NameVal name: StringView} out String is {
    i9: u64
    n9: xs.length
    for i9 < n9 loop {
        e9: xs.get i: i9
        if e9.name.stringview == name then return e9.val.copy
        i9 = i9 + 1
    }
    return "".string
}

nvHas: function {xs: List NameVal name: StringView} out bool is {
    i9: u64
    n9: xs.length
    for i9 < n9 loop {
        e9: xs.get i: i9
        if e9.name.stringview == name then return true
        i9 = i9 + 1
    }
    return false
}

# nvSet -- replace-or-append: one entry per name (map.set semantics).
nvSet: function {xs: List NameVal name: StringView val: StringView} is {
    i9: u64
    n9: xs.length
    for i9 < n9 loop {
        if (xs.get i: i9).name.stringview == name then {
            xs.set i: i9 val: (NameVal name: name.string val: val.string)
            return
        }
        i9 = i9 + 1
    }
    xs.append (NameVal name: name.string val: val.string)
}

# nvRemove -- drop name's entry (swap-with-last; names are unique).
nvRemove: function {xs: List NameVal name: StringView} is {
    i9: u64
    n9: xs.length
    for i9 < n9 loop {
        if (xs.get i: i9).name.stringview == name then {
            last9: xs.pop
            if i9 + 1 < n9 then xs.set i: i9 val: last9
            return
        }
        i9 = i9 + 1
    }
}

ntGet: function {xs: List NameTid name: StringView} out optionval u64 is {
    i9: u64
    n9: xs.length
    for i9 < n9 loop {
        e9: xs.get i: i9
        if e9.name.stringview == name then return (optionval.some e9.tid)
        i9 = i9 + 1
    }
    return (optionval.none u64)
}

ntSet: function {xs: List NameTid name: StringView tid: u64} is {
    i9: u64
    n9: xs.length
    for i9 < n9 loop {
        if (xs.get i: i9).name.stringview == name then {
            xs.set i: i9 val: (NameTid name: name.string :tid)
            return
        }
        i9 = i9 + 1
    }
    xs.append (NameTid name: name.string :tid)
}

ntRemove: function {xs: List NameTid name: StringView} is {
    i9: u64
    n9: xs.length
    for i9 < n9 loop {
        if (xs.get i: i9).name.stringview == name then {
            last9: xs.pop
            if i9 + 1 < n9 then xs.set i: i9 val: last9
            return
        }
        i9 = i9 + 1
    }
}

# aliasResolve -- a `.take` alias's base C name, or the name itself if none.
aliasResolve: function {ctx: Ctx name: StringView} out String is {
    # A match-arm narrowing (narrowBox) takes priority: inside the arm the name
    # resolves to the narrowed union payload cast, not the un-narrowed binding or a
    # stale for-loop/borrow/take alias -- mirrors takeSourceResolve.
    nbo: nvGet xs: ctx.narrowBox :name
    if nbo.length > 0 then return nbo
    ao: nvGet xs: ctx.aliases :name
    if ao.length > 0 then return ao
    return name.string
}

# takeSourceResolve -- the C lvalue to zero after a take of `name`: a match-arm
# narrowing's union box payload (narrowBox) takes priority over a plain `.take`
# alias, so the source zeroing invalidates the box, not just the narrowed copy.
takeSourceResolve: function {ctx: Ctx name: StringView} out String is {
    nbs9: nvGet xs: ctx.narrowBox :name
    hitN9: nbs9.length > 0
    if hitN9 then return nbs9
    # C-keyword-mangle the alias-resolved name for emission (this result is a
    # zeroing lvalue / source name). The narrowBox leg is a cast -- mangle no-op.
    ar: aliasResolve :ctx :name
    return (ztypes.mangleVarName name: ar.stringview)
}

# takeAliasBase -- the base atom of a `<x>.take` over a user record/class (an
# ownership-transfer alias: the binding reuses the source storage), else "".
takeAliasBase: function {ast: Ast symtab: zenv.ZSymbolTable n: Node} out String is {
    match (
        n
    ) case expression then {
        return (takeAliasBase :ast :symtab n: (ast.nodes.get i: (n.expression - 1).u64))
    } case statementline then {
        return (takeAliasBase :ast :symtab n: (ast.nodes.get i: (n.statementline - 1).u64))
    } case dottedpath then {
        cn9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if cn9.stringview != "take" then return "".string
        bnid9: atomNodeId9 n: (ast.nodes.get i: (n.parent - 1).u64)
        bt9: stampIdOf :symtab nid: bnid9
        bo9: monoOriginName :symtab tid: bt9
        if bo9.length != 0 then return "".string
        btt9: symtab.reg.typetypeOf typeId: bt9
        isUC9: false
        if btt9 == ztypes.ztypetype.recordType then isUC9 = true
        if btt9 == ztypes.ztypetype.classType then isUC9 = true
        if btt9 == ztypes.ztypetype.unionType then isUC9 = true
        if isUC9 then {
            return (atomTextOf :ast n: (ast.nodes.get i: (n.parent - 1).u64))
        } else {
            return "".string
        }
    } else {
        return "".string
    }
}

# takeStringSource -- if `n` is a `<atom>.take` over a String value, the resolved
# C name of the source local to zero after the move (the callee now owns the
# heap buffer), else "". Used at the statement level to suppress a double free.
takeStringSource: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
} out String is {
    match (
        n
    ) case expression then {
        return (takeStringSource :ast :symtab :ctx n: (ast.nodes.get i: (n.expression - 1).u64))
    } case statementline then {
        return (takeStringSource :ast :symtab :ctx n: (ast.nodes.get i: (n.statementline - 1).u64))
    } case dottedpath then {
        cn9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if cn9.stringview != "take" then return "".string
        bnid9: atomNodeId9 n: (ast.nodes.get i: (n.parent - 1).u64)
        bid9: stampIdOf :symtab nid: bnid9
        btn9: stampNameOf :symtab nid: bnid9
        isMv9: false
        if (stampIdOf :symtab nid: bnid9) == ctx.strTid then isMv9 = true
        if (symtab.reg.typetypeOf typeId: bid9) == ztypes.ztypetype.unionType then isMv9 = true
        if (symtab.reg.typetypeOf typeId: bid9) == ztypes.ztypetype.classType then {
            bn9c: atomTextOf :ast n: (ast.nodes.get i: (n.parent - 1).u64)
            if (isPtrVar :ctx name: bn9c.stringview) == false then isMv9 = true
        }
        if (isMv9) == false then return "".string
        bn9r: atomTextOf :ast n: (ast.nodes.get i: (n.parent - 1).u64)
        return (takeSourceResolve :ctx name: bn9r.stringview)
    } else {
        return "".string
    }
}

# takeMoveCtype -- the C type of a `<atom>.take` source (for the `(T){0}`
# zeroing), via typeRefC on the base's stamp (canonicalizes String to strC).
takeMoveCtype: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
} out String is {
    match (
        n
    ) case expression then {
        return (takeMoveCtype :ast :symtab :ctx n: (ast.nodes.get i: (n.expression - 1).u64))
    } case statementline then {
        return (takeMoveCtype :ast :symtab :ctx n: (ast.nodes.get i: (n.statementline - 1).u64))
    } case dottedpath then {
        bnid: atomNodeId9 n: (ast.nodes.get i: (n.parent - 1).u64)
        bid: stampIdOf :symtab nid: bnid
        return (typeRefC :ast :symtab :ctx tid: bid thisTid: 0)
    } else {
        return "".string
    }
}

# isFieldTake -- true iff `n` reduces to a `<obj>.field.take` whose parent is
# itself a dotted path (a field, not a bare atom). The field lvalue is zeroed
# after the move so the owner's destructor does not double-free the payload the
# take aliased out (a bare `<x>.take` is handled by takeStringSource).
isFieldTake: function {ast: Ast n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (isFieldTake :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case statementline then {
        return (isFieldTake :ast n: (ast.nodes.get i: (n.statementline - 1).u64))
    } case dottedpath then {
        cn9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if cn9.stringview != "take" then return false
        return (nodeIsDotted9 n: (ast.nodes.get i: (n.parent - 1).u64))
    } else {
        return false
    }
}

# emitNarrowedTakeZero -- before a return's scope cleanup, zero the payload box of
# every narrowed-subject `.take` reachable in the return value (a bare take, or a take
# passed as a construction/call arg). The un-shadowed narrowed subject is freed by the
# return cleanup; its `.take` moved the payload out as a shallow struct copy sharing the
# heap buffer, so the box must read {0} when the destructor walks it, else that buffer is
# double-freed. Non-narrowed takes are kept live by refsLocal and are not touched here.
# Mirrors the reference's implicit-take invalidation, flushed before scope cleanup.
emitNarrowedTakeZero: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    ind: StringView
    buf: String.borrow
} is {
    match (
        n
    ) case expression then {
        (emitNarrowedTakeZero
            :ast
            :symtab
            :ctx
            n: (ast.nodes.get i: (n.expression - 1).u64)
            :ind
            :buf
        )
    } case statementline then {
        sln9: ast.nodes.get i: (n.statementline - 1).u64
        emitNarrowedTakeZero :ast :symtab :ctx n: sln9 :ind :buf
    } case dottedpath then {
        cn9: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if cn9.stringview == "take" then {
            bn9: atomTextOf :ast n: (ast.nodes.get i: (n.parent - 1).u64)
            if (nvHas xs: ctx.narrowBox name: bn9.stringview) then {
                box9: takeSourceResolve :ctx name: bn9.stringview
                tido9: ntGet xs: ctx.narrowTid name: bn9.stringview
                match (
                    tido9
                ) case some then {
                    ct9: typeRefC :ast :symtab :ctx tid: tido9 thisTid: 0
                    inv9: "\{ind}\{box9} = (\{ct9}){0};\n"
                    buf.append inv9.stringview
                } case none then null
            }
        }
    } case call then {
        aiter9: n.arguments.iterate
        for a9Id9: aiter9 loop {
            a9: ast.nodes.get i: (a9Id9 - 1).u64
            match (
                a9
            ) case namedoperation then {
                (emitNarrowedTakeZero
                    :ast
                    :symtab
                    :ctx
                    n: (ast.nodes.get i: (a9.operation - 1).u64)
                    :ind
                    :buf
                )
            } else null
        }
    } else null
}

# implicitTakeSourceAtom -- the C move-source lvalue of a bare atom, decided by
# the typechecker's stamps ALONE (the emitter never re-resolves a name; a local
# may legitimately shadow a type). A local variable (atomVariableId) is a move
# source; a def/type/fn reference (atomUnitDefId) is not; an atom the checker
# stamped as neither (e.g. a generator-promoted local, now instance state) is a
# plain value and IS a move source.
implicitTakeSourceAtom: function {
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    nid: u64
    nm: StringView
} out String is {
    avo9: symtab.typing.atomVariableId.get key: nid
    match (
        avo9
    ) case some then {
        return (takeSourceResolve :ctx name: nm)
    } case none then null
    udo9: symtab.typing.atomUnitDefId.get key: nid
    match (
        udo9
    ) case some then {
        return "".string
    } case none then null
    return (takeSourceResolve :ctx name: nm)
}

implicitTakeSource: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
} out String is {
    match (
        n
    ) case expression then {
        return (implicitTakeSource :ast :symtab :ctx n: (ast.nodes.get i: (n.expression - 1).u64))
    } case atomid then {
        itA9: ast.names.texts.get i: (n.name - 1).u64
        return (implicitTakeSourceAtom :symtab :ctx nid: n.nodeid.u64 nm: itA9.stringview)
    } case labelvalue then {
        itL9: ast.names.texts.get i: (n.name - 1).u64
        return (implicitTakeSourceAtom :symtab :ctx nid: n.nodeid.u64 nm: itL9.stringview)
    } else {
        return "".string
    }
}

# implicitTakeFnId -- the param-bearing type for a call's implicit-take check: a
# direct FUNCTION callable, else the constructed type's `create` child, else the
# type itself (a field-wise construction reads field ownership from the type).
implicitTakeFnId: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out u64 is {
    cn0: atomTextOf :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    ct: userFnId :ast :symtab :ctx name: cn0.stringview
    if ct == 0 then {
        # A dotted method call resolves the method through the receiver's type,
        # not a bare-name lookup: a free function sharing the method's name
        # (zast.mkNamedOp vs the Parser.mkNamedOp method) otherwise wins below,
        # and its mismatched param names leave a moved-in owned arg un-zeroed.
        mdch0: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
        if mdch0.length > 0 then {
            xq229: ast.nodes.get i: (call.callable - 1).u64
            mrcv0: dottedReceiverStampId :ast :symtab callable: xq229
            if mrcv0 > 0 then {
                mmco0: (symtab.typing.childOf
                    pool: ast.names
                    parentTypeId: mrcv0
                    name: mdch0.stringview
                )
                match (
                    mmco0
                ) case some then {
                    if (symtab.reg.typetypeOf typeId: mmco0) == ztypes.ztypetype.functionType then {
                        ct = mmco0
                    }
                } case none then null
            }
        }
    }
    if ct == 0 then {
        # a cross-unit construction's callable is a dotted path (e.g.
        # `zast.UnitData`); atomTextOf is empty, so resolve the type by its
        # child name to reach its consuming `create` below (the same-unit path
        # resolves via the bare-atom userFnId above). Without this the moved-in
        # owned arg is never zeroed -> double free at the owner's destructor.
        dn0: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
        if dn0.length > 0 then {
            rt0: resolveTypeIdByName :ast :symtab :ctx name: dn0.stringview
            if rt0 > 0 then ct = rt0
        }
    }
    xq219: ast.nodes.get i: (call.callable - 1).u64
    if ct == 0 then return (stampIdOf :symtab nid: (nodeIdOf9 n: xq219))
    if (symtab.reg.typetypeOf typeId: ct) == ztypes.ztypetype.functionType then return ct
    cco: symtab.typing.childOfId parentTypeId: ct nameId: wkCreate
    match (
        cco
    ) case some then {
        if (symtab.reg.typetypeOf typeId: cco) == ztypes.ztypetype.functionType then return cco
    } case none then null
    return ct
}

# emitCallTakeInvalidations -- zero the source local of each ownership-moved arg
# of a call so its scope-exit destructor is a no-op (the move transferred
# ownership). An explicit `<atom>.take` uses takeStringSource; a bare owning-
# reftype local moved into a TAKE param is an implicit move (the hasDestructorName
# gate excludes borrow/lock views and scalars, which carry no destructor).
isCtorOwnerCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out bool is {
    smidO: stampIdOf :symtab nid: call.nodeid.u64
    soO: monoOriginName :symtab tid: smidO
    bnO: dottedBaseAtom :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    mcO9: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    if bnO.stringview == "meta" when mcO9.stringview == "create" then return true
    if (originIsTid
        :symtab
        tid: smidO
        originTid: ctx.optionOriginTid
    ) when bnO.stringview == "Option" then return true
    if (originIsTid
        :symtab
        tid: smidO
        originTid: ctx.resultOriginTid
    ) when bnO.stringview == "Result" then return true
    # user-defined union arm construction `MyUnion.arm <payload>`: the base atom
    # is the union TYPE (the child is the arm selector, not a type), so the
    # child-name resolution below misses it. A non-lock arm MOVES its payload
    # into the heap box, so the source must be zeroed (a lock arm BORROWS it).
    if bnO.length > 0 then {
        uctO: resolveTypeIdByName :ast :symtab :ctx name: bnO.stringview
        if uctO > 0 then {
            if (symtab.reg.typetypeOf typeId: uctO) == ztypes.ztypetype.unionType then {
                monoLk1: monoOriginName :symtab tid: uctO
                if monoLk1.length == 0 then {
                    uarmO: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
                    if (symtab.typing.isChildLockArm
                        pool: ast.names
                        parentTypeId: uctO
                        name: uarmO.stringview
                    ) == false then return true
                }
            }
        }
    }
    cn0: atomTextOf :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    ct: userFnId :ast :symtab :ctx name: cn0.stringview
    if ct == 0 then {
        # cross-unit construction (dotted callable, e.g. `zast.UnitData`):
        # resolve the constructed type by its child name so an owned arg moved
        # into a record/variant/class/union field is zeroed (else double free).
        dn0: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
        if dn0.length > 0 then {
            rt0: resolveTypeIdByName :ast :symtab :ctx name: dn0.stringview
            if rt0 > 0 then ct = rt0
        }
    }
    if ct == 0 then return false
    if (symtab.reg.typetypeOf typeId: ct) == ztypes.ztypetype.classType then return true
    if (symtab.reg.typetypeOf typeId: ct) == ztypes.ztypetype.unionType then return true
    if (symtab.reg.typetypeOf typeId: ct) == ztypes.ztypetype.recordType then return true
    if (symtab.reg.typetypeOf typeId: ct) == ztypes.ztypetype.variantType then return true
    return false
}

emitCallTakeInvalidations: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    ind: StringView
    buf: String.borrow
} is {
    ftid9: implicitTakeFnId :ast :symtab :ctx :call
    ctorOwner9: isCtorOwnerCall :ast :symtab :ctx :call
    mmn9: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    collMove9: false
    if mmn9.stringview == "append" then collMove9 = true
    if mmn9.stringview == "insert" then collMove9 = true
    if mmn9.stringview == "push" then collMove9 = true
    if collMove9 then {
        # The collection-move rule is for container elements; String.append
        # borrows its StringLike arg (byte copy), it never moves it.
        xr9: ast.nodes.get i: (call.callable - 1).u64
        rcm9: (chaseColMono
            :ast
            :symtab
            tid: (dottedReceiverStampId :ast :symtab callable: xr9)
        )
        if rcm9 == ctx.strTid then collMove9 = false
    }
    posI9: u64
    aiter9: call.arguments.iterate
    for a9Id9: aiter9 loop {
        a9: ast.nodes.get i: (a9Id9 - 1).u64
        match (
            a9
        ) case namedoperation then {
            ts9: takeStringSource :ast :symtab :ctx n: (ast.nodes.get i: (a9.operation - 1).u64)
            if ts9.length > 0 then {
                tc9: takeMoveCtype :ast :symtab :ctx n: (ast.nodes.get i: (a9.operation - 1).u64)
                inv9: "\{ind}\{ts9} = (\{tc9}){0};\n"
                buf.append inv9.stringview
            } else {
                isTake9: ctorOwner9
                if collMove9 then isTake9 = true
                lbl9: zast.nameTextCopy :ast ref: a9.name
                if lbl9.length > 0 then {
                    if (symtab.typing.childOwnershipIs
                        pool: ast.names
                        parentTypeId: ftid9
                        name: lbl9.stringview
                        own: ztypes.zparamownership.takeMode
                    ) then isTake9 = true
                    if (symtab.typing.childOwnershipIs
                        pool: ast.names
                        parentTypeId: ftid9
                        name: lbl9.stringview
                        own: ztypes.zparamownership.borrowMode
                    ) then isTake9 = false
                    if (symtab.typing.childOwnershipIs
                        pool: ast.names
                        parentTypeId: ftid9
                        name: lbl9.stringview
                        own: ztypes.zparamownership.lockMode
                    ) then isTake9 = false
                } else {
                    pnames9: (List String)
                    pids9: (List u64)
                    pids9Nm: (List u64)
                    recFieldLists :ast :symtab tid: ftid9 names: pnames9 ids: pids9 nameIds: pids9Nm
                    off9: u64
                    if pnames9.length > 0 then {
                        p09: pnames9.get i: 0
                        if p09.stringview == "this" then off9 = 1
                    }
                    pidx9: posI9 + off9
                    if pidx9 < pnames9.length then {
                        pn9: pnames9.get i: pidx9
                        if (symtab.typing.childOwnershipIs
                            pool: ast.names
                            parentTypeId: ftid9
                            name: pn9.stringview
                            own: ztypes.zparamownership.takeMode
                        ) then isTake9 = true
                    }
                }
                if isTake9 then {
                    isrc9: (implicitTakeSource
                        :ast
                        :symtab
                        :ctx
                        n: (ast.nodes.get i: (a9.operation - 1).u64)
                    )
                    if isrc9.length > 0 then {
                        istid9: (stampIdOf
                            :symtab
                            nid: (nodeIdOf9 n: (ast.nodes.get i: (a9.operation - 1).u64))
                        )
                        if (isHeapPtrCollection :ast :symtab :ctx tid: istid9) then {
                            iinvh9: "\{ind}\{isrc9} = NULL;\n"
                            buf.append iinvh9.stringview
                        } else {
                            if (symtab.reg.hasDestructorName typeId: istid9) then {
                                itc9: typeRefC :ast :symtab :ctx tid: istid9 thisTid: 0
                                iinv9: "\{ind}\{isrc9} = (\{itc9}){0};\n"
                                buf.append iinv9.stringview
                            }
                        }
                    }
                }
            }
            (emitValueTakeInvalidations
                :ast
                :symtab
                :ctx
                n: (ast.nodes.get i: (a9.operation - 1).u64)
                :ind
                :buf
            )
            posI9 = posI9 + 1
        } else null
    }
}

# emitValueTakeInvalidations -- statement-level source zeroing for a value node
# that reduces to a call (unwraps expression/statementline wrappers).
emitValueTakeInvalidations: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    ind: StringView
    buf: String.borrow
} is {
    match (
        n
    ) case expression then {
        iex69: ast.nodes.get i: (n.expression - 1).u64
        emitValueTakeInvalidations :ast :symtab :ctx n: iex69 :ind :buf
    } case statementline then {
        sln29: ast.nodes.get i: (n.statementline - 1).u64
        emitValueTakeInvalidations :ast :symtab :ctx n: sln29 :ind :buf
    } case call then {
        emitCallTakeInvalidations :ast :symtab :ctx call: n :ind :buf
    } else null
}

needsAdd: function {ctx: Ctx name: StringView} is {
    k: name.string
    v: true
    ctx.needs.set key: k value: v
}

needsHas: function {ctx: Ctx name: StringView} out bool is {
    k: name.string
    g: ctx.needs.get key: k
    match (
        g
    ) case some then {
        return true
    } case none then {
        return false
    }
}

isCompareOp: function {name: StringView} out bool is {
    if name == "==" then return true
    if name == "!=" then return true
    if name == "<" then return true
    if name == "<=" then return true
    if name == ">" then return true
    if name == ">=" then return true
    return false
}

isStringy: function {name: StringView} out bool is {
    if name == "String" then return true
    if name == "StringView" then return true
    return false
}

# isStringyTid -- the id form of isStringy: tid is canonical String or StringView.
isStringyTid: function {ctx: Ctx tid: u64} out bool is {
    if tid == ctx.strTid then return true
    return tid == ctx.svTid
}

# svValueForm -- a String/StringView operand as a by-value StringView C
# expression (a String operand view-converts via a compound literal).
svValueForm: function {ctx: Ctx expr: StringView isStr: bool} out String is {
    if isStr then {
        acc: ".".string
        if (isPtrVar :ctx name: expr) then acc = "->".string
        v1: "((\{ctx.svC}_t){ \{expr}\{acc}data, \{expr}\{acc}size })"
        return v1
    } else {
        v2: expr.string
        return v2
    }
}

# dottedBaseAtom / dottedChildText -- the parent atom and member name of
# a dotted path ("" when the shape is deeper than one segment).
dottedBaseAtom: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        return (atomTextOf :ast n: (ast.nodes.get i: (n.parent - 1).u64))
    } else {
        return "".string
    }
}

dottedChildText: function {ast: Ast n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        return (atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64))
    } else {
        return "".string
    }
}

# aliasOrChild / aliasChildName -- the internal member name a dotted-path node
# resolved to through a public-interface alias (typecheck stamp keyed on the
# dotted-path nodeid), else the plain AST child text. Centralizes rename-aware
# member-name emission so a renamed member emits its internal (declared) C name.
aliasOrChild: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    aliasId: u64
    childId: u32
} out String is {
    if symtab.typing.renameSeen then {
        ai9: symtab.typing.aliasInternalNameOf nodeid: aliasId
        if ai9.length > 0 then return ai9
    }
    return (atomTextOf :ast n: (ast.nodes.get i: (childId - 1).u64))
}

aliasChildName: function {ast: Ast symtab: zenv.ZSymbolTable n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        return (aliasOrChild :ast :symtab aliasId: n.nodeid.u64 childId: n.child)
    } else {
        return "".string
    }
}

dottedBaseNodeId: function {ast: Ast n: Node} out u64 is {
    match (
        n
    ) case dottedpath then {
        return (atomNodeId9 n: (ast.nodes.get i: (n.parent - 1).u64))
    } else {
        return 0
    }
}

# isSvParseNative -- a StringView parse native (parseF64/I64/U64) returning a
# resultval. Dispatched via ctx.svC so the canonical StringView cname is used
# (not a shell id stamped on a nested `.stringview` projection).
# isSvNoArgNative -- no-arg StringView natives whose fragments must be
# registered by the scanNeeds pre-pass: type-method bodies emit after
# emitNeededNatives, so an in-body needsAdd comes too late to matter.
isSvNoArgNative: function {name: StringView} out bool is {
    if name == "count" then return true
    if name == "hash" then return true
    if name == "codepoints" then return true
    if name == "lines" then return true
    return false
}

isSvParseNative: function {name: StringView} out bool is {
    if name == "parseF64" then return true
    if name == "parseI64" then return true
    if name == "parseU64" then return true
    return false
}

# svNativeName -- the simple StringView-native set C2b supports (the
# pointer-arg predicates and trims; indexOf/byteAt wait on optionval
# struct emission).
isSvSimpleNative: function {name: StringView} out bool is {
    if name == "isEmpty" then return true
    if name == "isAscii" then return true
    if name == "startsWith" then return true
    if name == "endsWith" then return true
    if name == "contains" then return true
    if name == "trim" then return true
    if name == "trimStart" then return true
    if name == "trimEnd" then return true
    if name == "toLowerAscii" then return true
    if name == "toUpperAscii" then return true
    if name == "replace" then return true
    if name == "replaceFirst" then return true
    if name == "repeated" then return true
    if name == "concat" then return true
    return false
}

# isSvArgNative -- an arg-taking StringView native returning optionval/
# Option (indexOf/byteAt/lastIndexOf/stripPrefix/stripSuffix/splitOnce).
isSvArgNative: function {name: StringView} out bool is {
    if name == "indexOf" then return true
    if name == "lastIndexOf" then return true
    if name == "byteAt" then return true
    if name == "stripPrefix" then return true
    if name == "stripSuffix" then return true
    if name == "splitOnce" then return true
    return false
}

# svArgAddr -- the &-form of a StringView native argument (pooled
# literal or local view); "" when unsupported.
svArgAddr: function {ast: Ast symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out String is {
    match (
        n
    ) case expression then {
        return (svArgAddr :ast :symtab :ctx n: (ast.nodes.get i: (n.expression - 1).u64))
    } case atomstring then {
        li: litIndexOf :ctx nid: n.nodeid.u64
        if li > 0 then {
            a1: "&_zs\{li}"
            return a1
        } else {
            return "".string
        }
    } case atomid then {
        anSA9: ast.names.texts.get i: (n.name - 1).u64
        an: anSA9.stringview
        # A String arg to a StringLike param projects to a by-value view.
        if (stampIdOf :symtab nid: n.nodeid.u64) == ctx.strTid then {
            svs9: svValueForm :ctx expr: an isStr: true
            a2s: "&\{svs9}"
            return a2s
        }
        a2: "&\{an}"
        return a2
    } case labelvalue then {
        anlC9: ast.names.texts.get i: (n.name - 1).u64
        anl: anlC9.stringview
        if (stampIdOf :symtab nid: n.nodeid.u64) == ctx.strTid then {
            svl9: svValueForm :ctx expr: anl isStr: true
            a2ls: "&\{svl9}"
            return a2ls
        }
        a2l: "&\{anl}"
        return a2l
    } case dottedpath then {
        dpm: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        if dpm.stringview == "stringview" then {
            pe: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (n.parent - 1).u64)
            ptid9: stampIdOf :symtab nid: (nodeIdOf9 n: (ast.nodes.get i: (n.parent - 1).u64))
            pIsStr9: ptid9 == ctx.strTid
            sv: svValueForm :ctx expr: pe.stringview isStr: pIsStr9
            a3: "&\{sv}"
            return a3
        }
        return "".string
    } else {
        return "".string
    }
}

# emitDottedCall -- a method call on a stamped String/StringView base:
# the simple native set emits {svC}_{member}(&base, &args...).
emitDottedCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    bn: dottedBaseAtom :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    mn: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    btid: u64
    if bn.length == 0 then {
        # nested/projected base (el.text.stringview.stripPrefix): no base atom, but
        # the base is a stamped String/StringView -- emit it as an expression (a
        # compound-literal lvalue, so the `&base` SV-native legs stay valid C).
        rsid9: (dottedReceiverStampId
            :ast
            :symtab
            callable: (ast.nodes.get i: (call.callable - 1).u64)
        )
        if (isStringyTid :ctx tid: rsid9) then {
            xq199: ast.nodes.get i: (call.callable - 1).u64
            bn = emitDottedReceiver :ast :symtab :ctx callable: xq199
            btid = rsid9
        } else {
            return "".string
        }
    } else {
        bnid: dottedBaseNodeId :ast n: (ast.nodes.get i: (call.callable - 1).u64)
        btid = stampIdOf :symtab nid: bnid
        # C-keyword-mangle the simple-atom receiver for emission (the bn.length==0
        # leg already routes through emitDottedReceiver). bn is emission-only below.
        bn = ztypes.mangleVarName name: bn.stringview
    }
    btIsStr9: btid == ctx.strTid
    if (isStringyTid :ctx tid: btid) when mn.stringview == "compare" then {
        # compare maps to the by-value cmp in the base fragment
        bf: svValueForm :ctx expr: bn.stringview isStr: btIsStr9
        cargs: String
        citer: call.arguments.iterate
        for caId9: citer loop {
            ca: ast.nodes.get i: (caId9 - 1).u64
            match (
                ca
            ) case namedoperation then {
                cae: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (ca.operation - 1).u64)
                cat: stampNameDeep :ast :symtab n: (ast.nodes.get i: (ca.operation - 1).u64)
                caIsStr9: cat.stringview == "String"
                caf: svValueForm :ctx expr: cae.stringview isStr: caIsStr9
                if cargs.length == 0 then cargs.append caf.stringview
            } else null
        }
        ce: "\{ctx.svC}_cmp(\{bf}, \{cargs})"
        return ce
    }
    if mn.stringview == "substring" then {
        fromA9: ctorArgByLabel :ast :symtab :ctx :call label: "from"
        toA9: ctorArgByLabel :ast :symtab :ctx :call label: "to"
        if fromA9.length > 0 when toA9.length > 0 then {
            recvp9: String
            if btid == ctx.svTid then {
                recvp9 = "&\{bn}"
            } else { if btIsStr9 then {
                bfs9: svValueForm :ctx expr: bn.stringview isStr: true
                recvp9 = "&\{bfs9}"
            } else {
                sacc9: ".".string
                if (isPtrVar :ctx name: bn.stringview) then sacc9 = "->".string
                recvp9 = "&((\{ctx.svC}_t){ \{bn}\{sacc9}data, \{bn}\{sacc9}len })"
            } }
            if recvp9.length > 0 then {
                needsAdd :ctx name: "substring"
                esb9: "\{ctx.svC}_substring(\{recvp9}, \{fromA9}, \{toA9})"
                return esb9
            }
        }
    }
    if (isStringyTid :ctx tid: btid) when mn.stringview == "split" then {
        needsAdd :ctx name: "sv_split"
        sepx9: String
        with siter9: call.arguments.iterate do for sa9Id9: siter9 loop {
            sa9: ast.nodes.get i: (sa9Id9 - 1).u64
            match (
                sa9
            ) case namedoperation then {
                opf2019: ast.nodes.get i: (sa9.operation - 1).u64
                if sepx9.length == 0 then {
                    sav9: svArgAddr :ast :symtab :ctx n: (ast.nodes.get i: (sa9.operation - 1).u64)
                    if sav9.length > 0 then {
                        sepx9.append sav9.stringview
                    } else {
                        sxe9: (emitExpr
                            :ast
                            :symtab
                            :ctx
                            n: (ast.nodes.get i: (sa9.operation - 1).u64)
                        )
                        sepx9.append "&"
                        if (stampIdOf
                            :symtab
                            nid: (nodeIdOf9 n: (ast.nodes.get i: (sa9.operation - 1).u64))
                        ) == ctx.strTid then {
                            sph9: (hoistBorrowValArg
                                :ast
                                :symtab
                                :ctx
                                isBorrow: (hoistExprIsBorrowRooted :ast :symtab :ctx n: opf2019)
                                av: sxe9.stringview
                                pid: ctx.strTid
                                paramTake: false
                            )
                            if sph9.length > 0 then sxe9 = sph9
                            svsp9: svValueForm :ctx expr: sxe9.stringview isStr: true
                            sepx9.append svsp9.stringview
                        } else {
                            sepx9.append sxe9.stringview
                        }
                    }
                }
            } else null

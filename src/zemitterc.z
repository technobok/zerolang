                # a typedef record (meters -> i64) is the chased scalar's zero
                ztd9: typedefChaseC :ast :symtab :ctx tid: brid
                if ztd9.length > 0 then return "((\{ztd9})0)"
                return (emitCtorDefaultsFill :ast :symtab :ctx tid: brid)
            } case none then null
            brc: cnameOf tid: brid name: btn.stringview
            be0: "((\{brc}_t){0})"

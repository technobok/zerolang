}

# ctorInterpArgByPosition -- the interp-arg form for the idx-th positional argument.
ctorInterpArgByPosition: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    idx: u64
    fid: u64
    pname: StringView
    pid: u64
} out String is {

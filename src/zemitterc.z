    pidlNm: (List u64)
    recFieldLists :ast :symtab tid: fnTid names: pn ids: pidl nameIds: pidlNm
    thisPn9: String
    {
        zo9: symtab.reg.typeById.get key: fnTid
        match (
            zo9
        ) case some then {
            thisPn9 = ztypecheck.optStrOrEmpty o: zo9.thisParamName
        } case none then null
    }
    args: String

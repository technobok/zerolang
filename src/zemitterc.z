    }
    return "".string
}

# argSlotList -- per call-argument (in call order), the index of the parameter
# slot it binds in `fpNames` (declaration order): a named arg binds by name, an
# unlabelled arg binds the next free slot via a positional cursor (first-arg
# elision). Returns `fpNames.length` (an out-of-range sentinel) for an argument
# that binds no value slot (e.g. a generic type-arg, whose name is not a value
# param). Lets a call's named args be emitted to C in PARAMETER order.
argSlotList: function {ast: Ast call: zast.CallData fpNames: List String} out List u64 is {
    out9: (List u64)
    cn9: fpNames.length
    consumed9: (List bool)
    ci9: u64
    for ci9 < cn9 loop {
        consumed9.append false
        ci9 = ci9 + 1
    }
    cursor9: u64
    aiter9: call.arguments.iterate
    for a9Id9: aiter9 loop {
        a9: ast.nodes.get i: (a9Id9 - 1).u64
        match (
            a9
        ) case namedoperation then {
            lbl9: zast.nameTextCopy :ast ref: a9.name
            slot9: fpNames.length
            if lbl9.length > 0 then {
                fi9: u64
                for fi9 < cn9 loop {
                    fpn9: fpNames.get i: fi9
                    if fpn9.stringview == lbl9.stringview then slot9 = fi9
                    fi9 = fi9 + 1
                }
            } else {
                adv9: true
                for adv9 loop {
                    if cursor9 >= cn9 then {
                        adv9 = false
                    } else {
                        if (consumed9.get i: cursor9) then {
                            cursor9 = cursor9 + 1
                        } else {
                            adv9 = false
                        }
                    }
                }
                if cursor9 < cn9 then {
                    slot9 = cursor9
                    cursor9 = cursor9 + 1
                }
            }
            if slot9 < cn9 then consumed9.set i: slot9 val: true
            out9.append slot9
        } else {
            out9.append fpNames.length
        }
    }
    return out9
}

# nodeConstText -- the C literal for a node carrying a compile-time
# const stamp (folded .LABEL data access, unit constants); "" otherwise.
nodeConstText: function {symtab: zenv.ZSymbolTable nid: u64} out String is {
    if nid == 0 then return "".string
    res: String
    if symtab.typing.nodeConst.length == 0 then return res
    with citer: symtab.typing.nodeConst.iterate do for row: citer loop {
        if row.nodeid == nid when res.length == 0 then {
            if row.value.kind == ztypes.zconstkind.ivalKind then {
                iv: row.value.ival
                res = "\{iv}"
                if iv > 9223372036854775807 then res = "\{iv}ULL"
            }
            if row.value.kind == ztypes.zconstkind.fvalKind then {
                fv: row.value.fval
                res = "\{fv}"
            }
        }
    }
    return res
}

# emitMetaCreateCall -- `meta.create field: val ...`, the enclosing type's raw
# allocator (its field children as params). The typecheck stamps the call node
# with that type; emit `{type}_meta_create(args)` (never `_create`, which the
# user's own create may override -> recursion). "" when not a meta.create.
# ctorHasLabel -- whether a call carries a named argument with this label.
ctorHasLabel: function {ast: Ast call: zast.CallData label: StringView} out bool is {
    aiter: call.arguments.iterate
    for aId9: aiter loop {
        a: ast.nodes.get i: (aId9 - 1).u64
        match (
            a
        ) case namedoperation then {
            an: zast.nameTextCopy :ast ref: a.name
            if an.stringview == label then return true
        } else null
    }
    return false
}

emitMetaCreateCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    mcb: ztypecheck.metaCreateBaseId :ast n: (ast.nodes.get i: (call.callable - 1).u64)
    match (
        mcb
    ) case some then {
        et: stampIdOf :symtab nid: call.nodeid.u64
        if et == 0 then return "".string
        etn: typeNameOfReg9 :symtab tid: et
        fnames: (List String)
        fids: (List u64)
        fidsNm: (List u64)
        recFieldLists :ast :symtab tid: et names: fnames ids: fids nameIds: fidsNm
        args: String
        fi: u64
        fn0: fnames.length
        for fi < fn0 loop {
            fname: fnames.get i: fi
            av: String
            if (ctorHasLabel :ast :call label: fname.stringview) then {
                av = ctorArgByLabel :ast :symtab :ctx :call label: fname.stringview
            } else {
                # a field absent from the meta.create args (a generator's promoted
                # local: an inner iterator struct or a loop counter) is value-
                # initialized; a typed zero compiles for both scalars and structs.
                ffid: fids.get i: fi
                ffct: typeRefC :ast :symtab :ctx tid: ffid thisTid: 0
                if ffct.length == 0 then {
                    pmsg7: "zemitterc: unspellable field type id \{ffid}"
                    panic pmsg7
                }
                if (symtab.typing.isChildLockField
                    pool: ast.names
                    parentTypeId: et
                    name: fname.stringview
                ) when (lockFieldIsReftypePtr :ast :symtab :ctx fid: ffid) then ffct = "\{ffct}*"
                av = "(\{ffct}){0}"
            }
            if fi > 0 then args.append ", "
            args.append av.stringview
            fi = fi + 1
        }
        ecb: cnameOf tid: et name: etn.stringview
        e0: "\{ecb}_meta_create(\{args})"
        return e0
    } case none then {
        return "".string
    }
}

# emitCrossUnitFnCall -- a cross-unit free-function call `unit.fn args`
# (e.g. zparser calling a zast/zlexer helper). The callee is a dottedpath whose
# base is a unit name; the function's shared id lives in resolved["{unit}.{fn}"],
# so emit z_t{id}_{fn}(args) with the same reftype-by-ref arg handling as a bare
# free-function call. "" when the callee is not a cross-unit function.
emitByrefArg: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    av: StringView
    pid: u64
    isBorrow: bool
} out String is {
    if (isNonLvalueArg s: av) == false then return "&\{av}"
    hn: ctx.argHoistCtr
    ctx.argHoistCtr = ctx.argHoistCtr + 1
    nmH: "_ah\{hn}"
    hcty: typeRefC :ast :symtab :ctx tid: pid thisTid: 0
    htyc: hcty.copy
    hrid: pid
    hduo: definedInUnitOf :symtab tid: pid
    match (
        hduo
    ) case none then {
        htn0: typeNameOfReg9 :symtab tid: pid
        hrr: resolveTypeIdByName :ast :symtab :ctx name: htn0.stringview
        if hrr > 0 then hrid = hrr
    } case some then null
    htn: typeNameOfReg9 :symtab tid: hrid
    hdt: String
    if isBorrow then {} else if hrid == ctx.strTid then {
        hdt = "    \{ctx.strC}_free(&\{nmH});\n"
    } else {
        if (symtab.reg.hasDestructorName typeId: hrid) then {
            hcb: cnameOf tid: hrid name: htn.stringview
            hdt = "    \{hcb}_destroy(&\{nmH});\n"
        }
    }
    avc: av.string
    r: "&\{nmH}"
    ctx.argHoistVals.append avc
    ctx.argHoistTypes.append htyc
    ctx.argHoistDtors.append hdt
    ctx.argHoistNames.append nmH
    return r
}

# fnIsNativeId -- the fn id's isNative flag (a mono inherits it from its
# native template at mint).
fnIsNativeId: function {symtab: zenv.ZSymbolTable fid: u64} out bool is {
    fz9: symtab.reg.typeById.get key: fid
    match (
        fz9
    ) case some then {
        return fz9.isNative
    } case none then {
        return false
    }
}

# emitGenericFnCall -- a generic free-function call (identity 42): the callable
# atom is stamped to the mono FUNCTION id by checkGenericCall. Emit that mono's
# cname applied to the args. "" when the callable does not resolve to a mono fn,
# or when the mono's template is NATIVE (no emitted body -- its C comes from a
# name interception like z_stringJoin).
emitGenericFnCall: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
} out String is {
    gdc9: aliasChildName :ast :symtab n: (ast.nodes.get i: (call.callable - 1).u64)
    if gdc9.length > 0 then return "".string
    gmf9: stampIdOf :symtab nid: (nodeIdOf9 n: (ast.nodes.get i: (call.callable - 1).u64))
    if gmf9 == 0 then return "".string
    if (symtab.reg.typetypeOf typeId: gmf9) != ztypes.ztypetype.functionType then return "".string
    gmo9: monoOriginName :symtab tid: gmf9
    if gmo9.length == 0 then return "".string
    if (fnIsNativeId :symtab fid: gmf9) then return "".string
    fc9: symtab.reg.cnameOf tid: gmf9
    fpNames9: (List String)
    fpIds9: (List u64)
    fpIds9Nm: (List u64)
    recFieldLists :ast :symtab tid: gmf9 names: fpNames9 ids: fpIds9 nameIds: fpIds9Nm
    slots9g: argSlotList :ast :call fpNames: fpNames9
    valBySlot9g: (Map u64 value: String)
    ai9: u64
    aiter9: call.arguments.iterate
    for a9Id9: aiter9 loop {
        a9: ast.nodes.get i: (a9Id9 - 1).u64
        match (
            a9
        ) case namedoperation then {
            opf2059: ast.nodes.get i: (a9.operation - 1).u64
            opf2049: ast.nodes.get i: (a9.operation - 1).u64
            slot9g: slots9g.get i: ai9
            if slot9g < fpNames9.length then {
                fpid9: fpIds9.get i: slot9g
                fpnO9: fpNames9.get i: slot9g
                iav9: (emitInterpArgForParam
                    :ast
                    :symtab
                    :ctx
                    n: (ast.nodes.get i: (a9.operation - 1).u64)
                    fid: gmf9
                    pname: fpnO9.stringview
                    pid: fpid9
                )
                if iav9.length > 0 then {
                    valBySlot9g.set key: slot9g value: iav9
                } else {
                    av9: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (a9.operation - 1).u64)
                    byref9: false
                    argRef9: String
                    ptra9: false
                    if (symtab.typing.childOwnershipIs
                        pool: ast.names
                        parentTypeId: gmf9
                        name: fpnO9.stringview
                        own: ztypes.zparamownership.takeMode
                    ) == false when (isReftypeParam :ast :symtab :ctx tid: fpid9) then {
                        ptra9 = true
                    } else {
                        if (isBorrowStringParam
                            :ast
                            :symtab
                            fid: gmf9
                            pname: fpnO9.stringview
                            pid: fpid9
                        ) then ptra9 = true
                    }
                    if (ptra9) == false then {
                        if (isListPtrParam
                            :ast
                            :symtab
                            fid: gmf9
                            pname: fpnO9.stringview
                            tid: fpid9
                        ) then ptra9 = true
                    }
                    if ptra9 then {
                        if (isPtrVar :ctx name: av9.stringview) == false then {
                            byref9 = true
                            argRef9 = (emitByrefArg
                                :ast
                                :symtab
                                :ctx
                                av: av9.stringview
                                pid: fpid9
                                isBorrow: (hoistExprIsBorrowRooted :ast :symtab :ctx n: opf2049)
                            )
                        }
                    }
                    vbh9x: String
                    if (ptra9) == false then {
                        vbh9x = (hoistBorrowValArg
                            :ast
                            :symtab
                            :ctx
                            av: av9.stringview
                            pid: fpid9
                            paramTake: (symtab.typing.childOwnershipIs
                                pool: ast.names
                                parentTypeId: gmf9
                                name: fpnO9.stringview
                                own: ztypes.zparamownership.takeMode
                            )
                            isBorrow: (hoistExprIsBorrowRooted :ast :symtab :ctx n: opf2059)
                        )
                    }
                    finalS9g: av9.copy
                    if byref9 then {
                        finalS9g = argRef9.copy
                    } else {
                        if vbh9x.length > 0 then finalS9g = vbh9x.copy
                    }
                    valBySlot9g.set key: slot9g value: finalS9g
                }
            }
            ai9 = ai9 + 1
        } else null
    }
    args9: String
    emitted9g: u64
    pp9g: u64
    ppn9g: fpNames9.length
    for pp9g < ppn9g loop {
        vo9g: valBySlot9g.get key: pp9g
        match (
            vo9g
        ) case some then {
            if emitted9g > 0 then args9.append ", "
            args9.append vo9g.stringview
            emitted9g = emitted9g + 1
        } case none then null
        pp9g = pp9g + 1
    }
    e9: "\{fc9}(\{args9})"
    return e9
}


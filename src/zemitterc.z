}

# emitErrorStmt -- an `error` call the fold pass could not eliminate. Behind
# a runtime guard it traps via z_panic (reachability is not provable); in
# unconditional position the spec says compilation fails: the message is
# recorded for the driver and the trap emitted as a placeholder.
emitErrorStmt: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    ind: StringView
    buf: String.borrow
} is {
    av: String
    lit: String
    got: false
    aiter: call.arguments.iterate
    for aId9: aiter loop {
        a: ast.nodes.get i: (aId9 - 1).u64
        match (
            a
        ) case namedoperation then {
            if (got) == false then {
                got = true
                opn9: ast.nodes.get i: (a.operation - 1).u64
                av = emitExpr :ast :symtab :ctx n: opn9
                lit = plainStringLiteral9 :ast n: opn9
            }
        } else null
    }
    okArg: false
    if got then {
        if (av.stringview.startsWith prefix: "/*") == false then okArg = true
    }
    if okArg then {
        el9: "\{ind}z_panic((const char*)\{av}.data);\n"
        buf.append el9.stringview
    } else {
        ef9: "\{ind}z_panic(\"(compile-time error)\");\n"
        buf.append ef9.stringview
    }
    if ctx.condDepth == 0 when ctx.genActive == false then {
        em9: lit.copy
        if em9.length == 0 then em9 = "compile-time error reached".string
        ctx.emitErrors.append from: em9
    }
}

# emitPanicStmt -- `panic "msg"` routes through the shared z_panic runtime
# helper. msg is a StringLike (String/StringView); both expose `.data` as a

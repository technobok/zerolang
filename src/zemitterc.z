        }
    } else null
}

emitRecordMethods: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    tid: u64
    op: Node
    declOnly: bool
    buf: String.borrow
} is {
    if (isGenericType :symtab :tid) then {
        emitClassMonoMethods :ast :symtab :ctx tplId: tid :op :declOnly :buf
        return
    }
    match (
        op
    ) case objectdef then {
        idxs: (List u64)
        names: (List String)
        ai: u64
        with aiter: op.asItems.iterate do for amId9: aiter loop {
            am: ast.nodes.get i: (amId9 - 1).u64
            match (
                am
            ) case namedoperation then {
                if (isFunctionDefWithBody9 n: (ast.nodes.get i: (am.operation - 1).u64)) then {
                    av: ai
                    idxs.append av
                    an: zast.nameTextCopy :ast ref: am.name
                    names.append an
                }
            } else null
            ai = ai + 1
        }
        wi: u64
        wn: idxs.length
        for wi < wn loop {
            midx: idxs.get i: wi
            mname: names.get i: wi
            am2Id9: op.asItems.get i: midx
            am2: ast.nodes.get i: (am2Id9 - 1).u64
            match (
                am2
            ) case namedoperation then {
                mo: symtab.typing.childOf pool: ast.names parentTypeId: tid name: mname.stringview
                match (
                    mo
                ) case some then {
                    (emitOneMethod
                        :ast
                        :symtab
                        :ctx
                        mid: mo
                        thisTid9: tid
                        op: (ast.nodes.get i: (am2.operation - 1).u64)
                        :declOnly
                        :buf
                    )
                } case none then null
            } else null
            wi = wi + 1
        }
        iidxs9: (List u64)
        inames9: (List String)
        iai9: u64
        with iiter9: op.isItems.iterate do for im9Id9: iiter9 loop {
            im9: ast.nodes.get i: (im9Id9 - 1).u64
            match (
                im9
            ) case namedoperation then {
                if (isFunctionDefWithBody9 n: (ast.nodes.get i: (im9.operation - 1).u64)) then {
                    iav9: iai9
                    iidxs9.append iav9
                    ian9: zast.nameTextCopy :ast ref: im9.name
                    inames9.append ian9
                }
            } else null
            iai9 = iai9 + 1
        }
        iwi9: u64
        iwn9: iidxs9.length
        for iwi9 < iwn9 loop {
            imidx9: iidxs9.get i: iwi9
            imname9: inames9.get i: iwi9
            im2Id9: op.isItems.get i: imidx9
            im2: ast.nodes.get i: (im2Id9 - 1).u64
            match (
                im2
            ) case namedoperation then {
                imo9: (symtab.typing.childOf
                    pool: ast.names
                    parentTypeId: tid
                    name: imname9.stringview
                )
                match (
                    imo9
                ) case some then {
                    (emitOneMethod
                        :ast
                        :symtab
                        :ctx
                        mid: imo9
                        thisTid9: tid
                        op: (ast.nodes.get i: (im2.operation - 1).u64)
                        :declOnly
                        :buf
                    )
                } case none then null
            } else null
            iwi9 = iwi9 + 1
        }
    } else null
}

# nodeYieldCount -- the number of `yield` expressions in a subtree (yields do
# not nest). Mirrors the typechecker's subtreeHasYield walk. Used to detect a
# generator `call` body and size its resume-state switch.
nodeYieldCount: function {ast: Ast n: Node} out u64 is {
    match (
        n
    ) case yieldexpr then {
        return 1
    } case statement then {
        c: u64
        siter: n.statements.iterate
        for stId9: siter loop {
            st: ast.nodes.get i: (stId9 - 1).u64
            c = c + (nodeYieldCount :ast n: st)
        }
        return c
    } case statementline then {
        sln9: ast.nodes.get i: (n.statementline - 1).u64
        return (nodeYieldCount :ast n: sln9)
    } case expression then {
        return (nodeYieldCount :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case assignment then {
        return (nodeYieldCount :ast n: (ast.nodes.get i: (n.value - 1).u64))
    } case forexpr then {
        if n.body == 0 then return 0
        return (nodeYieldCount :ast n: (ast.nodes.get i: (n.body - 1).u64))
    } case ifexpr then {
        c2: u64
        cliter: n.clauses.iterate
        for clId9: cliter loop {
            cl9r: ast.nodes.get i: (clId9 - 1).u64
            c2 = c2 + (nodeYieldCount :ast n: cl9r)
        }
        if n.elseclause > 0 then {
            ec9: ast.nodes.get i: (n.elseclause - 1).u64
            c2 = c2 + (nodeYieldCount :ast n: ec9)
        }
        return c2
    } case ifclause then {
        return (nodeYieldCount :ast n: (ast.nodes.get i: (n.statement - 1).u64))
    } else {
        return 0
    }
}

# fnYieldCount -- yields in a functiondef body (0 for a non-generator).
fnYieldCount: function {ast: Ast op: Node} out u64 is {
    match (
        op
    ) case functiondef then {
        if op.body == 0 then return 0
        return (nodeYieldCount :ast n: (ast.nodes.get i: (op.body - 1).u64))
    } else {
        return 0
    }
}

# setupGenCtx -- arm the generator state-machine context on ctx when `op` is a
# generator `call` (its body yields). Resolves the optionval wrapper from the
# method's return type. Returns false (and disarms) for a normal method.
setupGenCtx: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    mid: u64
    op: Node
} out bool is {
    gyc: fnYieldCount :ast :op
    if gyc == 0 then {
        ctx.genActive = false
        return false
    }
    rid: fnReturnTidOf :symtab tid: mid
    if rid == 0 then {
        mro: ztypecheck.methodReturnOf st: symtab :mid
        match (
            mro
        ) case some then {
            rid = mro
        } case none then null
    }
    if rid == 0 then {
        ctx.genActive = false
        return false
    }
    rn: typeNameOfReg9 :symtab tid: rid
    ru: cUpperOf text: rn.stringview
    rc: symtab.reg.cnameOf tid: rid
    ctx.genActive = true
    ctx.genYieldCount = gyc
    ctx.genYieldNext = 1
    ctx.genWrap = "\{rc}_t"
    ctx.genSomeTag = "Z_\{ru}_TAG_SOME"
    ctx.genNoneTag = "Z_\{ru}_TAG_NONE"
    # a reftype element wraps in Option: the yield leg boxes the payload
    # (emitOptionalAssign's malloc'd-box shape); valtype wrappers stay inline.
    gp9: String
    if (originIsTid :symtab tid: rid originTid: ctx.optionOriginTid) then {
        gp9 = armPayloadC :ast :symtab :ctx tid: rid arm: "some"
    }
    ctx.genPayC = gp9
    hasVal9: false
    match (
        op
    ) case functiondef then {
        with piter9: op.parameters.iterate do for pm9Id9: piter9 loop {
            pm9: ast.nodes.get i: (pm9Id9 - 1).u64
            match (
                pm9
            ) case namedoperation then {
                pl9: zast.nameTextCopy :ast ref: pm9.name
                if pl9.stringview == "value" then hasVal9 = true
            } else null
        }
    } else null
    ctx.genHasValue = hasVal9
    return true
}

# emitGenPrologue -- the resume dispatch: switch on this->state to L_entry / the
# per-yield resume labels / L_done.
emitGenPrologue: function {ctx: Ctx buf: String.borrow} is {
    if ctx.genHasValue then buf.append "    this->_resume_input = value;\n"
    buf.append "    switch (this->state) {\n"
    buf.append "        case 0: goto L_entry;\n"
    k: 1.u64
    for k <= ctx.genYieldCount loop {
        lk: "        case \{k}: goto L_resume_\{k};\n"
        buf.append lk.stringview
        k = k + 1
    }
    buf.append "        default: goto L_done;\n"
    buf.append "    }\n"
    buf.append "L_entry:;\n"
}

# emitGenEpilogue -- the terminal landing: mark done and return the NONE wrapper.
emitGenEpilogue: function {ctx: Ctx buf: String.borrow} is {
    buf.append "L_done:;\n"
    buf.append "    this->state = -1;\n"
    le: "    \{ctx.genWrap} _r_done = {0};\n"
    buf.append le.stringview
    lt: "    _r_done.tag = \{ctx.genNoneTag};\n"
    buf.append lt.stringview
    buf.append "    return _r_done;\n"
}

# isYieldNode -- the node (through expression wrappers) is a yield expression.
isYieldNode: function {ast: Ast n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (isYieldNode :ast n: (ast.nodes.get i: (n.expression - 1).u64))
    } case yieldexpr then {
        return true
    } else {
        return false
    }
}

# emitYieldFromNode -- emit the suspension for a yield reached through expression
# wrappers (the expression-form `name: yield E`).
emitYieldFromNode: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    match (
        n
    ) case expression then {
        iexF9: ast.nodes.get i: (n.expression - 1).u64
        emitYieldFromNode :ast :symtab :ctx n: iexF9 :ind :tmp :buf
    } case yieldexpr then {
        emitYieldStmt :ast :symtab :ctx yd: n :ind :tmp :buf
    } else null
}

# emitExprFormYield -- `name: yield E` in a bidirectional generator: suspend
# (yield E), then bind name to the resume input the next `.call value:` provides.
# A valtype binds the value directly; a borrowed reftype binds a pointer alias.
emitExprFormYield: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    value: Node
    aid: u64
    nm: StringView
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    emitYieldFromNode :ast :symtab :ctx n: value :ind :tmp :buf
    ltid9: stampIdOf :symtab nid: aid
    ct9: typeRefC :ast :symtab :ctx tid: ltid9 thisTid: 0
    if ct9.length == 0 then ct9 = "int64_t".string
    tt9: symtab.reg.typetypeOf typeId: ltid9
    isRef9: false
    if tt9 == ztypes.ztypetype.classType then isRef9 = true
    if tt9 == ztypes.ztypetype.unionType then isRef9 = true
    if isRef9 then {
        lp0: "\{ind}\{ct9}* __borrow_\{nm} = this->_resume_input;\n"
        buf.append lp0.stringview
        lp1: "\{ind}/* alias: \{nm} => (*__borrow_\{nm}) */\n"
        buf.append lp1.stringview
        av9: "(*__borrow_\{nm})"
        nvSet xs: ctx.aliases name: nm val: av9.stringview
    } else {
        lp2: "\{ind}\{ct9} \{nm} = this->_resume_input;\n"
        buf.append lp2.stringview
    }
}

# emitYieldStmt -- one `yield E` suspension: set the resume state, return the
# SOME-wrapped value, then drop a resume label at column 0 (goto-reachable into
# the enclosing block).
emitYieldStmt: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    yd: zast.YieldExprData
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    k: ctx.genYieldNext
    ctx.genYieldNext = k + 1
    # an interpolated yield value builds via a self-contained statement
    # expression (emitExpr :ast cannot emit the chain)
    yx9: ast.nodes.get i: (yd.expr - 1).u64
    ve: emitInterpArgExpr :ast :symtab :ctx n: yx9
    if ve.length == 0 then ve = emitExpr :ast :symtab :ctx n: yx9
    ls: "\{ind}this->state = \{k};\n"
    buf.append ls.stringview
    lw: "\{ind}\{ctx.genWrap} _ry_\{k} = {0};\n"
    buf.append lw.stringview
    tgt9: "_ry_\{k}"
    (emitOptionalAssign
        target: tgt9.stringview
        someTag: ctx.genSomeTag.stringview
        payC: ctx.genPayC.stringview
        vx: ve.stringview
        :ind
        :buf
    )
    # a boxed yield MOVES an lvalue operand (a promoted local `this->x`):
    # zero the source so the instance destructor does not double-free it
    if ctx.genPayC.length > 0 then {
        if (isNonLvalueArg s: ve.stringview) == false then {
            lzv9: "\{ind}\{ve} = (\{ctx.genPayC}){0};\n"
            buf.append lzv9.stringview
        }
    }
    lr: "\{ind}return _ry_\{k};\n"
    buf.append lr.stringview
    ll: "L_resume_\{k}:;\n"
    buf.append ll.stringview
}

emitOneMethod: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    mid: u64
    thisTid9: u64
    op: Node
    declOnly: bool
    buf: String.borrow
} is {
    mc: symtab.reg.cnameOf tid: mid
    ret: "void".string
    {
        rto: fnReturnTidOf :symtab tid: mid
        if rto > 0 then {
            rr: typeRefC :ast :symtab :ctx tid: rto thisTid: thisTid9
            if rr.length > 0 then ret = rr
        }
    }
    if ret.stringview == "void" then {
        # generic-mono returns (optionval/Option/resultval) carry no registry
        # returnTypeId; the return-type node stamp resolves the mono id.
        mro: ztypecheck.methodReturnOf st: symtab :mid
        match (
            mro
        ) case some then {
            mrr: typeRefC :ast :symtab :ctx tid: mro thisTid: thisTid9
            if mrr.length > 0 then ret = mrr
        } case none then null
    }
    if ret.stringview == "void" when thisTid9 > 0 then {
        rbn0: ztypecheck.fnReturnBaseNameOf :ast :op
        if rbn0.stringview == "this" then {
            tcb: symtab.reg.cnameOf tid: thisTid9
            ret = "\{tcb}_t"
        }
    }
    if ret.stringview == "void" then {
        rbn: ztypecheck.fnReturnBaseNameOf :ast :op
        if rbn.length > 0 then {
            rbi: userFnId :ast :symtab :ctx name: rbn.stringview
            if rbi > 0 then {
                rr2: typeRefC :ast :symtab :ctx tid: rbi thisTid: thisTid9
                if rr2.length > 0 then ret = rr2
            } else {
                rr3: cTypeOf name: rbn.stringview
                if rr3.length > 0 then ret = rr3
            }
        }
    }
    # a Set/Map return is a heap pointer (like a Set/Map param), so the
    # value-typed ret gets a `*`. Mirrors isSetMapPtrParam at the param sites.
    if ret.stringview != "void" then {
        retColId9: u64
        {
            tR9: symtab.reg.typeById.get key: mid
            match (
                tR9
            ) case some then {
                rtoR9: tR9.returnTypeId
                match (
                    rtoR9
                ) case some then {
                    retColId9 = rtoR9
                } case none then null
            } case none then null
        }
        if retColId9 == 0 then {
            mroR9: ztypecheck.methodReturnOf st: symtab :mid
            match (
                mroR9
            ) case some then {
                retColId9 = mroR9
            } case none then null
        }
        if retColId9 > 0 when (isHeapPtrCollection
            :ast
            :symtab
            :ctx
            tid: retColId9
        ) then ret = "\{ret}*"
    }
    params: String
    pnames: (List String)
    pids: (List u64)
    pidsNm: (List u64)
    recFieldLists :ast :symtab tid: mid names: pnames ids: pids nameIds: pidsNm
    # a CLASS method takes its `this` receiver by pointer (reference semantics):
    # the receiver param gets a `*` and its name is recorded so the body emits
    # `c->field`. Reset for this method (names must not leak into other bodies).
    ctx.ptrVars = (List String)
    ctx.aliases = (List NameVal)
    ctx.narrowBox = (List NameVal)
    encIsClass: false
    if (symtab.reg.typetypeOf typeId: thisTid9) == ztypes.ztypetype.classType then encIsClass = true
    clsNm9: typeNameOfReg9 :symtab tid: thisTid9
    pi: u64
    pn: pnames.length
    for pi < pn loop {
        pname: pnames.get i: pi
        pid: pids.get i: pi
        pt: typeRefC :ast :symtab :ctx tid: pid thisTid: thisTid9
        if pt.length == 0 then pt = "int64_t".string
        if encIsClass then {
            ptn9: typeNameOfReg9 :symtab tid: pid
            isRecv9: false
            if ptn9.stringview == "this" then isRecv9 = true
            if ptn9.stringview == clsNm9.stringview then isRecv9 = true
            if pid == thisTid9 then isRecv9 = true
            if isRecv9 then {
                pt = "\{pt}*"
                pnc9: pname.copy
                ctx.ptrVars.append pnc9
            } else {
                # a non-TAKE class param borrows the container (LOCK/BORROW, or the
                # borrow-default whose ownership a cross-unit shell records as "none")
                # -> pass by pointer. A `.take` (owning) class param stays by value:
                # a create/meta_create moves it into the struct.
                giveptr9: false
                if (symtab.typing.childOwnershipIs
                    pool: ast.names
                    parentTypeId: mid
                    name: pname.stringview
                    own: ztypes.zparamownership.takeMode
                ) == false then {
                    if (isReftypeParam :ast :symtab :ctx tid: pid) then giveptr9 = true
                }
                if (isBorrowStringParam :ast :symtab fid: mid pname: pname.stringview :pid) then {
                    giveptr9 = true
                }
                if (isListPtrParam :ast :symtab fid: mid pname: pname.stringview tid: pid) then {
                    giveptr9 = true
                }
                if (isSetMapPtrParam :ast :symtab fid: mid pname: pname.stringview tid: pid) then {
                    giveptr9 = true
                }
                if giveptr9 then {
                    pt = "\{pt}*"
                    pnc9b: pname.copy
                    ctx.ptrVars.append pnc9b
                }
            }
        }
        if pi > 0 then params.append ", "
        params.append pt.stringview
        params.append " "
        pmnDecl9: ztypes.mangleVarName name: pname.stringview
        params.append pmnDecl9.stringview
        pi = pi + 1
    }
    if pn == 0 then params.append "void"
    if declOnly then {
        ld: "static \{ret} \{mc}(\{params});\n"
        buf.append ld.stringview
    } else {
        lo: "static \{ret} \{mc}(\{params}) {\n"
        buf.append lo.stringview
        isGen9: setupGenCtx :ast :symtab :ctx :mid :op
        if isGen9 then emitGenPrologue :ctx :buf
        ctx.curThisTid = thisTid9
        emitFnBody :ast :symtab :ctx :op fid: mid :buf
        ctx.curThisTid = 0
        if isGen9 then {
            emitGenEpilogue :ctx :buf
            ctx.genActive = false
        }
        buf.append "}\n\n"
    }
    ctx.ptrVars = (List String)
    ctx.aliases = (List NameVal)
    ctx.narrowBox = (List NameVal)
}

# emitMonoNative -- a native fragment substituting z_StringView and (when
# mono is non-empty) the canonical z_{mono} to the mono's id-based cname.
emitMonoNative: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    frag: StringView
    mono: StringView
    buf: String.borrow
} is {
    p: "\{runtimeDir}/natives/\{frag}.inc"
    raw: readTemplateCached :ctx path: p.stringview
    if raw.length > 0 then {
        scv: ctx.svC.copy
        cur: substituteAll text: raw needle: "z_StringView" repl: scv.stringview
        if mono.length > 0 then {
            mid: u64
            moo: ztypecheck.resolveSystemChild :ast ty: symtab.typing reg: symtab.reg name: mono
            match (
                moo
            ) case some then {
                mid = moo
            } case none then null
            mc: cnameOf tid: mid name: mono
            cn: "z_\{mono}"
            cur = substituteAll text: cur needle: cn.stringview repl: mc.stringview
        }
        buf.append cur.stringview
        buf.append "\n"
    }
}

# emitParseNative -- a parse fragment, substituting the canonical
# z_resultval_*_parseerror to the mono's id-based cname and z_StringView.
emitParseNative: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    frag: StringView
    mono: StringView
    buf: String.borrow
} is {
    mid: u64
    mo: ztypecheck.resolveSystemChild :ast ty: symtab.typing reg: symtab.reg name: mono
    match (
        mo
    ) case some then {
        mid = mo
    } case none then null
    mc: cnameOf tid: mid name: mono
    p: "\{runtimeDir}/natives/\{frag}.inc"
    raw: readTemplateCached :ctx path: p.stringview
    if raw.length > 0 then {
        cn: "z_\{mono}"
        s1: substituteAll text: raw needle: cn.stringview repl: mc.stringview
        scv: ctx.svC.copy
        s2: substituteAll text: s1 needle: "z_StringView" repl: scv.stringview
        buf.append s2.stringview
        buf.append "\n"
    }
}

# emitCodepointsNatives -- the CpIter struct + codepoints factory + call,
# substituting the canonical z_CpIter / z_optionval_u32 to id-based cnames.
emitCodepointsNatives: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    runtimeDir: StringView
    buf: String.borrow
} is {
    cpId: u64
    cpo: (ztypecheck.resolvedByKey
        :ast
        ty: symtab.typing
        reg: symtab.reg
        key: "system.CpIter".string
    )
    match (
        cpo
    ) case some then {
        cpId = cpo
    } case none then null
    ovId: u64
    ovo: (ztypecheck.resolvedByKey
        :ast
        ty: symtab.typing
        reg: symtab.reg
        key: "system.optionval_u32".string
    )
    match (
        ovo
    ) case some then {
        ovId = ovo
    } case none then null
    cpc: cnameOf tid: cpId name: "CpIter"
    ovc: cnameOf tid: ovId name: "optionval_u32"
    (emitCpFrag
        :runtimeDir
        frag: "_Z_SV_CPITER_STRUCT"
        svC: ctx.svC.stringview
        cpc: cpc.stringview
        ovc: ovc.stringview
        :buf
    )
    (emitCpFrag
        :runtimeDir
        frag: "_Z_SV_CODEPOINTS"
        svC: ctx.svC.stringview
        cpc: cpc.stringview
        ovc: ovc.stringview
        :buf
    )
    (emitCpFrag
        :runtimeDir
        frag: "_Z_SV_CPITER_CALL"
        svC: ctx.svC.stringview
        cpc: cpc.stringview
        ovc: ovc.stringview
        :buf
    )
}

emitCpFrag: function {
    runtimeDir: StringView
    frag: StringView
    svC: StringView
    cpc: StringView
    ovc: StringView
    buf: String.borrow
} is {
    p: "\{runtimeDir}/natives/\{frag}.inc"
    raw: io.readText path: p.stringview
    match (
        raw
    ) case ok then {
        s1: substituteAll text: raw needle: "z_CpIter" repl: cpc
        s2: substituteAll text: s1 needle: "z_optionval_u32" repl: ovc
        s3: substituteAll text: s2 needle: "z_StringView" repl: svC
        buf.append s3.stringview
        buf.append "\n"
    } case err then null
}

mainNameOf9: function {program: Node} out String is {
    match (
        program
    ) case program then {
        mv: program.mainUnitName.stringview
        mc: mv.string
        return mc
    } else {
        return "".string
    }
}

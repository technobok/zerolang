            bareTid9: chaseStrTypedef :symtab :ctx tid: (stampIdOf :symtab nid: bnid2)
            bareSv9: bareTid9 == ctx.svTid
            bareStr9: bareTid9 == ctx.strTid
            if bareStr9 when (isSvNoArgNative name: mn2.stringview) then {

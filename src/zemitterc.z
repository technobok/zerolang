            if mn2.stringview == "length" then return "\{base9}.len"
            if mn2.stringview == "size" then return "\{nstrcb9}_size"
            if mn2.stringview == "string" then return "\{nstrcb9}_string(\{base9})"
            if mn2.stringview == "stringview" then {

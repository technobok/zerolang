                    daid9: chaseColMono :ast :symtab tid: daid0
                    daCt9: typeRefC :ast :symtab :ctx tid: daid9 thisTid: 0
                    daMn9: typeNameOfReg9 :symtab tid: daid9
                    daEid9: listElemType :symtab monoId: daid9
                    daEln9: typeNameOfReg9 :symtab tid: daEid9
                    daPfx9: 7 + daEln9.length
                    daLen9: monoElemName full: daMn9 prefixLen: daPfx9

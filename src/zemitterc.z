            hd9: symtab.typing.hasChildDefaultId parentTypeId: fnTid nameId: pnjId
            if (hd9) == false then return "".string
            dt: symtab.typing.childDefaultTextId parentTypeId: fnTid nameId: pnjId
            rv: renderDefault :ast :symtab :ctx default: dt.stringview targetTid: pij
            if args.length > 0 then args.append ", "
            args.append rv.stringview
        }
    }
    if (userSeen9) == false then return "".string
    return args
}

# emitExprStrZero -- the empty owned String value: the zero struct needs
# no allocation and no free.
emitExprStrZero: function {ctx: Ctx} out String is {
    return "((\{ctx.strC}_t){0})"
}

# emitCtorDefaultsFill -- the zero-argument construction of a record/class

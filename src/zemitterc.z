                }
            } else null
        }
        if mn.stringview == "byteAt" then {
            barg: String
            with biter: call.arguments.iterate do for baId9: biter loop {
                ba: ast.nodes.get i: (baId9 - 1).u64
                match (
                    ba
                ) case namedoperation then {
                    if barg.length == 0 then {

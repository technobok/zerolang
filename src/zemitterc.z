        if brid > 0 when (symtab.reg.typetypeOf typeId: brid) == ztypes.ztypetype.recordType then {
            btn: typeNameOfReg9 :symtab tid: brid
            cTypeLk1: cTypeOf name: btn.stringview
            if cTypeLk1.length > 0 then {
                # a stamped implicit zero-create is the scalar's zero value;
                # an unstamped scalar-name atom keeps the raw name text

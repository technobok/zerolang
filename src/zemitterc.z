            fbcn9: symtab.reg.cnameOf tid: brid
            fastid9: stampIdOf :symtab nid: n.nodeid.u64
            if fastid9 > 0 when (symtab.reg.typetypeOf typeId: fastid9) == ztypes.ztypetype.functionType then {
                # a node still stamped FUNCTION is a genuine reference (a

# zemitterc -- the C emitter (Phase C port of src/zemitterc.py).
#
# C1: preamble, String/StringView runtime fragments, string-literal pool,
# user-function emission, and a statement/expression walk covering the
# scalar core (locals, binops, if/for-while, return, recursion) plus
# print of plain and interpolated literals. Unhandled shapes emit marker
# comments so the C compiles and the gate reports honest RUN-DIFFs.

Node: zast.Node

# TmpCtr -- per-function temp name counter.
TmpCtr: class {
    n: u64
    frees: (List String)
    listFrees: (List String)
    listFreeVars: (List String)
} as {
    next: function {:this} out u64 is {
        v: this.n
        this.n = this.n + 1
        return v
    }
}

# optU64Or9 -- an (optionval t: u64) to a plain u64 (0 when none).
optU64Or9: function {o: optionval u64} out u64 is {
    match (
        o
    ) case some then {
        return o
    } case none then {
        return 0
    }
}

# cnameOf -- the id-based C name base for a type ("z_t{id}_{name}", dots
# joined with underscores). Mirrors the reference's _assign_cname scheme;
# ids differ between the two typecheckers by design.
cnameOf: function {tid: u64 name: StringView} out String is {
    flat: "".string
    biter: 0.u64
    n: name.length
    for while biter < n loop {
        bo: name.byteAt i: biter
        match (
            bo
        ) case some then {
            if bo == 46 then {
                flat.append "_"
            } else {
                flat.appendByte b: bo
            }
        } case none then {}
        biter = biter + 1
    }
    return "z_t\{tid}_\{flat}"
}

# cTypeOf -- the C spelling of a scalar type name ("" when not scalar).
cTypeOf: function {name: StringView} out String is {
    if name == "i8" then { return "int8_t".string }
    if name == "i16" then { return "int16_t".string }
    if name == "i32" then { return "int32_t".string }
    if name == "i64" then { return "int64_t".string }
    if name == "u8" then { return "uint8_t".string }
    if name == "u16" then { return "uint16_t".string }
    if name == "u32" then { return "uint32_t".string }
    if name == "u64" then { return "uint64_t".string }
    if name == "i128" then { return "__int128".string }
    if name == "u128" then { return "unsigned __int128".string }
    if name == "f32" then { return "float".string }
    if name == "f64" then { return "double".string }
    if name == "bool" then { return "bool".string }
    return "".string
}

# isIntName -- integer scalar family check (snprintf %ld path).
isIntName: function {name: StringView} out bool is {
    if name == "i8" then { return true }
    if name == "i16" then { return true }
    if name == "i32" then { return true }
    if name == "i64" then { return true }
    if name == "u8" then { return true }
    if name == "u16" then { return true }
    if name == "u32" then { return true }
    if name == "u64" then { return true }
    if name == "i128" then { return true }
    if name == "u128" then { return true }
    if name == "bool" then { return true }
    return false
}

isFloatName: function {name: StringView} out bool is {
    if name == "f32" then { return true }
    if name == "f64" then { return true }
    return false
}

# numBits -- integer numeric type bit width (0 if not an integer type).
numBits: function {name: StringView} out u64 is {
    if name == "i8" then { return 8 }
    if name == "u8" then { return 8 }
    if name == "c8" then { return 8 }
    if name == "i16" then { return 16 }
    if name == "u16" then { return 16 }
    if name == "i32" then { return 32 }
    if name == "u32" then { return 32 }
    if name == "c32" then { return 32 }
    if name == "i64" then { return 64 }
    if name == "u64" then { return 64 }
    if name == "i128" then { return 128 }
    if name == "u128" then { return 128 }
    return 0
}

# numSigned -- true for the signed integer family.
numSigned: function {name: StringView} out bool is {
    if name == "i8" then { return true }
    if name == "i16" then { return true }
    if name == "i32" then { return true }
    if name == "i64" then { return true }
    if name == "i128" then { return true }
    return false
}

# numLoStr / numHiStr -- decimal range bounds, the comparands of the
# overflow check emitted on a narrowing cast.
numLoStr: function {name: StringView} out String is {
    if name == "i8" then { return "-128".string }
    if name == "i16" then { return "-32768".string }
    if name == "i32" then { return "-2147483648".string }
    if name == "i64" then { return "-9223372036854775808".string }
    if name == "i128" then { return "-170141183460469231731687303715884105728".string }
    return "0".string
}
numHiStr: function {name: StringView} out String is {
    if name == "i8" then { return "127".string }
    if name == "i16" then { return "32767".string }
    if name == "i32" then { return "2147483647".string }
    if name == "i64" then { return "9223372036854775807".string }
    if name == "i128" then { return "170141183460469231731687303715884105727".string }
    if name == "u8" then { return "255".string }
    if name == "c8" then { return "255".string }
    if name == "u16" then { return "65535".string }
    if name == "u32" then { return "4294967295".string }
    if name == "c32" then { return "4294967295".string }
    if name == "u64" then { return "18446744073709551615".string }
    if name == "u128" then { return "340282366920938463463374607431768211455".string }
    return "0".string
}

# emitNumericCast -- a runtime numeric conversion `<val>.<dstName>` from source
# type `srcName`. Widening (source range fully inside dest) is a plain cast;
# narrowing emits an overflow-checked statement-expression (z_panic when out of
# range), mirroring the reference. Unknown / non-integer source falls back to a
# plain cast -- the typechecker has already validated the conversion is legal.
emitNumericCast: function {srcName: StringView dstName: StringView val: StringView} out String is {
    dct: cTypeOf name: dstName
    if dct.length == 0 then {
        return val.string
    }
    dbits: numBits name: dstName
    if dbits == 0 then {
        return "((\{dct})\{val})".string
    }
    sbits: numBits name: srcName
    if sbits == 0 then {
        return "((\{dct})\{val})".string
    }
    ssig: numSigned name: srcName
    dsig: numSigned name: dstName
    needsLo: true
    needsHi: true
    if ssig then {
        if dsig then {
            if sbits <= dbits then { needsLo = false }
        }
    } else {
        needsLo = false
    }
    if ssig == dsig then {
        if sbits <= dbits then { needsHi = false }
    } else {
        if ssig then {
            if sbits <= dbits then { needsHi = false }
        } else {
            if sbits < dbits then { needsHi = false }
        }
    }
    if (needsLo) == false then {
        if (needsHi) == false then {
            return "((\{dct})\{val})".string
        }
    }
    sct: cTypeOf name: srcName
    cond: "".string
    if needsLo then {
        if needsHi then {
            lo: numLoStr name: dstName
            hi: numHiStr name: dstName
            cond = "_v < \{lo} || _v > \{hi}".string
        } else {
            lo2: numLoStr name: dstName
            cond = "_v < \{lo2}".string
        }
    } else {
        hi2: numHiStr name: dstName
        cond = "_v > \{hi2}".string
    }
    r: "({ \{sct} _v = \{val}; if (\{cond}) z_panic(\"numeric cast overflow: \{srcName} to \{dstName}\"); (\{dct})_v; })".string
    return r
}

# cUpperOf -- ASCII upper-case for tag spellings.
cUpperOf: function {text: StringView} out String is {
    buf: "".string
    i: 0.u64
    n: text.length
    for while i < n loop {
        bo: text.byteAt i: i
        match (
            bo
        ) case some then {
            if bo >= 97 then {
                if bo <= 122 then {
                    buf.appendByte b: bo - 32
                } else {
                    buf.appendByte b: bo
                }
            } else {
                buf.appendByte b: bo
            }
        } case none then {}
        i = i + 1
    }
    return buf
}

# cEscape -- escape literal text for a C string body.
cEscape: function {text: StringView} out String is {
    buf: "".string
    i: 0.u64
    n: text.length
    for while i < n loop {
        bo: text.byteAt i: i
        match (
            bo
        ) case some then {
            if bo == 92 then {
                buf.append "\\\\"
            } else if bo == 34 then {
                buf.append "\\\""
            } else if bo == 10 then {
                buf.append "\\n"
            } else if bo == 9 then {
                buf.append "\\t"
            } else {
                buf.appendByte b: bo
            }
        } case none then {}
        i = i + 1
    }
    return buf
}

# substituteAll -- replace every occurrence of needle in text.
substituteAll: function {text: String needle: StringView repl: StringView} out String is {
    buf: "".string
    pos: 0.u64
    total: text.length
    for while pos < total loop {
        remv: (text.stringview from: pos to: total)
        fo: remv.indexOf needle: needle
        match (
            fo
        ) case some then {
            pre: (text.stringview from: pos to: pos + fo)
            buf.append pre
            buf.append repl
            pos = pos + fo + needle.length
        } case none then {
            tail: (text.stringview from: pos to: total)
            buf.append tail
            pos = total
        }
    }
    return buf
}

# loadFragment -- read a runtime fragment and substitute the canonical
# z_StringView / z_String names with the registry's id-based ones
# (StringView first: z_String is its prefix).
loadFragment: function {path: StringView svC: StringView strC: StringView} out String is {
    rd: io.readText path: path
    match (
        rd
    ) case ok then {
        s1: substituteAll text: rd needle: "z_StringView" repl: svC
        s2: substituteAll text: s1 needle: "z_String" repl: strC
        return s2
    } case err then {
        m9: "/* zemitterc: missing runtime fragment \{path} */\n"
        return m9
    }
}

# chunkText -- a stringchunk's text ("" for any other shape).
chunkText9: function {n: Node} out String is {
    match (
        n
    ) case stringchunk then {
        pv: n.text.stringview
        tc: pv.string
        return tc
    } else {
        return "".string
    }
}

# isInterp -- true when a literal has any non-chunk part.
isInterp: function {parts: List Node} out bool is {
    piter: parts.iterate
    for p: piter loop {
        isC: false
        match (
            p
        ) case stringchunk then {
            isC = true
        } else {}
        if (isC) == false then {
            return true
        }
    }
    return false
}

# wholeText -- a plain literal's joined chunk text.
wholeText: function {parts: List Node} out String is {
    buf: "".string
    piter: parts.iterate
    for p: piter loop {
        t: chunkText9 n: p
        buf.append t.stringview
    }
    return buf
}

# collectLiterals -- pool every PLAIN string-literal atom in walk order:
# parallel lists of (nodeid, text). Interpolated literals build at the
# use site instead.
collectLiterals: function {n: Node ids: List u64 texts: List String} is {
    match (
        n
    ) case statement then {
        siter: n.statements.iterate
        for s: siter loop {
            collectLiterals n: s ids: ids texts: texts
        }
    } case statementline then {
        collectLiterals n: n.statementline ids: ids texts: texts
    } case expression then {
        collectLiterals n: n.expression ids: ids texts: texts
    } case namedoperation then {
        collectLiterals n: n.operation ids: ids texts: texts
    } case call then {
        collectLiterals n: n.callable ids: ids texts: texts
        aiter: n.arguments.iterate
        for a: aiter loop {
            collectLiterals n: a ids: ids texts: texts
        }
    } case dottedpath then {
        collectLiterals n: n.parent ids: ids texts: texts
    } case binop then {
        collectLiterals n: n.lhs ids: ids texts: texts
        collectLiterals n: n.rhs ids: ids texts: texts
    } case assignment then {
        collectLiterals n: n.value ids: ids texts: texts
    } case reassignment then {
        collectLiterals n: n.value ids: ids texts: texts
    } case ifexpr then {
        citer: n.clauses.iterate
        for c: citer loop {
            collectLiterals n: c ids: ids texts: texts
        }
        collectLiteralsOpt o: n.elseclause ids: ids texts: texts
    } case caseexpr then {
        collectLiterals n: n.subject ids: ids texts: texts
        miter9: n.clauses.iterate
        for mc9: miter9 loop {
            collectLiterals n: mc9 ids: ids texts: texts
        }
        collectLiteralsOpt o: n.elseclause ids: ids texts: texts
    } case caseclause then {
        collectLiterals n: n.statement ids: ids texts: texts
    } case ifclause then {
        kiter: n.conditions.iterate
        for k: kiter loop {
            collectLiterals n: k ids: ids texts: texts
        }
        collectLiterals n: n.statement ids: ids texts: texts
    } case withexpr then {
        collectLiterals n: n.value ids: ids texts: texts
        collectLiterals n: n.body ids: ids texts: texts
    } case doexpr then {
        collectLiterals n: n.statement ids: ids texts: texts
    } case forexpr then {
        fiter: n.conditions.iterate
        for f: fiter loop {
            collectLiterals n: f ids: ids texts: texts
        }
        collectLiteralsOpt o: n.body ids: ids texts: texts
    } case atomstring then {
        if (isInterp parts: n.stringparts) == false then {
            t: wholeText parts: n.stringparts
            nid: n.nodeid.u64
            ids.append nid
            texts.append t
        } else {
            piter: n.stringparts.iterate
            for p: piter loop {
                collectLiterals n: p ids: ids texts: texts
            }
        }
    } else {}
}

collectLiteralsOpt: function {o: Option Node ids: List u64 texts: List String} is {
    match (
        o
    ) case some then {
        collectLiterals n: o ids: ids texts: texts
    } case none then {}
}

# litIndexOf -- the 1-based pool index for a literal's nodeid (0 = absent).
litIndexOf: function {ids: List u64 nid: u64} out u64 is {
    i: 0.u64
    n: ids.length
    for while i < n loop {
        v: ids.get i: i
        if v == nid then {
            return i + 1
        }
        i = i + 1
    }
    return 0
}

# ternaryClause / ternaryElse -- if-expression rendering as nested C
# ternaries: each clause opens "(cond ? value : " and the else closes.
ternaryClause: function {symtab: zenv.ZSymbolTable ctx: Ctx c: Node} out String is {
    match (
        c
    ) case ifclause then {
        cond: "".string
        kiter: c.conditions.iterate
        for k: kiter loop {
            match (
                k
            ) case namedoperation then {
                cv: emitExpr symtab: symtab ctx: ctx n: k.operation
                if cond.length > 0 then {
                    cond.append " && "
                }
                cond.append cv.stringview
            } else {}
        }
        vx: emitExpr symtab: symtab ctx: ctx n: c.statement
        t0: "((\{cond}) ? (\{vx}) : "
        return t0
    } else {
        return "(0 ? 0 : ".string
    }
}

ternaryElse: function {symtab: zenv.ZSymbolTable ctx: Ctx o: Option Node} out String is {
    match (
        o
    ) case some then {
        ev: emitExpr symtab: symtab ctx: ctx n: o
        e0: "(\{ev})"
        return e0
    } case none then {
        return "(0)".string
    }
}

# atomTextOf -- an atomid node's name text ("" for any other shape).
atomTextOf: function {n: Node} out String is {
    match (
        n
    ) case atomid then {
        av: n.name.stringview
        ac: av.string
        return ac
    } else {
        return "".string
    }
}

# atomTextDeep -- atom text through expression wrappers.
atomTextDeep: function {n: Node} out String is {
    match (
        n
    ) case expression then {
        return (atomTextDeep n: n.expression)
    } case atomid then {
        av: n.name.stringview
        ac: av.string
        return ac
    } else {
        return "".string
    }
}

# atomNodeId9 -- an atomid node's id (0 for any other shape).
atomNodeId9: function {n: Node} out u64 is {
    match (
        n
    ) case atomid then {
        return n.nodeid.u64
    } else {
        return 0
    }
}

stampIdOf: function {symtab: zenv.ZSymbolTable nid: u64} out u64 is {
    go: symtab.typing.nodeType.get key: nid
    match (
        go
    ) case some then {
        return go
    } case none then {
        return 0
    }
}

# stampNameOf -- the registry name of a node's stamped type ("" unstamped).
stampNameOf: function {symtab: zenv.ZSymbolTable nid: u64} out String is {
    go: symtab.typing.nodeType.get key: nid
    match (
        go
    ) case some then {
        t: symtab.reg.typeById.get key: go
        match (
            t
        ) case some then {
            return t.name.copy
        } case none then {}
    } case none then {}
    return "".string
}

# Ctx -- the per-program emission context (anchor cnames, main unit name,
# the literal pool, and the resolved-name map access).
Ctx: class {
    mainName: String
    realMain: String
    strC: String
    svC: String
    litIds: (List u64)
    constVals: (Map String value: String)
    needs: (Map String value: bool)
    methodReturns: (Map String value: String)
    dataElems: (Map String value: String)
    dataConst: (Map String value: String)
    ptrVars: (List String)
    aliases: (Map String value: String)
    narrowBox: (Map String value: String)
    narrowTid: (Map String value: u64)
    genActive: bool
    genYieldCount: u64
    genYieldNext: u64
    genWrap: String
    genSomeTag: String
    genNoneTag: String
    genHasValue: bool
    emittedUserTypes: (Map u64 value: bool)
    fwdDeclaredTypes: (Map u64 value: bool)
    argHoistNames: (List String)
    argHoistVals: (List String)
    argHoistTypes: (List String)
    argHoistDtors: (List String)
    argHoistCtr: u64
    breakLabels: (List u64)
    breakLabelCtr: u64
    breakLabelUsed: (Map u64 value: bool)
}

# userFnId -- the resolved type id of a main-unit function name (0 absent).
userFnId: function {symtab: zenv.ZSymbolTable ctx: Ctx name: StringView} out u64 is {
    k: "\{ctx.mainName}.\{name}".string
    go: symtab.typing.resolved.get key: k
    match (
        go
    ) case some then {
        return go
    } case none then {
        return 0
    }
}

# isPtrVar -- true when a local name is a pointer-receiver param of the current
# class method body (so field reads emit `->` instead of `.`).
isPtrVar: function {ctx: Ctx name: StringView} out bool is {
    pi: 0.u64
    pn: ctx.ptrVars.length
    for while pi < pn loop {
        pv: ctx.ptrVars.get i: pi
        if pv.stringview == name then {
            return true
        }
        pi = pi + 1
    }
    return false
}

# pathIsPointer -- does the expression evaluate to a C pointer? A ptrVar atom
# (pointer receiver / lock param) or a dotted read of a `.lock` field both do,
# so field access on them chains with `->`.
pathIsPointer: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (pathIsPointer symtab: symtab ctx: ctx n: n.expression)
    } case atomid then {
        rn: aliasResolve ctx: ctx name: n.name.stringview
        return (isPtrVar ctx: ctx name: rn.stringview)
    } case dottedpath then {
        cn: atomTextOf n: n.child
        pnid: atomNodeId9 n: n.parent
        pstamp: stampIdOf symtab: symtab nid: pnid
        pstn: typeNameOfReg9 symtab: symtab tid: pstamp
        prid: resolveTypeIdByName symtab: symtab ctx: ctx name: pstn.stringview
        ptid: pstamp
        if prid > 0 then {
            ptid = prid
        }
        return (symtab.typing.isChildLockField parentTypeId: ptid name: cn.stringview)
    } else {
        return false
    }
}

# aliasResolve -- a `.take` alias's base C name, or the name itself if none.
aliasResolve: function {ctx: Ctx name: StringView} out String is {
    # A match-arm narrowing (narrowBox) takes priority: inside the arm the name
    # resolves to the narrowed union payload cast, not the un-narrowed binding or a
    # stale for-loop/borrow/take alias -- mirrors takeSourceResolve.
    nbo: ctx.narrowBox.get key: name.string
    match (
        nbo
    ) case some then {
        return nbo.string
    } case none then {}
    ao: ctx.aliases.get key: name.string
    match (
        ao
    ) case some then {
        return ao.string
    } case none then {
        return name.string
    }
}

# takeSourceResolve -- the C lvalue to zero after a take of `name`: a match-arm
# narrowing's union box payload (narrowBox) takes priority over a plain `.take`
# alias, so the source zeroing invalidates the box, not just the narrowed copy.
takeSourceResolve: function {ctx: Ctx name: StringView} out String is {
    nbo: ctx.narrowBox.get key: name.string
    match (
        nbo
    ) case some then {
        return nbo.string
    } case none then {
        return (aliasResolve ctx: ctx name: name)
    }
}

# takeAliasBase -- the base atom of a `<x>.take` over a user record/class (an
# ownership-transfer alias: the binding reuses the source storage), else "".
takeAliasBase: function {symtab: zenv.ZSymbolTable n: Node} out String is {
    match (
        n
    ) case expression then {
        return (takeAliasBase symtab: symtab n: n.expression)
    } case statementline then {
        return (takeAliasBase symtab: symtab n: n.statementline)
    } case dottedpath then {
        cn9: atomTextOf n: n.child
        if cn9.stringview != "take" then {
            return "".string
        }
        bnid9: atomNodeId9 n: n.parent
        bt9: stampIdOf symtab: symtab nid: bnid9
        bo9: monoOriginName symtab: symtab tid: bt9
        if bo9.length != 0 then {
            return "".string
        }
        btt9: symtab.reg.typetypeOf typeId: bt9
        isUC9: false
        if btt9 == ztypes.ztypetype.RECORD then {
            isUC9 = true
        }
        if btt9 == ztypes.ztypetype.CLASS then {
            isUC9 = true
        }
        if btt9 == ztypes.ztypetype.UNION then {
            isUC9 = true
        }
        if isUC9 then {
            return (atomTextOf n: n.parent)
        } else {
            return "".string
        }
    } else {
        return "".string
    }
}

# takeStringSource -- if `n` is a `<atom>.take` over a String value, the resolved
# C name of the source local to zero after the move (the callee now owns the
# heap buffer), else "". Used at the statement level to suppress a double free.
takeStringSource: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out String is {
    match (
        n
    ) case expression then {
        return (takeStringSource symtab: symtab ctx: ctx n: n.expression)
    } case statementline then {
        return (takeStringSource symtab: symtab ctx: ctx n: n.statementline)
    } case dottedpath then {
        cn9: atomTextOf n: n.child
        if cn9.stringview != "take" then {
            return "".string
        }
        bnid9: atomNodeId9 n: n.parent
        bid9: stampIdOf symtab: symtab nid: bnid9
        btn9: stampNameOf symtab: symtab nid: bnid9
        isMv9: false
        if btn9.stringview == "String" then {
            isMv9 = true
        }
        if (symtab.reg.typetypeOf typeId: bid9) == ztypes.ztypetype.UNION then {
            isMv9 = true
        }
        if (symtab.reg.typetypeOf typeId: bid9) == ztypes.ztypetype.CLASS then {
            bn9c: atomTextOf n: n.parent
            if (isPtrVar ctx: ctx name: bn9c.stringview) == false then {
                isMv9 = true
            }
        }
        if (isMv9) == false then {
            return "".string
        }
        bn9r: atomTextOf n: n.parent
        return (takeSourceResolve ctx: ctx name: bn9r.stringview)
    } else {
        return "".string
    }
}

# takeMoveCtype -- the C type of a `<atom>.take` source (for the `(T){0}`
# zeroing), via typeRefC on the base's stamp (canonicalizes String to strC).
takeMoveCtype: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out String is {
    match (
        n
    ) case expression then {
        return (takeMoveCtype symtab: symtab ctx: ctx n: n.expression)
    } case statementline then {
        return (takeMoveCtype symtab: symtab ctx: ctx n: n.statementline)
    } case dottedpath then {
        bnid: atomNodeId9 n: n.parent
        bid: stampIdOf symtab: symtab nid: bnid
        return (typeRefC symtab: symtab ctx: ctx tid: bid thisTid: 0)
    } else {
        return "".string
    }
}

# emitNarrowedTakeZero -- before a return's scope cleanup, zero the payload box of
# every narrowed-subject `.take` reachable in the return value (a bare take, or a take
# passed as a construction/call arg). The un-shadowed narrowed subject is freed by the
# return cleanup; its `.take` moved the payload out as a shallow struct copy sharing the
# heap buffer, so the box must read {0} when the destructor walks it, else that buffer is
# double-freed. Non-narrowed takes are kept live by refsLocal and are not touched here.
# Mirrors the reference's implicit-take invalidation, flushed before scope cleanup.
emitNarrowedTakeZero: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node ind: StringView buf: String.borrow} is {
    match (
        n
    ) case expression then {
        emitNarrowedTakeZero symtab: symtab ctx: ctx n: n.expression ind: ind buf: buf
    } case statementline then {
        emitNarrowedTakeZero symtab: symtab ctx: ctx n: n.statementline ind: ind buf: buf
    } case dottedpath then {
        cn9: atomTextOf n: n.child
        if cn9.stringview == "take" then {
            bn9: atomTextOf n: n.parent
            if (ctx.narrowBox.has key: bn9.string) then {
                box9: takeSourceResolve ctx: ctx name: bn9.stringview
                tido9: ctx.narrowTid.get key: bn9.string
                match (
                    tido9
                ) case some then {
                    ct9: typeRefC symtab: symtab ctx: ctx tid: tido9 thisTid: 0
                    inv9: "\{ind}\{box9} = (\{ct9}){0};\n"
                    buf.append inv9.stringview
                } case none then {}
            }
        }
    } case call then {
        aiter9: n.arguments.iterate
        for a9: aiter9 loop {
            match (
                a9
            ) case namedoperation then {
                emitNarrowedTakeZero symtab: symtab ctx: ctx n: a9.operation ind: ind buf: buf
            } else {}
        }
    } else {}
}

# implicitTakeSource -- the C source local of a bare reftype/String atom arg
# (alias-resolved); "" for a type/fn definition reference or any non-atom shape.
# The source of an implicit ownership move (no explicit `.take`).
implicitTakeSource: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out String is {
    match (
        n
    ) case expression then {
        return (implicitTakeSource symtab: symtab ctx: ctx n: n.expression)
    } case atomid then {
        nm: n.name.stringview
        rid: resolveTypeIdByName symtab: symtab ctx: ctx name: nm
        if rid > 0 then {
            rtt9: symtab.reg.typetypeOf typeId: rid
            if rtt9 != ztypes.ztypetype.FUNCTION then {
                return "".string
            }
            mfn9: userFnId symtab: symtab ctx: ctx name: nm
            if mfn9 > 0 then {
                return "".string
            }
        }
        return (takeSourceResolve ctx: ctx name: nm)
    } else {
        return "".string
    }
}

# implicitTakeFnId -- the param-bearing type for a call's implicit-take check: a
# direct FUNCTION callable, else the constructed type's `create` child, else the
# type itself (a field-wise construction reads field ownership from the type).
implicitTakeFnId: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out u64 is {
    cn0: atomTextOf n: call.callable
    ct: userFnId symtab: symtab ctx: ctx name: cn0.stringview
    if ct == 0 then {
        # A dotted method call resolves the method through the receiver's type,
        # not a bare-name lookup: a free function sharing the method's name
        # (zast.mkNamedOp vs the Parser.mkNamedOp method) otherwise wins below,
        # and its mismatched param names leave a moved-in owned arg un-zeroed.
        mdch0: dottedChildText n: call.callable
        if mdch0.length > 0 then {
            mrcv0: dottedReceiverStampId symtab: symtab callable: call.callable
            if mrcv0 > 0 then {
                mmco0: symtab.typing.childOf parentTypeId: mrcv0 name: mdch0.stringview
                match (
                    mmco0
                ) case some then {
                    if (symtab.reg.typetypeOf typeId: mmco0) == ztypes.ztypetype.FUNCTION then {
                        ct = mmco0
                    }
                } case none then {}
            }
        }
    }
    if ct == 0 then {
        # a cross-unit construction's callable is a dotted path (e.g.
        # `zast.UnitData`); atomTextOf is empty, so resolve the type by its
        # child name to reach its consuming `create` below (the same-unit path
        # resolves via the bare-atom userFnId above). Without this the moved-in
        # owned arg is never zeroed -> double free at the owner's destructor.
        dn0: dottedChildText n: call.callable
        if dn0.length > 0 then {
            rt0: resolveTypeIdByName symtab: symtab ctx: ctx name: dn0.stringview
            if rt0 > 0 then {
                ct = rt0
            }
        }
    }
    if ct == 0 then {
        return (stampIdOf symtab: symtab nid: (nodeIdOf9 n: call.callable))
    }
    if (symtab.reg.typetypeOf typeId: ct) == ztypes.ztypetype.FUNCTION then {
        return ct
    }
    cco: symtab.typing.childOf parentTypeId: ct name: "create"
    match (
        cco
    ) case some then {
        if (symtab.reg.typetypeOf typeId: cco) == ztypes.ztypetype.FUNCTION then {
            return cco
        }
    } case none then {}
    return ct
}

# emitCallTakeInvalidations -- zero the source local of each ownership-moved arg
# of a call so its scope-exit destructor is a no-op (the move transferred
# ownership). An explicit `<atom>.take` uses takeStringSource; a bare owning-
# reftype local moved into a TAKE param is an implicit move (the hasDestructorName
# gate excludes borrow/lock views and scalars, which carry no destructor).
isCtorOwnerCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out bool is {
    smidO: stampIdOf symtab: symtab nid: call.nodeid.u64
    soO: monoOriginName symtab: symtab tid: smidO
    bnO: dottedBaseAtom n: call.callable
    mcO9: dottedChildText n: call.callable
    if bnO.stringview == "meta" when mcO9.stringview == "create" then {
        return true
    }
    if soO.stringview == "Option" when bnO.stringview == "Option" then {
        return true
    }
    if soO.stringview == "Result" when bnO.stringview == "Result" then {
        return true
    }
    # user-defined union arm construction `MyUnion.arm <payload>`: the base atom
    # is the union TYPE (the child is the arm selector, not a type), so the
    # child-name resolution below misses it. A non-lock arm MOVES its payload
    # into the heap box, so the source must be zeroed (a lock arm BORROWS it).
    if bnO.length > 0 then {
        uctO: resolveTypeIdByName symtab: symtab ctx: ctx name: bnO.stringview
        if uctO > 0 then {
            if (symtab.reg.typetypeOf typeId: uctO) == ztypes.ztypetype.UNION then {
                if (monoOriginName symtab: symtab tid: uctO).length == 0 then {
                    uarmO: dottedChildText n: call.callable
                    if (symtab.typing.isChildLockArm parentTypeId: uctO name: uarmO.stringview) == false then {
                        return true
                    }
                }
            }
        }
    }
    cn0: atomTextOf n: call.callable
    ct: userFnId symtab: symtab ctx: ctx name: cn0.stringview
    if ct == 0 then {
        # cross-unit construction (dotted callable, e.g. `zast.UnitData`):
        # resolve the constructed type by its child name so an owned arg moved
        # into a record/variant/class/union field is zeroed (else double free).
        dn0: dottedChildText n: call.callable
        if dn0.length > 0 then {
            rt0: resolveTypeIdByName symtab: symtab ctx: ctx name: dn0.stringview
            if rt0 > 0 then {
                ct = rt0
            }
        }
    }
    if ct == 0 then {
        return false
    }
    if (symtab.reg.typetypeOf typeId: ct) == ztypes.ztypetype.CLASS then {
        return true
    }
    if (symtab.reg.typetypeOf typeId: ct) == ztypes.ztypetype.UNION then {
        return true
    }
    if (symtab.reg.typetypeOf typeId: ct) == ztypes.ztypetype.RECORD then {
        return true
    }
    if (symtab.reg.typetypeOf typeId: ct) == ztypes.ztypetype.VARIANT then {
        return true
    }
    return false
}

emitCallTakeInvalidations: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData ind: StringView buf: String.borrow} is {
    ftid9: implicitTakeFnId symtab: symtab ctx: ctx call: call
    ctorOwner9: isCtorOwnerCall symtab: symtab ctx: ctx call: call
    mmn9: dottedChildText n: call.callable
    collMove9: false
    if mmn9.stringview == "append" then { collMove9 = true }
    if mmn9.stringview == "insert" then { collMove9 = true }
    if mmn9.stringview == "push" then { collMove9 = true }
    posI9: 0.u64
    aiter9: call.arguments.iterate
    for a9: aiter9 loop {
        match (
            a9
        ) case namedoperation then {
            ts9: takeStringSource symtab: symtab ctx: ctx n: a9.operation
            if ts9.length > 0 then {
                tc9: takeMoveCtype symtab: symtab ctx: ctx n: a9.operation
                inv9: "\{ind}\{ts9} = (\{tc9}){0};\n"
                buf.append inv9.stringview
            } else {
                isTake9: ctorOwner9
                if collMove9 then { isTake9 = true }
                lbl9: unitLabel9 o: a9.name
                if lbl9.length > 0 then {
                    own9: symtab.typing.childOwnershipText parentTypeId: ftid9 name: lbl9.stringview
                    if own9.stringview == "TAKE" then {
                        isTake9 = true
                    }
                    if own9.stringview == "BORROW" then {
                        isTake9 = false
                    }
                    if own9.stringview == "LOCK" then {
                        isTake9 = false
                    }
                } else {
                    pnames9: (List String)
                    pids9: (List u64)
                    recFieldLists symtab: symtab tid: ftid9 names: pnames9 ids: pids9
                    off9: 0.u64
                    if pnames9.length > 0 then {
                        p09: pnames9.get i: 0
                        if p09.stringview == "this" then {
                            off9 = 1
                        }
                    }
                    pidx9: posI9 + off9
                    if pidx9 < pnames9.length then {
                        pn9: pnames9.get i: pidx9
                        pown9: symtab.typing.childOwnershipText parentTypeId: ftid9 name: pn9.stringview
                        if pown9.stringview == "TAKE" then {
                            isTake9 = true
                        }
                    }
                }
                if isTake9 then {
                    isrc9: implicitTakeSource symtab: symtab ctx: ctx n: a9.operation
                    if isrc9.length > 0 then {
                        istid9: stampIdOf symtab: symtab nid: (nodeIdOf9 n: a9.operation)
                        if (isHeapPtrCollection symtab: symtab ctx: ctx tid: istid9) then {
                            iinvh9: "\{ind}\{isrc9} = NULL;\n"
                            buf.append iinvh9.stringview
                        } else {
                            if (symtab.reg.hasDestructorName typeId: istid9) then {
                                itc9: typeRefC symtab: symtab ctx: ctx tid: istid9 thisTid: 0
                                iinv9: "\{ind}\{isrc9} = (\{itc9}){0};\n"
                                buf.append iinv9.stringview
                            }
                        }
                    }
                }
            }
            emitValueTakeInvalidations symtab: symtab ctx: ctx n: a9.operation ind: ind buf: buf
            posI9 = posI9 + 1
        } else {}
    }
}

# emitValueTakeInvalidations -- statement-level source zeroing for a value node
# that reduces to a call (unwraps expression/statementline wrappers).
emitValueTakeInvalidations: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node ind: StringView buf: String.borrow} is {
    match (
        n
    ) case expression then {
        emitValueTakeInvalidations symtab: symtab ctx: ctx n: n.expression ind: ind buf: buf
    } case statementline then {
        emitValueTakeInvalidations symtab: symtab ctx: ctx n: n.statementline ind: ind buf: buf
    } case call then {
        emitCallTakeInvalidations symtab: symtab ctx: ctx call: n ind: ind buf: buf
    } else {}
}

needsAdd: function {ctx: Ctx name: StringView} is {
    k: name.string
    v: true
    ctx.needs.set key: k value: v
}

needsHas: function {ctx: Ctx name: StringView} out bool is {
    k: name.string
    g: ctx.needs.get key: k
    match (
        g
    ) case some then {
        return true
    } case none then {
        return false
    }
}

isCompareOp: function {name: StringView} out bool is {
    if name == "==" then { return true }
    if name == "!=" then { return true }
    if name == "<" then { return true }
    if name == "<=" then { return true }
    if name == ">" then { return true }
    if name == ">=" then { return true }
    return false
}

isStringy: function {name: StringView} out bool is {
    if name == "String" then { return true }
    if name == "StringView" then { return true }
    return false
}

# svValueForm -- a String/StringView operand as a by-value StringView C
# expression (Strings view-convert via a compound literal).
svValueForm: function {ctx: Ctx expr: StringView tname: StringView} out String is {
    if tname == "String" then {
        acc: ".".string
        if (isPtrVar ctx: ctx name: expr) then {
            acc = "->".string
        }
        v1: "((\{ctx.svC}_t){ \{expr}\{acc}data, \{expr}\{acc}size })"
        return v1
    } else {
        v2: expr.string
        return v2
    }
}

# dottedBaseAtom / dottedChildText -- the parent atom and member name of
# a dotted path ("" when the shape is deeper than one segment).
dottedBaseAtom: function {n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        return (atomTextOf n: n.parent)
    } else {
        return "".string
    }
}

dottedChildText: function {n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        return (atomTextOf n: n.child)
    } else {
        return "".string
    }
}

dottedBaseNodeId: function {n: Node} out u64 is {
    match (
        n
    ) case dottedpath then {
        return (atomNodeId9 n: n.parent)
    } else {
        return 0
    }
}

# isSvParseNative -- a StringView parse native (parseF64/I64/U64) returning a
# resultval. Dispatched via ctx.svC so the canonical StringView cname is used
# (not a shell id stamped on a nested `.stringview` projection).
isSvParseNative: function {name: StringView} out bool is {
    if name == "parseF64" then {
        return true
    }
    if name == "parseI64" then {
        return true
    }
    if name == "parseU64" then {
        return true
    }
    return false
}

# svNativeName -- the simple StringView-native set C2b supports (the
# pointer-arg predicates and trims; indexOf/byteAt wait on optionval
# struct emission).
isSvSimpleNative: function {name: StringView} out bool is {
    if name == "isEmpty" then { return true }
    if name == "isAscii" then { return true }
    if name == "startsWith" then { return true }
    if name == "endsWith" then { return true }
    if name == "contains" then { return true }
    if name == "trim" then { return true }
    if name == "trimStart" then { return true }
    if name == "trimEnd" then { return true }
    if name == "toLowerAscii" then { return true }
    if name == "toUpperAscii" then { return true }
    if name == "replace" then { return true }
    if name == "replaceFirst" then { return true }
    if name == "repeated" then { return true }
    if name == "concat" then { return true }
    return false
}

# isSvArgNative -- an arg-taking StringView native returning optionval/
# Option (indexOf/byteAt/lastIndexOf/stripPrefix/stripSuffix/splitOnce).
isSvArgNative: function {name: StringView} out bool is {
    if name == "indexOf" then { return true }
    if name == "lastIndexOf" then { return true }
    if name == "byteAt" then { return true }
    if name == "stripPrefix" then { return true }
    if name == "stripSuffix" then { return true }
    if name == "splitOnce" then { return true }
    return false
}

# svArgAddr -- the &-form of a StringView native argument (pooled
# literal or local view); "" when unsupported.
svArgAddr: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out String is {
    match (
        n
    ) case expression then {
        return (svArgAddr symtab: symtab ctx: ctx n: n.expression)
    } case atomstring then {
        li: litIndexOf ids: ctx.litIds nid: n.nodeid.u64
        if li > 0 then {
            a1: "&_zs\{li}"
            return a1
        } else {
            return "".string
        }
    } case atomid then {
        an: n.name.stringview
        a2: "&\{an}"
        return a2
    } case dottedpath then {
        dpm: atomTextOf n: n.child
        if dpm.stringview == "stringview" then {
            pe: emitExpr symtab: symtab ctx: ctx n: n.parent
            pt: stampNameOf symtab: symtab nid: (nodeIdOf9 n: n.parent)
            sv: svValueForm ctx: ctx expr: pe.stringview tname: pt.stringview
            a3: "&\{sv}"
            return a3
        }
        return "".string
    } else {
        return "".string
    }
}

# emitDottedCall -- a method call on a stamped String/StringView base:
# the simple native set emits {svC}_{member}(&base, &args...).
emitDottedCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    bn: dottedBaseAtom n: call.callable
    mn: dottedChildText n: call.callable
    bt: "".string
    if bn.length == 0 then {
        # nested/projected base (el.text.stringview.stripPrefix): no base atom, but
        # the base is a stamped String/StringView -- emit it as an expression (a
        # compound-literal lvalue, so the `&base` SV-native legs stay valid C).
        rsid9: dottedReceiverStampId symtab: symtab callable: call.callable
        bTy9: typeNameOfReg9 symtab: symtab tid: rsid9
        if (isStringy name: bTy9.stringview) then {
            bn = emitDottedReceiver symtab: symtab ctx: ctx callable: call.callable
            bt = bTy9
        } else {
            return "".string
        }
    } else {
        bnid: dottedBaseNodeId n: call.callable
        bt = stampNameOf symtab: symtab nid: bnid
    }
    if (isStringy name: bt.stringview) when mn.stringview == "compare" then {
        # compare maps to the by-value cmp in the base fragment
        bf: svValueForm ctx: ctx expr: bn.stringview tname: bt.stringview
        cargs: "".string
        citer: call.arguments.iterate
        for ca: citer loop {
            match (
                ca
            ) case namedoperation then {
                cae: emitExpr symtab: symtab ctx: ctx n: ca.operation
                cat: stampNameDeep symtab: symtab n: ca.operation
                caf: svValueForm ctx: ctx expr: cae.stringview tname: cat.stringview
                if cargs.length == 0 then {
                    cargs.append caf.stringview
                }
            } else {}
        }
        ce: "\{ctx.svC}_cmp(\{bf}, \{cargs})"
        return ce
    }
    if (isStringy name: bt.stringview) when mn.stringview == "split" then {
        needsAdd ctx: ctx name: "sv_split"
        sepx9: "".string
        with siter9: call.arguments.iterate do for sa9: siter9 loop {
            match (
                sa9
            ) case namedoperation then {
                if sepx9.length == 0 then {
                    sav9: svArgAddr symtab: symtab ctx: ctx n: sa9.operation
                    if sav9.length > 0 then {
                        sepx9.append sav9.stringview
                    } else {
                        sxe9: emitExpr symtab: symtab ctx: ctx n: sa9.operation
                        sepx9.append "&"
                        sepx9.append sxe9.stringview
                    }
                }
            } else {}
        }
        es9: "\{ctx.svC}_split(&\{bn}, \{sepx9})"
        return es9
    }
    if (isStringy name: bt.stringview) when mn.stringview == "lines" then {
        needsAdd ctx: ctx name: "sv_lines"
        el9: "\{ctx.svC}_lines(&\{bn})"
        return el9
    }
    if (isStringy name: bt.stringview) when (isSvParseNative name: mn.stringview) then {
        bfp9: svValueForm ctx: ctx expr: bn.stringview tname: bt.stringview
        needsAdd ctx: ctx name: mn.stringview
        epn9: "\{ctx.svC}_\{mn}(&\{bfp9})"
        return epn9
    }
    if (isStringy name: bt.stringview) when (isSvArgNative name: mn.stringview) then {
        bf: svValueForm ctx: ctx expr: bn.stringview tname: bt.stringview
        needsAdd ctx: ctx name: mn.stringview
        argx: "".string
        with aiter9: call.arguments.iterate do for a9: aiter9 loop {
            match (
                a9
            ) case namedoperation then {
                if argx.length == 0 then {
                    av9: svArgAddr symtab: symtab ctx: ctx n: a9.operation
                    if av9.length > 0 then {
                        argx.append av9.stringview
                    } else {
                        sx9: emitExpr symtab: symtab ctx: ctx n: a9.operation
                        argx.append sx9.stringview
                    }
                }
            } else {}
        }
        if mn.stringview == "byteAt" then {
            barg: "".string
            with biter: call.arguments.iterate do for ba: biter loop {
                match (
                    ba
                ) case namedoperation then {
                    if barg.length == 0 then {
                        bx: emitExpr symtab: symtab ctx: ctx n: ba.operation
                        barg.append bx.stringview
                    }
                } else {}
            }
            eb9: "\{ctx.svC}_byteAt(&\{bn}, \{barg})"
            return eb9
        }
        ea9: "\{ctx.svC}_\{mn}(&\{bn}, \{argx})"
        return ea9
    }
    if bt.stringview == "StringView" then {
        if (isSvSimpleNative name: mn.stringview) then {
            needsAdd ctx: ctx name: mn.stringview
            args: "".string
            aiter: call.arguments.iterate
            for a: aiter loop {
                match (
                    a
                ) case namedoperation then {
                    av: svArgAddr symtab: symtab ctx: ctx n: a.operation
                    if av.length > 0 then {
                        args.append ", "
                        args.append av.stringview
                    } else {
                        sv9: emitExpr symtab: symtab ctx: ctx n: a.operation
                        args.append ", "
                        args.append sv9.stringview
                    }
                } else {}
            }
            e1: "\{ctx.svC}_\{mn}(&\{bn}\{args})"
            return e1
        }
    }
    return "".string
}

# emitDataIndexCall -- `primes.index i`: a data-block element read,
# emitted as z_{name}[arg].
emitDataIndexCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    bn: dottedBaseAtom n: call.callable
    mn: dottedChildText n: call.callable
    if bn.length == 0 then {
        return "".string
    }
    bnid: dottedBaseNodeId n: call.callable
    bt: stampNameOf symtab: symtab nid: bnid
    isData: ctx.dataElems.has key: bn.copy
    if (isData) == false then {
        return "".string
    }
    if mn.stringview == "index" then {
        ax: "0".string
        aiter: call.arguments.iterate
        for a: aiter loop {
            match (
                a
            ) case namedoperation then {
                ax = emitExpr symtab: symtab ctx: ctx n: a.operation
            } else {}
        }
        e0: "z_\{bn}[\{ax}]"
        return e0
    }
    return "".string
}

# listCapArg -- the capacity: argument of a list construction value, or
# "0" when absent.
listCapArg: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out String is {
    match (
        n
    ) case expression then {
        return (listCapArg symtab: symtab ctx: ctx n: n.expression)
    } case call then {
        aiter: n.arguments.iterate
        for a: aiter loop {
            match (
                a
            ) case namedoperation then {
                an: unitLabel9 o: a.name
                if an.stringview == "capacity" then {
                    return (emitExpr symtab: symtab ctx: ctx n: a.operation)
                }
            } else {}
        }
        return "0".string
    } else {
        return "0".string
    }
}

# emitListMethodCall -- a method call on a List-mono receiver. Maps the
# labeled arguments to the runtime method's positional C signature.
# emitDottedReceiver -- the C expression for the receiver of a dotted method
# call (call.callable = recv.method). Uses emitExpr on the base node so a nested
# receiver (this.field.method, obj.a.b.method) works, not just a bare atom. ""
# when the callable is not a dotted path.
emitDottedReceiver: function {symtab: zenv.ZSymbolTable ctx: Ctx callable: Node} out String is {
    match (
        callable
    ) case dottedpath then {
        return (emitExpr symtab: symtab ctx: ctx n: callable.parent)
    } else {
        return "".string
    }
}

# dottedReceiverStampId -- the stamped type id of a dotted method call's
# receiver (the base node, via nodeIdOf9 which handles a nested dottedpath base).
# 0 when not a dotted path.
dottedReceiverStampId: function {symtab: zenv.ZSymbolTable callable: Node} out u64 is {
    match (
        callable
    ) case dottedpath then {
        return (stampIdOf symtab: symtab nid: (nodeIdOf9 n: callable.parent))
    } else {
        return 0
    }
}

# dottedReceiverIsPtr -- true when a dotted method call's receiver is already a
# C pointer (a ptrVar like `this`, or a `.lock` field), so the call passes it
# directly rather than taking its address.
dottedReceiverIsPtr: function {symtab: zenv.ZSymbolTable ctx: Ctx callable: Node} out bool is {
    match (
        callable
    ) case dottedpath then {
        return (pathIsPointer symtab: symtab ctx: ctx n: callable.parent)
    } else {
        return false
    }
}

# emitStringArgMethod -- a String mutating method WITH an arg (appendByte /
# reserve): emit \{ctx.strC}_<native>(&recv, arg). The native cname is
# snake_case (append_byte). "" when the receiver is not a String or the method
# is not one of these. String is a value-native, so the cname is always ctx.strC.
emitStringArgMethod: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    mn: dottedChildText n: call.callable
    nativeM: "".string
    if mn.stringview == "appendByte" then {
        nativeM = "append_byte".string
    }
    if mn.stringview == "reserve" then {
        nativeM = "reserve".string
    }
    if mn.stringview == "append" then {
        nativeM = "append".string
    }
    if nativeM.length == 0 then {
        return "".string
    }
    recvExpr: emitDottedReceiver symtab: symtab ctx: ctx callable: call.callable
    if recvExpr.length == 0 then {
        return "".string
    }
    rtid0: dottedReceiverStampId symtab: symtab callable: call.callable
    rtid: chaseColMono symtab: symtab tid: rtid0
    rtn: typeNameOfReg9 symtab: symtab tid: rtid
    if rtn.stringview != "String" then {
        return "".string
    }
    rptr: dottedReceiverIsPtr symtab: symtab ctx: ctx callable: call.callable
    recvAddr: "&\{recvExpr}"
    if rptr then {
        recvAddr = "\{recvExpr}"
    }
    argval: "".string
    with aiter: call.arguments.iterate do for a: aiter loop {
        match (
            a
        ) case namedoperation then {
            if argval.length == 0 then {
                av: emitExpr symtab: symtab ctx: ctx n: a.operation
                argval = av
            }
        } else {}
    }
    if mn.stringview == "append" then {
        rapp: "\{ctx.strC}_append(\{recvAddr}, (\{argval}).data, (\{argval}).length)"
        return rapp
    }
    r: "\{ctx.strC}_\{nativeM}(\{recvAddr}, \{argval})"
    return r
}

# isNonLvalueArg -- true when an emitted arg expression is a non-addressable
# rvalue (a call/cast result, e.g. `String_from_view(...)`) so `&expr` is invalid
# C and the arg must be hoisted to a named temp first. A deref projection
# `(*__borrow_x)` IS an lvalue, so it is excluded.
isNonLvalueArg: function {s: StringView} out bool is {
    if (s.contains needle: "(") == false then {
        return false
    }
    if (s.startsWith prefix: "(*") then {
        return false
    }
    return true
}

# flushArgHoists -- emit the `String_t _ahN = <rvalue>;` declarations recorded by
# emitInstanceMethodCall for borrow-String args that needed `&` on a non-lvalue.
# Called at statement level (which holds ind/tmp/buf) right after the call
# expression is built; registers each temp for scope-exit free.
flushArgHoists: function {ctx: Ctx ind: StringView tmp: TmpCtr buf: String.borrow} is {
    i: 0.u64
    n: ctx.argHoistNames.length
    for while i < n loop {
        nmo: ctx.argHoistNames.get i: i
        vlo: ctx.argHoistVals.get i: i
        cty: ctx.argHoistTypes.get i: i
        decl: "\{ind}\{cty} \{nmo} = \{vlo};\n"
        buf.append decl.stringview
        dto: ctx.argHoistDtors.get i: i
        if dto.length > 0 then {
            dtc: dto.copy
            tmp.listFrees.append dtc
            tmp.listFreeVars.append nmo.string
        }
        i = i + 1
    }
    ctx.argHoistNames = (List String)
    ctx.argHoistVals = (List String)
    ctx.argHoistTypes = (List String)
    ctx.argHoistDtors = (List String)
}

# pushLoopLabel -- allocate a unique break-target label for a loop and push it.
# A zerolang `break` inside the loop emits `goto __zbrk_<id>`: a bare C `break`
# would only leave an enclosing match->switch, not the loop. The label is
# emitted after the loop by popLoopLabel, but only if a break referenced it.
pushLoopLabel: function {ctx: Ctx} out u64 is {
    id: ctx.breakLabelCtr
    ctx.breakLabelCtr = id + 1
    ctx.breakLabels.append id
    return ctx.breakLabelCtr - 1
}

popLoopLabel: function {ctx: Ctx id: u64 ind: StringView buf: String.borrow} is {
    if ctx.breakLabels.length > 0 then {
        dropped: ctx.breakLabels.pop
    }
    uo: ctx.breakLabelUsed.get key: id
    match (
        uo
    ) case some then {
        lbl9: "\{ind}__zbrk_\{id}: ;\n"
        buf.append lbl9.stringview
    } case none then {}
}

# emitInstanceMethodCall -- `recv.method args` on a user CLASS instance (not a
# Type qualifier, not a collection / system native): emit
# {methodCname}(&recv, posArgs) with the receiver mapped to the :this param and
# the explicit args reordered by the method's param labels. "" when the receiver
# is not a user class or the method is unresolved.
# methodOwnerId -- the type id that actually owns method `mn`. A cross-unit
# receiver may be stamped a same-named SHELL id whose childOf lacks the method;
# scan for the same-named type that has it (emitter twin of canonicalChildBase).
methodOwnerId: function {symtab: zenv.ZSymbolTable ctx: Ctx rtid: u64 mn: StringView} out u64 is {
    direct: symtab.typing.childOf parentTypeId: rtid name: mn
    match (
        direct
    ) case some then {
        return rtid
    } case none then {}
    rn: typeNameOfReg9 symtab: symtab tid: rtid
    if rn.length == 0 then {
        return rtid
    }
    last: symtab.reg.nextTypeId
    t: 0.u64
    for while t < last loop {
        tn: typeNameOfReg9 symtab: symtab tid: t
        if tn.stringview == rn.stringview then {
            co: symtab.typing.childOf parentTypeId: t name: mn
            match (
                co
            ) case some then {
                return t.u64
            } case none then {}
        }
        t = t + 1
    }
    return rtid
}

emitInstanceMethodCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    mn: dottedChildText n: call.callable
    if mn.length == 0 then {
        return "".string
    }
    recvExpr: emitDottedReceiver symtab: symtab ctx: ctx callable: call.callable
    if recvExpr.length == 0 then {
        return "".string
    }
    rtid0: dottedReceiverStampId symtab: symtab callable: call.callable
    rtidc: chaseColMono symtab: symtab tid: rtid0
    rtid: methodOwnerId symtab: symtab ctx: ctx rtid: rtidc mn: mn.stringview
    if rtid == 0 then {
        return "".string
    }
    if (symtab.reg.typetypeOf typeId: rtid) != ztypes.ztypetype.CLASS then {
        return "".string
    }
    if (monoOriginName symtab: symtab tid: rtid).length > 0 then {
        return "".string
    }
    # system natives (String/StringView/io/cli/os) have dedicated dispatchers.
    rdu9: symtab.typing.definedInUnit.get key: rtid
    match (
        rdu9
    ) case some then {
        if rdu9.stringview == "system" then {
            return "".string
        }
        if rdu9.stringview == "collections" then {
            return "".string
        }
        if rdu9.stringview == "io" then {
            return "".string
        }
        if rdu9.stringview == "cli" then {
            return "".string
        }
        if rdu9.stringview == "os" then {
            return "".string
        }
    } case none then {}
    mco9: symtab.typing.childOf parentTypeId: rtid name: mn.stringview
    match (
        mco9
    ) case some then {
        if (symtab.reg.typetypeOf typeId: mco9) == ztypes.ztypetype.FUNCTION then {
            rptr9: dottedReceiverIsPtr symtab: symtab ctx: ctx callable: call.callable
            mtn9: typeNameOfReg9 symtab: symtab tid: mco9
            mcn9: cnameOf tid: mco9 name: mtn9.stringview
            pnames: (List String)
            pids: (List u64)
            recFieldLists symtab: symtab tid: mco9 names: pnames ids: pids
            args: "".string
            posIdx9: 0.u64
            pi9: 0.u64
            pn9: pnames.length
            for while pi9 < pn9 loop {
                pname9: pnames.get i: pi9
                pid9: pids.get i: pi9
                if pi9 > 0 then {
                    args.append ", "
                }
                if pname9.stringview == "this" then {
                    if rptr9 then {
                        args.append recvExpr.stringview
                    } else {
                        ra9: "&\{recvExpr}"
                        args.append ra9.stringview
                    }
                } else {
                    av9: ctorArgByLabel symtab: symtab ctx: ctx call: call label: pname9.stringview
                    if (ctorHasLabel call: call label: pname9.stringview) == false then {
                        pv9: ctorArgByPosition symtab: symtab ctx: ctx call: call idx: posIdx9
                        if pv9.length > 0 then {
                            av9 = pv9
                        }
                        posIdx9 = posIdx9 + 1
                    }
                    ptra9: false
                    isStrBorrow9: false
                    # a non-TAKE class arg passes by pointer (mirrors the method
                    # signature); isReftypeParam resolves a cross-unit class shell that
                    # a bare typetypeOf==CLASS check misses.
                    pown9: symtab.typing.childOwnershipText parentTypeId: mco9 name: pname9.stringview
                    isRef9: false
                    if pown9.stringview != "TAKE" then {
                        if (isReftypeParam symtab: symtab ctx: ctx tid: pid9) then {
                            isRef9 = true
                        }
                    }
                    if isRef9 then {
                        ptra9 = true
                    } else {
                        if (isBorrowStringParam symtab: symtab fid: mco9 pname: pname9.stringview pid: pid9) then {
                            ptra9 = true
                            isStrBorrow9 = true
                        }
                    }
                    if (ptra9) == false then {
                        if (isListPtrParam symtab: symtab fid: mco9 pname: pname9.stringview tid: pid9) then {
                            ptra9 = true
                        }
                    }
                    byref9: false
                    if ptra9 then {
                        if (isPtrVar ctx: ctx name: av9.stringview) == false then {
                            byref9 = true
                        }
                    }
                    if byref9 then {
                        if (isNonLvalueArg s: av9.stringview) then {
                            # `&` of a non-lvalue (a call result) is invalid C: hoist
                            # to a typed temp + destroy at block exit, mirroring the
                            # reference (`T _t = expr; f(&_t); T_destroy(&_t)`).
                            hn9: ctx.argHoistCtr
                            ctx.argHoistCtr = ctx.argHoistCtr + 1
                            nmH9: "_ah\{hn9}".string
                            hcty9: typeRefC symtab: symtab ctx: ctx tid: pid9 thisTid: 0
                            htyc9: hcty9.string
                            hdt9: "".string
                            if isStrBorrow9 then {
                                hdt9 = "    \{ctx.strC}_free(&\{nmH9});\n"
                            } else {
                                hrid9: pid9
                                hduo9: symtab.typing.definedInUnit.get key: pid9
                                match (
                                    hduo9
                                ) case none then {
                                    htn9: typeNameOfReg9 symtab: symtab tid: pid9
                                    hrr9: resolveTypeIdByName symtab: symtab ctx: ctx name: htn9.stringview
                                    if hrr9 > 0 then {
                                        hrid9 = hrr9
                                    }
                                } case some then {}
                                if (symtab.reg.hasDestructorName typeId: hrid9) then {
                                    hnm9: typeNameOfReg9 symtab: symtab tid: hrid9
                                    hcb9: cnameOf tid: hrid9 name: hnm9.stringview
                                    hdt9 = "    \{hcb9}_destroy(&\{nmH9});\n"
                                }
                            }
                            abh9: "&\{nmH9}"
                            args.append abh9.stringview
                            ctx.argHoistVals.append av9
                            ctx.argHoistTypes.append htyc9
                            ctx.argHoistDtors.append hdt9
                            ctx.argHoistNames.append nmH9
                        } else {
                            ab9: "&\{av9}"
                            args.append ab9.stringview
                        }
                    } else {
                        args.append av9.stringview
                    }
                }
                pi9 = pi9 + 1
            }
            r9: "\{mcn9}(\{args})"
            return r9
        }
    } case none then {}
    return "".string
}

# collectionValueCallRhs -- the binding RHS is a value-producing expression
# returning a collection (a call to a user function/method, or a bare dotted-path
# no-arg method auto-call / field access), as opposed to a collection construction
# (`(List of: T)` / `(Set ...)` / `(Map ...)` calls, or a bare typedef-collection
# atom like `Bytes` / `ByteView`). A value call must be emitted as the call;
# constructions emit the binding's mono create. Used by the List/Set/Map binding
# branches to choose between emitting the RHS expression and an empty create.
collectionValueCallRhs: function {n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (collectionValueCallRhs n: n.expression)
    } case statementline then {
        return (collectionValueCallRhs n: n.statementline)
    } case dottedpath then {
        # a bare dotted path returning a collection (e.g. `st.allNames`) is a
        # no-arg method auto-call or field access -- a value, never a construction.
        return (atomTextOf n: n.child).length > 0
    } case call then {
        cn: atomTextOf n: n.callable
        if cn.length == 0 then {
            # a dotted-path method callable (e.g. `p.operationPaths lex: lx`)
            # returning a List is a value-producing call, not a construction --
            # emit the call rather than falling to the empty-collection default.
            return (dottedChildText n: n.callable).length > 0
        }
        if cn.stringview == "List" then {
            return false
        }
        if cn.stringview == "Set" then {
            return false
        }
        if cn.stringview == "Map" then {
            return false
        }
        if cn.stringview == "Bytes" then {
            return false
        }
        if cn.stringview == "ByteView" then {
            return false
        }
        return true
    } else {
        return false
    }
}

# bindingRhsIsBorrow -- the binding RHS yields a non-owning borrow, so the bound
# String local must NOT be freed at scope exit (its owner -- the list or the
# struct -- frees it; a premature free is a use-after-free / double-free). Two
# shapes: a `<list>.get i:` over a List/ListView (a shallow element view), and a
# plain field access `<base>.<field>` (the field's String is owned by `<base>`).
# A no-arg method call (the child resolves to a FUNCTION) returns an owned value
# and is NOT a borrow. (Map.get returns an owned Option, handled elsewhere;
# `.copy` / `.string` / `.take` are owned and handled before this check.)
bindingRhsIsBorrow: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (bindingRhsIsBorrow symtab: symtab ctx: ctx n: n.expression)
    } case statementline then {
        return (bindingRhsIsBorrow symtab: symtab ctx: ctx n: n.statementline)
    } case call then {
        ch: dottedChildText n: n.callable
        if ch.stringview != "get" then {
            return false
        }
        rid: dottedReceiverStampId symtab: symtab callable: n.callable
        rid = chaseColMono symtab: symtab tid: rid
        omn: monoOriginName symtab: symtab tid: rid
        if omn.stringview == "List" then {
            return true
        }
        if omn.stringview == "ListView" then {
            return true
        }
        return false
    } case dottedpath then {
        ch9: atomTextOf n: n.child
        bnm9: atomTextOf n: n.parent
        if (ctx.narrowBox.has key: bnm9.string) then {
            # a field read off a narrowed subject is a shallow-copy borrow (it aliases
            # the subject's heap); an ownership builtin yields an owned value.
            if ch9.stringview == "take" then { return false }
            if ch9.stringview == "copy" then { return false }
            if ch9.stringview == "string" then { return false }
            return true
        }
        ptid9: stampIdOf symtab: symtab nid: (nodeIdOf9 n: n.parent)
        cco9: symtab.typing.childOf parentTypeId: ptid9 name: ch9.stringview
        match (
            cco9
        ) case some then {
            if (symtab.reg.typetypeOf typeId: cco9) == ztypes.ztypetype.FUNCTION then {
                return false
            }
            return true
        } case none then {
            return false
        }
    } else {
        return false
    }
}

# emitEmptyColCreate -- an empty collection construction `(List of: T)` /
# `(Set of: T)` / `(Map ...)` as a value: emit the collection mono's create with
# capacity 0, resolved from the call-node stamp. "" when not such a construction.
emitEmptyColCreate: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData cn0: StringView} out String is {
    isCol9: false
    if cn0 == "List" then {
        isCol9 = true
    }
    if cn0 == "Set" then {
        isCol9 = true
    }
    if cn0 == "Map" then {
        isCol9 = true
    }
    if (isCol9) == false then {
        return "".string
    }
    mid9: stampIdOf symtab: symtab nid: call.nodeid.u64
    mid9 = chaseColMono symtab: symtab tid: mid9
    if (monoOriginName symtab: symtab tid: mid9).length <= 0 then {
        return "".string
    }
    mn9: typeNameOfReg9 symtab: symtab tid: mid9
    cb9: cnameOf tid: mid9 name: mn9.stringview
    return "\{cb9}_create((uint64_t)0)"
}

# colRecvRef -- a collection (List) receiver as a C lvalue for a method call: a
# ptrVar List (a by-pointer param) is already a pointer and passes directly; a
# value List passes its address.
colRecvRef: function {ctx: Ctx bn: StringView} out String is {
    if (isPtrVar ctx: ctx name: bn) then {
        return bn.string
    }
    return "&\{bn}"
}

emitListMethodCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    mn: dottedChildText n: call.callable
    bn: emitDottedReceiver symtab: symtab ctx: ctx callable: call.callable
    if bn.length == 0 then {
        return "".string
    }
    brid9: dottedReceiverStampId symtab: symtab callable: call.callable
    bt: chaseColMono symtab: symtab tid: brid9
    omn: monoOriginName symtab: symtab tid: bt
    isLV: false
    if omn.stringview != "List" then {
        if omn.stringview == "ListView" then {
            isLV = true
        } else {
            return "".string
        }
    }
    btn: typeNameOfReg9 symtab: symtab tid: bt
    cb: cnameOf tid: bt name: btn.stringview
    recvR9: colRecvRef ctx: ctx bn: bn.stringview
    if mn.stringview == "append" then {
        v: colArg symtab: symtab ctx: ctx call: call label: "from" consumes: true
        e0: "\{cb}_append(\{recvR9}, \{v})"
        return e0
    }
    if mn.stringview == "get" then {
        v: listArg symtab: symtab ctx: ctx call: call label: "i"
        e1: "\{cb}_get(\{recvR9}, \{v})"
        return e1
    }
    if mn.stringview == "set" then {
        vi: listArg symtab: symtab ctx: ctx call: call label: "i"
        vv: listArg symtab: symtab ctx: ctx call: call label: "val"
        e2: "\{cb}_set(\{recvR9}, \{vi}, \{vv})"
        return e2
    }
    if mn.stringview == "pop" then {
        e3: "\{cb}_pop(\{recvR9})"
        return e3
    }
    if mn.stringview == "insert" then {
        vf: listArg symtab: symtab ctx: ctx call: call label: "from"
        va: listArg symtab: symtab ctx: ctx call: call label: "at"
        e4: "\{cb}_insert(\{recvR9}, \{vf}, \{va})"
        return e4
    }
    if mn.stringview == "extend" then {
        ea: listTakeArgBase symtab: symtab ctx: ctx call: call label: "from"
        e5: "\{cb}_extend(\{recvR9}, &\{ea})"
        return e5
    }
    if mn.stringview == "contains" then {
        vc: listArg symtab: symtab ctx: ctx call: call label: "item"
        e6: "\{cb}_contains(\{recvR9}, \{vc})"
        return e6
    }
    if mn.stringview == "sort" then {
        e7: "\{cb}_sort(\{recvR9})"
        return e7
    }
    return "".string
}

# emitSetMethodCall -- an arg-taking method on a Set-mono receiver (a heap
# pointer, so the receiver passes directly without `&`). "" when not a Set
# call; the no-arg `.length`/`.iterate` reads ride the dottedpath leg.
emitSetMethodCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    bn: emitDottedReceiver symtab: symtab ctx: ctx callable: call.callable
    mn: dottedChildText n: call.callable
    if bn.length == 0 then {
        return "".string
    }
    brid9: dottedReceiverStampId symtab: symtab callable: call.callable
    bt: chaseColMono symtab: symtab tid: brid9
    omn: monoOriginName symtab: symtab tid: bt
    if omn.stringview != "Set" then {
        return "".string
    }
    btn: typeNameOfReg9 symtab: symtab tid: bt
    cb: cnameOf tid: bt name: btn.stringview
    if mn.stringview == "add" then {
        v: colArg symtab: symtab ctx: ctx call: call label: "item" consumes: true
        e0: "\{cb}_add(\{bn}, \{v})"
        return e0
    }
    if mn.stringview == "has" then {
        v: colArg symtab: symtab ctx: ctx call: call label: "item" consumes: false
        e1: "\{cb}_has(\{bn}, \{v})"
        return e1
    }
    if mn.stringview == "delete" then {
        v: colArg symtab: symtab ctx: ctx call: call label: "item" consumes: false
        e2: "\{cb}_delete(\{bn}, \{v})"
        return e2
    }
    return "".string
}

# emitMapMethodCall -- an arg-taking method on a Map-mono receiver (a heap
# pointer). set/get/has/delete pass the pointer directly; "" otherwise. The
# no-arg `.length`/`.capacity` reads ride the dottedpath leg.
emitMapMethodCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    bn: emitDottedReceiver symtab: symtab ctx: ctx callable: call.callable
    mn: dottedChildText n: call.callable
    if bn.length == 0 then {
        return "".string
    }
    brid9: dottedReceiverStampId symtab: symtab callable: call.callable
    bt: chaseColMono symtab: symtab tid: brid9
    omn: monoOriginName symtab: symtab tid: bt
    if omn.stringview != "Map" then {
        return "".string
    }
    btn: typeNameOfReg9 symtab: symtab tid: bt
    cb: cnameOf tid: bt name: btn.stringview
    if mn.stringview == "set" then {
        vk: colArg symtab: symtab ctx: ctx call: call label: "key" consumes: true
        vv: colArg symtab: symtab ctx: ctx call: call label: "value" consumes: true
        e0: "\{cb}_set(\{bn}, \{vk}, \{vv})"
        return e0
    }
    if mn.stringview == "get" then {
        vk: colArg symtab: symtab ctx: ctx call: call label: "key" consumes: false
        e1: "\{cb}_get(\{bn}, \{vk})"
        return e1
    }
    if mn.stringview == "has" then {
        vk: colArg symtab: symtab ctx: ctx call: call label: "key" consumes: false
        e2: "\{cb}_has(\{bn}, \{vk})"
        return e2
    }
    if mn.stringview == "delete" then {
        vk: colArg symtab: symtab ctx: ctx call: call label: "key" consumes: false
        e3: "\{cb}_delete(\{bn}, \{vk})"
        return e3
    }
    return "".string
}

# emitInterpArgExpr -- if n is (or wraps/projects via .string/.stringview) an
# interpolated string literal, return a self-contained statement expression that
# builds and yields the owned String; "" otherwise. Used for inline argument
# positions, where the pure emitExpr cannot emit the multi-statement interp build.
emitInterpArgExpr: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out String is {
    match (
        n
    ) case expression then {
        return (emitInterpArgExpr symtab: symtab ctx: ctx n: n.expression)
    } case atomstring then {
        if (isInterp parts: n.stringparts) then {
            ltmp: (TmpCtr n: 0 frees: (List String) listFrees: (List String) listFreeVars: (List String))
            lbuf: "".string
            sM: emitInterpBuild symtab: symtab ctx: ctx parts: n.stringparts ind: " " tmp: ltmp buf: lbuf
            r: "({ \{lbuf}_s\{sM}; })".string
            return r
        }
        return "".string
    } case dottedpath then {
        cm: atomTextOf n: n.child
        if cm.stringview == "string" then {
            return (emitInterpArgExpr symtab: symtab ctx: ctx n: n.parent)
        }
        if cm.stringview == "stringview" then {
            return (emitInterpArgExpr symtab: symtab ctx: ctx n: n.parent)
        }
        return "".string
    } else {
        return "".string
    }
}

# emitInterpStmtValue -- like emitInterpArgExpr, but emits the interp build chain
# as PRIOR statements into buf (so a referenced local is read at THIS point) and
# returns the owned-String temp name "_sN"; "" otherwise. Used where the build
# must precede the statement -- a reassignment drop-old, so `s = "\{s}x"` reads
# old s before the old value is freed (mirrors emitStringBindValue / the
# reference's _temp.decls). emitInterpBuild does NOT register _sN for free, so the
# assignment `nm2 = _sN` moves the storage into the lvalue with no double-free.
emitInterpStmtValue: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node ind: StringView tmp: TmpCtr buf: String.borrow} out String is {
    match (
        n
    ) case expression then {
        return (emitInterpStmtValue symtab: symtab ctx: ctx n: n.expression ind: ind tmp: tmp buf: buf)
    } case atomstring then {
        if (isInterp parts: n.stringparts) then {
            sB: emitInterpBuild symtab: symtab ctx: ctx parts: n.stringparts ind: ind tmp: tmp buf: buf
            return "_s\{sB}".string
        }
        return "".string
    } case dottedpath then {
        cm: atomTextOf n: n.child
        if cm.stringview == "string" then {
            return (emitInterpStmtValue symtab: symtab ctx: ctx n: n.parent ind: ind tmp: tmp buf: buf)
        }
        if cm.stringview == "stringview" then {
            return (emitInterpStmtValue symtab: symtab ctx: ctx n: n.parent ind: ind tmp: tmp buf: buf)
        }
        return "".string
    } else {
        return "".string
    }
}

# emitColInterpArg -- an interpolated-string collection-method argument hoisted to
# an owned String temp via the argHoist mechanism (flushed at the statement). When
# the method BORROWS the arg (consumes == false: has/delete/get), a scope-exit
# free is registered; a consuming method (add/set) moves the temp in. "" when n is
# not an interpolated string.
emitColInterpArg: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node consumes: bool} out String is {
    sx: emitInterpArgExpr symtab: symtab ctx: ctx n: n
    if sx.length == 0 then {
        if consumes then {
            return "".string
        }
        tn9: stampNameDeep symtab: symtab n: n
        if tn9.stringview != "String" then {
            return "".string
        }
        ex9: emitExpr symtab: symtab ctx: ctx n: n
        if (isNonLvalueArg s: ex9.stringview) == false then {
            return "".string
        }
        sx = ex9
    }
    hn: ctx.argHoistCtr
    ctx.argHoistCtr = ctx.argHoistCtr + 1
    nmH: "_ah\{hn}".string
    hdt: "".string
    if (consumes) == false then {
        hdt = "    \{ctx.strC}_free(&\{nmH});\n"
    }
    retx: nmH.copy
    ctx.argHoistVals.append sx
    ctx.argHoistTypes.append "\{ctx.strC}_t".string
    ctx.argHoistDtors.append hdt
    ctx.argHoistNames.append nmH
    return retx
}

# colArg -- a collection-method argument: the interp-string hoist when the arg is
# an interpolated literal, else the plain expression (mirrors listArg). consumes
# distinguishes take params (add/set) from borrow params (has/delete/get).
colArg: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData label: StringView consumes: bool} out String is {
    posFirst: "".string
    havePos: false
    aiter: call.arguments.iterate
    for a: aiter loop {
        match (
            a
        ) case namedoperation then {
            an: unitLabel9 o: a.name
            if an.stringview == label then {
                ic: emitColInterpArg symtab: symtab ctx: ctx n: a.operation consumes: consumes
                if ic.length > 0 then {
                    return ic
                }
                return (emitExpr symtab: symtab ctx: ctx n: a.operation)
            }
            if an.length == 0 when havePos == false then {
                havePos = true
                icp: emitColInterpArg symtab: symtab ctx: ctx n: a.operation consumes: consumes
                if icp.length > 0 then {
                    posFirst = icp
                } else {
                    posFirst = emitExpr symtab: symtab ctx: ctx n: a.operation
                }
            }
        } else {}
    }
    if havePos then {
        return posFirst
    }
    return "0".string
}

# listArg -- the C expression for a labeled list-method argument ("0" if
# absent).
listArg: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData label: StringView} out String is {
    posFirst: "".string
    havePos: false
    aiter: call.arguments.iterate
    for a: aiter loop {
        match (
            a
        ) case namedoperation then {
            an: unitLabel9 o: a.name
            if an.stringview == label then {
                return (emitExpr symtab: symtab ctx: ctx n: a.operation)
            }
            if an.length == 0 when havePos == false then {
                havePos = true
                posFirst = emitExpr symtab: symtab ctx: ctx n: a.operation
            }
        } else {}
    }
    # a single positional arg binds to the (sole) labelless call site, e.g.
    # `xs.get i2` -> the `i` param.
    if havePos then {
        return posFirst
    }
    return "0".string
}

# listTakeArgBase -- the base atom of a `x.take` list argument (the
# extend source); the bare atom text otherwise.
listTakeArgBase: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData label: StringView} out String is {
    aiter: call.arguments.iterate
    for a: aiter loop {
        match (
            a
        ) case namedoperation then {
            an: unitLabel9 o: a.name
            if an.stringview == label then {
                return (takeArgBase n: a.operation)
            }
        } else {}
    }
    return "0".string
}

takeArgBase: function {n: Node} out String is {
    match (
        n
    ) case expression then {
        return (takeArgBase n: n.expression)
    } case dottedpath then {
        return (atomTextOf n: n.parent)
    } case atomid then {
        av: n.name.stringview
        ac: av.string
        return ac
    } else {
        return "0".string
    }
}

# emitTypedefCreateCall -- `meters.create from: 42` / `meters 42`: a
# zero-overhead cast; emit the single argument expression.
emitTypedefCreateCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    bn: dottedBaseAtom n: call.callable
    if bn.length == 0 then {
        bn = atomTextOf n: call.callable
    }
    if bn.length == 0 then {
        return "".string
    }
    tid: userFnId symtab: symtab ctx: ctx name: bn.stringview
    if tid == 0 then {
        return "".string
    }
    if (isTypedefType symtab: symtab tid: tid) == false then {
        return "".string
    }
    aiter: call.arguments.iterate
    for a: aiter loop {
        match (
            a
        ) case namedoperation then {
            return (emitExpr symtab: symtab ctx: ctx n: a.operation)
        } else {}
    }
    return "0".string
}

# emitVariantCtorCall -- `result.ok 42`: a dotted callee whose base is a
# variant type and whose member is a payload arm; emits a designated
# compound literal.
# emitInlineVariantCtor -- a value (inline-payload) variant/optionval/resultval
# constructor as a compound literal: some-arm carries the first arg in .data.arm,
# none-arm just the tag. tid is the concrete VARIANT/mono type.
emitInlineVariantCtor: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData tid: u64 arm: StringView} out String is {
    pc: armPayloadC symtab: symtab ctx: ctx tid: tid arm: arm
    tg: variantTag symtab: symtab tid: tid arm: arm
    vn: typeNameOfReg9 symtab: symtab tid: tid
    vc: cnameOf tid: tid name: vn.stringview
    if pc.length > 0 then {
        av: "0".string
        aiter: call.arguments.iterate
        got: false
        for a: aiter loop {
            match (
                a
            ) case namedoperation then {
                if (got) == false then {
                    got = true
                    av = emitExpr symtab: symtab ctx: ctx n: a.operation
                }
            } else {}
        }
        e0: "((\{vc}_t){ .tag = \{tg}, .data.\{arm} = (\{av}) })"
        return e0
    } else {
        e1: "((\{vc}_t){ .tag = \{tg} })"
        return e1
    }
}

# emitUnionCtor -- a main-unit user union arm construction (`U.arm payload`):
# a GCC statement-expression building the heap-payload union value (tag + a
# malloc'd box for the payload, or NULL data for a payload-less arm). Generic
# monos (Option/Result) keep their own emission paths.
emitUnionCtor: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    bn: dottedBaseAtom n: call.callable
    if bn.length == 0 then {
        return "".string
    }
    mn: dottedChildText n: call.callable
    if mn.length == 0 then {
        return "".string
    }
    smid0: stampIdOf symtab: symtab nid: call.nodeid.u64
    if (monoOriginName symtab: symtab tid: smid0).length > 0 then {
        return "".string
    }
    utid: resolveTypeIdByName symtab: symtab ctx: ctx name: bn.stringview
    if utid == 0 then {
        return "".string
    }
    if (symtab.reg.typetypeOf typeId: utid) != ztypes.ztypetype.UNION then {
        return "".string
    }
    if (monoOriginName symtab: symtab tid: utid).length != 0 then {
        return "".string
    }
    vc: cnameOf tid: utid name: bn.stringview
    tg: variantTag symtab: symtab tid: utid arm: mn.stringview
    payC: armPayloadC symtab: symtab ctx: ctx tid: utid arm: mn.stringview
    if payC.length > 0 then {
        av: "".string
        got: false
        aiter: call.arguments.iterate
        for a: aiter loop {
            match (
                a
            ) case namedoperation then {
                if (got) == false then {
                    got = true
                    av = emitExpr symtab: symtab ctx: ctx n: a.operation
                }
            } else {}
        }
        e: "({ \{vc}_t _u = {0}; _u.tag = \{tg}; \{payC}* _b = (\{payC}*)z_xmalloc(sizeof(\{payC})); *_b = \{av}; _u.data = _b; _u; })"
        return e
    } else {
        e2: "({ \{vc}_t _u = {0}; _u.tag = \{tg}; _u.data = NULL; _u; })"
        return e2
    }
}

emitVariantCtorCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    bn: dottedBaseAtom n: call.callable
    mn: dottedChildText n: call.callable
    if bn.length == 0 then {
        return "".string
    }
    # system monos (optionval/resultval inline, Option none) -- the call node is
    # stamped with the concrete mono id (userFnId fails for these). Option.some
    # is a heap box handled by emitOptionBoxHoist at the statement site.
    smid: stampIdOf symtab: symtab nid: call.nodeid.u64
    sorig: monoOriginName symtab: symtab tid: smid
    sInline: false
    if sorig.stringview == "optionval" when bn.stringview == "optionval" then {
        sInline = true
    }
    if sorig.stringview == "resultval" when bn.stringview == "resultval" then {
        sInline = true
    }
    if sInline then {
        return (emitInlineVariantCtor symtab: symtab ctx: ctx call: call tid: smid arm: mn.stringview)
    }
    if sorig.stringview == "Option" then {
        ovn9: typeNameOfReg9 symtab: symtab tid: smid
        ovc9: cnameOf tid: smid name: ovn9.stringview
        if mn.stringview == "none" then {
            otg9: variantTag symtab: symtab tid: smid arm: "none"
            en9: "((\{ovc9}_t){ .tag = \{otg9}, .data = NULL })"
            return en9
        }
        if mn.stringview == "some" then {
            otg9s: variantTag symtab: symtab tid: smid arm: "some"
            opayC9: armPayloadC symtab: symtab ctx: ctx tid: smid arm: "some"
            oav9: "0".string
            ogot9: false
            oaiter9: call.arguments.iterate
            for oa9: oaiter9 loop {
                match (
                    oa9
                ) case namedoperation then {
                    if (ogot9) == false then {
                        ogot9 = true
                        oav9 = emitExpr symtab: symtab ctx: ctx n: oa9.operation
                    }
                } else {}
            }
            es9: "({ \{ovc9}_t _u = {0}; _u.tag = \{otg9s}; \{opayC9}* _b = (\{opayC9}*)z_xmalloc(sizeof(\{opayC9})); *_b = \{oav9}; _u.data = _b; _u; })"
            return es9
        }
        return "".string
    }
    vtid: userFnId symtab: symtab ctx: ctx name: bn.stringview
    if vtid == 0 then {
        return "".string
    }
    if (symtab.reg.typetypeOf typeId: vtid) != ztypes.ztypetype.VARIANT then {
        return "".string
    }
    return (emitInlineVariantCtor symtab: symtab ctx: ctx call: call tid: vtid arm: mn.stringview)
}

# emitColTypedefCall -- `ByteView.borrow from: X` / `Bytes.create from: X` on a
# collection-typedef-class (Bytes/ByteView): the typedef is a zero-overhead
# alias, so the borrow/create is transparent -- emit the underlying arg. ""
# for any non-collection-typedef base.
emitColTypedefCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    bn: dottedBaseAtom n: call.callable
    if bn.length == 0 then {
        return "".string
    }
    mn: dottedChildText n: call.callable
    isBC: false
    if mn.stringview == "borrow" then {
        isBC = true
    }
    if mn.stringview == "create" then {
        isBC = true
    }
    if (isBC) == false then {
        return "".string
    }
    bid: resolveTypeIdByName symtab: symtab ctx: ctx name: bn.stringview
    if bid == 0 then {
        return "".string
    }
    mid: chaseColMono symtab: symtab tid: bid
    if mid == bid then {
        return "".string
    }
    return (ctorArgByLabel symtab: symtab ctx: ctx call: call label: "from")
}

# emitTypeQualCall -- `point.add a: x b: y`: a dotted callee whose base
# resolves to a record type and whose member is a FUNCTION child; args
# reorder to the method's param order by label.
emitTypeQualCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    bn: dottedBaseAtom n: call.callable
    mn: dottedChildText n: call.callable
    if bn.length == 0 then {
        return "".string
    }
    btid: userFnId symtab: symtab ctx: ctx name: bn.stringview
    if btid == 0 then {
        return "".string
    }
    bttq: symtab.reg.typetypeOf typeId: btid
    isStructQ: false
    if bttq == ztypes.ztypetype.RECORD then {
        isStructQ = true
    }
    if bttq == ztypes.ztypetype.CLASS then {
        isStructQ = true
    }
    if (isStructQ) == false then {
        return "".string
    }
    mco: symtab.typing.childOf parentTypeId: btid name: mn.stringview
    match (
        mco
    ) case some then {
        if (symtab.reg.typetypeOf typeId: mco) == ztypes.ztypetype.FUNCTION then {
            pnames: (List String)
            pids: (List u64)
            recFieldLists symtab: symtab tid: mco names: pnames ids: pids
            # the default (synth) `create` carries no params -- route it to the
            # type's ctor (field-label args), the same path bare-name uses.
            if mn.stringview == "create" when pnames.length == 0 then {
                return (emitRecordCtor symtab: symtab ctx: ctx call: call tid: btid name: bn.stringview)
            }
            pn: pnames.length
            args: "".string
            if mn.stringview == "create" then {
                # user create: args by the create's own param labels
                pi: 0.u64
                for while pi < pn loop {
                    pname: pnames.get i: pi
                    av: ctorArgByLabel symtab: symtab ctx: ctx call: call label: pname.stringview
                    if pi > 0 then {
                        args.append ", "
                    }
                    args.append av.stringview
                    pi = pi + 1
                }
            } else {
                # a method: positional args; a CLASS receiver passes by address
                clsNmQ: typeNameOfReg9 symtab: symtab tid: btid
                ai9: 0.u64
                with aiterQ: call.arguments.iterate do for aQ: aiterQ loop {
                    match (
                        aQ
                    ) case namedoperation then {
                        avq: emitExpr symtab: symtab ctx: ctx n: aQ.operation
                        byRef9: false
                        if bttq == ztypes.ztypetype.CLASS when ai9 < pn then {
                            ppid9: pids.get i: ai9
                            pptn9: typeNameOfReg9 symtab: symtab tid: ppid9
                            if pptn9.stringview == "this" then {
                                byRef9 = true
                            }
                            if pptn9.stringview == clsNmQ.stringview then {
                                byRef9 = true
                            }
                            if ppid9 == btid then {
                                byRef9 = true
                            }
                        }
                        if ai9 > 0 then {
                            args.append ", "
                        }
                        if byRef9 then {
                            argq9: "&\{avq}"
                            args.append argq9.stringview
                        } else {
                            args.append avq.stringview
                        }
                        ai9 = ai9 + 1
                    } else {}
                }
            }
            mtn3: typeNameOfReg9 symtab: symtab tid: mco
            mc3: cnameOf tid: mco name: mtn3.stringview
            e7: "\{mc3}(\{args})"
            return e7
        }
    } case none then {}
    return "".string
}

# emitRecordCtor -- a record construction call: args reordered to field
# order by label, emitted through the create alias.
emitRecordCtor: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData tid: u64 name: StringView} out String is {
    # a user-defined `create` (non-empty params) overrides the field-wise ctor:
    # bare-name construction routes through it, args by the create's own labels.
    cco: symtab.typing.childOf parentTypeId: tid name: "create"
    match (
        cco
    ) case some then {
        if (symtab.reg.typetypeOf typeId: cco) == ztypes.ztypetype.FUNCTION then {
            cpn: (List String)
            cpi: (List u64)
            recFieldLists symtab: symtab tid: cco names: cpn ids: cpi
            if cpn.length > 0 then {
                cargs: "".string
                ci: 0.u64
                ccn: cpn.length
                for while ci < ccn loop {
                    cpname: cpn.get i: ci
                    cav: ctorArgByLabel symtab: symtab ctx: ctx call: call label: cpname.stringview
                    if ci > 0 then {
                        cargs.append ", "
                    }
                    cargs.append cav.stringview
                    ci = ci + 1
                }
                ccbn: typeNameOfReg9 symtab: symtab tid: cco
                ccb: cnameOf tid: cco name: ccbn.stringview
                ce: "\{ccb}(\{cargs})"
                return ce
            }
        }
    } case none then {}
    fnames: (List String)
    fids: (List u64)
    recFieldLists symtab: symtab tid: tid names: fnames ids: fids
    args: "".string
    fi: 0.u64
    fn0: fnames.length
    for while fi < fn0 loop {
        fname: fnames.get i: fi
        av: ctorArgByLabel symtab: symtab ctx: ctx call: call label: fname.stringview
        if fi > 0 then {
            args.append ", "
        }
        args.append av.stringview
        fi = fi + 1
    }
    rc: cnameOf tid: tid name: name
    e0: "\{rc}_create(\{args})"
    return e0
}

ctorArgByLabel: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData label: StringView} out String is {
    aiter: call.arguments.iterate
    for a: aiter loop {
        match (
            a
        ) case namedoperation then {
            an: unitLabel9 o: a.name
            if an.stringview == label then {
                return (emitExpr symtab: symtab ctx: ctx n: a.operation)
            }
        } else {}
    }
    return "0".string
}

# ctorArgByPosition -- the idx-th POSITIONAL (unlabeled) argument's C text, for a
# method call passing args positionally (`this.formatLockHolder holder`) rather
# than by label; "" when there is no such arg.
ctorArgByPosition: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData idx: u64} out String is {
    seen9: 0.u64
    aiter: call.arguments.iterate
    for a: aiter loop {
        match (
            a
        ) case namedoperation then {
            an: unitLabel9 o: a.name
            if an.length == 0 then {
                if seen9 == idx then {
                    return (emitExpr symtab: symtab ctx: ctx n: a.operation)
                }
                seen9 = seen9 + 1
            }
        } else {}
    }
    return "".string
}

# nodeConstText -- the C literal for a node carrying a compile-time
# const stamp (folded .LABEL data access, unit constants); "" otherwise.
nodeConstText: function {symtab: zenv.ZSymbolTable nid: u64} out String is {
    if nid == 0 then {
        return "".string
    }
    res: "".string
    with citer: symtab.typing.nodeConst.iterate do for row: citer loop {
        if row.nodeid == nid when res.length == 0 then {
            if row.value.kind == ztypes.zconstkind.IVAL then {
                iv: row.value.ival
                res = "\{iv}"
            }
            if row.value.kind == ztypes.zconstkind.FVAL then {
                fv: row.value.fval
                res = "\{fv}"
            }
        }
    }
    return res
}

# emitMetaCreateCall -- `meta.create field: val ...`, the enclosing type's raw
# allocator (its field children as params). The typecheck stamps the call node
# with that type; emit `{type}_meta_create(args)` (never `_create`, which the
# user's own create may override -> recursion). "" when not a meta.create.
# ctorHasLabel -- whether a call carries a named argument with this label.
ctorHasLabel: function {call: zast.CallData label: StringView} out bool is {
    aiter: call.arguments.iterate
    for a: aiter loop {
        match (
            a
        ) case namedoperation then {
            an: unitLabel9 o: a.name
            if an.stringview == label then {
                return true
            }
        } else {}
    }
    return false
}

emitMetaCreateCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    mcb: ztypecheck.metaCreateBaseId n: call.callable
    match (
        mcb
    ) case some then {
        et: stampIdOf symtab: symtab nid: call.nodeid.u64
        if et == 0 then {
            return "".string
        }
        etn: typeNameOfReg9 symtab: symtab tid: et
        fnames: (List String)
        fids: (List u64)
        recFieldLists symtab: symtab tid: et names: fnames ids: fids
        args: "".string
        fi: 0.u64
        fn0: fnames.length
        for while fi < fn0 loop {
            fname: fnames.get i: fi
            av: "".string
            if (ctorHasLabel call: call label: fname.stringview) then {
                av = ctorArgByLabel symtab: symtab ctx: ctx call: call label: fname.stringview
            } else {
                # a field absent from the meta.create args (a generator's promoted
                # local: an inner iterator struct or a loop counter) is value-
                # initialized; a typed zero compiles for both scalars and structs.
                ffid: fids.get i: fi
                ffct: typeRefC symtab: symtab ctx: ctx tid: ffid thisTid: 0
                if ffct.length == 0 then {
                    ffct = "int64_t".string
                }
                if (symtab.typing.isChildLockField parentTypeId: et name: fname.stringview) when (lockFieldIsReftypePtr symtab: symtab ctx: ctx fid: ffid) then {
                    ffct = "\{ffct}*"
                }
                av = "(\{ffct}){0}".string
            }
            if fi > 0 then {
                args.append ", "
            }
            args.append av.stringview
            fi = fi + 1
        }
        ecb: cnameOf tid: et name: etn.stringview
        e0: "\{ecb}_meta_create(\{args})"
        return e0
    } case none then {
        return "".string
    }
}

# emitCrossUnitFnCall -- a cross-unit free-function call `unit.fn args`
# (e.g. zparser calling a zast/zlexer helper). The callee is a dottedpath whose
# base is a unit name; the function's shared id lives in resolved["{unit}.{fn}"],
# so emit z_t{id}_{fn}(args) with the same reftype-by-ref arg handling as a bare
# free-function call. "" when the callee is not a cross-unit function.
emitByrefArg: function {symtab: zenv.ZSymbolTable ctx: Ctx av: StringView pid: u64} out String is {
    if (isNonLvalueArg s: av) == false then {
        return "&\{av}"
    }
    hn: ctx.argHoistCtr
    ctx.argHoistCtr = ctx.argHoistCtr + 1
    nmH: "_ah\{hn}".string
    hcty: typeRefC symtab: symtab ctx: ctx tid: pid thisTid: 0
    htyc: hcty.string
    hrid: pid
    hduo: symtab.typing.definedInUnit.get key: pid
    match (
        hduo
    ) case none then {
        htn0: typeNameOfReg9 symtab: symtab tid: pid
        hrr: resolveTypeIdByName symtab: symtab ctx: ctx name: htn0.stringview
        if hrr > 0 then {
            hrid = hrr
        }
    } case some then {}
    htn: typeNameOfReg9 symtab: symtab tid: hrid
    hdt: "".string
    if htn.stringview == "String" then {
        hdt = "    \{ctx.strC}_free(&\{nmH});\n"
    } else {
        if (symtab.reg.hasDestructorName typeId: hrid) then {
            hcb: cnameOf tid: hrid name: htn.stringview
            hdt = "    \{hcb}_destroy(&\{nmH});\n"
        }
    }
    avc: av.string
    r: "&\{nmH}"
    ctx.argHoistVals.append avc
    ctx.argHoistTypes.append htyc
    ctx.argHoistDtors.append hdt
    ctx.argHoistNames.append nmH
    return r
}

emitCrossUnitFnCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    base: dottedBaseAtom n: call.callable
    child: dottedChildText n: call.callable
    if base.length == 0 then {
        return "".string
    }
    if child.length == 0 then {
        return "".string
    }
    if (symtab.reg.isUnitName name: base.stringview) == false then {
        return "".string
    }
    k: "\{base}.\{child}".string
    go: symtab.typing.resolved.get key: k
    fid: 0.u64
    match (
        go
    ) case some then {
        fid = go
    } case none then {}
    if fid == 0 then {
        return "".string
    }
    if (symtab.reg.typetypeOf typeId: fid) != ztypes.ztypetype.FUNCTION then {
        return "".string
    }
    fc: cnameOf tid: fid name: child.stringview
    fpNames: (List String)
    fpIds: (List u64)
    recFieldLists symtab: symtab tid: fid names: fpNames ids: fpIds
    args: "".string
    ai8: 0.u64
    aiter: call.arguments.iterate
    for a: aiter loop {
        match (
            a
        ) case namedoperation then {
            av9: emitExpr symtab: symtab ctx: ctx n: a.operation
            byref8: false
            argRef8: "".string
            if ai8 < fpIds.length then {
                fpid8: fpIds.get i: ai8
                ptra8: false
                ownC8: "".string
                if ai8 < fpNames.length then {
                    fpnO8: fpNames.get i: ai8
                    ownC8 = symtab.typing.childOwnershipText parentTypeId: fid name: fpnO8.stringview
                }
                if ownC8.stringview != "TAKE" when (isReftypeParam symtab: symtab ctx: ctx tid: fpid8) then {
                    ptra8 = true
                } else {
                    if ai8 < fpNames.length then {
                        fpn8: fpNames.get i: ai8
                        if (isBorrowStringParam symtab: symtab fid: fid pname: fpn8.stringview pid: fpid8) then {
                            ptra8 = true
                        }
                    }
                }
                if (ptra8) == false then {
                    if ai8 < fpNames.length then {
                        fpnL8: fpNames.get i: ai8
                        if (isListPtrParam symtab: symtab fid: fid pname: fpnL8.stringview tid: fpid8) then {
                            ptra8 = true
                        }
                    }
                }
                if ptra8 then {
                    if (isPtrVar ctx: ctx name: av9.stringview) == false then {
                        byref8 = true
                        argRef8 = emitByrefArg symtab: symtab ctx: ctx av: av9.stringview pid: fpid8
                    }
                }
            }
            if ai8 > 0 then {
                args.append ", "
            }
            if byref8 then {
                args.append argRef8.stringview
            } else {
                args.append av9.stringview
            }
            ai8 = ai8 + 1
        } else {}
    }
    e8: "\{fc}(\{args})"
    return e8
}

# emitCrossUnitCtor -- construction of a cross-unit record/class
# `unit.TypeName field: val ...` (e.g. a Node arm's zast.ErrorData payload):
# resolve the type via the shared cross-unit identity and route to the field-wise
# (or user-create) constructor. "" when not such a construction.
# dottedParentChild -- the middle segment of a 3-segment dotted path `a.b.c`:
# the child text of the parent (`b`). "" when not a nested dotted path.
dottedParentChild: function {n: Node} out String is {
    match (
        n
    ) case expression then {
        return (dottedParentChild n: n.expression)
    } case dottedpath then {
        return (dottedChildText n: n.parent)
    } else {
        return "".string
    }
}

# emitCrossUnitBareCreate -- a bare (no-arg) cross-unit construction
# `unit.Type.create` written as a dotted path (not a call): emit `<Type>_create()`
# (the user create, no receiver). "" when not such a 3-segment bare create.
emitCrossUnitBareCreate: function {symtab: zenv.ZSymbolTable ctx: Ctx parent: Node child: StringView} out String is {
    if child != "create" then {
        return "".string
    }
    pbase9: dottedBaseAtom n: parent
    ptype9: dottedChildText n: parent
    if pbase9.length == 0 then {
        return "".string
    }
    if ptype9.length == 0 then {
        return "".string
    }
    if (symtab.reg.isUnitName name: pbase9.stringview) == false then {
        return "".string
    }
    k9: "\{pbase9}.\{ptype9}".string
    go9: symtab.typing.resolved.get key: k9
    tid9: 0.u64
    match (
        go9
    ) case some then {
        tid9 = go9
    } case none then {}
    if tid9 == 0 then {
        return "".string
    }
    cco9: symtab.typing.childOf parentTypeId: tid9 name: "create"
    match (
        cco9
    ) case some then {
        if (symtab.reg.typetypeOf typeId: cco9) == ztypes.ztypetype.FUNCTION then {
            ccbn9: typeNameOfReg9 symtab: symtab tid: cco9
            ccb9: cnameOf tid: cco9 name: ccbn9.stringview
            return "\{ccb9}()"
        }
    } case none then {}
    return "".string
}

# emitCrossUnitExplicitCreate -- an explicit cross-unit construction
# `unit.Type.create args`: resolve `unit.Type` and emit the user `create` call
# `<Type>_create(args)` (no receiver). "" when not such a 3-segment create.
emitCrossUnitExplicitCreate: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    pbase: dottedBaseAtom n: call.callable
    ptype: dottedParentChild n: call.callable
    if pbase.length == 0 then {
        return "".string
    }
    if ptype.length == 0 then {
        return "".string
    }
    if (symtab.reg.isUnitName name: pbase.stringview) == false then {
        return "".string
    }
    k: "\{pbase}.\{ptype}".string
    go: symtab.typing.resolved.get key: k
    tid: 0.u64
    match (
        go
    ) case some then {
        tid = go
    } case none then {}
    if tid == 0 then {
        return "".string
    }
    cco: symtab.typing.childOf parentTypeId: tid name: "create"
    match (
        cco
    ) case some then {
        if (symtab.reg.typetypeOf typeId: cco) == ztypes.ztypetype.FUNCTION then {
            cpn: (List String)
            cpi: (List u64)
            recFieldLists symtab: symtab tid: cco names: cpn ids: cpi
            cargs: "".string
            ci: 0.u64
            ccn: cpn.length
            for while ci < ccn loop {
                cpname: cpn.get i: ci
                cav: ctorArgByLabel symtab: symtab ctx: ctx call: call label: cpname.stringview
                if ci > 0 then {
                    cargs.append ", "
                }
                cargs.append cav.stringview
                ci = ci + 1
            }
            ccbn: typeNameOfReg9 symtab: symtab tid: cco
            ccb: cnameOf tid: cco name: ccbn.stringview
            return "\{ccb}(\{cargs})"
        }
    } case none then {}
    return "".string
}

emitCrossUnitCtor: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    base: dottedBaseAtom n: call.callable
    child: dottedChildText n: call.callable
    if base.length == 0 then {
        return "".string
    }
    if child.length == 0 then {
        return "".string
    }
    if child.stringview == "create" then {
        ce9: emitCrossUnitExplicitCreate symtab: symtab ctx: ctx call: call
        if ce9.length > 0 then {
            return ce9
        }
    }
    if (symtab.reg.isUnitName name: base.stringview) == false then {
        return "".string
    }
    k: "\{base}.\{child}".string
    go: symtab.typing.resolved.get key: k
    tid: 0.u64
    match (
        go
    ) case some then {
        tid = go
    } case none then {}
    if tid == 0 then {
        return "".string
    }
    tt: symtab.reg.typetypeOf typeId: tid
    isRc: false
    if tt == ztypes.ztypetype.RECORD then {
        isRc = true
    }
    if tt == ztypes.ztypetype.CLASS then {
        isRc = true
    }
    if (isRc) == false then {
        return "".string
    }
    return (emitRecordCtor symtab: symtab ctx: ctx call: call tid: tid name: child.stringview)
}

# emitCrossUnitTag -- a 3-segment cross-unit variant/enum tag value
# `unit.Type.arm` (zlexer.TT.DOT, zast.err.BADREFERENCE): pbase=unit, ptype=Type,
# arm=arm. Resolve the variant via the shared cross-unit identity and emit the
# no-payload tag value. "" when not such a reference.
emitCrossUnitTag: function {symtab: zenv.ZSymbolTable ctx: Ctx pbase: StringView ptype: StringView arm: StringView} out String is {
    if pbase.length == 0 then {
        return "".string
    }
    if ptype.length == 0 then {
        return "".string
    }
    if arm.length == 0 then {
        return "".string
    }
    if (symtab.reg.isUnitName name: pbase) == false then {
        return "".string
    }
    k: "\{pbase}.\{ptype}".string
    go: symtab.typing.resolved.get key: k
    vtid: 0.u64
    match (
        go
    ) case some then {
        vtid = go
    } case none then {}
    if vtid == 0 then {
        return "".string
    }
    vtt: symtab.reg.typetypeOf typeId: vtid
    isTagged: false
    if vtt == ztypes.ztypetype.VARIANT then {
        isTagged = true
    }
    if vtt == ztypes.ztypetype.UNION then {
        isTagged = true
    }
    if (isTagged) == false then {
        return "".string
    }
    pc: armPayloadC symtab: symtab ctx: ctx tid: vtid arm: arm
    if pc.length == 0 then {
        tg: variantTag symtab: symtab tid: vtid arm: arm
        vn: typeNameOfReg9 symtab: symtab tid: vtid
        vc: cnameOf tid: vtid name: vn.stringview
        e: "((\{vc}_t){ .tag = \{tg} })"
        return e
    }
    return "".string
}

# emitCallValue -- the C expression for a call (the dispatch chain:
# dotted/list/typedef/data/record-ctor/type-qual/variant/user-fn).
# Shared by emitExpr's call arm and the statement-position call leg
# so neither clones the node (clones lose the type stamps).
emitCallValue: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    mcc: emitMetaCreateCall symtab: symtab ctx: ctx call: call
    if mcc.length > 0 then {
        return mcc
    }
    pdc: emitProtocolDispatch symtab: symtab ctx: ctx call: call
    if pdc.length > 0 then {
        return pdc
    }
    ioc: emitIoCall symtab: symtab ctx: ctx call: call
    if ioc.length > 0 then {
        return ioc
    }
    fmc: emitFileMethodCall symtab: symtab ctx: ctx call: call
    if fmc.length > 0 then {
        return fmc
    }
    clic: emitCliCall symtab: symtab ctx: ctx call: call
    if clic.length > 0 then {
        return clic
    }
    clisc: emitCliSpecCreate symtab: symtab ctx: ctx call: call
    if clisc.length > 0 then {
        return clisc
    }
    pmc: emitParsedMethodCall symtab: symtab ctx: ctx call: call
    if pmc.length > 0 then {
        return pmc
    }
    uic: emitUserIterCall symtab: symtab ctx: ctx call: call
    if uic.length > 0 then {
        return uic
    }
    osc: emitOsCall symtab: symtab ctx: ctx call: call
    if osc.length > 0 then {
        return osc
    }
    dc: emitDottedCall symtab: symtab ctx: ctx call: call
    if dc.length > 0 then {
        return dc
    }
    sam9: emitStringArgMethod symtab: symtab ctx: ctx call: call
    if sam9.length > 0 then {
        return sam9
    }
    lmc: emitListMethodCall symtab: symtab ctx: ctx call: call
    if lmc.length > 0 then {
        return lmc
    }
    smc: emitSetMethodCall symtab: symtab ctx: ctx call: call
    if smc.length > 0 then {
        return smc
    }
    mmc: emitMapMethodCall symtab: symtab ctx: ctx call: call
    if mmc.length > 0 then {
        return mmc
    }
    tdq: emitTypedefCreateCall symtab: symtab ctx: ctx call: call
    if tdq.length > 0 then {
        return tdq
    }
    pcc: emitProtocolCreateCall symtab: symtab ctx: ctx call: call
    if pcc.length > 0 then {
        return pcc
    }
    ddq: emitDataIndexCall symtab: symtab ctx: ctx call: call
    if ddq.length > 0 then {
        return ddq
    }
    cufc: emitCrossUnitFnCall symtab: symtab ctx: ctx call: call
    if cufc.length > 0 then {
        return cufc
    }
    cuct: emitCrossUnitCtor symtab: symtab ctx: ctx call: call
    if cuct.length > 0 then {
        return cuct
    }
    cn0: atomTextOf n: call.callable
    ecc9: emitEmptyColCreate symtab: symtab ctx: ctx call: call cn0: cn0.stringview
    if ecc9.length > 0 then {
        return ecc9
    }
    fid: userFnId symtab: symtab ctx: ctx name: cn0.stringview
    if fid > 0 when (symtab.reg.typetypeOf typeId: fid) == ztypes.ztypetype.RECORD then {
        return (emitRecordCtor symtab: symtab ctx: ctx call: call tid: fid name: cn0.stringview)
    }
    if fid > 0 when (symtab.reg.typetypeOf typeId: fid) == ztypes.ztypetype.CLASS then {
        return (emitRecordCtor symtab: symtab ctx: ctx call: call tid: fid name: cn0.stringview)
    }
    iwc: emitIoWrapperCreate symtab: symtab ctx: ctx call: call
    if iwc.length > 0 then {
        return iwc
    }
    ctc: emitColTypedefCall symtab: symtab ctx: ctx call: call
    if ctc.length > 0 then {
        return ctc
    }
    tq: emitTypeQualCall symtab: symtab ctx: ctx call: call
    if tq.length > 0 then {
        return tq
    }
    vq: emitVariantCtorCall symtab: symtab ctx: ctx call: call
    if vq.length > 0 then {
        return vq
    }
    uq: emitUnionCtor symtab: symtab ctx: ctx call: call
    if uq.length > 0 then {
        return uq
    }
    imc9: emitInstanceMethodCall symtab: symtab ctx: ctx call: call
    if imc9.length > 0 then {
        return imc9
    }
    if fid > 0 then {
        fc: cnameOf tid: fid name: cn0.stringview
        fpNames: (List String)
        fpIds: (List u64)
        recFieldLists symtab: symtab tid: fid names: fpNames ids: fpIds
        args: "".string
        ai8: 0.u64
        aiter: call.arguments.iterate
        for a: aiter loop {
            match (
                a
            ) case namedoperation then {
                av9: emitExpr symtab: symtab ctx: ctx n: a.operation
                byref8: false
                argRef8: "".string
                if ai8 < fpIds.length then {
                    fpid8: fpIds.get i: ai8
                    ptra8: false
                    ownC8: "".string
                    if ai8 < fpNames.length then {
                        fpnO8: fpNames.get i: ai8
                        ownC8 = symtab.typing.childOwnershipText parentTypeId: fid name: fpnO8.stringview
                    }
                    if ownC8.stringview != "TAKE" when (isReftypeParam symtab: symtab ctx: ctx tid: fpid8) then {
                        ptra8 = true
                    } else {
                        if ai8 < fpNames.length then {
                            fpn8: fpNames.get i: ai8
                            if (isBorrowStringParam symtab: symtab fid: fid pname: fpn8.stringview pid: fpid8) then {
                                ptra8 = true
                            }
                        }
                    }
                    if (ptra8) == false then {
                        if ai8 < fpNames.length then {
                            fpnL8: fpNames.get i: ai8
                            if (isListPtrParam symtab: symtab fid: fid pname: fpnL8.stringview tid: fpid8) then {
                                ptra8 = true
                            }
                        }
                    }
                    if ptra8 then {
                        if (isPtrVar ctx: ctx name: av9.stringview) == false then {
                            byref8 = true
                            argRef8 = emitByrefArg symtab: symtab ctx: ctx av: av9.stringview pid: fpid8
                        }
                    }
                }
                if ai8 > 0 then {
                    args.append ", "
                }
                if byref8 then {
                    args.append argRef8.stringview
                } else {
                    args.append av9.stringview
                }
                ai8 = ai8 + 1
            } else {}
        }
        e8: "\{fc}(\{args})"
        return e8
    } else {
        if cn0.stringview == "stringJoin" then {
            needsAdd ctx: ctx name: "coll_join"
            sjargs9: "".string
            sji9: 0.u64
            with sjiter9: call.arguments.iterate do for sja9: sjiter9 loop {
                match (
                    sja9
                ) case namedoperation then {
                    if sji9 > 0 then {
                        sjargs9.append ", "
                    }
                    sjv9: emitExpr symtab: symtab ctx: ctx n: sja9.operation
                    sjargs9.append sjv9.stringview
                    sji9 = sji9 + 1
                } else {}
            }
            return "z_stringJoin(\{sjargs9})"
        }
        m8: "/* zemitterc: unhandled callee \{cn0} */0"
        return m8
    }
}

# emitStringMethod -- a String value-context method call. String is a native
# singleton whose struct + methods emit once under ctx.strC; dispatch by name so
# the cname is canonical (not a per-shell receiver id). `recv` is the receiver C
# expression; recvIsPtr picks `->`/no-`&`. "" for an unrecognized method.
emitStringMethod: function {ctx: Ctx recv: StringView recvIsPtr: bool mn: StringView} out String is {
    if mn == "copy" then {
        if recvIsPtr then {
            return "\{ctx.strC}_copy(\{recv})"
        }
        return "\{ctx.strC}_copy(&\{recv})"
    }
    if mn == "string" then {
        if recvIsPtr then {
            return "\{ctx.strC}_copy(\{recv})"
        }
        return "\{ctx.strC}_copy(&\{recv})"
    }
    if mn == "length" then {
        if recvIsPtr then {
            return "\{recv}->size"
        }
        return "\{recv}.size"
    }
    if mn == "capacity" then {
        if recvIsPtr then {
            return "\{recv}->capacity"
        }
        return "\{recv}.capacity"
    }
    if mn == "stringview" then {
        return (svValueForm ctx: ctx expr: recv tname: "String")
    }
    if mn == "shrink" then {
        if recvIsPtr then {
            return "\{ctx.strC}_shrink(\{recv})"
        }
        return "\{ctx.strC}_shrink(&\{recv})"
    }
    return "".string
}

# emitExpr -- the C expression text for a node (calls inline; the scalar
# examples carry no order-sensitive multi-call arguments).
emitExpr: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out String is {
    cv9: nodeConstText symtab: symtab nid: (nodeIdOf9 n: n)
    if cv9.length > 0 then {
        return cv9
    }
    match (
        n
    ) case expression then {
        return (emitExpr symtab: symtab ctx: ctx n: n.expression)
    } case statementline then {
        return (emitExpr symtab: symtab ctx: ctx n: n.statementline)
    } case statement then {
        if n.statements.length == 1 then {
            s0: n.statements.get i: 0
            return (emitExpr symtab: symtab ctx: ctx n: s0)
        }
        return "/* zemitterc: unhandled expr */0".string
    } case atomid then {
        av: n.name.stringview
        ac: av.string
        cgo: ctx.constVals.get key: ac
        match (
            cgo
        ) case some then {
            cvv: cgo.stringview
            cvc: cvv.string
            return cvc
        } case none then {}
        brid: userFnId symtab: symtab ctx: ctx name: av
        if brid > 0 when (symtab.reg.typetypeOf typeId: brid) == ztypes.ztypetype.RECORD then {
            btn: typeNameOfReg9 symtab: symtab tid: brid
            if (cTypeOf name: btn.stringview).length > 0 then {
                bsv: btn.stringview

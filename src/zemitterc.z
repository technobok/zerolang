            if mn2.stringview == "iterateItems" then return "\{nmpcb9}_iterateItems(\{base9})"
        }
        if nlid9 > 0 then {
            nrtt9: symtab.reg.typetypeOf typeId: nlid9
            nDisp9: false
            if nrtt9 == ztypes.ztypetype.classType then nDisp9 = true
            if nrtt9 == ztypes.ztypetype.recordType then nDisp9 = true
            if nDisp9 then {
                nlidM9: methodOwnerId :ast :symtab :ctx rtid: nlid9 mn: mn2.stringview
                nmco9: (symtab.typing.childOf
                    pool: ast.names
                    parentTypeId: nlidM9
                    name: mn2.stringview
                )
                match (
                    nmco9
                ) case some then {
                    if (symtab.reg.typetypeOf typeId: nmco9) == ztypes.ztypetype.functionType then {
                        # no-arg SV natives on a nested stringy base: the
                        # canonical native symbol, not the method-id cname
                        if (isSvNoArgNative name: mn2.stringview) when (isStringyTid
                            :ctx
                            tid: nlid9
                        ) then {
                            needsAdd :ctx name: mn2.stringview
                            svfn9: (svValueForm
                                :ctx
                                expr: base9.stringview
                                isStr: nlid9 == ctx.strTid
                            )
                            return "\{ctx.svC}_\{mn2}(&\{svfn9})"
                        }
                        nmc9: symtab.reg.cnameOf tid: nmco9
                        nrttM9: symtab.reg.typetypeOf typeId: nlidM9
                        nmrecv9: "\{base9}"
                        if nrttM9 == ztypes.ztypetype.classType then {
                            dpu9: ast.nodes.get i: (n.parent - 1).u64
                            if (pathIsPointer :ast :symtab :ctx n: dpu9) == false then {
                                nmrecv9 = "&\{base9}"
                            }
                        }
                        return "\{nmc9}(\{nmrecv9})"
                    }
                } case none then null
            }
        }
        # a Map/Set-typed base is a heap pointer regardless of how it was
        # reached (a field path fails pathIsPointer's lock-field test)
        nstPtr9: pathIsPointer :ast :symtab :ctx n: (ast.nodes.get i: (n.parent - 1).u64)
        if nstPtr9 == false then nstPtr9 = isHeapPtrCollection :ast :symtab :ctx tid: nlid9
        if nstPtr9 then {
            ep9: "\{base9}->\{mn2}"
            return ep9
        } else {
            ed9: "\{base9}.\{mn2}"
            return ed9
        }
    } case atomstring then {
        li9: litIndexOf :ctx nid: n.nodeid.u64
        if li9 > 0 then {
            se9: "_zs\{li9}"
            return se9
        }
        return "/* zemitterc: unhandled atomstring expr */0".string
    } case ifexpr then {
        tx: String
        depth: u64
        citer: n.clauses.iterate
        for cId9: citer loop {
            c9r: ast.nodes.get i: (cId9 - 1).u64
            cx: ternaryClause :ast :symtab :ctx c: c9r
            tx.append cx.stringview
            depth = depth + 1
        }
        ex9: ternaryElse :ast :symtab :ctx oId: n.elseclause
        tx.append ex9.stringview
        dk: u64
        for dk < depth loop {
            tx.append ")"
            dk = dk + 1
        }
        return tx
    } case binop then {
        l: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (n.lhs - 1).u64)
        op: atomTextOf :ast n: (ast.nodes.get i: (n.operator - 1).u64)
        r: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (n.rhs - 1).u64)
        if (nodeIsAtomBox
            :ast
            :symtab
            :ctx
            n: (ast.nodes.get i: (n.lhs - 1).u64)
        ) then l = "(*\{l})"
        if (nodeIsAtomBox
            :ast
            :symtab
            :ctx
            n: (ast.nodes.get i: (n.rhs - 1).u64)
        ) then r = "(*\{r})"
        if (isCompareOp name: op.stringview) then {
            lt: stampNameDeep :ast :symtab n: (ast.nodes.get i: (n.lhs - 1).u64)
            lti: userFnId :ast :symtab :ctx name: lt.stringview
            if lti == 0 then {
                ltSc9: cTypeOf name: lt.stringview
                if ltSc9.length == 0 then {
                    if (isStringy name: lt.stringview) == false then {
                        lti = resolveTypeIdByName :ast :symtab :ctx name: lt.stringview
                    }
                }
            }
            if lti > 0 when (symtab.reg.typetypeOf typeId: lti) == ztypes.ztypetype.recordType then {
                rce: symtab.reg.cnameOf tid: lti
                if op.stringview == "==" then {
                    re1: "\{rce}_eq(\{l}, \{r})"
                    return re1
                }
                if op.stringview == "!=" then {
                    re2: "!\{rce}_eq(\{l}, \{r})"
                    return re2
                }
            }
            if lti > 0 when (symtab.reg.typetypeOf typeId: lti) == ztypes.ztypetype.variantType then {
                vce: symtab.reg.cnameOf tid: lti
                if op.stringview == "==" then {
                    ee1: "\{vce}_eq(\{l}, \{r})"
                    return ee1
                }
                if op.stringview == "!=" then {
                    ee2: "!\{vce}_eq(\{l}, \{r})"
                    return ee2
                }
            }
            if (isStringy name: lt.stringview) then {
                rt: stampNameDeep :ast :symtab n: (ast.nodes.get i: (n.rhs - 1).u64)
                ltIsStr9: lt.stringview == "String"
                rtIsStr9: rt.stringview == "String"
                lf: svValueForm :ctx expr: l.stringview isStr: ltIsStr9
                rf: svValueForm :ctx expr: r.stringview isStr: rtIsStr9
                if op.stringview == "==" then {
                    eq1: "\{ctx.svC}_eq(\{lf}, \{rf})"
                    return eq1
                }
                if op.stringview == "!=" then {
                    eq2: "!\{ctx.svC}_eq(\{lf}, \{rf})"
                    return eq2
                }
                cm1: "(\{ctx.svC}_cmp(\{lf}, \{rf}) \{op} 0)"
                return cm1
            }
        }
        e9: "(\{l} \{op} \{r})"
        return e9
    } case call then {
        return (emitCallValue :ast :symtab :ctx call: n)
    } else {
        return "/* zemitterc: unhandled expr */0".string
    }
}

# emitInterpPrint -- the interpolated-print temp chain: create, per-part
# append (literal bytes or snprintf-formatted scalar), print, free.
emitInterpPrint: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    parts: List u32
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    sN: emitInterpBuild :ast :symtab :ctx :parts :ind :tmp :buf
    l1: "\{ind}\{ctx.strC}_print(&_s\{sN});\n"
    buf.append l1.stringview
    l2: "\{ind}\{ctx.strC}_free(&_s\{sN});\n"
    buf.append l2.stringview
}

# emitInterpBuild -- the create/append chain for an interpolated literal;
# returns the _sN temp index (caller prints/frees or binds it).
emitInterpBuild: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    parts: List u32
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} out u64 is {
    est: u64
    with piter: parts.iterate do for pId9: piter loop {
        p: ast.nodes.get i: (pId9 - 1).u64
        isC: false
        match (
            p
        ) case stringchunk then {
            isC = true
            tl: p.text.length
            est = est + tl
        } else null
        if (isC) == false then est = est + 16
    }
    sN: tmp.next
    l0: "\{ind}\{ctx.strC}_t _s\{sN} = \{ctx.strC}_create((uint64_t)\{est});\n"
    buf.append l0.stringview
    qiter: parts.iterate
    for qId9: qiter loop {
        emitInterpPart :ast :symtab :ctx n: (ast.nodes.get i: (qId9 - 1).u64) :sN :ind :tmp :buf
    }
    return sN
}

numericFormatName: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    tn: StringView
} out String is {
    mrk: tn.string
    mro: ctx.methodReturns.get key: mrk
    match (
        mro
    ) case some then {
        mrv: mro.stringview
        return (numericFormatName :ast :symtab :ctx tn: mrv)
    } case none then null
    if (isIntName name: tn) then {
        r0: tn.string
        return r0
    }
    if (isFloatName name: tn) then {
        r1: tn.string
        return r1
    }
    tid: userFnId :ast :symtab :ctx name: tn
    if tid > 0 then {
        bc: typedefChaseC :ast :symtab :ctx :tid
        if bc.stringview == "double" then {
            return "f64".string
        } else if bc.stringview == "float" then {
            return "f32".string
        } else if bc.length > 0 then return "i64".string
    }
    rr: tn.string
    return rr
}

dataIndexElemName: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
} out String is {
    match (
        n
    ) case expression then {
        return (dataIndexElemName :ast :symtab :ctx n: (ast.nodes.get i: (n.expression - 1).u64))
    } case call then {
        mn: dottedChildText :ast n: (ast.nodes.get i: (n.callable - 1).u64)
        if mn.stringview == "index" then {
            bn: dottedBaseAtom :ast n: (ast.nodes.get i: (n.callable - 1).u64)
            dk: bn.copy
            go: ctx.dataElems.get key: dk
            match (
                go
            ) case some then {
                gv: go.stringview
                gc: gv.string
                return gc
            } case none then null
        }
        return "".string
    } else {
        return "".string
    }
}

# interpBaseIsMapEntry -- true when an interp part is `<entry>.key`/`.value`
# off a borrowed MapEntry: the projected String views the bucket, so it must
# be appended inline (freeing the hoisted copy would double-free the bucket key).
interpBaseIsMapEntry: function {ast: Ast symtab: zenv.ZSymbolTable n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (interpBaseIsMapEntry :ast :symtab n: (ast.nodes.get i: (n.expression - 1).u64))
    } case statementline then {
        return (interpBaseIsMapEntry :ast :symtab n: (ast.nodes.get i: (n.statementline - 1).u64))
    } case dottedpath then {
        bnid: atomNodeId9 n: (ast.nodes.get i: (n.parent - 1).u64)
        bt: stampIdOf :symtab nid: bnid
        bo: monoOriginName :symtab tid: bt
        meT9: builtinTid :ast :symtab base: "MapEntry"
        if (originIsTid :symtab tid: bt originTid: meT9) then return true
        return false
    } else {
        return false
    }
}

# interpBaseIsOwnedStructField -- a `<inst>.field` read off a user record/class:
# the projected String VIEWS the owner's field (freed by the owner's destructor),
# so it appends inline -- freeing a hoisted copy would double-free the field.
interpBaseIsOwnedStructField: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    n: Node
} out bool is {
    match (
        n
    ) case expression then {
        iex39: ast.nodes.get i: (n.expression - 1).u64
        return (interpBaseIsOwnedStructField :ast :symtab n: iex39)
    } case statementline then {
        sln9: ast.nodes.get i: (n.statementline - 1).u64
        return (interpBaseIsOwnedStructField :ast :symtab n: sln9)
    } case dottedpath then {
        bnid: atomNodeId9 n: (ast.nodes.get i: (n.parent - 1).u64)
        bt: stampIdOf :symtab nid: bnid
        bo: monoOriginName :symtab tid: bt
        # a user-generic mono owns its fields once it carries a destructor;
        # other monos (views, collections) keep the owned-call-result legs
        if bo.length != 0 then {
            if (symtab.reg.hasDestructorName typeId: bt) == false then return false
        }
        btt: symtab.reg.typetypeOf typeId: bt
        isUC: false
        if btt == ztypes.ztypetype.recordType then isUC = true
        if btt == ztypes.ztypetype.classType then isUC = true
        if (isUC) == false then return false
        cn: atomTextOf :ast n: (ast.nodes.get i: (n.child - 1).u64)
        co: symtab.typing.childOf pool: ast.names parentTypeId: bt name: cn.stringview
        match (
            co
        ) case some then {
            if (symtab.reg.typetypeOf typeId: co) == ztypes.ztypetype.functionType then {
                return false
            } else {
                return true
            }
        } case none then {
            return false
        }
    } else {
        return false
    }
}

emitInterpPart: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    n: Node
    sN: u64
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    match (
        n
    ) case stringchunk then {
        tv: n.text.stringview
        esc: cEscape text: tv
        l3: "\{ind}\{ctx.strC}_append(&_s\{sN}, \"\{esc}\", sizeof(\"\{esc}\")-1);\n"
        buf.append l3.stringview
    } else {
        di0: dataIndexElemName :ast :symtab :ctx :n
        tn0: stampNameDeep :ast :symtab :n
        tn: numericFormatName :ast :symtab :ctx tn: tn0.stringview
        if di0.length > 0 then tn = di0
        val: emitExpr :ast :symtab :ctx :n
        # a call fragment may have hoisted non-lvalue args to _ah temps:
        # declare them before the fragment uses them (mirrors the direct
        # print path's flush after emitCallValue)
        flushArgHoists :ctx :ind :tmp :buf
        bN: tmp.next
        if (isIntName name: tn.stringview) then {
            l4: "\{ind}char _b\{bN}[32]; int _b\{bN}_n = snprintf(_b\{bN}, 32, \"%ld\", (long)(int64_t)\{val});\n"
            buf.append l4.stringview
            l5: "\{ind}\{ctx.strC}_append(&_s\{sN}, _b\{bN}, (uint64_t)_b\{bN}_n);\n"
            buf.append l5.stringview
        } else if (isFloatName name: tn.stringview) then {
            l6: "\{ind}char _b\{bN}[64]; int _b\{bN}_n = snprintf(_b\{bN}, 64, \"%g\", (double)\{val});\n"
            buf.append l6.stringview
            l7: "\{ind}\{ctx.strC}_append(&_s\{sN}, _b\{bN}, (uint64_t)_b\{bN}_n);\n"
            buf.append l7.stringview
        } else if tn.stringview == "StringView" then {
            # by-value operand today; a pointer-passed SV would need the
            # String leg's accessor treatment below
            lsv: "\{ind}\{ctx.strC}_append(&_s\{sN}, \{val}.data, \{val}.length);\n"
            buf.append lsv.stringview
        } else if tn.stringview == "String" then {
            isAtomP: false
            an0: atomTextDeep :ast :n
            if an0.length > 0 then isAtomP = true
            if (interpBaseIsMapEntry :ast :symtab :n) then isAtomP = true
            if (interpBaseIsOwnedStructField :ast :symtab :n) then isAtomP = true
            if isAtomP then {
                # a borrowed String param is a pointer (isBorrowStringParam
                # registers the raw name); compound bases (map-entry deref,
                # owned struct field) have an0 == "" and keep the value form
                sAcc9: ".".string
                if an0.length > 0 when (isPtrVar :ctx name: an0.stringview) then sAcc9 = "->".string
                lss: "\{ind}\{ctx.strC}_append(&_s\{sN}, \{val}\{sAcc9}data, \{val}\{sAcc9}size);\n"
                buf.append lss.stringview
            } else if (hoistExprIsBorrowRooted :ast :symtab :ctx :n) then {
                # borrow-returning call result (a shared element view): hoist
                # for single evaluation and append -- the container owns the
                # storage, so no free (the MapEntry exemption, generalized by
                # the declared signature).
                hN: tmp.next
                lh0: "\{ind}\{ctx.strC}_t _h\{hN} = \{val};\n"
                buf.append lh0.stringview
                lh1: "\{ind}\{ctx.strC}_append(&_s\{sN}, _h\{hN}.data, _h\{hN}.size);\n"
                buf.append lh1.stringview
            } else {
                # owned call result: hoist, append, free
                hN: tmp.next
                lh0: "\{ind}\{ctx.strC}_t _h\{hN} = \{val};\n"
                buf.append lh0.stringview
                lh1: "\{ind}\{ctx.strC}_append(&_s\{sN}, _h\{hN}.data, _h\{hN}.size);\n"
                buf.append lh1.stringview
                lh2: "\{ind}\{ctx.strC}_free(&_h\{hN});\n"
                buf.append lh2.stringview
            }
        } else {
            pStrId9: stampIdOf :symtab nid: (nodeIdOf9 :n)
            pStrOr9: monoOriginName :symtab tid: pStrId9
            if (originIsTid :symtab tid: pStrId9 originTid: ctx.strOriginTid) then {
                lstri9: "\{ind}\{ctx.strC}_append(&_s\{sN}, \{val}.data, \{val}.len);\n"
                buf.append lstri9.stringview
            } else {
                l8: "\{ind}/* zemitterc: unhandled interp part type \{tn} */\n"
                buf.append l8.stringview
            }
        }
    }
}

# nodeIdOf9 -- the nodeid of expression-ish shapes used by interp parts.
nodeIdOf9: function {n: Node} out u64 is {
    match (
        n
    ) case expression then {
        return n.nodeid.u64
    } case atomid then {
        return n.nodeid.u64
    } case labelvalue then {
        return n.nodeid.u64
    } case call then {
        return n.nodeid.u64
    } case binop then {
        return n.nodeid.u64
    } case dottedpath then {
        return n.nodeid.u64
    } case atomstring then {
        return n.nodeid.u64
    } else {
        return 0
    }
}

# stampNameDeep -- a node's stamped type name, peeling expression
# wrappers when the wrapper itself is unstamped.
# methodReturnByName -- given a "Base.member" method name, resolve the
# base type's member child and return its return-type name ("" if not).
methodReturnByName: function {ast: Ast symtab: zenv.ZSymbolTable dotted: StringView} out String is {
    base: String
    member: String
    seenDot: false
    di: u64
    dn: dotted.length
    for di < dn loop {
        bo0: dotted.byteAt i: di
        match (
            bo0
        ) case some then {
            if bo0 == 46 then {
                seenDot = true
            } else {
                if seenDot then {
                    member.appendByte b: bo0
                } else {
                    base.appendByte b: bo0
                }
            }
        } case none then null
        di = di + 1
    }
    if (seenDot) == false then return "".string
    # scan for a parent type named `base` that actually declares the
    # `member` child (a typedef has both a shell and a canonical id;
    # only the canonical bears children).
    pids: (List u64)
    cids: (List u64)
    with citer: symtab.typing.typeChild.iterate do for tc: citer loop {
        cnBe9: ast.names.texts.get i: (tc.nameId - 1).u64
        if cnBe9.stringview == member.stringview then {
            cto: symtab.typing.childTypeById.get key: tc.childNameId
            match (
                cto
            ) case some then {
                pv9: tc.parentTypeId
                pids.append pv9
                cv9: cto
                cids.append cv9
            } case none then null
        }
    }
    found: u64
    si: u64
    sn: pids.length
    for si < sn loop {
        pid: pids.get i: si
        pn: typeNameOfReg9 :symtab tid: pid
        if pn.stringview == base.stringview when found == 0 then found = cids.get i: si
        si = si + 1
    }
    if found > 0 then {
        rt2: fnReturnTidOf :symtab tid: found
        if rt2 > 0 then return (typeNameOfReg9 :symtab tid: rt2)
    }
    return "".string
}

stampNameDeep: function {ast: Ast symtab: zenv.ZSymbolTable n: Node} out String is {
    nid: nodeIdOf9 :n
    sid: stampIdOf :symtab :nid
    if sid > 0 then {
        # a value-position FUNCTION stamp is an auto-call; its value
        # type is the method's return.
        if (symtab.reg.typetypeOf typeId: sid) == ztypes.ztypetype.functionType then {
            rto: fnReturnTidOf :symtab tid: sid
            if rto > 0 then return (typeNameOfReg9 :symtab tid: rto)
            rno9: symtab.typing.funcReturnNode.get key: sid
            match (
                rno9
            ) case some then {
                rrt9: stampIdOf :symtab nid: rno9
                if rrt9 > 0 then return (typeNameOfReg9 :symtab tid: rrt9)
            } case none then null
            # a shell FUNCTION named "Base.member": resolve the method
            # through the base type's child and read its return.
            fnm: typeNameOfReg9 :symtab tid: sid
            rmn: methodReturnByName :ast :symtab dotted: fnm.stringview
            if rmn.length > 0 then return rmn
        }
        return (typeNameOfReg9 :symtab tid: sid)
    }
    match (
        n
    ) case expression then {
        return (stampNameDeep :ast :symtab n: (ast.nodes.get i: (n.expression - 1).u64))
    } else {
        return "".string
    }
}

# emitPrintStmt -- a statement-position print call.
emitPrintStmt: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    ind: StringView
    tmp: TmpCtr
    buf: String.borrow
} is {
    emitted: false
    aiter: call.arguments.iterate
    for aId9: aiter loop {
        a: ast.nodes.get i: (aId9 - 1).u64
        match (
            a
        ) case namedoperation then {
            if (emitted) == false then {
                emitted = true
                (emitPrintArg
                    :ast
                    :symtab
                    :ctx
                    n: (ast.nodes.get i: (a.operation - 1).u64)
                    :ind
                    :tmp
                    :buf
                )
            }
        } else null
    }
    if (emitted) == false then buf.append "    /* zemitterc: print with no argument */\n"
}

# cfold -- an emit-time integer fold result.
cfold: record {
    ok: bool
    val: i64
}

# evalConstI64 -- best-effort integer fold of an expression at emit time:
# int literals, unit constants whose pre-rendered C text is a plain integer,
# and arithmetic/comparison binops over folded operands. ok=false when any
# part is not provably constant.
evalConstI64: function {ast: Ast ctx: Ctx n: Node} out cfold is {
    match (
        n
    ) case expression then {
        return (evalConstI64 :ast :ctx n: (ast.nodes.get i: (n.expression - 1).u64))
    } case atomid then {
        atC9: ast.names.texts.get i: (n.name - 1).u64
        at9: atC9.stringview
        pl9: at9.parseI64
        match (
            pl9
        ) case ok then {
            return (cfold ok: true val: pl9)
        } case err then null
        cg9: ctx.constVals.getv key: at9
        match (
            cg9
        ) case some then {
            cgv9: cg9.stringview
            pc9: cgv9.parseI64
            match (
                pc9
            ) case ok then {
                return (cfold ok: true val: pc9)
            } case err then null
        } case none then null
        return (cfold ok: false val: 0)
    } case binop then {
        lf9: evalConstI64 :ast :ctx n: (ast.nodes.get i: (n.lhs - 1).u64)
        rf9: evalConstI64 :ast :ctx n: (ast.nodes.get i: (n.rhs - 1).u64)
        if lf9.ok when rf9.ok then {
            opt9: atomTextOf :ast n: (ast.nodes.get i: (n.operator - 1).u64)
            ops9: opt9.stringview
            if ops9 == "+" then return (cfold ok: true val: lf9.val + rf9.val)
            if ops9 == "-" then return (cfold ok: true val: lf9.val - rf9.val)
            if ops9 == "*" then return (cfold ok: true val: lf9.val * rf9.val)
            cb9: false
            hit9: false
            if ops9 == "==" then {
                cb9 = lf9.val == rf9.val
                hit9 = true
            } else if ops9 == "!=" then {
                cb9 = lf9.val != rf9.val
                hit9 = true
            } else if ops9 == "<" then {
                cb9 = lf9.val < rf9.val
                hit9 = true
            } else if ops9 == "<=" then {
                cb9 = lf9.val <= rf9.val
                hit9 = true
            } else if ops9 == ">" then {
                cb9 = lf9.val > rf9.val
                hit9 = true
            } else if ops9 == ">=" then {
                cb9 = lf9.val >= rf9.val
                hit9 = true
            }
            if hit9 then {
                if cb9 then return (cfold ok: true val: 1)
                return (cfold ok: true val: 0)
            }
        }
        return (cfold ok: false val: 0)
    } else {
        return (cfold ok: false val: 0)
    }
}

# foldIfClause9 -- fold every plain (non-binding) condition of an ifclause;
# ok only when all fold, val 1 when all are true.
foldIfClause9: function {ast: Ast ctx: Ctx conds: List u32} out cfold is {
    tv9: 1
    with citer: conds.iterate do for cid9: citer loop {
        c9: ast.nodes.get i: (cid9 - 1).u64
        match (
            c9
        ) case namedoperation then {
            cl9: zast.nameTextCopy :ast ref: c9.name
            clv9: cl9.stringview
            if clv9.length > 0 when clv9 != "when" then return (cfold ok: false val: 0)
            f9: evalConstI64 :ast :ctx n: (ast.nodes.get i: (c9.operation - 1).u64)
            if f9.ok == false then return (cfold ok: false val: 0)
            if f9.val == 0 then tv9 = 0
        } else {
            return (cfold ok: false val: 0)
        }
    }
    return (cfold ok: true val: tv9)
}

# plainStringLiteral9 -- the text of a single-chunk string literal (through
# expression wrappers); "" for interpolated or non-literal expressions.
plainStringLiteral9: function {ast: Ast n: Node} out String is {
    match (
        n

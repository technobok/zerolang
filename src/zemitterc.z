            ) case namedoperation then {
                av9: emitExpr symtab: symtab ctx: ctx n: a.operation
                byref8: false
                if ai8 < fpIds.length then {
                    fpid8: fpIds.get i: ai8
                    ptra8: false
                    if (isReftypeParam symtab: symtab ctx: ctx tid: fpid8) then {
                        ptra8 = true
                    } else {
                        if ai8 < fpNames.length then {
                            fpn8: fpNames.get i: ai8
                            if (isBorrowStringParam symtab: symtab fid: fid pname: fpn8.stringview pid: fpid8) then {
                                ptra8 = true
                            } else {}
                        } else {}
                    }
                    if ptra8 then {
                        if (isPtrVar ctx: ctx name: av9.stringview) then {} else {
                            byref8 = true
                        }
                    } else {}
                } else {}
                if ai8 > 0.u64 then {
                    args.append ", "
                } else {}
                if byref8 then {
                    ab8: "&\{av9}"
                    args.append ab8.stringview
                } else {
                    args.append av9.stringview
                }
                ai8 = ai8 + 1.u64
            } else {}
        }
        e8: "\{fc}(\{args})"
        return e8
    } else {
        m8: "/* zemitterc: unhandled callee \{cn0} */0"
        return m8
    }
}

# emitStringMethod -- a String value-context method call. String is a native
# singleton whose struct + methods emit once under ctx.strC; dispatch by name so
# the cname is canonical (not a per-shell receiver id). `recv` is the receiver C
# expression; recvIsPtr picks `->`/no-`&`. "" for an unrecognized method.
emitStringMethod: function {ctx: Ctx recv: StringView recvIsPtr: bool mn: StringView} out String is {
    if mn == "copy" then {
        if recvIsPtr then {
            return "\{ctx.strC}_copy(\{recv})"
        } else {}
        return "\{ctx.strC}_copy(&\{recv})"
    } else {}
    if mn == "length" then {
        if recvIsPtr then {
            return "\{recv}->size"
        } else {}
        return "\{recv}.size"
    } else {}
    if mn == "capacity" then {
        if recvIsPtr then {
            return "\{recv}->capacity"
        } else {}
        return "\{recv}.capacity"
    } else {}
    if mn == "stringview" then {
        return (svValueForm ctx: ctx expr: recv tname: "String")
    } else {}
    if mn == "shrink" then {
        if recvIsPtr then {
            return "\{ctx.strC}_shrink(\{recv})"
        } else {}
        return "\{ctx.strC}_shrink(&\{recv})"
    } else {}
    return "".string
}

# emitExpr -- the C expression text for a node (calls inline; the scalar
# examples carry no order-sensitive multi-call arguments).
emitExpr: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out String is {
    cv9: nodeConstText symtab: symtab nid: (nodeIdOf9 n: n)
    if cv9.length > 0.u64 then {
        return cv9
    } else {}
    match (
        n
    ) case expression then {
        return (emitExpr symtab: symtab ctx: ctx n: n.expression)
    } case statementline then {
        return (emitExpr symtab: symtab ctx: ctx n: n.statementline)
    } case statement then {
        if n.statements.length == 1.u64 then {
            s0: n.statements.get i: 0.u64
            return (emitExpr symtab: symtab ctx: ctx n: s0)
        } else {}
        return "/* zemitterc: unhandled expr */0".string
    } case atomid then {
        av: n.name.stringview
        ac: av.string
        cgo: ctx.constVals.get key: ac
        match (
            cgo
        ) case some then {
            cvv: cgo.stringview
            cvc: cvv.string
            return cvc
        } case none then {}
        brid: userFnId symtab: symtab ctx: ctx name: av
        if brid > 0.u64 when (symtab.reg.typetypeOf typeId: brid) == ztypes.ztypetype.RECORD then {
            btn: typeNameOfReg9 symtab: symtab tid: brid
            if (cTypeOf name: btn.stringview).length > 0.u64 then {
                bsv: btn.stringview
                bsc: bsv.string
                return bsc
            } else {}
            brc: cnameOf tid: brid name: btn.stringview
            be0: "((\{brc}_t){0})"
            return be0
        } else {}
        ac2: aliasResolve ctx: ctx name: av
        return ac2
    } case labelvalue then {
        lvn9: n.name.stringview
        return (aliasResolve ctx: ctx name: lvn9)
    } case dottedpath then {
        mnc0: atomTextOf n: n.child
        if mnc0.stringview == "string" then {
            scl: bindLitIndex symtab: symtab ctx: ctx n: n.parent
            if scl > 0.u64 then {
                se0: "\{ctx.strC}_from_view(_zs\{scl})"
                return se0
            } else {}
        } else {}
        bn2r: atomTextOf n: n.parent
        bn2: aliasResolve ctx: ctx name: bn2r.stringview
        mn2: atomTextOf n: n.child
        if bn2r.stringview == "io" then {
            isStdS9: false
            if mn2.stringview == "stdout" then {
                isStdS9 = true
            } else {}
            if mn2.stringview == "stderr" then {
                isStdS9 = true
            } else {}
            if mn2.stringview == "stdin" then {
                isStdS9 = true
            } else {}
            if isStdS9 then {
                needsAdd ctx: ctx name: "io"
                sname9: "io_\{mn2}".string
                needsAdd ctx: ctx name: sname9.stringview
                return "z_io_\{mn2}()"
            } else {}
        } else {}
        if bn2r.stringview == "os" then {
            if (isOsNoArgFn name: mn2.stringview) then {
                needsAdd ctx: ctx name: "os"
                osn9: "os_\{mn2}".string
                needsAdd ctx: ctx name: osn9.stringview
                return "z_os_\{mn2}()".string
            } else {}
        } else {}
        # `.private` is a compile-time friend marker -- it emits the receiver itself.
        if mn2.stringview == "private" then {
            return (emitExpr symtab: symtab ctx: ctx n: n.parent)
        } else {}
        # `.lock` on a value is a borrow marker (no type has a literal `lock`
        # field); emit the base, which the borrow param then addresses.
        if mn2.stringview == "lock" then {
            return (emitExpr symtab: symtab ctx: ctx n: n.parent)
        } else {}
        # `.take` on a heap reftype (String / union / by-value class) is an
        # ownership MOVE: emit the base value. The statement-level emitter zeroes
        # the source after the call so its scope-exit free is a no-op (the callee
        # now owns the heap). A borrowed pointer-param class is not a move source.
        if mn2.stringview == "take" then {
            tknid9: atomNodeId9 n: n.parent
            tkt9: stampIdOf symtab: symtab nid: tknid9
            tktn9: stampNameOf symtab: symtab nid: tknid9
            isMove9: false
            if tktn9.stringview == "String" then {
                isMove9 = true
            } else {}
            if (symtab.reg.typetypeOf typeId: tkt9) == ztypes.ztypetype.UNION then {
                isMove9 = true
            } else {}
            if (symtab.reg.typetypeOf typeId: tkt9) == ztypes.ztypetype.CLASS then {
                tkbn9: atomTextOf n: n.parent
                if (isPtrVar ctx: ctx name: tkbn9.stringview) then {} else {
                    isMove9 = true
                }
            } else {}
            if isMove9 then {
                return (emitExpr symtab: symtab ctx: ctx n: n.parent)
            } else {}
        } else {}
        if (cTypeOf name: mn2.stringview).length > 0.u64 then {
            # runtime numeric conversion `<expr>.<numtype>` -> a C cast (checked
            # on narrowing). Works for any base (atom or compound binop/dotted);
            # folded literal conversions return earlier via nodeConstText.
            ncSrc9: stampNameOf symtab: symtab nid: (nodeIdOf9 n: n.parent)
            ncVal9: emitExpr symtab: symtab ctx: ctx n: n.parent
            return (emitNumericCast srcName: ncSrc9.stringview dstName: mn2.stringview val: ncVal9.stringview)
        } else {}
        if bn2.length > 0.u64 then {
            # typed numeric literal (3.u64): the base text is the C literal
            b1: bn2.stringview.byteAt i: 0.u64
            match (
                b1
            ) case some then {
                if b1 >= 48.u8 then {
                    if b1 <= 57.u8 then {
                        if (cTypeOf name: mn2.stringview).length > 0.u64 then {
                            bv1: bn2.stringview
                            bc1: bv1.string
                            return bc1
                        } else {}
                    } else {}
                } else {}
            } case none then {}
            bnid2: atomNodeId9 n: n.parent
            bt2: stampNameOf symtab: symtab nid: bnid2
            if bt2.stringview == "StringView" then {
                if mn2.stringview == "length" then {
                    e2: "\{bn2}.length"
                    return e2
                } else {}
                if mn2.stringview == "count" then {
                    needsAdd ctx: ctx name: "count"
                    ec2: "\{ctx.svC}_count(&\{bn2})"
                    return ec2
                } else {}
                if mn2.stringview == "codepoints" then {
                    needsAdd ctx: ctx name: "codepoints"
                    ecp: "\{ctx.svC}_codepoints(&\{bn2})"
                    return ecp
                } else {}
                if mn2.stringview == "parseI64" then {
                    needsAdd ctx: ctx name: "parseI64"
                    epi: "\{ctx.svC}_parseI64(&\{bn2})"
                    return epi
                } else {}
                if mn2.stringview == "parseU64" then {
                    needsAdd ctx: ctx name: "parseU64"
                    epu: "\{ctx.svC}_parseU64(&\{bn2})"
                    return epu
                } else {}
                if mn2.stringview == "parseF64" then {
                    needsAdd ctx: ctx name: "parseF64"
                    epf: "\{ctx.svC}_parseF64(&\{bn2})"
                    return epf
                } else {}
                if (isSvSimpleNative name: mn2.stringview) then {
                    # a no-paren method reference auto-calls
                    needsAdd ctx: ctx name: mn2.stringview
                    e4: "\{ctx.svC}_\{mn2}(&\{bn2})"
                    return e4
                } else {}
            } else {}
            if bt2.stringview == "String" then {
                if mn2.stringview == "length" then {
                    e3: "\{bn2}.size"
                    return e3
                } else {}
            } else {}
            vtid2: resolveTypeIdByName symtab: symtab ctx: ctx name: bn2.stringview
            if vtid2 > 0.u64 when (symtab.reg.typetypeOf typeId: vtid2) == ztypes.ztypetype.VARIANT then {
                pc2: armPayloadC symtab: symtab ctx: ctx tid: vtid2 arm: mn2.stringview
                if pc2.length == 0.u64 then {
                    tg2: variantTag symtab: symtab tid: vtid2 arm: mn2.stringview
                    vn2: typeNameOfReg9 symtab: symtab tid: vtid2
                    vc2: cnameOf tid: vtid2 name: vn2.stringview
                    e8: "((\{vc2}_t){ .tag = \{tg2} })"
                    return e8
                } else {}
            } else {}
            bstamp0: stampIdOf symtab: symtab nid: bnid2
            bstamp: bstamp0
            bsn0: typeNameOfReg9 symtab: symtab tid: bstamp0
            bcid: userFnId symtab: symtab ctx: ctx name: bsn0.stringview
            if bcid > 0.u64 then {
                bstamp = bcid
            } else {
                # canonicalize a SHELL (no defining unit) by name: a system type
                # like String reached via a fresh shell id resolves to the
                # registered class whose struct + methods are emitted (mirrors
                # the typeRefC canonicalization, so method cnames match).
                bduo9: symtab.typing.definedInUnit.get key: bstamp0
                match (
                    bduo9
                ) case some then {} case none then {
                    brid9: resolveTypeIdByName symtab: symtab ctx: ctx name: bsn0.stringview
                    if brid9 > 0.u64 then {
                        bstamp = brid9
                    } else {}
                }
            }
            bstamp = chaseColMono symtab: symtab tid: bstamp
            rtt: symtab.reg.typetypeOf typeId: bstamp
            if rtt == ztypes.ztypetype.PROTOCOL then {
                isPMn9: true
                if mn2.stringview == "create" then {
                    isPMn9 = false
                } else {}
                if mn2.stringview == "borrow" then {
                    isPMn9 = false
                } else {}
                if mn2.stringview == "release" then {
                    isPMn9 = false
                } else {}
                if isPMn9 then {
                    pacc9: ".".string
                    if (isPtrVar ctx: ctx name: bn2.stringview) then {
                        pacc9 = "->".string
                    } else {}
                    return "\{bn2}\{pacc9}vtable->\{mn2}(\{bn2}\{pacc9}data)"
                } else {}
            } else {}
            isRecOrCls: false
            if rtt == ztypes.ztypetype.RECORD then {
                isRecOrCls = true
            } else {}
            if rtt == ztypes.ztypetype.CLASS then {
                # user classes only -- collection monos (List/Set/Map, with a
                # generic origin) keep their own dottedpath legs below.
                bsoNm0: monoOriginName symtab: symtab tid: bstamp
                if bsoNm0.length == 0.u64 then {
                    isRecOrCls = true
                } else {}
            } else {}
            if isRecOrCls then {
                fbtn9: typeNameOfReg9 symtab: symtab tid: bstamp
                if fbtn9.stringview == "String" then {
                    sptr9: isPtrVar ctx: ctx name: bn2.stringview
                    sm9: emitStringMethod ctx: ctx recv: bn2.stringview recvIsPtr: sptr9 mn: mn2.stringview
                    if sm9.length > 0.u64 then {
                        return sm9
                    } else {}
                } else {}
                isFile9: false
                fduo9: symtab.typing.definedInUnit.get key: bstamp
                match (
                    fduo9
                ) case some then {
                    if fduo9.stringview == "io" then {
                        isFile9 = true
                    } else {}
                    if fduo9.stringview == "os" then {
                        isFile9 = true
                    } else {}
                    if fduo9.stringview == "cli" then {
                        isFile9 = true
                    } else {}
                } case none then {}
                if isFile9 then {
                    isFN9: false
                    if mn2.stringview == "close" then {
                        isFN9 = true
                    } else {}
                    if mn2.stringview == "flush" then {
                        isFN9 = true
                    } else {}
                    if mn2.stringview == "readLine" then {
                        isFN9 = true
                    } else {}
                    if isFN9 then {
                        ffc9: cnameOf tid: bstamp name: fbtn9.stringview
                        needsAdd ctx: ctx name: "io"
                        ffn9: "io_file_\{mn2}".string
                        needsAdd ctx: ctx name: ffn9.stringview
                        frecv9: "&\{bn2}".string
                        if (isPtrVar ctx: ctx name: bn2.stringview) then {
                            frecv9 = "\{bn2}".string
                        } else {}
                        return "\{ffc9}_\{mn2}(\{frecv9})"
                    } else {}
                } else {}
                mco: symtab.typing.childOf parentTypeId: bstamp name: mn2.stringview
                match (
                    mco
                ) case some then {
                    if (symtab.reg.typetypeOf typeId: mco) == ztypes.ztypetype.PROTOCOL then {
                        # borrowed conformance projection: f.myreader ->
                        # {Impl}_{label}_create(&f) (a borrowed fat pointer).
                        ib9: cnameOf tid: bstamp name: bsn0.stringview
                        if (isPtrVar ctx: ctx name: bn2.stringview) then {
                            pj9: "\{ib9}_\{mn2}_create(\{bn2})"
                            return pj9
                        } else {}
                        pj9b: "\{ib9}_\{mn2}_create(&\{bn2})"
                        return pj9b
                    } else {}
                    if (symtab.reg.typetypeOf typeId: mco) == ztypes.ztypetype.FUNCTION then {
                        # member auto-call: a CLASS method takes its receiver by
                        # pointer (&recv, or recv when already a ptrVar); a RECORD
                        # method takes it by value.
                        mtn2: typeNameOfReg9 symtab: symtab tid: mco
                        mc2: cnameOf tid: mco name: mtn2.stringview
                        mrecv6: "\{bn2}"
                        if rtt == ztypes.ztypetype.CLASS then {
                            if (isPtrVar ctx: ctx name: bn2.stringview) then {} else {
                                mrecv6 = "&\{bn2}"
                            }
                        } else {}
                        e6: "\{mc2}(\{mrecv6})"
                        return e6
                    } else {}
                } case none then {}
                if (isPtrVar ctx: ctx name: bn2.stringview) then {
                    e5p: "\{bn2}->\{mn2}"
                    return e5p
                } else {}
                e5: "\{bn2}.\{mn2}"
                return e5
            } else {}
            if rtt == ztypes.ztypetype.VARIANT then {
                e9: "\{bn2}.data.\{mn2}"
                return e9
            } else {}
            bsmn: monoOriginName symtab: symtab tid: bstamp
            if bsmn.stringview == "List" then {
                if mn2.stringview == "length" then {
                    el0: "\{bn2}.length"
                    return el0
                } else {}
                if mn2.stringview == "capacity" then {
                    el1: "\{bn2}.capacity"
                    return el1
                } else {}
                bstn: typeNameOfReg9 symtab: symtab tid: bstamp
                lcb2: cnameOf tid: bstamp name: bstn.stringview
                if mn2.stringview == "pop" then {
                    ep0: "\{lcb2}_pop(&\{bn2})"
                    return ep0
                } else {}
                if mn2.stringview == "sort" then {
                    ep1: "\{lcb2}_sort(&\{bn2})"
                    return ep1
                } else {}
                if mn2.stringview == "listview" then {
                    ep2: "\{lcb2}_listview(&\{bn2})"
                    return ep2
                } else {}
            } else {}
            if bsmn.stringview == "ListView" then {
                if mn2.stringview == "length" then {
                    elv: "\{bn2}.length"
                    return elv
                } else {}
            } else {}
            if bsmn.stringview == "Set" then {
                if mn2.stringview == "length" then {
                    esl: "\{bn2}->length"
                    return esl
                } else {}
                if mn2.stringview == "capacity" then {
                    esc: "\{bn2}->capacity"
                    return esc
                } else {}
                bstns: typeNameOfReg9 symtab: symtab tid: bstamp
                scb2: cnameOf tid: bstamp name: bstns.stringview
                if mn2.stringview == "iterate" then {
                    esi: "\{scb2}_iterate(\{bn2})"
                    return esi
                } else {}
            } else {}
            if bsmn.stringview == "Map" then {
                if mn2.stringview == "length" then {
                    eml: "\{bn2}->length"
                    return eml
                } else {}
                if mn2.stringview == "capacity" then {
                    emc: "\{bn2}->capacity"
                    return emc
                } else {}
                bstnm: typeNameOfReg9 symtab: symtab tid: bstamp
                mcb2: cnameOf tid: bstamp name: bstnm.stringview
                if mn2.stringview == "iterate" then {
                    emi: "\{mcb2}_iterate(\{bn2})"
                    return emi
                } else {}
                if mn2.stringview == "iterateItems" then {
                    emii: "\{mcb2}_iterateItems(\{bn2})"
                    return emii
                } else {}
            } else {}
            if bsmn.stringview == "MapEntry" then {
                # a borrowed entry yielded by iterateItems: key/value project
                # the entry struct's fields through the borrowed pointer.
                if mn2.stringview == "key" then {
                    eek: "\{bn2}->key"
                    return eek
                } else {}
                if mn2.stringview == "value" then {
                    eev: "\{bn2}->value"
                    return eev
                } else {}
            } else {}
            if rtt == ztypes.ztypetype.DATA then {
                if mn2.stringview == "length" then {
                    ed0: "z_\{bn2}_len"
                    return ed0
                } else {}
                dck: "\{bn2}.\{mn2}".string
                dco: ctx.dataConst.get key: dck
                match (
                    dco
                ) case some then {
                    dcv: dco.stringview
                    dcc: dcv.string
                    return dcc
                } case none then {}
            } else {}
        } else {}
        # `.stringview` on a String/StringView projects an inline view, not a
        # field access (matches the simple-base svValueForm path).
        if mn2.stringview == "stringview" then {
            ppid9: nodeIdOf9 n: n.parent
            ptn9: stampNameOf symtab: symtab nid: ppid9
            if ptn9.stringview == "String" then {
                pbv9: emitExpr symtab: symtab ctx: ctx n: n.parent
                sv9: svValueForm ctx: ctx expr: pbv9.stringview tname: "String"
                return sv9
            } else {}
            if ptn9.stringview == "StringView" then {
                return (emitExpr symtab: symtab ctx: ctx n: n.parent)
            } else {}
        } else {}
        # a nested base (e.g. it.target.a): emit the base expression, then chain
        # `.`/`->` by whether the base resolves to a pointer (ptrVar / lock field).
        base9: emitExpr symtab: symtab ctx: ctx n: n.parent
        if (base9.stringview.startsWith prefix: "/*") then {
            return "/* zemitterc: unhandled dotted */0".string
        } else {}
        nptn9: stampNameDeep symtab: symtab n: n.parent
        if nptn9.stringview == "String" then {
            nptr9: pathIsPointer symtab: symtab ctx: ctx n: n.parent
            nsm9: emitStringMethod ctx: ctx recv: base9.stringview recvIsPtr: nptr9 mn: mn2.stringview
            if nsm9.length > 0.u64 then {
                return nsm9
            } else {}
        } else {}
        # a no-arg List method on a nested receiver (this.field.pop): the bsmn
        # leg above missed it (bstamp keys off an atom base, 0 for a nested
        # path). Resolve the List mono from the base node and emit the call.
        nlid9: stampIdOf symtab: symtab nid: (nodeIdOf9 n: n.parent)
        nlid9 = chaseColMono symtab: symtab tid: nlid9
        nlomn9: monoOriginName symtab: symtab tid: nlid9
        if nlomn9.stringview == "List" then {
            nltn9: typeNameOfReg9 symtab: symtab tid: nlid9
            nlcb9: cnameOf tid: nlid9 name: nltn9.stringview
            if mn2.stringview == "pop" then {
                return "\{nlcb9}_pop(&\{base9})"
            } else {}
            if mn2.stringview == "sort" then {
                return "\{nlcb9}_sort(&\{base9})"
            } else {}
            if mn2.stringview == "listview" then {
                return "\{nlcb9}_listview(&\{base9})"
            } else {}
        } else {}
        if (pathIsPointer symtab: symtab ctx: ctx n: n.parent) then {
            ep9: "\{base9}->\{mn2}"
            return ep9
        } else {
            ed9: "\{base9}.\{mn2}"
            return ed9
        }
    } case atomstring then {
        li9: litIndexOf ids: ctx.litIds nid: n.nodeid.u64
        if li9 > 0.u64 then {
            se9: "_zs\{li9}"
            return se9
        } else {}
        return "/* zemitterc: unhandled atomstring expr */0".string
    } case ifexpr then {
        tx: "".string
        depth: 0.u64
        citer: n.clauses.iterate
        for c: citer loop {
            cx: ternaryClause symtab: symtab ctx: ctx c: c
            tx.append cx.stringview
            depth = depth + 1.u64
        }
        ex9: ternaryElse symtab: symtab ctx: ctx o: n.elseclause
        tx.append ex9.stringview
        dk: 0.u64
        for while dk < depth loop {
            tx.append ")"
            dk = dk + 1.u64
        }
        return tx
    } case binop then {
        l: emitExpr symtab: symtab ctx: ctx n: n.lhs
        op: atomTextOf n: n.operator
        r: emitExpr symtab: symtab ctx: ctx n: n.rhs
        if (isCompareOp name: op.stringview) then {
            lt: stampNameDeep symtab: symtab n: n.lhs
            lti: userFnId symtab: symtab ctx: ctx name: lt.stringview
            if lti > 0.u64 when (symtab.reg.typetypeOf typeId: lti) == ztypes.ztypetype.RECORD then {
                rne: typeNameOfReg9 symtab: symtab tid: lti
                rce: cnameOf tid: lti name: rne.stringview
                if op.stringview == "==" then {
                    re1: "\{rce}_eq(\{l}, \{r})"
                    return re1
                } else {}
                if op.stringview == "!=" then {
                    re2: "!\{rce}_eq(\{l}, \{r})"
                    return re2
                } else {}
            } else {}
            if lti > 0.u64 when (symtab.reg.typetypeOf typeId: lti) == ztypes.ztypetype.VARIANT then {
                vne: typeNameOfReg9 symtab: symtab tid: lti
                vce: cnameOf tid: lti name: vne.stringview
                if op.stringview == "==" then {
                    ee1: "\{vce}_eq(\{l}, \{r})"
                    return ee1
                } else {}
                if op.stringview == "!=" then {
                    ee2: "!\{vce}_eq(\{l}, \{r})"
                    return ee2
                } else {}
            } else {}
            if (isStringy name: lt.stringview) then {
                rt: stampNameDeep symtab: symtab n: n.rhs
                lf: svValueForm ctx: ctx expr: l.stringview tname: lt.stringview
                rf: svValueForm ctx: ctx expr: r.stringview tname: rt.stringview
                if op.stringview == "==" then {
                    eq1: "\{ctx.svC}_eq(\{lf}, \{rf})"
                    return eq1
                } else {}
                if op.stringview == "!=" then {
                    eq2: "!\{ctx.svC}_eq(\{lf}, \{rf})"
                    return eq2
                } else {}
                cm1: "(\{ctx.svC}_cmp(\{lf}, \{rf}) \{op} 0)"
                return cm1
            } else {}
        } else {}
        e9: "(\{l} \{op} \{r})"
        return e9
    } case call then {
        return (emitCallValue symtab: symtab ctx: ctx call: n)
    } else {
        return "/* zemitterc: unhandled expr */0".string
    }
}

# emitInterpPrint -- the interpolated-print temp chain: create, per-part
# append (literal bytes or snprintf-formatted scalar), print, free.
emitInterpPrint: function {symtab: zenv.ZSymbolTable ctx: Ctx parts: (List of: Node) ind: StringView tmp: TmpCtr buf: String.borrow} is {
    sN: emitInterpBuild symtab: symtab ctx: ctx parts: parts ind: ind tmp: tmp buf: buf
    l1: "\{ind}\{ctx.strC}_print(&_s\{sN});\n"
    buf.append l1.stringview
    l2: "\{ind}\{ctx.strC}_free(&_s\{sN});\n"
    buf.append l2.stringview
}

# emitInterpBuild -- the create/append chain for an interpolated literal;
# returns the _sN temp index (caller prints/frees or binds it).
emitInterpBuild: function {symtab: zenv.ZSymbolTable ctx: Ctx parts: (List of: Node) ind: StringView tmp: TmpCtr buf: String.borrow} out u64 is {
    est: 0.u64
    with piter: parts.iterate do for p: piter loop {
        isC: false
        match (
            p
        ) case stringchunk then {
            isC = true
            tl: p.text.length
            est = est + tl
        } else {}
        if isC then {} else {
            est = est + 16.u64
        }
    }
    sN: tmp.next
    l0: "\{ind}\{ctx.strC}_t _s\{sN} = \{ctx.strC}_create((uint64_t)\{est});\n"
    buf.append l0.stringview
    qiter: parts.iterate
    for q: qiter loop {
        emitInterpPart symtab: symtab ctx: ctx n: q sN: sN ind: ind tmp: tmp buf: buf
    }
    return sN
}

numericFormatName: function {symtab: zenv.ZSymbolTable ctx: Ctx tn: StringView} out String is {
    mrk: tn.string
    mro: ctx.methodReturns.get key: mrk
    match (
        mro
    ) case some then {
        mrv: mro.stringview
        return (numericFormatName symtab: symtab ctx: ctx tn: mrv)
    } case none then {}
    if (isIntName name: tn) then {
        r0: tn.string
        return r0
    } else {}
    if (isFloatName name: tn) then {
        r1: tn.string
        return r1
    } else {}
    tid: userFnId symtab: symtab ctx: ctx name: tn
    if tid > 0.u64 then {
        bc: typedefChaseC symtab: symtab ctx: ctx tid: tid
        if bc.stringview == "double" then {
            return "f64".string
        } else if bc.stringview == "float" then {
            return "f32".string
        } else if bc.length > 0.u64 then {
            return "i64".string
        } else {}
    } else {}
    rr: tn.string
    return rr
}

dataIndexElemName: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out String is {
    match (
        n
    ) case expression then {
        return (dataIndexElemName symtab: symtab ctx: ctx n: n.expression)
    } case call then {
        mn: dottedChildText n: n.callable
        if mn.stringview == "index" then {
            bn: dottedBaseAtom n: n.callable
            dk: bn.string
            go: ctx.dataElems.get key: dk
            match (
                go
            ) case some then {
                gv: go.stringview
                gc: gv.string
                return gc
            } case none then {}
        } else {}
        return "".string
    } else {
        return "".string
    }
}

# interpBaseIsMapEntry -- true when an interp part is `<entry>.key`/`.value`
# off a borrowed MapEntry: the projected String views the bucket, so it must
# be appended inline (freeing the hoisted copy would double-free the bucket key).
interpBaseIsMapEntry: function {symtab: zenv.ZSymbolTable n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (interpBaseIsMapEntry symtab: symtab n: n.expression)
    } case statementline then {
        return (interpBaseIsMapEntry symtab: symtab n: n.statementline)
    } case dottedpath then {
        bnid: atomNodeId9 n: n.parent
        bt: stampIdOf symtab: symtab nid: bnid
        bo: monoOriginName symtab: symtab tid: bt
        if bo.stringview == "MapEntry" then {
            return true
        } else {}
        return false
    } else {
        return false
    }
}

# interpBaseIsOwnedStructField -- a `<inst>.field` read off a user record/class:
# the projected String VIEWS the owner's field (freed by the owner's destructor),
# so it appends inline -- freeing a hoisted copy would double-free the field.
interpBaseIsOwnedStructField: function {symtab: zenv.ZSymbolTable n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (interpBaseIsOwnedStructField symtab: symtab n: n.expression)
    } case statementline then {
        return (interpBaseIsOwnedStructField symtab: symtab n: n.statementline)
    } case dottedpath then {
        bnid: atomNodeId9 n: n.parent
        bt: stampIdOf symtab: symtab nid: bnid
        bo: monoOriginName symtab: symtab tid: bt
        if bo.length == 0.u64 then {} else {
            return false
        }
        btt: symtab.reg.typetypeOf typeId: bt
        isUC: false
        if btt == ztypes.ztypetype.RECORD then {
            isUC = true
        } else {}
        if btt == ztypes.ztypetype.CLASS then {
            isUC = true
        } else {}
        if isUC then {} else {
            return false
        }
        cn: atomTextOf n: n.child
        co: symtab.typing.childOf parentTypeId: bt name: cn.stringview
        match (
            co
        ) case some then {
            if (symtab.reg.typetypeOf typeId: co) == ztypes.ztypetype.FUNCTION then {
                return false
            } else {
                return true
            }
        } case none then {
            return false
        }
    } else {
        return false
    }
}

emitInterpPart: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node sN: u64 ind: StringView tmp: TmpCtr buf: String.borrow} is {
    match (
        n
    ) case stringchunk then {
        tv: n.text.stringview
        esc: cEscape text: tv
        l3: "\{ind}\{ctx.strC}_append(&_s\{sN}, \"\{esc}\", sizeof(\"\{esc}\")-1);\n"
        buf.append l3.stringview
    } else {
        di0: dataIndexElemName symtab: symtab ctx: ctx n: n
        tn0: stampNameDeep symtab: symtab n: n
        tn: numericFormatName symtab: symtab ctx: ctx tn: tn0.stringview
        if di0.length > 0.u64 then {
            tn = di0
        } else {}
        val: emitExpr symtab: symtab ctx: ctx n: n
        bN: tmp.next
        if (isIntName name: tn.stringview) then {
            l4: "\{ind}char _b\{bN}[32]; int _b\{bN}_n = snprintf(_b\{bN}, 32, \"%ld\", (long)(int64_t)\{val});\n"
            buf.append l4.stringview
            l5: "\{ind}\{ctx.strC}_append(&_s\{sN}, _b\{bN}, (uint64_t)_b\{bN}_n);\n"
            buf.append l5.stringview
        } else if (isFloatName name: tn.stringview) then {
            l6: "\{ind}char _b\{bN}[64]; int _b\{bN}_n = snprintf(_b\{bN}, 64, \"%g\", (double)\{val});\n"
            buf.append l6.stringview
            l7: "\{ind}\{ctx.strC}_append(&_s\{sN}, _b\{bN}, (uint64_t)_b\{bN}_n);\n"
            buf.append l7.stringview
        } else if tn.stringview == "StringView" then {
            lsv: "\{ind}\{ctx.strC}_append(&_s\{sN}, \{val}.data, \{val}.length);\n"
            buf.append lsv.stringview
        } else if tn.stringview == "String" then {
            isAtomP: false
            an0: atomTextDeep n: n
            if an0.length > 0.u64 then {
                isAtomP = true
            } else {}
            if (interpBaseIsMapEntry symtab: symtab n: n) then {
                isAtomP = true
            } else {}
            if (interpBaseIsOwnedStructField symtab: symtab n: n) then {
                isAtomP = true
            } else {}
            if isAtomP then {
                lss: "\{ind}\{ctx.strC}_append(&_s\{sN}, \{val}.data, \{val}.size);\n"
                buf.append lss.stringview
            } else {
                # owned call result: hoist, append, free
                hN: tmp.next
                lh0: "\{ind}\{ctx.strC}_t _h\{hN} = \{val};\n"
                buf.append lh0.stringview
                lh1: "\{ind}\{ctx.strC}_append(&_s\{sN}, _h\{hN}.data, _h\{hN}.size);\n"
                buf.append lh1.stringview
                lh2: "\{ind}\{ctx.strC}_free(&_h\{hN});\n"
                buf.append lh2.stringview
            }
        } else {
            l8: "\{ind}/* zemitterc: unhandled interp part type \{tn} */\n"
            buf.append l8.stringview
        }
    }
}

# nodeIdOf9 -- the nodeid of expression-ish shapes used by interp parts.
nodeIdOf9: function {n: Node} out u64 is {
    match (
        n
    ) case expression then {
        return n.nodeid.u64
    } case atomid then {
        return n.nodeid.u64
    } case call then {
        return n.nodeid.u64
    } case binop then {
        return n.nodeid.u64
    } case dottedpath then {
        return n.nodeid.u64
    } case atomstring then {
        return n.nodeid.u64
    } else {
        return 0.u64
    }
}

# stampNameDeep -- a node's stamped type name, peeling expression
# wrappers when the wrapper itself is unstamped.
# methodReturnByName -- given a "Base.member" method name, resolve the
# base type's member child and return its return-type name ("" if not).
methodReturnByName: function {symtab: zenv.ZSymbolTable dotted: StringView} out String is {
    base: "".string
    member: "".string
    seenDot: false
    di: 0.u64
    dn: dotted.length
    for while di < dn loop {
        bo0: dotted.byteAt i: di
        match (
            bo0
        ) case some then {
            if bo0 == 46.u8 then {
                seenDot = true
            } else {
                if seenDot then {
                    member.appendByte b: bo0
                } else {
                    base.appendByte b: bo0
                }
            }
        } case none then {}
        di = di + 1.u64
    }
    if seenDot then {} else {
        return "".string
    }
    # scan for a parent type named `base` that actually declares the
    # `member` child (a typedef has both a shell and a canonical id;
    # only the canonical bears children).
    pids: (List of: u64)
    cids: (List of: u64)
    with citer: symtab.typing.typeChild.iterate do for tc: citer loop {
        if tc.childName.stringview == member.stringview then {
            cto: symtab.typing.childTypeById.get key: tc.childNameId
            match (
                cto
            ) case some then {
                pv9: tc.parentTypeId
                pids.append pv9
                cv9: cto
                cids.append cv9
            } case none then {}
        } else {}
    }
    found: 0.u64
    si: 0.u64
    sn: pids.length
    for while si < sn loop {
        pid: pids.get i: si
        pn: typeNameOfReg9 symtab: symtab tid: pid
        if pn.stringview == base.stringview when found == 0.u64 then {
            found = cids.get i: si
        } else {}
        si = si + 1.u64
    }
    if found > 0.u64 then {
        mt: symtab.reg.typeById.get key: found
        match (
            mt
        ) case some then {
            rt2: mt.returnTypeId
            match (
                rt2
            ) case some then {
                return (typeNameOfReg9 symtab: symtab tid: rt2)
            } case none then {}
        } case none then {}
    } else {}
    return "".string
}

stampNameDeep: function {symtab: zenv.ZSymbolTable n: Node} out String is {
    nid: nodeIdOf9 n: n
    sid: stampIdOf symtab: symtab nid: nid
    if sid > 0.u64 then {
        # a value-position FUNCTION stamp is an auto-call; its value
        # type is the method's return.
        if (symtab.reg.typetypeOf typeId: sid) == ztypes.ztypetype.FUNCTION then {
            t: symtab.reg.typeById.get key: sid
            match (
                t
            ) case some then {
                rto: t.returnTypeId
                match (
                    rto
                ) case some then {
                    return (typeNameOfReg9 symtab: symtab tid: rto)
                } case none then {}
            } case none then {}
            # a shell FUNCTION named "Base.member": resolve the method
            # through the base type's child and read its return.
            fnm: typeNameOfReg9 symtab: symtab tid: sid
            rmn: methodReturnByName symtab: symtab dotted: fnm.stringview
            if rmn.length > 0.u64 then {
                return rmn
            } else {}
        } else {}
        return (typeNameOfReg9 symtab: symtab tid: sid)
    } else {}
    match (
        n
    ) case expression then {
        return (stampNameDeep symtab: symtab n: n.expression)
    } else {
        return "".string
    }
}

# emitPrintStmt -- a statement-position print call.
emitPrintStmt: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData ind: StringView tmp: TmpCtr buf: String.borrow} is {
    emitted: false
    aiter: call.arguments.iterate
    for a: aiter loop {
        match (
            a
        ) case namedoperation then {
            if emitted then {} else {
                emitted = true
                emitPrintArg symtab: symtab ctx: ctx n: a.operation ind: ind tmp: tmp buf: buf
            }
        } else {}
    }
    if emitted then {} else {
        buf.append "    /* zemitterc: print with no argument */\n"
    }
}

# emitPanicStmt -- `panic "msg"` routes through the shared z_panic runtime
# helper. msg is a StringLike (String/StringView); both expose `.data` as a
# char pointer. A non-string or unhandled arg falls back to a bare marker.
emitPanicStmt: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData ind: StringView buf: String.borrow} is {
    av: "".string
    got: false
    aiter: call.arguments.iterate
    for a: aiter loop {
        match (
            a
        ) case namedoperation then {
            if got then {} else {
                got = true
                av = emitExpr symtab: symtab ctx: ctx n: a.operation
            }
        } else {}
    }
    okArg: false
    if got then {
        if (av.stringview.startsWith prefix: "/*") then {} else {
            okArg = true
        }
    } else {}
    if okArg then {
        pl: "\{ind}z_panic((const char*)\{av}.data);\n"
        buf.append pl.stringview
    } else {
        pf: "\{ind}z_panic(\"(panic)\");\n"
        buf.append pf.stringview
    }
}

emitPrintArg: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node ind: StringView tmp: TmpCtr buf: String.borrow} is {
    match (
        n
    ) case expression then {
        emitPrintArg symtab: symtab ctx: ctx n: n.expression ind: ind tmp: tmp buf: buf
    } case atomstring then {
        if (isInterp parts: n.stringparts) then {
            emitInterpPrint symtab: symtab ctx: ctx parts: n.stringparts ind: ind tmp: tmp buf: buf
        } else {
            li: litIndexOf ids: ctx.litIds nid: n.nodeid.u64
            if li > 0.u64 then {
                l9: "\{ind}\{ctx.svC}_print(_zs\{li});\n"
                buf.append l9.stringview
            } else {
                buf.append "    /* zemitterc: unpooled literal */\n"
            }
        }
    } case atomid then {
        tn9: stampNameOf symtab: symtab nid: n.nodeid.u64
        an9: n.name.stringview
        anm: an9.string
        if tn9.stringview == "String" then {
            lps: "\{ind}\{ctx.strC}_print(&\{anm});\n"
            buf.append lps.stringview
        } else if tn9.stringview == "StringView" then {
            lpv: "\{ind}\{ctx.svC}_print(\{anm});\n"
            buf.append lpv.stringview
        } else {
            argTid: stampIdOf symtab: symtab nid: n.nodeid.u64
            svco: symtab.typing.childOf parentTypeId: argTid name: "stringview"
            match (
                svco
            ) case some then {
                mtn: typeNameOfReg9 symtab: symtab tid: svco
                mcb: cnameOf tid: svco name: mtn.stringview
                amn: monoOriginName symtab: symtab tid: argTid
                usesAmp: false
                if (symtab.reg.typetypeOf typeId: argTid) == ztypes.ztypetype.CLASS when amn.length == 0.u64 then {
                    if (isPtrVar ctx: ctx name: anm.stringview) then {} else {
                        usesAmp = true
                    }
                } else {}
                if usesAmp then {
                    lpt: "\{ind}\{ctx.svC}_print(\{mcb}(&\{anm}));\n"
                    buf.append lpt.stringview
                } else {
                    lpt2: "\{ind}\{ctx.svC}_print(\{mcb}(\{anm}));\n"
                    buf.append lpt2.stringview
                }
            } case none then {
                lpu: "\{ind}/* zemitterc: unhandled print of \{anm} type \{tn9} */\n"
                buf.append lpu.stringview
            }
        }
    } else {
        buf.append "    /* zemitterc: unhandled print argument */\n"
    }
}

# bindLitIndex -- the pool index of a plain-literal value node (0 = none).
bindLitIndex: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out u64 is {
    match (
        n
    ) case expression then {
        return (bindLitIndex symtab: symtab ctx: ctx n: n.expression)
    } case atomstring then {
        if (isInterp parts: n.stringparts) then {
            return 0.u64
        } else {
            return (litIndexOf ids: ctx.litIds nid: n.nodeid.u64)
        }
    } else {
        return 0.u64
    }
}

# stringviewOfBase -- the base name of `X.stringview` over a String local
# ("" otherwise).
stringviewOfBase: function {symtab: zenv.ZSymbolTable n: Node} out String is {
    match (
        n
    ) case expression then {
        return (stringviewOfBase symtab: symtab n: n.expression)
    } case dottedpath then {
        mn: atomTextOf n: n.child
        if mn.stringview == "stringview" then {
            bnid: atomNodeId9 n: n.parent
            bt: stampNameOf symtab: symtab nid: bnid
            if bt.stringview == "String" then {
                return (atomTextOf n: n.parent)
            } else {}
        } else {}
        return "".string
    } else {
        return "".string
    }
}

# stringCopyLitIndex -- the pool index of `\"lit\".string` (0 otherwise).
stringCopyLitIndex: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out u64 is {
    match (
        n
    ) case expression then {
        return (stringCopyLitIndex symtab: symtab ctx: ctx n: n.expression)
    } case dottedpath then {
        mn: atomTextOf n: n.child
        if mn.stringview == "string" then {
            return (bindLitIndex symtab: symtab ctx: ctx n: n.parent)
        } else {
            return 0.u64
        }
    } else {
        return 0.u64
    }
}

# emitStringBindValue -- bind an interpolated-literal value to a String
# local (build chain + binding + scope-end free); false when the value
# is not an interpolated literal.
emitStringBindValue: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node nm: StringView ind: StringView tmp: TmpCtr buf: String.borrow} out bool is {
    match (
        n
    ) case expression then {
        return (emitStringBindValue symtab: symtab ctx: ctx n: n.expression nm: nm ind: ind tmp: tmp buf: buf)
    } case atomstring then {
        if (isInterp parts: n.stringparts) then {
            sB: emitInterpBuild symtab: symtab ctx: ctx parts: n.stringparts ind: ind tmp: tmp buf: buf
            lst: "\{ind}\{ctx.strC}_t \{nm} = _s\{sB};\n"
            buf.append lst.stringview
            nmc: nm.string
            tmp.frees.append nmc
            return true
        } else {
            return false
        }
    } else {
        return false
    }
}

# emitOptionBoxHoist -- `Option.some <val>`: a heap-boxed union ctor, emitted as
# statements (the box can't be an expression). Returns the `_cN` temp name, or ""
# when n is not an Option.some (so the caller falls back to the expression path).
emitOptionBoxHoist: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node ind: StringView tmp: TmpCtr buf: String.borrow} out String is {
    match (
        n
    ) case expression then {
        return (emitOptionBoxHoist symtab: symtab ctx: ctx n: n.expression ind: ind tmp: tmp buf: buf)
    } case statementline then {
        return (emitOptionBoxHoist symtab: symtab ctx: ctx n: n.statementline ind: ind tmp: tmp buf: buf)
    } case call then {
        cn: dottedChildText n: n.callable
        if cn.stringview == "some" then {} else {
            return "".string
        }
        mid: stampIdOf symtab: symtab nid: n.nodeid.u64
        mo9: monoOriginName symtab: symtab tid: mid
        if mo9.stringview == "Option" then {} else {
            return "".string
        }
        av: "0".string
        got: false
        aiter9: n.arguments.iterate
        for a9: aiter9 loop {
            match (
                a9
            ) case namedoperation then {
                if got then {} else {
                    got = true
                    av = emitExpr symtab: symtab ctx: ctx n: a9.operation
                }
            } else {}
        }
        vn: typeNameOfReg9 symtab: symtab tid: mid
        vc: cnameOf tid: mid name: vn.stringview
        payC: armPayloadC symtab: symtab ctx: ctx tid: mid arm: "some"
        tg: variantTag symtab: symtab tid: mid arm: "some"
        bN: tmp.next
        b0: "\{ind}\{vc}_t _c\{bN} = {0};\n"
        buf.append b0.stringview
        b1: "\{ind}_c\{bN}.tag = \{tg};\n"
        buf.append b1.stringview
        b2: "\{ind}\{payC} _t\{bN} = \{av};\n"
        buf.append b2.stringview
        b3: "\{ind}\{payC}* _Box\{bN} = (\{payC}*)z_xmalloc(sizeof(\{payC}));\n"
        buf.append b3.stringview
        b4: "\{ind}*_Box\{bN} = _t\{bN};\n"
        buf.append b4.stringview
        b5: "\{ind}_c\{bN}.data = _Box\{bN};\n"
        buf.append b5.stringview
        return "_c\{bN}".string
    } else {
        return "".string
    }
}

# emitCallStmt -- one call-shaped statement: return / print / a plain call.
emitCallStmt: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData ind: StringView tmp: TmpCtr buf: String.borrow} is {
    relmn: dottedChildText n: call.callable
    if relmn.stringview == "release" then {
        relbnid: dottedBaseNodeId n: call.callable
        reltid: stampIdOf symtab: symtab nid: relbnid
        if (symtab.reg.typetypeOf typeId: reltid) == ztypes.ztypetype.PROTOCOL then {
            return
        } else {}
    } else {}
    cn0: atomTextOf n: call.callable
    if cn0.stringview == "print" then {
        emitPrintStmt symtab: symtab ctx: ctx call: call ind: ind tmp: tmp buf: buf
        return
    } else {}
    if cn0.stringview == "panic" then {
        emitPanicStmt symtab: symtab ctx: ctx call: call ind: ind buf: buf
        return
    } else {}
    if cn0.stringview == "return" then {
        hasArg: false
        aiter: call.arguments.iterate
        for a: aiter loop {
            match (
                a
            ) case namedoperation then {
                if hasArg then {} else {
                    hasArg = true
                    bx: emitOptionBoxHoist symtab: symtab ctx: ctx n: a.operation ind: ind tmp: tmp buf: buf
                    if bx.length > 0.u64 then {
                        lrb: "\{ind}return \{bx};\n"
                        buf.append lrb.stringview
                    } else {
                        rv: emitExpr symtab: symtab ctx: ctx n: a.operation
                        lr: "\{ind}return \{rv};\n"
                        buf.append lr.stringview
                    }
                }
            } else {}
        }
        if hasArg then {} else {
            if ctx.genActive then {
                lgd: "\{ind}goto L_done;\n"
                buf.append lgd.stringview
            } else {
                lr2: "\{ind}return;\n"
                buf.append lr2.stringview
            }
        }
        return
    } else {}
    ce: emitCallValue symtab: symtab ctx: ctx call: call
    lc: "\{ind}\{ce};\n"
    buf.append lc.stringview
    emitCallTakeInvalidations symtab: symtab ctx: ctx call: call ind: ind buf: buf
}

# nodeIsDotted9 -- the node is a dotted-path auto-call (a no-arg method
# reference used in statement position).
nodeIsDotted9: function {n: Node} out bool is {
    match (
        n
    ) case dottedpath then {
        return true
    } else {
        return false
    }
}

# emitStmt -- one statement of a function body.
emitStmt: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node ind: StringView tmp: TmpCtr buf: String.borrow} is {
    match (
        n
    ) case statementline then {
        emitStmt symtab: symtab ctx: ctx n: n.statementline ind: ind tmp: tmp buf: buf
    } case expression then {
        emitStmt symtab: symtab ctx: ctx n: n.expression ind: ind tmp: tmp buf: buf
    } case statement then {
        siter9: n.statements.iterate
        for s9: siter9 loop {
            emitStmt symtab: symtab ctx: ctx n: s9 ind: ind tmp: tmp buf: buf
        }
    } case doexpr then {
        emitBodyNode symtab: symtab ctx: ctx n: n.statement ind: ind tmp: tmp buf: buf
    } case call then {
        emitCallStmt symtab: symtab ctx: ctx call: n ind: ind tmp: tmp buf: buf
    } case assignment then {
        tn: stampNameOf symtab: symtab nid: n.nodeid.u64
        ct: cTypeOf name: tn.stringview
        if ct.length == 0.u64 then {
            tgo: symtab.typing.nodeType.get key: n.nodeid.u64
            match (
                tgo
            ) case some then {
                ct = typeRefC symtab: symtab ctx: ctx tid: tgo thisTid: 0.u64
            } case none then {}
        } else {}
        nm: n.name.stringview
        if ctx.genActive when (isYieldNode n: n.value) then {
            emitExprFormYield symtab: symtab ctx: ctx value: n.value aid: n.nodeid.u64 nm: nm.stringview ind: ind tmp: tmp buf: buf
            return
        } else {}
        # `x: <inst>.take` over a record/class is an ownership alias: record
        # `x => inst` and emit no storage (subsequent `x` resolves to `inst`).
        tabA: takeAliasBase symtab: symtab n: n.value
        if tabA.length > 0.u64 then {
            lalA: "\{ind}/* alias: \{nm} => \{tabA} */\n"
            buf.append lalA.stringview
            ctx.aliases.set key: nm.string value: tabA
            return
        } else {}
        ltid: stampIdOf symtab: symtab nid: n.nodeid.u64
        ltid = chaseColMono symtab: symtab tid: ltid
        ltnm: typeNameOfReg9 symtab: symtab tid: ltid
        ltmn: monoOriginName symtab: symtab tid: ltid
        if ltmn.stringview == "List" then {
            lcb: cnameOf tid: ltid name: ltnm.stringview
            if (osNoArgCallRhs n: n.value) then {
                # owned List returned by os.args / os.envNames: emit the call.
                losr: emitExpr symtab: symtab ctx: ctx n: n.value
                losb: "\{ind}\{lcb}_t \{nm} = \{losr};\n"
                buf.append losb.stringview
            } else {
                if (forexprValue n: n.value) then {
                    # list comprehension: `xs: for ... loop { expr }` create + populate
                    lc0: "\{ind}\{lcb}_t \{nm} = \{lcb}_create((uint64_t)0);\n"
                    buf.append lc0.stringview
                    emitListComprehension symtab: symtab ctx: ctx forNode: n.value listCb: lcb.stringview listVar: nm ind: ind tmp: tmp buf: buf
                } else {
                    lcap: listCapArg symtab: symtab ctx: ctx n: n.value
                    lb0: "\{ind}\{lcb}_t \{nm} = \{lcb}_create((uint64_t)\{lcap});\n"
                    buf.append lb0.stringview
                }
            }
            lfree: "    \{lcb}_destroy(&\{nm});\n"
            lfsv: lfree.stringview
            lfv: lfsv.string
            tmp.listFrees.append lfv
            return
        } else {}
        if ltmn.stringview == "Set" then {
            stn: typeNameOfReg9 symtab: symtab tid: ltid
            scb: cnameOf tid: ltid name: stn.stringview
            scap: listCapArg symtab: symtab ctx: ctx n: n.value
            sb0: "\{ind}\{scb}_t* \{nm} = \{scb}_create((uint64_t)\{scap});\n"
            buf.append sb0.stringview
            sfree: "    \{scb}_destroy(\{nm});\n"
            sfsv: sfree.stringview
            sfv: sfsv.string
            tmp.listFrees.append sfv
            return
        } else {}
        if ltmn.stringview == "Map" then {
            mtn: typeNameOfReg9 symtab: symtab tid: ltid
            mcb: cnameOf tid: ltid name: mtn.stringview
            mcap: listCapArg symtab: symtab ctx: ctx n: n.value
            mb0: "\{ind}\{mcb}_t* \{nm} = \{mcb}_create((uint64_t)\{mcap});\n"
            buf.append mb0.stringview
            mfree: "    \{mcb}_destroy(\{nm});\n"
            mfsv: mfree.stringview
            mfv: mfsv.string
            tmp.listFrees.append mfv
            return
        } else {}
        if tn.stringview == "StringView" then {
            lvN: bindLitIndex symtab: symtab ctx: ctx n: n.value
            if lvN > 0.u64 then {
                lsv2: "\{ind}\{ctx.svC}_t \{nm} = _zs\{lvN};\n"
                buf.append lsv2.stringview
                return
            } else {}
            svb: stringviewOfBase symtab: symtab n: n.value
            if svb.length > 0.u64 then {
                lsv4: "\{ind}\{ctx.svC}_t \{nm} = (\{ctx.svC}_t){ \{svb}.data, \{svb}.size };\n"
                buf.append lsv4.stringview
                return
            } else {}
            vx: emitExpr symtab: symtab ctx: ctx n: n.value
            if (vx.stringview.startsWith prefix: "/*") then {
                lsv3: "\{ind}/* zemitterc: unhandled StringView binding \{nm} */\n"
                buf.append lsv3.stringview
            } else {
                lsv5: "\{ind}\{ctx.svC}_t \{nm} = \{vx};\n"
                buf.append lsv5.stringview
            }
            return
        } else {}
        if tn.stringview == "String" then {
            fvN: stringCopyLitIndex symtab: symtab ctx: ctx n: n.value
            if fvN > 0.u64 then {
                lsc: "\{ind}\{ctx.strC}_t \{nm} = \{ctx.strC}_from_view(_zs\{fvN});\n"
                buf.append lsc.stringview
                nmc2: nm.string
                tmp.frees.append nmc2
                return
            } else {}
            did9: emitStringBindValue symtab: symtab ctx: ctx n: n.value nm: nm ind: ind tmp: tmp buf: buf
            if did9 then {
                return
            } else {}
            sx: emitExpr symtab: symtab ctx: ctx n: n.value
            if (sx.stringview.startsWith prefix: "/*") then {
                lst2: "\{ind}/* zemitterc: unhandled String binding \{nm} */\n"
                buf.append lst2.stringview
            } else {
                lst3: "\{ind}\{ctx.strC}_t \{nm} = \{sx};\n"
                buf.append lst3.stringview
                nmc3: nm.string
                tmp.frees.append nmc3
            }
            return
        } else {}
        if ct.length > 0.u64 then {
            dm9: emitMatchBindValue symtab: symtab ctx: ctx n: n.value nm: nm ct: ct.stringview ind: ind tmp: tmp buf: buf
            if dm9 then {
                return
            } else {}
            di9: emitIfBindValue symtab: symtab ctx: ctx n: n.value nm: nm ct: ct.stringview ind: ind tmp: tmp buf: buf
            if di9 then {
                return
            } else {}
        } else {}
        rv: emitExpr symtab: symtab ctx: ctx n: n.value
        if ct.length > 0.u64 then {
            la: "\{ind}\{ct} \{nm} = \{rv};\n"
            buf.append la.stringview
            emitValueTakeInvalidations symtab: symtab ctx: ctx n: n.value ind: ind buf: buf
            # an owned class/record local with heap fields is destroyed at scope
            # exit (String/collection locals returned earlier; take-aliases too).
            if (symtab.reg.hasDestructorName typeId: ltid) then {
                ldcb: cnameOf tid: ltid name: tn.stringview
                ldf: "    \{ldcb}_destroy(&\{nm});\n"
                ldfs: ldf.string
                tmp.listFrees.append ldfs
            } else {}
        } else {
            lb: "\{ind}/* zemitterc: unhandled binding type \{tn} for \{nm} */\n"
            buf.append lb.stringview
        }
    } case reassignment then {
        nm2: emitExpr symtab: symtab ctx: ctx n: n.topath
        rv2: emitExpr symtab: symtab ctx: ctx n: n.value
        lc2: "\{ind}\{nm2} = \{rv2};\n"
        buf.append lc2.stringview
    } case swapstmt then {
        lx: emitExpr symtab: symtab ctx: ctx n: n.lhs
        rx: emitExpr symtab: symtab ctx: ctx n: n.rhs
        lnid: nodeIdOf9 n: n.lhs
        lsid: stampIdOf symtab: symtab nid: lnid
        lct: typeRefC symtab: symtab ctx: ctx tid: lsid thisTid: 0.u64
        if lct.length == 0.u64 then {
            lct = "int64_t".string
        } else {}
        sN: tmp.next
        s0: "\{ind}{\n"
        buf.append s0.stringview
        s1: "\{ind}    \{lct} _sw\{sN} = \{lx};\n"
        buf.append s1.stringview
        s2: "\{ind}    \{lx} = \{rx};\n"
        buf.append s2.stringview
        s3: "\{ind}    \{rx} = _sw\{sN};\n"
        buf.append s3.stringview
        s4: "\{ind}}\n"
        buf.append s4.stringview
    } case ifexpr then {
        ifAssign: "".string
        first: true
        citer: n.clauses.iterate
        for c: citer loop {
            isFirst: first
            first = false
            emitIfClause symtab: symtab ctx: ctx n: c isFirst: isFirst assignTo: ifAssign.stringview ind: ind tmp: tmp buf: buf
        }
        match (
            n.elseclause
        ) case some then {
        } case none then {}
        emitElse9 symtab: symtab ctx: ctx o: n.elseclause assignTo: ifAssign.stringview ind: ind tmp: tmp buf: buf
        le: "\{ind}}\n"
        buf.append le.stringview
    } case caseexpr then {
        emitMatchStmt symtab: symtab ctx: ctx m: n assignTo: "" ind: ind tmp: tmp buf: buf
    } case withexpr then {
        wn9: n.name.stringview
        wnm: wn9.string
        wtn: stampNameDeep symtab: symtab n: n.value
        wct: cTypeForName symtab: symtab ctx: ctx name: wtn.stringview
        wv: emitExpr symtab: symtab ctx: ctx n: n.value
        if wct.length > 0.u64 then {
            lwv: "\{ind}\{wct} \{wnm} = \{wv};\n"
            buf.append lwv.stringview
        } else {
            lwv2: "\{ind}int64_t \{wnm} = \{wv};\n"
            buf.append lwv2.stringview
        }
        emitBodyNode symtab: symtab ctx: ctx n: n.body ind: ind tmp: tmp buf: buf
    } case forexpr then {
        if (emitObjIterFor symtab: symtab ctx: ctx m: n ind: ind tmp: tmp buf: buf) then {
            return
        } else {}
        if (emitIntRangeFor symtab: symtab ctx: ctx m: n ind: ind tmp: tmp buf: buf) then {
            return
        } else {}
        # do-while: no pre-conditions, a post-condition (`for loop {...} while C`).
        if n.conditions.length == 0.u64 when n.postconditions.length > 0.u64 then {
            ldw: "\{ind}do {\n"
            buf.append ldw.stringview
            ind2d: "\{ind}    "
            fLd9: tmp.frees.length
            lLd9: tmp.listFrees.length
            emitBodyOpt symtab: symtab ctx: ctx o: n.body ind: ind2d.stringview tmp: tmp buf: buf
            flushBlockFrees ctx: ctx tmp: tmp fL: fLd9 lL: lLd9 buf: buf
            pcond: "".string
            pkiter: n.postconditions.iterate
            for pk: pkiter loop {
                pcv: emitExpr symtab: symtab ctx: ctx n: pk
                if pcond.length > 0.u64 then {
                    pcond.append " && "
                } else {}
                pcond.append pcv.stringview
            }
            if pcond.length == 0.u64 then {
                pcond.append "0"
            } else {}
            lpw: "\{ind}} while (\{pcond});\n"
            buf.append lpw.stringview
            return
        } else {}
        cond: "".string
        kiter: n.conditions.iterate
        for k: kiter loop {
            emitForCond symtab: symtab ctx: ctx n: k cond: cond ind: ind tmp: tmp buf: buf
        }
        if cond.length == 0.u64 then {
            # an unhandled loop header must not spin: emit a skipped
            # loop (honest RUN-DIFF) rather than while(1).
            cond.append "0 /* zemitterc: unhandled loop header */"
        } else {}
        lw: "\{ind}while (\{cond}) {\n"
        buf.append lw.stringview
        ind2: "\{ind}    "
        fLw9: tmp.frees.length
        lLw9: tmp.listFrees.length
        emitBodyOpt symtab: symtab ctx: ctx o: n.body ind: ind2.stringview tmp: tmp buf: buf
        flushBlockFrees ctx: ctx tmp: tmp fL: fLw9 lL: lLw9 buf: buf
        lwc: "\{ind}}\n"
        buf.append lwc.stringview
    } case yieldexpr then {
        emitYieldStmt symtab: symtab ctx: ctx yd: n ind: ind tmp: tmp buf: buf
    } else {
        # a no-arg method auto-call in statement position (this.accept,
        # this.statepop) is a dotted path: emit the call expression as a statement.
        if (nodeIsDotted9 n: n) then {
            # `.release` on a protocol is a transfer marker (scope-exit destroy
            # covers it) -- emit nothing, like emitCallStmt.
            dct9: dottedChildText n: n
            isRel9: false
            if dct9.stringview == "release" then {
                rrid9: dottedReceiverStampId symtab: symtab callable: n
                if (symtab.reg.typetypeOf typeId: rrid9) == ztypes.ztypetype.PROTOCOL then {
                    isRel9 = true
                } else {}
            } else {}
            if isRel9 then {
                return
            } else {}
            de9: emitExpr symtab: symtab ctx: ctx n: n
            if (de9.stringview.startsWith prefix: "/*") then {
                lud9: "\{ind}/* zemitterc: unhandled statement */\n"
                buf.append lud9.stringview
            } else {
                dss9: "\{ind}\{de9};\n"
                buf.append dss9.stringview
            }
            return
        } else {}
        # bare control keywords parse as an AtomId reference (no value): a
        # no-value `return` (goto L_done inside a generator), `break`, `continue`.
        bkw9: atomTextOf n: n
        if bkw9.stringview == "return" then {
            if ctx.genActive then {
                lgd9: "\{ind}goto L_done;\n"
                buf.append lgd9.stringview
            } else {
                lrt9: "\{ind}return;\n"
                buf.append lrt9.stringview
            }
        } else {
            if bkw9.stringview == "break" then {
                lbk9: "\{ind}break;\n"
                buf.append lbk9.stringview
            } else {
                if bkw9.stringview == "continue" then {
                    lct9: "\{ind}continue;\n"
                    buf.append lct9.stringview
                } else {
                    lu: "\{ind}/* zemitterc: unhandled statement */\n"
                    buf.append lu.stringview
                }
            }
        }
    }
}

# resolveTypeIdByName -- a type id for a name: main-unit, then mono table,
# then the cross-unit lookup. 0 when unresolved.
resolveTypeIdByName: function {symtab: zenv.ZSymbolTable ctx: Ctx name: StringView} out u64 is {
    f: userFnId symtab: symtab ctx: ctx name: name
    if f > 0.u64 then {
        return f
    } else {}
    mo: symtab.typing.monoByName.get key: name.string
    match (
        mo
    ) case some then {
        return mo
    } case none then {}
    return (optU64Or9 o: (ztypecheck.lookupTyperef resolved: symtab.typing.resolved mainName: ctx.mainName.stringview base: name))
}

# emitMatchStmt -- a variant-subject match as a tag switch over a temp;
# payload arms shadow the subject name with the payload value.
emitMatchStmt: function {symtab: zenv.ZSymbolTable ctx: Ctx m: zast.CaseData assignTo: StringView ind: StringView tmp: TmpCtr buf: String.borrow} is {
    sx: emitExpr symtab: symtab ctx: ctx n: m.subject
    stn: stampNameDeep symtab: symtab n: m.subject
    vtid: resolveTypeIdByName symtab: symtab ctx: ctx name: stn.stringview
    isVar: false
    isUni: false
    if vtid > 0.u64 then {
        vtt0: symtab.reg.typetypeOf typeId: vtid
        if vtt0 == ztypes.ztypetype.VARIANT then { isVar = true } else {}
        if vtt0 == ztypes.ztypetype.UNION then { isUni = true } else {}
    } else {}
    if isVar then {} else {
        if isUni then {} else {
            sct: cTypeOf name: stn.stringview
            if sct.length > 0.u64 then {
                emitScalarMatch symtab: symtab ctx: ctx m: m subj: sx.stringview assignTo: assignTo ind: ind tmp: tmp buf: buf
                return
            } else {}
            lu0: "\{ind}/* zemitterc: unhandled match subject type \{stn} */\n"
            buf.append lu0.stringview
            return
        }
    }
    vn: typeNameOfReg9 symtab: symtab tid: vtid
    vc: cnameOf tid: vtid name: vn.stringview
    mN: tmp.next
    l0: "\{ind}\{vc}_t _m\{mN} = \{sx};\n"
    buf.append l0.stringview
    l1: "\{ind}switch (_m\{mN}.tag) {\n"
    buf.append l1.stringview
    sname: atomTextDeep n: m.subject
    ind2: "\{ind}    "
    citer: m.clauses.iterate
    for c: citer loop {
        emitMatchClause symtab: symtab ctx: ctx c: c vtid: vtid isUni: isUni mN: mN sname: sname.stringview assignTo: assignTo ind: ind2.stringview tmp: tmp buf: buf
    }
    emitMatchElse symtab: symtab ctx: ctx o: m.elseclause assignTo: assignTo ind: ind2.stringview tmp: tmp buf: buf
    l9: "\{ind}}\n"
    buf.append l9.stringview
}

# emitScalarMatch -- a value match over a scalar subject: a C switch with
# constant arm labels (arm names resolve through the constant pool).
emitScalarMatch: function {symtab: zenv.ZSymbolTable ctx: Ctx m: zast.CaseData subj: StringView assignTo: StringView ind: StringView tmp: TmpCtr buf: String.borrow} is {
    l0: "\{ind}switch (\{subj}) {\n"
    buf.append l0.stringview
    ind2: "\{ind}    "
    citer: m.clauses.iterate
    for c: citer loop {
        emitScalarClause symtab: symtab ctx: ctx c: c assignTo: assignTo ind: ind2.stringview tmp: tmp buf: buf
    }
    emitMatchElse symtab: symtab ctx: ctx o: m.elseclause assignTo: assignTo ind: ind2.stringview tmp: tmp buf: buf
    l9: "\{ind}}\n"
    buf.append l9.stringview
}

# scalarArmLabel -- the C case label for a scalar arm: the constant
# pool's rendering when the arm names a constant, else the name itself.
scalarArmLabel: function {ctx: Ctx arm: StringView} out String is {
    ck: arm.string
    cgo: ctx.constVals.get key: ck
    match (
        cgo
    ) case some then {
        cvv: cgo.stringview
        cvc: cvv.string
        return cvc
    } case none then {
        ac: arm.string
        return ac
    }
}

# flushBlockFrees -- emit + reclaim the heap/collection destructors registered
# since (fL, lL) so a local declared inside a block (a match arm) is freed at
# block end, not function end (where it is out of C scope). LIFO order.
flushBlockFrees: function {ctx: Ctx tmp: TmpCtr fL: u64 lL: u64 buf: String.borrow} is {
    for while tmp.listFrees.length > lL loop {
        lvo: tmp.listFrees.pop
        buf.append lvo.stringview
    }
    for while tmp.frees.length > fL loop {
        fvo: tmp.frees.pop
        ff9: "    \{ctx.strC}_free(&\{fvo});\n"
        buf.append ff9.stringview
    }
}

emitScalarClause: function {symtab: zenv.ZSymbolTable ctx: Ctx c: Node assignTo: StringView ind: StringView tmp: TmpCtr buf: String.borrow} is {
    match (
        c
    ) case caseclause then {
        arm: c.name.stringview
    lbl: scalarArmLabel ctx: ctx arm: arm
        l2: "\{ind}case \{lbl}: {\n"
        buf.append l2.stringview
        ind3: "\{ind}    "
        if assignTo.length > 0.u64 then {
            vx9: emitExpr symtab: symtab ctx: ctx n: c.statement
            la9: "\{ind}    \{assignTo} = \{vx9};\n"
            buf.append la9.stringview
        } else {
            fL9: tmp.frees.length
            lL9: tmp.listFrees.length
            emitBodyNode symtab: symtab ctx: ctx n: c.statement ind: ind3.stringview tmp: tmp buf: buf
            flushBlockFrees ctx: ctx tmp: tmp fL: fL9 lL: lL9 buf: buf
        }
        l5: "\{ind}    break;\n"
        buf.append l5.stringview
        l6: "\{ind}}\n"
        buf.append l6.stringview
    } else {}
}

emitMatchClause: function {symtab: zenv.ZSymbolTable ctx: Ctx c: Node vtid: u64 isUni: bool mN: u64 sname: StringView assignTo: StringView ind: StringView tmp: TmpCtr buf: String.borrow} is {
    match (
        c
    ) case caseclause then {
        arm: c.name.stringview
        tg: variantTag symtab: symtab tid: vtid arm: arm
        l2: "\{ind}case \{tg}: {\n"
        buf.append l2.stringview
        pc: armPayloadC symtab: symtab ctx: ctx tid: vtid arm: arm
        ind3: "\{ind}    "
        if pc.length > 0.u64 when sname.length > 0.u64 then {
            if isUni then {
                l3u: "\{ind}    \{pc} \{sname} = *(\{pc}*)_m\{mN}.data;\n"
                buf.append l3u.stringview
            } else {
                l3: "\{ind}    \{pc} \{sname} = _m\{mN}.data.\{arm};\n"
                buf.append l3.stringview
            }
            l4: "\{ind}    (void)\{sname};\n"
            buf.append l4.stringview
        } else {}
        if assignTo.length > 0.u64 then {
            vx9: emitExpr symtab: symtab ctx: ctx n: c.statement
            la9: "\{ind}    \{assignTo} = \{vx9};\n"
            buf.append la9.stringview
        } else {
            fL9: tmp.frees.length
            lL9: tmp.listFrees.length
            emitBodyNode symtab: symtab ctx: ctx n: c.statement ind: ind3.stringview tmp: tmp buf: buf
            flushBlockFrees ctx: ctx tmp: tmp fL: fL9 lL: lL9 buf: buf
        }
        l5: "\{ind}    break;\n"
        buf.append l5.stringview
        l6: "\{ind}}\n"
        buf.append l6.stringview
    } else {}
}

emitMatchElse: function {symtab: zenv.ZSymbolTable ctx: Ctx o: (Option t: Node) assignTo: StringView ind: StringView tmp: TmpCtr buf: String.borrow} is {
    match (
        o
    ) case some then {
        l7: "\{ind}default: {\n"
        buf.append l7.stringview
        ind3: "\{ind}    "
        if assignTo.length > 0.u64 then {
            vx8: emitExpr symtab: symtab ctx: ctx n: o
            la8: "\{ind}    \{assignTo} = \{vx8};\n"
            buf.append la8.stringview
        } else {
            emitBodyNode symtab: symtab ctx: ctx n: o ind: ind3.stringview tmp: tmp buf: buf
        }
        l8: "\{ind}    break;\n"
        buf.append l8.stringview
        l9: "\{ind}}\n"
        buf.append l9.stringview
    } case none then {
        ld0: "\{ind}default: break;\n"
        buf.append ld0.stringview
    }
}

# emitMatchBindValue -- `x: (match c case ok then 1 ...)`: declare the
# local and assign per arm; false when the value is not a match.
emitMatchBindValue: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node nm: StringView ct: StringView ind: StringView tmp: TmpCtr buf: String.borrow} out bool is {
    match (
        n
    ) case expression then {
        return (emitMatchBindValue symtab: symtab ctx: ctx n: n.expression nm: nm ct: ct ind: ind tmp: tmp buf: buf)
    } case caseexpr then {
        ld: "\{ind}\{ct} \{nm};\n"
        buf.append ld.stringview
        emitMatchStmt symtab: symtab ctx: ctx m: n assignTo: nm ind: ind tmp: tmp buf: buf
        return true
    } else {
        return false
    }
}

# emitIfBindValue -- `s: if c then a else b`: declare the local and emit
# an if-statement assigning the branch value to it; false otherwise.
emitIfBindValue: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node nm: StringView ct: StringView ind: StringView tmp: TmpCtr buf: String.borrow} out bool is {
    match (
        n
    ) case expression then {
        return (emitIfBindValue symtab: symtab ctx: ctx n: n.expression nm: nm ct: ct ind: ind tmp: tmp buf: buf)
    } case ifexpr then {
        ld: "\{ind}\{ct} \{nm};\n"
        buf.append ld.stringview
        first: true
        citer: n.clauses.iterate
        for c: citer loop {
            isFirst: first
            first = false
            emitIfClause symtab: symtab ctx: ctx n: c isFirst: isFirst assignTo: nm ind: ind tmp: tmp buf: buf
        }
        emitElse9 symtab: symtab ctx: ctx o: n.elseclause assignTo: nm ind: ind tmp: tmp buf: buf
        le: "\{ind}}\n"
        buf.append le.stringview
        return true
    } else {
        return false
    }
}

# childExists -- does the type have a child of this name.
childExists: function {symtab: zenv.ZSymbolTable tid: u64 name: StringView} out bool is {
    co: symtab.typing.childOf parentTypeId: tid name: name
    match (
        co
    ) case some then {
        return true
    } case none then {
        return false
    }
}

# loopVarTypeName -- the yield type name of an iterator loop, read from
# the loop variable's first stamped reference in the body ("" if none).
loopVarTypeName: function {symtab: zenv.ZSymbolTable body: (Option t: Node) lbl: StringView} out String is {
    res: "".string
    match (
        body
    ) case some then {
        scanLoopVar symtab: symtab n: body lbl: lbl res: res
    } case none then {}
    return res
}

scanLoopVar: function {symtab: zenv.ZSymbolTable n: Node lbl: StringView res: String.borrow} is {
    if res.length > 0.u64 then {
        return
    } else {}
    match (
        n
    ) case atomid then {
        if n.name.stringview == lbl then {
            tid: stampIdOf symtab: symtab nid: n.nodeid.u64
            if tid > 0.u64 then {
                tn: typeNameOfReg9 symtab: symtab tid: tid
                if tn.length > 0.u64 then {
                    tv: tn.stringview
                    res.append tv
                } else {}
            } else {}
        } else {}
    } case expression then {
        scanLoopVar symtab: symtab n: n.expression lbl: lbl res: res
    } case statement then {
        with sit: n.statements.iterate do for s: sit loop {
            scanLoopVar symtab: symtab n: s lbl: lbl res: res
        }
    } case statementline then {
        scanLoopVar symtab: symtab n: n.statementline lbl: lbl res: res
    } case call then {
        with ait: n.arguments.iterate do for a: ait loop {
            scanLoopVar symtab: symtab n: a lbl: lbl res: res
        }
    } case namedoperation then {
        scanLoopVar symtab: symtab n: n.operation lbl: lbl res: res
    } case binop then {
        scanLoopVar symtab: symtab n: n.lhs lbl: lbl res: res
        scanLoopVar symtab: symtab n: n.rhs lbl: lbl res: res
    } case atomstring then {
        with pit: n.stringparts.iterate do for p: pit loop {
            scanLoopVar symtab: symtab n: p lbl: lbl res: res
        }
    } else {}
}

# emitObjIterFor -- `for x: <iter> loop` where <iter> is an iterator value
# (a type with a `.call` child returning optionval/Option). Emits the
# while(1) / call / tag==NONE break / payload-extract pattern. Value
# payloads (optionval) extract `.data.some`; reftype payloads (Option)
# wait on the heap-extract slice. Returns false when not an iterator loop.
# iterableNodeId -- the stamped node id of a for-loop iterable: peel expression
# wrappers, then take the inner atom / dotted-field / call node (the expression
# wrapper itself may be unstamped for a `this._iterN` field iterator).
iterableNodeId: function {n: Node} out u64 is {
    match (
        n
    ) case expression then {
        return (iterableNodeId n: n.expression)
    } case atomid then {
        return n.nodeid.u64
    } case dottedpath then {
        return n.nodeid.u64
    } case call then {
        return n.nodeid.u64
    } else {
        return 0.u64
    }
}

# isForIterCall -- the for-loop iterable is a call expression (an rvalue that
# must be hoisted to a temp before `&recv`); a bare atom / dotted field is an
# lvalue used directly.
isForIterCall: function {n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (isForIterCall n: n.expression)
    } case call then {
        return true
    } else {
        return false
    }
}

emitObjIterFor: function {symtab: zenv.ZSymbolTable ctx: Ctx m: zast.ForData ind: StringView tmp: TmpCtr buf: String.borrow} out bool is {
    if m.conditions.length != 1.u64 then {
        return false
    } else {}
    c0: m.conditions.get i: 0.u64
    match (
        c0
    ) case namedoperation then {
        lbl: unitLabel9 o: c0.name
        if lbl.length == 0.u64 then {
            return false
        } else {}
        oeid: iterableNodeId n: c0.operation
        itid0: stampIdOf symtab: symtab nid: oeid
        if itid0 == 0.u64 then {
            oeidF: exprNodeId9 n: c0.operation
            itid0 = stampIdOf symtab: symtab nid: oeidF
        } else {}
        itid: itid0
        # bare generator-fn iterable (`for x: counter loop`): itid0 is the
        # generator function itself; resolve via its return type (the iterator
        # class) and auto-call it below.
        bareFnId9: 0.u64
        if (symtab.reg.typetypeOf typeId: itid0) == ztypes.ztypetype.FUNCTION then {
            brt9: 0.u64
            btx9: symtab.reg.typeById.get key: itid0
            match (
                btx9
            ) case some then {
                brto9: btx9.returnTypeId
                match (
                    brto9
                ) case some then {
                    brt9 = brto9
                } case none then {}
            } case none then {}
            if brt9 == 0.u64 then {
                mro9: ztypecheck.methodReturnOf st: symtab mid: itid0
                match (
                    mro9
                ) case some then {
                    brt9 = mro9
                } case none then {}
            } else {}
            if brt9 > 0.u64 when (childExists symtab: symtab tid: brt9 name: "call") then {
                itid = brt9
                bareFnId9 = itid0
            } else {}
        } else {}
        if itid == 0.u64 then {
            return false
        } else {}
        if bareFnId9 == 0.u64 then {
            itn0: typeNameOfReg9 symtab: symtab tid: itid0
            cano: ztypecheck.lookupTyperef resolved: symtab.typing.resolved mainName: ctx.mainName.stringview base: itn0.stringview
            match (
                cano
            ) case some then {
                if (childExists symtab: symtab tid: cano name: "call") then {
                    itid = cano
                } else {}
            } case none then {}
        } else {}
        cco: symtab.typing.childOf parentTypeId: itid name: "call"
        match (
            cco
        ) case some then {
            ovid: 0.u64
            {
                ct: symtab.reg.typeById.get key: cco
                match (
                    ct
                ) case some then {
                    rto: ct.returnTypeId
                    match (
                        rto
                    ) case some then {
                        ovid = rto
                    } case none then {}
                } case none then {}
            }
            if ovid == 0.u64 then {
                # user-class iterator: returnTypeId unset, but the .call return
                # node carries the mono stamp.
                mro: ztypecheck.methodReturnOf st: symtab mid: cco
                match (
                    mro
                ) case some then {
                    ovid = mro
                } case none then {}
            } else {}
            if ovid == 0.u64 then {
                # native iterator call: returnTypeId unset. Resolve the
                # yield type from the loop var's body usage -> optionval_T.
                ytn: loopVarTypeName symtab: symtab body: m.body lbl: lbl.stringview
                if ytn.length == 0.u64 then {
                    return false
                } else {}
                ovnm: "optionval_\{ytn}".string
                ovo: symtab.typing.monoByName.get key: ovnm.stringview.string
                match (
                    ovo
                ) case some then {
                    ovid = ovo
                } case none then {
                    return false
                }
            } else {}
            itn: typeNameOfReg9 symtab: symtab tid: itid
            # a main-unit user-class iterator's .call is emitted by emitOneMethod
            # (its own cname id); native/collection iterators (CpIter, SetIter,
            # emitted with the type-id cname) keep the template's `{type}_call`.
            callC: "".string
            itUfn9: userFnId symtab: symtab ctx: ctx name: itn.stringview
            isUserCls9: false
            if itUfn9 > 0.u64 when (symtab.reg.typetypeOf typeId: itid) == ztypes.ztypetype.CLASS then {
                # exclude collection monos (SetIter etc., monoOriginName != "")
                itorig9: monoOriginName symtab: symtab tid: itid
                if itorig9.length == 0.u64 then {
                    isUserCls9 = true
                } else {}
            } else {}
            if isUserCls9 then {
                ccn9: typeNameOfReg9 symtab: symtab tid: cco
                callC = cnameOf tid: cco name: ccn9.stringview
            } else {
                itc9: cnameOf tid: itid name: itn.stringview
                callC = "\{itc9}_call".string
            }
            ovn: typeNameOfReg9 symtab: symtab tid: ovid
            ovc: cnameOf tid: ovid name: ovn.stringview
            ovu: cUpperOf text: ovn.stringview
            payC: armPayloadC symtab: symtab ctx: ctx tid: ovid arm: "some"
            oovorig: monoOriginName symtab: symtab tid: ovid
            mN: tmp.next
            itCb9: cnameOf tid: itid name: itn.stringview
            iterRecv9: "".string
            if bareFnId9 > 0.u64 then {
                bnm9: typeNameOfReg9 symtab: symtab tid: bareFnId9
                bcn9: cnameOf tid: bareFnId9 name: bnm9.stringview
                lgh9: "\{ind}\{itCb9}_t _git\{mN} = \{bcn9}();\n"
                buf.append lgh9.stringview
                iterRecv9 = "_git\{mN}".string
            } else {
                ivex9: emitExpr symtab: symtab ctx: ctx n: c0.operation
                if (isForIterCall n: c0.operation) then {
                    lgi9: "\{ind}\{itCb9}_t _git\{mN} = \{ivex9};\n"
                    buf.append lgi9.stringview
                    iterRecv9 = "_git\{mN}".string
                } else {
                    iterRecv9 = ivex9
                }
            }
            l0: "\{ind}while (1) {\n"
            buf.append l0.stringview
            l1: "\{ind}    \{ovc}_t _iter\{mN} = \{callC}(&\{iterRecv9});\n"
            buf.append l1.stringview
            if oovorig.stringview == "Option" then {
                # owned heap-payload union: destroy the box on the NONE arm too.
                l2o: "\{ind}    if (_iter\{mN}.tag == Z_\{ovu}_TAG_NONE) { \{ovc}_destroy(&_iter\{mN}); break; }\n"
                buf.append l2o.stringview
            } else {
                l2: "\{ind}    if (_iter\{mN}.tag == Z_\{ovu}_TAG_NONE) break;\n"
                buf.append l2.stringview
            }
            if oovorig.stringview == "OptionView" then {
                # borrowed-view yield: scalar payloads copy by value; aggregate
                # payloads bind a borrowed pointer (no copy -> the shared fields
                # are never double-freed).
                payElemPfx: oovorig.length + 1.u64
                payElemName: monoElemName full: ovn prefixLen: payElemPfx
                payScalarC: cTypeOf name: payElemName.stringview
                if payScalarC.length > 0.u64 then {
                    l3v: "\{ind}    \{payC} \{lbl} = *(\{payC}*)_iter\{mN}.data;\n"
                    buf.append l3v.stringview
                } else {
                    l3p: "\{ind}    \{payC}* \{lbl} = (\{payC}*)_iter\{mN}.data;\n"
                    buf.append l3p.stringview
                }
            } else if oovorig.stringview == "Option" then {
                # owned heap yield: move the payload out, free just the box; the
                # loop var owns it and is freed at the end of each iteration.
                l3op: "\{ind}    \{payC} \{lbl} = *(\{payC}*)_iter\{mN}.data;\n"
                buf.append l3op.stringview
                l3of: "\{ind}    free(_iter\{mN}.data);\n"
                buf.append l3of.stringview
            } else {
                l3: "\{ind}    \{payC} \{lbl} = _iter\{mN}.data.some;\n"
                buf.append l3.stringview
            }
            ind2: "\{ind}    "
            emitBodyOpt symtab: symtab ctx: ctx o: m.body ind: ind2.stringview tmp: tmp buf: buf
            if oovorig.stringview == "Option" then {
                freeFn: payloadDestructor symtab: symtab ctx: ctx tid: ovid arm: "some"
                if freeFn.length > 0.u64 then {
                    l3od: "\{ind}    \{freeFn}(&\{lbl});\n"
                    buf.append l3od.stringview
                } else {}
            } else {}
            l9: "\{ind}}\n"
            buf.append l9.stringview
            return true
        } case none then {
            return false
        }
    } else {
        return false
    }
}

# emitIntRangeFor -- `for x: N.iterate loop` / `for x: (N.iterate from: F)`:
# a counted C for-loop `for (T x = F; x < N; x++)`. Returns false when the
# header is not a single integer-range binding.
emitIntRangeFor: function {symtab: zenv.ZSymbolTable ctx: Ctx m: zast.ForData ind: StringView tmp: TmpCtr buf: String.borrow} out bool is {
    if m.conditions.length != 1.u64 then {
        return false
    } else {}
    c0: m.conditions.get i: 0.u64
    match (
        c0
    ) case namedoperation then {
        lbl: unitLabel9 o: c0.name
        if lbl.length == 0.u64 then {
            return false
        } else {}
        bound: rangeBoundExpr symtab: symtab ctx: ctx n: c0.operation
        if bound.length == 0.u64 then {
            return false
        } else {}
        fromx: rangeFromExpr symtab: symtab ctx: ctx n: c0.operation
        lh: "\{ind}for (int64_t \{lbl} = \{fromx}; \{lbl} < (int64_t)(\{bound}); \{lbl}++) {\n"
        buf.append lh.stringview
        ind2: "\{ind}    "
        emitBodyOpt symtab: symtab ctx: ctx o: m.body ind: ind2.stringview tmp: tmp buf: buf
        lc: "\{ind}}\n"
        buf.append lc.stringview
        return true
    } else {
        return false
    }
}

# rangeBoundExpr -- the upper bound of an `N.iterate` range (the dotted
# receiver N); "" when the operation is not an iterate call.
rangeBoundExpr: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out String is {
    match (
        n
    ) case expression then {
        return (rangeBoundExpr symtab: symtab ctx: ctx n: n.expression)
    } case call then {
        mn: dottedChildText n: n.callable
        if mn.stringview == "iterate" then {
            return (rangeReceiver symtab: symtab ctx: ctx n: n.callable)
        } else {}
        return "".string
    } case dottedpath then {
        cmn: atomTextOf n: n.child
        if cmn.stringview == "iterate" then {
            # the receiver may be a dotted-path itself (squares.length.iterate)
            # -- stampNameDeep resolves its scalar type either way.
            btn: stampNameDeep symtab: symtab n: n.parent
            if (cTypeOf name: btn.stringview).length > 0.u64 then {
                return (emitExpr symtab: symtab ctx: ctx n: n.parent)
            } else {}
        } else {}
        return "".string
    } else {
        return "".string
    }
}

# rangeReceiver -- the C expression for the receiver of a `.iterate`
# dotted callable.
rangeReceiver: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        return (emitExpr symtab: symtab ctx: ctx n: n.parent)
    } else {
        return "".string
    }
}

# rangeFromExpr -- the `from:` argument of an iterate range, or "0".
rangeFromExpr: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out String is {
    match (
        n
    ) case expression then {
        return (rangeFromExpr symtab: symtab ctx: ctx n: n.expression)
    } case call then {
        aiter: n.arguments.iterate
        for a: aiter loop {
            match (
                a
            ) case namedoperation then {
                an: unitLabel9 o: a.name
                if an.stringview == "from" then {
                    return (emitExpr symtab: symtab ctx: ctx n: a.operation)
                } else {}
            } else {}
        }
        return "0".string
    } else {
        return "0".string
    }
}

# emitForCond -- one for-header arm: a `while:` arm joins the loop
# condition; a named binding arm emits its init before the loop.
emitForCond: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node cond: String.borrow ind: StringView tmp: TmpCtr buf: String.borrow} is {
    match (
        n
    ) case namedoperation then {
        lbl: unitLabel9 o: n.name
        if lbl.length == 0.u64 then {
            cv: emitExpr symtab: symtab ctx: ctx n: n.operation
            if cond.length > 0.u64 then {
                cond.append " && "
            } else {}
            cond.append cv.stringview
        } else {
            onid: exprNodeId9 n: n.operation
            tn: stampNameOf symtab: symtab nid: onid
            ct: cTypeOf name: tn.stringview
            iv: emitExpr symtab: symtab ctx: ctx n: n.operation
            if ct.length > 0.u64 then {
                li: "\{ind}\{ct} \{lbl} = \{iv};\n"
                buf.append li.stringview
            } else {
                li2: "\{ind}int64_t \{lbl} = \{iv};\n"
                buf.append li2.stringview
            }
        }
    } else {}
}

exprNodeId9: function {n: Node} out u64 is {
    match (
        n
    ) case expression then {
        return n.nodeid.u64
    } case atomid then {
        return n.nodeid.u64
    } else {
        return 0.u64
    }
}

emitIfClause: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node isFirst: bool assignTo: StringView ind: StringView tmp: TmpCtr buf: String.borrow} is {
    match (
        n
    ) case ifclause then {
        cond: "".string
        kiter: n.conditions.iterate
        for k: kiter loop {
            match (
                k
            ) case namedoperation then {
                cv: emitExpr symtab: symtab ctx: ctx n: k.operation
                if cond.length > 0.u64 then {
                    cond.append " && "
                } else {}
                cond.append cv.stringview
            } else {}
        }
        if isFirst then {
            lf: "\{ind}if (\{cond}) {\n"
            buf.append lf.stringview
        } else {
            lg: "\{ind}} else if (\{cond}) {\n"
            buf.append lg.stringview
        }
        ind2: "\{ind}    "
        if assignTo.length > 0.u64 then {
            emitBranchAssign symtab: symtab ctx: ctx n: n.statement target: assignTo ind: ind2.stringview tmp: tmp buf: buf
        } else {
            fLi9: tmp.frees.length
            lLi9: tmp.listFrees.length
            emitBodyNode symtab: symtab ctx: ctx n: n.statement ind: ind2.stringview tmp: tmp buf: buf
            flushBlockFrees ctx: ctx tmp: tmp fL: fLi9 lL: lLi9 buf: buf
        }
    } else {}
}

emitElse9: function {symtab: zenv.ZSymbolTable ctx: Ctx o: (Option t: Node) assignTo: StringView ind: StringView tmp: TmpCtr buf: String.borrow} is {
    match (
        o
    ) case some then {
        lh: "\{ind}} else {\n"
        buf.append lh.stringview
        ind2: "\{ind}    "
        if assignTo.length > 0.u64 then {
            emitBranchAssign symtab: symtab ctx: ctx n: o target: assignTo ind: ind2.stringview tmp: tmp buf: buf
        } else {
            fLe9: tmp.frees.length
            lLe9: tmp.listFrees.length
            emitBodyNode symtab: symtab ctx: ctx n: o ind: ind2.stringview tmp: tmp buf: buf
            flushBlockFrees ctx: ctx tmp: tmp fL: fLe9 lL: lLe9 buf: buf
        }
    } case none then {}
}

# emitBranchAssign -- emit an if/match branch whose final value assigns
# to a target: a block emits all but its last statement normally, the
# last as `target = <value>`; a single node assigns directly.
emitBranchAssign: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node target: StringView ind: StringView tmp: TmpCtr buf: String.borrow} is {
    match (
        n
    ) case statement then {
        cnt: n.statements.length
        si: 0.u64
        for while si < cnt loop {
            sx: n.statements.get i: si
            if si + 1.u64 == cnt then {
                vx: emitExpr symtab: symtab ctx: ctx n: sx
                la: "\{ind}\{target} = \{vx};\n"
                buf.append la.stringview
            } else {
                emitStmt symtab: symtab ctx: ctx n: sx ind: ind tmp: tmp buf: buf
            }
            si = si + 1.u64
        }
    } else {
        vx2: emitExpr symtab: symtab ctx: ctx n: n
        la2: "\{ind}\{target} = \{vx2};\n"
        buf.append la2.stringview
    }
}

emitBodyNode: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node ind: StringView tmp: TmpCtr buf: String.borrow} is {
    match (
        n
    ) case statement then {
        siter: n.statements.iterate
        for s: siter loop {
            emitStmt symtab: symtab ctx: ctx n: s ind: ind tmp: tmp buf: buf
        }
    } else {
        emitStmt symtab: symtab ctx: ctx n: n ind: ind tmp: tmp buf: buf
    }
}

emitBodyOpt: function {symtab: zenv.ZSymbolTable ctx: Ctx o: (Option t: Node) ind: StringView tmp: TmpCtr buf: String.borrow} is {
    match (
        o
    ) case some then {
        emitBodyNode symtab: symtab ctx: ctx n: o ind: ind tmp: tmp buf: buf
    } case none then {}
}

# forexprValue -- the value being bound is a for-loop (a list comprehension).
forexprValue: function {n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (forexprValue n: n.expression)
    } case forexpr then {
        return true
    } else {
        return false
    }
}

# emitComprehensionBody -- unwrap the body Option (borrowed via the param) and
# emit its statements, the last appended to the list.
emitComprehensionBody: function {symtab: zenv.ZSymbolTable ctx: Ctx body: (Option t: Node) listCb: StringView listVar: StringView ind: StringView tmp: TmpCtr buf: String.borrow} is {
    match (
        body
    ) case some then {
        emitComprehensionNode symtab: symtab ctx: ctx n: body listCb: listCb listVar: listVar ind: ind tmp: tmp buf: buf
    } case none then {}
}

# emitComprehensionNode -- the body's statements: each but the last emits
# normally; the last is the value expression, appended to the list.
emitComprehensionNode: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node listCb: StringView listVar: StringView ind: StringView tmp: TmpCtr buf: String.borrow} is {
    match (
        n
    ) case statement then {
        cnt: n.statements.length
        si: 0.u64
        for while si < cnt loop {
            st: n.statements.get i: si
            if si == (cnt - 1.u64) then {
                av: emitExpr symtab: symtab ctx: ctx n: st
                la: "\{ind}\{listCb}_append(&\{listVar}, (\{av}));\n"
                buf.append la.stringview
            } else {
                emitStmt symtab: symtab ctx: ctx n: st ind: ind tmp: tmp buf: buf
            }
            si = si + 1.u64
        }
    } else {
        av2: emitExpr symtab: symtab ctx: ctx n: n
        la2: "\{ind}\{listCb}_append(&\{listVar}, (\{av2}));\n"
        buf.append la2.stringview
    }
}

# emitListComprehension -- populate listVar from `for x: N.iterate loop { expr }`:
# a counted for-loop whose body appends the comprehension's value expression.
emitListComprehension: function {symtab: zenv.ZSymbolTable ctx: Ctx forNode: Node listCb: StringView listVar: StringView ind: StringView tmp: TmpCtr buf: String.borrow} is {
    match (
        forNode
    ) case expression then {
        emitListComprehension symtab: symtab ctx: ctx forNode: forNode.expression listCb: listCb listVar: listVar ind: ind tmp: tmp buf: buf
    } case forexpr then {
        if forNode.conditions.length != 1.u64 then {
            return
        } else {}
        c0: forNode.conditions.get i: 0.u64
        match (
            c0
        ) case namedoperation then {
            lbl: unitLabel9 o: c0.name
            bound: rangeBoundExpr symtab: symtab ctx: ctx n: c0.operation
            from: rangeFromExpr symtab: symtab ctx: ctx n: c0.operation
            if bound.length == 0.u64 then {
                return
            } else {}
            fh: "\{ind}for (int64_t \{lbl} = \{from}; \{lbl} < \{bound}; \{lbl}++) {\n"
            buf.append fh.stringview
            ind2: "\{ind}    "
            emitComprehensionBody symtab: symtab ctx: ctx body: forNode.body listCb: listCb listVar: listVar ind: ind2.stringview tmp: tmp buf: buf
            lcc9: "\{ind}}\n"
            buf.append lcc9.stringview
        } else {}
    } else {}
}

# unitLabel9 -- a namedoperation's label text ("" when absent).
unitLabel9: function {o: (Option t: String)} out String is {
    match (
        o
    ) case some then {
        ov: o.stringview
        oc: ov.string
        return oc
    } case none then {
        return "".string
    }
}

# fnSignature -- "RET cname(PARAMS)" for a user function from its
# resolved type's children and return stamp (z_main for main).
# fnReturnTypeId -- the stamped type id of a function's return-type node (the
# typecheck stamps `op.returntype`, even for concrete fns whose registry
# returnTypeId is unset). 0 when the fn has no return type.
fnReturnTypeId: function {symtab: zenv.ZSymbolTable op: Node} out u64 is {
    match (
        op
    ) case functiondef then {
        rtopt9: op.returntype
        match (
            rtopt9
        ) case some then {
            return (stampIdOf symtab: symtab nid: (nodeIdOf9 n: rtopt9))
        } case none then {
            return 0.u64
        }
    } else {
        return 0.u64
    }
}

# isReftypeParam -- a user reftype (class/union) param, passed BY REFERENCE: a
# function param that is a CLASS or UNION, not a collection mono (List/Map/Set),
# and not a value-native (String/StringView live in the system/collections
# units). Records/variants/facets (valtypes) and natives stay by value.
isReftypeParam: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64} out bool is {
    cid: tid
    rduo0: symtab.typing.definedInUnit.get key: tid
    isShell0: true
    match (
        rduo0
    ) case some then {
        isShell0 = false
    } case none then {}
    if isShell0 then {
        rtn0: typeNameOfReg9 symtab: symtab tid: tid
        rrid0: resolveTypeIdByName symtab: symtab ctx: ctx name: rtn0.stringview
        if rrid0 > 0.u64 then {
            cid = rrid0
        } else {}
    } else {}
    tt: symtab.reg.typetypeOf typeId: cid
    # Only CLASS params pass by reference. A UNION is a small value-stable
    # {tag, void* data} struct passed BY VALUE (the data pointer is shared with
    # the source; the borrow is tracked separately), matching the reference.
    if tt == ztypes.ztypetype.CLASS then {} else {
        return false
    }
    if (monoOriginName symtab: symtab tid: cid).length > 0.u64 then {
        return false
    } else {}
    duo: symtab.typing.definedInUnit.get key: cid
    match (
        duo
    ) case some then {
        if duo.stringview == "system" then {
            return false
        } else {}
        if duo.stringview == "collections" then {
            return false
        } else {}
    } case none then {}
    return true
}

# isBorrowStringParam -- a String param with BORROW/LOCK ownership, passed BY
# REFERENCE so the callee's mutations (append/reserve) persist to the caller. A
# `.take` String param is moved by value instead; StringView is value-passed.
isBorrowStringParam: function {symtab: zenv.ZSymbolTable fid: u64 pname: StringView pid: u64} out bool is {
    ptn9: typeNameOfReg9 symtab: symtab tid: pid
    if ptn9.stringview == "String" then {} else {
        return false
    }
    own9: symtab.typing.childOwnershipText parentTypeId: fid name: pname
    if own9.stringview == "BORROW" then {
        return true
    } else {}
    if own9.stringview == "LOCK" then {
        return true
    } else {}
    return false
}

# registerReftypeParams -- add a top-level function's reftype (class/union)
# params to ctx.ptrVars, so the body reads them as `param->field` and method
# calls pass them directly (they arrive as pointers). Caller resets ptrVars.
registerReftypeParams: function {symtab: zenv.ZSymbolTable ctx: Ctx fid: u64} is {
    pNames: (List of: String)
    pIds: (List of: u64)
    with citer: symtab.typing.typeChild.iterate do for tc: citer loop {
        if tc.parentTypeId == fid then {
            cto: symtab.typing.childTypeById.get key: tc.childNameId
            match (
                cto
            ) case some then {
                nm: tc.childName.copy
                pNames.append nm
                pIds.append cto
            } case none then {}
        } else {}
    }
    ri: 0.u64
    rn: pNames.length
    for while ri < rn loop {
        rpid: pIds.get i: ri
        rpn: pNames.get i: ri
        regp9: false
        if (isReftypeParam symtab: symtab ctx: ctx tid: rpid) then {
            regp9 = true
        } else {
            if (isBorrowStringParam symtab: symtab fid: fid pname: rpn.stringview pid: rpid) then {
                regp9 = true
            } else {}
        }
        if regp9 then {
            rpc: rpn.string
            ctx.ptrVars.append rpc
        } else {}
        ri = ri + 1.u64
    }
}

fnSignature: function {symtab: zenv.ZSymbolTable ctx: Ctx name: StringView fid: u64 op: Node} out String is {
    if name == "main" then {
        return "void z_main(void)".string
    } else {}
    ret: "void".string
    rbn: ztypecheck.fnReturnBaseNameOf op: op
    if rbn.length > 0.u64 then {
        rbc: cTypeOf name: rbn.stringview
        if rbn.stringview == "String" then {
            rs0: "\{ctx.strC}_t"
            ret = rs0
        } else if rbn.stringview == "StringView" then {
            rs1: "\{ctx.svC}_t"
            ret = rs1
        } else if rbc.length > 0.u64 then {
            ret = rbc
        } else {
            rbi9: userFnId symtab: symtab ctx: ctx name: rbn.stringview
            if rbi9 > 0.u64 then {
                rr9: typeRefC symtab: symtab ctx: ctx tid: rbi9 thisTid: 0.u64
                if rr9.length > 0.u64 then {
                    ret = rr9
                } else {}
            } else {}
        }
    } else {}
    {
        t: symtab.reg.typeById.get key: fid
        match (
            t
        ) case some then {
            rto: t.returnTypeId
            match (
                rto
            ) case some then {
                rn: typeNameOfReg9 symtab: symtab tid: rto
                rc: cTypeOf name: rn.stringview
                if rc.length > 0.u64 then {
                    ret = rc
                } else {
                    # a non-scalar return the rbn block didn't resolve -- e.g. an
                    # optionval/resultval (or other) mono. Use typeRefC, which
                    # gives the mono's C type. Only when ret is still void, so a
                    # resolution from rbn above is never overridden.
                    if ret.stringview == "void" then {
                        rr2: typeRefC symtab: symtab ctx: ctx tid: rto thisTid: 0.u64
                        if rr2.length > 0.u64 then {
                            ret = rr2
                        } else {}
                    } else {}
                }
            } case none then {}
        } case none then {}
    }
    if ret.stringview == "void" then {
        rtnid9: fnReturnTypeId symtab: symtab op: op
        if rtnid9 > 0.u64 then {
            rtr9: typeRefC symtab: symtab ctx: ctx tid: rtnid9 thisTid: 0.u64
            if rtr9.length > 0.u64 then {
                ret = rtr9
            } else {}
        } else {}
    } else {}
    params: "".string
    cNames: (List of: String)
    cIds: (List of: u64)
    with citer: symtab.typing.typeChild.iterate do for tc: citer loop {
        if tc.parentTypeId == fid then {
            cto: symtab.typing.childTypeById.get key: tc.childNameId
            match (
                cto
            ) case some then {
                cn0: tc.childName.copy
                cNames.append cn0
                cid2: cto
                cIds.append cid2
            } case none then {}
        } else {}
    }
    pi: 0.u64
    pn: cNames.length
    for while pi < pn loop {
        pname: cNames.get i: pi
        pid: cIds.get i: pi
        ct: typeRefC symtab: symtab ctx: ctx tid: pid thisTid: 0.u64
        ptrp9: false
        if (isReftypeParam symtab: symtab ctx: ctx tid: pid) then {
            ptrp9 = true
        } else {
            if (isBorrowStringParam symtab: symtab fid: fid pname: pname.stringview pid: pid) then {
                ptrp9 = true
            } else {}
        }
        if ptrp9 then {
            if ct.length > 0.u64 then {
                ctp9: "\{ct}*"
                ct = ctp9
            } else {}
        } else {}
        if pi > 0.u64 then {
            params.append ", "
        } else {}
        if ct.length > 0.u64 then {
            params.append ct.stringview
        } else {
            params.append "int64_t"
        }
        params.append " "
        params.append pname.stringview
        pi = pi + 1.u64
    }
    if pn == 0.u64 then {
        params.append "void"
    } else {}
    fc: cnameOf tid: fid name: name
    sig: "\{ret} \{fc}(\{params})"
    return sig
}

# typedefChaseC -- the underlying C scalar of a typedef record, chasing
# the typedef-base chain (meters -> i64, height -> meters -> i64); ""
# when the type is not a typedef.
typedefChaseC: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64} out String is {
    bo: symtab.typing.typedefBaseName.get key: tid
    match (
        bo
    ) case some then {
        bn: bo.stringview.string
        bc: cTypeOf name: bn.stringview
        if bc.length > 0.u64 then {
            return bc
        } else {}
        bid: userFnId symtab: symtab ctx: ctx name: bn.stringview
        if bid > 0.u64 then {
            return (typeRefC symtab: symtab ctx: ctx tid: bid thisTid: 0.u64)
        } else {}
        return "int64_t".string
    } case none then {
        return "".string
    }
}

# isTypedefType -- the type id carries a typedef base.
isTypedefType: function {symtab: zenv.ZSymbolTable tid: u64} out bool is {
    bo: symtab.typing.typedefBaseName.get key: tid
    match (
        bo
    ) case some then {
        return true
    } case none then {
        return false
    }
}

# isCollectionOrigin -- a generic-origin template name that mints a C
# struct type (List/ListView/Set/Map/MapEntry and the iterators).
isCollectionOrigin: function {name: StringView} out bool is {
    if name == "List" then { return true } else {}
    if name == "ListView" then { return true } else {}
    if name == "Set" then { return true } else {}
    if name == "Map" then { return true } else {}
    if name == "MapEntry" then { return true } else {}
    if name == "ListIter" then { return true } else {}
    if name == "SetIter" then { return true } else {}
    if name == "MapKeyIter" then { return true } else {}
    if name == "MapItemIter" then { return true } else {}
    return false
}

# cTypeForName -- the C type for a type NAME: scalar via cTypeOf, else
# resolve the type id (across units) and use typeRefC; "" when unknown.
cTypeForName: function {symtab: zenv.ZSymbolTable ctx: Ctx name: StringView} out String is {
    sc: cTypeOf name: name
    if sc.length > 0.u64 then {
        return sc
    } else {}
    to: ztypecheck.lookupTyperef resolved: symtab.typing.resolved mainName: ctx.mainName.stringview base: name
    match (
        to
    ) case some then {
        return (typeRefC symtab: symtab ctx: ctx tid: to thisTid: 0.u64)
    } case none then {
        return "".string
    }
}

# typeRefC -- the C spelling for a type id: scalars by name, records by
# their id-based cname ("" when unsupported).
# chaseColMono -- if tid is a typedef-class over a collection mono (Bytes ->
# List_u8, ByteView -> ListView_u8), the underlying mono id; else tid. The
# emitter treats Bytes/ByteView as zero-overhead aliases of their collection.
chaseColMono: function {symtab: zenv.ZSymbolTable tid: u64} out u64 is {
    bo: symtab.typing.typedefBaseMangled.get key: tid
    match (
        bo
    ) case some then {
        mo: symtab.typing.monoByName.get key: bo.string
        match (
            mo
        ) case some then {
            cmo9: monoOriginName symtab: symtab tid: mo
            if (isCollectionOrigin name: cmo9.stringview) then {
                return mo
            } else {}
        } case none then {}
    } case none then {}
    return tid
}

typeRefC: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64 thisTid: u64} out String is {
    tn: typeNameOfReg9 symtab: symtab tid: tid
    ct: cTypeOf name: tn.stringview
    if ct.length > 0.u64 then {
        return ct
    } else {}
    # canonicalize shells: a param/field child may be a fresh shell id
    # named after the real type; this-typed params take the receiver.
    cid: tid
    if tn.stringview == "this" when thisTid > 0.u64 then {
        cid = thisTid
        tn = typeNameOfReg9 symtab: symtab tid: cid
    } else {
        # only canonicalize a SHELL (no defining unit) by name; a fully-registered
        # type is used directly, so a cross-unit same-name type (io.Reader vs a
        # main-unit Reader) is not re-resolved to the main unit's.
        hasUnit9: false
        duo0: symtab.typing.definedInUnit.get key: tid
        match (
            duo0
        ) case some then {
            hasUnit9 = true
        } case none then {}
        if hasUnit9 then {} else {
            rid9: resolveTypeIdByName symtab: symtab ctx: ctx name: tn.stringview
            if rid9 > 0.u64 then {
                cid = rid9
            } else {}
        }
    }
    cmid9: chaseColMono symtab: symtab tid: cid
    if cmid9 != cid then {
        cmn9: typeNameOfReg9 symtab: symtab tid: cmid9
        cmc9: cnameOf tid: cmid9 name: cmn9.stringview
        return "\{cmc9}_t"
    } else {}
    tdc: typedefChaseC symtab: symtab ctx: ctx tid: cid
    if tdc.length > 0.u64 then {
        return tdc
    } else {}
    if tn.stringview == "String" then {
        ts0: "\{ctx.strC}_t"
        return ts0
    } else {}
    if tn.stringview == "StringView" then {
        ts1: "\{ctx.svC}_t"
        return ts1
    } else {}
    omn9: monoOriginName symtab: symtab tid: cid
    if (isCollectionOrigin name: omn9.stringview) then {
        cc9: cnameOf tid: cid name: tn.stringview
        ct9: "\{cc9}_t"
        return ct9
    } else {}
    ctt: symtab.reg.typetypeOf typeId: cid
    if ctt == ztypes.ztypetype.RECORD then {
        rc: cnameOf tid: cid name: tn.stringview
        rt9: "\{rc}_t"
        return rt9
    } else {}
    if ctt == ztypes.ztypetype.VARIANT then {
        rc2: cnameOf tid: cid name: tn.stringview
        rt8: "\{rc2}_t"
        return rt8
    } else {}
    if ctt == ztypes.ztypetype.CLASS then {
        rc3: cnameOf tid: cid name: tn.stringview
        rt7: "\{rc3}_t"
        return rt7
    } else {}
    if ctt == ztypes.ztypetype.UNION then {
        rc4: cnameOf tid: cid name: tn.stringview
        rt6: "\{rc4}_t"
        return rt6
    } else {}
    if ctt == ztypes.ztypetype.PROTOCOL then {
        rc5: cnameOf tid: cid name: tn.stringview
        rt5: "\{rc5}_t"
        return rt5
    } else {}
    return "".string
}

# variantArms -- a variant's arm names and payload ids in order
# (non-FUNCTION children, the tag child excluded).
variantArms: function {symtab: zenv.ZSymbolTable tid: u64 names: (List of: String) ids: (List of: u64)} is {
    with citer: symtab.typing.typeChild.iterate do for tc: citer loop {
        if tc.parentTypeId == tid then {
            cto: symtab.typing.childTypeById.get key: tc.childNameId
            match (
                cto
            ) case some then {
                if (symtab.reg.typetypeOf typeId: cto) == ztypes.ztypetype.FUNCTION then {} else {
                    if tc.childName.stringview == "tag" then {} else {
                        cn0: tc.childName.copy
                        names.append cn0
                        cid0: cto
                        ids.append cid0
                    }
                }
            } case none then {}
        } else {}
    }
}

# variantTag -- the C tag constant for an arm.
variantTag: function {symtab: zenv.ZSymbolTable tid: u64 arm: StringView} out String is {
    vn: typeNameOfReg9 symtab: symtab tid: tid
    vu: cUpperOf text: vn.stringview
    au: cUpperOf text: arm
    t9: "Z_\{vu}_TAG_\{au}"
    return t9
}

# armPayloadC -- an arm's payload C type ("" for null arms).
armPayloadC: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64 arm: StringView} out String is {
    co: symtab.typing.childOf parentTypeId: tid name: arm
    match (
        co
    ) case some then {
        pn: typeNameOfReg9 symtab: symtab tid: co
        if pn.stringview == "null" then {
            return "".string
        } else {}
        return (typeRefC symtab: symtab ctx: ctx tid: co thisTid: 0.u64)
    } case none then {
        return "".string
    }
}

# isConformanceMarker -- is (tid, name) an as-block protocol/facet conformance
# marker (`label: Spec` / `:Spec`) rather than a stored field? Such children
# carry the spec type id but must never be emitted as struct fields.
isConformanceMarker: function {conf: (List of: ztypes.ZConformance) tid: u64 name: StringView} out bool is {
    found: false
    with citer: conf.iterate do for row: citer loop {
        if row.implTypeId == tid when row.label.stringview == name then {
            found = true
        } else {}
    }
    return found
}

# recFieldLists -- a record type's field names and type ids in order
# (non-FUNCTION children, conformance markers excluded).
recFieldLists: function {symtab: zenv.ZSymbolTable tid: u64 names: (List of: String) ids: (List of: u64)} is {
    with citer: symtab.typing.typeChild.iterate do for tc: citer loop {
        if tc.parentTypeId == tid then {
            cto: symtab.typing.childTypeById.get key: tc.childNameId
            match (
                cto
            ) case some then {
                if (symtab.reg.typetypeOf typeId: cto) == ztypes.ztypetype.FUNCTION then {} else {
                    if (isConformanceMarker conf: symtab.typing.conformance tid: tid name: tc.childName.stringview) then {} else {
                        cn0: tc.childName.copy
                        names.append cn0
                        cid0: cto
                        ids.append cid0
                    }
                }
            } case none then {}
        } else {}
    }
}

typeNameOfReg9: function {symtab: zenv.ZSymbolTable tid: u64} out String is {
    t: symtab.reg.typeById.get key: tid
    match (
        t
    ) case some then {
        return t.name.copy
    } case none then {
        return "".string
    }
}

# isConstShape -- a unit member value that folds to a C constant
# expression: numeric/float atoms, already-rendered constant names, and
# binop trees over those.
isConstShape: function {ctx: Ctx n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (isConstShape ctx: ctx n: n.expression)
    } case atomid then {
        av: n.name.stringview
        b0: av.byteAt i: 0.u64
        match (
            b0
        ) case some then {
            if b0 >= 48.u8 then {
                if b0 <= 57.u8 then {
                    return true
                } else {}
            } else {}
        } case none then {}
        ak: av.string
        cgo: ctx.constVals.get key: ak
        match (
            cgo
        ) case some then {
            return true
        } case none then {
            return false
        }
    } case binop then {
        if (isConstShape ctx: ctx n: n.lhs) then {
            return (isConstShape ctx: ctx n: n.rhs)
        } else {
            return false
        }
    } case ifexpr then {
        return true
    } else {
        return false
    }
}

# fillMethodReturns -- record each main-unit type method's return
# format name (TypeName.method -> i64/f64/...), so interpolation can
# format auto-call results whose node carries only a FUNCTION stamp.
fillDataElems: function {program: Node symtab: zenv.ZSymbolTable ctx: Ctx} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        with uiter: program.units.iterate do for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                un: unitLabel9 o: u.name
                if un.stringview == mainName then {
                    fillDataElemsIn symtab: symtab ctx: ctx mainOp: u.operation
                } else {}
            } else {}
        }
    } else {}
}

fillDataElemsIn: function {symtab: zenv.ZSymbolTable ctx: Ctx mainOp: Node} is {
    match (
        mainOp
    ) case unitdef then {
        biter: mainOp.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                dnm: unitLabel9 o: bm.name
                fillOneDataElem symtab: symtab ctx: ctx name: dnm.stringview op: bm.operation
            } else {}
        }
    } else {}
}

fillOneDataElem: function {symtab: zenv.ZSymbolTable ctx: Ctx name: StringView op: Node} is {
    match (
        op
    ) case expression then {
        fillOneDataElem symtab: symtab ctx: ctx name: name op: op.expression
    } case datablock then {
        ebn: dataElemBaseName o: op.outType
        k9: name.string
        if ebn.length > 0.u64 then {
            ebv9: ebn.stringview
            ev9: ebv9.string
            ctx.dataElems.set key: k9 value: ev9
        } else {
            iv9: "i64".string
            ctx.dataElems.set key: k9 value: iv9
        }
        idx9: 0.u64
        eiter9: op.elements.iterate
        for e9: eiter9 loop {
            vx9: emitDataElem symtab: symtab ctx: ctx n: e9
            ik9: "\{name}.\{idx9}".string
            iv2: vx9.copy
            ctx.dataConst.set key: ik9 value: iv2
            elbl: dataElemLabel n: e9
            if elbl.length > 0.u64 then {
                lk9: "\{name}.\{elbl}".string
                lv9: vx9.copy
                ctx.dataConst.set key: lk9 value: lv9
            } else {}
            idx9 = idx9 + 1.u64
        }
    } else {}
}

dataElemLabel: function {n: Node} out String is {
    match (
        n
    ) case namedoperation then {
        return (unitLabel9 o: n.name)
    } else {
        return "".string
    }
}

fillMethodReturns: function {program: Node symtab: zenv.ZSymbolTable ctx: Ctx} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        with uiter: program.units.iterate do for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                un: unitLabel9 o: u.name
                if un.stringview == mainName then {
                    fillMethodReturnsIn symtab: symtab ctx: ctx mainOp: u.operation
                } else {}
            } else {}
        }
    } else {}
}

fillMethodReturnsIn: function {symtab: zenv.ZSymbolTable ctx: Ctx mainOp: Node} is {
    match (
        mainOp
    ) case unitdef then {
        biter: mainOp.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                tnm: unitLabel9 o: bm.name
                fillTypeMethodReturns symtab: symtab ctx: ctx typeName: tnm.stringview op: bm.operation
            } else {}
        }
    } else {}
}

fillTypeMethodReturns: function {symtab: zenv.ZSymbolTable ctx: Ctx typeName: StringView op: Node} is {
    match (
        op
    ) case objectdef then {
        with aiter: op.asItems.iterate do for am: aiter loop {
            match (
                am
            ) case namedoperation then {
                if (isFunctionDefWithBody9 n: am.operation) then {
                    mnm: unitLabel9 o: am.name
                    rbn: ztypecheck.fnReturnBaseNameOf op: am.operation
                    if rbn.length > 0.u64 then {
                        k9: "\{typeName}.\{mnm}".string
                        rbv: rbn.stringview
                        v9: rbv.string
                        ctx.methodReturns.set key: k9 value: v9
                    } else {}
                } else {}
            } else {}
        }
    } else {}
}

# fillConstVals -- pre-render each main-unit constant's C text in
# definition order (constants reference only earlier ones; C folds the
# arithmetic in the emitted expression).
fillConstVals: function {program: Node symtab: zenv.ZSymbolTable ctx: Ctx} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        with uiter: program.units.iterate do for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                un: unitLabel9 o: u.name
                if un.stringview == mainName then {
                    fillConstValsIn symtab: symtab ctx: ctx mainOp: u.operation
                } else {}
            } else {}
        }
    } else {}
}

fillConstValsIn: function {symtab: zenv.ZSymbolTable ctx: Ctx mainOp: Node} is {
    match (
        mainOp
    ) case unitdef then {
        biter: mainOp.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                if (isConstShape ctx: ctx n: bm.operation) then {
                    nm: unitLabel9 o: bm.name
                    cv: emitExpr symtab: symtab ctx: ctx n: bm.operation
                    nmv: nm.stringview
                    nk: nmv.string
                    cvv: cv.stringview
                    ck: cvv.string
                    ctx.constVals.set key: nk value: ck
                } else {}
            } else {}
        }
    } else {}
}

# emitFns -- the main unit's function declarations then definitions
# (two-phase index walk so the body list is free during emission).
emitFns: function {program: Node symtab: zenv.ZSymbolTable ctx: Ctx buf: String.borrow} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        with uiter: program.units.iterate do for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                un: unitLabel9 o: u.name
                if un.stringview == mainName then {
                    emitFnsIn symtab: symtab ctx: ctx mainOp: u.operation buf: buf
                } else {}
            } else {}
        }
    } else {}
}

emitFnsIn: function {symtab: zenv.ZSymbolTable ctx: Ctx mainOp: Node buf: String.borrow} is {
    match (
        mainOp
    ) case unitdef then {
        idxs: (List of: u64)
        names: (List of: String)
        di: 0.u64
        with biter: mainOp.body.iterate do for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                if (isFunctionDefWithBody9 n: bm.operation) then {
                    dv: di
                    idxs.append dv
                    nm: unitLabel9 o: bm.name
                    names.append nm
                } else {}
            } else {}
            di = di + 1.u64
        }
        wi: 0.u64
        wn: idxs.length
        for while wi < wn loop {
            nm2: names.get i: wi
            didx: idxs.get i: wi
            dm2: mainOp.body.get i: didx
            match (
                dm2
            ) case namedoperation then {
                fid: userFnId symtab: symtab ctx: ctx name: nm2.stringview
                sig: fnSignature symtab: symtab ctx: ctx name: nm2.stringview fid: fid op: dm2.operation
                ld: "\{sig};\n"
                buf.append ld.stringview
            } else {}
            wi = wi + 1.u64
        }
        buf.append "\n"
        wj: 0.u64
        for while wj < wn loop {
            bidx: idxs.get i: wj
            nm3: names.get i: wj
            bm2: mainOp.body.get i: bidx
            match (
                bm2
            ) case namedoperation then {
                fid2: userFnId symtab: symtab ctx: ctx name: nm3.stringview
                sig2: fnSignature symtab: symtab ctx: ctx name: nm3.stringview fid: fid2 op: bm2.operation
                lo: "\{sig2} {\n"
                buf.append lo.stringview
                ctx.ptrVars = (List of: String)
                registerReftypeParams symtab: symtab ctx: ctx fid: fid2
                emitFnBody symtab: symtab ctx: ctx op: bm2.operation buf: buf
                buf.append "}\n\n"
            } else {}
            wj = wj + 1.u64
        }
    } else {}
}

isFunctionDefWithBody9: function {n: Node} out bool is {
    match (
        n
    ) case functiondef then {
        match (
            n.body
        ) case some then {
            return true
        } case none then {
            return false
        }
    } else {
        return false
    }
}

emitFnBody: function {symtab: zenv.ZSymbolTable ctx: Ctx op: Node buf: String.borrow} is {
    match (
        op
    ) case functiondef then {
        tmp: (TmpCtr n: 0 frees: (List of: String) listFrees: (List of: String))
        emitBodyOpt symtab: symtab ctx: ctx o: op.body ind: "    " tmp: tmp buf: buf
        fiter9: tmp.frees.iterate
        for fv: fiter9 loop {
            lf9: "    \{ctx.strC}_free(&\{fv});\n"
            buf.append lf9.stringview
        }
        lfi9: tmp.listFrees.iterate
        for lfs: lfi9 loop {
            buf.append lfs.stringview
        }
    } else {}
}

# collectUnitLiterals -- pool the plain literals of every main-unit
# function body.
collectUnitLiterals: function {program: Node ids: (List of: u64) texts: (List of: String)} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        with uiter: program.units.iterate do for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                un: unitLabel9 o: u.name
                if un.stringview == mainName then {
                    collectUnitLiteralsIn mainOp: u.operation ids: ids texts: texts
                } else {}
            } else {}
        }
    } else {}
}

collectUnitLiteralsIn: function {mainOp: Node ids: (List of: u64) texts: (List of: String)} is {
    match (
        mainOp
    ) case unitdef then {
        biter: mainOp.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                collectFnLiterals n: bm.operation ids: ids texts: texts
            } else {}
        }
    } else {}
}

collectFnLiterals: function {n: Node ids: (List of: u64) texts: (List of: String)} is {
    match (
        n
    ) case functiondef then {
        collectLiteralsOpt o: n.body ids: ids texts: texts
    } case objectdef then {
        with aiter: n.asItems.iterate do for am: aiter loop {
            match (
                am
            ) case namedoperation then {
                collectFnLiterals n: am.operation ids: ids texts: texts
            } else {}
        }
    } else {}
}

# emitC -- emit the C translation unit for a typechecked program.
emitC: function {program: Node symtab: zenv.ZSymbolTable runtimeDir: StringView} out String is {
    buf: "".string
    needsHash: usesHashCollections symtab: symtab
    buf.append "/* Generated by zerolang compiler */\n"
    buf.append "\n"
    buf.append "#define _POSIX_C_SOURCE 200809L\n"
    if needsHash then {
        buf.append "#define _DEFAULT_SOURCE\n"
    } else {}
    buf.append "\n"
    buf.append "#include <stdio.h>\n"
    buf.append "#include <stdint.h>\n"
    buf.append "#include <stdlib.h>\n"
    buf.append "#include <stdbool.h>\n"
    buf.append "#include <string.h>\n"
    buf.append "#include <errno.h>\n"
    buf.append "#include <fcntl.h>\n"
    buf.append "#include <unistd.h>\n"
    buf.append "#include <sys/stat.h>\n"
    buf.append "#include <sys/types.h>\n"
    buf.append "#include <dirent.h>\n"
    buf.append "#include <pwd.h>\n"
    if needsHash then {
        buf.append "#include <sys/random.h>\n"
        buf.append "#include <sys/syscall.h>\n"
    } else {}
    buf.append "\n"
    buf.append "static _Noreturn void z_panic(const char* msg) {\n"
    buf.append "    fprintf(stderr, \"zpanic: %s\\n\", msg);\n"
    buf.append "    exit(1);\n"
    buf.append "}\n"
    buf.append "static void* z_xmalloc(size_t n) {\n"
    buf.append "    void* p = malloc(n);\n"
    buf.append "    if (!p) z_panic(\"out of memory\");\n"
    buf.append "    return p;\n"
    buf.append "}\n"
    buf.append "static void* z_xcalloc(size_t count, size_t size) {\n"
    buf.append "    void* p = calloc(count, size);\n"
    buf.append "    if (!p) z_panic(\"out of memory\");\n"
    buf.append "    return p;\n"
    buf.append "}\n"
    buf.append "static void* z_xrealloc(void* p, size_t n) {\n"
    buf.append "    void* q = realloc(p, n);\n"
    buf.append "    if (!q) z_panic(\"out of memory\");\n"
    buf.append "    return q;\n"
    buf.append "}\n"
    buf.append "\n"
    strId: 0.u64
    svId: 0.u64
    k1: "system.String".string
    sgo: symtab.typing.resolved.get key: k1
    match (
        sgo
    ) case some then {
        strId = sgo
    } case none then {}
    k2: "system.StringView".string
    vgo: symtab.typing.resolved.get key: k2
    match (
        vgo
    ) case some then {
        svId = vgo
    } case none then {}
    strC: cnameOf tid: strId name: "String"
    svC: cnameOf tid: svId name: "StringView"
    p1: "\{runtimeDir}/z_String.inc"
    f1: loadFragment path: p1.stringview svC: svC.stringview strC: strC.stringview
    buf.append f1.stringview
    buf.append "\n"
    p2: "\{runtimeDir}/z_StringView.inc"
    f2: loadFragment path: p2.stringview svC: svC.stringview strC: strC.stringview
    buf.append f2.stringview
    buf.append "\n"
    if needsHash then {
        ph: "\{runtimeDir}/z_hash.inc"
        fh: loadFragment path: ph.stringview svC: svC.stringview strC: strC.stringview
        buf.append fh.stringview
        buf.append "\n"
    } else {}
    mn: mainNameOf9 program: program
    litIds: (List of: u64)
    litTexts: (List of: String)
    collectUnitLiterals program: program ids: litIds texts: litTexts
    poolBuf: "".string
    i: 0.u64
    n: litIds.length
    for while i < n loop {
        t: litTexts.get i: i
        tv: t.stringview
        esc: cEscape text: tv
        blen: tv.length
        idx: i + 1.u64
        l1: "static const char _zs\{idx}_d[] = \"\{esc}\";\n"
        poolBuf.append l1.stringview
        l2: "static const \{svC}_t _zs\{idx} = { _zs\{idx}_d, \{blen} };\n"
        poolBuf.append l2.stringview
        i = i + 1.u64
    }
    ctx: (Ctx mainName: mn strC: strC svC: svC litIds: litIds constVals: (Map key: String value: String) needs: (Map key: String value: bool) methodReturns: (Map key: String value: String) dataElems: (Map key: String value: String) dataConst: (Map key: String value: String) ptrVars: (List of: String) aliases: (Map key: String value: String) genActive: false genYieldCount: 0.u64 genYieldNext: 0.u64 genWrap: "".string genSomeTag: "".string genNoneTag: "".string genHasValue: false emittedUserTypes: (Map key: u64 value: bool))
    fillConstVals program: program symtab: symtab ctx: ctx
    fillMethodReturns program: program symtab: symtab ctx: ctx
    fillDataElems program: program symtab: symtab ctx: ctx
    fnsBuf: "".string
    emitFns program: program symtab: symtab ctx: ctx buf: fnsBuf
    hasMain: programHasMain program: program
    if hasMain then {} else {
        fnsBuf.append "void z_main(void) {\n"
        fnsBuf.append "}\n\n"
    }
    # the string-literal pool precedes the monos/records/methods/functions that
    # reference _zsN (class-method bodies use pooled literals too).
    buf.append poolBuf.stringview
    buf.append "\n"
    emitMonos symtab: symtab ctx: ctx runtimeDir: runtimeDir buf: buf
    emitNeededNatives symtab: symtab ctx: ctx runtimeDir: runtimeDir buf: buf
    fidF9: ioFileId symtab: symtab ctx: ctx
    if fidF9 > 0.u64 then {
        needsAdd ctx: ctx name: "io"
        needsAdd ctx: ctx name: "io_file_close"
        needsAdd ctx: ctx name: "io_file_read"
        needsAdd ctx: ctx name: "io_file_write"
        needsAdd ctx: ctx name: "io_file_seek"
        needsAdd ctx: ctx name: "io_file_flush"
    } else {}
    emitRuntimeIo symtab: symtab ctx: ctx runtimeDir: runtimeDir buf: buf
    emitIoFileConformance symtab: symtab ctx: ctx buf: buf
    emitIoStdStreams symtab: symtab ctx: ctx buf: buf
    emitRuntimeCli symtab: symtab ctx: ctx runtimeDir: runtimeDir buf: buf
    emitRuntimeOs symtab: symtab ctx: ctx runtimeDir: runtimeDir buf: buf
    emitRecordDefs program: program symtab: symtab ctx: ctx buf: buf
    buf.append fnsBuf.stringview
    buf.append "int main(int argc, char* argv[]) {\n"
    if (needsHas ctx: ctx name: "os_args") then {
        buf.append "    z_os_argc_g = argc;\n"
        buf.append "    z_os_argv_g = argv;\n"
    } else {}
    if needsHash then {
        buf.append "    z_siphash_init();\n"
    } else {}
    buf.append "    z_main();\n"
    buf.append "    return 0;\n"
    buf.append "}\n"
    return buf
}

programHasMain: function {program: Node} out bool is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        with uiter: program.units.iterate do for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                un: unitLabel9 o: u.name
                if un.stringview == mainName then {
                    if (unitHasMain9 mainOp: u.operation) then {
                        return true
                    } else {}
                } else {}
            } else {}
        }
        return false
    } else {
        return false
    }
}

unitHasMain9: function {mainOp: Node} out bool is {
    match (
        mainOp
    ) case unitdef then {
        biter: mainOp.body.iterate
        for bm: biter loop {
            match (
                bm
            ) case namedoperation then {
                bn: unitLabel9 o: bm.name
                if bn.stringview == "main" then {
                    return true
                } else {}
            } else {}
        }
        return false
    } else {
        return false
    }
}

# emitNeededNatives -- the gated native fragments for the needs the body
# walk collected, in the reference's emission order.
emitNeededNatives: function {symtab: zenv.ZSymbolTable ctx: Ctx runtimeDir: StringView buf: String.borrow} is {
    emitNativeIf ctx: ctx need: "isEmpty" frag: "_Z_SV_IS_EMPTY" runtimeDir: runtimeDir buf: buf
    emitNativeIf ctx: ctx need: "isAscii" frag: "_Z_SV_IS_ASCII" runtimeDir: runtimeDir buf: buf
    emitNativeIf ctx: ctx need: "startsWith" frag: "_Z_SV_STARTS_WITH" runtimeDir: runtimeDir buf: buf
    emitNativeIf ctx: ctx need: "endsWith" frag: "_Z_SV_ENDS_WITH" runtimeDir: runtimeDir buf: buf
    needRaw: needsHas ctx: ctx name: "contains"
    if (needsHas ctx: ctx name: "indexOf") then { needRaw = true } else {}
    if (needsHas ctx: ctx name: "lastIndexOf") then { needRaw = true } else {}
    if needRaw then {
        emitMonoNative symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_SV_INDEX_OF_RAW" mono: "" buf: buf
    } else {}
    emitNativeIf ctx: ctx need: "contains" frag: "_Z_SV_CONTAINS" runtimeDir: runtimeDir buf: buf
    hasTrim: needsHas ctx: ctx name: "trim"
    hasTrimS: needsHas ctx: ctx name: "trimStart"
    hasTrimE: needsHas ctx: ctx name: "trimEnd"
    anyTrim: hasTrim
    if hasTrimS then { anyTrim = true } else {}
    if hasTrimE then { anyTrim = true } else {}
    if anyTrim then {
        p0: nativePath runtimeDir: runtimeDir frag: "_Z_SV_IS_ASCII_WS"
        sc0: ctx.svC.copy
        tc0: ctx.strC.copy
        f0: loadFragment path: p0.stringview svC: sc0.stringview strC: tc0.stringview
        buf.append f0.stringview
    } else {}
    emitNativeIf ctx: ctx need: "trim" frag: "_Z_SV_TRIM" runtimeDir: runtimeDir buf: buf
    emitNativeIf ctx: ctx need: "trimStart" frag: "_Z_SV_TRIM_START" runtimeDir: runtimeDir buf: buf
    emitNativeIf ctx: ctx need: "trimEnd" frag: "_Z_SV_TRIM_END" runtimeDir: runtimeDir buf: buf
    emitNativeIf ctx: ctx need: "toLowerAscii" frag: "_Z_SV_TO_LOWER_ASCII" runtimeDir: runtimeDir buf: buf
    hasRep: needsHas ctx: ctx name: "replace"
    hasRepF: needsHas ctx: ctx name: "replaceFirst"
    anyRep: hasRep
    if hasRepF then { anyRep = true } else {}
    if anyRep then {
        pR: nativePath runtimeDir: runtimeDir frag: "_Z_SV_REPLACE_IMPL"
        scR: ctx.svC.copy
        tcR: ctx.strC.copy
        fR: loadFragment path: pR.stringview svC: scR.stringview strC: tcR.stringview
        buf.append fR.stringview
    } else {}
    emitNativeIf ctx: ctx need: "replace" frag: "_Z_SV_REPLACE" runtimeDir: runtimeDir buf: buf
    emitNativeIf ctx: ctx need: "replaceFirst" frag: "_Z_SV_REPLACE_FIRST" runtimeDir: runtimeDir buf: buf
    emitNativeIf ctx: ctx need: "repeated" frag: "_Z_SV_REPEAT" runtimeDir: runtimeDir buf: buf
    emitNativeIf ctx: ctx need: "concat" frag: "_Z_SV_CONCAT" runtimeDir: runtimeDir buf: buf
    emitNativeIf ctx: ctx need: "toUpperAscii" frag: "_Z_SV_TO_UPPER_ASCII" runtimeDir: runtimeDir buf: buf
    hasCount: needsHas ctx: ctx name: "count"
    hasCp: needsHas ctx: ctx name: "codepoints"
    anyUtf8: hasCount
    if hasCp then { anyUtf8 = true } else {}
    if anyUtf8 then {
        pu: nativePath runtimeDir: runtimeDir frag: "_Z_SV_UTF8_DECODE"
        scu: ctx.svC.copy
        tcu: ctx.strC.copy
        fu: loadFragment path: pu.stringview svC: scu.stringview strC: tcu.stringview
        buf.append fu.stringview
    } else {}
    emitNativeIf ctx: ctx need: "count" frag: "_Z_SV_COUNT" runtimeDir: runtimeDir buf: buf
    if hasCp then {
        emitCodepointsNatives symtab: symtab ctx: ctx runtimeDir: runtimeDir buf: buf
    } else {}
    if (needsHas ctx: ctx name: "indexOf") then {
        emitMonoNative symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_SV_INDEX_OF" mono: "optionval_u64" buf: buf
    } else {}
    if (needsHas ctx: ctx name: "lastIndexOf") then {
        emitMonoNative symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_SV_LAST_INDEX_OF" mono: "optionval_u64" buf: buf
    } else {}
    if (needsHas ctx: ctx name: "byteAt") then {
        emitMonoNative symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_SV_BYTE_AT" mono: "optionval_u8" buf: buf
    } else {}
    if (needsHas ctx: ctx name: "stripPrefix") then {
        emitMonoNative symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_SV_STRIP_PREFIX" mono: "Option_StringView" buf: buf
    } else {}
    if (needsHas ctx: ctx name: "stripSuffix") then {
        emitMonoNative symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_SV_STRIP_SUFFIX" mono: "Option_StringView" buf: buf
    } else {}
    if (needsHas ctx: ctx name: "splitOnce") then {
        emitMonoNative symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_SV_SPLIT_ONCE" mono: "optionval_u64" buf: buf
    } else {}
    if (needsHas ctx: ctx name: "parseI64") then {
        emitParseNative symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_SV_PARSE_I64" mono: "resultval_i64_parseerror" buf: buf
    } else {}
    if (needsHas ctx: ctx name: "parseU64") then {
        emitParseNative symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_SV_PARSE_U64" mono: "resultval_u64_parseerror" buf: buf
    } else {}
    if (needsHas ctx: ctx name: "parseF64") then {
        emitParseNative symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_SV_PARSE_F64" mono: "resultval_f64_parseerror" buf: buf
    } else {}
}

nativePath: function {runtimeDir: StringView frag: StringView} out String is {
    p: "\{runtimeDir}/natives/\{frag}.inc"
    return p
}

emitNativeIf: function {ctx: Ctx need: StringView frag: StringView runtimeDir: StringView buf: String.borrow} is {
    if (needsHas ctx: ctx name: need) then {
        p9: nativePath runtimeDir: runtimeDir frag: frag
        sc9: ctx.svC.copy
        tc9: ctx.strC.copy
        f9: loadFragment path: p9.stringview svC: sc9.stringview strC: tc9.stringview
        buf.append f9.stringview
    } else {}
}

# cbaseNoPrefix -- the id-based cname without the leading "z_" (the runtime
# templates spell z_@@NAME@@, so NAME omits the prefix).
cbaseNoPrefix: function {tid: u64 name: StringView} out String is {
    full: cnameOf tid: tid name: name
    fl: full.length
    rest: (full.stringview from: 2.u64 to: fl)
    return rest.string
}

# applyTmpl -- substitute one @@KEY@@ placeholder in template text.
applyTmpl: function {text: String key: StringView val: StringView} out String is {
    needle: "@@\{key}@@".string
    return (substituteAll text: text needle: needle.stringview repl: val)
}

# monoOriginName -- the template name a mono derives from (List/Map/Set),
# "" when not a mono.
monoOriginName: function {symtab: zenv.ZSymbolTable tid: u64} out String is {
    t: symtab.reg.typeById.get key: tid
    match (
        t
    ) case some then {
        go: t.genericOriginId
        match (
            go
        ) case some then {
            return (typeNameOfReg9 symtab: symtab tid: go)
        } case none then {}
    } case none then {}
    return "".string
}

# listElemType -- a List/ListView mono's element type id (the get-child
# return), 0 when absent.
listElemType: function {symtab: zenv.ZSymbolTable monoId: u64} out u64 is {
    go: symtab.typing.childOf parentTypeId: monoId name: "get"
    match (
        go
    ) case some then {
        t: symtab.reg.typeById.get key: go
        match (
            t
        ) case some then {
            rt: t.returnTypeId
            match (
                rt
            ) case some then {
                return rt
            } case none then {}
        } case none then {}
    } case none then {}
    return 0.u64
}

# ctypeOrI64 -- the given C type name as an owned String, or int64_t
# when empty.
ctypeOrI64: function {s: StringView} out String is {
    if s.length > 0.u64 then {
        return s.string
    } else {
        return "int64_t".string
    }
}

# emitListMono -- substitute z_List.c.tmpl for a List instance + the
# linear-scan contains companion (scalar element equality).
emitListMono: function {symtab: zenv.ZSymbolTable ctx: Ctx runtimeDir: StringView monoId: u64 buf: String.borrow} is {
    mn: typeNameOfReg9 symtab: symtab tid: monoId
    nm: cbaseNoPrefix tid: monoId name: mn.stringview
    eid: listElemType symtab: symtab monoId: monoId
    eln9: typeNameOfReg9 symtab: symtab tid: eid
    isStrEl9: false
    if eln9.stringview == "String" then {
        isStrEl9 = true
    } else {}
    ect0: typeRefC symtab: symtab ctx: ctx tid: eid thisTid: 0.u64
    ect: ctypeOrI64 s: ect0.stringview
    p: "\{runtimeDir}/z_List.c.tmpl"
    raw: io.readText path: p.stringview
    match (
        raw
    ) case ok then {
        t1: applyTmpl text: raw key: "NAME" val: nm.stringview
        t2: applyTmpl text: t1 key: "ELEM_T" val: ect.stringview
        t3: applyTmpl text: t2 key: "DESTROY_ELEMS" val: ""
        lvm: listviewMethods symtab: symtab ctx: ctx monoId: monoId nm: nm.stringview ect: ect.stringview
        t4: applyTmpl text: t3 key: "LISTVIEW_METHODS" val: lvm.stringview
        buf.append t4.stringview
        buf.append "\n"
    } case err then {
        return
    }
    co: symtab.typing.childOf parentTypeId: monoId name: "contains"
    match (
        co
    ) case some then {
        c0: "static bool z_\{nm}_contains(z_\{nm}_t* _this, \{ect} _needle);\n"
        buf.append c0.stringview
        c1: "static bool z_\{nm}_contains(z_\{nm}_t* _this, \{ect} _needle) {\n"
        buf.append c1.stringview
        buf.append "    for (uint64_t i = 0; i < _this->length; i++) {\n"
        if isStrEl9 then {
            buf.append "        if (_this->data[i].size == _needle.size && memcmp(_this->data[i].data, _needle.data, _needle.size) == 0) return true;\n"
        } else {
            buf.append "        if (_this->data[i] == _needle) return true;\n"
        }
        buf.append "    }\n"
        buf.append "    return false;\n"
        buf.append "}\n\n"
    } case none then {}
    so: symtab.typing.childOf parentTypeId: monoId name: "sort"
    match (
        so
    ) case some then {
        emitListSort nm: nm.stringview ect: ect.stringview isStr: isStrEl9 strC: ctx.strC.stringview buf: buf
    } case none then {}
}

# emitListSort -- stable in-place mergesort companion (scalar `<`).
emitListSort: function {nm: StringView ect: StringView isStr: bool strC: StringView buf: String.borrow} is {
    if isStr then {
        s0s: "static int z_\{nm}_sort_lt(\{ect} _a, \{ect} _b) { return \{strC}_cmp(&_a, &_b) < 0; }\n"
        buf.append s0s.stringview
    } else {
        s0: "static int z_\{nm}_sort_lt(\{ect} _a, \{ect} _b) { return _a < _b; }\n"
        buf.append s0.stringview
    }
    s1: "static void z_\{nm}_sort_merge(\{ect}* data, \{ect}* scratch, uint64_t lo, uint64_t mid, uint64_t hi) {\n"
    buf.append s1.stringview
    buf.append "    uint64_t i = lo, j = mid, k = lo;\n"
    buf.append "    while (i < mid && j < hi) {\n"
    sm: "        if (!z_\{nm}_sort_lt(data[j], data[i])) scratch[k++] = data[i++];\n"
    buf.append sm.stringview
    buf.append "        else scratch[k++] = data[j++];\n"
    buf.append "    }\n"
    buf.append "    while (i < mid) scratch[k++] = data[i++];\n"
    buf.append "    while (j < hi) scratch[k++] = data[j++];\n"
    buf.append "    memcpy(&data[lo], &scratch[lo], (hi - lo) * sizeof(*data));\n"
    buf.append "}\n"
    s2: "static void z_\{nm}_sort_rec(\{ect}* data, \{ect}* scratch, uint64_t lo, uint64_t hi) {\n"
    buf.append s2.stringview
    buf.append "    if (hi - lo <= 1) return;\n"
    buf.append "    uint64_t mid = lo + (hi - lo) / 2;\n"
    sr1: "    z_\{nm}_sort_rec(data, scratch, lo, mid);\n"
    buf.append sr1.stringview
    sr2: "    z_\{nm}_sort_rec(data, scratch, mid, hi);\n"
    buf.append sr2.stringview
    sr3: "    z_\{nm}_sort_merge(data, scratch, lo, mid, hi);\n"
    buf.append sr3.stringview
    buf.append "}\n"
    s3: "static void z_\{nm}_sort(z_\{nm}_t* _this) {\n"
    buf.append s3.stringview
    buf.append "    if (_this->length < 2) return;\n"
    sa: "    \{ect}* scratch = (\{ect}*)z_xmalloc(_this->length * sizeof(\{ect}));\n"
    buf.append sa.stringview
    sd: "    z_\{nm}_sort_rec(_this->data, scratch, 0, _this->length);\n"
    buf.append sd.stringview
    buf.append "    free(scratch);\n"
    buf.append "}\n\n"
}

# emitListViewMono -- substitute z_ListView.c.tmpl for a ListView mono.
emitListViewMono: function {symtab: zenv.ZSymbolTable ctx: Ctx runtimeDir: StringView monoId: u64 buf: String.borrow} is {
    mn: typeNameOfReg9 symtab: symtab tid: monoId
    nm: cbaseNoPrefix tid: monoId name: mn.stringview
    eid: listElemType symtab: symtab monoId: monoId
    ect0: typeRefC symtab: symtab ctx: ctx tid: eid thisTid: 0.u64
    ect: ctypeOrI64 s: ect0.stringview
    p: "\{runtimeDir}/z_ListView.c.tmpl"
    raw: io.readText path: p.stringview
    match (
        raw
    ) case ok then {
        t1: applyTmpl text: raw key: "NAME" val: nm.stringview
        t2: applyTmpl text: t1 key: "ELEM_T" val: ect.stringview
        buf.append t2.stringview
        buf.append "\n"
    } case err then {}
}

# listviewMethods -- the _listview cast + _extendView companions when a
# List mono carries a listview child; "" otherwise.
listviewMethods: function {symtab: zenv.ZSymbolTable ctx: Ctx monoId: u64 nm: StringView ect: StringView} out String is {
    lo: symtab.typing.childOf parentTypeId: monoId name: "listview"
    match (
        lo
    ) case some then {
        t: symtab.reg.typeById.get key: lo
        match (
            t
        ) case some then {
            rt: t.returnTypeId
            match (
                rt
            ) case some then {
                lvn0: typeNameOfReg9 symtab: symtab tid: rt
                lvc: cnameOf tid: rt name: lvn0.stringview
                buf: "".string
                m0: "static \{lvc}_t z_\{nm}_listview(z_\{nm}_t* _this) { return *(\{lvc}_t*)_this; }\n"
                buf.append m0.stringview
                m1: "static void z_\{nm}_extendView(z_\{nm}_t* _this, \{lvc}_t _from) {\n"
                buf.append m1.stringview
                m2: "    z_\{nm}_grow(_this, _this->length + _from.length);\n"
                buf.append m2.stringview
                m3: "    memcpy(&_this->data[_this->length], _from.data, _from.length * sizeof(\{ect}));\n"
                buf.append m3.stringview
                buf.append "    _this->length += _from.length;\n"
                buf.append "}\n\n"
                return buf
            } case none then {}
        } case none then {}
    } case none then {}
    return "".string
}

# isGenericType -- the type is a generic template (arms typed by generic
# params; never emitted as a concrete struct).
isGenericType: function {symtab: zenv.ZSymbolTable tid: u64} out bool is {
    t: symtab.reg.typeById.get key: tid
    match (
        t
    ) case some then {
        return t.isgeneric
    } case none then {
        return false
    }
}

# definedInNonMain -- the type is defined in a non-main (system/io/...)
# unit (a reachable library type to emit alongside the main closure).
definedInNonMain: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64} out bool is {
    duo: symtab.typing.definedInUnit.get key: tid
    match (
        duo
    ) case some then {
        if duo.stringview == ctx.mainName.stringview then {
            return false
        } else {
            return true
        }
    } case none then {
        return false
    }
}

# emitUnionMono -- a UNION mono (Option/Result): tag enum + { tag; void*
# data } heap-payload struct + destroy (free the payload on non-null arms,
# recursing into an aggregate payload's destructor first).
emitUnionMono: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64 name: StringView buf: String.borrow} is {
    egu9: ctx.emittedUserTypes.get key: tid
    match (
        egu9
    ) case some then {
        return
    } case none then {}
    ctx.emittedUserTypes.set key: tid.u64 value: true
    anames: (List of: String)
    aids: (List of: u64)
    variantArms symtab: symtab tid: tid names: anames ids: aids
    vc: cnameOf tid: tid name: name
    buf.append "typedef enum {\n"
    ai: 0.u64
    an: anames.length
    for while ai < an loop {
        aname: anames.get i: ai
        tg: variantTag symtab: symtab tid: tid arm: aname.stringview
        lt: "    \{tg},\n"
        buf.append lt.stringview
        ai = ai + 1.u64
    }
    le: "} \{vc}_tag_t;\n"
    buf.append le.stringview
    buf.append "typedef struct {\n"
    lf: "    \{vc}_tag_t tag;\n"
    buf.append lf.stringview
    buf.append "    void* data;\n"
    lg: "} \{vc}_t;\n"
    buf.append lg.stringview
    ld: "static void \{vc}_destroy(\{vc}_t* u) {\n"
    buf.append ld.stringview
    buf.append "    if (!u) return;\n"
    buf.append "    if (!u->data) return;\n"
    buf.append "    switch (u->tag) {\n"
    pj: 0.u64
    for while pj < an loop {
        pname: anames.get i: pj
        pc: armPayloadC symtab: symtab ctx: ctx tid: tid arm: pname.stringview
        if pc.length > 0.u64 then {
            ptg: variantTag symtab: symtab tid: tid arm: pname.stringview
            lcase: "        case \{ptg}:\n"
            buf.append lcase.stringview
            pdtr: payloadDestructor symtab: symtab ctx: ctx tid: tid arm: pname.stringview
            if pdtr.length > 0.u64 then {
                ldd: "            \{pdtr}((\{pc}*)u->data);\n"
                buf.append ldd.stringview
            } else {}
            buf.append "            free(u->data);\n"
            buf.append "            break;\n"
        } else {}
        pj = pj + 1.u64
    }
    buf.append "        default: break;\n"
    buf.append "    }\n"
    buf.append "}\n\n"
}

# payloadDestructor -- the destructor cname for an arm whose payload is an
# aggregate with a destructor ("" for scalar/view payloads).
payloadDestructor: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64 arm: StringView} out String is {
    co: symtab.typing.childOf parentTypeId: tid name: arm
    match (
        co
    ) case some then {
        pn: typeNameOfReg9 symtab: symtab tid: co
        rid: optU64Or9 o: (ztypecheck.lookupTyperef resolved: symtab.typing.resolved mainName: ctx.mainName.stringview base: pn.stringview)
        if rid > 0.u64 then {
            # Build the destructor cname the way the emitter NAMES its definitions
            # (cnameOf + suffix), not from the stored destructorName String -- the
            # latter is a plain name (`String_destroy`) the port never substitutes
            # to the id-based form, and binding it off the borrowed registry value
            # would move out of the borrow (scope-exit free -> UAF). String, the
            # only native `_free` type, always owns its heap and is freed here.
            if pn.stringview == "String" then {
                return "\{ctx.strC}_free".string
            } else if (symtab.reg.hasDestructorName typeId: rid) then {
                cb: cnameOf tid: rid name: pn.stringview
                return "\{cb}_destroy".string
            } else {}
        } else {}
    } case none then {}
    return "".string
}

# usesHashCollections -- true when the program instantiates any Set or Map
# mono (gates the SipHash runtime + its startup seed).
usesHashCollections: function {symtab: zenv.ZSymbolTable} out bool is {
    last: symtab.reg.nextTypeId
    t: 0.u64
    for while t < last loop {
        onm: monoOriginName symtab: symtab tid: t
        if onm.stringview == "Set" then {
            return true
        } else {}
        if onm.stringview == "Map" then {
            return true
        } else {}
        t = t + 1.u64
    }
    return false
}

# monoIdByName -- a mono instance id looked up by its registry name, 0 absent.
monoIdByName: function {symtab: zenv.ZSymbolTable name: StringView} out u64 is {
    mo: symtab.typing.monoByName.get key: name.string
    match (
        mo
    ) case some then {
        return mo
    } case none then {
        return 0.u64
    }
}

# monoElemName -- a mono name's element segment, dropping a known prefix
# (e.g. "Set_i64" with prefixLen 4 -> "i64"). Substring rides String.stringview
# (a bare StringView receiver mis-resolves `from:/to:` to a .create).
monoElemName: function {full: String prefixLen: u64} out String is {
    fl: full.length
    rest: (full.stringview from: prefixLen to: fl)
    return rest.string
}

# setHashBody / setEqBody / setDestroyItems -- the element-kind-specific
# fragments of a Set mono: SipHash + memcmp + per-item free for String keys,
# the integer hash + `==` + no item cleanup otherwise.
setHashBody: function {isStr: bool} out String is {
    if isStr then {
        return "z_siphash_string(_key)".string
    } else {}
    return "z_hash_u64((uint64_t)_key)".string
}

setEqBody: function {isStr: bool} out String is {
    if isStr then {
        return "_a.size == _b.size && memcmp(_a.data, _b.data, _a.size) == 0".string
    } else {}
    return "_a == _b".string
}

setDestroyItems: function {isStr: bool strC: StringView} out String is {
    if isStr then {
        return "    for (uint64_t i = 0; i < p->entries_len; i++) {\n        if (p->entries[i].alive) {\n            \{strC}_free(&p->entries[i].item);\n        }\n    }\n".string
    } else {}
    return "".string
}

# emitOptionViewMono -- the borrowed-view option a collection iterator yields:
# a {tag; void* data} struct with a no-op destroy (the view owns nothing).
emitOptionViewMono: function {symtab: zenv.ZSymbolTable ctx: Ctx monoId: u64 buf: String.borrow} is {
    mn: typeNameOfReg9 symtab: symtab tid: monoId
    nm: cbaseNoPrefix tid: monoId name: mn.stringview
    ovu: cUpperOf text: mn.stringview
    buf.append "typedef enum {\n"
    l1: "    Z_\{ovu}_TAG_NONE,\n"
    buf.append l1.stringview
    l2: "    Z_\{ovu}_TAG_SOME,\n"
    buf.append l2.stringview
    l3: "} z_\{nm}_tag_t;\n"
    buf.append l3.stringview
    buf.append "typedef struct {\n"
    l4: "    z_\{nm}_tag_t tag;\n"
    buf.append l4.stringview
    buf.append "    void* data;\n"
    l5: "} z_\{nm}_t;\n"
    buf.append l5.stringview
    l6: "static void z_\{nm}_destroy(z_\{nm}_t* u) { (void)u; }\n\n"
    buf.append l6.stringview
}

# emitSetMono -- substitute z_Set.c.tmpl for a Set instance (compact-dict
# struct + add/has/delete/iterate + the SetIter companion). Depends on the
# element's OptionView mono being emitted first (the iterator yields it).
emitSetMono: function {symtab: zenv.ZSymbolTable ctx: Ctx runtimeDir: StringView monoId: u64 buf: String.borrow} is {
    mn: typeNameOfReg9 symtab: symtab tid: monoId
    nm: cbaseNoPrefix tid: monoId name: mn.stringview
    mcr: cUpperOf text: nm.stringview
    elemName: monoElemName full: mn prefixLen: 4.u64
    itemT: cTypeForName symtab: symtab ctx: ctx name: elemName.stringview
    isStr: elemName.stringview == "String"
    ovName: "OptionView_\{elemName}".string
    ovId: monoIdByName symtab: symtab name: ovName.stringview
    siName: "SetIter_\{elemName}".string
    siId: monoIdByName symtab: symtab name: siName.stringview
    if ovId == 0.u64 then {
        return
    } else {}
    if siId == 0.u64 then {
        return
    } else {}
    ov: cbaseNoPrefix tid: ovId name: ovName.stringview
    ovu: cUpperOf text: ovName.stringview
    si: cbaseNoPrefix tid: siId name: siName.stringview
    hashBody: setHashBody isStr: isStr
    eqBody: setEqBody isStr: isStr
    destroyItems: setDestroyItems isStr: isStr strC: ctx.strC.stringview
    p: "\{runtimeDir}/z_Set.c.tmpl"
    raw: io.readText path: p.stringview
    match (
        raw
    ) case ok then {
        t1: applyTmpl text: raw key: "NAME" val: nm.stringview
        t2: applyTmpl text: t1 key: "MACRO" val: mcr.stringview
        t3: applyTmpl text: t2 key: "ITEM_T" val: itemT.stringview
        t4: applyTmpl text: t3 key: "HASH_BODY" val: hashBody.stringview
        t5: applyTmpl text: t4 key: "EQ_BODY" val: eqBody.stringview
        t6: applyTmpl text: t5 key: "DESTROY_ITEMS" val: destroyItems.stringview
        t7: applyTmpl text: t6 key: "OPTIONVIEW" val: ov.stringview
        t8: applyTmpl text: t7 key: "OPTIONVIEW_TAG" val: ovu.stringview
        t9: applyTmpl text: t8 key: "SETITER" val: si.stringview
        buf.append t9.stringview
        buf.append "\n"
    } case err then {
        return
    }
}

# mapKeyName -- a Map mono's key segment: "Map_<K>_<V>" minus the "Map_"
# prefix and the trailing "_<V>" (vlen is the value name's length).
mapKeyName: function {full: String vlen: u64} out String is {
    fl: full.length
    endx: fl - vlen - 1.u64
    rest: (full.stringview from: 4.u64 to: endx)
    return rest.string
}

# mapDestroyEntries / mapFreeKeyDup / mapFreeKeyDel -- String-key cleanup
# fragments: per-entry key free on destroy, incoming-key free when a set hits
# an existing key, stored-key free on delete. Empty for non-heap keys.
mapDestroyEntries: function {isStr: bool strC: StringView} out String is {
    if isStr then {
        return "    for (uint64_t i = 0; i < p->entries_len; i++) {\n        if (p->entries[i].alive) {\n            \{strC}_free(&p->entries[i].key);\n        }\n    }\n".string
    } else {}
    return "".string
}

mapFreeKeyDup: function {isStr: bool strC: StringView} out String is {
    if isStr then {
        return "        \{strC}_free(&_key);\n".string
    } else {}
    return "".string
}

mapFreeKeyDel: function {isStr: bool strC: StringView} out String is {
    if isStr then {
        return "    \{strC}_free(&_this->entries[idx].key);\n".string
    } else {}
    return "".string
}

# emitMapIters -- the MapKeyIter/MapItemIter/MapEntry block for a Map mono,
# emitted only when those iterator monos were minted. Their OptionView returns
# (OptionView_<K>, OptionView_MapEntry_<K>_<V>) are defined by the earlier
# OptionView leg.
emitMapIters: function {symtab: zenv.ZSymbolTable runtimeDir: StringView nm: StringView keyName: StringView valName: StringView keyT: StringView valT: StringView buf: String.borrow} is {
    miiName: "MapItemIter_\{keyName}_\{valName}".string
    miiId: monoIdByName symtab: symtab name: miiName.stringview
    if miiId == 0.u64 then {
        return
    } else {}
    mkiName: "MapKeyIter_\{keyName}_\{valName}".string
    mkiId: monoIdByName symtab: symtab name: mkiName.stringview
    meName: "MapEntry_\{keyName}_\{valName}".string
    meId: monoIdByName symtab: symtab name: meName.stringview
    ovkName: "OptionView_\{keyName}".string
    ovkId: monoIdByName symtab: symtab name: ovkName.stringview
    oveName: "OptionView_\{meName}".string
    oveId: monoIdByName symtab: symtab name: oveName.stringview
    if mkiId == 0.u64 then {
        return
    } else {}
    if meId == 0.u64 then {
        return
    } else {}
    if ovkId == 0.u64 then {
        return
    } else {}
    if oveId == 0.u64 then {
        return
    } else {}
    mki: cbaseNoPrefix tid: mkiId name: mkiName.stringview
    mii: cbaseNoPrefix tid: miiId name: miiName.stringview
    me: cbaseNoPrefix tid: meId name: meName.stringview
    ovk: cbaseNoPrefix tid: ovkId name: ovkName.stringview
    ovku: cUpperOf text: ovkName.stringview
    ove: cbaseNoPrefix tid: oveId name: oveName.stringview
    oveu: cUpperOf text: oveName.stringview
    pi: "\{runtimeDir}/z_MapIter.c.tmpl"
    rawi: io.readText path: pi.stringview
    match (
        rawi
    ) case ok then {
        i1: applyTmpl text: rawi key: "NAME" val: nm
        i2: applyTmpl text: i1 key: "KEY_T" val: keyT
        i3: applyTmpl text: i2 key: "VAL_T" val: valT
        i4: applyTmpl text: i3 key: "MAPKEYITER" val: mki.stringview
        i5: applyTmpl text: i4 key: "OPTIONVIEW_K" val: ovk.stringview
        i6: applyTmpl text: i5 key: "OPTIONVIEW_K_TAG" val: ovku.stringview
        i7: applyTmpl text: i6 key: "MAPENTRY" val: me.stringview
        i8: applyTmpl text: i7 key: "MAPITEMITER" val: mii.stringview
        i9: applyTmpl text: i8 key: "OPTIONVIEW_ENTRY" val: ove.stringview
        i10: applyTmpl text: i9 key: "OPTIONVIEW_ENTRY_TAG" val: oveu.stringview
        buf.append i10.stringview
        buf.append "\n"
    } case err then {}
}

# emitMapMono -- substitute z_Map.c.tmpl for a Map instance (compact-dict +
# set/get/has/delete). The value's optionval mono (get's return) supplies the
# value type and the OPTIONVAL placeholders; the key name is the remainder.
emitMapMono: function {symtab: zenv.ZSymbolTable ctx: Ctx runtimeDir: StringView monoId: u64 buf: String.borrow} is {
    mn: typeNameOfReg9 symtab: symtab tid: monoId
    nm: cbaseNoPrefix tid: monoId name: mn.stringview
    mcr: cUpperOf text: nm.stringview
    ovId: 0.u64
    go: symtab.typing.childOf parentTypeId: monoId name: "get"
    match (
        go
    ) case some then {
        gt: symtab.reg.typeById.get key: go
        match (
            gt
        ) case some then {
            rto: gt.returnTypeId
            match (
                rto
            ) case some then {
                ovId = rto
            } case none then {}
        } case none then {}
    } case none then {}
    if ovId == 0.u64 then {
        return
    } else {}
    ovName: typeNameOfReg9 symtab: symtab tid: ovId
    ovOrigin: monoOriginName symtab: symtab tid: ovId
    ovPrefixLen: ovOrigin.length + 1.u64
    valName: monoElemName full: ovName prefixLen: ovPrefixLen
    valT: cTypeForName symtab: symtab ctx: ctx name: valName.stringview
    ov: cbaseNoPrefix tid: ovId name: ovName.stringview
    ovu: cUpperOf text: ovName.stringview
    keyName: mapKeyName full: mn vlen: valName.length
    keyT: cTypeForName symtab: symtab ctx: ctx name: keyName.stringview
    keyIsStr: keyName.stringview == "String"
    hashKeyBody: setHashBody isStr: keyIsStr
    keysEqBody: setEqBody isStr: keyIsStr
    destroyEntries: mapDestroyEntries isStr: keyIsStr strC: ctx.strC.stringview
    freeKeyDup: mapFreeKeyDup isStr: keyIsStr strC: ctx.strC.stringview
    freeKeyDel: mapFreeKeyDel isStr: keyIsStr strC: ctx.strC.stringview
    getBody: "".string
    if ovOrigin.stringview == "optionval" then {
        gbV: "    z_\{ov}_t _r;\n    if (idx >= 0) {\n        _r.tag = Z_\{ovu}_TAG_SOME;\n        _r.data.some = _this->entries[idx].value;\n    } else {\n        _r.tag = Z_\{ovu}_TAG_NONE;\n    }\n    return _r;"
        getBody = gbV
    } else {
        if valName.stringview == "String" then {
            gbS: "    z_\{ov}_t _r = {0};\n    if (idx >= 0) {\n        _r.tag = Z_\{ovu}_TAG_SOME;\n        \{valT}* _copy = (\{valT}*)z_xmalloc(sizeof(\{valT}));\n        _copy->size = _this->entries[idx].value.size;\n        _copy->capacity = _copy->size + 1;\n        _copy->data = (char*)z_xmalloc(_copy->capacity);\n        memcpy(_copy->data, _this->entries[idx].value.data, _copy->size);\n        _copy->data[_copy->size] = 0;\n        _r.data = _copy;\n    } else {\n        _r.tag = Z_\{ovu}_TAG_NONE;\n        _r.data = NULL;\n    }\n    return _r;"
            getBody = gbS
        } else {
            gbR: "    z_\{ov}_t _r = {0};\n    if (idx >= 0) {\n        _r.tag = Z_\{ovu}_TAG_SOME;\n        \{valT}* _copy = (\{valT}*)z_xmalloc(sizeof(\{valT}));\n        *_copy = _this->entries[idx].value;\n        _r.data = _copy;\n    } else {\n        _r.tag = Z_\{ovu}_TAG_NONE;\n        _r.data = NULL;\n    }\n    return _r;"
            getBody = gbR
        }
    }
    p: "\{runtimeDir}/z_Map.c.tmpl"
    raw: io.readText path: p.stringview
    match (
        raw
    ) case ok then {
        t1: applyTmpl text: raw key: "NAME" val: nm.stringview
        t2: applyTmpl text: t1 key: "MACRO" val: mcr.stringview
        t3: applyTmpl text: t2 key: "KEY_T" val: keyT.stringview
        t4: applyTmpl text: t3 key: "VAL_T" val: valT.stringview
        t5: applyTmpl text: t4 key: "HASH_KEY_BODY" val: hashKeyBody.stringview
        t6: applyTmpl text: t5 key: "KEYS_EQUAL_BODY" val: keysEqBody.stringview
        t7: applyTmpl text: t6 key: "DESTROY_ENTRIES" val: destroyEntries.stringview
        t8: applyTmpl text: t7 key: "FREE_KEY_DUP" val: freeKeyDup.stringview
        t9: applyTmpl text: t8 key: "FREE_KEY_DEL" val: freeKeyDel.stringview
        t10: applyTmpl text: t9 key: "OPTIONVAL" val: ov.stringview
        t11: applyTmpl text: t10 key: "OPTIONVAL_TAG" val: ovu.stringview
        t12: applyTmpl text: t11 key: "GET_BODY" val: getBody.stringview
        buf.append t12.stringview
        buf.append "\n"
    } case err then {
        return
    }
    emitMapIters symtab: symtab runtimeDir: runtimeDir nm: nm.stringview keyName: keyName.stringview valName: valName.stringview keyT: keyT.stringview valT: valT.stringview buf: buf
}

# emitMonos -- emit every collection-mono instance in the registry (List
# today; Map/Set/iterators land with their slices).
# ioCanonCname -- the id-based cname for an io canonical stem (the part after
# `z_` in a runtime fragment): a mono (Result_*/List_u8/...) via monoByName,
# else a named system type (IoError/File/filestat/Reader/...) by registry name.
# "" when the type is not in the (demand-driven) registry for this program.
ioCanonCname: function {symtab: zenv.ZSymbolTable ctx: Ctx canon: StringView} out String is {
    mo: symtab.typing.monoByName.get key: canon.string
    match (
        mo
    ) case some then {
        return (cnameOf tid: mo name: canon)
    } case none then {}
    last: symtab.reg.nextTypeId
    found: 0.u64
    ti: 1.u64
    for while ti < last loop {
        if found == 0.u64 then {
            if (definedInNonMain symtab: symtab ctx: ctx tid: ti) then {
                tn: typeNameOfReg9 symtab: symtab tid: ti
                if tn.stringview == canon then {
                    found = ti
                } else {}
            } else {}
        } else {}
        ti = ti + 1.u64
    }
    if found > 0.u64 then {
        return (cnameOf tid: found name: canon)
    } else {}
    return "".string
}

# loadIoFragment -- read an io/cli runtime `.inc` and substitute the canonical
# names it references (`z_<canon>` -> the typecheck cname) plus StringView/
# String. Tags (Z_IOERROR_TAG_*) are name-based and already match. Unregistered
# canons resolve to "" and are skipped. StringView before String (prefix).
loadIoFragment: function {symtab: zenv.ZSymbolTable ctx: Ctx path: StringView} out String is {
    rd: io.readText path: path
    match (
        rd
    ) case ok then {
        cur: substituteAll text: rd needle: "z_StringView" repl: ctx.svC.stringview
        canons: (List of: String)
        canons.append "Result_List_String_IoError".string
        canons.append "Result_filestat_IoError".string
        canons.append "Result_String_IoError".string
        canons.append "Result_File_IoError".string
        canons.append "Result_null_IoError".string
        canons.append "Result_u64_IoError".string
        canons.append "Option_String".string
        canons.append "ListView_u8".string
        canons.append "List_String".string
        canons.append "List_u8".string
        canons.append "BufWriter".string
        canons.append "BufReader".string
        canons.append "TextWriter".string
        canons.append "TextReader".string
        canons.append "IoError".string
        canons.append "filestat".string
        canons.append "openmode".string
        canons.append "seekorigin".string
        canons.append "filekind".string
        canons.append "Reader".string
        canons.append "Writer".string
        canons.append "Closer".string
        canons.append "Seeker".string
        canons.append "File".string
        canons.append "Result_Parsed_CliError".string
        canons.append "Map_String_String".string
        canons.append "List_PositionalDef".string
        canons.append "List_OptionDef".string
        canons.append "List_FlagDef".string
        canons.append "PositionalDef".string
        canons.append "OptionDef".string
        canons.append "FlagDef".string
        canons.append "CliError".string
        canons.append "Parsed".string
        canons.append "Spec".string
        canons.append "platformkind".string
        canons.append "archkind".string
        ci: 0.u64
        cn: canons.length
        for while ci < cn loop {
            canon: canons.get i: ci
            cc: ioCanonCname symtab: symtab ctx: ctx canon: canon.stringview
            if cc.length > 0.u64 then {
                needle: "z_\{canon}".string
                cur = substituteAll text: cur needle: needle.stringview repl: cc.stringview
            } else {}
            ci = ci + 1.u64
        }
        cur = substituteAll text: cur needle: "z_String" repl: ctx.strC.stringview
        return cur
    } case err then {
        return "/* zemitterc: missing io fragment \{path} */\n".string
    }
}

# ioFragIf -- emit an io runtime fragment when its need flag is set.
ioFragIf: function {symtab: zenv.ZSymbolTable ctx: Ctx runtimeDir: StringView need: StringView frag: StringView buf: String.borrow} is {
    if (needsHas ctx: ctx name: need) then {
        p9: nativePath runtimeDir: runtimeDir frag: frag
        f9: loadIoFragment symtab: symtab ctx: ctx path: p9.stringview
        buf.append f9.stringview
        buf.append "\n"
    } else {}
}

# ioFileId -- the io File class type id (0 when File is not reachable).
ioFileId: function {symtab: zenv.ZSymbolTable ctx: Ctx} out u64 is {
    last: symtab.reg.nextTypeId
    ti: 1.u64
    for while ti < last loop {
        if (symtab.reg.typetypeOf typeId: ti) == ztypes.ztypetype.CLASS then {
            tn: typeNameOfReg9 symtab: symtab tid: ti
            if tn.stringview == "File" when (definedInNonMain symtab: symtab ctx: ctx tid: ti) then {
                return ti
            } else {}
        } else {}
        ti = ti + 1.u64
    }
    return 0.u64
}

# ioClassReferenced -- a reachable io/os/cli class named `name`.
ioClassReferenced: function {symtab: zenv.ZSymbolTable ctx: Ctx name: StringView} out bool is {
    last: symtab.reg.nextTypeId
    ti: 1.u64
    for while ti < last loop {
        if (symtab.reg.typetypeOf typeId: ti) == ztypes.ztypetype.CLASS then {
            tn: typeNameOfReg9 symtab: symtab tid: ti
            if tn.stringview == name then {
                duo: symtab.typing.definedInUnit.get key: ti
                match (
                    duo
                ) case some then {
                    if duo.stringview == "io" then {
                        return true
                    } else {}
                    if duo.stringview == "os" then {
                        return true
                    } else {}
                    if duo.stringview == "cli" then {
                        return true
                    } else {}
                } case none then {}
            } else {}
        } else {}
        ti = ti + 1.u64
    }
    return false
}

# cliClassTypeId -- the type id of a cli-unit CLASS named `name` (0 absent).
cliClassTypeId: function {symtab: zenv.ZSymbolTable ctx: Ctx name: StringView} out u64 is {
    last: symtab.reg.nextTypeId
    ti: 1.u64
    for while ti < last loop {
        if (symtab.reg.typetypeOf typeId: ti) == ztypes.ztypetype.CLASS then {
            tn: typeNameOfReg9 symtab: symtab tid: ti
            if tn.stringview == name then {
                duo: symtab.typing.definedInUnit.get key: ti
                match (
                    duo
                ) case some then {
                    if duo.stringview == "cli" then {
                        return ti
                    } else {}
                } case none then {}
            } else {}
        } else {}
        ti = ti + 1.u64
    }
    return 0.u64
}

# isHeapPtrCollection -- a Map/Set mono is stored as a heap pointer (List is
# embedded by value); a struct field of one is a pointer, freed without `&`.
# fieldMonoId -- resolve a field/param type id to its real collection-mono id.
# A field child is often a fresh SHELL id (named after the type, no defining
# unit); `typeRefC` resolves it by name, and so must any origin/destructor query
# (else monoOriginName of the shell is "" and a Map/List field looks scalar).
fieldMonoId: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64} out u64 is {
    cid: tid
    duo: symtab.typing.definedInUnit.get key: tid
    match (
        duo
    ) case some then {} case none then {
        tn: typeNameOfReg9 symtab: symtab tid: tid
        rid: resolveTypeIdByName symtab: symtab ctx: ctx name: tn.stringview
        if rid > 0.u64 then {
            cid = rid
        } else {}
    }
    return (chaseColMono symtab: symtab tid: cid)
}

isHeapPtrCollection: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64} out bool is {
    cm: fieldMonoId symtab: symtab ctx: ctx tid: tid
    onm: monoOriginName symtab: symtab tid: cm
    if onm.stringview == "Map" then {
        return true
    } else {}
    if onm.stringview == "Set" then {
        return true
    } else {}
    return false
}

# cliClassIsComposite -- a cli class holding any List/Map/Set field; such a
# class must be emitted after the collection monos it embeds (Spec/Parsed),
# while leaf classes (FlagDef/OptionDef/PositionalDef) emit before them.
cliClassIsComposite: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64} out bool is {
    fnames: (List of: String)
    fids: (List of: u64)
    recFieldLists symtab: symtab tid: tid names: fnames ids: fids
    fi: 0.u64
    fn0: fnames.length
    for while fi < fn0 loop {
        fid: fids.get i: fi
        cm: fieldMonoId symtab: symtab ctx: ctx tid: fid
        onm: monoOriginName symtab: symtab tid: cm
        if onm.stringview == "List" then {
            return true
        } else {}
        if onm.stringview == "Map" then {
            return true
        } else {}
        if onm.stringview == "Set" then {
            return true
        } else {}
        fi = fi + 1.u64
    }
    return false
}

# emitCliFwdDecls -- Parsed is the ok-arm payload of Result_Parsed_CliError,
# whose destructor (emitted with the Option/Result monos) casts to and frees a
# Parsed before Parsed's own body emits (late, after its collection monos). A
# named-tag forward typedef + a destructor prototype satisfy that forward use.
emitCliFwdDecls: function {symtab: zenv.ZSymbolTable ctx: Ctx buf: String.borrow} is {
    pid: cliClassTypeId symtab: symtab ctx: ctx name: "Parsed"
    if pid == 0.u64 then {
        return
    } else {}
    pc: cnameOf tid: pid name: "Parsed"
    l0: "typedef struct \{pc}_t \{pc}_t;\n"
    buf.append l0.stringview
    l1: "static void \{pc}_destroy(\{pc}_t* p);\n"
    buf.append l1.stringview
}

# ioFrag -- load + append an io runtime fragment unconditionally.
ioFrag: function {symtab: zenv.ZSymbolTable ctx: Ctx runtimeDir: StringView frag: StringView buf: String.borrow} is {
    p9: nativePath runtimeDir: runtimeDir frag: frag
    f9: loadIoFragment symtab: symtab ctx: ctx path: p9.stringview
    buf.append f9.stringview
    buf.append "\n"
}

# emitIoFileConformance -- protocol conformance helpers for every reachable io
# class (File -> Reader/Writer/Closer/Seeker; BufWriter -> Writer; BufReader ->
# Reader), emitted after the io natives the wrappers forward to.
emitIoFileConformance: function {symtab: zenv.ZSymbolTable ctx: Ctx buf: String.borrow} is {
    last: symtab.reg.nextTypeId
    ti: 1.u64
    for while ti < last loop {
        if (symtab.reg.typetypeOf typeId: ti) == ztypes.ztypetype.CLASS then {
            cmo9: monoOriginName symtab: symtab tid: ti
            if cmo9.length == 0.u64 then {
                duo9: symtab.typing.definedInUnit.get key: ti
                isIoC9: false
                match (
                    duo9
                ) case some then {
                    if duo9.stringview == "io" then {
                        isIoC9 = true
                    } else {}
                    if duo9.stringview == "os" then {
                        isIoC9 = true
                    } else {}
                    if duo9.stringview == "cli" then {
                        isIoC9 = true
                    } else {}
                } case none then {}
                if isIoC9 then {
                    cn9: typeNameOfReg9 symtab: symtab tid: ti
                    okEmit9: false
                    if cn9.stringview == "File" then {
                        okEmit9 = true
                    } else {
                        unc9: "io_uses_\{cn9}".string
                        if (needsHas ctx: ctx name: unc9.stringview) then {
                            okEmit9 = true
                        } else {}
                    }
                    if okEmit9 then {
                        emitProtocolImplsForType symtab: symtab ctx: ctx implTid: ti implName: cn9.stringview buf: buf
                    } else {}
                } else {}
            } else {}
        } else {}
        ti = ti + 1.u64
    }
}

# emitIoStdStreams -- io.stdin/stdout/stderr: a borrowed Reader/Writer over a
# static backing File on fd 0/1/2 (closed=true so RAII never closes it).
emitIoStdStreams: function {symtab: zenv.ZSymbolTable ctx: Ctx buf: String.borrow} is {
    needAny: false
    if (needsHas ctx: ctx name: "io_stdout") then {
        needAny = true
    } else {}
    if (needsHas ctx: ctx name: "io_stderr") then {
        needAny = true
    } else {}
    if (needsHas ctx: ctx name: "io_stdin") then {
        needAny = true
    } else {}
    if needAny then {} else {
        return
    }
    fid: ioFileId symtab: symtab ctx: ctx
    if fid == 0.u64 then {
        return
    } else {}
    fbase: cnameOf tid: fid name: "File"
    wcn: ioCanonCname symtab: symtab ctx: ctx canon: "Writer"
    rcn: ioCanonCname symtab: symtab ctx: ctx canon: "Reader"
    if (needsHas ctx: ctx name: "io_stdout") then {
        b0: "static \{fbase}_t z_io_stdout_File = { 1, true };\nstatic \{wcn}_t z_io_stdout(void) {\n    return \{fbase}_Writer_create(&z_io_stdout_File);\n}\n\n"
        buf.append b0.stringview
    } else {}
    if (needsHas ctx: ctx name: "io_stderr") then {
        b1: "static \{fbase}_t z_io_stderr_File = { 2, true };\nstatic \{wcn}_t z_io_stderr(void) {\n    return \{fbase}_Writer_create(&z_io_stderr_File);\n}\n\n"
        buf.append b1.stringview
    } else {}
    if (needsHas ctx: ctx name: "io_stdin") then {
        b2: "static \{fbase}_t z_io_stdin_File = { 0, true };\nstatic \{rcn}_t z_io_stdin(void) {\n    return \{fbase}_Reader_create(&z_io_stdin_File);\n}\n\n"
        buf.append b2.stringview
    } else {}
}

# emitIoFileClass -- the io.File value rep: { int32_t fd; bool closed } + a
# destructor that closes the fd once (RAII). Emitted only when File is reachable
# (in the demand-driven registry). The generic record path can't produce the
# close-fd destructor, so File gets this dedicated emitter.
emitIoFileClass: function {symtab: zenv.ZSymbolTable ctx: Ctx buf: String.borrow} is {
    last: symtab.reg.nextTypeId
    fid: 0.u64
    ti: 1.u64
    for while ti < last loop {
        if fid == 0.u64 then {
            if (symtab.reg.typetypeOf typeId: ti) == ztypes.ztypetype.CLASS then {
                tn: typeNameOfReg9 symtab: symtab tid: ti
                if tn.stringview == "File" then {
                    if (definedInNonMain symtab: symtab ctx: ctx tid: ti) then {
                        fid = ti
                    } else {}
                } else {}
            } else {}
        } else {}
        ti = ti + 1.u64
    }
    if fid == 0.u64 then {
        return
    } else {}
    fc: cnameOf tid: fid name: "File"
    l0: "typedef struct {\n    int32_t fd;\n    bool closed;\n} \{fc}_t;\n"
    buf.append l0.stringview
    l1: "static void \{fc}_destroy(\{fc}_t* p) {\n    if (!p) return;\n    if (p->closed) return;\n    close(p->fd);\n    p->closed = true;\n}\n\n"
    buf.append l1.stringview
}

# emitRuntimeIo -- the io runtime bodies (need-gated, dependency-ordered). The
# universal helpers (z_sv_to_cstr inline, errno-map) emit whenever any io call
# is present; the rest gate on their specific need.
emitRuntimeIo: function {symtab: zenv.ZSymbolTable ctx: Ctx runtimeDir: StringView buf: String.borrow} is {
    ioAct9: needsHas ctx: ctx name: "io"
    osEr9: osNeedsErrno ctx: ctx
    runIo9: ioAct9
    if (osNeedsSvCstr ctx: ctx) then {
        runIo9 = true
    } else {}
    if osEr9 then {
        runIo9 = true
    } else {}
    if runIo9 then {} else {
        return
    }
    csc: "static char* z_sv_to_cstr(\{ctx.svC}_t v) {\n    char* buf = (char*)z_xmalloc(v.length + 1);\n    if (v.length > 0) memcpy(buf, v.data, v.length);\n    buf[v.length] = '\\0';\n    return buf;\n}\n\n"
    buf.append csc.stringview
    needErr9: ioAct9
    if osEr9 then {
        needErr9 = true
    } else {}
    if needErr9 then {
        ioFrag symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_IO_ERRNO_MAP" buf: buf
    } else {}
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "io_eprintln" frag: "_Z_IO_EPRINTLN" buf: buf
    needWC: needsHas ctx: ctx name: "io_writeText"
    if (needsHas ctx: ctx name: "io_appendText") then {
        needWC = true
    } else {}
    if needWC then {
        p8: nativePath runtimeDir: runtimeDir frag: "_Z_IO_WRITE_COMMON"
        f8: loadIoFragment symtab: symtab ctx: ctx path: p8.stringview
        buf.append f8.stringview
        buf.append "\n"
    } else {}
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "io_readText" frag: "_Z_IO_READ_TEXT" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "io_writeText" frag: "_Z_IO_WRITE_TEXT" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "io_appendText" frag: "_Z_IO_APPEND_TEXT" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "io_open" frag: "_Z_IO_OPEN" buf: buf
    needU64: needsHas ctx: ctx name: "io_file_read"
    if (needsHas ctx: ctx name: "io_file_write") then {
        needU64 = true
    } else {}
    if (needsHas ctx: ctx name: "io_file_seek") then {
        needU64 = true
    } else {}
    if needU64 then {
        pwu: nativePath runtimeDir: runtimeDir frag: "_Z_IO_WRAP_U64_RESULT"
        fwu: loadIoFragment symtab: symtab ctx: ctx path: pwu.stringview
        buf.append fwu.stringview
        buf.append "\n"
    } else {}
    needNull: needsHas ctx: ctx name: "io_file_close"
    if (needsHas ctx: ctx name: "io_file_flush") then {
        needNull = true
    } else {}
    if (needsHas ctx: ctx name: "io_mkdir") then {
        needNull = true
    } else {}
    if (needsHas ctx: ctx name: "io_mkdirp") then {
        needNull = true
    } else {}
    if (needsHas ctx: ctx name: "io_remove") then {
        needNull = true
    } else {}
    if (needsHas ctx: ctx name: "io_rename") then {
        needNull = true
    } else {}
    if needNull then {
        pwn: nativePath runtimeDir: runtimeDir frag: "_Z_IO_WRAP_NULL_RESULT"
        fwn: loadIoFragment symtab: symtab ctx: ctx path: pwn.stringview
        buf.append fwn.stringview
        buf.append "\n"
    } else {}
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "io_file_close" frag: "_Z_FILE_CLOSE" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "io_file_write" frag: "_Z_FILE_WRITE" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "io_file_read" frag: "_Z_FILE_READ" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "io_file_seek" frag: "_Z_FILE_SEEK" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "io_file_flush" frag: "_Z_FILE_FLUSH" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "io_exists" frag: "_Z_IO_EXISTS" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "io_mkdir" frag: "_Z_IO_MKDIR" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "io_mkdirp" frag: "_Z_IO_MKDIRP" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "io_remove" frag: "_Z_IO_REMOVE" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "io_rename" frag: "_Z_IO_RENAME" buf: buf
    needFstat: needsHas ctx: ctx name: "io_stat"
    if (needsHas ctx: ctx name: "io_lstat") then {
        needFstat = true
    } else {}
    if needFstat then {
        psf: nativePath runtimeDir: runtimeDir frag: "_Z_IO_STAT_FILL"
        fsf: loadIoFragment symtab: symtab ctx: ctx path: psf.stringview
        buf.append fsf.stringview
        buf.append "\n"
    } else {}
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "io_stat" frag: "_Z_IO_STAT" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "io_lstat" frag: "_Z_IO_LSTAT" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "io_listDir" frag: "_Z_IO_LIST_DIR" buf: buf
    if (needsHas ctx: ctx name: "io_uses_BufWriter") then {
        ioFrag symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_BUFWRITER_CREATE" buf: buf
        ioFrag symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_BUFWRITER_FLUSH" buf: buf
        ioFrag symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_BUFWRITER_WRITE" buf: buf
    } else {}
    if (needsHas ctx: ctx name: "io_uses_BufReader") then {
        ioFrag symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_BUFREADER_CREATE" buf: buf
        ioFrag symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_BUFREADER_READ" buf: buf
    } else {}
    if (needsHas ctx: ctx name: "io_uses_TextWriter") then {
        ioFrag symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_TEXTWRITER_CREATE" buf: buf
        ioFrag symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_TEXTWRITER_WRITE" buf: buf
        ioFrag symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_TEXTWRITER_WRITE_LINE" buf: buf
        ioFrag symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_TEXTWRITER_FLUSH" buf: buf
    } else {}
    if (needsHas ctx: ctx name: "io_uses_TextReader") then {
        ioFrag symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_IO_UTF8_VALIDATE" buf: buf
        ioFrag symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_TEXTREADER_CREATE" buf: buf
        ioFrag symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_TEXTREADER_READ_LINE" buf: buf
        ioFrag symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_TEXTREADER_CALL" buf: buf
    } else {}
}

# emitRuntimeCli -- the cli runtime bodies (need-gated, dependency-ordered),
# reusing the io fragment loader/gate. The helpers ride the parse need (parse is
# their only caller) and precede parse's body for a clean forward declaration.
emitRuntimeCli: function {symtab: zenv.ZSymbolTable ctx: Ctx runtimeDir: StringView buf: String.borrow} is {
    if (needsHas ctx: ctx name: "cli") then {} else {
        return
    }
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "cli_spec_create" frag: "_Z_CLI_SPEC_CREATE" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "cli_addFlag" frag: "_Z_CLI_ADD_FLAG" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "cli_addOption" frag: "_Z_CLI_ADD_OPTION" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "cli_addPositional" frag: "_Z_CLI_ADD_POSITIONAL" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "cli_parse" frag: "_Z_CLI_HELPERS" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "cli_parse" frag: "_Z_CLI_PARSE" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "cli_helpText" frag: "_Z_CLI_HELP_TEXT" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "cli_hasFlag" frag: "_Z_PARSED_HAS_FLAG" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "cli_option" frag: "_Z_PARSED_GET_OPTION" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "cli_positional" frag: "_Z_PARSED_GET_POSITIONAL" buf: buf
}

# emitRuntimeOs -- the os runtime bodies (need-gated). Only os.args is wired so
# far: its argc/argv globals + the args() copy, both gated on the os_args need
# (main() captures argc/argv into the globals when the same need is set).
emitRuntimeOs: function {symtab: zenv.ZSymbolTable ctx: Ctx runtimeDir: StringView buf: String.borrow} is {
    if (needsHas ctx: ctx name: "os") then {} else {
        return
    }
    if (needsHas ctx: ctx name: "os_args") then {
        ioFrag symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_OS_ARGV_GLOBALS" buf: buf
        ioFrag symtab: symtab ctx: ctx runtimeDir: runtimeDir frag: "_Z_OS_ARGS" buf: buf
    } else {}
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "os_env" frag: "_Z_OS_GET_ENV" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "os_setEnv" frag: "_Z_OS_SET_ENV" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "os_unsetEnv" frag: "_Z_OS_UNSET_ENV" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "os_envNames" frag: "_Z_OS_ENV_NAMES" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "os_cwd" frag: "_Z_OS_CWD" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "os_setCwd" frag: "_Z_OS_SET_CWD" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "os_pid" frag: "_Z_OS_PID" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "os_ppid" frag: "_Z_OS_PPID" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "os_userName" frag: "_Z_OS_USER_NAME" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "os_homeDir" frag: "_Z_OS_HOME_DIR" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "os_platform" frag: "_Z_OS_PLATFORM" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "os_arch" frag: "_Z_OS_ARCH" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "os_hostname" frag: "_Z_OS_HOSTNAME" buf: buf
    ioFragIf symtab: symtab ctx: ctx runtimeDir: runtimeDir need: "os_exit" frag: "_Z_OS_EXIT" buf: buf
}

# maybePreEmitElem -- a main-unit user type (variant/record/class) used as a
# collection element is embedded BY VALUE by the List/ListView mono, so its
# struct must precede the mono. Emit it here (guarded by ctx.emittedUserTypes);
# its methods still emit later in emitRecordDefsIn. Monos / generics / typedefs
# and non-main types are handled by their own sweeps and skipped.
maybePreEmitElem: function {symtab: zenv.ZSymbolTable ctx: Ctx eid: u64 buf: String.borrow} is {
    if eid == 0.u64 then {
        return
    } else {}
    rid0: eid
    snm0: typeNameOfReg9 symtab: symtab tid: eid
    sduo: symtab.typing.definedInUnit.get key: eid
    match (
        sduo
    ) case some then {} case none then {
        if snm0.length > 0.u64 then {
            srid: resolveTypeIdByName symtab: symtab ctx: ctx name: snm0.stringview
            if srid > 0.u64 then {
                rid0 = srid
            } else {}
        } else {}
    }
    cid: chaseColMono symtab: symtab tid: rid0
    if (monoOriginName symtab: symtab tid: cid).length > 0.u64 then {
        return
    } else {}
    if (isGenericType symtab: symtab tid: cid) then {
        return
    } else {}
    if (definedInNonMain symtab: symtab ctx: ctx tid: cid) then {
        return
    } else {}
    nm: typeNameOfReg9 symtab: symtab tid: cid
    if nm.length == 0.u64 then {
        return
    } else {}
    tt: symtab.reg.typetypeOf typeId: cid
    if tt == ztypes.ztypetype.VARIANT then {
        emitOneVariant symtab: symtab ctx: ctx tid: cid name: nm.stringview buf: buf
    } else {}
    if tt == ztypes.ztypetype.RECORD then {
        emitOneRecord symtab: symtab ctx: ctx tid: cid name: nm.stringview buf: buf
    } else {}
    if tt == ztypes.ztypetype.CLASS then {
        emitOneRecord symtab: symtab ctx: ctx tid: cid name: nm.stringview buf: buf
    } else {}
    if tt == ztypes.ztypetype.PROTOCOL then {
        emitOneProtocol symtab: symtab ctx: ctx tid: cid name: nm.stringview buf: buf
    } else {}
    if tt == ztypes.ztypetype.UNION then {
        emitUnionMono symtab: symtab ctx: ctx tid: cid name: nm.stringview buf: buf
    } else {}
}

# preEmitEmbeddedTypes -- emit the main-unit user types a variant/record/class
# embeds BY VALUE (arm payloads, field types) before its own struct, so they are
# declared first. Idempotent via ctx.emittedUserTypes, which also breaks cycles.
preEmitEmbeddedTypes: function {symtab: zenv.ZSymbolTable ctx: Ctx ids: (List of: u64) buf: String.borrow} is {
    pi: 0.u64
    pn: ids.length
    for while pi < pn loop {
        eidv: ids.get i: pi
        maybePreEmitElem symtab: symtab ctx: ctx eid: eidv buf: buf
        pi = pi + 1.u64
    }
}

emitMonos: function {symtab: zenv.ZSymbolTable ctx: Ctx runtimeDir: StringView buf: String.borrow} is {
    last: symtab.reg.nextTypeId
    emitCliFwdDecls symtab: symtab ctx: ctx buf: buf
    # reachable non-mono system UNIONs (IoError) -- the error payload of the
    # Result monos; emit before them so the mono destructors can call IoError's.
    tsu: 0.u64
    for while tsu < last loop {
        if (symtab.reg.typetypeOf typeId: tsu) == ztypes.ztypetype.UNION then {
            iuo: monoOriginName symtab: symtab tid: tsu
            iugen: isGenericType symtab: symtab tid: tsu
            if iuo.length == 0.u64 when iugen == false then {
                iduo: symtab.typing.definedInUnit.get key: tsu
                isIoUnit: false
                match (
                    iduo
                ) case some then {
                    if iduo.stringview == "io" then {
                        isIoUnit = true
                    } else {}
                    if iduo.stringview == "os" then {
                        isIoUnit = true
                    } else {}
                    if iduo.stringview == "cli" then {
                        isIoUnit = true
                    } else {}
                } case none then {}
                if isIoUnit then {
                    iun: typeNameOfReg9 symtab: symtab tid: tsu
                    emitUnionMono symtab: symtab ctx: ctx tid: tsu name: iun.stringview buf: buf
                } else {}
            } else {}
        } else {}
        tsu = tsu + 1.u64
    }
    emitIoFileClass symtab: symtab ctx: ctx buf: buf
    # reachable cli LEAF classes (FlagDef/OptionDef/PositionalDef) -- pure-string
    # classes the List monos below embed; emitted before those monos.
    tclf: 0.u64
    for while tclf < last loop {
        if (symtab.reg.typetypeOf typeId: tclf) == ztypes.ztypetype.CLASS then {
            clfgen: isGenericType symtab: symtab tid: tclf
            clfmo: monoOriginName symtab: symtab tid: tclf
            if clfmo.length == 0.u64 when clfgen == false then {
                clfduo: symtab.typing.definedInUnit.get key: tclf
                isCliLeaf: false
                match (
                    clfduo
                ) case some then {
                    if clfduo.stringview == "cli" then {
                        isCliLeaf = true
                    } else {}
                } case none then {}
                if isCliLeaf when (cliClassIsComposite symtab: symtab ctx: ctx tid: tclf) then {
                    isCliLeaf = false
                } else {}
                if isCliLeaf then {
                    clfn: typeNameOfReg9 symtab: symtab tid: tclf
                    emitOneRecord symtab: symtab ctx: ctx tid: tclf name: clfn.stringview buf: buf
                } else {}
            } else {}
        } else {}
        tclf = tclf + 1.u64
    }
    # reachable non-mono system VARIANTs (parseerror, seekorigin, ...) --
    # payloads of the variant monos / used directly.
    tsv: 0.u64
    for while tsv < last loop {
        if (symtab.reg.typetypeOf typeId: tsv) == ztypes.ztypetype.VARIANT then {
            svo: monoOriginName symtab: symtab tid: tsv
            svgen: isGenericType symtab: symtab tid: tsv
            if svo.length == 0.u64 when svgen == false then {
                svu: definedInNonMain symtab: symtab ctx: ctx tid: tsv
                if svu then {
                    svn: typeNameOfReg9 symtab: symtab tid: tsv
                    emitOneVariant symtab: symtab ctx: ctx tid: tsv name: svn.stringview buf: buf
                } else {}
            } else {}
        } else {}
        tsv = tsv + 1.u64
    }
    # reachable non-mono system RECORDs (filestat) -- the ok payload of a Result
    # mono; after its filekind variant, before the Result monos that box it.
    tsr: 0.u64
    for while tsr < last loop {
        if (symtab.reg.typetypeOf typeId: tsr) == ztypes.ztypetype.RECORD then {
            sro: monoOriginName symtab: symtab tid: tsr
            srgen: isGenericType symtab: symtab tid: tsr
            if sro.length == 0.u64 when srgen == false then {
                rduo: symtab.typing.definedInUnit.get key: tsr
                isIoR: false
                match (
                    rduo
                ) case some then {
                    if rduo.stringview == "io" then {
                        isIoR = true
                    } else {}
                    if rduo.stringview == "os" then {
                        isIoR = true
                    } else {}
                    if rduo.stringview == "cli" then {
                        isIoR = true
                    } else {}
                } case none then {}
                if isIoR then {
                    srn: typeNameOfReg9 symtab: symtab tid: tsr
                    emitOneRecord symtab: symtab ctx: ctx tid: tsr name: srn.stringview buf: buf
                } else {}
            } else {}
        } else {}
        tsr = tsr + 1.u64
    }
    # optionval + resultval variant monos -- iterators/collection-gets /
    # parsers return them by value (payloads now resolvable).
    tido: 0.u64
    for while tido < last loop {
        oonm: monoOriginName symtab: symtab tid: tido
        isVm: false
        if oonm.stringview == "optionval" then { isVm = true } else {}
        if oonm.stringview == "resultval" then { isVm = true } else {}
        if isVm then {
            oovn: typeNameOfReg9 symtab: symtab tid: tido
            emitOneVariant symtab: symtab ctx: ctx tid: tido name: oovn.stringview buf: buf
        } else {}
        tido = tido + 1.u64
    }
    # Option union monos (tag + void* data heap payload) -- reftype
    # option returns (string strip/split, map get over reftype).
    tiu: 0.u64
    for while tiu < last loop {
        uonm: monoOriginName symtab: symtab tid: tiu
        isUM: false
        if uonm.stringview == "Option" then {
            isUM = true
        } else {}
        if uonm.stringview == "Result" then {
            isUM = true
        } else {}
        if isUM then {
            uvn: typeNameOfReg9 symtab: symtab tid: tiu
            emitUnionMono symtab: symtab ctx: ctx tid: tiu name: uvn.stringview buf: buf
        } else {}
        tiu = tiu + 1.u64
    }
    # OptionView structs -- the borrowed-view option every collection
    # iterator yields; emitted before the collections that reference it.
    tiov: 0.u64
    for while tiov < last loop {
        oovnm: monoOriginName symtab: symtab tid: tiov
        if oovnm.stringview == "OptionView" then {
            emitOptionViewMono symtab: symtab ctx: ctx monoId: tiov buf: buf
        } else {}
        tiov = tiov + 1.u64
    }
    # element types first: a main-unit user type used as a List/ListView element
    # is embedded by value, so its struct must precede the collection mono.
    # Iterating all monos covers nesting (a List of List_T processes List_T too).
    tpe: 0.u64
    for while tpe < last loop {
        peo: monoOriginName symtab: symtab tid: tpe
        isCol9: false
        if peo.stringview == "List" then {
            isCol9 = true
        } else {}
        if peo.stringview == "ListView" then {
            isCol9 = true
        } else {}
        if isCol9 then {
            elemId9: listElemType symtab: symtab monoId: tpe
            maybePreEmitElem symtab: symtab ctx: ctx eid: elemId9 buf: buf
        } else {}
        tpe = tpe + 1.u64
    }
    # ListView structs next -- a List's listview companion references
    # the ListView struct by value.
    tid: 0.u64
    for while tid < last loop {
        onm: monoOriginName symtab: symtab tid: tid
        if onm.stringview == "ListView" then {
            emitListViewMono symtab: symtab ctx: ctx runtimeDir: runtimeDir monoId: tid buf: buf
        } else {}
        tid = tid + 1.u64
    }
    tid2: 0.u64
    for while tid2 < last loop {
        onm2: monoOriginName symtab: symtab tid: tid2
        if onm2.stringview == "List" then {
            emitListMono symtab: symtab ctx: ctx runtimeDir: runtimeDir monoId: tid2 buf: buf
        } else {}
        tid2 = tid2 + 1.u64
    }
    # Set monos last -- the compact-dict + SetIter; needs its element's
    # OptionView (above) already defined.
    tset: 0.u64
    for while tset < last loop {
        snm: monoOriginName symtab: symtab tid: tset
        if snm.stringview == "Set" then {
            emitSetMono symtab: symtab ctx: ctx runtimeDir: runtimeDir monoId: tset buf: buf
        } else {}
        tset = tset + 1.u64
    }
    # Map monos -- the compact-dict over key+value; get's return optionval
    # (emitted above) supplies the value type.
    tmap: 0.u64
    for while tmap < last loop {
        mnm: monoOriginName symtab: symtab tid: tmap
        if mnm.stringview == "Map" then {
            emitMapMono symtab: symtab ctx: ctx runtimeDir: runtimeDir monoId: tmap buf: buf
        } else {}
        tmap = tmap + 1.u64
    }
    # reachable cli COMPOSITE classes (Spec/Parsed) -- after the List/Map monos
    # they embed; Parsed was forward-declared above for the Result mono destroy.
    tclc: 0.u64
    for while tclc < last loop {
        if (symtab.reg.typetypeOf typeId: tclc) == ztypes.ztypetype.CLASS then {
            clcgen: isGenericType symtab: symtab tid: tclc
            clcmo: monoOriginName symtab: symtab tid: tclc
            if clcmo.length == 0.u64 when clcgen == false then {
                clcduo: symtab.typing.definedInUnit.get key: tclc
                isCliComp: false
                match (
                    clcduo
                ) case some then {
                    if clcduo.stringview == "cli" then {
                        isCliComp = true
                    } else {}
                } case none then {}
                if isCliComp when (cliClassIsComposite symtab: symtab ctx: ctx tid: tclc) then {} else {
                    isCliComp = false
                }
                if isCliComp then {
                    clcn: typeNameOfReg9 symtab: symtab tid: tclc
                    fwd9: false
                    if clcn.stringview == "Parsed" then {
                        fwd9 = true
                    } else {}
                    emitCliCompositeClass symtab: symtab ctx: ctx tid: tclc name: clcn.stringview fwdDeclared: fwd9 buf: buf
                } else {}
            } else {}
        } else {}
        tclc = tclc + 1.u64
    }
    # reachable system PROTOCOLs (Reader/Writer/Closer/Seeker) -- emitted after
    # the collection monos their vtable function-pointer signatures reference.
    tsp: 0.u64
    for while tsp < last loop {
        if (symtab.reg.typetypeOf typeId: tsp) == ztypes.ztypetype.PROTOCOL then {
            spgen: isGenericType symtab: symtab tid: tsp
            if spgen then {} else {
                if (definedInNonMain symtab: symtab ctx: ctx tid: tsp) then {
                    spn: typeNameOfReg9 symtab: symtab tid: tsp
                    emitOneProtocol symtab: symtab ctx: ctx tid: tsp name: spn.stringview buf: buf
                } else {}
            }
        } else {}
        tsp = tsp + 1.u64
    }
    # reachable io wrapper CLASSes (BufWriter/BufReader/TextWriter/TextReader) --
    # after the protocols their .lock fields hold. File has its own emitter.
    tsc: 0.u64
    for while tsc < last loop {
        if (symtab.reg.typetypeOf typeId: tsc) == ztypes.ztypetype.CLASS then {
            scgen: isGenericType symtab: symtab tid: tsc
            scmo: monoOriginName symtab: symtab tid: tsc
            if scmo.length == 0.u64 when scgen == false then {
                scn: typeNameOfReg9 symtab: symtab tid: tsc
                cduo: symtab.typing.definedInUnit.get key: tsc
                isIoC: false
                match (
                    cduo
                ) case some then {
                    if cduo.stringview == "io" then {
                        isIoC = true
                    } else {}
                    if cduo.stringview == "os" then {
                        isIoC = true
                    } else {}
                    if cduo.stringview == "cli" then {
                        isIoC = true
                    } else {}
                } case none then {}
                if isIoC when scn.stringview == "File" then {
                    isIoC = false
                } else {}
                unb9: "io_uses_\{scn}".string
                if isIoC when (needsHas ctx: ctx name: unb9.stringview) then {
                    emitOneRecord symtab: symtab ctx: ctx tid: tsc name: scn.stringview buf: buf
                } else {}
            } else {}
        } else {}
        tsc = tsc + 1.u64
    }
}

# emitRecordDefs -- main-unit record structs + meta_create constructors
# (scalar/record fields; the create alias mirrors the reference).
emitRecordDefs: function {program: Node symtab: zenv.ZSymbolTable ctx: Ctx buf: String.borrow} is {
    match (
        program
    ) case program then {
        mainName: program.mainUnitName.stringview
        with uiter: program.units.iterate do for u: uiter loop {
            match (
                u
            ) case namedoperation then {
                un: unitLabel9 o: u.name
                if un.stringview == mainName then {
                    emitRecordDefsIn symtab: symtab ctx: ctx mainOp: u.operation buf: buf
                } else {}
            } else {}
        }
    } else {}
}

# emitDefMethods -- emit a record/class def's as-block methods (forward decls
# when declOnly, bodies otherwise). Used by the method passes of emitRecordDefsIn.
emitDefMethods: function {symtab: zenv.ZSymbolTable ctx: Ctx bm: Node declOnly: bool buf: String.borrow} is {
    match (
        bm
    ) case namedoperation then {
        if (isRecordDef9 n: bm.operation) then {
            nm: unitLabel9 o: bm.name
            rid: userFnId symtab: symtab ctx: ctx name: nm.stringview
            if rid > 0.u64 then {
                emitRecordMethods symtab: symtab ctx: ctx tid: rid op: bm.operation declOnly: declOnly buf: buf
            } else {}
        } else {}
        if (isClassDef9 n: bm.operation) then {
            nmc: unitLabel9 o: bm.name
            cid9: userFnId symtab: symtab ctx: ctx name: nmc.stringview
            if cid9 > 0.u64 then {
                emitRecordMethods symtab: symtab ctx: ctx tid: cid9 op: bm.operation declOnly: declOnly buf: buf
            } else {}
        } else {}
    } else {}
}

# isProtocolDef9 -- an objectdef whose kind is PROTOCOL.
isProtocolDef9: function {n: Node} out bool is {
    match (
        n
    ) case objectdef then {
        if n.kind == zast.nodetype.PROTOCOL then {
            return true
        } else {
            return false
        }
    } else {
        return false
    }
}

# protoChildMethods -- a protocol's spec-method children (FUNCTION children,
# excluding the synth create/borrow), names + ids in registration order.
protoChildMethods: function {symtab: zenv.ZSymbolTable tid: u64 names: (List of: String) ids: (List of: u64)} is {
    with citer: symtab.typing.typeChild.iterate do for tc: citer loop {
        if tc.parentTypeId == tid then {
            cto: symtab.typing.childTypeById.get key: tc.childNameId
            match (
                cto
            ) case some then {
                if (symtab.reg.typetypeOf typeId: cto) == ztypes.ztypetype.FUNCTION then {
                    cn0: tc.childName.copy
                    isSynth: false
                    if cn0.stringview == "create" then {
                        isSynth = true
                    } else {}
                    if cn0.stringview == "borrow" then {
                        isSynth = true
                    } else {}
                    if isSynth then {} else {
                        names.append cn0
                        ids.append cto
                    }
                } else {}
            } case none then {}
        } else {}
    }
}

# methodRetCtype -- a method's C return type via the registry returnTypeId
# (scalars/records/classes resolve through typeRefC); "void" when unset.
methodRetCtype: function {symtab: zenv.ZSymbolTable ctx: Ctx mid: u64 thisTid: u64} out String is {
    mro: ztypecheck.methodReturnOf st: symtab mid: mid
    match (
        mro
    ) case some then {
        rr: typeRefC symtab: symtab ctx: ctx tid: mro thisTid: thisTid
        if rr.length > 0.u64 then {
            return rr
        } else {}
    } case none then {}
    return "void".string
}

# protoParamCtype -- a protocol spec-method param's C type: typeRefC, with a
# `*` for collection params (List/ListView/Map and the Bytes/ByteView typedefs),
# which the vtable function pointers and wrappers pass by pointer.
protoParamCtype: function {symtab: zenv.ZSymbolTable ctx: Ctx pid: u64 thisTid: u64} out String is {
    # the spec param is a shell named after the system type; canonicalize to the
    # real id (resolveTypeIdByName covers system types) so typeRefC resolves it
    # (and chases ByteView/Bytes to their collection mono).
    cpid: pid
    pn9: typeNameOfReg9 symtab: symtab tid: pid
    rcid: resolveTypeIdByName symtab: symtab ctx: ctx name: pn9.stringview
    if rcid > 0.u64 then {
        cpid = rcid
    } else {}
    pct: typeRefC symtab: symtab ctx: ctx tid: cpid thisTid: thisTid
    if pct.length == 0.u64 then {
        pct = "int64_t".string
    } else {}
    isCol: false
    if (chaseColMono symtab: symtab tid: cpid) != cpid then {
        isCol = true
    } else {}
    pco9: monoOriginName symtab: symtab tid: cpid
    if (isCollectionOrigin name: pco9.stringview) then {
        isCol = true
    } else {}
    if isCol then {
        return "\{pct}*"
    } else {}
    return pct
}

# emitOneProtocol -- the protocol value representation: vtable typedef (one
# function pointer per spec method, `this` dropped for a leading void*),
# the fat-pointer struct {data, vtable, destroy}, and the destroy helper.
emitOneProtocol: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64 name: StringView buf: String.borrow} is {
    egp9: ctx.emittedUserTypes.get key: tid
    match (
        egp9
    ) case some then {
        return
    } case none then {}
    ctx.emittedUserTypes.set key: tid.u64 value: true
    pbase: cnameOf tid: tid name: name
    mnames: (List of: String)
    mids: (List of: u64)
    protoChildMethods symtab: symtab tid: tid names: mnames ids: mids
    vfuncs: "".string
    mi: 0.u64
    mn: mnames.length
    for while mi < mn loop {
        mname: mnames.get i: mi
        smid: mids.get i: mi
        mroP: ztypecheck.methodReturnOf st: symtab mid: smid
        match (
            mroP
        ) case some then {
            maybePreEmitElem symtab: symtab ctx: ctx eid: mroP buf: buf
        } case none then {}
        ret: methodRetCtype symtab: symtab ctx: ctx mid: smid thisTid: tid
        vparams: "void*".string
        pnames: (List of: String)
        pids: (List of: u64)
        recFieldLists symtab: symtab tid: smid names: pnames ids: pids
        preEmitEmbeddedTypes symtab: symtab ctx: ctx ids: pids buf: buf
        pi: 0.u64
        pn: pnames.length
        for while pi < pn loop {
            pnm: pnames.get i: pi
            pid: pids.get i: pi
            ptn: typeNameOfReg9 symtab: symtab tid: pid
            isThis: false
            if pnm.stringview == "this" then {
                isThis = true
            } else {}
            if ptn.stringview == "this" then {
                isThis = true
            } else {}
            if ptn.stringview == name then {
                isThis = true
            } else {}
            if pid == tid then {
                isThis = true
            } else {}
            if isThis then {} else {
                pct: protoParamCtype symtab: symtab ctx: ctx pid: pid thisTid: tid
                vparams.append ", "
                vparams.append pct.stringview
            }
            pi = pi + 1.u64
        }
        vline: "    \{ret} (*\{mname})(\{vparams});\n"
        vfuncs.append vline.stringview
        mi = mi + 1.u64
    }
    l0: "typedef struct {\n\{vfuncs}} \{pbase}_vtable_t;\n\n"
    buf.append l0.stringview
    l1: "typedef struct {\n    void* data;\n    \{pbase}_vtable_t* vtable;\n    void (*destroy)(void*);\n} \{pbase}_t;\n\n"
    buf.append l1.stringview
    l2: "static void \{pbase}_destroy(\{pbase}_t* proto) {\n    if (!proto) return;\n    if (proto->destroy) proto->destroy(proto->data);\n    proto->destroy = NULL;\n}\n\n"
    buf.append l2.stringview
}

# emitProtocolImpl -- the per-(impl,label) conformance helpers: one wrapper per
# spec method (casts void* -> impl, calls the impl method), the static vtable
# instance, the borrowed create (data=val, no destroy), and the owned
# create/destroy (heap-box the value, free + impl-destroy on drop).
emitProtocolImpl: function {symtab: zenv.ZSymbolTable ctx: Ctx implTid: u64 implName: StringView protoTid: u64 protoName: StringView label: StringView buf: String.borrow} is {
    omn: monoOriginName symtab: symtab tid: implTid
    if omn.length == 0.u64 then {} else {
        return
    }
    implBase: cnameOf tid: implTid name: implName
    implCtype: "\{implBase}_t"
    protoBase: cnameOf tid: protoTid name: protoName
    protoCtype: "\{protoBase}_t"
    vtableCtype: "\{protoBase}_vtable_t"
    wbase: "\{implBase}_\{label}"
    implIsClass: false
    if (symtab.reg.typetypeOf typeId: implTid) == ztypes.ztypetype.CLASS then {
        implIsClass = true
    } else {}
    mnames: (List of: String)
    mids: (List of: u64)
    protoChildMethods symtab: symtab tid: protoTid names: mnames ids: mids
    mi: 0.u64
    mn: mnames.length
    for while mi < mn loop {
        mname: mnames.get i: mi
        smid: mids.get i: mi
        ret: methodRetCtype symtab: symtab ctx: ctx mid: smid thisTid: protoTid
        wparams: "void* _data".string
        cargs: "_self".string
        if implIsClass then {} else {
            cargs = "(*_self)".string
        }
        pnames: (List of: String)
        pids: (List of: u64)
        recFieldLists symtab: symtab tid: smid names: pnames ids: pids
        pi: 0.u64
        pn: pnames.length
        for while pi < pn loop {
            pnm: pnames.get i: pi
            pid: pids.get i: pi
            ptn: typeNameOfReg9 symtab: symtab tid: pid
            isThis: false
            if pnm.stringview == "this" then {
                isThis = true
            } else {}
            if ptn.stringview == "this" then {
                isThis = true
            } else {}
            if ptn.stringview == protoName then {
                isThis = true
            } else {}
            if pid == protoTid then {
                isThis = true
            } else {}
            if isThis then {} else {
                pct: protoParamCtype symtab: symtab ctx: ctx pid: pid thisTid: protoTid
                wparams.append ", "
                wparams.append pct.stringview
                wparams.append " "
                wparams.append pnm.stringview
                cargs.append ", "
                cargs.append pnm.stringview
            }
            pi = pi + 1.u64
        }
        implMid: 0.u64
        imo: symtab.typing.childOf parentTypeId: implTid name: mname.stringview
        match (
            imo
        ) case some then {
            implMid = imo
        } case none then {}
        implMc: "".string
        if (definedInNonMain symtab: symtab ctx: ctx tid: implTid) then {
            implMc = "\{implBase}_\{mname}".string
        } else {
            implMtn: typeNameOfReg9 symtab: symtab tid: implMid
            implMc = (cnameOf tid: implMid name: implMtn.stringview)
        }
        retkw: "return ".string
        if ret.stringview == "void" then {
            retkw = "".string
        } else {}
        w0: "static \{ret} \{wbase}_\{mname}_wrapper(\{wparams}) {\n"
        buf.append w0.stringview
        w1: "    \{implCtype}* _self = (\{implCtype}*)_data;\n"
        buf.append w1.stringview
        w2: "    \{retkw}\{implMc}(\{cargs});\n"
        buf.append w2.stringview
        buf.append "}\n\n"
        mi = mi + 1.u64
    }
    vi0: "static \{vtableCtype} \{wbase}_vtable = {\n"
    buf.append vi0.stringview
    mj: 0.u64
    for while mj < mn loop {
        mname2: mnames.get i: mj
        vrow: "    .\{mname2} = \{wbase}_\{mname2}_wrapper,\n"
        buf.append vrow.stringview
        mj = mj + 1.u64
    }
    buf.append "};\n\n"
    bc0: "static \{protoCtype} \{wbase}_create(\{implCtype}* val) {\n    \{protoCtype} proto = {0};\n    proto.data = val;\n    proto.vtable = &\{wbase}_vtable;\n    proto.destroy = NULL;\n    return proto;\n}\n\n"
    buf.append bc0.stringview
    od0: "static void \{wbase}_owned_destroy(void* p) {\n"
    buf.append od0.stringview
    if (symtab.reg.hasDestructorName typeId: implTid) then {
        od1: "    \{implBase}_destroy((\{implCtype}*)p);\n"
        buf.append od1.stringview
    } else {}
    buf.append "    free(p);\n}\n\n"
    oc0: "static \{protoCtype} \{wbase}_create_owned(\{implCtype}* val) {\n    \{protoCtype} proto = {0};\n    \{implCtype}* boxed = (\{implCtype}*)z_xmalloc(sizeof(\{implCtype}));\n    *boxed = *val;\n    proto.data = boxed;\n    proto.vtable = &\{wbase}_vtable;\n    proto.destroy = \{wbase}_owned_destroy;\n    return proto;\n}\n\n"
    buf.append oc0.stringview
}

# emitProtocolImplsForType -- emit conformance helpers for every PROTOCOL the
# given impl type satisfies (facet conformances, e.g. :Text, get no vtable).
emitProtocolImplsForType: function {symtab: zenv.ZSymbolTable ctx: Ctx implTid: u64 implName: StringView buf: String.borrow} is {
    ptids: (List of: u64)
    plabels: (List of: String)
    with citer: symtab.typing.conformance.iterate do for row: citer loop {
        if row.implTypeId == implTid then {
            ptids.append row.specTypeId
            plabels.append row.label.copy
        } else {}
    }
    pi: 0.u64
    pn: ptids.length
    for while pi < pn loop {
        ptid: ptids.get i: pi
        plabel: plabels.get i: pi
        if (symtab.reg.typetypeOf typeId: ptid) == ztypes.ztypetype.PROTOCOL then {
            pname: typeNameOfReg9 symtab: symtab tid: ptid
            emitProtocolImpl symtab: symtab ctx: ctx implTid: implTid implName: implName protoTid: ptid protoName: pname.stringview label: plabel.stringview buf: buf
        } else {}
        pi = pi + 1.u64
    }
}

# conformanceLabelFor -- the as-block label under which implTid satisfies
# protoTid (e.g. "myreader"); "" when not found.
conformanceLabelFor: function {symtab: zenv.ZSymbolTable implTid: u64 protoTid: u64} out String is {
    res: "".string
    with citer: symtab.typing.conformance.iterate do for row: citer loop {
        if row.implTypeId == implTid when row.specTypeId == protoTid then {
            if res.length == 0.u64 then {
                res.append row.label.stringview
            } else {}
        } else {}
    }
    return res
}

# emitProtocolDispatch -- a method call on a protocol-typed receiver routes
# through the vtable: `r.read b: 5` -> `r.vtable->read(r.data, 5)`.
# fileTypeIdOf -- the io File class type id if `nid` stamps as File, else 0.
fileTypeIdOf: function {symtab: zenv.ZSymbolTable ctx: Ctx nid: u64} out u64 is {
    tid: stampIdOf symtab: symtab nid: nid
    if tid == 0.u64 then {
        return 0.u64
    } else {}
    if (symtab.reg.typetypeOf typeId: tid) == ztypes.ztypetype.CLASS then {} else {
        return 0.u64
    }
    omn9: monoOriginName symtab: symtab tid: tid
    if omn9.length == 0.u64 then {} else {
        return 0.u64
    }
    duo9: symtab.typing.definedInUnit.get key: tid
    isIoT9: false
    match (
        duo9
    ) case some then {
        if duo9.stringview == "io" then {
            isIoT9 = true
        } else {}
        if duo9.stringview == "os" then {
            isIoT9 = true
        } else {}
        if duo9.stringview == "cli" then {
            isIoT9 = true
        } else {}
    } case none then {}
    if isIoT9 then {
        return tid
    } else {}
    return 0.u64
}

# emitFileMethodCall -- a File method (close/read/write/seek/flush), native,
# taking the receiver by pointer and collection args (Bytes/ByteView) by
# pointer. "" for any non-File receiver.
emitFileMethodCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    bn: dottedBaseAtom n: call.callable
    if bn.length == 0.u64 then {
        return "".string
    } else {}
    mn: dottedChildText n: call.callable
    isFM: false
    if mn.stringview == "close" then {
        isFM = true
    } else {}
    if mn.stringview == "read" then {
        isFM = true
    } else {}
    if mn.stringview == "write" then {
        isFM = true
    } else {}
    if mn.stringview == "seek" then {
        isFM = true
    } else {}
    if mn.stringview == "flush" then {
        isFM = true
    } else {}
    if mn.stringview == "writeLine" then {
        isFM = true
    } else {}
    if isFM then {} else {
        return "".string
    }
    bnid: dottedBaseNodeId n: call.callable
    fid: fileTypeIdOf symtab: symtab ctx: ctx nid: bnid
    if fid == 0.u64 then {
        return "".string
    } else {}
    fcn9: typeNameOfReg9 symtab: symtab tid: fid
    fc: cnameOf tid: fid name: fcn9.stringview
    recv: aliasResolve ctx: ctx name: bn.stringview
    recvExpr: "&\{recv}".string
    if (isPtrVar ctx: ctx name: recv.stringview) then {
        recvExpr = recv
    } else {}
    needsAdd ctx: ctx name: "io"
    fmn: "io_file_\{mn}".string
    needsAdd ctx: ctx name: fmn.stringview
    if mn.stringview == "close" then {
        return "\{fc}_close(\{recvExpr})"
    } else {}
    if mn.stringview == "flush" then {
        return "\{fc}_flush(\{recvExpr})"
    } else {}
    if mn.stringview == "write" then {
        fv: ctorArgByLabel symtab: symtab ctx: ctx call: call label: "from"
        return "\{fc}_write(\{recvExpr}, &\{fv})"
    } else {}
    if mn.stringview == "read" then {
        iv: ctorArgByLabel symtab: symtab ctx: ctx call: call label: "into"
        mv: ctorArgByLabel symtab: symtab ctx: ctx call: call label: "max"
        return "\{fc}_read(\{recvExpr}, &\{iv}, \{mv})"
    } else {}
    if mn.stringview == "seek" then {
        tv: ctorArgByLabel symtab: symtab ctx: ctx call: call label: "to"
        ov: ctorArgByLabel symtab: symtab ctx: ctx call: call label: "from"
        return "\{fc}_seek(\{recvExpr}, \{tv}, \{ov})"
    } else {}
    if mn.stringview == "writeLine" then {
        wlv: ctorArgByLabel symtab: symtab ctx: ctx call: call label: "from"
        return "\{fc}_writeLine(\{recvExpr}, &\{wlv})"
    } else {}
    return "".string
}

# ioCreateWrapper -- the wrapper name X of an `io.X.create` callable, else "".
ioCreateWrapper: function {n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        ccn: atomTextOf n: n.child
        if ccn.stringview == "create" then {
            pb: dottedBaseAtom n: n.parent
            if pb.stringview == "io" then {
                return (dottedChildText n: n.parent)
            } else {}
        } else {}
    } else {}
    return "".string
}

# wrapperCreateArg -- one io-wrapper create arg by the create-param type: a
# protocol-lock param projects the `.lock` base to that protocol; a class-lock
# param takes the base's address; a scalar param emits the arg directly.
wrapperCreateArg: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData label: StringView ptid: u64} out String is {
    prtn: typeNameOfReg9 symtab: symtab tid: ptid
    prtid: resolveTypeIdByName symtab: symtab ctx: ctx name: prtn.stringview
    aiter: call.arguments.iterate
    for a: aiter loop {
        match (
            a
        ) case namedoperation then {
            al: unitLabel9 o: a.name
            if al.stringview == label then {
                if (symtab.reg.typetypeOf typeId: prtid) == ztypes.ztypetype.PROTOCOL then {
                    ab: dottedBaseAtom n: a.operation
                    abr: aliasResolve ctx: ctx name: ab.stringview
                    abnid: dottedBaseNodeId n: a.operation
                    abtid: stampIdOf symtab: symtab nid: abnid
                    abtn: typeNameOfReg9 symtab: symtab tid: abtid
                    abcb: cnameOf tid: abtid name: abtn.stringview
                    ablab: conformanceLabelFor symtab: symtab implTid: abtid protoTid: prtid
                    return "\{abcb}_\{ablab}_create(&\{abr})"
                } else {}
                if (symtab.reg.typetypeOf typeId: prtid) == ztypes.ztypetype.CLASS then {
                    ab2: dottedBaseAtom n: a.operation
                    abr2: aliasResolve ctx: ctx name: ab2.stringview
                    return "&\{abr2}"
                } else {}
                return (emitExpr symtab: symtab ctx: ctx n: a.operation)
            } else {}
        } else {}
    }
    return "0".string
}

# emitIoWrapperCreate -- `io.BufWriter.create to: w.lock capacity: 16` ->
# z_t{id}_BufWriter_create(<projected/addressed args in param order>). "" for
# any non-io-wrapper-create callee.
emitIoWrapperCreate: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    wn: ioCreateWrapper n: call.callable
    if wn.length == 0.u64 then {
        return "".string
    } else {}
    wid: resolveTypeIdByName symtab: symtab ctx: ctx name: wn.stringview
    if wid == 0.u64 then {
        return "".string
    } else {}
    if (symtab.reg.typetypeOf typeId: wid) == ztypes.ztypetype.CLASS then {} else {
        return "".string
    }
    cco: symtab.typing.childOf parentTypeId: wid name: "create"
    cid: 0.u64
    match (
        cco
    ) case some then {
        cid = cco
    } case none then {}
    if cid == 0.u64 then {
        return "".string
    } else {}
    pnames: (List of: String)
    pids: (List of: u64)
    recFieldLists symtab: symtab tid: cid names: pnames ids: pids
    args: "".string
    pi: 0.u64
    pn: pnames.length
    for while pi < pn loop {
        pnm: pnames.get i: pi
        ptid: pids.get i: pi
        astr: wrapperCreateArg symtab: symtab ctx: ctx call: call label: pnm.stringview ptid: ptid
        if pi > 0.u64 then {
            args.append ", "
        } else {}
        args.append astr.stringview
        pi = pi + 1.u64
    }
    wcn: cnameOf tid: wid name: wn.stringview
    un9w: "io_uses_\{wn}".string
    needsAdd ctx: ctx name: un9w.stringview
    return "\{wcn}_create(\{args})"
}

# emitIoCall -- a free io.* native call (io.readText/writeText/appendText/
# eprintln/open/exists/mkdir/.../stat/listDir): `z_io_<name>(args...)` in the
# native's parameter order, setting the per-call need so emitRuntimeIo emits
# the body. Returns "" for any non-io callee.
# isOsNoArgFn -- a no-arg os.* function (auto-called bare: os.pid / os.platform
# / os.cwd / ...). args is here too (the existing os.args leg).
isOsNoArgFn: function {name: StringView} out bool is {
    if name == "args" then { return true } else {}
    if name == "pid" then { return true } else {}
    if name == "ppid" then { return true } else {}
    if name == "platform" then { return true } else {}
    if name == "arch" then { return true } else {}
    if name == "cwd" then { return true } else {}
    if name == "hostname" then { return true } else {}
    if name == "userName" then { return true } else {}
    if name == "homeDir" then { return true } else {}
    if name == "envNames" then { return true } else {}
    return false
}

# osNoArgCallRhs -- a binding RHS that is a bare `os.<noArgFn>` auto-call
# (os.args / os.envNames return an owned List, so the binding's List branch
# must emit the call, not a fresh empty list).
osNoArgCallRhs: function {n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (osNoArgCallRhs n: n.expression)
    } case statementline then {
        return (osNoArgCallRhs n: n.statementline)
    } case dottedpath then {
        base9: atomTextOf n: n.parent
        if base9.stringview == "os" then {} else {
            return false
        }
        memb9: atomTextOf n: n.child
        return (isOsNoArgFn name: memb9.stringview)
    } else {
        return false
    }
}

# osNeedsSvCstr -- an os native that converts a StringView arg to a C string.
osNeedsSvCstr: function {ctx: Ctx} out bool is {
    if (needsHas ctx: ctx name: "os_env") then { return true } else {}
    if (needsHas ctx: ctx name: "os_setEnv") then { return true } else {}
    if (needsHas ctx: ctx name: "os_unsetEnv") then { return true } else {}
    if (needsHas ctx: ctx name: "os_setCwd") then { return true } else {}
    return false
}

# osNeedsErrno -- an os native that maps errno to an IoError.
osNeedsErrno: function {ctx: Ctx} out bool is {
    if (needsHas ctx: ctx name: "os_setEnv") then { return true } else {}
    if (needsHas ctx: ctx name: "os_unsetEnv") then { return true } else {}
    if (needsHas ctx: ctx name: "os_cwd") then { return true } else {}
    if (needsHas ctx: ctx name: "os_setCwd") then { return true } else {}
    if (needsHas ctx: ctx name: "os_userName") then { return true } else {}
    if (needsHas ctx: ctx name: "os_homeDir") then { return true } else {}
    if (needsHas ctx: ctx name: "os_hostname") then { return true } else {}
    return false
}

# emitOsCall -- an arg-taking os.* native (env/setEnv/unsetEnv/setCwd/exit):
# `z_os_<name>(args...)` in source order. "" for any non-os callee. (No-arg os
# fns ride the emitExpr dotted leg.)
emitOsCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    bn: dottedBaseAtom n: call.callable
    if bn.stringview == "os" then {} else {
        return "".string
    }
    mn: dottedChildText n: call.callable
    isOsC: false
    if mn.stringview == "env" then { isOsC = true } else {}
    if mn.stringview == "setEnv" then { isOsC = true } else {}
    if mn.stringview == "unsetEnv" then { isOsC = true } else {}
    if mn.stringview == "setCwd" then { isOsC = true } else {}
    if mn.stringview == "exit" then { isOsC = true } else {}
    if isOsC then {} else {
        return "".string
    }
    needsAdd ctx: ctx name: "os"
    oname9: "os_\{mn}".string
    needsAdd ctx: ctx name: oname9.stringview
    args: "".string
    first: true
    with aiter: call.arguments.iterate do for a: aiter loop {
        match (
            a
        ) case namedoperation then {
            av: emitExpr symtab: symtab ctx: ctx n: a.operation
            if first then {
                first = false
            } else {
                args.append ", "
            }
            args.append av.stringview
        } else {}
    }
    return "z_os_\{mn}(\{args})"
}

emitIoCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    bn: dottedBaseAtom n: call.callable
    if bn.stringview == "io" then {} else {
        return "".string
    }
    mn: dottedChildText n: call.callable
    fname: "".string
    if mn.stringview == "readText" then {
        fname = "z_io_readText".string
    } else {}
    if mn.stringview == "writeText" then {
        fname = "z_io_writeText".string
    } else {}
    if mn.stringview == "appendText" then {
        fname = "z_io_appendText".string
    } else {}
    if mn.stringview == "eprintln" then {
        fname = "z_io_eprintln".string
    } else {}
    if mn.stringview == "open" then {
        fname = "z_io_open".string
    } else {}
    if mn.stringview == "exists" then {
        fname = "z_io_exists".string
    } else {}
    if mn.stringview == "mkdir" then {
        fname = "z_io_mkdir".string
    } else {}
    if mn.stringview == "mkdirp" then {
        fname = "z_io_mkdirp".string
    } else {}
    if mn.stringview == "remove" then {
        fname = "z_io_remove".string
    } else {}
    if mn.stringview == "rename" then {
        fname = "z_io_rename".string
    } else {}
    if mn.stringview == "stat" then {
        fname = "z_io_stat".string
    } else {}
    if mn.stringview == "lstat" then {
        fname = "z_io_lstat".string
    } else {}
    if mn.stringview == "listDir" then {
        fname = "z_io_listDir".string
    } else {}
    if fname.length == 0.u64 then {
        return "".string
    } else {}
    needsAdd ctx: ctx name: "io"
    iname: "io_\{mn}".string
    needsAdd ctx: ctx name: iname.stringview
    args: "".string
    first: true
    with aiter: call.arguments.iterate do for a: aiter loop {
        match (
            a
        ) case namedoperation then {
            av: emitExpr symtab: symtab ctx: ctx n: a.operation
            if first then {
                first = false
            } else {
                args.append ", "
            }
            args.append av.stringview
        } else {}
    }
    return "\{fname}(\{args})"
}

# cliSpecArg -- the `spec:` argument of a cli free-function call, addressed
# (the natives take `z_Spec_t* spec`); a pointer receiver is passed as-is.
cliSpecArg: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    aiter: call.arguments.iterate
    for a: aiter loop {
        match (
            a
        ) case namedoperation then {
            al: unitLabel9 o: a.name
            if al.stringview == "spec" then {
                at: atomTextOf n: a.operation
                ar: aliasResolve ctx: ctx name: at.stringview
                if (isPtrVar ctx: ctx name: ar.stringview) then {
                    return ar
                } else {}
                return "&\{ar}".string
            } else {}
        } else {}
    }
    return "0".string
}

# emitCliCall -- a cli free-function (addFlag/addOption/addPositional/parse/
# helpText): `z_cli_<name>(&spec, …)` in the native's param order. "" otherwise.
emitCliCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    bn: dottedBaseAtom n: call.callable
    if bn.stringview == "cli" then {} else {
        return "".string
    }
    mn: dottedChildText n: call.callable
    isMod: false
    if mn.stringview == "addFlag" then {
        isMod = true
    } else {}
    if mn.stringview == "addOption" then {
        isMod = true
    } else {}
    if mn.stringview == "addPositional" then {
        isMod = true
    } else {}
    if mn.stringview == "parse" then {
        isMod = true
    } else {}
    if mn.stringview == "helpText" then {
        isMod = true
    } else {}
    if isMod then {} else {
        return "".string
    }
    needsAdd ctx: ctx name: "cli"
    cneed: "cli_\{mn}".string
    needsAdd ctx: ctx name: cneed.stringview
    sp9: cliSpecArg symtab: symtab ctx: ctx call: call
    if mn.stringview == "addFlag" then {
        na: ctorArgByLabel symtab: symtab ctx: ctx call: call label: "name"
        sa: ctorArgByLabel symtab: symtab ctx: ctx call: call label: "shortName"
        ha: ctorArgByLabel symtab: symtab ctx: ctx call: call label: "help"
        return "z_cli_addFlag(\{sp9}, \{na}, \{sa}, \{ha})"
    } else {}
    if mn.stringview == "addOption" then {
        na2: ctorArgByLabel symtab: symtab ctx: ctx call: call label: "name"
        sa2: ctorArgByLabel symtab: symtab ctx: ctx call: call label: "shortName"
        ha2: ctorArgByLabel symtab: symtab ctx: ctx call: call label: "help"
        ra2: ctorArgByLabel symtab: symtab ctx: ctx call: call label: "required"
        return "z_cli_addOption(\{sp9}, \{na2}, \{sa2}, \{ha2}, \{ra2})"
    } else {}
    if mn.stringview == "addPositional" then {
        na3: ctorArgByLabel symtab: symtab ctx: ctx call: call label: "name"
        ha3: ctorArgByLabel symtab: symtab ctx: ctx call: call label: "help"
        ra3: ctorArgByLabel symtab: symtab ctx: ctx call: call label: "required"
        return "z_cli_addPositional(\{sp9}, \{na3}, \{ha3}, \{ra3})"
    } else {}
    if mn.stringview == "parse" then {
        pa: ctorArgByLabel symtab: symtab ctx: ctx call: call label: "args"
        return "z_cli_parse(\{sp9}, \{pa})"
    } else {}
    if mn.stringview == "helpText" then {
        return "z_cli_helpText(\{sp9})"
    } else {}
    return "".string
}

# cliCreateClass -- the class name X of a `cli.X.create` callable, else "".
cliCreateClass: function {n: Node} out String is {
    match (
        n
    ) case dottedpath then {
        ccn: atomTextOf n: n.child
        if ccn.stringview == "create" then {
            pb: dottedBaseAtom n: n.parent
            if pb.stringview == "cli" then {
                return (dottedChildText n: n.parent)
            } else {}
        } else {}
    } else {}
    return "".string
}

# emitCliSpecCreate -- `cli.Spec.create programName: … summary: …` ->
# z_t{id}_Spec_create(<args in param order>). "" for any non-cli-create callee.
emitCliSpecCreate: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    cn: cliCreateClass n: call.callable
    if cn.length == 0.u64 then {
        return "".string
    } else {}
    cid: cliClassTypeId symtab: symtab ctx: ctx name: cn.stringview
    if cid == 0.u64 then {
        return "".string
    } else {}
    cco: symtab.typing.childOf parentTypeId: cid name: "create"
    crid: 0.u64
    match (
        cco
    ) case some then {
        crid = cco
    } case none then {}
    if crid == 0.u64 then {
        return "".string
    } else {}
    pnames: (List of: String)
    pids: (List of: u64)
    recFieldLists symtab: symtab tid: crid names: pnames ids: pids
    args: "".string
    pi: 0.u64
    pn: pnames.length
    for while pi < pn loop {
        pnm: pnames.get i: pi
        astr: ctorArgByLabel symtab: symtab ctx: ctx call: call label: pnm.stringview
        if pi > 0.u64 then {
            args.append ", "
        } else {}
        args.append astr.stringview
        pi = pi + 1.u64
    }
    needsAdd ctx: ctx name: "cli"
    needsAdd ctx: ctx name: "cli_spec_create"
    ccb: cnameOf tid: cid name: cn.stringview
    return "\{ccb}_create(\{args})"
}

# emitParsedMethodCall -- a Parsed accessor (hasFlag/option/positional), native,
# receiver by pointer (incl. the narrowed Result ok-arm projection) and the
# StringView name by pointer. "" for any non-Parsed receiver.
emitParsedMethodCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    bn: dottedBaseAtom n: call.callable
    if bn.length == 0.u64 then {
        return "".string
    } else {}
    mn: dottedChildText n: call.callable
    isPM: false
    if mn.stringview == "hasFlag" then {
        isPM = true
    } else {}
    if mn.stringview == "option" then {
        isPM = true
    } else {}
    if mn.stringview == "positional" then {
        isPM = true
    } else {}
    if isPM then {} else {
        return "".string
    }
    bnid: dottedBaseNodeId n: call.callable
    pid: fileTypeIdOf symtab: symtab ctx: ctx nid: bnid
    if pid == 0.u64 then {
        return "".string
    } else {}
    pcn: typeNameOfReg9 symtab: symtab tid: pid
    if pcn.stringview == "Parsed" then {} else {
        return "".string
    }
    pc: cnameOf tid: pid name: pcn.stringview
    recv: aliasResolve ctx: ctx name: bn.stringview
    recvExpr: "&\{recv}".string
    if (isPtrVar ctx: ctx name: recv.stringview) then {
        recvExpr = recv
    } else {}
    needsAdd ctx: ctx name: "cli"
    pneed: "cli_\{mn}".string
    needsAdd ctx: ctx name: pneed.stringview
    nameArg: ctorArgByLabel symtab: symtab ctx: ctx call: call label: "name"
    return "\{pc}_\{mn}(\{recvExpr}, &\{nameArg})"
}

# isLockArg -- the argument (through expression wrappers) is an `x.lock` borrow
# projection; such a value passes by address to a borrow param.
isLockArg: function {n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (isLockArg n: n.expression)
    } case dottedpath then {
        cn9: atomTextOf n: n.child
        return cn9.stringview == "lock"
    } else {
        return false
    }
}

# emitUserIterCall -- a manual `g.call value: X` on a user iterator class (a
# generator's iter): `z_t{id}_{Fn}_iter_call(&g, X)`; a `.lock` borrow value
# passes by address. "" for any non-user-iter `.call`.
emitUserIterCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    bn: dottedBaseAtom n: call.callable
    if bn.length == 0.u64 then {
        return "".string
    } else {}
    mn: dottedChildText n: call.callable
    if mn.stringview == "call" then {} else {
        return "".string
    }
    bnid: dottedBaseNodeId n: call.callable
    rid0: stampIdOf symtab: symtab nid: bnid
    if rid0 == 0.u64 then {
        return "".string
    } else {}
    iterId: rid0
    rtn9: typeNameOfReg9 symtab: symtab tid: rid0
    cano9: ztypecheck.lookupTyperef resolved: symtab.typing.resolved mainName: ctx.mainName.stringview base: rtn9.stringview
    match (
        cano9
    ) case some then {
        if (childExists symtab: symtab tid: cano9 name: "call") then {
            iterId = cano9
        } else {}
    } case none then {}
    if (symtab.reg.typetypeOf typeId: iterId) == ztypes.ztypetype.CLASS then {} else {
        return "".string
    }
    itorig9: monoOriginName symtab: symtab tid: iterId
    if itorig9.length == 0.u64 then {} else {
        return "".string
    }
    itn9: typeNameOfReg9 symtab: symtab tid: iterId
    if (userFnId symtab: symtab ctx: ctx name: itn9.stringview) > 0.u64 then {} else {
        return "".string
    }
    cco9: symtab.typing.childOf parentTypeId: iterId name: "call"
    match (
        cco9
    ) case some then {
        ccn9: typeNameOfReg9 symtab: symtab tid: cco9
        callC9: cnameOf tid: cco9 name: ccn9.stringview
        recv9: aliasResolve ctx: ctx name: bn.stringview
        recvExpr9: "&\{recv9}".string
        if (isPtrVar ctx: ctx name: recv9.stringview) then {
            recvExpr9 = recv9
        } else {}
        valArg9: "".string
        hasVal9: false
        with aiter9: call.arguments.iterate do for av9: aiter9 loop {
            match (
                av9
            ) case namedoperation then {
                al9: unitLabel9 o: av9.name
                if al9.stringview == "value" then {
                    hasVal9 = true
                    ve9: emitExpr symtab: symtab ctx: ctx n: av9.operation
                    if (isLockArg n: av9.operation) then {
                        valArg9 = "&\{ve9}".string
                    } else {
                        valArg9 = ve9
                    }
                } else {}
            } else {}
        }
        if hasVal9 then {
            return "\{callC9}(\{recvExpr9}, \{valArg9})"
        } else {}
        return "\{callC9}(\{recvExpr9})"
    } case none then {
        return "".string
    }
}

emitProtocolDispatch: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    bn: dottedBaseAtom n: call.callable
    if bn.length == 0.u64 then {
        return "".string
    } else {}
    mn: dottedChildText n: call.callable
    if mn.stringview == "create" then {
        return "".string
    } else {}
    if mn.stringview == "borrow" then {
        return "".string
    } else {}
    if mn.stringview == "release" then {
        return "".string
    } else {}
    bnid: dottedBaseNodeId n: call.callable
    baseTid: stampIdOf symtab: symtab nid: bnid
    if (symtab.reg.typetypeOf typeId: baseTid) == ztypes.ztypetype.PROTOCOL then {} else {
        return "".string
    }
    recv: aliasResolve ctx: ctx name: bn.stringview
    acc: ".".string
    if (isPtrVar ctx: ctx name: recv.stringview) then {
        acc = "->".string
    } else {}
    dargs: "\{recv}\{acc}data".string
    with aiter: call.arguments.iterate do for a: aiter loop {
        match (
            a
        ) case namedoperation then {
            av: emitExpr symtab: symtab ctx: ctx n: a.operation
            atid9: stampIdOf symtab: symtab nid: (nodeIdOf9 n: a.operation)
            apfx9: "".string
            if (chaseColMono symtab: symtab tid: atid9) != atid9 then {
                apfx9 = "&".string
            } else {}
            aco9: monoOriginName symtab: symtab tid: atid9
            if (isCollectionOrigin name: aco9.stringview) then {
                apfx9 = "&".string
            } else {}
            dargs.append ", "
            dargs.append apfx9.stringview
            dargs.append av.stringview
        } else {}
    }
    de: "\{recv}\{acc}vtable->\{mn}(\{dargs})"
    return de
}

# emitProtocolCreateCall -- `Reader.create from: g.take` (owned, heap-box +
# source invalidation) / `Provider.borrow from: m.lock` (borrowed, shares the
# source). Both route to the impl's conformance helper for the protocol.
emitProtocolCreateCall: function {symtab: zenv.ZSymbolTable ctx: Ctx call: zast.CallData} out String is {
    bn: dottedBaseAtom n: call.callable
    if bn.length == 0.u64 then {
        return "".string
    } else {}
    mn: dottedChildText n: call.callable
    isCreate: false
    if mn.stringview == "create" then {
        isCreate = true
    } else {}
    if mn.stringview == "borrow" then {
        isCreate = true
    } else {}
    if isCreate then {} else {
        return "".string
    }
    protoTid: resolveTypeIdByName symtab: symtab ctx: ctx name: bn.stringview
    if (symtab.reg.typetypeOf typeId: protoTid) == ztypes.ztypetype.PROTOCOL then {} else {
        return "".string
    }
    suffix: "create_owned".string
    if mn.stringview == "borrow" then {
        suffix = "create".string
    } else {}
    aiter: call.arguments.iterate
    for a: aiter loop {
        match (
            a
        ) case namedoperation then {
            an: unitLabel9 o: a.name
            if an.stringview == "from" then {
                fromBase: dottedBaseAtom n: a.operation
                if fromBase.length == 0.u64 then {
                    fromBase = (atomTextOf n: a.operation)
                } else {}
                fdn: stampNameDeep symtab: symtab n: a.operation
                fromTid: resolveTypeIdByName symtab: symtab ctx: ctx name: fdn.stringview
                if fromTid == 0.u64 then {
                    return "".string
                } else {}
                implName: typeNameOfReg9 symtab: symtab tid: fromTid
                implBase: cnameOf tid: fromTid name: implName.stringview
                label: conformanceLabelFor symtab: symtab implTid: fromTid protoTid: protoTid
                if label.length == 0.u64 then {
                    return "".string
                } else {}
                valVar: aliasResolve ctx: ctx name: fromBase.stringview
                ce: "\{implBase}_\{label}_\{suffix}(&\{valVar})"
                return ce
            } else {}
        } else {}
    }
    return "".string
}

# emitRecordDefsIn -- three passes so cross-class references resolve: all structs
# (+ variants + data blocks), then all method forward decls, then all method
# bodies (a method may return/construct a class defined later in the unit).
emitRecordDefsIn: function {symtab: zenv.ZSymbolTable ctx: Ctx mainOp: Node buf: String.borrow} is {
    match (
        mainOp
    ) case unitdef then {
        with biterU: mainOp.body.iterate do for bu: biterU loop {
            match (
                bu
            ) case namedoperation then {
                if (isUnionDef9 n: bu.operation) then {
                    nmu: unitLabel9 o: bu.name
                    uidu: userFnId symtab: symtab ctx: ctx name: nmu.stringview
                    if uidu > 0.u64 then {
                        emitUnionMono symtab: symtab ctx: ctx tid: uidu name: nmu.stringview buf: buf
                    } else {}
                } else {}
            } else {}
        }
        with biterP: mainOp.body.iterate do for bp: biterP loop {
            match (
                bp
            ) case namedoperation then {
                if (isProtocolDef9 n: bp.operation) then {
                    nmp: unitLabel9 o: bp.name
                    pid7: userFnId symtab: symtab ctx: ctx name: nmp.stringview
                    if pid7 > 0.u64 then {
                        emitOneProtocol symtab: symtab ctx: ctx tid: pid7 name: nmp.stringview buf: buf
                    } else {}
                } else {}
            } else {}
        }
        with biterA: mainOp.body.iterate do for bm: biterA loop {
            match (
                bm
            ) case namedoperation then {
                if (isRecordDef9 n: bm.operation) then {
                    nm: unitLabel9 o: bm.name
                    rid: userFnId symtab: symtab ctx: ctx name: nm.stringview
                    if rid > 0.u64 then {
                        emitOneRecord symtab: symtab ctx: ctx tid: rid name: nm.stringview buf: buf
                    } else {}
                } else {}
                if (isClassDef9 n: bm.operation) then {
                    nmc: unitLabel9 o: bm.name
                    cid9: userFnId symtab: symtab ctx: ctx name: nmc.stringview
                    if cid9 > 0.u64 then {
                        emitOneRecord symtab: symtab ctx: ctx tid: cid9 name: nmc.stringview buf: buf
                    } else {}
                } else {}
                if (isVariantDef9 n: bm.operation) then {
                    nm5: unitLabel9 o: bm.name
                    vid5: userFnId symtab: symtab ctx: ctx name: nm5.stringview
                    if vid5 > 0.u64 then {
                        emitOneVariant symtab: symtab ctx: ctx tid: vid5 name: nm5.stringview buf: buf
                    } else {}
                } else {}
                nm6: unitLabel9 o: bm.name
                emitDataBlock symtab: symtab ctx: ctx name: nm6.stringview op: bm.operation buf: buf
            } else {}
        }
        with biterB: mainOp.body.iterate do for bmd: biterB loop {
            emitDefMethods symtab: symtab ctx: ctx bm: bmd declOnly: true buf: buf
        }
        with biterI: mainOp.body.iterate do for bi: biterI loop {
            match (
                bi
            ) case namedoperation then {
                isImpl7: false
                if (isClassDef9 n: bi.operation) then {
                    isImpl7 = true
                } else {}
                if (isRecordDef9 n: bi.operation) then {
                    isImpl7 = true
                } else {}
                if isImpl7 then {
                    nmi7: unitLabel9 o: bi.name
                    iid7: userFnId symtab: symtab ctx: ctx name: nmi7.stringview
                    if iid7 > 0.u64 then {
                        emitProtocolImplsForType symtab: symtab ctx: ctx implTid: iid7 implName: nmi7.stringview buf: buf
                    } else {}
                } else {}
            } else {}
        }
        # main-unit function forward decls, after the struct defs (so a generator
        # function returning its synth iter class resolves) and before the method
        # bodies (a synth iterator's call body may call another generator's fn).
        with biterFD: mainOp.body.iterate do for bfd: biterFD loop {
            match (
                bfd
            ) case namedoperation then {
                if (isFunctionDefWithBody9 n: bfd.operation) then {
                    fdn: unitLabel9 o: bfd.name
                    fdid: userFnId symtab: symtab ctx: ctx name: fdn.stringview
                    fdsig: fnSignature symtab: symtab ctx: ctx name: fdn.stringview fid: fdid op: bfd.operation
                    fdl: "\{fdsig};\n"
                    buf.append fdl.stringview
                } else {}
            } else {}
        }
        with biterC: mainOp.body.iterate do for bmb: biterC loop {
            emitDefMethods symtab: symtab ctx: ctx bm: bmb declOnly: false buf: buf
        }
    } else {}
}

# emitDataBlock -- `name: data { e0 e1 ... } out T`: a static const array
# z_{name}[] plus z_{name}_len, with the element C type from out T (i64
# default). The plain z_{name} cname matches the reference.
emitDataBlock: function {symtab: zenv.ZSymbolTable ctx: Ctx name: StringView op: Node buf: String.borrow} is {
    match (
        op
    ) case expression then {
        emitDataBlock symtab: symtab ctx: ctx name: name op: op.expression buf: buf
    } case datablock then {
        ect: "int64_t".string
        rbn: dataElemBaseName o: op.outType
        if rbn.length > 0.u64 then {
            rc: cTypeOf name: rbn.stringview
            if rc.length > 0.u64 then {
                ect = rc
            } else {}
        } else {}
        elems: "".string
        cnt: 0.u64
        eiter: op.elements.iterate
        for e: eiter loop {
            ev: emitDataElem symtab: symtab ctx: ctx n: e
            if cnt > 0.u64 then {
                elems.append ", "
            } else {}
            elems.append ev.stringview
            cnt = cnt + 1.u64
        }
        l0: "static const \{ect} z_\{name}[] = {\{elems}};\n"
        buf.append l0.stringview
        l1: "static const \{ect} z_\{name}_len = \{cnt};\n\n"
        buf.append l1.stringview
    } else {}
}

# emitDataElem -- a data-block element (a NamedOperation wrapping the
# value atom); emit its inner expression.
emitDataElem: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node} out String is {
    match (
        n
    ) case namedoperation then {
        return (emitExpr symtab: symtab ctx: ctx n: n.operation)
    } else {
        return (emitExpr symtab: symtab ctx: ctx n: n)
    }
}

dataElemBaseName: function {o: (Option t: Node)} out String is {
    match (
        o
    ) case some then {
        return (atomTextDeep n: o)
    } case none then {
        return "".string
    }
}

isVariantDef9: function {n: Node} out bool is {
    match (
        n
    ) case objectdef then {
        if n.kind == zast.nodetype.VARIANT then {
            return true
        } else {
            return false
        }
    } else {
        return false
    }
}

isUnionDef9: function {n: Node} out bool is {
    match (
        n
    ) case objectdef then {
        if n.kind == zast.nodetype.UNION then {
            return true
        } else {
            return false
        }
    } else {
        return false
    }
}

# emitOneVariant -- tag enum + tagged struct (+ payload union when any
# arm carries one) + the by-tag/value eq helper.
emitOneVariant: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64 name: StringView buf: String.borrow} is {
    egv9: ctx.emittedUserTypes.get key: tid
    match (
        egv9
    ) case some then {
        return
    } case none then {}
    ctx.emittedUserTypes.set key: tid.u64 value: true
    anames: (List of: String)
    aids: (List of: u64)
    variantArms symtab: symtab tid: tid names: anames ids: aids
    preEmitEmbeddedTypes symtab: symtab ctx: ctx ids: aids buf: buf
    vc: cnameOf tid: tid name: name
    buf.append "typedef enum {\n"
    ai: 0.u64
    an: anames.length
    for while ai < an loop {
        aname: anames.get i: ai
        tg: variantTag symtab: symtab tid: tid arm: aname.stringview
        lt: "    \{tg},\n"
        buf.append lt.stringview
        ai = ai + 1.u64
    }
    le: "} \{vc}_tag_t;\n"
    buf.append le.stringview
    buf.append "typedef struct {\n"
    lf: "    \{vc}_tag_t tag;\n"
    buf.append lf.stringview
    haveP: false
    pj: 0.u64
    for while pj < an loop {
        pname: anames.get i: pj
        pc: armPayloadC symtab: symtab ctx: ctx tid: tid arm: pname.stringview
        if pc.length > 0.u64 then {
            if haveP then {} else {
                haveP = true
                buf.append "    union {\n"
            }
            lp: "        \{pc} \{pname};\n"
            buf.append lp.stringview
        } else {}
        pj = pj + 1.u64
    }
    if haveP then {
        buf.append "    } data;\n"
    } else {}
    lg: "} \{vc}_t;\n"
    buf.append lg.stringview
    lq: "static bool \{vc}_eq(\{vc}_t a, \{vc}_t b) {\n"
    buf.append lq.stringview
    if haveP then {
        buf.append "    if (a.tag != b.tag) return false;\n"
        buf.append "    switch (a.tag) {\n"
        qk: 0.u64
        for while qk < an loop {
            qname: anames.get i: qk
            qc: armPayloadC symtab: symtab ctx: ctx tid: tid arm: qname.stringview
            if qc.length > 0.u64 then {
                qtg: variantTag symtab: symtab tid: tid arm: qname.stringview
                qco: symtab.typing.childOf parentTypeId: tid name: qname.stringview
                qeq: "".string
                match (
                    qco
                ) case some then {
                    qtn: typeNameOfReg9 symtab: symtab tid: qco
                    qsc: cTypeOf name: qtn.stringview
                    if qsc.length == 0.u64 then {
                        qrid: optU64Or9 o: (ztypecheck.lookupTyperef resolved: symtab.typing.resolved mainName: ctx.mainName.stringview base: qtn.stringview)
                        if qrid > 0.u64 then {
                            qtt: symtab.reg.typetypeOf typeId: qrid
                            isAgg: false
                            if qtt == ztypes.ztypetype.RECORD then { isAgg = true } else {}
                            if qtt == ztypes.ztypetype.VARIANT then { isAgg = true } else {}
                            if isAgg then {
                                qrc: cnameOf tid: qrid name: qtn.stringview
                                qe: "\{qrc}_eq(a.data.\{qname}, b.data.\{qname})"
                                qeq.append qe.stringview
                            } else {}
                        } else {}
                    } else {}
                } case none then {}
                if qeq.length == 0.u64 then {
                    qe2: "a.data.\{qname} == b.data.\{qname}"
                    qeq.append qe2.stringview
                } else {}
                lr: "        case \{qtg}: return \{qeq};\n"
                buf.append lr.stringview
            } else {}
            qk = qk + 1.u64
        }
        buf.append "        default: return true;\n"
        buf.append "    }\n"
    } else {
        buf.append "    return a.tag == b.tag;\n"
    }
    buf.append "}\n\n"
}

isClassDef9: function {n: Node} out bool is {
    match (
        n
    ) case objectdef then {
        if n.kind == zast.nodetype.CLASS then {
            return true
        } else {
            return false
        }
    } else {
        return false
    }
}

isRecordDef9: function {n: Node} out bool is {
    match (
        n
    ) case objectdef then {
        if n.kind == zast.nodetype.RECORD then {
            return true
        } else {
            return false
        }
    } else {
        return false
    }
}

# emitStructDestructor -- a record/class destructor freeing each heap-owning
# field: String fields via the String free, aggregate fields with a destructor
# recursively; scalars are skipped. Emitted only when the type has a destructor.
emitStructDestructor: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64 name: StringView fnames: (List of: String) fids: (List of: u64) buf: String.borrow} is {
    rc: cnameOf tid: tid name: name
    d0: "static void \{rc}_destroy(\{rc}_t* p);\n"
    buf.append d0.stringview
    d1: "static void \{rc}_destroy(\{rc}_t* p) {\n"
    buf.append d1.stringview
    buf.append "    if (!p) return;\n"
    fi: 0.u64
    fn0: fnames.length
    for while fi < fn0 loop {
        fname: fnames.get i: fi
        fid: fids.get i: fi
        # a `.lock` field is a borrowed pointer -- never freed by the destructor.
        if (symtab.typing.isChildLockField parentTypeId: tid name: fname.stringview) then {} else {
            ftn: typeNameOfReg9 symtab: symtab tid: fid
            if ftn.stringview == "String" then {
                ds: "    \{ctx.strC}_free(&p->\{fname});\n"
                buf.append ds.stringview
            } else {
                frid: optU64Or9 o: (ztypecheck.lookupTyperef resolved: symtab.typing.resolved mainName: ctx.mainName.stringview base: ftn.stringview)
                if frid > 0.u64 then {
                    frid = chaseColMono symtab: symtab tid: frid
                    frn2: typeNameOfReg9 symtab: symtab tid: frid
                    if (symtab.reg.hasDestructorName typeId: frid) then {
                        fcb: cnameOf tid: frid name: frn2.stringview
                        df: "    \{fcb}_destroy(&p->\{fname});\n"
                        buf.append df.stringview
                    } else {}
                } else {}
            }
        }
        fi = fi + 1.u64
    }
    buf.append "}\n\n"
}

# lockFieldIsProtocol -- a `.lock` field whose locked type is a protocol stores
# the protocol fat pointer BY VALUE (the borrow lives in its data); a class-typed
# `.lock` stores a pointer to the container.
lockFieldIsProtocol: function {symtab: zenv.ZSymbolTable ctx: Ctx fid: u64} out bool is {
    ftn: typeNameOfReg9 symtab: symtab tid: fid
    ftid: resolveTypeIdByName symtab: symtab ctx: ctx name: ftn.stringview
    if ftid > 0.u64 when (symtab.reg.typetypeOf typeId: ftid) == ztypes.ztypetype.PROTOCOL then {
        return true
    } else {}
    return false
}

# lockFieldIsReftypePtr -- a `.lock` field is stored as a pointer to its container
# only when that container is a reftype (class/union); a protocol lock is the fat
# pointer by value, and a valtype lock (a bidirectional generator's bool resume
# input) is stored by value.
lockFieldIsReftypePtr: function {symtab: zenv.ZSymbolTable ctx: Ctx fid: u64} out bool is {
    ftn: typeNameOfReg9 symtab: symtab tid: fid
    ftid: resolveTypeIdByName symtab: symtab ctx: ctx name: ftn.stringview
    if ftid == 0.u64 then {
        ftid = fid
    } else {}
    tt: symtab.reg.typetypeOf typeId: ftid
    if tt == ztypes.ztypetype.CLASS then {
        return true
    } else {}
    if tt == ztypes.ztypetype.UNION then {
        return true
    } else {}
    return false
}

emitOneRecord: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64 name: StringView buf: String.borrow} is {
    egr9: ctx.emittedUserTypes.get key: tid
    match (
        egr9
    ) case some then {
        return
    } case none then {}
    ctx.emittedUserTypes.set key: tid.u64 value: true
    if (isTypedefType symtab: symtab tid: tid) then {
        # typedef records are zero-overhead aliases of their base; they have no
        # struct of their own. Their methods are emitted in the later passes.
        return
    } else {}
    fnames: (List of: String)
    fids: (List of: u64)
    recFieldLists symtab: symtab tid: tid names: fnames ids: fids
    preEmitEmbeddedTypes symtab: symtab ctx: ctx ids: fids buf: buf
    rc: cnameOf tid: tid name: name
    l0: "typedef struct {\n"
    buf.append l0.stringview
    fi: 0.u64
    fn0: fnames.length
    for while fi < fn0 loop {
        fname: fnames.get i: fi
        fid: fids.get i: fi
        fct: typeRefC symtab: symtab ctx: ctx tid: fid thisTid: 0.u64
        if fct.length == 0.u64 then {
            fct = "int64_t".string
        } else {}
        # a `.lock` field borrows the container: protocol-typed -> fat pointer by
        # value; class-typed -> a pointer to the container.
        if (symtab.typing.isChildLockField parentTypeId: tid name: fname.stringview) then {
            if (lockFieldIsReftypePtr symtab: symtab ctx: ctx fid: fid) then {
                fct = "\{fct}*"
            } else {}
        } else {}
        l1: "    \{fct} \{fname};\n"
        buf.append l1.stringview
        fi = fi + 1.u64
    }
    l2: "} \{rc}_t;\n"
    buf.append l2.stringview
    params: "".string
    inits: "".string
    fj: 0.u64
    for while fj < fn0 loop {
        fname2: fnames.get i: fj
        fid2: fids.get i: fj
        fct2: typeRefC symtab: symtab ctx: ctx tid: fid2 thisTid: 0.u64
        if fct2.length == 0.u64 then {
            fct2 = "int64_t".string
        } else {}
        # a `.lock` field's meta_create param matches the field (protocol by value).
        if (symtab.typing.isChildLockField parentTypeId: tid name: fname2.stringview) then {
            if (lockFieldIsReftypePtr symtab: symtab ctx: ctx fid: fid2) then {
                fct2 = "\{fct2}*"
            } else {}
        } else {}
        if fj > 0.u64 then {
            params.append ", "
            inits.append ", "
        } else {}
        params.append fct2.stringview
        params.append " "
        params.append fname2.stringview
        inits.append fname2.stringview
        fj = fj + 1.u64
    }
    l3: "static \{rc}_t \{rc}_meta_create(\{params}) {\n"
    buf.append l3.stringview
    l4: "    \{rc}_t z = { \{inits} };\n"
    buf.append l4.stringview
    buf.append "    return z;\n"
    buf.append "}\n"
    if (definedInNonMain symtab: symtab ctx: ctx tid: tid) then {} else {
        l5: "#define \{rc}_create \{rc}_meta_create\n"
        buf.append l5.stringview
    }
    skipEqR: false
    if (symtab.reg.typetypeOf typeId: tid) == ztypes.ztypetype.CLASS then {
        skipEqR = true
    } else {}
    if skipEqR then {} else {
    lq: "static bool \{rc}_eq(\{rc}_t a, \{rc}_t b) {\n"
    buf.append lq.stringview
    if fn0 == 0.u64 then {
        buf.append "    (void)a; (void)b;\n"
        buf.append "    return true;\n"
    } else {
        eqx: "".string
        fk: 0.u64
        for while fk < fn0 loop {
            fkn: fnames.get i: fk
            fki: fids.get i: fk
            if fk > 0.u64 then {
                eqx.append " && "
            } else {}
            ftn: typeNameOfReg9 symtab: symtab tid: fki
            fscalar: cTypeOf name: ftn.stringview
            fdone: false
            if fscalar.length == 0.u64 then {
                frid: optU64Or9 o: (ztypecheck.lookupTyperef resolved: symtab.typing.resolved mainName: ctx.mainName.stringview base: ftn.stringview)
                if frid > 0.u64 then {
                    ftt: symtab.reg.typetypeOf typeId: frid
                    isAggF: false
                    if ftt == ztypes.ztypetype.RECORD then { isAggF = true } else {}
                    if ftt == ztypes.ztypetype.VARIANT then { isAggF = true } else {}
                    if isAggF then {
                        frc: cnameOf tid: frid name: ftn.stringview
                        fe: "\{frc}_eq(a.\{fkn}, b.\{fkn})"
                        eqx.append fe.stringview
                        fdone = true
                    } else {}
                } else {}
            } else {}
            if fdone then {} else {
                fe2: "a.\{fkn} == b.\{fkn}"
                eqx.append fe2.stringview
            }
            fk = fk + 1.u64
        }
        lr: "    return \{eqx};\n"
        buf.append lr.stringview
    }
    buf.append "}\n\n"
    }
    if (symtab.reg.hasDestructorName typeId: tid) then {
        emitStructDestructor symtab: symtab ctx: ctx tid: tid name: name fnames: fnames fids: fids buf: buf
    } else {}
}

# emitCliCompositeClass -- a cli class holding collection fields (Spec/Parsed).
# Lists embed by value; Maps/Sets are heap pointers. Parsed is forward-declared
# (named tag) so the Result_Parsed_CliError destructor can reference it before
# this body emits; Spec emits its own typedef inline. No `_create` alias (the
# create is native / inline) and no `_eq` (a class).
emitCliCompositeClass: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64 name: StringView fwdDeclared: bool buf: String.borrow} is {
    fnames: (List of: String)
    fids: (List of: u64)
    recFieldLists symtab: symtab tid: tid names: fnames ids: fids
    rc: cnameOf tid: tid name: name
    if fwdDeclared then {} else {
        lt: "typedef struct \{rc}_t \{rc}_t;\n"
        buf.append lt.stringview
    }
    l0: "struct \{rc}_t {\n"
    buf.append l0.stringview
    fi: 0.u64
    fn0: fnames.length
    for while fi < fn0 loop {
        fname: fnames.get i: fi
        fid: fids.get i: fi
        fct: typeRefC symtab: symtab ctx: ctx tid: fid thisTid: 0.u64
        if fct.length == 0.u64 then {
            fct = "int64_t".string
        } else {}
        if (isHeapPtrCollection symtab: symtab ctx: ctx tid: fid) then {
            fct = "\{fct}*"
        } else {}
        l1: "    \{fct} \{fname};\n"
        buf.append l1.stringview
        fi = fi + 1.u64
    }
    buf.append "};\n"
    params: "".string
    inits: "".string
    fj: 0.u64
    for while fj < fn0 loop {
        fname2: fnames.get i: fj
        fid2: fids.get i: fj
        fct2: typeRefC symtab: symtab ctx: ctx tid: fid2 thisTid: 0.u64
        if fct2.length == 0.u64 then {
            fct2 = "int64_t".string
        } else {}
        if (isHeapPtrCollection symtab: symtab ctx: ctx tid: fid2) then {
            fct2 = "\{fct2}*"
        } else {}
        if fj > 0.u64 then {
            params.append ", "
            inits.append ", "
        } else {}
        params.append fct2.stringview
        params.append " "
        params.append fname2.stringview
        inits.append fname2.stringview
        fj = fj + 1.u64
    }
    l3: "static \{rc}_t \{rc}_meta_create(\{params}) {\n"
    buf.append l3.stringview
    l4: "    \{rc}_t z = { \{inits} };\n"
    buf.append l4.stringview
    buf.append "    return z;\n"
    buf.append "}\n"
    d0: "static void \{rc}_destroy(\{rc}_t* p);\n"
    buf.append d0.stringview
    d1: "static void \{rc}_destroy(\{rc}_t* p) {\n"
    buf.append d1.stringview
    buf.append "    if (!p) return;\n"
    dk: 0.u64
    for while dk < fn0 loop {
        dfn: fnames.get i: dk
        dfi: fids.get i: dk
        dtn: typeNameOfReg9 symtab: symtab tid: dfi
        if dtn.stringview == "String" then {
            ds: "    \{ctx.strC}_free(&p->\{dfn});\n"
            buf.append ds.stringview
        } else {
            dcm: fieldMonoId symtab: symtab ctx: ctx tid: dfi
            if (symtab.reg.hasDestructorName typeId: dcm) then {
                dcn: typeNameOfReg9 symtab: symtab tid: dcm
                dcb: cnameOf tid: dcm name: dcn.stringview
                if (isHeapPtrCollection symtab: symtab ctx: ctx tid: dfi) then {
                    df: "    \{dcb}_destroy(p->\{dfn});\n"
                    buf.append df.stringview
                } else {
                    df2: "    \{dcb}_destroy(&p->\{dfn});\n"
                    buf.append df2.stringview
                }
            } else {}
        }
        dk = dk + 1.u64
    }
    buf.append "}\n\n"
}

# emitRecordMethods -- the record's as-block functions as free C
# functions taking the record by value (params from the method type's
# children; the AST return fallback covers unstamped returns).
emitRecordMethods: function {symtab: zenv.ZSymbolTable ctx: Ctx tid: u64 op: Node declOnly: bool buf: String.borrow} is {
    match (
        op
    ) case objectdef then {
        idxs: (List of: u64)
        names: (List of: String)
        ai: 0.u64
        with aiter: op.asItems.iterate do for am: aiter loop {
            match (
                am
            ) case namedoperation then {
                if (isFunctionDefWithBody9 n: am.operation) then {
                    av: ai
                    idxs.append av
                    an: unitLabel9 o: am.name
                    names.append an
                } else {}
            } else {}
            ai = ai + 1.u64
        }
        wi: 0.u64
        wn: idxs.length
        for while wi < wn loop {
            midx: idxs.get i: wi
            mname: names.get i: wi
            am2: op.asItems.get i: midx
            match (
                am2
            ) case namedoperation then {
                mo: symtab.typing.childOf parentTypeId: tid name: mname.stringview
                match (
                    mo
                ) case some then {
                    emitOneMethod symtab: symtab ctx: ctx mid: mo thisTid9: tid op: am2.operation declOnly: declOnly buf: buf
                } case none then {}
            } else {}
            wi = wi + 1.u64
        }
    } else {}
}

# nodeYieldCount -- the number of `yield` expressions in a subtree (yields do
# not nest). Mirrors the typechecker's subtreeHasYield walk. Used to detect a
# generator `call` body and size its resume-state switch.
nodeYieldCount: function {n: Node} out u64 is {
    match (
        n
    ) case yieldexpr then {
        return 1.u64
    } case statement then {
        c: 0.u64
        siter: n.statements.iterate
        for st: siter loop {
            c = c + (nodeYieldCount n: st)
        }
        return c
    } case statementline then {
        return (nodeYieldCount n: n.statementline)
    } case expression then {
        return (nodeYieldCount n: n.expression)
    } case assignment then {
        return (nodeYieldCount n: n.value)
    } case forexpr then {
        return (optNodeYieldCount o: n.body)
    } case ifexpr then {
        c2: 0.u64
        cliter: n.clauses.iterate
        for cl: cliter loop {
            c2 = c2 + (nodeYieldCount n: cl)
        }
        c2 = c2 + (optNodeYieldCount o: n.elseclause)
        return c2
    } case ifclause then {
        return (nodeYieldCount n: n.statement)
    } else {
        return 0.u64
    }
}

optNodeYieldCount: function {o: (Option t: Node)} out u64 is {
    match (
        o
    ) case some then {
        return (nodeYieldCount n: o)
    } case none then {
        return 0.u64
    }
}

# fnYieldCount -- yields in a functiondef body (0 for a non-generator).
fnYieldCount: function {op: Node} out u64 is {
    match (
        op
    ) case functiondef then {
        return (optNodeYieldCount o: op.body)
    } else {
        return 0.u64
    }
}

# setupGenCtx -- arm the generator state-machine context on ctx when `op` is a
# generator `call` (its body yields). Resolves the optionval wrapper from the
# method's return type. Returns false (and disarms) for a normal method.
setupGenCtx: function {symtab: zenv.ZSymbolTable ctx: Ctx mid: u64 op: Node} out bool is {
    gyc: fnYieldCount op: op
    if gyc == 0.u64 then {
        ctx.genActive = false
        return false
    } else {}
    rid: 0.u64
    t: symtab.reg.typeById.get key: mid
    match (
        t
    ) case some then {
        rto: t.returnTypeId
        match (
            rto
        ) case some then {
            rid = rto
        } case none then {}
    } case none then {}
    if rid == 0.u64 then {
        mro: ztypecheck.methodReturnOf st: symtab mid: mid
        match (
            mro
        ) case some then {
            rid = mro
        } case none then {}
    } else {}
    if rid == 0.u64 then {
        ctx.genActive = false
        return false
    } else {}
    rn: typeNameOfReg9 symtab: symtab tid: rid
    ru: cUpperOf text: rn.stringview
    rc: cnameOf tid: rid name: rn.stringview
    ctx.genActive = true
    ctx.genYieldCount = gyc
    ctx.genYieldNext = 1.u64
    ctx.genWrap = "\{rc}_t".string
    ctx.genSomeTag = "Z_\{ru}_TAG_SOME".string
    ctx.genNoneTag = "Z_\{ru}_TAG_NONE".string
    hasVal9: false
    match (
        op
    ) case functiondef then {
        with piter9: op.parameters.iterate do for pm9: piter9 loop {
            match (
                pm9
            ) case namedoperation then {
                pl9: unitLabel9 o: pm9.name
                if pl9.stringview == "value" then {
                    hasVal9 = true
                } else {}
            } else {}
        }
    } else {}
    ctx.genHasValue = hasVal9
    return true
}

# emitGenPrologue -- the resume dispatch: switch on this->state to L_entry / the
# per-yield resume labels / L_done.
emitGenPrologue: function {ctx: Ctx buf: String.borrow} is {
    if ctx.genHasValue then {
        buf.append "    this->_resume_input = value;\n"
    } else {}
    buf.append "    switch (this->state) {\n"
    buf.append "        case 0: goto L_entry;\n"
    k: 1.u64
    for while k <= ctx.genYieldCount loop {
        lk: "        case \{k}: goto L_resume_\{k};\n"
        buf.append lk.stringview
        k = k + 1.u64
    }
    buf.append "        default: goto L_done;\n"
    buf.append "    }\n"
    buf.append "L_entry:;\n"
}

# emitGenEpilogue -- the terminal landing: mark done and return the NONE wrapper.
emitGenEpilogue: function {ctx: Ctx buf: String.borrow} is {
    buf.append "L_done:;\n"
    buf.append "    this->state = -1;\n"
    le: "    \{ctx.genWrap} _r_done = {0};\n"
    buf.append le.stringview
    lt: "    _r_done.tag = \{ctx.genNoneTag};\n"
    buf.append lt.stringview
    buf.append "    return _r_done;\n"
}

# isYieldNode -- the node (through expression wrappers) is a yield expression.
isYieldNode: function {n: Node} out bool is {
    match (
        n
    ) case expression then {
        return (isYieldNode n: n.expression)
    } case yieldexpr then {
        return true
    } else {
        return false
    }
}

# emitYieldFromNode -- emit the suspension for a yield reached through expression
# wrappers (the expression-form `name: yield E`).
emitYieldFromNode: function {symtab: zenv.ZSymbolTable ctx: Ctx n: Node ind: StringView tmp: TmpCtr buf: String.borrow} is {
    match (
        n
    ) case expression then {
        emitYieldFromNode symtab: symtab ctx: ctx n: n.expression ind: ind tmp: tmp buf: buf
    } case yieldexpr then {
        emitYieldStmt symtab: symtab ctx: ctx yd: n ind: ind tmp: tmp buf: buf
    } else {}
}

# emitExprFormYield -- `name: yield E` in a bidirectional generator: suspend
# (yield E), then bind name to the resume input the next `.call value:` provides.
# A valtype binds the value directly; a borrowed reftype binds a pointer alias.
emitExprFormYield: function {symtab: zenv.ZSymbolTable ctx: Ctx value: Node aid: u64 nm: StringView ind: StringView tmp: TmpCtr buf: String.borrow} is {
    emitYieldFromNode symtab: symtab ctx: ctx n: value ind: ind tmp: tmp buf: buf
    ltid9: stampIdOf symtab: symtab nid: aid
    ct9: typeRefC symtab: symtab ctx: ctx tid: ltid9 thisTid: 0.u64
    if ct9.length == 0.u64 then {
        ct9 = "int64_t".string
    } else {}
    tt9: symtab.reg.typetypeOf typeId: ltid9
    isRef9: false
    if tt9 == ztypes.ztypetype.CLASS then {
        isRef9 = true
    } else {}
    if tt9 == ztypes.ztypetype.UNION then {
        isRef9 = true
    } else {}
    if isRef9 then {
        lp0: "\{ind}\{ct9}* __borrow_\{nm} = this->_resume_input;\n"
        buf.append lp0.stringview
        lp1: "\{ind}/* alias: \{nm} => (*__borrow_\{nm}) */\n"
        buf.append lp1.stringview
        av9: "(*__borrow_\{nm})".string
        ctx.aliases.set key: nm.string value: av9
    } else {
        lp2: "\{ind}\{ct9} \{nm} = this->_resume_input;\n"
        buf.append lp2.stringview
    }
}

# emitYieldStmt -- one `yield E` suspension: set the resume state, return the
# SOME-wrapped value, then drop a resume label at column 0 (goto-reachable into
# the enclosing block).
emitYieldStmt: function {symtab: zenv.ZSymbolTable ctx: Ctx yd: zast.YieldExprData ind: StringView tmp: TmpCtr buf: String.borrow} is {
    k: ctx.genYieldNext
    ctx.genYieldNext = k + 1.u64
    ve: emitExpr symtab: symtab ctx: ctx n: yd.expr
    ls: "\{ind}this->state = \{k};\n"
    buf.append ls.stringview
    lw: "\{ind}\{ctx.genWrap} _ry_\{k} = {0};\n"
    buf.append lw.stringview
    lg: "\{ind}_ry_\{k}.tag = \{ctx.genSomeTag};\n"
    buf.append lg.stringview
    ld: "\{ind}_ry_\{k}.data.some = \{ve};\n"
    buf.append ld.stringview
    lr: "\{ind}return _ry_\{k};\n"
    buf.append lr.stringview
    ll: "L_resume_\{k}:;\n"
    buf.append ll.stringview
}

emitOneMethod: function {symtab: zenv.ZSymbolTable ctx: Ctx mid: u64 thisTid9: u64 op: Node declOnly: bool buf: String.borrow} is {
    mtn: typeNameOfReg9 symtab: symtab tid: mid
    mc: cnameOf tid: mid name: mtn.stringview
    ret: "void".string
    {
        t: symtab.reg.typeById.get key: mid
        match (
            t
        ) case some then {
            rto: t.returnTypeId
            match (
                rto
            ) case some then {
                rr: typeRefC symtab: symtab ctx: ctx tid: rto thisTid: thisTid9
                if rr.length > 0.u64 then {
                    ret = rr
                } else {}
            } case none then {}
        } case none then {}
    }
    if ret.stringview == "void" then {
        # generic-mono returns (optionval/Option/resultval) carry no registry
        # returnTypeId; the return-type node stamp resolves the mono id.
        mro: ztypecheck.methodReturnOf st: symtab mid: mid
        match (
            mro
        ) case some then {
            mrr: typeRefC symtab: symtab ctx: ctx tid: mro thisTid: thisTid9
            if mrr.length > 0.u64 then {
                ret = mrr
            } else {}
        } case none then {}
    } else {}
    if ret.stringview == "void" when thisTid9 > 0.u64 then {
        rbn0: ztypecheck.fnReturnBaseNameOf op: op
        if rbn0.stringview == "this" then {
            ttn: typeNameOfReg9 symtab: symtab tid: thisTid9
            tcb: cnameOf tid: thisTid9 name: ttn.stringview
            ret = "\{tcb}_t"
        } else {}
    } else {}
    if ret.stringview == "void" then {
        rbn: ztypecheck.fnReturnBaseNameOf op: op
        if rbn.length > 0.u64 then {
            rbi: userFnId symtab: symtab ctx: ctx name: rbn.stringview
            if rbi > 0.u64 then {
                rr2: typeRefC symtab: symtab ctx: ctx tid: rbi thisTid: thisTid9
                if rr2.length > 0.u64 then {
                    ret = rr2
                } else {}
            } else {
                rr3: cTypeOf name: rbn.stringview
                if rr3.length > 0.u64 then {
                    ret = rr3
                } else {}
            }
        } else {}
    } else {}
    params: "".string
    pnames: (List of: String)
    pids: (List of: u64)
    recFieldLists symtab: symtab tid: mid names: pnames ids: pids
    # a CLASS method takes its `this` receiver by pointer (reference semantics):
    # the receiver param gets a `*` and its name is recorded so the body emits
    # `c->field`. Reset for this method (names must not leak into other bodies).
    ctx.ptrVars = (List of: String)
    encIsClass: false
    if (symtab.reg.typetypeOf typeId: thisTid9) == ztypes.ztypetype.CLASS then {
        encIsClass = true
    } else {}
    clsNm9: typeNameOfReg9 symtab: symtab tid: thisTid9
    pi: 0.u64
    pn: pnames.length
    for while pi < pn loop {
        pname: pnames.get i: pi
        pid: pids.get i: pi
        pt: typeRefC symtab: symtab ctx: ctx tid: pid thisTid: thisTid9
        if pt.length == 0.u64 then {
            pt = "int64_t".string
        } else {}
        if encIsClass then {
            ptn9: typeNameOfReg9 symtab: symtab tid: pid
            isRecv9: false
            if ptn9.stringview == "this" then {
                isRecv9 = true
            } else {}
            if ptn9.stringview == clsNm9.stringview then {
                isRecv9 = true
            } else {}
            if pid == thisTid9 then {
                isRecv9 = true
            } else {}
            if isRecv9 then {
                pt = "\{pt}*"
                pnc9: pname.string
                ctx.ptrVars.append pnc9
            } else {
                # a LOCK/BORROW class param borrows the container -> pass by pointer.
                own9: symtab.typing.childOwnershipText parentTypeId: mid name: pname.stringview
                isLB9: false
                if own9.stringview == "LOCK" then {
                    isLB9 = true
                } else {}
                if own9.stringview == "BORROW" then {
                    isLB9 = true
                } else {}
                if isLB9 then {
                    prid9: resolveTypeIdByName symtab: symtab ctx: ctx name: ptn9.stringview
                    if prid9 > 0.u64 when (symtab.reg.typetypeOf typeId: prid9) == ztypes.ztypetype.CLASS then {
                        pmo9: monoOriginName symtab: symtab tid: prid9
                        if pmo9.length == 0.u64 then {
                            pt = "\{pt}*"
                            pnc9b: pname.string
                            ctx.ptrVars.append pnc9b
                        } else {}
                    } else {}
                } else {}
            }
        } else {}
        if pi > 0.u64 then {
            params.append ", "
        } else {}
        params.append pt.stringview
        params.append " "
        params.append pname.stringview
        pi = pi + 1.u64
    }
    if pn == 0.u64 then {
        params.append "void"
    } else {}
    if declOnly then {
        ld: "static \{ret} \{mc}(\{params});\n"
        buf.append ld.stringview
    } else {
        lo: "static \{ret} \{mc}(\{params}) {\n"
        buf.append lo.stringview
        isGen9: setupGenCtx symtab: symtab ctx: ctx mid: mid op: op
        if isGen9 then {
            emitGenPrologue ctx: ctx buf: buf
        } else {}
        emitFnBody symtab: symtab ctx: ctx op: op buf: buf
        if isGen9 then {
            emitGenEpilogue ctx: ctx buf: buf
            ctx.genActive = false
        } else {}
        buf.append "}\n\n"
    }
    ctx.ptrVars = (List of: String)
}

# emitMonoNative -- a native fragment substituting z_StringView and (when
# mono is non-empty) the canonical z_{mono} to the mono's id-based cname.
emitMonoNative: function {symtab: zenv.ZSymbolTable ctx: Ctx runtimeDir: StringView frag: StringView mono: StringView buf: String.borrow} is {
    p: "\{runtimeDir}/natives/\{frag}.inc"
    raw: io.readText path: p.stringview
    match (
        raw
    ) case ok then {
        scv: ctx.svC.copy
        cur: substituteAll text: raw needle: "z_StringView" repl: scv.stringview
        if mono.length > 0.u64 then {
            mid: 0.u64
            mok: mono.string
            moo: symtab.typing.monoByName.get key: mok
            match (
                moo
            ) case some then {
                mid = moo
            } case none then {}
            mc: cnameOf tid: mid name: mono
            cn: "z_\{mono}"
            cur = substituteAll text: cur needle: cn.stringview repl: mc.stringview
        } else {}
        buf.append cur.stringview
        buf.append "\n"
    } case err then {}
}

# emitParseNative -- a parse fragment, substituting the canonical
# z_resultval_*_parseerror to the mono's id-based cname and z_StringView.
emitParseNative: function {symtab: zenv.ZSymbolTable ctx: Ctx runtimeDir: StringView frag: StringView mono: StringView buf: String.borrow} is {
    mid: 0.u64
    mo: symtab.typing.monoByName.get key: mono.string
    match (
        mo
    ) case some then {
        mid = mo
    } case none then {}
    mc: cnameOf tid: mid name: mono
    p: "\{runtimeDir}/natives/\{frag}.inc"
    raw: io.readText path: p.stringview
    match (
        raw
    ) case ok then {
        cn: "z_\{mono}"
        s1: substituteAll text: raw needle: cn.stringview repl: mc.stringview
        scv: ctx.svC.copy
        s2: substituteAll text: s1 needle: "z_StringView" repl: scv.stringview
        buf.append s2.stringview
        buf.append "\n"
    } case err then {}
}

# emitCodepointsNatives -- the CpIter struct + codepoints factory + call,
# substituting the canonical z_CpIter / z_optionval_u32 to id-based cnames.
emitCodepointsNatives: function {symtab: zenv.ZSymbolTable ctx: Ctx runtimeDir: StringView buf: String.borrow} is {
    cpId: 0.u64
    cpo: symtab.typing.resolved.get key: "system.CpIter".string
    match (
        cpo
    ) case some then {
        cpId = cpo
    } case none then {}
    ovId: 0.u64
    ovo: symtab.typing.monoByName.get key: "optionval_u32".string
    match (
        ovo
    ) case some then {
        ovId = ovo
    } case none then {}
    cpc: cnameOf tid: cpId name: "CpIter"
    ovc: cnameOf tid: ovId name: "optionval_u32"
    emitCpFrag runtimeDir: runtimeDir frag: "_Z_SV_CPITER_STRUCT" svC: ctx.svC.stringview cpc: cpc.stringview ovc: ovc.stringview buf: buf
    emitCpFrag runtimeDir: runtimeDir frag: "_Z_SV_CODEPOINTS" svC: ctx.svC.stringview cpc: cpc.stringview ovc: ovc.stringview buf: buf
    emitCpFrag runtimeDir: runtimeDir frag: "_Z_SV_CPITER_CALL" svC: ctx.svC.stringview cpc: cpc.stringview ovc: ovc.stringview buf: buf
}

emitCpFrag: function {runtimeDir: StringView frag: StringView svC: StringView cpc: StringView ovc: StringView buf: String.borrow} is {
    p: "\{runtimeDir}/natives/\{frag}.inc"
    raw: io.readText path: p.stringview
    match (
        raw
    ) case ok then {
        s1: substituteAll text: raw needle: "z_CpIter" repl: cpc
        s2: substituteAll text: s1 needle: "z_optionval_u32" repl: ovc
        s3: substituteAll text: s2 needle: "z_StringView" repl: svC
        buf.append s3.stringview
        buf.append "\n"
    } case err then {}
}

mainNameOf9: function {program: Node} out String is {
    match (
        program
    ) case program then {
        mv: program.mainUnitName.stringview
        mc: mv.string
        return mc
    } else {
        return "".string
    }
}

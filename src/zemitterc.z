# nodeConstText -- the C literal for a node carrying a compile-time
# const stamp (folded .LABEL data access, unit constants); "" otherwise.
nodeConstText: function {symtab: zenv.ZSymbolTable nid: u64} out String is {
    if nid == 0.u64 then {
        return "".string
    } else {}
    res: "".string
    with citer: symtab.typing.nodeConst.iterate do for row: citer loop {
        if row.nodeid == nid when res.length == 0.u64 then {
            if row.value.kind == ztypes.zconstkind.IVAL then {
                iv: row.value.ival
                res = "\{iv}"
            } else {}
            if row.value.kind == ztypes.zconstkind.FVAL then {
                fv: row.value.fval
                res = "\{fv}"
            } else {}
        } else {}
    }
    return res
}

# emitMetaCreateCall -- `meta.create field: val ...`, the enclosing type's raw
# allocator (its field children as params). The typecheck stamps the call node

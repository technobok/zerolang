        with aiter9: call.arguments.iterate do for a9Id9: aiter9 loop {
            a9: ast.nodes.get i: (a9Id9 - 1).u64
            match (
                a9
            ) case namedoperation then {
                opf2029: ast.nodes.get i: (a9.operation - 1).u64
                if argx.length == 0 then {
                    av9: svArgAddr :ast :symtab :ctx n: (ast.nodes.get i: (a9.operation - 1).u64)
                    if av9.length > 0 then {
                        argx.append av9.stringview
                    } else {
                        sx9: emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (a9.operation - 1).u64)
                        if (stampIdOf
                            :symtab
                            nid: (nodeIdOf9 n: (ast.nodes.get i: (a9.operation - 1).u64))
                        ) == ctx.strTid then {

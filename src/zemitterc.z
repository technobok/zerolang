}

emitRecordCtor: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    tid: u64
    name: StringView
} out String is {
    # a user-defined `create` (non-empty params) overrides the field-wise ctor:
    # bare-name construction routes through it, args by the create's own labels.
    cco: symtab.typing.childOfId parentTypeId: tid nameId: wkCreate
    match (
        cco
    ) case some then {
        if (symtab.reg.typetypeOf typeId: cco) == ztypes.ztypetype.functionType then {
            crB9: false
            crn9: symtab.typing.funcReturnNode.get key: cco
            match (
                crn9
            ) case some then {
                crB9 = true
            } case none then null
            cpn: (List String)
            cpi: (List u64)
            cpiNm: (List u64)
            recFieldLists :ast :symtab tid: cco names: cpn ids: cpi nameIds: cpiNm
            if crB9 then {
                cargs: String
                ci: u64
                ccn: cpn.length
                cposIdx: u64
                for ci < ccn loop {
                    cpname: cpn.get i: ci
                    cpnameId: cpiNm.get i: ci
                    cav: ctorArgByLabel :ast :symtab :ctx :call label: cpname.stringview
                    if (ctorHasLabel :ast :call label: cpname.stringview) == false then {
                        cposUsed: false
                        cpv: ctorArgByPosition :ast :symtab :ctx :call idx: cposIdx
                        if cpv.length > 0 then {
                            cav = cpv
                            cposUsed = true
                        }
                        cposIdx = cposIdx + 1
                        if (cposUsed) == false then {
                            if (symtab.typing.hasChildDefaultId
                                parentTypeId: tid
                                nameId: cpnameId
                            ) then {
                                cdt0: (symtab.typing.childDefaultTextId
                                    parentTypeId: tid
                                    nameId: cpnameId
                                )
                                cpid0: cpi.get i: ci
                                cav = (renderDefault
                                    :ast
                                    :symtab
                                    :ctx
                                    default: cdt0.stringview
                                    targetTid: cpid0
                                )
                            }
                        }
                    }
                    if ci > 0 then cargs.append ", "
                    cargs.append cav.stringview
                    ci = ci + 1
                }
                ccb: symtab.reg.cnameOf tid: cco
                ce: "\{ccb}(\{cargs})"
                return ce
            }
        }
    } case none then null
    fnames: (List String)
    fids: (List u64)
    fidsNm: (List u64)
    recFieldLists :ast :symtab :tid names: fnames ids: fids nameIds: fidsNm
    args: String
    fi: u64
    fn0: fnames.length
    fposIdx: u64
    for fi < fn0 loop {
        fname: fnames.get i: fi
        ffid0: fids.get i: fi
        fnameId: fidsNm.get i: fi
        av: ctorArgByLabel :ast :symtab :ctx :call label: fname.stringview
        # an absent label binds the next positional (unlabeled) arg by cursor; then a
        # registered default; then an fnptr slot's method address; else the "0" fallback.
        if (ctorHasLabel :ast :call label: fname.stringview) == false then {
            fposUsed: false
            fpv: ctorArgByPosition :ast :symtab :ctx :call idx: fposIdx
            if fpv.length > 0 then {
                av = fpv
                fposUsed = true
            }
            fposIdx = fposIdx + 1
            if (fposUsed) == false then {
                if (symtab.typing.hasChildDefaultId parentTypeId: tid nameId: fnameId) then {
                    cdt1: symtab.typing.childDefaultTextId parentTypeId: tid nameId: fnameId
                    av = renderDefault :ast :symtab :ctx default: cdt1.stringview targetTid: ffid0
                } else {
                    if (symtab.typing.isChildFnptrFieldId parentTypeId: tid nameId: fnameId) then {
                        av = symtab.reg.cnameOf tid: ffid0
                    }
                }
            }
        }
        if fi > 0 then args.append ", "
        args.append av.stringview
        fi = fi + 1
    }
    rc: cnameOf :tid :name
    e0: "\{rc}_create(\{args})"
    return e0
}

# ctorArgIsBorrow / ctorArgIsBorrowPos -- bindingRhsIsBorrow over the
# argument ctorArgByLabel / ctorArgByPosition would emit: a hoisted
# borrow-returning result must not register a destroy.
ctorArgIsBorrow: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    label: StringView
} out bool is {
    aiter: call.arguments.iterate
    for aId9: aiter loop {
        a: ast.nodes.get i: (aId9 - 1).u64
        match (
            a
        ) case namedoperation then {
            an: zast.nameTextCopy :ast ref: a.name
            if an.stringview == label then return (hoistExprIsBorrowRooted
                :ast
                :symtab
                :ctx
                n: (ast.nodes.get i: (a.operation - 1).u64)
            )
        } else null
    }
    return false
}

ctorArgIsBorrowPos: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    idx: u64
} out bool is {
    seen9: u64
    aiter: call.arguments.iterate
    for aId9: aiter loop {
        a: ast.nodes.get i: (aId9 - 1).u64
        match (
            a
        ) case namedoperation then {
            an: zast.nameTextCopy :ast ref: a.name
            if an.length == 0 then {
                if seen9 == idx then return (hoistExprIsBorrowRooted
                    :ast
                    :symtab
                    :ctx
                    n: (ast.nodes.get i: (a.operation - 1).u64)
                )
                seen9 = seen9 + 1
            }
        } else null
    }
    return false
}

ctorArgByLabel: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    label: StringView
} out String is {
    aiter: call.arguments.iterate
    for aId9: aiter loop {
        a: ast.nodes.get i: (aId9 - 1).u64
        match (
            a
        ) case namedoperation then {
            an: zast.nameTextCopy :ast ref: a.name
            if an.stringview == label then {
                # an interpolated argument builds via a self-contained statement
                # expression (emitExpr cannot emit the chain)
                iv9: emitInterpArgExpr :ast :symtab :ctx n: (ast.nodes.get i: (a.operation - 1).u64)
                if iv9.length > 0 then return iv9
                return (emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (a.operation - 1).u64))
            }
        } else null
    }
    return "0".string
}

# argIsPointerByLabel -- true when the arg at `label` already evaluates to a C
# pointer (a reftype/List param or a `.lock` field), so a native by-pointer
# parameter must pass it directly rather than re-addressing it with `&`.
argIsPointerByLabel: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    label: StringView
} out bool is {
    aiter: call.arguments.iterate
    for aId9: aiter loop {
        a: ast.nodes.get i: (aId9 - 1).u64
        match (
            a
        ) case namedoperation then {
            an: zast.nameTextCopy :ast ref: a.name
            if an.stringview == label then return (pathIsPointer
                :ast
                :symtab
                :ctx
                n: (ast.nodes.get i: (a.operation - 1).u64)
            )
        } else null
    }
    return false
}

# ctorArgByPosition -- the idx-th POSITIONAL (unlabeled) argument's C text, for a
# method call passing args positionally (`this.formatLockHolder holder`) rather
# than by label; "" when there is no such arg.
ctorArgByPosition: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    idx: u64
} out String is {
    seen9: u64
    aiter: call.arguments.iterate
    for aId9: aiter loop {
        a: ast.nodes.get i: (aId9 - 1).u64
        match (
            a
        ) case namedoperation then {
            an: zast.nameTextCopy :ast ref: a.name
            if an.length == 0 then {
                if seen9 == idx then {
                    ip9: (emitInterpArgExpr
                        :ast
                        :symtab
                        :ctx
                        n: (ast.nodes.get i: (a.operation - 1).u64)
                    )
                    if ip9.length > 0 then return ip9
                    return (emitExpr :ast :symtab :ctx n: (ast.nodes.get i: (a.operation - 1).u64))
                }
                seen9 = seen9 + 1
            }
        } else null
    }
    return "".string
}

# ctorInterpArgByLabel -- the interp-arg form (emitInterpArgForParam) for the
# labeled argument, or "" when absent or not an interpolated literal. Lets a
# method/ctor call pass an interpolated literal directly (build + coerce + free).
ctorInterpArgByLabel: function {
    ast: Ast
    symtab: zenv.ZSymbolTable
    ctx: Ctx
    call: zast.CallData
    label: StringView
    fid: u64
    pname: StringView
    pid: u64

Widget: class {
    id: u64
}

grab: function {a: Widget.take b: Widget.lock c: Widget} out u64 is {
    return a.id
}

peek: function {s: String.lock} out StringView.borrow is {
    return s.stringview
}

calc: function {a: i64 b: 10 c: 20} out i64 is {
    return a + b + c
}

main: function is {
    w1: Widget id: 1
    w2: Widget id: 2
    w3: Widget id: 3
    n: grab a: w1 b: w2 c: w3
    print "\{n}"
    txt: "hello".string
    sv: peek s: txt
    print "\{sv}"
    m: calc a: 1
    print "\{m}"
}

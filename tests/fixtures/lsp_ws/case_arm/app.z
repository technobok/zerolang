color: variant {
    red: null
    green: null
    blue: null
} as { tag: u8.tag }

describe: function {c: color} out i64 is {
    r: 0
    match (
        c
    ) case red then {
        r = 1
    } else {
        r = 0
    }
    return r
}

main: function is {
    n: describe c: color.green
    print "\{n}"
}

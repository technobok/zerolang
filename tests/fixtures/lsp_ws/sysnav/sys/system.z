# sysnav mini system unit -- trimmed declaration shapes for the lsp
# system-file navigation test. Native declarations need no
# implementations here: zls only parses and typechecks.

tag: record is native as { t: Any.generic }

Any: union is native

u8: record {
    ==: function {:this rhs: type} out bool is native
    i64: function {:this} out i64 is native
} as {
    tag: tag
}

u64: record {
    ==: function {:this rhs: type} out bool is native
    +: function {:this rhs: type} out type is native
} as {
    tag: tag
}

i64: record {
    +: function {:this rhs: type} out type is native
    ==: function {:this rhs: type} out bool is native
    u8: function {:this} out u8 is native
} as {
    tag: tag
}

null: record is native

never: record is native

bool: variant { false: null  true: null } as { tag: u8.tag }

StringView: class is native as {
    length: function {:this} out u64 is native
    string: function {:this} out String is native
}

String: class is native as {
    ==: function {:this rhs: String} out bool is native
    length: function {:this} out u64 is native
    stringview: function {:this} out StringView is native
}

pick: function {a: String b: String} out String is native

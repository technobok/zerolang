Widget: class {
    id: u64
} as {
    combine: function {w: this other: Widget factor: u64} out u64 is {
        return w.id
    }
}

grab: function {a: Widget.take b: Widget.lock c: Widget d: u64} out u64 is {
    return a.id
}

main: function is {
    w1: Widget id: 1
    w2: Widget id: 2
    n: grab 
    r: w1.combine 
    print "ok"
}

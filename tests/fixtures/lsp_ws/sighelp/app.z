Widget: class {
    id: u64
} as {
    combine: function {w: this other: Widget factor: u64} out u64 is {
        return w.id
    }
}

grab: function {a: Widget b: Widget c: u64} out u64 is {
    return a.id
}

pick: function {x: Widget} out Widget is {
    return x
}

main: function is {
    w1: Widget id: 1
    w2: Widget id: 2
    n: grab a: (pick x: w1) b: w2 c: 3
    r: w1.combine other: w2 factor: 5
}

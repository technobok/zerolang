# navigation fixture for the name/decl/type identity redesign: bare base
# types resolve to core's re-exports, explicit system stays on system,
# and the `:name` shorthand is navigable in call args + public blocks.
public: unit {
    :main
    :addup
}

addup: function {count: i64 base: system.i64} out i64 is {
    return count + base
}

main: function is {
    count: 41
    r: addup :count base: 1
    print "r=\{r}"
}

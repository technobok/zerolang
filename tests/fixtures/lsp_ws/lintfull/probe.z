Gadget: class {
    value: u64
} as {
    public: unit { :peek }
    peek: function {:this} out u64 is {
        return this.value
    }
    deadm: function {:this} out u64 is {
        return this.value
    }
}

deadp: function {x: u64 y: u64} out u64 is {
    return x
}

main: function is {
    g: Gadget value: 5
    s: g.peek
    t: deadp x: 1 y: 2
    dead: 5.u64
    if s == 0.u64 then print "zero"
    print "\{s} \{t}"
}

# FSProvider smoke: register against a real on-disk tree (provisioned
# by the test runner from fs_provider.tree/), exercise walk / stat /
# path / open + the cache-hit fast path + a NOTFOUND walk.
# `{ROOT}` is template-substituted to the tmp_path by the test runner
# before the binary is invoked.
provider fs {ROOT} mounted
walk 0 a 0
walk 0 b.txt 1
stat 0 0
stat 0 1
stat 0 2
path 0 2
open 0 2
walk 0 b.txt 1
walk 0 missing 0
stat 0 3
open 0 3

# Smoke script: append one of each dentry arm, then dump each.
# Reproduces PR 1's hard-coded smoke output via the script
# dispatcher, so the parity check survives the dispatch rewrite.
entry root
entry notfound 0 0 0
entry file 0 0 1
entry directory 0 0 2
entry mount 0 0 0 false
dump 0
dump 1
dump 2
dump 3
dump 4

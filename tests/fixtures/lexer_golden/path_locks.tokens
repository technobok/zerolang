1:1 COMMENT "# path_locks.z -- Path-scoped lock semantics"
1:45 EOL "\n"
2:1 COMMENT "#"
2:2 EOL "\n"
3:1 COMMENT "# Demonstrates the path-scoped lock model: locking one field of a"
3:66 EOL "\n"
4:1 COMMENT "# record does not lock its siblings. A local view into one string field"
4:72 EOL "\n"
5:1 COMMENT "# coexists with mutation of a sibling i64 field \u{2014} under the older"
5:66 EOL "\n"
6:1 COMMENT "# name-scoped lock model the view on `p.name` would have locked all of"
6:71 EOL "\n"
7:1 COMMENT "# `p`, rejecting the `p.age = ...` write."
7:42 EOL "\n"
8:1 COMMENT "#"
8:2 EOL "\n"
9:1 COMMENT "# See doc/ownership.pdoc, \"Path-scoped locks\" for the full semantics."
9:70 EOL "\n"
10:1 EOL "\n"
11:1 COMMENT "# A small class with two independent fields."
11:45 EOL "\n"
12:1 LABEL "Person"
12:7 COLON ":"
12:8 WS " "
12:9 CLASS "class"
12:14 WS " "
12:15 BRACEOPEN "{"
12:16 EOL "\n"
13:1 WS "    "
13:5 LABEL "name"
13:9 COLON ":"
13:10 WS " "
13:11 REFID "String"
13:17 EOL "\n"
14:1 WS "    "
14:5 LABEL "age"
14:8 COLON ":"
14:9 WS " "
14:10 REFID "i64"
14:13 EOL "\n"
15:1 BRACECLOSE "}"
15:2 EOL "\n"
16:1 EOL "\n"
17:1 LABEL "main"
17:5 COLON ":"
17:6 WS " "
17:7 FUNCTION "function"
17:15 WS " "
17:16 IS "is"
17:18 WS " "
17:19 BRACEOPEN "{"
17:20 EOL "\n"
18:1 WS "    "
18:5 LABEL "p"
18:6 COLON ":"
18:7 WS " "
18:8 REFID "Person"
18:14 WS " "
18:15 LABEL "name"
18:19 COLON ":"
18:20 WS " "
18:21 STRBEG "\""
18:22 STRMID "alice"
18:27 STREND "\""
18:28 DOT "."
18:29 REFID "string"
18:35 WS " "
18:36 LABEL "age"
18:39 COLON ":"
18:40 WS " "
18:41 REFID "30"
18:43 EOL "\n"
19:1 EOL "\n"
20:1 WS "    "
20:5 COMMENT "# Borrow a stringview of p.name \u{2014} the lock targets `(p, name)`:"
20:68 EOL "\n"
21:1 WS "    "
21:5 COMMENT "# EXCLUSIVE on the leaf plus SHARED on `(p,)`. Sibling-path access to"
21:74 EOL "\n"
22:1 WS "    "
22:5 COMMENT "# `p.age` remains permitted."
22:33 EOL "\n"
23:1 WS "    "
23:5 LABEL "v"
23:6 COLON ":"
23:7 WS " "
23:8 REFID "p"
23:9 DOT "."
23:10 REFID "name"
23:14 DOT "."
23:15 REFID "stringview"
23:25 EOL "\n"
24:1 WS "    "
24:5 REFID "p"
24:6 DOT "."
24:7 REFID "age"
24:10 WS " "
24:11 EQUALS "="
24:12 WS " "
24:13 REFID "p"
24:14 DOT "."
24:15 REFID "age"
24:18 WS " "
24:19 REFID "+"
24:20 WS " "
24:21 REFID "1"
24:22 EOL "\n"
25:1 EOL "\n"
26:1 WS "    "
26:5 REFID "print"
26:10 WS " "
26:11 STRBEG "\""
26:12 STREXPRBEG "\\"
26:13 BRACEOPEN "{"
26:14 REFID "v"
26:15 BRACECLOSE "}"
26:16 STRMID ", age="
26:22 STREXPRBEG "\\"
26:23 BRACEOPEN "{"
26:24 REFID "p"
26:25 DOT "."
26:26 REFID "age"
26:29 BRACECLOSE "}"
26:30 STREND "\""
26:31 EOL "\n"
27:1 EOL "\n"
28:1 WS "    "
28:5 COMMENT "# v falls out of main's scope \u{2014} the lock on p.name releases."
28:65 EOL "\n"
29:1 BRACECLOSE "}"
29:2 EOL "\n"
30:1 EOF ""

17:4 COLON ":"
17:5 WS " "
17:6 CLASS "class"
17:11 WS " "
17:12 BRACEOPEN "{"
17:13 EOL "\n"
18:1 WS "    "
18:5 LABEL "x"
18:6 COLON ":"
18:7 WS " "
18:8 REFID "i64"
18:11 EOL "\n"
19:1 BRACECLOSE "}"
19:2 EOL "\n"
20:1 EOL "\n"
21:1 COMMENT "# Three-yield generator: emits 1, then reads the resumed bag's x"
21:65 EOL "\n"
22:1 COMMENT "# field. `b` is used in the same window it was bound in (between"
22:65 EOL "\n"
23:1 COMMENT "# `b: yield 2` and the next `yield`), so the liveness check passes."
23:68 EOL "\n"

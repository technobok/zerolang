1:1 COMMENT "# box.z - Box type demonstration"
1:33 EOL "\n"
2:1 COMMENT "# box heap-allocates any type, giving pointer-based semantics:"
2:63 EOL "\n"
3:1 COMMENT "#   - Stack values (valtypes, classes, strings): box heap-allocates a copy"
3:75 EOL "\n"
4:1 COMMENT "#   - Already-heap types (list, map): passthrough (take ownership)"
4:67 EOL "\n"
5:1 EOL "\n"
6:1 LABEL "main"
6:5 COLON ":"
6:6 WS " "
6:7 FUNCTION "function"
6:15 WS " "
6:16 IS "is"
6:18 WS " "
6:19 BRACEOPEN "{"
6:20 EOL "\n"
7:1 WS "    "
7:5 COMMENT "# --- Box an integer (valtype) ---"
7:39 EOL "\n"
8:1 WS "    "
8:5 COMMENT "# heap-allocates the integer; b is int64_t*"
8:48 EOL "\n"
9:1 WS "    "
9:5 LABEL "b"
9:6 COLON ":"
9:7 WS " "
9:8 REFID "Box"
9:11 WS " "
9:12 LABEL "from"
9:16 COLON ":"
9:17 WS " "
9:18 REFID "42"
9:20 EOL "\n"
10:1 WS "    "
10:5 LABEL "r"
10:6 COLON ":"
10:7 WS " "
10:8 REFID "b"
10:9 WS " "
10:10 REFID "+"
10:11 WS " "
10:12 REFID "8"
10:13 EOL "\n"
11:1 WS "    "
11:5 REFID "print"
11:10 WS " "
11:11 STRBEG "\""
11:12 STRMID "boxed 42 + 8 = "
11:27 STREXPRBEG "\\"
11:28 BRACEOPEN "{"
11:29 REFID "r"
11:30 BRACECLOSE "}"
11:31 STREND "\""
11:32 EOL "\n"
12:1 EOL "\n"
13:1 WS "    "
13:5 COMMENT "# comparison works transparently"
13:37 EOL "\n"
14:1 WS "    "
14:5 IF "if"
14:7 WS " "
14:8 REFID "b"
14:9 WS " "
14:10 REFID "=="
14:12 WS " "
14:13 REFID "42"
14:15 WS " "
14:16 THEN "then"
14:20 WS " "
14:21 BRACEOPEN "{"
14:22 WS " "
14:23 REFID "print"
14:28 WS " "
14:29 STRBEG "\""
14:30 STRMID "b is 42"
14:37 STREND "\""
14:38 WS " "
14:39 BRACECLOSE "}"
14:40 EOL "\n"
15:1 EOL "\n"
16:1 WS "    "
16:5 COMMENT "# --- Box a string ---"
16:27 EOL "\n"
17:1 WS "    "
17:5 COMMENT "# string is a stack struct; box heap-allocates the struct"
17:62 EOL "\n"
18:1 WS "    "
18:5 LABEL "s"
18:6 COLON ":"
18:7 WS " "
18:8 REFID "Box"
18:11 WS " "
18:12 LABEL "from"
18:16 COLON ":"
18:17 WS " "
18:18 STRBEG "\""
18:19 STRMID "hello"
18:24 STREND "\""
18:25 DOT "."
18:26 REFID "string"
18:32 EOL "\n"
19:1 EOL "\n"
20:1 WS "    "
20:5 COMMENT "# --- Box with from: syntax ---"
20:36 EOL "\n"
21:1 WS "    "
21:5 LABEL "b2"
21:7 COLON ":"
21:8 WS " "
21:9 REFID "Box"
21:12 WS " "
21:13 LABEL "from"
21:17 COLON ":"
21:18 WS " "
21:19 REFID "100"
21:22 EOL "\n"
22:1 WS "    "
22:5 LABEL "r2"
22:7 COLON ":"
22:8 WS " "
22:9 REFID "b2"
22:11 WS " "
22:12 REFID "*"
22:13 WS " "
22:14 REFID "2"
22:15 EOL "\n"
23:1 WS "    "
23:5 REFID "print"
23:10 WS " "
23:11 STRBEG "\""
23:12 STRMID "boxed 100 * 2 = "
23:28 STREXPRBEG "\\"
23:29 BRACEOPEN "{"
23:30 REFID "r2"
23:32 BRACECLOSE "}"
23:33 STREND "\""
23:34 EOL "\n"
24:1 EOL "\n"
25:1 WS "    "
25:5 REFID "print"
25:10 WS " "
25:11 STRBEG "\""
25:12 STRMID "done"
25:16 STREND "\""
25:17 EOL "\n"
26:1 BRACECLOSE "}"
26:2 EOL "\n"
27:1 EOF ""

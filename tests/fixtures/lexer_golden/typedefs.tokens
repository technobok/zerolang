1:1 COMMENT "# typedefs.z -- Zero-overhead typedef wrapper types"
1:52 EOL "\n"
2:1 COMMENT "# Demonstrates valtype typedefs, methods, chaining, and backward compatibility"
2:79 EOL "\n"
3:1 EOL "\n"
4:1 COMMENT "# valtype typedef: meters wrapping i64"
4:39 EOL "\n"
5:1 LABEL "meters"
5:7 COLON ":"
5:8 WS " "
5:9 RECORD "record"
5:15 WS " "
5:16 BRACEOPEN "{"
5:17 WS " "
5:18 LABEL "val"
5:21 COLON ":"
5:22 WS " "
5:23 REFID "i64"
5:26 DOT "."
5:27 REFID "typedef"
5:34 WS " "
5:35 BRACECLOSE "}"
5:36 WS " "
5:37 AS "as"
5:39 WS " "
5:40 BRACEOPEN "{"
5:41 EOL "\n"
6:1 WS "    "
6:5 LABEL "double"
6:11 COLON ":"
6:12 WS " "
6:13 FUNCTION "function"
6:21 WS " "
6:22 BRACEOPEN "{"
6:23 LABEL "self"
6:27 COLON ":"
6:28 WS " "
6:29 REFID "meters"
6:35 BRACECLOSE "}"
6:36 WS " "
6:37 OUT "out"
6:40 WS " "
6:41 REFID "i64"
6:44 WS " "
6:45 IS "is"
6:47 WS " "
6:48 BRACEOPEN "{"
6:49 EOL "\n"
7:1 WS "        "
7:9 REFID "return"
7:15 WS " "
7:16 REFID "self"
7:20 WS " "
7:21 REFID "*"
7:22 WS " "
7:23 REFID "2"
7:24 EOL "\n"
8:1 WS "    "
8:5 BRACECLOSE "}"
8:6 EOL "\n"
9:1 BRACECLOSE "}"
9:2 EOL "\n"
10:1 EOL "\n"
11:1 COMMENT "# chained typedef: height wrapping meters (which wraps i64)"
11:60 EOL "\n"
12:1 LABEL "height"
12:7 COLON ":"
12:8 WS " "
12:9 RECORD "record"
12:15 WS " "
12:16 BRACEOPEN "{"
12:17 WS " "
12:18 LABEL "h"
12:19 COLON ":"
12:20 WS " "
12:21 REFID "meters"
12:27 DOT "."
12:28 REFID "typedef"
12:35 WS " "
12:36 BRACECLOSE "}"
12:37 WS " "
12:38 AS "as"
12:40 WS " "
12:41 BRACEOPEN "{"
12:42 BRACECLOSE "}"
12:43 EOL "\n"
13:1 EOL "\n"
14:1 COMMENT "# function expecting the base type (i64) -- typedefs are backward compatible"
14:77 EOL "\n"
15:1 LABEL "add_one"
15:8 COLON ":"
15:9 WS " "
15:10 FUNCTION "function"
15:18 WS " "
15:19 BRACEOPEN "{"
15:20 LABEL "x"
15:21 COLON ":"
15:22 WS " "
15:23 REFID "i64"
15:26 BRACECLOSE "}"
15:27 WS " "
15:28 OUT "out"
15:31 WS " "
15:32 REFID "i64"
15:35 WS " "
15:36 IS "is"
15:38 WS " "
15:39 BRACEOPEN "{"
15:40 EOL "\n"
16:1 WS "    "
16:5 REFID "return"
16:11 WS " "
16:12 REFID "x"
16:13 WS " "
16:14 REFID "+"
16:15 WS " "
16:16 REFID "1"
16:17 EOL "\n"
17:1 BRACECLOSE "}"
17:2 EOL "\n"
18:1 EOL "\n"
19:1 LABEL "main"
19:5 COLON ":"
19:6 WS " "
19:7 FUNCTION "function"
19:15 WS " "
19:16 IS "is"
19:18 WS " "
19:19 BRACEOPEN "{"
19:20 EOL "\n"
20:1 WS "    "
20:5 COMMENT "# create a typedef instance -- zero overhead, same as i64 at runtime"
20:73 EOL "\n"
21:1 WS "    "
21:5 LABEL "m"
21:6 COLON ":"
21:7 WS " "
21:8 REFID "meters"
21:14 DOT "."
21:15 REFID "create"
21:21 WS " "
21:22 LABEL "from"
21:26 COLON ":"
21:27 WS " "
21:28 REFID "42"
21:30 EOL "\n"
22:1 WS "    "
22:5 REFID "print"
22:10 WS " "
22:11 STRBEG "\""
22:12 STRMID "meters value: "
22:26 STREXPRBEG "\\"
22:27 BRACEOPEN "{"
22:28 REFID "m"
22:29 BRACECLOSE "}"
22:30 STREND "\""
22:31 EOL "\n"
23:1 EOL "\n"
24:1 WS "    "
24:5 COMMENT "# call a method defined on the typedef (inline in interpolation)"
24:69 EOL "\n"
25:1 WS "    "
25:5 REFID "print"
25:10 WS " "
25:11 STRBEG "\""
25:12 STRMID "doubled: "
25:21 STREXPRBEG "\\"
25:22 BRACEOPEN "{"
25:23 REFID "m"
25:24 DOT "."
25:25 REFID "double"
25:31 BRACECLOSE "}"
25:32 STREND "\""
25:33 EOL "\n"
26:1 EOL "\n"
27:1 WS "    "
27:5 COMMENT "# backward compatible: pass typedef where base type is expected"
27:68 EOL "\n"
28:1 WS "    "
28:5 LABEL "r"
28:6 COLON ":"
28:7 WS " "
28:8 REFID "add_one"
28:15 WS " "
28:16 REFID "m"
28:17 EOL "\n"
29:1 WS "    "
29:5 REFID "print"
29:10 WS " "
29:11 STRBEG "\""
29:12 STRMID "add_one: "
29:21 STREXPRBEG "\\"
29:22 BRACEOPEN "{"
29:23 REFID "r"
29:24 BRACECLOSE "}"
29:25 STREND "\""
29:26 EOL "\n"
30:1 EOL "\n"
31:1 WS "    "
31:5 COMMENT "# chained typedef: height wraps meters wraps i64"
31:53 EOL "\n"
32:1 WS "    "
32:5 LABEL "h"
32:6 COLON ":"
32:7 WS " "
32:8 REFID "height"
32:14 DOT "."
32:15 REFID "create"
32:21 WS " "
32:22 LABEL "from"
32:26 COLON ":"
32:27 WS " "
32:28 PARENOPEN "("
32:29 REFID "meters"
32:35 DOT "."
32:36 REFID "create"
32:42 WS " "
32:43 LABEL "from"
32:47 COLON ":"
32:48 WS " "
32:49 REFID "100"
32:52 PARENCLOSE ")"
32:53 EOL "\n"
33:1 WS "    "
33:5 REFID "print"
33:10 WS " "
33:11 STRBEG "\""
33:12 STRMID "height value: "
33:26 STREXPRBEG "\\"
33:27 BRACEOPEN "{"
33:28 REFID "h"
33:29 BRACECLOSE "}"
33:30 STREND "\""
33:31 EOL "\n"
34:1 EOL "\n"
35:1 WS "    "
35:5 COMMENT "# chained typedef is also backward compatible with the base type"
35:69 EOL "\n"
36:1 WS "    "
36:5 LABEL "r2"
36:7 COLON ":"
36:8 WS " "
36:9 REFID "add_one"
36:16 WS " "
36:17 REFID "h"
36:18 EOL "\n"
37:1 WS "    "
37:5 REFID "print"
37:10 WS " "
37:11 STRBEG "\""
37:12 STRMID "height add_one: "
37:28 STREXPRBEG "\\"
37:29 BRACEOPEN "{"
37:30 REFID "r2"

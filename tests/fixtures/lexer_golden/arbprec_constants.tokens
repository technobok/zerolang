35:20 EOL "\n"
36:1 WS "    "
36:5 COMMENT "# Call-arg coercion: bare 100 coerces to u8 (fits)."
36:56 EOL "\n"
37:1 WS "    "
37:5 REFID "push_byte"
37:14 WS " "
37:15 LABEL "b"
37:16 COLON ":"
37:17 WS " "
37:18 REFID "100"
37:21 EOL "\n"
38:1 EOL "\n"
39:1 WS "    "
39:5 COMMENT "# Call-arg coercion: explicit suffix still works."
39:54 EOL "\n"
40:1 WS "    "

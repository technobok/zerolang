61:14 WS " "
61:15 REFID "100"
61:18 WS " "
61:19 REFID "-"
61:20 WS " "
61:21 REFID "250"
61:24 EOL "\n"
62:1 EOL "\n"
63:1 WS "    "
63:5 COMMENT "# The small_value function exercises return-value coercion at"
63:66 EOL "\n"
64:1 WS "    "
64:5 COMMENT "# its own definition (`200 + 100 - 250` returning u8)."
64:59 EOL "\n"

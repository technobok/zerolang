62:14 WS " "
62:15 REFID "100"
62:18 WS " "
62:19 REFID "-"
62:20 WS " "
62:21 REFID "250"
62:24 EOL "\n"
63:1 EOL "\n"
64:1 WS "    "
64:5 COMMENT "# The small_value function exercises return-value coercion at"
64:66 EOL "\n"
65:1 WS "    "
65:5 COMMENT "# its own definition (`200 + 100 - 250` returning u8)."
65:59 EOL "\n"

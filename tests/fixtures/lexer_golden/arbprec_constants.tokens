37:1 WS "    "
37:5 COMMENT "# Call-arg coercion: bare 100 coerces to u8 (fits)."
37:56 EOL "\n"
38:1 WS "    "
38:5 REFID "push_byte"
38:14 WS " "
38:15 LABEL "b"
38:16 COLON ":"
38:17 WS " "
38:18 REFID "100"
38:21 EOL "\n"
39:1 EOL "\n"
40:1 WS "    "
40:5 COMMENT "# Call-arg coercion: explicit suffix still works."
40:54 EOL "\n"
41:1 WS "    "
41:5 REFID "push_byte"
41:14 WS " "
41:15 LABEL "b"
41:16 COLON ":"
41:17 WS " "
41:18 REFID "100"
41:21 DOT "."
41:22 REFID "u8"
41:24 EOL "\n"
42:1 EOL "\n"
43:1 WS "    "
43:5 COMMENT "# Call-arg coercion: constant expression folds and fits."
43:61 EOL "\n"
44:1 WS "    "
44:5 REFID "push_byte"
44:14 WS " "
44:15 LABEL "b"
44:16 COLON ":"
44:17 WS " "
44:18 REFID "50"
44:20 WS " "
44:21 REFID "+"
44:22 WS " "
44:23 REFID "25"
44:25 WS " "
44:26 REFID "+"
44:27 WS " "
44:28 REFID "25"
44:30 EOL "\n"
45:1 EOL "\n"
46:1 WS "    "
46:5 COMMENT "# Call-arg coercion: arithmetic where the intermediate exceeds"
46:67 EOL "\n"
47:1 WS "    "
47:5 COMMENT "# u8 but the final value fits."
47:35 EOL "\n"
48:1 WS "    "
48:5 REFID "push_byte"
48:14 WS " "
48:15 LABEL "b"
48:16 COLON ":"
48:17 WS " "
48:18 REFID "200"
48:21 WS " "
48:22 REFID "+"
48:23 WS " "
48:24 REFID "100"
48:27 WS " "
48:28 REFID "-"
48:29 WS " "
48:30 REFID "250"
48:33 EOL "\n"
49:1 EOL "\n"
50:1 WS "    "
50:5 COMMENT "# Arbitrary-precision intermediate: `0xff...ff + 1` is `2^64`,"
50:67 EOL "\n"
51:1 WS "    "
51:5 COMMENT "# which doesn't fit any concrete integer type \u{2014} but the"
51:60 EOL "\n"
52:1 WS "    "
52:5 COMMENT "# subsequent `- 1` brings it back to `u64::MAX`, which the call-"
52:69 EOL "\n"
53:1 WS "    "
53:5 COMMENT "# arg coercion accepts as u64. With Wave 1 (concrete-typed"
53:63 EOL "\n"
54:1 WS "    "
54:5 COMMENT "# operands) the binop folder would have rejected the"
54:57 EOL "\n"
55:1 WS "    "
55:5 COMMENT "# intermediate; Wave 2 keeps the intermediate at unbounded"
55:63 EOL "\n"
56:1 WS "    "
56:5 COMMENT "# precision."
56:17 EOL "\n"
57:1 WS "    "
57:5 REFID "push_u64"
57:13 WS " "
57:14 LABEL "x"
57:15 COLON ":"
57:16 WS " "
57:17 REFID "0xffffffffffffffff"
57:35 WS " "
57:36 REFID "+"
57:37 WS " "
57:38 REFID "1"
57:39 WS " "
57:40 REFID "-"
57:41 WS " "
57:42 REFID "1"
57:43 EOL "\n"
58:1 EOL "\n"
59:1 WS "    "
59:5 COMMENT "# Reassignment coercion: bare literal coerces to a's u8 type."
59:66 EOL "\n"
60:1 WS "    "
60:5 LABEL "a"
60:6 COLON ":"
60:7 WS " "
60:8 REFID "10"
60:10 DOT "."
60:11 REFID "u8"
60:13 EOL "\n"
61:1 WS "    "
61:5 REFID "a"
61:6 WS " "
61:7 EQUALS "="
61:8 WS " "
61:9 REFID "100"
61:12 EOL "\n"
62:1 WS "    "
62:5 REFID "a"
62:6 WS " "
62:7 EQUALS "="
62:8 WS " "
62:9 REFID "200"
62:12 WS " "

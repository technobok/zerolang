40:14 WS " "
40:15 LABEL "b"
40:16 COLON ":"
40:17 WS " "
40:18 REFID "100"
40:21 DOT "."
40:22 REFID "u8"
40:24 EOL "\n"
41:1 EOL "\n"
42:1 WS "    "
42:5 COMMENT "# Call-arg coercion: constant expression folds and fits."
42:61 EOL "\n"
43:1 WS "    "
43:5 REFID "push_byte"
43:14 WS " "
43:15 LABEL "b"
43:16 COLON ":"
43:17 WS " "
43:18 REFID "50"
43:20 WS " "
43:21 REFID "+"
43:22 WS " "
43:23 REFID "25"
43:25 WS " "
43:26 REFID "+"
43:27 WS " "
43:28 REFID "25"
43:30 EOL "\n"
44:1 EOL "\n"
45:1 WS "    "
45:5 COMMENT "# Call-arg coercion: arithmetic where the intermediate exceeds"
45:67 EOL "\n"
46:1 WS "    "
46:5 COMMENT "# u8 but the final value fits."
46:35 EOL "\n"
47:1 WS "    "
47:5 REFID "push_byte"
47:14 WS " "
47:15 LABEL "b"
47:16 COLON ":"
47:17 WS " "
47:18 REFID "200"
47:21 WS " "
47:22 REFID "+"
47:23 WS " "
47:24 REFID "100"
47:27 WS " "
47:28 REFID "-"
47:29 WS " "
47:30 REFID "250"
47:33 EOL "\n"
48:1 EOL "\n"
49:1 WS "    "
49:5 COMMENT "# Arbitrary-precision intermediate: `0xff...ff + 1` is `2^64`,"
49:67 EOL "\n"
50:1 WS "    "
50:5 COMMENT "# which doesn't fit any concrete integer type \u{2014} but the"
50:60 EOL "\n"
51:1 WS "    "
51:5 COMMENT "# subsequent `- 1` brings it back to `u64::MAX`, which the call-"
51:69 EOL "\n"
52:1 WS "    "
52:5 COMMENT "# arg coercion accepts as u64. With Wave 1 (concrete-typed"
52:63 EOL "\n"
53:1 WS "    "
53:5 COMMENT "# operands) the binop folder would have rejected the"
53:57 EOL "\n"
54:1 WS "    "
54:5 COMMENT "# intermediate; Wave 2 keeps the intermediate at unbounded"
54:63 EOL "\n"
55:1 WS "    "
55:5 COMMENT "# precision."
55:17 EOL "\n"
56:1 WS "    "
56:5 REFID "push_u64"
56:13 WS " "
56:14 LABEL "x"
56:15 COLON ":"
56:16 WS " "
56:17 REFID "0xffffffffffffffff"
56:35 WS " "
56:36 REFID "+"
56:37 WS " "
56:38 REFID "1"
56:39 WS " "
56:40 REFID "-"
56:41 WS " "
56:42 REFID "1"
56:43 EOL "\n"
57:1 EOL "\n"
58:1 WS "    "
58:5 COMMENT "# Reassignment coercion: bare literal coerces to a's u8 type."
58:66 EOL "\n"
59:1 WS "    "
59:5 LABEL "a"
59:6 COLON ":"
59:7 WS " "
59:8 REFID "10"
59:10 DOT "."
59:11 REFID "u8"
59:13 EOL "\n"

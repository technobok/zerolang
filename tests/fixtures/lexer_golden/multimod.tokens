1:1 COMMENT "# multimod.z -- Multi-module program"
1:37 EOL "\n"
2:1 COMMENT "# v1 target: units, imports, forward reference resolution"
2:58 EOL "\n"
3:1 COMMENT "# This file imports from mathutil.z (in the same directory)"
3:60 EOL "\n"
4:1 EOL "\n"
5:1 LABEL "main"
5:5 COLON ":"
5:6 WS " "
5:7 FUNCTION "function"
5:15 WS " "
5:16 IS "is"
5:18 WS " "
5:19 BRACEOPEN "{"
5:20 EOL "\n"
6:1 WS "    "
6:5 LABEL "result"
6:11 COLON ":"
6:12 WS " "
6:13 REFID "mathutil"
6:21 DOT "."
6:22 REFID "square"
6:28 WS " "
6:29 REFID "7"
6:30 EOL "\n"
7:1 WS "    "
7:5 REFID "print"
7:10 WS " "
7:11 STRBEG "\""
7:12 STRMID "7 squared = "
7:24 STREXPRBEG "\\"
7:25 BRACEOPEN "{"
7:26 REFID "result"
7:32 BRACECLOSE "}"
7:33 STREND "\""
7:34 EOL "\n"
8:1 EOL "\n"
9:1 WS "    "
9:5 LABEL "result2"
9:12 COLON ":"
9:13 WS " "
9:14 REFID "mathutil"
9:22 DOT "."

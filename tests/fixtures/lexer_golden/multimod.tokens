10:1 WS "    "
10:5 REFID "print"
10:10 WS " "
10:11 STRBEG "\""
10:12 STRMID "3 cubed = "
10:22 STREXPRBEG "\\"
10:23 BRACEOPEN "{"
10:24 REFID "result2"
10:31 BRACECLOSE "}"

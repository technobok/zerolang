1:1 COMMENT "# create_null.z -- Disabling the default constructor with `create: null`"
1:73 EOL "\n"
2:1 COMMENT "#"
2:2 EOL "\n"
3:1 COMMENT "# Demonstrates:"
3:16 EOL "\n"
4:1 COMMENT "# - `create: null` suppresses the compiler-generated default constructor"
4:73 EOL "\n"
5:1 COMMENT "#   so bare-name construction `mything x: 1` and explicit `mything.create`"
5:75 EOL "\n"
6:1 COMMENT "#   both produce a targeted compile-time error"
6:47 EOL "\n"
7:1 COMMENT "# - A named alternate constructor (here, `build`) can be defined and called"
7:76 EOL "\n"
8:1 COMMENT "#   explicitly"
8:15 EOL "\n"
9:1 COMMENT "# - `meta.create` inside the alternate constructor body allocates the raw"
9:74 EOL "\n"
10:1 COMMENT "#   fields"
10:11 EOL "\n"
11:1 EOL "\n"
12:1 LABEL "Secret"
12:7 COLON ":"
12:8 WS " "
12:9 CLASS "class"
12:14 WS " "
12:15 BRACEOPEN "{"
12:16 WS " "
12:17 LABEL "value"
12:22 COLON ":"
12:23 WS " "
12:24 REFID "i64"
12:27 WS " "
12:28 BRACECLOSE "}"
12:29 WS " "
12:30 AS "as"
12:32 WS " "
12:33 BRACEOPEN "{"
12:34 EOL "\n"
13:1 WS "    "
13:5 COMMENT "# No generated create \u{2014} callers cannot allocate a `secret` directly."
13:73 EOL "\n"
14:1 WS "    "
14:5 LABEL "create"
14:11 COLON ":"
14:12 WS " "
14:13 REFID "null"
14:17 EOL "\n"
15:1 EOL "\n"
16:1 WS "    "
16:5 COMMENT "# Only `secret.build` constructs a secret. The body uses `meta.create`"
16:75 EOL "\n"
17:1 WS "    "
17:5 COMMENT "# to set the raw field value."
17:34 EOL "\n"
18:1 WS "    "

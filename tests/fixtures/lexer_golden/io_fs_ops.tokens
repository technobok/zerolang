1:1 COMMENT "# io_fs_ops.z -- filesystem operations."
1:40 EOL "\n"
2:1 COMMENT "#"
2:2 EOL "\n"
3:1 COMMENT "# Four simple one-shot primitives:"
3:35 EOL "\n"
4:1 COMMENT "#"
4:2 EOL "\n"
5:1 COMMENT "#   io.exists path: string          \u{2192} bool"
5:43 EOL "\n"
6:1 COMMENT "#   io.mkdir  path: string          \u{2192} result(null, ioerror)"
6:60 EOL "\n"
7:1 COMMENT "#   io.remove path: string          \u{2192} result(null, ioerror)"
7:60 EOL "\n"
8:1 COMMENT "#   io.rename from: ... to: ...     \u{2192} result(null, ioerror)"
8:60 EOL "\n"
9:1 COMMENT "#"
9:2 EOL "\n"
10:1 COMMENT "# `exists` does not distinguish missing from permission-denied \u{2014} both"
10:70 EOL "\n"
11:1 COMMENT "# return false. For that distinction use `stat` (future phase)."
11:64 EOL "\n"
12:1 COMMENT "# `remove` handles both files and empty directories; non-empty"
12:63 EOL "\n"
13:1 COMMENT "# directories error with ENOTEMPTY (mapped to ioerror.other)."
13:62 EOL "\n"
14:1 EOL "\n"

15:8 COLON ":"
15:9 WS "  "
15:11 REFID "64"
15:13 EOL "\n"
16:1 WS "    "
16:5 LABEL "HIGH"
16:9 COLON ":"
16:10 WS " "
16:11 REFID "250"
16:14 EOL "\n"
17:1 BRACECLOSE "}"
17:2 WS " "
17:3 OUT "out"
17:6 WS " "
17:7 REFID "u8"
17:9 EOL "\n"
18:1 EOL "\n"
19:1 COMMENT "# Untyped: element type defaults to i64. Literals coerce at use"
19:64 EOL "\n"
20:1 COMMENT "# sites \u{2014} `primes.0` flows into whatever numeric slot the caller"
20:65 EOL "\n"
21:1 COMMENT "# expects."
21:11 EOL "\n"

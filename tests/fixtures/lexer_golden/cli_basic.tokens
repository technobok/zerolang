1:1 COMMENT "# cli_basic.z -- register-then-parse CLI demo."
1:47 EOL "\n"
2:1 COMMENT "#"
2:2 EOL "\n"
3:1 COMMENT "# Models a zgrep-style tool:"
3:29 EOL "\n"
4:1 COMMENT "#   cli_basic [-v] [-i] [--output=FILE] PATTERN FILE"
4:53 EOL "\n"
5:1 COMMENT "#"
5:2 EOL "\n"
6:1 COMMENT "# Registers two flags, one option, and two required positionals."
6:65 EOL "\n"
7:1 COMMENT "# On parse success, prints each extracted value. On parse error,"
7:65 EOL "\n"
8:1 COMMENT "# prints the usage block."
8:26 EOL "\n"

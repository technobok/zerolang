14:11 COLON ":"
14:12 WS " "
14:13 FUNCTION "function"
14:21 WS " "
14:22 IS "is"
14:24 WS " "
14:25 BRACEOPEN "{"
14:26 EOL "\n"
15:1 WS "    "

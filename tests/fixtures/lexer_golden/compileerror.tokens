1:1 COMMENT "# compileerror.z -- Compile-time error"
1:39 EOL "\n"
2:1 COMMENT "#"
2:2 EOL "\n"
3:1 COMMENT "# The error builtin produces a compile-time error. When the compiler"
3:69 EOL "\n"
4:1 COMMENT "# can prove an error call is reachable, compilation fails with the"
4:67 EOL "\n"
5:1 COMMENT "# user's message. Use it inside if branches with constant conditions"
5:69 EOL "\n"
6:1 COMMENT "# to create conditional compilation errors."
6:44 EOL "\n"
7:1 COMMENT "#"
7:2 EOL "\n"
8:1 COMMENT "# error \"message\"                   -- always fails"
8:52 EOL "\n"
9:1 COMMENT "# if CONST == 0 then { error \"x\" } -- fails only when CONST is 0"
9:65 EOL "\n"
10:1 COMMENT "# if CONST != 0 then { error \"x\" } -- eliminated when CONST is 0"
10:65 EOL "\n"
11:1 EOL "\n"

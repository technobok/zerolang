15:15 WS " "
15:16 REFID "0"
15:17 WS " "
15:18 THEN "then"
15:22 WS " "
15:23 REFID "error"
15:28 WS " "
15:29 STRBEG "\""
15:30 STRMID "MODE must not be zero"
15:51 STREND "\""
15:52 EOL "\n"
16:1 WS "    "
16:5 REFID "print"
16:10 WS " "

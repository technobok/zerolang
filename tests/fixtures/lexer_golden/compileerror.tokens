16:12 STRMID "mode ok"
16:19 STREND "\""
16:20 EOL "\n"
17:1 BRACECLOSE "}"
17:2 EOL "\n"
18:1 EOL "\n"
19:1 COMMENT "# With numeric generics: validate parameters at monomorphisation time."
19:71 EOL "\n"
20:1 COMMENT "# Each instantiation evaluates the condition with the concrete value."
20:70 EOL "\n"

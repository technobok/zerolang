1:1 COMMENT "# PR 6 fixture: raw triple-quoted string literals."
1:51 EOL "\n"
2:1 COMMENT "# Backslash is literal (no escape processing); closing run must"
2:64 EOL "\n"
3:1 COMMENT "# match the opening length.  ASCII-only -- UTF-8 multi-byte emission"
3:69 EOL "\n"
4:1 COMMENT "# for hex escapes is PR 7.  Embedded `\"` runs inside the body are"
4:66 EOL "\n"
5:1 COMMENT "# intentionally avoided here: the Python reference has a quirk where"
5:69 EOL "\n"
6:1 COMMENT "# a non-cleared delim accumulator under-consumes the closing run"
6:65 EOL "\n"
7:1 COMMENT "# when a shorter `\"` run precedes it.  The port mirrors the quirk"
7:66 EOL "\n"
8:1 COMMENT "# byte-for-byte; the fixture stays on the clean side of it."
8:60 EOL "\n"
9:1 STRBEG "\"\"\""
9:4 STRMID "hello"
9:9 STREND "\"\"\""
9:12 EOL "\n"
10:1 STRBEG "\"\"\""
10:4 STRMID "back\\nslash"
10:15 STREND "\"\"\""
10:18 EOL "\n"
11:1 STRBEG "\"\"\""
11:4 STRMID "line1"
11:9 EOL "\n"
12:1 STRMID "line2"
12:6 STREND "\"\"\""
12:9 EOL "\n"
13:1 STRBEG "\"\"\"\"\""
13:6 STRMID "hi"
13:8 STREND "\"\"\"\"\""
13:13 EOL "\n"
14:1 EOF ""

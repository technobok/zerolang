1:1 COMMENT "# PR 6 fixture: raw triple-quoted string literals."
1:51 EOL "\n"
2:1 COMMENT "# Backslash is literal (no escape processing); closing run must"
2:64 EOL "\n"
3:1 COMMENT "# match the opening length.  Shorter `\"` runs inside the body are"
3:66 EOL "\n"
4:1 COMMENT "# literal content (the embedded-quote case exercises this)."
4:60 EOL "\n"
5:1 COMMENT "# ASCII-only -- UTF-8 multi-byte emission for hex escapes is PR 7."
5:67 EOL "\n"
6:1 STRBEG "\"\"\""
6:4 STRMID "hello"
6:9 STREND "\"\"\""
6:12 EOL "\n"
7:1 STRBEG "\"\"\""
7:4 STRMID "back\\nslash"
7:15 STREND "\"\"\""
7:18 EOL "\n"
8:1 STRBEG "\"\"\""
8:4 STRMID "line1"
8:9 EOL "\n"
9:1 STRMID "line2"
9:6 STREND "\"\"\""
9:9 EOL "\n"
10:1 STRBEG "\"\"\"\"\""
10:6 STRMID "hi"
10:8 STREND "\"\"\"\"\""
10:13 EOL "\n"
11:1 STRBEG "\"\"\""
11:4 STRMID "one\"two\"\"three"
11:18 STREND "\"\"\""
11:21 EOL "\n"
12:1 EOF ""

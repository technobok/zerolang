# optionval_return.z -- a function returning (optionval t: T). fnSignature must
# resolve the variant-mono return type to its C type (the lexer's
# utf8_decode_at returns (optionval t: u32)); without it the signature emits
# `void` and the call binding fails ("invalid initializer").

decode: function {n: u32} out (optionval t: u32) is {
    if n > 100.u32 then {
        return (optionval.none u32)
    }
    return (optionval.some n)
}

main: function is {
    r: decode n: 7.u32
    match (
        r
    ) case some then {
        print "got=\{r}"
    } case none then {
        print "none"
    }
}

# Map/Set fields are heap pointers: reading .length/.capacity through a
# field path (this.field, param.field, narrowed.field) must emit ->, not .
Store: class {
    counts: (Map String value: u64)
    seen: (Set u64)
} as {
    tally: function {:this} out u64 is {
        return this.counts.length + this.seen.length
    }
}

Held: union {
    store: Store
    nothing: null
}

storeSize: function {s: Store} out u64 is {
    return s.counts.length
}

main: function is {
    st: Store counts: (Map String value: u64) seen: (Set u64)
    k1: "alpha".string
    v1: 1.u64
    st.counts.set key: k1 value: v1
    k2: "beta".string
    v2: 2.u64
    st.counts.set key: k2 value: v2
    st.seen.add item: 7
    print "tally=\{st.tally}"
    print "free=\{storeSize s: st}"
    print "direct=\{st.counts.length}"
    h: Held.store st
    match (
        h
    ) case store then {
        print "narrowed=\{h.counts.length}"
    } case nothing then {}
}

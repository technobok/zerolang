# shadow_list_iter.z -- a user record shadowing the builtin scalar `i64` as a
# List element, iterated in a for-loop with a field read. ListIter's `.call`
# returns an OptionView over the element; its return type id is linked by mono id
# (linkMonoReturn sets the method returnTypeId), so the emitter reads the some-arm
# payload by canonical id -- the user struct, not the by-name system scalar. The
# loop var is the user struct; x.hi reads it.

i64: record {
    hi: 0
    lo: 0
}

main: function is {
    xs: (List of: i64)
    xs.append (i64 hi: 1 lo: 2)
    xs.append (i64 hi: 3 lo: 4)
    it: xs.iterate
    for x: it loop {
        print "hi=\{x.hi}"
    }
    print "done"
}

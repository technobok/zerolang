# generator_reftype_yield.z -- generators yielding REFTYPES wrap in Option
# (boxed payload): the yield leg boxes the owned value, the consumer loop
# moves it out and frees box + payload per iteration, and the loop-owned
# iterator instance destroys at block exit (freeing owned captured params).
# No string literals inside generator bodies (the literal pool does not
# reach lowered synth bodies yet) and no heap-owning locals (their fn-exit
# frees land after the resume labels -- pre-existing, tracked as an open).

tags: function {base: String.take n: u64} out (Iterator gives: String) is {
    i: 0.u64
    for i < n loop {
        yield base.copy
        i = i + 1
    }
}

pair: function {base: String.take} out (Iterator gives: String.take) is {
    yield base.copy
    yield base.copy
}

main: function is {
    for s: (tags base: "alpha".string n: 3) loop print "s: \{s}"
    xs: (List String)
    for t: (pair base: "gamma".string) loop {
        xs.append t
    }
    n: xs.length
    print "collected: \{n}"
    i: 0.u64
    for i < n loop {
        e: xs.get i: i
        print "e: \{e}"
        i = i + 1
    }
    print "done"
}

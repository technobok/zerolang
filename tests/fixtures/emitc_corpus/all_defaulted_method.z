# all_defaulted_method.z -- a bare reference to a method whose every
# non-receiver parameter has a default auto-calls with the defaults
# filled (receiver first); the explicit labeled call still overrides.

Gadget: class {
    value: 4.i64
} as {
    scaled: function {:this factor: 2.i64} out i64 is {
        return this.value * factor
    }

    poke: function {:this bump: 10.i64} is {
        this.value = this.value + bump
    }
}

main: function is {
    g: Gadget
    v: g.scaled
    print "\{v}"
    w: g.scaled factor: 3
    print "\{w}"
    g.poke
    print "\{g.value}"
    g.poke bump: 1
    print "\{g.value}"
}

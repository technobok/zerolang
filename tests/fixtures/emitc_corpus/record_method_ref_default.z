# record_method_ref_default.z -- a record field defaulting to a sibling method
# (`hook: transform1`): the field is a function-pointer slot typed by the
# referenced method and defaulting to its address; construction omits it and
# calls through it. Mirrors the class form (defaults.z Hookc); the record path
# resolves the sibling ref to its FUNCTION type the same way.

mrec: record {
    val: i64
    transform1: function {r: this} out i64 is { return r.val + 100 }
    transform2: function {r: this} out i64 is { return r.val * 10 }
    hook: transform1
}

main: function is {
    r: mrec val: 5
    print "\{r.hook r: r}"
}

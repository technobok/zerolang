# list_fn_call_binding.z -- a binding whose RHS is a USER FUNCTION returning
# (List of: String). emitStmt's List-binding branch hardcoded an empty
# List_create in its default (covering only `(List of: T)` literals + the
# osNoArgCallRhs os.args case), so a value-producing RHS was DROPPED -> the
# binding got an empty list (compiles + runs, but behaviorally wrong). Now the
# default emits emitExpr(rhs), which renders `(List of: T)` as create(0) and a
# call as the call. Mirrors zvfs runScript -> dispatchLine -> tokenizeLine
# (`toks: tokenizeLine line: sv`), whose empty result produced no script output.

makeList: function {n: u64} out (List of: String) is {
    buf: (List of: String)
    i: 0.u64
    for while i < n loop {
        buf.append "x".string
        i = i + 1.u64
    }
    return buf
}

main: function is {
    xs: makeList n: 3.u64
    print "len=\{xs.length}"
}

# string_append.z -- String.append s: <StringView> (a literal and a String's
# .stringview). The runtime native z_String_append(s, const char* data, u64 len)
# consumes the view as data+length, so the emitter must unpack `.data`/`.length`
# -- not pass the StringView struct by value (unlike appendByte's scalar arg).
# emitStringArgMethod handled appendByte/reserve but not append -> the call fell
# through to `/* unhandled callee */0`. Mirrors zvfs ZVfs.path's assembly loop
# (out_str.append s: "/" / out_str.append s: nm.stringview).

main: function is {
    out_str: "".string
    nm: "world".string
    out_str.append s: "hello, "
    out_str.append s: nm.stringview
    print "out=\{out_str}"
}

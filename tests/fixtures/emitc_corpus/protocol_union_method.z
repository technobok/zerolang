# protocol_union_method.z -- a protocol whose method returns a union (zvfs's
# ZVfsProvider.open -> OpenResult shape), implemented by a class, created as an
# owned protocol from an intermediate binding moved with `.take`. The protocol
# vtable references the union return type, so the union struct must be emitted
# BEFORE the protocol (vtable fn pointer); otherwise the vtable struct is
# malformed (undefined type / missing member).

Res: union {
    ok: i64
    bad: i64
}

Reader: protocol {
    read: function {:this} out Res
}

MyFile: class {
    marker: bool
} as {
    myreader: Reader
    read: function {f: this} out Res is {
        return (Res.ok 7)
    }
}

main: function is {
    f: MyFile marker: false
    r: Reader.create from: f.take
    g: r.read
    match (
        g
    ) case ok then {
        print "ok=\{g}"
    } case bad then {
        print "bad"
    }
}

# union_noarg_arm.z -- a no-payload union arm in value position (c: Result.missing).
# The emitter handles no-payload VARIANT arms (nodekind.dir -> ((nodekind_t){.tag
# = TAG})) but not UNION arms, so `Result.missing` emitted a bare member access
# -> `Result undeclared`. Mirrors zvfs's `e: IoError.notfound`.

Result: union {
    ok: u32
    missing: null
}

main: function is {
    c: Result.missing
    match (
        c
    ) case ok then {
        print "ok"
    } case missing then {
        print "missing"
    }
}

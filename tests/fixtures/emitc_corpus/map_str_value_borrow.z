# map_str_value_borrow.z -- Map.get over a native-String VALUE returns an
# OptionView (a borrowed, locked view into the map's storage), not a deep-copied
# owned Option. The matched value is read through the borrow (.stringview) and
# `.copy`d to keep an owned copy past the borrow; the map still owns its value
# (no deep-copy on get, no leak).

main: function is {
    m: (Map key: i64 value: String)
    m.set key: 1 value: "hello".string
    g: m.get key: 1
    match (g) case some then {
        kept: g.copy
        print "read \{g.stringview} kept \{kept.stringview}"
    } case none then {
        print "none"
    }
    print "len \{m.length}"
}

# shadow_i64.z -- a user record SHADOWS the builtin scalar `i64` (scalar names are
# not reserved). The user value must be built AND stored as its struct
# (z_t{N}_i64_t x = ..._create(...)), not `int64_t x` by name, and field access
# x.hi must hit the struct. Meanwhile the system `i64` reached via print->io (the
# File.Seeker.seek `to: i64` param) must stay the C scalar: the emitter trusts
# each reference's canonical id (definedInUnit) and never re-resolves by name.

i64: record {
    hi: 0
    lo: 0
}

main: function is {
    x: i64 hi: 1 lo: 2
    print "hi=\{x.hi} lo=\{x.lo}"
}

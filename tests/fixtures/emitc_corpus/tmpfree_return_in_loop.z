# Early return from a for-loop body while an interpolation temp is live:
# the return value is built from the temp, then the temp frees on the
# return path; prior iterations flush per iteration.
findAt: function {limit: u64} out String is {
    i: 0.u64
    for i < limit loop {
        msg: "probe-\{i}"
        if i == 2 then {
            return "found:\{msg}"
        }
        i = i + 1
    }
    return "none".string
}

main: function is {
    r: findAt limit: 5
    print "\{r}"
}

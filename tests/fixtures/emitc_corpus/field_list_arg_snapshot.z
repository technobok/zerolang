# field_list_arg_snapshot.z -- the snapshot idiom for passing a container that
# has outstanding views: scope the element view to a block and copy the value
# fields you need out of it, then the container is free to lend to a call that
# grows it. (Copying the element itself is not available: `.copy` of a user
# reftype is E0100 by design.)
Box: class {
    n: u64
}

Prog: class {
    units: (List Box)
}

clobber: function {xs: List Box} is {
    i: u64
    for i < 64 loop {
        xs.append (Box n: (100 + i))
        i = i + 1
    }
}

main: function is {
    p: (Prog units: (List Box))
    p.units.append (Box n: 1)
    p.units.append (Box n: 2)
    first: u64
    second: u64
    {
        e0: p.units.get i: 0
        first = e0.n
        e1: p.units.get i: 1
        second = e1.n
    }
    clobber xs: p.units
    print "first=\{first} second=\{second} len=\{p.units.length}"
    {
        last: p.units.get i: (p.units.length - 1)
        print "last=\{last.n}"
    }
    print "done"
}

# append_stringlike.z -- String.append takes a StringLike arg: a StringView,
# a literal, or an owned String pass directly (no .stringview projection).
# The String arg is BORROWED (byte copy) -- it stays live after the call,
# including through a borrowed-String param.
glue: function {dst: String.borrow part: String} is {
    dst.append part
    dst.append part
}

main: function is {
    a: "base".string
    v: " view"
    a.append v
    a.append " lit"
    b: " owned \{1}"
    a.append b
    print "b=\{b}"
    print "a=\{a}"
    g: "go".string
    p: "-x \{2}"
    glue dst: g part: p
    print "p=\{p}"
    print "g=\{g}"
}

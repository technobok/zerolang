# dobreak_reftype.z -- a break-carrying block value with a REFTYPE result
# wraps in Option (boxed payload): none on early break, a malloc'd box on
# normal completion, destroyed with the local. The last expression's take
# args invalidate (the moved-in String is not double-freed), on both the
# break-carrying and plain block-value paths. Interpolated construction
# arguments emit via the self-contained interp statement expression on
# both paths (no pre-bound temp needed).
C: class {
    v: u64
    tag: String
}

main: function is {
    i: 0.u64
    for i < 3 loop {
        i = i + 1
        t: "item \{i}"
        r: {
            if i == 2 then break
            C v: i tag: t.take
        }
        match (
            r
        ) case some then {
            print "got \{r.v} \{r.tag}"
        } case none then {
            print "broke at \{i}"
        }
    }
    u: "plain \{9}"
    y: {
        C v: 9 tag: u.take
    }
    print "y=\{y.v} \{y.tag}"
    w: 0.u64
    for w < 3 loop {
        w = w + 1
        d: "w\{w}"
        q: {
            if w == 2 then break
            C v: w tag: "i\{d}"
        }
        match (
            q
        ) case some then {
            print "iq \{q.v} \{q.tag}"
        } case none then {
            print "ibroke \{w}"
        }
    }
    z: {
        C v: 7 tag: "z\{7}"
    }
    print "z=\{z.v} \{z.tag}"
}

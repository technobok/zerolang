# os_exePath.z -- os.exePath returns the running executable's absolute
# path. The two differential binaries live at different paths, so assert
# only the stable shape (ok + leading '/'), never the path itself.

main: function is {
    r: os.exePath
    match (
        r
    ) case ok then {
        abs: r.stringview.startsWith prefix: "/"
        print "exePath ok abs=\{abs}"
    } case err then {
        print "exePath err"
    }
}

# continue_iter_payload.z -- jumps out of an owned-payload iterator loop
# (plain continue / continue-in-do via __zcont / break / return) run the
# loop's per-iteration payload destructor before jumping: the fall-through
# dtor line sits after the jump targets and would otherwise be skipped.
# Generator bodies hold no literals (pool gap) and no heap-owning locals
# (fn-exit-free gap) -- both recorded opens.

tags: function {base: String.take n: u64} out (Iterator gives: String) is {
    i: 0.u64
    for i < n loop {
        yield base.copy
        i = i + 1
    }
}

sumret: function out u64 is {
    k: 0.u64
    for s: (tags base: "delta".string n: 4) loop {
        k = k + s.length
        if k > 8 then return k
    }
    return k
}

main: function is {
    i: 0.u64
    for s: (tags base: "alpha".string n: 4) loop {
        i = i + 1
        if i == 2 then continue
        print "s: \{i} \{s}"
    }
    j: 0.u64
    for t: (tags base: "beta".string n: 4) loop {
        j = j + 1
        {
            if j == 9 then break
            if j == 2 then continue
            print "t: \{j} \{t}"
        }
    }
    k: 0.u64
    for u: (tags base: "gamma".string n: 4) loop {
        k = k + 1
        if k == 2 then break
        print "u: \{k} \{u}"
    }
    r: sumret
    print "r: \{r}"
    print "done"
}

# fwd_recursive_union.z -- a self-referential union (Thing) whose arm class
# (Item) embeds a `(List of: Thing)`, so the union, the arm class, their
# destructors, and the List/Option monos all reference each other ahead of their
# bodies. Without named-struct forward declarations the arm-class structs +
# destructors are undeclared / used-before-declared. emitMainFwdDecls forward-
# declares main-unit RECORD/UNION/CLASS types (named structs + destroy protos);
# the bodies emit as plain `struct X_t { ... };`. Mirrors zast's Node union +
# its *Data arm classes.

Item: class {
    label: String
    kids:  (List of: Thing)
}

Thing: union {
    item:  Item
    blank: Item
}

main: function is {
    box: Item label: "root".string kids: (List of: Thing)
    th: Thing.item box.take
    match (
        th
    ) case item then {
        print "label=\{th.label} kids=\{th.kids.length}"
    } case blank then {
        print "blank"
    }
}

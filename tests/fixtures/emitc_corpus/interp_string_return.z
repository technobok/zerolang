# interp_string_return.z -- `return "\{a}/\{b}"` (an interpolated-String
# literal in return position). emitStringReturnValue builds the interp String
# and returns the owned temp. Mirrors zvfs's joinPath.

joinPath: function {a: StringView b: StringView} out String is {
    return "\{a}/\{b}"
}

main: function is {
    p: joinPath a: "usr" b: "bin"
    print "p=\{p}"
}

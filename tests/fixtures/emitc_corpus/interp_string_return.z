# interp_string_return.z -- `return "\{a}/\{b}".string` (an interpolated-String
# literal in return position). emitCallStmt's return arm tried emitOptionBoxHoist
# then fell straight to emitExpr, which emitted `/* unhandled dotted */0` for the
# interp-`.string` value -> `return <int>` from a String fn. emitStringReturnValue
# builds the interp String and returns the owned temp. Mirrors zvfs's joinPath.

joinPath: function {a: StringView b: StringView} out String is {
    return "\{a}/\{b}".string
}

main: function is {
    p: joinPath a: "usr" b: "bin"
    print "p=\{p}"
}

# ifacelib -- a library unit exposing a renamed public interface. `areaOf` is
# public as-is; `perimImpl` is exposed under the public name `perimeter`;
# `secret` is omitted, so it is private and unreachable from another unit.
areaOf: function {w: i64 h: i64} out i64 is { return w * h }
perimImpl: function {w: i64 h: i64} out i64 is { return (w + h) + (w + h) }
secret: function {n: i64} out i64 is { return n + 1 }
public: unit { :areaOf perimeter: perimImpl }

svlen2: function {sv: StringView} out u64 is {
    return (sv.length)
}

Box: class {
    n: u64
} as {
    create: function {start: u64} out this is {
        return (meta.create n: start)
    }

    label: function {:this nm: String} out u64 is {
        return (svlen2 sv: nm.stringview)
    }
}

main: function is {
    b: Box start: 0.u64
    r: b.label nm: "hello".string
    print "\{r}"
}

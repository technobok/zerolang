# Break from inside a match arm: owned temps live at loop depth and arm
# depth when the break fires; the break path must free both levels.
main: function is {
    total: 0.u64
    i: 0.u64
    for i < 5 loop {
        li: "loop-\{i}"
        sel: optionval.some i
        match (
            sel
        ) case some then {
            ai: "arm-\{sel}"
            if sel == 3 then {
                break
            }
            total = total + ai.length
        } case none then {}
        total = total + li.length
        i = i + 1
    }
    print "total=\{total}"
}

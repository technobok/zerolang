# ctor_positional.z -- record construction mixing a leading positional arg with a
# labeled one (`point 3 y: 7`): the positional binds the first field by declaration
# order, the label binds by name. Exercises the emitter positional-cursor fallback
# in emitRecordCtor; the examples corpus only ever constructs by label.

point: record {
    x: i64
    y: i64
}

main: function is {
    p: point 3 y: 7
    print "\{p.x},\{p.y}"
}

# shadow_record_eq.z -- a user record (Pair) has fields whose type is a user scalar
# shadow (i64). The auto-generated Pair_eq must compare each field via the field
# type's own _eq (z_t{N}_i64_eq), not the scalar `==`: the field is a struct, not
# int64_t. emitOneRecord keys the scalar-vs-struct choice on the field's canonical
# id, not its name.

i64: record {
    hi: 0
    lo: 0
}

Pair: record {
    a: i64
    b: i64
}

main: function is {
    p: Pair a: (i64 hi: 1 lo: 2) b: (i64 hi: 3 lo: 4)
    q: Pair a: (i64 hi: 1 lo: 2) b: (i64 hi: 3 lo: 4)
    if p == q then { print "eq" } else { print "ne" }
}

# static_call_class_param.z -- an explicit-receiver static method call
# `Type.method <p>` where the receiver p is a class PARAM (already a pointer).
# emitTypeQualCall emitted &p (a Cat**); a local receiver correctly needs the &.

Cat: class {
    k: i64
    bump: function {c: this} out i64 is {
        return c.k + 1
    }
}

callVia: function {p: Cat} out i64 is {
    return (Cat.bump p)
}

main: function is {
    c: Cat k: 41
    print "b=\{callVia p: c}"
}

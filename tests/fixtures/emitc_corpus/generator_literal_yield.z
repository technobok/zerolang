# generator_literal_yield.z -- string literals and interpolations inside
# generator bodies: the literal pool walks yield operands (collectLiterals
# yieldexpr arm) and the yield leg routes interpolated values through the
# self-contained interp statement expression. Payloads are owned Strings
# (boxed Option wrappers).

lits: function out (Iterator gives: String) is {
    yield "alpha".string
    yield "beta".string
}

nums: function {n: u64} out (Iterator gives: String) is {
    i: 0.u64
    for i < n loop {
        i = i + 1
        yield "n=\{i}"
    }
}

main: function is {
    for s: lits loop print "s: \{s}"
    for t: (nums n: 3) loop print "t: \{t}"
    print "done"
}

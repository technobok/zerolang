# generic_mono_dtor.z -- a generic user class whose SUBSTITUTED fields are
# destructible carries an auto-destructor, exactly like its non-generic
# counterpart: the mono frees its payload at scope exit, and field interps
# read in place (no hoisted copy, no accidental free). Pins the zero-read
# leak and the double-read use-after-free.

G: class {
    val: t
} as { t: Any.generic }

main: function is {
    silent: G val: "unread".string
    g: G val: "hello".string
    print "one=\{g.val}"
    print "two=\{g.val}"
    s2: "moved".string
    m: G val: s2.take
    print "m=\{m.val}"
    n: G val: 42
    print "n=\{n.val}"
    print "done"
}

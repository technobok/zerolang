Item: record {
    n: u64
}

total: function {xs: (List of: Item).take} out u64 is {
    acc: 0.u64
    with it: xs.iterate do for x: it loop {
        acc = acc + x.n
    }
    return acc
}

bump: function {x: u64} out u64 is {
    return x + 1.u64
}

main: function is {
    ys: (List of: Item)
    ys.append (Item n: 5.u64)
    a: total xs: ys
    b: bump x: 10.u64
    print "\{a} \{b}"
}

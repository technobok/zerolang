# public-interface renaming: a member may be exposed under a different public
# name. `:name` exposes it as-is; `alias: internal` renames it. The internal
# name stays private; only the public name is reachable from outside.
point: record { x: i64 y: i64 } as {
    public: unit { px: x py: y }
}

adder: class { base: i64 } as {
    public: unit { add: addImpl }
    addImpl: function {:this delta: i64} out i64 is { return this.base + delta }
}

shape: union { circleArm: i64 boxArm: i64 } as {
    public: unit { circle: circleArm }
}

main: function is {
    p: point x: 1 y: 2
    print "px=\{p.px} py=\{p.py}"
    with a: (adder base: 100) do print "add=\{a.add delta: 5}"
    s: shape.circle 7
    if s.circle then print "circle" else print "other"
}

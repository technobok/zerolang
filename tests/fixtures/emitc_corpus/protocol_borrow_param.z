# protocol_borrow_param.z -- an explicit `Proto.borrow from: <p>.lock` where the
# source `p` is a reftype-class PARAM (already a pointer). emitProtocolCreateCall
# emitted the conformance helper as `_create(&p)` = a Cat** where Cat* is
# expected; a local source correctly still needs the &.

Greeter: protocol {
    greet: function {:this n: i64} out i64
}

Cat: class {
    k: i64
} as {
    :Greeter
    greet: function {c: this n: i64} out i64 is {
        return c.k + n
    }
}

viaBorrow: function {p: Cat n: i64} out i64 is {
    g: Greeter.borrow from: p.lock
    return (g.greet :n)
}

main: function is {
    c: Cat k: 40
    v: viaBorrow p: c n: 2
    print "greet=\{v}"
}

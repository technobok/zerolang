# map_view_locks.z -- the Map accessor contract, audited: get views bind
# SHARED (readers -- more gets, has, length -- coexist; writers conflict),
# valtype-valued maps stay lock-free plain copies, and a discarded remove
# destroys its owned Option payload.

main: function is {
    m: (Map String value: String)
    m.set key: "k1".string value: "v1".string
    m.set key: "k2".string value: "v2".string
    {
        e1: m.get key: "k1".string
        e2: m.get key: "k2".string
        h: m.has key: "k1".string
        n: m.length
        match (e1) case some then print "e1=\{e1}" case none then print "n1"
        match (e2) case some then print "e2=\{e2} h=\{h} n=\{n}" case none then print "n2"
    }
    m.set key: "k3".string value: "v3".string
    m.remove key: "k3".string
    v: (Map String value: u64)
    v.set key: "a".string value: 7
    x: v.get key: "a".string
    v.set key: "b".string value: 9
    match (x) case some then print "x=\{x}" case none then print "xn"
    print "done n=\{m.length} vn=\{v.length}"
}

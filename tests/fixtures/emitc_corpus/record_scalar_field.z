# record_scalar_field.z -- record fields named after numeric scalars, read
# through a value. `h.u8` is a member of a user type (memberOwnerTid), so the
# emitter's cast leg must skip it; genuine conversions (`x.u8` on i64, the
# literal `65.u8`) keep casting. Includes the shadow interplay: a field named
# `u8` on a record NAMED `u64`.

holder: record {
    u8: 0
}

u64: record {
    u8: 0
}

main: function is {
    h: holder u8: 9
    print "field u8=\{h.u8}"
    sh: u64 u8: 3
    print "shadow field=\{sh.u8}"
    x: 65.i64
    y: x.u8.orPanic
    print "conv=\{y}"
    lit: 65.u8
    print "lit=\{lit}"
}

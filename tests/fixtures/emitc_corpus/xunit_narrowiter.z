HolderData: class {
    items: (List of: u64)
}

LeafData: class {
    v: u64
}

Wrap: union {
    holder: HolderData
    leaf: LeafData
}

mkHolder: function {seed: u64} out Wrap is {
    h: HolderData items: (List of: u64)
    h.items.append 3.u64
    h.items.append 4.u64
    return (Wrap.holder h)
}

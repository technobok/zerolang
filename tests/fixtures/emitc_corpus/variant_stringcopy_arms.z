# variant_stringcopy_arms.z -- arms named `string` and `copy` (the emitter's
# name-gated .string/.copy legs are stamp-gated inside and must fall through
# to the tagged leg), plus a variant NAMED `io` with an arm named `stdout`
# (the io-base name leg must lose to the hoisted dpTaggedParent leg).

io: variant {
    stdout: null
    stderr: null
}

modes: variant {
    string: null
    copy: null
    plain: null
}

main: function is {
    s: io.stdout
    match (
        s
    ) case stdout then {
        print "io stdout arm"
    } else {
        print "io other"
    }
    m: modes.string
    match (
        m
    ) case string then {
        print "modes string arm"
    } else {
        print "modes other"
    }
    c: modes.copy
    match (
        c
    ) case copy then {
        print "modes copy arm"
    } else {
        print "modes other2"
    }
}

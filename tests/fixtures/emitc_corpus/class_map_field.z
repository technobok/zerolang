# class_map_field.z -- a class with a Map field, constructed field-wise. The
# field-wise meta_create takes the Map by POINTER (Maps/Sets are heap pointers);
# emitOneRecord only added `*` for `.lock` fields, so `Store_meta_create(Map_t c)`
# mismatched the `Map_create()`-returns-`Map_t*` argument. Construction +
# scope-exit destruction exercise the Map* param and the Map* field cleanup.
# Mirrors zvfs's StringProvider/FSProvider field-wise construction.

Store: class {
    name:   String
    counts: (Map key: String value: u32)
}

main: function is {
    s: Store name: "store".string counts: (Map key: String value: u32)
    print "name=\{s.name}"
}

Prober: class {
    tag: u32
} as {
    probe: function {:this p: StringView} out u32 is {
        sr: io.stat p
        match (
            sr
        ) case ok then {
            match (
                sr.kind
            ) case file then {
                return 1.u32
            } case dir then {
                return 2.u32
            } case symlink then {
                return 3.u32
            } case other then {
                return 4.u32
            }
        } case err then {
            return 0.u32
        }
    }
}

# A variant-match `else`/default arm that binds an OWNED collection (List u64),
# uses it, and falls through (no return in the arm). The arm-local's destructor
# must emit inside the `default: { }` C block (via flushBlockFrees), not at
# function end where it is out of scope. Mirrors zparser acceptTypeDefinition /
# acceptExpression binding `paths`/`eqOpt` in a match-else arm.
choice: variant {
    a: null
    b: null
}

pick: function {c: choice} out u64 is {
    r: 0.u64
    match (
        c
    ) case a then {
        r = 1.u64
    } else {
        items: (List of: u64)
        items.append 7.u64
        items.append 9.u64
        r = items.length
    }
    return r
}

main: function is {
    x: pick c: choice.a
    y: pick c: choice.b
    print "a=\{x} else=\{y}"
}

# A non-`.take` List param is a borrow-default reftype: appends must persist to
# the caller. By value (the bug) loses them -> length 0; by pointer -> 5.

fillFree: function {dst: (List of: u64)} is {
    dst.append 10.u64
    dst.append 20.u64
}

Tally: class {
    tag: u64
} as {
    create: function {t: u64} out this is {
        return (meta.create tag: t)
    }

    fillMethod: function {:this dst: (List of: u64)} is {
        dst.append 30.u64
        dst.append 40.u64
        dst.append 50.u64
    }
}

main: function is {
    xs: (List of: u64)
    fillFree dst: xs
    b: Tally t: 0.u64
    b.fillMethod dst: xs
    print "\{xs.length}"
}

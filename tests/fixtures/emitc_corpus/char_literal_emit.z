# char_literal_emit.z -- `0c<char>` literals lower to their codepoint in
# the emitted C: comparisons against u8 (free function and method), and
# the typed-suffix forms `0cZ.u8` / `0cA.u32`. Pins the emitter decode
# (the raw lexeme is not a C token).

isUpperA: function {b: u8} out bool is {
    if b == 0cA then return true
    return false
}

Sc: class {
    cur: u8
} as {
    isT: function {:this} out bool is {
        b: this.cur
        if b == 0ct then return true
        return false
    }
}

main: function is {
    r1: (isUpperA b: 65)
    print "cmp fn: \{r1}"
    s: (Sc cur: 116)
    r2: s.isT
    print "cmp method: \{r2}"
    pin: 0cZ.u8
    print "suffix u8: \{pin}"
    wide: 0cA.u32
    print "suffix u32: \{wide}"
}

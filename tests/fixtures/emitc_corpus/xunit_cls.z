Box: class {
    n: u64
} as {
    create: function {v: u64} out this is {
        return (meta.create n: v)
    }

    bump: function {:this} is {
        this.n = this.n + 1.u64
    }

    bumpTwice: function {:this} is {
        this.bump
        this.bump
    }

    value: function {:this} out u64 is {
        return this.n
    }
}

mkBox: function {v: u64} out Box is {
    return (Box v: v)
}

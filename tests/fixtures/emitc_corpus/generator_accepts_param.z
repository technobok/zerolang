# generator_accepts_param.z -- a bidirectional generator (`accepts: Bag.lock`)
# driven with `g.call value: <p>.lock` where p is a Bag PARAM (already a
# pointer). emitUserIterCall emitted &p (a Bag**) for the value arg; a local
# source correctly needs the &.

Bag: class {
    x: i64
}

peek: function {n: i64} out (Iterator gives: i64 accepts: Bag.lock) is {
    yield 1
    b: yield 2
    yield b.x
}

drive: function {p: Bag} out i64 is {
    total: 0
    with g: (peek n: 0) do {
        a: g.call value: p.lock
        b: g.call value: p.lock
        c: g.call value: p.lock
        match (
            c
        ) case some then {
            total = c
        } case none then {}
    }
    return total
}

main: function is {
    bag: Bag x: 42
    r: drive p: bag
    print "r=\{r}"
}

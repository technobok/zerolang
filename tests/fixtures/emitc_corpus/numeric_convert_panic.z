# numeric_convert_panic.z -- `.orPanic` on a lossy conversion that fails aborts
# through z_panic ("zpanic: <msg>" on stderr, exit 1). 300 does not fit i8, so
# the unwrap panics and the trailing print never runs.

main: function is {
    print "before"
    x: 300.i64
    y: x.i8.orPanic
    print "after \{y}"
}

Driver: class {
    tag: u64
} as {
    create: function {t: u64} out this is {
        return (meta.create tag: t)
    }

    # `c` is a plain (borrow-default) cross-unit class param. A method must
    # pass it BY POINTER so the bumps persist to the caller's Counter; a
    # by-value shallow copy would lose them (prints 10 instead of 13).
    run: function {:this c: xunit_method_param_byref.Counter} is {
        c.bump
        c.bump
        c.bump
    }
}

main: function is {
    c: xunit_method_param_byref.mkCounter start: 10.u64
    d: Driver t: 0.u64
    d.run c: c
    print "\{c.value}"
}

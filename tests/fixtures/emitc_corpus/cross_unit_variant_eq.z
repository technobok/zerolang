# A cross-unit variant whose arm carries a record (pt). Comparing two `shape`
# values with `==` makes the emitter generate `shape_eq`, whose `dot` arm must
# call `pt_eq` (a cross-unit record). The arm-payload type lives in the dep unit,
# so the variant _eq generator must resolve it cross-unit (resolveTypeIdByName),
# not via the main+system-only lookupTyperef. Mirrors zvfs `dentry`.
main: function is {
    a: xunit_variant_eq.mkdot x: 1 y: 2
    b: xunit_variant_eq.mkdot x: 1 y: 2
    c: xunit_variant_eq.mkdot x: 9 y: 9
    if a == b then {
        print "ab-eq"
    } else {
        print "ab-neq"
    }
    if a == c then {
        print "ac-eq"
    } else {
        print "ac-neq"
    }
}

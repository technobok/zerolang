# union_take_arg.z -- a union and a by-value class moved with `.take` in ARG
# position (zvfs's `OpenResult.err e.take` and `this.providers.append box.take`).
# `.take` is an ownership MOVE: pass the value, zero the source so its
# scope-exit destructor doesn't double-free the shared heap. The gap-5 move
# machinery was String-only; this generalizes it to any heap reftype.

IErr: union {
    code: i64
    other: i64
}

Res: union {
    okv: i64
    fail: IErr
}

Box: class {
    n: i64
}

main: function is {
    # union `.take` into a union constructor argument
    e: IErr.code 13
    r: Res.fail e.take
    match (
        r
    ) case okv then {
        print "got ok"
    } case fail then {
        print "got fail"
    }

    # by-value class `.take` into a List append argument
    bx: Box n: 7
    xs: (List of: Box)
    xs.append bx.take
    print "len=\{xs.length}"
}

# continue_in_do.z -- `continue` inside a break-carrying block statement (the
# do{}while(0) wrapper) must resume the enclosing LOOP, not just exit the
# wrapper: it jumps to the loop's __zcont label past the wrapper. Covers a
# single wrapper and a nested pair.
main: function is {
    total: 0.u64
    seen: 0.u64
    i: 0.u64
    for i < 6 loop {
        i = i + 1
        {
            if i == 5 then break
            if i == 2 then continue
            seen = seen + 1
        }
        total = total + 1
    }
    print "i=\{i} seen=\{seen} total=\{total}"
    deep: 0.u64
    tail: 0.u64
    j: 0.u64
    for j < 4 loop {
        j = j + 1
        {
            if j == 9 then break
            {
                if j == 9 then break
                if j == 3 then continue
                deep = deep + 1
            }
        }
        tail = tail + 1
    }
    print "j=\{j} deep=\{deep} tail=\{tail}"
}

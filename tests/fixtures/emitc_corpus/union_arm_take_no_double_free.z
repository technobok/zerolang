# Regression: a heap-payload union arm consumed by an owning sink (.take) must
# invalidate the union box, not just a copy of the narrowed payload. Otherwise
# the post-match union destroy double-frees the moved heap buffer. Mirrors
# zparser main's readText -> match ok -> Tokenizer.create source: r.take shape.

Sr: union {
    ok: String
    err: i64
}

Sink: class {
    s: String
} as {
    create: function {s: String.take} out this is {
        return (meta.create s: s)
    }

    val: function {:this} out String is {
        return this.s.copy
    }
}

main: function is {
    r: Sr.ok "payload".string
    match (
        r
    ) case ok then {
        snk: Sink.create s: r.take
        print "got: \{snk.val}"
    } case err then {
        print "err"
    }
}

# variant_payload_order.z -- a variant embeds a record payload BY VALUE (entry ->
# info), and a class field is a variant (Node -> kind). Both are used as collection
# elements, so the emitter pre-emits their structs early (ahead of the normal type
# pass). The embedded record/variant must be emitted FIRST, under the SAME (resolved)
# id the field/arm decl canonicalizes to -- otherwise the struct names an undeclared
# shell-id type and gcc falls back to implicit-int. Mirrors zvfs's `dentry` (record
# arms) + `StringNode.kind` (variant field).

kind: variant {
    dir: null
    file: null
}

info: record {
    a: u32
    b: u32
}

entry: variant {
    empty: null
    full: info
}

Node: class {
    k: kind
    n: u32
}

main: function is {
    es: (List of: entry)
    ns: (List of: Node)
    nd: Node k: kind.dir n: 7
    print "n=\{nd.n} lens=\{es.length},\{ns.length}"
}

# interp_string.z -- a binding to an interpolated-String literal
# (`k: "\{a}:\{b}"`). An interpolated literal is an owned String: the binding
# declares a String local and interpolating String locals reads their data.
# Mirrors zvfs's `childpath: "\{parent_node.path}/\{piece}"`.

main: function is {
    a: "x".string
    b: "y".string
    k: "\{a}:\{b}"
    print "k=\{k}"
}

# A no-arg, collection-returning method called as a bare dotted path in a binding
# RHS must emit the call, not an empty-collection construction. The bug dropped
# `xs: b.makeList` / `s: b.makeSet` / `m: b.makeMap` to an empty `*_create(0)`,
# so the bound collections came out empty (lengths 0 instead of 2/2/1).

Box: class {
    tag: u64
} as {
    create: function {t: u64} out this is {
        return (meta.create tag: t)
    }

    makeList: function {:this} out List String is {
        r: (List String)
        r.append "a".string
        r.append "b".string
        return r
    }

    makeSet: function {:this} out Set String is {
        s: (Set String)
        s.add item: "x".string
        s.add item: "y".string
        return s
    }

    makeMap: function {:this} out (Map String value: u64) is {
        m: (Map String value: u64)
        m.set key: "k".string value: 7.u64
        return m
    }
}

main: function is {
    b: Box t: 0.u64
    xs: b.makeList
    print "\{xs.length}"
    s: b.makeSet
    print "\{s.length}"
    m: b.makeMap
    print "\{m.length}"
}

# generic_copy.z -- `.copy` on a generic-param value inside a template:
# the fn-mono re-walk resolves the bare param through the mono's concrete
# param child. String deep-copies; valtypes (numeric, StringView, record)
# copy bitwise.
point: record {
    x: i64
}

dup: function as { t: Any.generic } in {v: t} out t is {
    return v.copy
}

main: function is {
    n: dup v: 7
    print "int: \{n}"
    s0: "own".string
    s1: dup v: s0
    print "string: \{s1}"
    sv: "view"
    s2: dup v: sv
    print "view: \{s2}"
    p: point x: 3
    q: dup v: p
    print "record: \{q.x}"
}

# shadowkey.z -- Stage-2 id-based identity for Set ELEMENTS and Map KEYS.
# A user value-type String shadows the builtin and is used as a Set element: it
# is hashed/compared by its NATURE (a by-value struct -> byte-range siphash +
# memcmp over contents), NOT as the native String (which would mis-call
# z_siphash_string over the user struct and read absent .data/.size fields). A
# plain POD record is also used as a Map key, proving content hashing of
# by-value structs. Companion to usershadow / shadowcol / shadowmapval.

String: record { code: i64 }

point: record { x: i64 y: i64 }

main: function is {
    s: (Set of: String)
    s.add item: (String code: 5)
    s.add item: (String code: 5)
    s.add item: (String code: 7)
    print "set: \{s.length}"

    m: (Map key: point value: i64)
    m.set key: (point x: 1 y: 2) value: 100
    m.set key: (point x: 3 y: 4) value: 200
    print "map: \{m.length}"
    print "has (1,2): \{m.has key: (point x: 1 y: 2)}"
    print "has (9,9): \{m.has key: (point x: 9 y: 9)}"
}

# discard_owned_result.z -- a statement-position call whose owned destructible
# result is discarded (String / class / union returns) binds the result to a
# temp and destroys it, across all three statement shapes: explicit calls,
# dotted auto-calls, and bare-atom auto-calls. The exclusion is the declared
# signature (funcReturnsBorrow) plus the container element-view rule: a
# discarded List.get is a shallow element view and is NOT destroyed.

C: class {
    v: u64
    tag: String
}

mk: function out String is {
    s: "beta".string
    return s
}

mkc: function out C is {
    return (C v: 1 tag: "boxed".string)
}

main: function is {
    xs: (List String)
    a: "alpha".string
    xs.append a
    xs.get i: 0
    xs.pop
    b: "gamma".string
    xs.append b
    c: "delta".string
    xs.set i: 0 val: c
    mk
    mkc
    n: xs.length
    print "n=\{n}"
    e: xs.get i: 0
    print "e=\{e}"
    print "done"
}

# sv_split_lines.z -- StringView.split / .lines native iterators + .string copy.
# `sv.split sep:` -> Splitter, `sv.lines` -> LinesIter, both driven by the
# user-iterator for-loop (yields borrowed StringView via .call -> Option_StringView);
# piece.string deep-copies the borrowed view into an owned String. Mirrors zvfs.

main: function is {
    s: "a/b/c".string
    sv: s.stringview
    parts: (List of: String)
    with it: (sv.split sep: "/") do for piece: it loop {
        parts.append piece.string
    }
    print "parts=\{parts.length}"
    text: "line1\nline2\nline3".string
    tv: text.stringview
    cnt: 0
    with li: tv.lines do for line: li loop {
        cnt = cnt + 1
    }
    print "lines=\{cnt}"
}

# generator_local_cleanup.z -- EVERY generator-body local promotes to a
# synth-class field (a resumable body has no persistent stack frame): a
# local bound and dropped before any yield, one yielded bare (moved into
# the boxed payload, source zeroed), one used across yields, and one bound
# per loop iteration all clean up through the instance destructor -- no
# fn-exit frees ever run on a fresh frame.

drop: function {base: String.take} out (Iterator gives: u64) is {
    s2: base.copy
    y: s2.length
    yield y
    yield 1
}

give: function {base: String.take} out (Iterator gives: String) is {
    s2: base.copy
    yield s2
    yield base.copy
}

span: function {base: String.take} out (Iterator gives: u64) is {
    s2: base.copy
    yield s2.length
    yield s2.length
}

looped: function {base: String.take n: u64} out (Iterator gives: u64) is {
    i: 0.u64
    for i < n loop {
        t: base.copy
        yield t.length
        i = i + 1
    }
}

main: function is {
    for a: (drop base: "alpha".string) loop print "a=\{a}"
    for s: (give base: "gamma".string) loop print "s=\{s}"
    for b: (span base: "beta".string) loop print "b=\{b}"
    for c: (looped base: "delta".string n: 2) loop print "c=\{c}"
    print "done"
}

addUp: function {x: u64} out u64 is {
    return (x)
}

sumWrap: function {w: xunit_narrowiter.Wrap} out u64 is {
    total: 0.u64
    match (
        w
    ) case holder then {
        it: w.items.iterate
        for x: it loop {
            total = total + (addUp x: x)
        }
    } case leaf then {
        total = w.v
    }
    return total
}

main: function is {
    w: xunit_narrowiter.mkHolder seed: 0.u64
    print "\{sumWrap w: w}"
}

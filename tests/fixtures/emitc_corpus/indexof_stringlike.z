# indexof_stringlike.z -- a generic native with a generic-instance return
# (`out (optionval t: u64)`): the mono's return heals from the return node's
# stamped type, so the binding and the match subject type correctly. The
# String needle is borrowed (stays live after the call).
main: function is {
    sv: "find the needle here"
    n: "needle".string
    io: sv.indexOf needle: n
    match (
        io
    ) case some then {
        print "at \{io}"
    } case none then {
        print "missing"
    }
    mo: sv.indexOf needle: "absent"
    match (
        mo
    ) case some then {
        print "unexpected \{mo}"
    } case none then {
        print "none ok"
    }
    print "n=\{n}"
}

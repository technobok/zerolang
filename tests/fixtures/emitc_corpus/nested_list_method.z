# nested_list_method.z -- a no-arg List method (pop) on a nested receiver
# (this.field), the lexer's statepop pattern (this.statestack.pop). Methods
# with args on a nested receiver already work; the no-arg ones (pop/sort/
# listview) went through the member-access fallback.

Stack: class {
    items: (List of: u64)
} as {
    drop: function {:this} is {
        this.items.pop
    }
}

main: function is {
    s: Stack items: (List of: u64)
    s.items.append from: 5.u64
    s.items.append from: 6.u64
    s.drop
    print "n=\{s.items.length}"
}

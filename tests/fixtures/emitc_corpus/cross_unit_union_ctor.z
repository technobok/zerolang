# cross_unit_union_ctor.z -- constructing another unit's union arm through
# the fully qualified three-segment path (unit.Union.arm payload), with no
# local typedef alias.

main: function is {
    v: (json.Value.intval 7)
    o: json.serialize v: v
    print o
    t: (json.Value.text "qualified".string)
    o2: json.serialize v: t
    print o2
    n: json.Value.nul
    o3: json.serialize v: n
    print o3
}

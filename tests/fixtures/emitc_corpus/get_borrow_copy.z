# get_borrow_copy.z -- element gets are SHARED borrows: many gets and
# readers coexist inside the borrow scope; ownership escapes via `.copy`
# (directly or through a narrowing block), after which the container is
# writable again; valtype elements stay plain owned copies (no lock).
main: function is {
    xs: (List String)
    a: "alpha".string
    xs.append a
    b: "beta".string
    xs.append b
    {
        e1: xs.get i: 0
        e2: xs.get i: 1
        n1: xs.length
        print "e1=\{e1} e2=\{e2} n=\{n1}"
    }
    owned: "".string
    {
        e3: xs.get i: 0
        owned = e3.copy
    }
    xs.append owned
    direct: (xs.get i: 1).copy
    xs.append direct
    n2: xs.length
    {
        last: xs.get i: 3
        print "n=\{n2} last=\{last}"
    }
    ns: (List u64)
    ns.append 7
    v: ns.get i: 0
    ns.append 9
    m: ns.length
    print "v=\{v} m=\{m}"
    print "done"
}

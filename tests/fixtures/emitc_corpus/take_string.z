# take_string.z -- a String moved via `.take` into a constructor that stores it
# in a field, mirroring the lexer's `Tokenizer.create source: r.take`. The move
# passes the value and invalidates the source; the holder's destructor frees the
# moved String exactly once (no double-free, no leak at exit).

Holder: class {
    text: String
}

main: function is {
    r: "hello world".string
    h: Holder text: r.take
    print "len=\{h.text.length}"
}

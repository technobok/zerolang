# variant_create_arm.z -- a variant arm named `create`. `Type.create` is also
# the constructor idiom (children[create] routing); a null-payload arm with
# that name must still resolve and emit as the tag construction.

maker: variant {
    create: null
    fetch: null
}

main: function is {
    k: maker.create
    match (
        k
    ) case create then {
        print "maker create arm"
    } else {
        print "maker fetch"
    }
}

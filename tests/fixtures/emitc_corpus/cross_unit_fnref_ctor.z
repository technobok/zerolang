# Cross-unit function references with .take: constructor argument, plain
# call argument, and a local binding with reassignment.
unop: function {v: u64} out u64

double: function {v: u64} out u64 is {
    return v * 2
}

Proc: class {
    op: function {v: u64} out u64
} as {
    run: function {:this v: u64} out u64 is {
        return (this.op v: v)
    }
}

apply: function {f: unop x: u64} out u64 is {
    return (f v: x)
}

main: function is {
    p: (Proc op: xdep_fnref.fnval.take)
    print "\{p.run v: 41}"
    print "\{apply f: xdep_fnref.fnval.take x: 10}"
    cb: xdep_fnref.fnval.take
    print "\{cb v: 5}"
    cb = double.take
    print "\{cb v: 5}"
}

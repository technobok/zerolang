# shadow_fnptr.z -- a user record shadowing the builtin scalar `i64` used in a
# function-pointer field's signature, called through the field. The fnptr typedef
# and the call use the user struct (the field's canonical id), not the by-name
# system scalar; in a single unit the signature's i64 IS the shadow, resolved by id.

i64: record {
    hi: 0
    lo: 0
}

bump: function {a: i64} out i64 is {
    return (i64 hi: (a.hi + 1) lo: a.lo)
}

Proc: class {
    op: function {a: i64} out i64
}

main: function is {
    p: Proc op: bump.take
    r: p.op a: (i64 hi: 5 lo: 6)
    print "hi=\{r.hi}"
}

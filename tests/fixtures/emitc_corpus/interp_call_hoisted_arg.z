# interp_call_hoisted_arg.z -- a call inside an interpolation whose argument
# is a non-lvalue String rvalue: the arg hoists to an _ah temp whose
# declaration must land in the interp fragment's block (and its free must
# still run for owned rvalues).

consume: function {s: String} out u64 is {
    return s.length
}

main: function is {
    print "empty=\{consume s: String} owned=\{consume s: "xyz".string}"
    n: 4.u64
    print "mixed \{n} \{consume s: "ab".string}"
}

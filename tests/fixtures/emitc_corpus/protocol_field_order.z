# protocol_field_order.z -- a class field is a PROTOCOL (Box.r), and the class is
# used as a collection element, so its struct is pre-emitted early. The protocol's
# fat-ptr struct + vtable typedef must precede it, and the vtable references the
# spec methods' return/param types -- so those must be emitted first too. Mirrors
# zvfs's `ProviderBox.p: ZVfsProvider` (whose methods return a union/variant).

Reader: protocol {
    read: function {:this n: u32} out u32
}

Impl: class {
    base: u32
} as {
    :Reader
    read: function {:this n: u32} out u32 is { return (this.base + n) }
}

Box: class {
    r: Reader
}

main: function is {
    boxes: (List of: Box)
    im: Impl base: 10
    rd: Reader.create from: im.take
    got: rd.read n: 5
    print "got=\{got} boxes=\{boxes.length}"
}

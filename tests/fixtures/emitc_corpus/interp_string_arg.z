# interp_string_arg.z -- interpolated string literals passed DIRECTLY as
# String-method arguments hoist through the arg-temp machinery (the
# bound-first form always worked; the inline form used to emit an
# unhandled-atomstring placeholder).

main: function is {
    buf: "".string
    n: 42
    buf.append "\{n}!"
    f: 2.5
    buf.append " f=\{f}"
    w: "txt"
    buf.append " w=\{w}"
    print buf
}

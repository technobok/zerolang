# shadowmethods.z -- Stage-3 id-based identity for a user String shadow used
# through a METHOD receiver, a by-value PARAM, and a RETURN value. A user value
# type (record) shadows the builtin String; `use` takes it as a param and `make_one`
# returns it. The param must pass BY VALUE (it is a record, not the native heap
# reftype) and the return type must be the user struct -- the name-based borrow
# classifier (isBorrowNativeReftype) and fnSignature return mapping previously
# treated the shadow AS native String (param by-ref / native return type).

String: record {
    n: i64
} as {
    twice: function {s: this} out i64 is {
        return s.n + s.n
    }
}

use: function {s: String} out i64 is {
    return s.twice
}

make_one: function {v: i64} out String is {
    return (String n: v)
}

main: function is {
    a: make_one v: 21
    print "twice: \{a.twice}"
    print "via use: \{use s: a}"
    print "field: \{a.n}"
}

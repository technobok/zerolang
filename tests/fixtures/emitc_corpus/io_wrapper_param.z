# io_wrapper_param.z -- an io wrapper create (`io.BufWriter.create to: <f>.lock`)
# whose lock base f is an io.File PARAM (already a pointer). wrapperCreateArg
# emitted the Writer conformance helper as _create(&f) (a File**); a local
# source correctly needs the &.

useBuf: function {f: io.File} is {
    bw: io.BufWriter.create to: f.lock capacity: 16.u64
    outbuf: Bytes
    outbuf.append from: 104.u8
    bv: ByteView.borrow from: outbuf.listview
    wr: bw.write from: bv
    match (
        wr
    ) case ok then {} case err then {}
    fr: bw.flush
    match (
        fr
    ) case ok then {} case err then {}
}

main: function is {
    w: io.open path: "z_wrap_probe.txt" mode: io.openmode.write
    match (
        w
    ) case ok then {
        useBuf f: w
        print "done"
    } case err then {
        print "open failed"
    }
}

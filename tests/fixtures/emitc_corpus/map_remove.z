# map_remove.z -- Map.remove(key) extracts the OWNED value (Rust-style) and
# deletes the entry: an optionval for a valtype value (inline move), an Option for
# a String/reftype value (heap-boxed move). The key is freed; the value's ownership
# transfers to the caller (no copy, no leak, no double-free).

main: function is {
    a: (Map key: String value: i64)
    a.set key: "x".string value: 5
    ra: a.remove key: "x".string
    match (ra) case some then { print "a=\{ra}" } case none then { print "a=none" }

    b: (Map key: i64 value: String)
    b.set key: 1 value: "hi".string
    rb: b.remove key: 1
    match (rb) case some then { print "b=\{rb}" } case none then { print "b=none" }

    miss: a.remove key: "nope".string
    match (miss) case some then { print "miss=\{miss}" } case none then { print "miss=none" }

    print "lens \{a.length} \{b.length}"
}

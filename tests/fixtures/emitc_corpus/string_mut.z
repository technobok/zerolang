# string_mut.z -- String mutating methods with args + no-arg shrink.
#
# appendByte (native cname String_append_byte) / reserve take an arg and reach
# the call dispatch; shrink is a no-arg method. The compiler's own source builds
# strings byte-by-byte this way (the lexer's appendByte is its dominant pattern).

main: function is {
    s: "".string
    s.appendByte 72.u8
    s.appendByte 105.u8
    s.appendByte 33.u8
    s.reserve 64.u64
    s.shrink
    print "s=\{s.stringview}"
    print "len=\{s.length}"
}

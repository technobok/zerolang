# io_removetree.z -- io.removeTree deletes a nested tree (files, subdirs,
# and symlinks-as-links); a symlink TARGET outside the tree survives.

main: function is {
    base: "/tmp/zrmt_\{os.pid}"
    inner: "\{base.stringview}/a/b"
    io.mkdirp path: inner.stringview
    f1: "\{base.stringview}/top.txt"
    io.writeText path: f1.stringview content: "x"
    f2: "\{inner.stringview}/deep.txt"
    io.writeText path: f2.stringview content: "y"
    outside: "/tmp/zrmt_target_\{os.pid}.txt"
    io.writeText path: outside.stringview content: "keep"
    link: "\{base.stringview}/a/ln"
    io.symlink target: outside.stringview link: link.stringview
    io.removeTree path: base.stringview
    if (io.exists path: base.stringview) == false then print "tree gone"
    if (io.exists path: outside.stringview) then print "target survives"
    io.removeTree path: outside.stringview
}

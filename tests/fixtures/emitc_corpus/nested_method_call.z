# A no-arg method called on a nested `this.<field>` receiver where the field is a
# user class: `this.w.grab`. The emitter's nested-base dotted leg handled String
# and List methods but fell through to a FIELD access for a user CLASS/RECORD
# method (gcc: "widget has no member grab"). Mirrors zlexer Lexer.advance calling
# `this.lexer.token` (Tokenizer method) when compiling zparser.
widget: class {
    v: u32
} as {
    grab: function {:this} out u32 is {
        return this.v
    }
}

frame: class {
    w: widget
} as {
    fetch: function {:this} out u32 is {
        return this.w.grab
    }
}

main: function is {
    f: frame w: (widget v: 42.u32)
    print "v=\{f.fetch}"
}

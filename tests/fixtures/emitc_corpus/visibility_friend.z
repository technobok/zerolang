# Friend forwarding + cross-instance private access. `a` is private (not in the
# `public:` list). The class mints `.private` (peek -> b.private); a friend
# forwards it onward (friendReadA -> h.private); and a Bag method reads another
# Bag instance's private `a` (same-type receiver).
Bag: class { a: i64 count: i64 } as {
    public: unit { :count :peek :addOther }
    peek: function {b: this.lock} out i64 is { return (friendReadA h: b.private) }
    addOther: function {:this other: Bag} out i64 is { return this.a + other.a }
}

friendReadA: function {h: Bag.private.lock} out i64 is { return (friendAgain h: h.private) }
friendAgain: function {h: Bag.private.lock} out i64 is { return h.a }

main: function is {
    b: (Bag a: 42 count: 3)
    c: (Bag a: 8 count: 1)
    print "count=\{b.count}"
    print "peek=\{b.peek}"
    print "sum=\{b.addOther other: c}"
}

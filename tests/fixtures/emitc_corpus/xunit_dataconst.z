codes: data {
    alpha: 65
    beta: 66
}

Picker: class {
    n: u64
} as {
    create: function {start: u64} out this is {
        return (meta.create n: start)
    }

    pick: function {:this which: bool} out u64 is {
        if which then {
            return codes.alpha
        } else {
            return codes.beta
        }
    }
}

mkPicker: function {s: u64} out Picker is {
    return (Picker start: s)
}

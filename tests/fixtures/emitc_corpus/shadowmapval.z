# shadowmapval.z -- a user value-type (record) String shadows the builtin and is
# used as a Map VALUE. The Map stores it by value; get() returns an owned copy via
# a plain struct copy (not the native String's heap deep-copy), and the value is
# freed by the user type's own (id-based) destructor, not z_String_free. Companion
# to usershadow.z (struct fields) and shadowcol.z (List elements). Stage-2.

String: record { n: i64 }

main: function is {
    m: (Map key: i64 value: String)
    m.set key: 1 value: (String n: 9)
    g: m.get key: 1
    match (g) case some then { print "got \{g.n}" } case none then { print "none" }
}

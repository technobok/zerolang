# shadowcol.z -- a user String shadows the native builtin and is used as the
# ELEMENT of a native List. The element's free must use the user String's
# (no-op) destroy, not z_String_free over the user struct; and a user shadow is
# not the native builtin, so the List earns no builtin contains/sort (like any
# user type). Companion to usershadow.z (struct fields). Stage-2 collection slice.

String: class { n: i64 }

main: function is {
    xs: (List String)
    xs.append (String n: 3)
    first: xs.get i: 0
    print "len \{xs.length} first \{first.n}"
}

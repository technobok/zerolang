# cross_unit_fnptr.z -- a user i64 shadow in the MAIN unit using a dep unit
# (xunit_fnptr_sig) whose function-pointer field signature names i64 = the SYSTEM
# scalar (the dep does not shadow). The emitted fnptr typedef in the main unit keeps
# the dep's system i64 (int64_t), NOT re-resolved by name to the main shadow struct:
# the signature type id carries definedInUnit, so typeRefC uses it directly.

i64: record {
    hi: 0
    lo: 0
}

main: function is {
    p: xunit_fnptr_sig.mkProc
    r: p.op a: 5
    print "r=\{r}"
}

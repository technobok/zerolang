# bare_zero_demand_walk.z -- bare zero-inits inside method bodies whose
# owner is first referenced through a dotted base (`Scanner.create`): the
# demand walk of the method bodies must not inherit the dotted-base
# suppression, or the zero-create stamps go missing.

Scanner: class {
    pos: 0.u64
} as {
    create: function {} out this is {
        return (meta.create pos: 0.u64)
    }

    scan: function {:this} out u64 is {
        n: u64
        s: String
        s.append "ab"
        return n + s.length
    }
}

main: function is {
    t: Scanner.create
    print "\{t.scan}"
}

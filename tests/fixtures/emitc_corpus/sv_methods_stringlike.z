# sv_methods_stringlike.z -- the readonly StringView methods take StringLike
# args: an owned String passes with no .stringview projection and is borrowed
# (stays live). Covers bool, optionval, Option, Splitter, and String returns,
# plus the two-type-param forms (replace needle/replacement).
main: function is {
    sv: "alpha beta gamma"
    w: "beta".string
    r: " B \{1}"
    if (sv.contains needle: w) then print "has"
    if (sv.startsWith prefix: "alpha".string) then print "starts"
    if (sv.endsWith suffix: "gamma".string) then print "ends"
    lo: sv.lastIndexOf needle: w
    match (
        lo
    ) case some then {
        print "last \{lo}"
    } case none then {}
    sp: sv.stripPrefix p: "alpha ".string
    match (
        sp
    ) case some then {
        print "stripped \{sp}"
    } case none then {}
    x: sv.replace needle: w replacement: r
    print "\{x}"
    c: sv.concat other: w
    print "\{c}"
    s2: "a::b::c"
    d: "::".string
    with it: (s2.split sep: d) do for part: it loop {
        print "[\{part}]"
    }
    so: s2.splitOnce sep: d
    match (
        so
    ) case some then {
        print "once \{so}"
    } case none then {}
    print "w=\{w} d=\{d}"
}

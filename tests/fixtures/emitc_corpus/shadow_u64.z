# shadow_u64.z -- a user record shadows the builtin scalar `u64`, passed through a
# function param AND return. fnSignature must emit the user struct for both the
# `a: u64` param and the `out u64` return (z_t{N}_u64_t), not `uint64_t` by name,
# so the body's `return a` type-matches. A system u64 param reached via print->io
# (Reader.read `max: u64`) must stay the C scalar: each reference keeps its
# canonical id's nature.

u64: record {
    tag: 0
}

wrap: function {a: u64} out u64 is {
    return a
}

main: function is {
    v: u64 tag: 7
    r: wrap a: v
    print "tag=\{r.tag}"
}

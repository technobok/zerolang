# Regression: an interpolated string literal passed directly as a call argument
# (build + coerce to the parameter's C form + free), across the param-ownership
# matrix and both free-function and instance-method calls. A StringView param
# takes the literal via an explicit `.stringview`; a String param takes the bare
# literal (take = moved/no-free, borrow = by-pointer/freed at block end).
fsv: function {m: StringView} is { print m }
ftk: function {m: String.take} is { print m }
fbr: function {m: String} is { print m.stringview }

Obj: class { tag: i64 } as {
    mv: function {:this tail: StringView} is { print tail }
    mt: function {:this tail: String.take} is { print tail }
}

main: function is {
    n: 5.i64
    fsv m: "fsv=\{n}".stringview
    ftk m: "ftk=\{n}"
    fbr m: "fbr=\{n}"
    o: Obj tag: 0
    o.mv tail: "mv=\{n}".stringview
    o.mt tail: "mt=\{n}"
}

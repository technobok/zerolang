# string_param_mut.z -- a String parameter that the callee MUTATES. A borrow
# String param (the default for a plain `String` param) must pass BY REFERENCE
# so the append persists to the caller, mirroring the lexer's
# `escapeAppend {dst: String}` doing `dst.appendByte`. Passing it by value would
# mutate a copy and the caller's String would stay unchanged.

appendBang: function {dst: String} is {
    dst.appendByte 33.u8
    dst.appendByte 33.u8
}

main: function is {
    s: "hi".string
    appendBang dst: s
    print "len=\{s.length}"
}

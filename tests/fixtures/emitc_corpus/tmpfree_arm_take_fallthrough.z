# A match arm takes a FIELD of the narrowed payload and falls through to
# the post-match cleanup: the union destroy must no-op on the moved-out
# field and still free the rest of the payload.
Pack: class {
    label: String
    weight: u64
}

Wrap: union {
    pack: Pack
    nothing: null
}

main: function is {
    w: Wrap.pack (Pack label: "cargo".string weight: 7)
    got: "".string
    match (
        w
    ) case pack then {
        got = w.label.take
    } case nothing then {}
    print "got=\{got} len=\{got.length}"
}

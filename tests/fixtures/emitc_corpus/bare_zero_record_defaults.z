# bare_zero_record_defaults.z -- bare-name record/class construction fills
# declared defaults (not blind zeroes) and calls a user create.

conf: record {
    retries: 3
    limit: 100
}

Wrap: class {
    n: 0.u32
} as {
    create: function {} out this is {
        return (meta.create n: 7.u32)
    }
}

main: function is {
    c: conf
    print "\{c.retries} \{c.limit}"
    w: Wrap
    print "\{w.n}"
}

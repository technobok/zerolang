# borrow_arg_construct.z -- an inline OWNED union construct passed to a
# BORROW param of a cross-unit function: the hoisted temp's payload box
# must be destroyed at scope exit (leak-gated).

Value: json.Value

main: function is {
    o: json.serialize v: (Value.intval 7)
    print o
    t: json.serialize v: (Value.text "boxed".string)
    print t
}

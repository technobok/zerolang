# list_field_method_get.z -- a (List <cross-unit union>) FIELD read via
# .get inside a class METHOD: collection-kind classification must ride
# the mono's origin name (the graph-independent identity), not an id
# comparison against a by-name-resolved origin tid.

Value: json.Value

Store: class {
    items: (List Value)
} as {
    kindAt: function {:this i: u64} out u64 is {
        v: this.items.get :i
        match (
            v
        ) case intval then {
            return 1
        } else {
            return 0
        }
    }
}

main: function is {
    s: (Store items: (List Value))
    s.items.append (Value.intval 7)
    k: s.kindAt i: 0
    print "k=\{k}"
    s.items.append (Value.text "x".string)
    k2: s.kindAt i: 1
    print "k2=\{k2}"
}

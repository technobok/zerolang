# option_some_positions.z -- `Option.some <val>` in the two positions that the
# zast port exercises but the emitter mishandled: (a) a direct binding RHS, and
# (b) a NESTED constructor argument with a moved aggregate payload. Both must
# resolve the SPECIALIZED Option mono (Option_String) and hoist the heap box to
# a temp with the moved source zeroed -- not the generic `Option` template with
# an inline box (which both picks the wrong mono and double-frees the move).

Holder: class {
    label: String
    opt:   (Option t: String)
}

main: function is {
    o1: (Option.some "direct".string)
    match (
        o1
    ) case some then {
        print "o1 some"
    } case none then {
        print "o1 none"
    }
    s: "moved".string
    h: Holder label: "h".string opt: (Option.some s.take)
    match (
        h.opt
    ) case some then {
        print "h some"
    } case none then {
        print "h none"
    }
}

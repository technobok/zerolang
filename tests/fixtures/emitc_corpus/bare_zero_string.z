# bare_zero_string.z -- bare `String` is the empty owned string; it grows,
# reassigns over a heap value, and passes as a call argument leak-free.

consume: function {s: String} out u64 is {
    return s.length
}

main: function is {
    s: String
    s.append "abc"
    t: String
    print "\{s} \{t.length} \{s.length}"
    u: "owned".string
    u = String
    n: consume s: String
    print "\{u.length} \{n}"
}

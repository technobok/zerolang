# bare_zero_scalar.z -- every numeric scalar constructs zero from its bare name.

main: function is {
    a: u8
    b: u16
    c: u32
    d: u64
    e: i8
    g: i16
    h: i32
    j: i64
    p: f32
    q: f64
    print "\{a} \{b} \{c} \{d} \{e} \{g} \{h} \{j} \{p} \{q}"
    k: i128
    m: u128
    if k == 0 then print "i128 zero"
    if m == 0 then print "u128 zero"
}

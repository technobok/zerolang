# union_basic.z -- a main-unit user UNION (reftype tagged sum): define,
# construct, match, and `.take`. zvfs's OpenResult is this shape. The emitter
# emits generic union monos (Option/Result) and io/os/cli unions, but never a
# main-unit user union -- emitRecordDefsIn has no union path. This exercises the
# whole chain: struct/tag/destructor emission, construction, match, and move.

Res: union {
    ok: i64
    err: String
}

describe: function {r: Res} out String is {
    match (
        r
    ) case ok then {
        return "is-ok".string
    } case err then {
        return "is-err".string
    }
}

main: function is {
    a: Res.ok 42
    print "a: \{describe a}"
    b: Res.err "bad".string
    print "b: \{describe b}"
    c: b.take
    print "c: \{describe c}"
}

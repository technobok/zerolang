# Named-fn-typed class fields: the field is a fn-pointer of that
# function's signature; the constructor argument supplies the reference.
inc: function {v: u64} out u64 is {
    return v + 1
}

Proc: class {
    op: inc
} as {
    run: function {:this v: u64} out u64 is {
        return (this.op v: v)
    }
}

main: function is {
    d: (Proc op: inc.take)
    print "\{d.run v: 1}"
    p: (Proc op: xdep_fnref.fnval.take)
    print "\{p.run v: 41}"
}

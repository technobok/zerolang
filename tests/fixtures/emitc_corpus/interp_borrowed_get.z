# interp_borrowed_get.z -- hoisted borrow-returning call results (element
# gets and their field reads) are shared views: interp parts and call-arg
# hoists append or pass them WITHOUT registering a free -- the MapEntry
# key/value exemption, generalized by the declared signature
# (bindingRhsIsBorrow). Covers: interp of a get, interp of a get's field,
# a get passed to a borrow-String param, and a get's list field passed to
# a borrow-List param; MapEntry interp pins the original exemption.

C: class {
    path: String
    v: u64
}

shout: function {s: String} out u64 is {
    return s.length
}

measure: function {parts: List String} out u64 is {
    return parts.length
}

H: class {
    parts: List String
}

main: function is {
    xs: (List String)
    a: "alpha".string
    xs.append a
    print "e=\{xs.get i: 0}"
    ns: (List C)
    c0: (C path: "root".string v: 1)
    ns.append c0
    print "p=\{(ns.get i: 0).path}"
    n1: shout s: (xs.get i: 0)
    print "n1=\{n1}"
    p: (List String)
    s1: "a".string
    p.append s1
    h: (H parts: p.take)
    hs: (List H)
    hs.append h
    n2: measure parts: (hs.get i: 0).parts
    print "n2=\{n2}"
    m: (Map String value: u64)
    m.set key: "k1".string value: 7
    with it: m.iterateItems do for en: it loop print "k=\{en.key} v=\{en.value}"
    print "done"
}

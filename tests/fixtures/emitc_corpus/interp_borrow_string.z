# A borrowed String param is a pointer in C: interpolating it must read
# ->data/->size. Covers the free-fn and method ptrVars registration paths.
Tagger: class {
    prefix: String
} as {
    tag: function {:this label: String} out String is {
        return "\{this.prefix}:\{label}"
    }
}

wrap: function {bn: String} out String is {
    return "x=\{bn}"
}

main: function is {
    s: "hello".string
    w: wrap bn: s
    print "\{w}"
    t: Tagger prefix: "pre".string
    lbl: "core".string
    r: t.tag label: lbl
    print "\{r}"
}

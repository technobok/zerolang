# protocol_create_take.z -- owned protocol creation from an intermediate binding
# moved with an explicit `.take` (zvfs's `prov: ZVfsProvider.create from:
# np.take` shape). The working owned_protocol example uses a bare `from: f`
# (implicit take); the explicit `.take` form must emit the same owned-protocol
# constructor and invalidate the source.

Reader: protocol {
    read: function {:this b: i64} out i64
}

MyFile: class {
    fd: i64
} as {
    myreader: Reader
    read: function {f: this b: i64} out i64 is {
        return f.fd + b
    }
}

main: function is {
    f: MyFile fd: 10
    r: Reader.create from: f.take
    n: r.read b: 5
    print "owned.read = \{n}"
}

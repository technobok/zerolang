# Do-block break with owned String temps at block scope: the break path
# frees the block's temps before exiting (none-arm), the fall-through
# path frees them at block close after the some-assign, and both free
# inside the block's C scope. One block per path.
main: function is {
    n: {
        pre: "prefix".string
        if pre.length > 3 then { break }
        pre.length
    }
    match (
        n
    ) case some then {
        print "some=\{n}"
    } case none then {
        print "none"
    }
    m: {
        pre2: "ab".string
        if pre2.length > 3 then { break }
        pre2.length
    }
    match (
        m
    ) case some then {
        print "some=\{m}"
    } case none then {
        print "none"
    }
}

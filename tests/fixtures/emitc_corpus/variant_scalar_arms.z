# variant_scalar_arms.z -- variant/union arms named after numeric scalars
# (i8, bool, f64). The typechecker resolves `Type.arm` as a tagged member and
# stamps dpTaggedParent; the emitter's hoisted stamp leg must emit the tag,
# not a numeric C cast (the cast leg once fired on any child named like a
# scalar, clobbering the arm).

numkind: variant {
    i8: null
    bool: null
    other: null
}

wide: union {
    f64: null
    narrow: null
}

main: function is {
    k: numkind.i8
    match (
        k
    ) case i8 then {
        print "arm i8"
    } case bool then {
        print "arm bool"
    } else {
        print "arm other"
    }
    b: numkind.bool
    match (
        b
    ) case bool then {
        print "arm bool2"
    } else {
        print "not bool"
    }
    w: wide.f64
    match (
        w
    ) case f64 then {
        print "wide f64 arm"
    } else {
        print "wide narrow"
    }
}

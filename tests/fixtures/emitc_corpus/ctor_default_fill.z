# ctor_default_fill.z -- record construction omitting a field that carries a
# non-zero default (`y: 42`): the construction site fills the registered default.
# Exercises childDefault population + default rendering; the examples corpus only
# has zero-valued field defaults, which a missing-field zero-init would mask.

point: record {
    x: i64
    y: 42
}

main: function is {
    p: point x: 5
    print "\{p.x},\{p.y}"
}

# shadow_matrix.z -- one program shadows several builtin scalars at once (i32,
# u32, f32), each constructed and field-accessed, with i32 passed through a
# function param + return. Proves the user-shadow C-type gate is name-agnostic:
# the whole scalar family rides one code path (keyed on defined_in_unit, not the
# type name). i64/u64 are covered by shadow_i64 / shadow_u64.

i32: record {
    v: 0
}

u32: record {
    w: 0
}

f32: record {
    p: 0
    q: 0
}

rt32: function {a: i32} out i32 is {
    return a
}

main: function is {
    a: i32 v: 5
    b: u32 w: 9
    c: f32 p: 1 q: 2
    r: rt32 a: a
    print "i32=\{a.v} u32=\{b.w} f32=\{c.p} rt=\{r.v}"
}

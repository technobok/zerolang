E: xunit_union.Expr

main: function is {
    xs: (List of: E)
    s0: xunit_union.mkSum x: 3.u64 y: 4.u64
    xs.append s0
    l0: xunit_union.mkLit code: 9.u64
    xs.append l0
    e: xs.get i: 0.u64
    match (
        e
    ) case sum then {
        print "sum"
    } case lit then {
        print "lit"
    }
}

# strlike_binding.z -- BINDING the bool result of a StringLike-generic
# native (endsWith/startsWith/contains) on both receiver kinds: the
# generic-native method's declared `out bool` must stamp the call node
# so the binding types (used to emit an unhandled-binding placeholder).

main: function is {
    s: "alpha_beta".string
    b1: s.endsWith "beta"
    b2: s.startsWith "nope"
    v: "alpha_beta"
    b3: v.contains "pha_b"
    b4: v.endsWith "alpha"
    print "b1=\{b1} b2=\{b2} b3=\{b3} b4=\{b4}"
}

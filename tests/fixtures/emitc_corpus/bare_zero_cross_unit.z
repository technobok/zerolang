# bare_zero_cross_unit.z -- a unit-qualified bare type name constructs its
# zero value exactly like the in-unit bare form: record defaults fill and
# a class routes through its create.

main: function is {
    c: xunit_zero.Conf
    print "\{c.retries} \{c.limit}"
    t: xunit_zero.Tally
    t.bump
    print "\{t.count}"
}

# shadow_option.z -- a user record shadows the builtin union `Option`, a non-
# scalar builtin the compiler uses pervasively (optional returns, Map.get, ...).
# It is handled by its own canonical id, not its name, so the internal Option
# machinery and the user shadow coexist. A frontier check that the id-based
# identity holds beyond the scalar family.

Option: record {
    x: 0
}

main: function is {
    o: Option x: 5
    print "x=\{o.x}"
}

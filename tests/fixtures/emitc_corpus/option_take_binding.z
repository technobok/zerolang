# option_take_binding.z -- binding a match-narrowed OWNED Option's payload
# via .take: the binding carries the PAYLOAD type (real storage) and the
# option's box zeroes, so the post-match destroy no-ops (heap payload,
# both the fall-through and return-in-arm paths).

Doc: class {
    name: String
}

grab: function {m: (Map String value: Doc)} out String is {
    rem: m.remove key: "k2".string
    match (
        rem
    ) case some then {
        d: rem.take
        return d.name.copy
    } case none then {
        return "none".string
    }
}

main: function is {
    m: (Map String value: Doc)
    m.set key: "k".string value: (Doc name: "heapname".string)
    m.set key: "k2".string value: (Doc name: "second".string)
    rem: m.remove key: "k".string
    match (
        rem
    ) case some then {
        d: rem.take
        dn: d.name.stringview
        print "took \{dn}"
    } case none then {
        print "missing"
    }
    g: grab :m
    print "grabbed \{g.stringview}"
    print "len=\{m.length}"
}

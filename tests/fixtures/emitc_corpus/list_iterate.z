# list_iterate.z -- List.iterate / ListIter for a SIMPLE-atom base, in the
# bind-then-loop shape (`it: xs.iterate` then `for x: it loop`). emitListMono now
# emits ListIter_<T> ({List*; idx} -> OptionView<T> by reference) + List_<T>_iterate;
# the emitExpr List leg dispatches `.iterate` to {List}_iterate(&recv). (A nested
# field base like obj.items.iterate needs the auto-call base to be type-stamped --
# still open.)
main: function is {
    xs: (List of: u32)
    xs.append 10.u32
    xs.append 20.u32
    xs.append 5.u32
    sum: 0.u32
    it: xs.iterate
    for x: it loop {
        sum = sum + x
    }
    print "sum=\{sum}"
}

# xunit_fnptr_sig.z -- dependency unit for cross_unit_fnptr: a class with a
# function-pointer field whose signature names the SYSTEM i64 (no shadow here),
# plus a factory that builds one.

Proc: class {
    op: function {a: i64} out i64
}

addOne: function {a: i64} out i64 is {
    return (a + 1)
}

mkProc: function out Proc is {
    return (Proc op: addOne.take)
}

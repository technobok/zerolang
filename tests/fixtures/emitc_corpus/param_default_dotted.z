# param_default_dotted.z -- a dotted numeric literal as a function-param
# default (`width: 0.u64`) fills correctly when the caller omits it.

pad: function {s: String width: 0.u64} out u64 is {
    return s.length + width
}

base: function {origin: 3.u32 scale: 2.u32} out u32 is {
    return origin * scale
}

main: function is {
    t: "xy".string
    k: pad s: t
    print "\{k}"
    m: pad s: t width: 7
    print "\{m}"
    c: base scale: 5
    print "\{c}"
}

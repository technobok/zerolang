# visibility_units.z -- `public:` restricts a type's interface; excluded members
# (vault's `value`) are private and reachable only through the type's own
# methods. `private:` cannot be redefined (it is always all members).

point: record { x: i64 y: i64 } as {
    public: unit { :x :y }
}

vault: class { value: i64 } as {
    public: unit { :peek }
    peek: function {:this} out i64 is { return this.value }
}

main: function is {
    p: point x: 1 y: 2
    print "x=\{p.x} y=\{p.y}"
    with v: (vault value: 7) do print "peek=\{v.peek}"
}

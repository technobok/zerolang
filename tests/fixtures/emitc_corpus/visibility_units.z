# visibility_units.z -- the `public:` / `private:` unit members (visibility
# declarations) stay declarable; E0037 reserves the marker names for every
# other member form.

point: record { x: i64 y: i64 } as {
    public: unit { :x :y }
}

vault: class { value: i64 } as {
    private: unit { :value }
    peek: function {:this} out i64 is { return this.value }
}

main: function is {
    p: point x: 1 y: 2
    print "x=\{p.x} y=\{p.y}"
    with v: (vault value: 7) do print "peek=\{v.peek}"
}

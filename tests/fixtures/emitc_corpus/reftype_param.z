# reftype_param.z -- a user class passed to a top-level function.
#
# A reftype (class) parameter must pass BY REFERENCE: the function mutates the
# param through a method, and the mutation must persist to the caller. The
# reference passes such a param by pointer; emitting it by value would mutate a
# copy (wrong result) and shallow-copy any heap-owning field (double free).

Counter: class {
    n: i64
} as {
    create: function {start: i64} out this is {
        return (meta.create n: start)
    }
    bump: function {:this by: i64} is {
        this.n = this.n + by
    }
    total: function {:this} out i64 is {
        return this.n
    }
}

advance: function {c: Counter steps: i64} is {
    i: 0
    for i < steps loop {
        c.bump by: 2
        i = i + 1
    }
}

main: function is {
    c: Counter start: 10
    advance c: c steps: 3
    print "total=\{c.total}"
}

# shadow_generator_yield.z -- a user record shadowing the builtin scalar `i64`,
# yielded from a generator and read field-wise in a for-loop. A generator lowers
# to a synth iterator class whose `state` cursor is a system i64; that cursor must
# resolve to the system scalar, NOT the user shadow, so the state machine stays an
# integer (the synth `state` type node is resolved system-scoped by canonical id).
# Independently, the synth `.call` returns an optionval wrapper over the yield type:
# its mono name carries the shadow's canonical id so it cannot collide with a system
# optionval_i64 in monoByName. The loop var is the user struct; x.n reads it.

i64: record {
    n: 0
}

gen: function out (Iterator gives: i64) is {
    yield (i64 n: 10)
    yield (i64 n: 20)
    yield (i64 n: 30)
}

main: function is {
    for x: gen loop {
        print "n: \{x.n}"
    }
    print "done"
}

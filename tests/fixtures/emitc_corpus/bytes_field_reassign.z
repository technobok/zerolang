# bytes_field_reassign.z -- reassigning a collection-typedef class FIELD
# (Bytes = class typedef over List u8) destroys the old value through the
# CHASED underlying mono's destructor, exactly like a Bytes local does.

Holder: class {
    buf: Bytes
} as {
    reset: function {:this} is {
        fresh: Bytes
        this.buf = fresh
    }
}

main: function is {
    ib: Bytes
    h: (Holder buf: ib)
    h.buf.append from: 65.u8
    n1: h.buf.length
    h.reset
    n2: h.buf.length
    h.buf.append from: 66.u8
    n3: h.buf.length
    print "n1=\{n1} n2=\{n2} n3=\{n3}"
}

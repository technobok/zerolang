# os_spawn_list_param.z -- a (List String) PARAM forwarded to os.spawn's
# by-pointer argv, the shape that made emitOsCall emit &argv (a List** where
# List* is expected). A local list needs the &; a reftype/List param already
# arrives as a pointer, so it must be passed directly.

runSpawn: function {argv: List String} out i32 is {
    return (os.spawn :argv cwd: "" outPath: "/dev/null" errPath: "/dev/null" timeoutSecs: 0)
}

main: function is {
    av: (List String)
    av.append from: "/bin/true".string
    code: runSpawn argv: av
    print "code=\{code}"
}

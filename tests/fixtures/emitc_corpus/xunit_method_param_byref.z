Counter: class {
    n: u64
} as {
    create: function {start: u64} out this is {
        return (meta.create n: start)
    }

    bump: function {:this} is {
        this.n = this.n + 1.u64
    }

    value: function {:this} out u64 is {
        return this.n
    }
}

mkCounter: function {start: u64} out Counter is {
    return (Counter start: start)
}

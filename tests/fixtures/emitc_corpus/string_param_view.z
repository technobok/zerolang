# string_param_view.z -- `.stringview` on a borrowed String PARAM (passed by
# pointer) must use `->`, not `.`. The port emitted `(StringView){ text.data,
# text.size }` against a String* param -> "text is a pointer". Mirrors zvfs's
# `runScript {text: String}` doing `sv: text.stringview`.

greet: function {text: String} is {
    sv: text.stringview
    print "len=\{sv.length}"
}

main: function is {
    s: "hello".string
    greet text: s
}

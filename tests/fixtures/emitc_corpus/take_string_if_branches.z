# take_string_if_branches.z -- a String local taken in BOTH arms of an if/else.
# checkIf lacked per-arm take-state restore: the if-arm's take propagated (via
# popTo) into the else arm, which then saw the var as gone and never stamped its
# `.take` use as a String -> the emitter emitted `cp.take` (member access) ->
# "String_t has no member take". restoreTakenArm clears the take between arms so
# the else arm sees `cp` live. Mirrors zvfs StringProvider.addFile (childpath.take
# in the file / dir branches of a `case none` arm).

sink: function {s: String.take} out u64 is {
    return s.length
}

pick: function {cond: bool a: StringView b: StringView} out u64 is {
    cp: "\{a}/\{b}"
    n: 0.u64
    if cond then {
        n = sink s: cp.take
    } else {
        n = sink s: cp.take
    }
    return n
}

main: function is {
    x: pick cond: true a: "u" b: "v"
    y: pick cond: false a: "pp" b: "qq"
    print "x=\{x} y=\{y}"
}

# empty_list.z -- an empty (List of: T) constructed as a value (here a function
# arg). The lexer initializes its state stack this way
# (statestack: (List of: tokstatetype)); the construction must emit the
# collection's create, not an unhandled callee.

takeList: function {xs: (List of: u64)} out u64 is {
    return xs.length
}

main: function is {
    n: takeList xs: (List of: u64)
    print "n=\{n}"
}

LitData: class {
    text: String
    code: u64
}

SumData: class {
    x: u64
    y: u64
}

Expr: union {
    lit: LitData
    sum: SumData
}

mkSum: function {x: u64 y: u64} out Expr is {
    return (Expr.sum (SumData x: x y: y))
}

mkLit: function {code: u64} out Expr is {
    return (Expr.lit (LitData text: "hi".string code: code))
}

# shadow_map_val.z -- a user record shadowing the builtin scalar `i64` used as a
# Map VALUE. Map.get's return wrapper (an optionval over the value) must
# monomorphise over the user shadow, not the same-named system i64. The get-wrapper
# mono name is disambiguated by canonical id so it does not collide with the system
# optionval_i64 in monoByName (which would reuse the system instance, giving the
# wrong `some`-arm type). The matched value's field read (g.hi) hits the user struct.

i64: record {
    hi: 0
    lo: 0
}

main: function is {
    m: (Map key: String value: i64)
    m.set key: "k".string value: (i64 hi: 7 lo: 8)
    g: m.get key: "k".string
    match (g) case some then { print "got \{g.hi}" } case none then { print "none" }
}

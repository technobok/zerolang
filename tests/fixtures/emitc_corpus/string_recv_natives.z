# string_recv_natives.z -- StringLike simple natives on STRING receivers
# in condition position: these used to fall out of the simple-native leg
# (StringView-gated) and emit an unhandled placeholder that evaluated
# FALSE silently -- the worst failure mode. Views pin the same calls.

main: function is {
    s: "prefix_body_suffix".string
    hits: 0
    if s.startsWith "prefix" then hits = hits + 1
    if s.endsWith "suffix" then hits = hits + 1
    if s.contains "body" then hits = hits + 1
    if s.contains "nope" then hits = hits + 100
    v: "prefix_body_suffix"
    if v.startsWith "prefix" then hits = hits + 1
    if v.endsWith "suffix" then hits = hits + 1
    if v.contains "body" then hits = hits + 1
    print "hits=\{hits}"
}

# protocol_field_dispatch.z -- call a method THROUGH a class's protocol-typed
# field (box.r.read), the dispatch case protocol_field_order.z does NOT cover
# (it only reads the field for struct-ordering, never dispatches through it).
# Mirrors zvfs's `prov: ZVfsProvider.create from: np.take` -> `box: ProviderBox
# p: prov` -> `box.p.walk`. The emitter's protocol dispatch keys off the leading
# atom (box, a class) instead of the receiver (box.r, the protocol), so the call
# emits `/*unhandled callee*/0` unless box.r is stamped with the resolved
# protocol type id.

Reader: protocol {
    read: function {:this n: u32} out u32
}

Impl: class {
    base: u32
} as {
    :Reader
    read: function {:this n: u32} out u32 is { return (this.base + n) }
}

Box: class {
    r: Reader
}

main: function is {
    im: Impl base: 10
    prov: Reader.create from: im.take
    box: Box r: prov
    got: box.r.read n: 5
    print "got=\{got}"
}

# shadow_map_key.z -- a user scalar shadow (i64) as a Map key. emitMapMono's KEY_T
# must be the user struct, not the by-name scalar; the key hashes via the POD
# byte-range path. (A scalar-shadow Map VALUE additionally needs the get-mono to
# monomorphize its optionval over the user shadow -- tracked separately.)

i64: record {
    hi: 0
    lo: 0
}

main: function is {
    m: (Map i64 value: StringView)
    m.set key: (i64 hi: 1 lo: 2) value: "v"
    print "size=\{m.length}"
}

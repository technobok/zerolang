# usershadow.z -- a program defines its OWN String and List (shadowing the
# native builtins; resolution is user-precedence) and uses them as struct
# fields on a class with a destructor path. Before id-based type identity the
# field resolved to the native String and the destructor emitted
# z_String_free over the user struct (memory corruption / incompatible-pointer
# build break). Now type identity is a canonical id, so the field is the user
# String and its (no-op) destroy runs. Regression for the type-shell soundness
# bug; the control examples/unions.z (user Result + a String arm) stays green.

String: class { n: i64 }
List: class { n: i64 }
Box: class { s: String  l: List }

main: function is {
    b: Box s: (String n: 5) l: (List n: 7)
    print "box \{b.s.n} \{b.l.n}"
}

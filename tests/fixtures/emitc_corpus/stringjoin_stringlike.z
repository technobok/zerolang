# stringjoin_stringlike.z -- a generic NATIVE free function routes to its
# name interception (z_stringJoin), not a bodyless mono cname. The sep is
# StringLike: an owned String (borrowed, coerced to a view), a view var, or
# a literal all pass.
main: function is {
    xs: (List String)
    xs.append "a".string
    xs.append "b".string
    xs.append "c".string
    ssep: " - ".string
    j: stringJoin parts: xs sep: ssep
    print "\{j}"
    vsep: "+"
    k: stringJoin parts: xs sep: vsep
    print "\{k}"
    l: stringJoin parts: xs sep: ", "
    print "\{l}"
    print "sep=\{ssep}"
}

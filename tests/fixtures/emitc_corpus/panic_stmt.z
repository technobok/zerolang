# panic_stmt.z -- `panic "msg"` as a statement routes through the shared z_panic
# helper: "zpanic: <msg>" on stderr, exit 1. The emitter must emit
# z_panic((const char*)<arg>.data); an unhandled panic falls through and the
# program exits 0 instead (caught here by the exit-code differential). The lexer
# and VFS use this heavily for unrecoverable states.

main: function is {
    print "before panic"
    panic "boom"
}

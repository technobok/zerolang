# io_interp_args.z -- interpolated arguments to io StringLike natives build
# through a hoisted owned temp (freed at the statement flush) and pass as a
# view, in every body context: free function, method (the leg that used to
# emit the unhandled-atomstring marker), and element-get interps. eprintln
# writes stderr (not golden-captured); the run pins compile + leak-free
# execution.

helper: function {tag: StringView n: u64} is {
    io.eprintln "tag=\{tag} n=\{n}"
}

C: class {
    name: String
} as {
    dump: function {:this pad: u64} is {
        io.eprintln "name=\{this.name} pad=\{pad}"
    }
}

main: function is {
    v: "beta"
    io.eprintln "x=\{v}"
    helper tag: "t1" n: 7
    c: C name: "cn".string
    c.dump pad: 1
    xs: (List String)
    a: "el".string
    xs.append a
    io.eprintln "e=\{xs.get i: 0}"
    print "done"
}

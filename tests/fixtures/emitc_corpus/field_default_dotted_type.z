# field_default_dotted_type.z -- a dotted numeric literal default declares
# the SUFFIX type: `value: 4.u64` is a u64 field (u64 C storage and strict
# u64 reads), not the bare-literal i64 default. Pins class + record fields,
# a float suffix, and true unsigned semantics above i64's range.

Gadget: class {
    value: 4.u64
} as {
    twice: function {:this} out u64 is {
        return this.value * 2
    }
}

pointw: record {
    w: 3.u32
}

Meter: class {
    ratio: 2.5.f32
} as {
    doubled: function {:this} out f32 is {
        return this.ratio * 2
    }
}

Big: class {
    top: 0x8000000000000001.u64
} as {
    isHuge: function {:this} out bool is {
        if this.top > 0x7fffffffffffffff.u64 then return true
        return false
    }
}

widen: function {v: u32} out u32 is {
    return v + 1
}

padw: function {width: 7.u64} out u64 is {
    return width
}

main: function is {
    g: Gadget
    print "\{g.twice}"
    p: pointw
    print "\{widen v: p.w}"
    m: Meter
    print "\{m.doubled}"
    b: Big
    if b.isHuge then print "unsigned ok"
    print "\{padw}"
}

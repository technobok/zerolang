# io_stringlike.z -- io path/content params take StringLike args: an owned
# String path and interpolated-String content pass with no projection and
# stay live after the calls.
main: function is {
    p: "/tmp/zl_io_stringlike_fixture.txt".string
    c: "hello io \{42}"
    w: io.writeText path: p content: c
    match (
        w
    ) case ok then {
        print "wrote"
    } case err then {
        print "write failed"
    }
    if (io.exists path: p) then print "exists"
    r: io.readText path: p
    match (
        r
    ) case ok then {
        print "read: \{r}"
    } case err then {
        print "read failed"
    }
    d: io.remove path: p
    match (
        d
    ) case ok then {
        print "removed"
    } case err then {}
    print "p=\{p} c=\{c}"
}

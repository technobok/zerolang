# shadow_variant_eq.z -- a user variant (V) has arms whose payload type is a user
# scalar shadow (i64). The auto-generated V_eq must compare a matching arm payload
# via its _eq (z_t{N}_i64_eq), not the scalar `==`. emitOneVariant keys the
# scalar-vs-struct choice on the payload's canonical id, not its name.

i64: record {
    hi: 0
    lo: 0
}

V: variant {
    a: i64
    b: i64
}

main: function is {
    x: V.a (i64 hi: 1 lo: 2)
    y: V.a (i64 hi: 1 lo: 2)
    if x == y then { print "eq" } else { print "ne" }
}

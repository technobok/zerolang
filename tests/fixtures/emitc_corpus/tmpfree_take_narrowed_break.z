# .take of a match-narrowed union payload followed by break: the taken
# payload survives, the post-switch destroy no-ops on it, and the break
# path frees only the untaken loop temps.
Holder: union {
    text: String
    num: i64
}

main: function is {
    kept: "".string
    i: 0.u64
    for i < 4 loop {
        h: Holder.text "item-\{i}"
        match (
            h
        ) case text then {
            if i == 2 then {
                kept = h.take
                break
            }
        } case num then {}
        i = i + 1
    }
    print "kept=\{kept}"
}

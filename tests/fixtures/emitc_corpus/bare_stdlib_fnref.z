# bare_stdlib_fnref.z -- a `.take` reference to a BODIED stdlib free
# function: stored in an fn-typed slot, passed, and called through.

cleaner: function {victim: StringView} is {
    io.removeTree path: victim
}

runIt: function {f: cleaner target: StringView} is {
    f victim: target
}

main: function is {
    base: "/tmp/zfnref_\{os.pid}"
    io.mkdirp path: base.stringview
    runIt f: io.removeTree.take target: base.stringview
    if (io.exists path: base.stringview) == false then print "ref cleaned"
    g: io.removeTree.take
    base2: "/tmp/zfnref2_\{os.pid}"
    io.mkdirp path: base2.stringview
    g path: base2.stringview
    if (io.exists path: base2.stringview) == false then print "local ref cleaned"
}

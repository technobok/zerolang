# named_arg_order.z -- named call args supplied OUT of declaration order must
# emit to C in PARAMETER order, not call order. Same-typed params make the
# miscompile silent (no gcc error). Covers a free function, a generic function,
# a record constructor, and a protocol method dispatch.

add3: function {a: i64 b: i64 c: i64} out i64 is {
    return (a * 100) + (b * 10) + c
}

gpick: function as {
    t: Any.generic
} in {
    p: t
    q: t
} out t is {
    return p
}

acc: record {
    x: i64
    y: i64
}

Calc: protocol {
    op: function {:this a: i64 b: i64} out i64
}

MyCalc: class {
    base: i64
} as {
    mycalc: Calc
    op: function {f: this a: i64 b: i64} out i64 is {
        return (f.base * 100) + (a * 10) + b
    }
}

usecalc: function {c: Calc} out i64 is {
    return (c.op b: 2 a: 1)
}

main: function is {
    r: add3 c: 3 a: 1 b: 2
    g: gpick q: 20 p: 10
    p: acc y: 7 x: 4
    mc: MyCalc base: 8
    cc: mc.mycalc
    pr: usecalc cc
    print "\{r} \{g} \{p.x} \{p.y} \{pr}"
}

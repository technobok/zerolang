# A StringView native (stripPrefix, returns Option StringView) called on a
# NESTED/projected base `this.text.stringview` INSIDE A CLASS METHOD. Exercises
# both: (1) emitDottedCall dispatching a SV method on a non-atom base, and
# (2) scanNeeds pre-registering the stripPrefix need for a method body (else the
# fragment emits before the method -> implicit declaration). Mirrors zparser
# Parser.stripStringWhitespace `el.text.stringview.stripPrefix`.
holder: class {
    text: String
} as {
    head: function {:this} out u64 is {
        sp: this.text.stringview.stripPrefix p: "hello "
        match (
            sp
        ) case some then {
            return sp.length
        } case none then {
            return 0.u64
        }
    }
}

main: function is {
    h: holder text: "hello world".string
    print "n=\{h.head}"
}

# Regression: `print m` where `m` is a String BORROW parameter.
#
# A borrow String param is emitted as `z_String_t*` and registered in
# ctx.ptrVars (registerReftypeParams for free fns / the method param loop), so the
# atomid String arm of emitPrintArg must emit z_String_print(m) -- passing the
# pointer through. The old code emitted z_String_print(&m), a String**, which
# overruns z_String_print (ASan: stack-buffer-overflow). Owned String values
# (a `.take` param, a plain local) are by-value and still need the `&`.
printBorrow: function {m: String} is { print m }
printOwned: function {m: String.take} is { print m }

main: function is {
    a: "alpha".string
    b: "bravo".string
    print a
    printOwned m: "charlie".string
    printBorrow m: b
    print b
}

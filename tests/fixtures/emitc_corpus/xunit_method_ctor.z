Inner: class {
    k: u64
} as {
    create: function {v: u64} out this is {
        return (meta.create k: v)
    }

    get: function {:this} out u64 is {
        return this.k
    }
}

Maker: class {
    total: u64
} as {
    create: function {start: u64} out this is {
        return (meta.create total: start)
    }

    add: function {:this v: u64} is {
        inner: Inner v: v
        this.total = this.total + inner.get
    }

    sum: function {:this} out u64 is {
        return this.total
    }
}

mkMaker: function {start: u64} out Maker is {
    return (Maker start: start)
}

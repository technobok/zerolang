# sv_count_method.z -- StringView.count reached ONLY through a type-method
# body: the fragment must be registered by the scanNeeds pre-pass (method
# bodies emit after emitNeededNatives, so in-body needsAdd is too late).

Counter: class {
    label: String
} as {
    width: function {:this} out u64 is {
        sv: this.label.stringview
        return sv.count
    }
}

main: function is {
    c: (Counter label: "héllo".string)
    w: c.width
    print "cp=\{w}"
    s: "naïve".string
    w2: s.stringview.count
    print "chain=\{w2}"
    w3: s.count
    print "direct=\{w3}"
}

# bare_all_defaulted_call.z -- a bare reference to an ALL-DEFAULTED function
# auto-calls (the binding takes the return value, defaults filled); the
# explicit labeled call still overrides; `.take` remains the reference form.

base: function {origin: 3.u32 scale: 2.u32} out u32 is {
    return origin * scale
}

other: function {origin: 1.u32 scale: 1.u32} out u32 is {
    return origin + scale
}

applyIt: function {f: other} out u32 is {
    return (f origin: 4 scale: 5)
}

main: function is {
    b: base
    print "\{b}"
    c: base scale: 5
    print "\{c}"
    print "\{base}"
    r: applyIt f: base.take
    print "\{r}"
    d: applyIt
    print "\{d}"
}

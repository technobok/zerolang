# generic_interp.z -- interpolating a generic-param value inside a template:
# the fn-mono re-walk resolves the bare param through the mono's concrete
# param child (numeric, float, StringView, String).
show: function as { t: Any.generic } in {v: t} is {
    print "v=\{v} end"
}

main: function is {
    show v: 7
    show v: 2.5
    sv: "text"
    show v: sv
    s0: "owned".string
    show v: s0
}

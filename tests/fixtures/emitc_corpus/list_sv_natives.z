# list_sv_natives.z -- List StringView generated natives: contains uses
# length+memcmp equality and sort orders lexicographically via the
# StringView cmp (struct == / < are not valid C on views).
main: function is {
    xs: (List StringView)
    xs.append from: "cherry"
    xs.append from: "apple"
    xs.append from: "banana"
    xs.sort
    with it: xs.iterate do for e: it loop print "e=\{e}"
    if (xs.contains item: "apple") then print "has apple"
    if (xs.contains item: "durian") == false then print "no durian"
}

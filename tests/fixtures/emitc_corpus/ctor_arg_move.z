# ctor_arg_move.z -- owned locals flow into class-construction arguments
# inside conditional branches: a .copy arg never invalidates its source
# on the fallthrough path, and a bare move in one branch coexists with a
# .copy on the other.

H: class {
    s: String
    n: u32
}

mkCopy: function {cond: bool} out H is {
    src: "x".string
    if cond then {
        return (H s: src.copy n: 1)
    }
    return (H s: src.copy n: 2)
}

mkMove: function {cond: bool} out H is {
    src: "y".string
    if cond then {
        return (H s: src n: 1)
    }
    return (H s: src.copy n: 2)
}

main: function is {
    a: mkCopy cond: true
    b: mkCopy cond: false
    c: mkMove cond: true
    d: mkMove cond: false
    print "\{a.n}\{a.s} \{b.n}\{b.s} \{c.n}\{c.s} \{d.n}\{d.s}"
}

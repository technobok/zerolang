# Nested loops: inner break and outer continue, owned temps at both
# levels. The inner break frees inner-iteration temps; the outer continue
# frees the outer-iteration temps above the outer loop's marks.
main: function is {
    acc: 0.u64
    i: 0.u64
    for i < 4 loop {
        oi: "outer-\{i}"
        j: 0.u64
        hit: false
        for j < 4 loop {
            ij: "inner-\{i}-\{j}"
            if j == 2 then {
                hit = true
                break
            }
            acc = acc + ij.length
            j = j + 1
        }
        if hit then {
            i = i + 1
            continue
        }
        acc = acc + oi.length
        i = i + 1
    }
    print "acc=\{acc}"
}

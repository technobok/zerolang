# shadow_set_elem.z -- a user scalar shadow (i64) as a Set element. emitSetMono's
# ITEM_T (the element C type, stored + hashed) must be the user struct, not the
# by-name scalar; the element hashes via the POD byte-range path (keyHashKind
# RECORD), like any self-contained value type.

i64: record {
    hi: 0
    lo: 0
}

main: function is {
    s: (Set i64)
    s.add (i64 hi: 1 lo: 2)
    print "size=\{s.length}"
}

# protocol_read_param_buf.z -- a Bytes PARAM passed to a protocol-dispatched
# `read into:` (the io.Reader vtable path), the shape zls's transportRead
# stdio arm hits. A local buffer needs `&`, but a reftype param already
# arrives as a pointer, so the protocol dispatch must not re-address it.

readVia: function {rdr: io.Reader into9: Bytes} out u64 is {
    n9: 0.u64
    rr: rdr.read into: into9 max: 16
    match (
        rr
    ) case ok then {
        n9 = rr
    } case err then {}
    return n9
}

main: function is {
    p9: "protoread_probe.dat"
    {
        wf: io.open path: p9 mode: io.openmode.write
        match (
            wf
        ) case ok then {
            data9: Bytes
            data9.append from: 122.u8
            data9.append from: 108.u8
            data9.append from: 115.u8
            bv9: ByteView.borrow from: data9.listview
            ww: wf.write from: bv9
            match (
                ww
            ) case ok then {} case err then {}
        } case err then {
            print "open-write failed"
        }
    }
    rf: io.open path: p9 mode: io.openmode.read
    match (
        rf
    ) case ok then {
        buf: Bytes
        got9: readVia rdr: rf into9: buf
        print "got=\{got9}"
        b0: buf.get i: 0
        print "first=\{b0}"
    } case err then {
        print "open-read failed"
    }
    print "done"
}

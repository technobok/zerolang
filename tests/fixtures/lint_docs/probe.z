# A point in 2D space.
Point: class {
    # the horizontal coordinate
    x: i64
    y: i64  # the vertical coordinate
    z: i64
} as {
    # Sum of the coordinates.
    sum: function {:this} out i64 is {
        return (this.x + this.y) + this.z
    }
    prod: function {:this factor: i64} out i64 is {
        return this.x * factor
    }
}

gap: function {
    # the base value
    base: i64
    delta: i64
} out i64 is {
    return base + delta
}

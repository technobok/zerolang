# Compute the area of a rectangle.
areaOf: function {w: i64 h: i64} out i64 is { return (w * h) }

# a private helper -- documented for readers, but not part of the public
# interface, so `zl lint --docs` does not require it.
bump: function {n: i64} out i64 is { return (n + 1) }

secretUndocumented: function {n: i64} out i64 is { return (n - 1) }

public: unit { :areaOf }

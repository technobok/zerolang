# doctl.z -- minimal do-block (library module, like mathutil/ifctl/forctl).
# Isolates the do body-walk: the "block" scope + its value. No break, no calls.

doval: function {n: i64} out i64 is {
    {
        n
    }
    return n
}

main: function is {
    print "doval 5 = \{doval n: 5}"
    print "doval 0 = \{doval n: 0}"
}

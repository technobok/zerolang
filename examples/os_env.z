# os_env.z -- env mutation and enumeration primitives.
#
# Exercises os.set_env / os.unset_env (fallible, `result(null, ioerror)`)
# and os.env_names (infallible, owned list of keys).

main: function is {
    # Set a known-unique key so the test is hermetic.
    sr: os.setEnv key: "Z_OS_ENV_DEMO" value: "hello"
    match (
        sr
    ) case ok then {
        print "set ok"
    } case err then {
        print "set err"
    }

    # Read it back.
    ev: os.env key: "Z_OS_ENV_DEMO"
    match (
        ev
    ) case some then {
        print "read ok"
    } case none then {
        print "read miss"
    }

    # Enumerate: count is always >= 1 because we just set one.
    names: os.envNames
    has: names.length > 0
    print "names nonempty=\{has}"

    # Unset and verify.
    ur: os.unsetEnv key: "Z_OS_ENV_DEMO"
    match (
        ur
    ) case ok then {
        print "unset ok"
    } case err then {
        print "unset err"
    }

    ev2: os.env key: "Z_OS_ENV_DEMO"
    match (
        ev2
    ) case some then {
        print "still set"
    } case none then {
        print "gone"
    }
}

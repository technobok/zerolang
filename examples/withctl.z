# withctl.z -- minimal with-binding (library module, like ifctl/forctl/doctl).
# Isolates the with body-walk: the with scope + its bound alias variable. The
# do-block body yields a value (no return) so the types stay simple.

withval: function {n: i64} out i64 is {
    with y: n do {
        y
    }
}

main: function is {
    print "withval 7 = \{withval n: 7}"
    print "withval -3 = \{withval n: -3}"
}

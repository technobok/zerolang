# char_types.z -- c8 / c32 character types (backed by u8 / u32) and their
# conversions to and from the integer types.

main: function is {
    a: 0cA.c32
    print "\{a}"
    z: 0cz.c8
    print "\{z}"
    w: 65.c8
    x: w.c32
    print "\{x}"
    emoji: 0x1F600.c32
    print "\{emoji}"
    b: 200.u8
    c: b.c8
    d: c.u32
    print "\{d}"
}

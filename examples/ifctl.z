# ifctl.z -- minimal if/then/else control flow (library module, like mathutil).
# Isolates the if body-walk: condition binop, braced branch blocks, branch
# divergence. No main, no calls, no literals.

chk: function {n: i64 lo: i64} out i64 is {
    if n < lo then {
        return lo
    } else {
        return n
    }
}

# callctl.z -- minimal user-function call (library, like ifctl/asgn).
# Isolates the CALL scope a regular user call pushes (vs the generic print
# which returns early), and the call's result type.

inc: function {n: i64} out i64 is {
    return n
}

useInc: function {n: i64} out i64 is {
    return (inc n)
}

# listview.z - generic read-only view into a list

main: function is {
    nums: (List of: i64)
    nums.append from: 10
    nums.append from: 20
    nums.append from: 30
    nums.append from: 40

    # Create a view into the list (zero-cost cast)
    v: nums.listview
    print "listview length: \{v.length}"
    print "first: \{v.get i: 0}"
    print "second: \{v.get i: 1}"
    print "last: \{v.get i: 3}"
}

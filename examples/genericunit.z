# genericunit.z - Generic unit demonstration

# A generic unit parameterized by type 't'
mathops: unit as {
  t: any.generic
  add: function {a: t b: t} out t is { return a + b }
  double: function {v: t} out t is { return v + v }
}

main: function is {
  # instantiate with i64
  intmath: (mathops t: i64)
  print "add: \{intmath.add a: 3 b: 5}"
  print "double: \{intmath.double 21}"

  # instantiate with i32
  i32math: (mathops t: i32)
  print "i32 add: \{i32math.add a: 10.i32 b: 20.i32}"
}

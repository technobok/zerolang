# strview.z - Demonstrates the stringview type

main: function is {
    s: "hello world"

    # create stringview from string
    sv: s.toview
    print sv

    # stringview length
    print "\{sv.length}"

    # convert stringview back to string
    copy: sv.string
    print copy

    # string length
    print "\{s.length}"

    # stringview in interpolation
    print "view says: \{sv}"
}

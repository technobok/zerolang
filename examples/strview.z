# strview.z - Demonstrates stringview and mutable string operations

main: function is {
    s: "hello".string
    s.append " world"
    print s
    print "\{s.length}"

    # reserve and shrink
    s.reserve 100u64
    print "\{s.capacity}"
    s.shrink
    print "\{s.capacity}"

    # stringview from string
    sv: s.toview
    print sv
    print "\{sv.length}"

    # convert back
    copy: sv.string
    print copy
}

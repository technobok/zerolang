# int128_print.z -- 128-bit integers print their full decimal value
# (beyond what a 64-bit snprintf cast could carry)

main: function is {
    big: 18446744073709551615.u64
    w: big.u128
    x: (w * 1000) + 7
    bigi: 9223372036854775807.i64
    ni: bigi.i128 * (0 - 1000)
    zero: u128
    print "\{x}"
    print "\{ni}"
    print "\{zero}"
}

# fibonacci.z -- Fibonacci sequence
# v1 target: loops, integer arithmetic, functions, assignments

fib: function {n: i64} out i64 is {
    if n < 2 then return n

    a: 0
    b: 1
    i: 2
    for while i <= n loop {
        temp: a + b
        a = b
        b = temp
        i = i + 1
    }
    return b
}

main: function is {
    for i: 0 while i < 10 loop {
        print "fib(\{i}) = \{fib i}"
        i = i + 1
    }
}

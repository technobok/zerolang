# float_mod.z -- the % operator on every float width routes through the
# C fmod family (C's % is integer-only).

main: function is {
    a: 7.5
    b: a % 2.0
    print "\{b}"
    c: 7.5.f32
    d: c % 2.0
    print "\{d}"
    h: 7.5.f16
    i: h % 2.0
    print "\{i}"
    q: 7.5.f128
    r: q % 2.0
    print "\{r}"
    n: 0.0 - 7.5
    m: n % 2.0
    print "\{m}"
}

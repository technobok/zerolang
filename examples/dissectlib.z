# dissectlib.z -- a generic file unit (no main) whose exported function
# dissects on the unit's type parameter. Instantiated by dissectuse.z.

t: Any.generic

describe: function {} out StringView is {
    match t case i32 then {
        return "i32"
    } case i64 then {
        return "i64"
    } else {
        return "other"
    }
}

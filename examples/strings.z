# strings.z -- String interpolation and literals
# v1 target: string types, interpolation, raw strings

main: function is {
    name: "Zero"
    version: 1

    print "Welcome to \{name} v\{version}"

    greeting: "Hello, \{name}!"
    print greeting

    # raw string (no interpolation)
    raw: """This is a raw string with \n no escape processing"""
    print raw

    # multiline string
    multi: "
        This is a
        multiline string
        "
    print multi
}

# genericfileunit.z - Generic file unit demonstration
# The 'genmath' file unit is generic (parameterized by type 't')

# instantiate at unit level
intmath: (genmath t: i64)
i32math: (genmath t: i32)

main: function is {
  print "add: \{intmath.add a: 3 b: 5}"
  print "double: \{intmath.double 21}"
  print "i32 add: \{i32math.add a: 10.i32 b: 20.i32}"
}

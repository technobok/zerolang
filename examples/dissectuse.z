# dissectuse.z -- instantiate the generic file unit dissectlib at two concrete
# types; each `describe` mono keeps only its matching arm (compile-time
# dissection of a file unit's type parameter).

ints: (dissectlib t: i64)
i32s: (dissectlib t: i32)

main: function is {
    print "int = \{ints.describe}"
    print "i32 = \{i32s.describe}"
}

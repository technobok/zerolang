# Regression: `print` accepts a String, an inline `.stringview` projection, and
# a bound StringView. The inline projection (`print s.stringview`) previously
# emitted nothing (the emitter's print arg dispatch had no dotted-path case).
main: function is {
    s: "alpha".string
    print s
    print s.stringview
    v: s.stringview
    print v
}

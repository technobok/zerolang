# factorial.z -- Factorial via recursion
# v1 target: recursion, return values, if/else expressions

factorial: function {n: i64} out i64 is {
    if n <= 1 then return 1
    return n * (factorial n - 1)
}

main: function is {
    for i: 0 while i <= 12 loop {
        print "\{i}! = \{factorial i}"
        i = i + 1
    }
}

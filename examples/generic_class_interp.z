# generic_class_interp.z - interpolation and .copy of param-typed members
# inside generic class method bodies (per-mono side stamps)
Box: class {
    val: t
    describe: function {:this} out String is {
        return "v=\{this.val}"
    }
    dup: function {:this} out t is {
        return this.val.copy
    }
} as { t: Any.generic }

main: function is {
    b: Box val: 7
    print (b.describe)
    print "dup: \{b.dup}"
    s: Box val: "hey".string
    print (s.describe)
}
